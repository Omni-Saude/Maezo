<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_IdentityRegistration"
                  targetNamespace="http://cib7.health/patient/registration"
                  exporter="Claude Code"
                  exporterVersion="1.0">

  <bpmn:process id="Process_IdentityRegistration" name="SP-PA-003 Identity Registration" isExecutable="true">

    <!-- Start Event: New Patient Signal -->
    <bpmn:startEvent id="Start_NewPatient" name="New Patient">
      <bpmn:signalEventDefinition signalRef="Signal_NewPatient"/>
      <bpmn:outgoing>Flow_ToCreateRecord</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Task 1: Create Patient Record -->
    <bpmn:serviceTask id="Task_CreatePatientRecord" name="Create Patient Record"
                      camunda:type="external" camunda:topic="patient.create_patient_record">
      <bpmn:incoming>Flow_ToCreateRecord</bpmn:incoming>
      <bpmn:outgoing>Flow_ToAssignMRN</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Task 2: Assign Medical Record Number -->
    <bpmn:serviceTask id="Task_AssignMRN" name="Assign Medical Record Number"
                      camunda:type="external" camunda:topic="patient.assign_medical_record_number">
      <bpmn:incoming>Flow_ToAssignMRN</bpmn:incoming>
      <bpmn:outgoing>Flow_ToBusinessRule</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Business Rule Task: Coding Rules -->
    <bpmn:businessRuleTask id="Task_CodingRules" name="Apply Coding Rules"
                           camunda:decisionRef="auth_coding_002"
                           camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>Flow_ToBusinessRule</bpmn:incoming>
      <bpmn:outgoing>Flow_ToGateway</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <!-- Gateway: Has Dependent? -->
    <bpmn:exclusiveGateway id="Gateway_HasDependent" name="Has Dependent?">
      <bpmn:incoming>Flow_ToGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_WithDependent</bpmn:outgoing>
      <bpmn:outgoing>Flow_NoDependent</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Task 3: Register Dependent -->
    <bpmn:serviceTask id="Task_RegisterDependent" name="Register Dependent"
                      camunda:type="external" camunda:topic="patient.register_dependent">
      <bpmn:incoming>Flow_WithDependent</bpmn:incoming>
      <bpmn:outgoing>Flow_ToMerge</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Merge Gateway -->
    <bpmn:exclusiveGateway id="Gateway_Merge" name="Merge">
      <bpmn:incoming>Flow_ToMerge</bpmn:incoming>
      <bpmn:incoming>Flow_NoDependent</bpmn:incoming>
      <bpmn:outgoing>Flow_ToUpdateRegistry</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Task 4: Update Patient Registry -->
    <bpmn:serviceTask id="Task_UpdatePatientRegistry" name="Update Patient Registry"
                      camunda:type="external" camunda:topic="patient.update_patient_registry">
      <bpmn:incoming>Flow_ToUpdateRegistry</bpmn:incoming>
      <bpmn:outgoing>Flow_ToGenerateCard</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Task 5: Generate Patient Card -->
    <bpmn:serviceTask id="Task_GeneratePatientCard" name="Generate Patient Card"
                      camunda:type="external" camunda:topic="patient.generate_patient_card">
      <bpmn:incoming>Flow_ToGenerateCard</bpmn:incoming>
      <bpmn:outgoing>Flow_ToNotify</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Task 6: Notify Registration Complete -->
    <bpmn:serviceTask id="Task_NotifyRegistrationComplete" name="Notify Registration Complete"
                      camunda:type="external" camunda:topic="patient.notify_registration_complete">
      <bpmn:incoming>Flow_ToNotify</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEnd</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- End Event -->
    <bpmn:endEvent id="End_RegistrationComplete" name="Registration Complete">
      <bpmn:incoming>Flow_ToEnd</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="Flow_ToCreateRecord" sourceRef="Start_NewPatient" targetRef="Task_CreatePatientRecord"/>
    <bpmn:sequenceFlow id="Flow_ToAssignMRN" sourceRef="Task_CreatePatientRecord" targetRef="Task_AssignMRN"/>
    <bpmn:sequenceFlow id="Flow_ToBusinessRule" sourceRef="Task_AssignMRN" targetRef="Task_CodingRules"/>
    <bpmn:sequenceFlow id="Flow_ToGateway" sourceRef="Task_CodingRules" targetRef="Gateway_HasDependent"/>
    <bpmn:sequenceFlow id="Flow_WithDependent" sourceRef="Gateway_HasDependent" targetRef="Task_RegisterDependent">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${has_dependent == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NoDependent" sourceRef="Gateway_HasDependent" targetRef="Gateway_Merge">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${has_dependent == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ToMerge" sourceRef="Task_RegisterDependent" targetRef="Gateway_Merge"/>
    <bpmn:sequenceFlow id="Flow_ToUpdateRegistry" sourceRef="Gateway_Merge" targetRef="Task_UpdatePatientRegistry"/>
    <bpmn:sequenceFlow id="Flow_ToGenerateCard" sourceRef="Task_UpdatePatientRegistry" targetRef="Task_GeneratePatientCard"/>
    <bpmn:sequenceFlow id="Flow_ToNotify" sourceRef="Task_GeneratePatientCard" targetRef="Task_NotifyRegistrationComplete"/>
    <bpmn:sequenceFlow id="Flow_ToEnd" sourceRef="Task_NotifyRegistrationComplete" targetRef="End_RegistrationComplete"/>

  </bpmn:process>

  <!-- Signal Definition -->
  <bpmn:signal id="Signal_NewPatient" name="NewPatientSignal"/>

  <!-- Diagram Interchange -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_IdentityRegistration">
    <bpmndi:BPMNPlane id="BPMNPlane_IdentityRegistration" bpmnElement="Process_IdentityRegistration">

      <!-- Start Event -->
      <bpmndi:BPMNShape id="Shape_Start_NewPatient" bpmnElement="Start_NewPatient">
        <dc:Bounds x="152" y="102" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="138" y="145" width="64" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Create Patient Record -->
      <bpmndi:BPMNShape id="Shape_Task_CreatePatientRecord" bpmnElement="Task_CreatePatientRecord">
        <dc:Bounds x="240" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- Assign MRN -->
      <bpmndi:BPMNShape id="Shape_Task_AssignMRN" bpmnElement="Task_AssignMRN">
        <dc:Bounds x="390" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- Coding Rules -->
      <bpmndi:BPMNShape id="Shape_Task_CodingRules" bpmnElement="Task_CodingRules">
        <dc:Bounds x="540" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- Has Dependent Gateway -->
      <bpmndi:BPMNShape id="Shape_Gateway_HasDependent" bpmnElement="Gateway_HasDependent" isMarkerVisible="true">
        <dc:Bounds x="695" y="95" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="676" y="152" width="88" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Register Dependent -->
      <bpmndi:BPMNShape id="Shape_Task_RegisterDependent" bpmnElement="Task_RegisterDependent">
        <dc:Bounds x="800" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- Merge Gateway -->
      <bpmndi:BPMNShape id="Shape_Gateway_Merge" bpmnElement="Gateway_Merge" isMarkerVisible="true">
        <dc:Bounds x="955" y="95" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="963" y="152" width="34" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Update Patient Registry -->
      <bpmndi:BPMNShape id="Shape_Task_UpdatePatientRegistry" bpmnElement="Task_UpdatePatientRegistry">
        <dc:Bounds x="1060" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- Generate Patient Card -->
      <bpmndi:BPMNShape id="Shape_Task_GeneratePatientCard" bpmnElement="Task_GeneratePatientCard">
        <dc:Bounds x="1210" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- Notify Registration Complete -->
      <bpmndi:BPMNShape id="Shape_Task_NotifyRegistrationComplete" bpmnElement="Task_NotifyRegistrationComplete">
        <dc:Bounds x="1360" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- End Event -->
      <bpmndi:BPMNShape id="Shape_End_RegistrationComplete" bpmnElement="End_RegistrationComplete">
        <dc:Bounds x="1522" y="102" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1500" y="145" width="80" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Sequence Flow Edges -->
      <bpmndi:BPMNEdge id="Edge_Flow_ToCreateRecord" bpmnElement="Flow_ToCreateRecord">
        <di:waypoint x="188" y="120"/>
        <di:waypoint x="240" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Flow_ToAssignMRN" bpmnElement="Flow_ToAssignMRN">
        <di:waypoint x="340" y="120"/>
        <di:waypoint x="390" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Flow_ToBusinessRule" bpmnElement="Flow_ToBusinessRule">
        <di:waypoint x="490" y="120"/>
        <di:waypoint x="540" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Flow_ToGateway" bpmnElement="Flow_ToGateway">
        <di:waypoint x="640" y="120"/>
        <di:waypoint x="695" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Flow_WithDependent" bpmnElement="Flow_WithDependent">
        <di:waypoint x="745" y="120"/>
        <di:waypoint x="800" y="120"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="750" y="102" width="45" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Flow_NoDependent" bpmnElement="Flow_NoDependent">
        <di:waypoint x="720" y="145"/>
        <di:waypoint x="720" y="220"/>
        <di:waypoint x="980" y="220"/>
        <di:waypoint x="980" y="145"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="740" y="202" width="60" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Flow_ToMerge" bpmnElement="Flow_ToMerge">
        <di:waypoint x="900" y="120"/>
        <di:waypoint x="955" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Flow_ToUpdateRegistry" bpmnElement="Flow_ToUpdateRegistry">
        <di:waypoint x="1005" y="120"/>
        <di:waypoint x="1060" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Flow_ToGenerateCard" bpmnElement="Flow_ToGenerateCard">
        <di:waypoint x="1160" y="120"/>
        <di:waypoint x="1210" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Flow_ToNotify" bpmnElement="Flow_ToNotify">
        <di:waypoint x="1310" y="120"/>
        <di:waypoint x="1360" y="120"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Flow_ToEnd" bpmnElement="Flow_ToEnd">
        <di:waypoint x="1460" y="120"/>
        <di:waypoint x="1522" y="120"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
