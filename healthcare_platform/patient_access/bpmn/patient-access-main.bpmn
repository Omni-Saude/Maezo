<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_patient_access_main"
                  targetNamespace="http://cib7.healthcare/patient-access"
                  exporter="CIB Seven 2.1.3"
                  exporterVersion="1.0">

  <!-- Error Definitions -->
  <bpmn:error id="Error_PatientAccess" name="PATIENT_ACCESS_ERROR" errorCode="PA_ERROR"/>

  <!-- Message Definitions -->
  <bpmn:message id="msg_patient_contact" name="msg_patient_contact"/>
  <bpmn:message id="msg_patient_ready_for_care" name="msg_patient_ready_for_care"/>
  <bpmn:message id="msg_encounter_created" name="msg_encounter_created"/>
  <bpmn:message id="msg_clearance_approved" name="msg_clearance_approved"/>
  <bpmn:message id="msg_patient_admitted" name="msg_patient_admitted"/>
  <bpmn:message id="msg_authorization_denied" name="msg_authorization_denied"/>

  <!-- Main Patient Access Orchestrator Process -->
  <bpmn:process id="patient_access_main" name="Patient Access Orchestrator" isExecutable="true">

    <!-- Start Event: Patient Contact -->
    <bpmn:startEvent id="start_patient_contact" name="Patient Contact Received">
      <bpmn:outgoing>flow_to_demand_capture</bpmn:outgoing>
      <bpmn:messageEventDefinition id="msgDef_start" messageRef="msg_patient_contact"/>
    </bpmn:startEvent>

    <!-- Call Activity: SP-PA-001 Demand Capture -->
    <bpmn:callActivity id="call_SP_PA_001" name="Capturar Demanda e Qualificar Acesso" calledElement="SP_PA_001_Demand_Capture">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="demandChannel" target="demandChannel"/>
        <camunda:in source="patientFhirId" target="patientFhirId"/>
        <camunda:out source="demandQualified" target="demandQualified"/>
        <camunda:out source="appointmentNeeded" target="appointmentNeeded"/>
        <camunda:out source="serviceType" target="serviceType"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_demand_capture</bpmn:incoming>
      <bpmn:outgoing>flow_to_appointment_check</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Error Boundary Event: SP-PA-001 -->
    <bpmn:boundaryEvent id="error_SP_PA_001" name="Demand Capture Error" attachedToRef="call_SP_PA_001">
      <bpmn:outgoing>flow_to_error_handler_001</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_PA_001" errorRef="Error_PatientAccess"/>
    </bpmn:boundaryEvent>

    <!-- Exclusive Gateway: Appointment Needed? -->
    <bpmn:exclusiveGateway id="gateway_appointment_needed" name="Appointment needed?">
      <bpmn:incoming>flow_to_appointment_check</bpmn:incoming>
      <bpmn:outgoing>flow_to_scheduling</bpmn:outgoing>
      <bpmn:outgoing>flow_to_identity_direct</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Call Activity: SP-PA-002 Scheduling & Capacity -->
    <bpmn:callActivity id="call_SP_PA_002" name="Orquestrar Agendamento e Capacidade" calledElement="SP_PA_002_Scheduling_Capacity">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="patientFhirId" target="patientFhirId"/>
        <camunda:in source="serviceType" target="serviceType"/>
        <camunda:in source="demandQualified" target="demandQualified"/>
        <camunda:out source="appointmentFhirId" target="appointmentFhirId"/>
        <camunda:out source="scheduledDateTime" target="scheduledDateTime"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_scheduling</bpmn:incoming>
      <bpmn:outgoing>flow_from_scheduling</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Error Boundary Event: SP-PA-002 -->
    <bpmn:boundaryEvent id="error_SP_PA_002" name="Scheduling Error" attachedToRef="call_SP_PA_002">
      <bpmn:outgoing>flow_to_error_handler_002</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_PA_002" errorRef="Error_PatientAccess"/>
    </bpmn:boundaryEvent>

    <!-- MSG-004: AuthorizationDenied catch (non-interrupting) - triggers rescheduling -->
    <bpmn:boundaryEvent id="catch_authorization_denied" name="Authorization Denied" cancelActivity="false" attachedToRef="call_SP_PA_002">
      <bpmn:outgoing>flow_auth_denied_to_reschedule</bpmn:outgoing>
      <bpmn:messageEventDefinition id="msgDef_auth_denied" messageRef="msg_authorization_denied"/>
    </bpmn:boundaryEvent>

    <!-- Service Task: Handle Authorization Denial Rescheduling -->
    <bpmn:serviceTask id="task_handle_auth_denial" name="Reschedule Due to Authorization Denial" camunda:class="com.cib7.healthcare.delegates.AuthDenialRescheduleDelegate">
      <bpmn:incoming>flow_auth_denied_to_reschedule</bpmn:incoming>
      <bpmn:outgoing>flow_auth_denial_handled</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- End Event: Authorization Denial Handled -->
    <bpmn:endEvent id="end_auth_denial_handled" name="Rescheduled (Auth Denied)">
      <bpmn:incoming>flow_auth_denial_handled</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Exclusive Gateway: Merge after scheduling decision -->
    <bpmn:exclusiveGateway id="gateway_scheduling_merge" name="Merge">
      <bpmn:incoming>flow_from_scheduling</bpmn:incoming>
      <bpmn:incoming>flow_to_identity_direct</bpmn:incoming>
      <bpmn:outgoing>flow_to_identity</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Call Activity: SP-PA-003 Identity & Registration -->
    <bpmn:callActivity id="call_SP_PA_003" name="Verificar Identidade e Registrar Paciente" calledElement="SP_PA_003_Identity_Registration">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="patientFhirId" target="patientFhirId"/>
        <camunda:in source="demandChannel" target="demandChannel"/>
        <camunda:out source="patientVerified" target="patientVerified"/>
        <camunda:out source="patientFhirId" target="patientFhirId"/>
        <camunda:out source="coverageFhirId" target="coverageFhirId"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_identity</bpmn:incoming>
      <bpmn:outgoing>flow_to_parallel_fork</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Error Boundary Event: SP-PA-003 -->
    <bpmn:boundaryEvent id="error_SP_PA_003" name="Identity Error" attachedToRef="call_SP_PA_003">
      <bpmn:outgoing>flow_to_error_handler_003</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_PA_003" errorRef="Error_PatientAccess"/>
    </bpmn:boundaryEvent>

    <!-- Parallel Gateway: Fork for Financial + Intake -->
    <bpmn:parallelGateway id="gateway_parallel_fork" name="Fork: Financial + Intake">
      <bpmn:incoming>flow_to_parallel_fork</bpmn:incoming>
      <bpmn:outgoing>flow_to_financial</bpmn:outgoing>
      <bpmn:outgoing>flow_to_intake</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- Call Activity: SP-PA-004 Financial Clearance -->
    <bpmn:callActivity id="call_SP_PA_004" name="Executar Clearance Financeiro e Estimativas" calledElement="SP_PA_004_Financial_Clearance">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="patientFhirId" target="patientFhirId"/>
        <camunda:in source="coverageFhirId" target="coverageFhirId"/>
        <camunda:in source="serviceType" target="serviceType"/>
        <camunda:out source="clearanceStatus" target="clearanceStatus"/>
        <camunda:out source="payerId" target="payerId"/>
        <camunda:out source="estimatedCost" target="estimatedCost"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_financial</bpmn:incoming>
      <bpmn:outgoing>flow_from_financial</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Error Boundary Event: SP-PA-004 -->
    <bpmn:boundaryEvent id="error_SP_PA_004" name="Financial Error" attachedToRef="call_SP_PA_004">
      <bpmn:outgoing>flow_to_error_handler_004</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_PA_004" errorRef="Error_PatientAccess"/>
    </bpmn:boundaryEvent>

    <!-- Timer Boundary Event: SP-PA-004 (2h SLA) -->
    <bpmn:boundaryEvent id="timer_SP_PA_004" name="2h Clearance SLA" cancelActivity="false" attachedToRef="call_SP_PA_004">
      <bpmn:outgoing>flow_to_sla_escalation</bpmn:outgoing>
      <bpmn:timerEventDefinition id="timerDef_PA_004">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT2H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- Service Task: SLA Escalation Handler -->
    <bpmn:serviceTask id="task_sla_escalation" name="Escalate Financial Clearance SLA" camunda:class="com.cib7.healthcare.delegates.SLAEscalationDelegate">
      <bpmn:incoming>flow_to_sla_escalation</bpmn:incoming>
      <bpmn:outgoing>flow_from_sla_escalation</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- End Event: SLA Escalated -->
    <bpmn:endEvent id="end_sla_escalated" name="SLA Escalated">
      <bpmn:incoming>flow_from_sla_escalation</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Call Activity: SP-PA-005 Digital Intake -->
    <bpmn:callActivity id="call_SP_PA_005" name="Executar Intake Digital Pré-Atendimento" calledElement="SP_PA_005_Digital_Intake">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="patientFhirId" target="patientFhirId"/>
        <camunda:in source="appointmentFhirId" target="appointmentFhirId"/>
        <camunda:in source="demandChannel" target="demandChannel"/>
        <camunda:out source="intakeCompleted" target="intakeCompleted"/>
        <camunda:out source="consentSigned" target="consentSigned"/>
        <camunda:out source="formsCompleted" target="formsCompleted"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_intake</bpmn:incoming>
      <bpmn:outgoing>flow_from_intake</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Error Boundary Event: SP-PA-005 -->
    <bpmn:boundaryEvent id="error_SP_PA_005" name="Intake Error" attachedToRef="call_SP_PA_005">
      <bpmn:outgoing>flow_to_error_handler_005</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_PA_005" errorRef="Error_PatientAccess"/>
    </bpmn:boundaryEvent>

    <!-- Parallel Gateway: Join after Financial + Intake -->
    <bpmn:parallelGateway id="gateway_parallel_join" name="Join: Financial + Intake">
      <bpmn:incoming>flow_from_financial</bpmn:incoming>
      <bpmn:incoming>flow_from_intake</bpmn:incoming>
      <bpmn:outgoing>flow_to_clearance_check</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- Intermediate Catch Event: Clearance Approved (optional) -->
    <bpmn:intermediateCatchEvent id="catch_clearance_approved" name="Clearance Approved">
      <bpmn:incoming>flow_to_clearance_check</bpmn:incoming>
      <bpmn:outgoing>flow_to_checkin</bpmn:outgoing>
      <bpmn:messageEventDefinition id="msgDef_clearance" messageRef="msg_clearance_approved"/>
    </bpmn:intermediateCatchEvent>

    <!-- Call Activity: SP-PA-006 Check-in & Flow -->
    <bpmn:callActivity id="call_SP_PA_006" name="Executar Check-in e Gerenciar Fluxo" calledElement="SP_PA_006_Checkin_Flow">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="patientFhirId" target="patientFhirId"/>
        <camunda:in source="appointmentFhirId" target="appointmentFhirId"/>
        <camunda:in source="clearanceStatus" target="clearanceStatus"/>
        <camunda:in source="intakeCompleted" target="intakeCompleted"/>
        <camunda:out source="encounterFhirId" target="encounterFhirId"/>
        <camunda:out source="checkInCompleted" target="checkInCompleted"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_checkin</bpmn:incoming>
      <bpmn:outgoing>flow_to_ready_for_care</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Error Boundary Event: SP-PA-006 -->
    <bpmn:boundaryEvent id="error_SP_PA_006" name="Check-in Error" attachedToRef="call_SP_PA_006">
      <bpmn:outgoing>flow_to_error_handler_006</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_PA_006" errorRef="Error_PatientAccess"/>
    </bpmn:boundaryEvent>

    <!-- Intermediate Throw Event: Patient Ready for Care -->
    <bpmn:intermediateThrowEvent id="throw_ready_for_care" name="Patient Ready for Care">
      <bpmn:incoming>flow_to_ready_for_care</bpmn:incoming>
      <bpmn:outgoing>flow_to_patient_admitted</bpmn:outgoing>
      <bpmn:messageEventDefinition id="msgDef_ready" messageRef="msg_patient_ready_for_care"/>
    </bpmn:intermediateThrowEvent>

    <!-- MSG-001: PatientAdmitted throw (Patient Access → Revenue Cycle) -->
    <bpmn:intermediateThrowEvent id="throw_patient_admitted" name="Patient Admitted">
      <bpmn:incoming>flow_to_patient_admitted</bpmn:incoming>
      <bpmn:outgoing>flow_to_encounter_created</bpmn:outgoing>
      <bpmn:messageEventDefinition id="msgDef_patient_admitted" messageRef="msg_patient_admitted"/>
    </bpmn:intermediateThrowEvent>

    <!-- Intermediate Throw Event: Encounter Created -->
    <bpmn:intermediateThrowEvent id="throw_encounter_created" name="Encounter Created">
      <bpmn:incoming>flow_to_encounter_created</bpmn:incoming>
      <bpmn:outgoing>flow_to_end</bpmn:outgoing>
      <bpmn:messageEventDefinition id="msgDef_encounter" messageRef="msg_encounter_created"/>
    </bpmn:intermediateThrowEvent>

    <!-- End Event: Patient Access Complete -->
    <bpmn:endEvent id="end_patient_access_complete" name="Patient Access Complete">
      <bpmn:incoming>flow_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Error Handler Service Tasks -->
    <bpmn:serviceTask id="task_error_handler_001" name="Handle Demand Capture Error" camunda:class="com.cib7.healthcare.delegates.ErrorHandlerDelegate">
      <bpmn:incoming>flow_to_error_handler_001</bpmn:incoming>
      <bpmn:outgoing>flow_to_error_end_001</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="task_error_handler_002" name="Handle Scheduling Error" camunda:class="com.cib7.healthcare.delegates.ErrorHandlerDelegate">
      <bpmn:incoming>flow_to_error_handler_002</bpmn:incoming>
      <bpmn:outgoing>flow_to_error_end_002</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="task_error_handler_003" name="Handle Identity Error" camunda:class="com.cib7.healthcare.delegates.ErrorHandlerDelegate">
      <bpmn:incoming>flow_to_error_handler_003</bpmn:incoming>
      <bpmn:outgoing>flow_to_error_end_003</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="task_error_handler_004" name="Handle Financial Error" camunda:class="com.cib7.healthcare.delegates.ErrorHandlerDelegate">
      <bpmn:incoming>flow_to_error_handler_004</bpmn:incoming>
      <bpmn:outgoing>flow_to_error_end_004</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="task_error_handler_005" name="Handle Intake Error" camunda:class="com.cib7.healthcare.delegates.ErrorHandlerDelegate">
      <bpmn:incoming>flow_to_error_handler_005</bpmn:incoming>
      <bpmn:outgoing>flow_to_error_end_005</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="task_error_handler_006" name="Handle Check-in Error" camunda:class="com.cib7.healthcare.delegates.ErrorHandlerDelegate">
      <bpmn:incoming>flow_to_error_handler_006</bpmn:incoming>
      <bpmn:outgoing>flow_to_error_end_006</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Error End Events -->
    <bpmn:endEvent id="end_error_001" name="Demand Capture Failed">
      <bpmn:incoming>flow_to_error_end_001</bpmn:incoming>
      <bpmn:errorEventDefinition id="errEndDef_001" errorRef="Error_PatientAccess"/>
    </bpmn:endEvent>

    <bpmn:endEvent id="end_error_002" name="Scheduling Failed">
      <bpmn:incoming>flow_to_error_end_002</bpmn:incoming>
      <bpmn:errorEventDefinition id="errEndDef_002" errorRef="Error_PatientAccess"/>
    </bpmn:endEvent>

    <bpmn:endEvent id="end_error_003" name="Identity Failed">
      <bpmn:incoming>flow_to_error_end_003</bpmn:incoming>
      <bpmn:errorEventDefinition id="errEndDef_003" errorRef="Error_PatientAccess"/>
    </bpmn:endEvent>

    <bpmn:endEvent id="end_error_004" name="Financial Failed">
      <bpmn:incoming>flow_to_error_end_004</bpmn:incoming>
      <bpmn:errorEventDefinition id="errEndDef_004" errorRef="Error_PatientAccess"/>
    </bpmn:endEvent>

    <bpmn:endEvent id="end_error_005" name="Intake Failed">
      <bpmn:incoming>flow_to_error_end_005</bpmn:incoming>
      <bpmn:errorEventDefinition id="errEndDef_005" errorRef="Error_PatientAccess"/>
    </bpmn:endEvent>

    <bpmn:endEvent id="end_error_006" name="Check-in Failed">
      <bpmn:incoming>flow_to_error_end_006</bpmn:incoming>
      <bpmn:errorEventDefinition id="errEndDef_006" errorRef="Error_PatientAccess"/>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="flow_to_demand_capture" sourceRef="start_patient_contact" targetRef="call_SP_PA_001"/>
    <bpmn:sequenceFlow id="flow_to_appointment_check" sourceRef="call_SP_PA_001" targetRef="gateway_appointment_needed"/>
    <bpmn:sequenceFlow id="flow_to_scheduling" name="Yes" sourceRef="gateway_appointment_needed" targetRef="call_SP_PA_002">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${appointmentNeeded == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_to_identity_direct" name="No (Walk-in)" sourceRef="gateway_appointment_needed" targetRef="gateway_scheduling_merge">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${appointmentNeeded == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_from_scheduling" sourceRef="call_SP_PA_002" targetRef="gateway_scheduling_merge"/>
    <bpmn:sequenceFlow id="flow_to_identity" sourceRef="gateway_scheduling_merge" targetRef="call_SP_PA_003"/>
    <bpmn:sequenceFlow id="flow_to_parallel_fork" sourceRef="call_SP_PA_003" targetRef="gateway_parallel_fork"/>
    <bpmn:sequenceFlow id="flow_to_financial" sourceRef="gateway_parallel_fork" targetRef="call_SP_PA_004"/>
    <bpmn:sequenceFlow id="flow_to_intake" sourceRef="gateway_parallel_fork" targetRef="call_SP_PA_005"/>
    <bpmn:sequenceFlow id="flow_from_financial" sourceRef="call_SP_PA_004" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="flow_from_intake" sourceRef="call_SP_PA_005" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="flow_to_clearance_check" sourceRef="gateway_parallel_join" targetRef="catch_clearance_approved"/>
    <bpmn:sequenceFlow id="flow_to_checkin" sourceRef="catch_clearance_approved" targetRef="call_SP_PA_006"/>
    <bpmn:sequenceFlow id="flow_to_ready_for_care" sourceRef="call_SP_PA_006" targetRef="throw_ready_for_care"/>
    <bpmn:sequenceFlow id="flow_to_patient_admitted" sourceRef="throw_ready_for_care" targetRef="throw_patient_admitted"/>
    <bpmn:sequenceFlow id="flow_to_encounter_created" sourceRef="throw_patient_admitted" targetRef="throw_encounter_created"/>

    <!-- Authorization Denied flows -->
    <bpmn:sequenceFlow id="flow_auth_denied_to_reschedule" sourceRef="catch_authorization_denied" targetRef="task_handle_auth_denial"/>
    <bpmn:sequenceFlow id="flow_auth_denial_handled" sourceRef="task_handle_auth_denial" targetRef="end_auth_denial_handled"/>
    <bpmn:sequenceFlow id="flow_to_end" sourceRef="throw_encounter_created" targetRef="end_patient_access_complete"/>

    <!-- SLA Escalation Flows -->
    <bpmn:sequenceFlow id="flow_to_sla_escalation" sourceRef="timer_SP_PA_004" targetRef="task_sla_escalation"/>
    <bpmn:sequenceFlow id="flow_from_sla_escalation" sourceRef="task_sla_escalation" targetRef="end_sla_escalated"/>

    <!-- Error Handler Flows -->
    <bpmn:sequenceFlow id="flow_to_error_handler_001" sourceRef="error_SP_PA_001" targetRef="task_error_handler_001"/>
    <bpmn:sequenceFlow id="flow_to_error_end_001" sourceRef="task_error_handler_001" targetRef="end_error_001"/>
    <bpmn:sequenceFlow id="flow_to_error_handler_002" sourceRef="error_SP_PA_002" targetRef="task_error_handler_002"/>
    <bpmn:sequenceFlow id="flow_to_error_end_002" sourceRef="task_error_handler_002" targetRef="end_error_002"/>
    <bpmn:sequenceFlow id="flow_to_error_handler_003" sourceRef="error_SP_PA_003" targetRef="task_error_handler_003"/>
    <bpmn:sequenceFlow id="flow_to_error_end_003" sourceRef="task_error_handler_003" targetRef="end_error_003"/>
    <bpmn:sequenceFlow id="flow_to_error_handler_004" sourceRef="error_SP_PA_004" targetRef="task_error_handler_004"/>
    <bpmn:sequenceFlow id="flow_to_error_end_004" sourceRef="task_error_handler_004" targetRef="end_error_004"/>
    <bpmn:sequenceFlow id="flow_to_error_handler_005" sourceRef="error_SP_PA_005" targetRef="task_error_handler_005"/>
    <bpmn:sequenceFlow id="flow_to_error_end_005" sourceRef="task_error_handler_005" targetRef="end_error_005"/>
    <bpmn:sequenceFlow id="flow_to_error_handler_006" sourceRef="error_SP_PA_006" targetRef="task_error_handler_006"/>
    <bpmn:sequenceFlow id="flow_to_error_end_006" sourceRef="task_error_handler_006" targetRef="end_error_006"/>

  </bpmn:process>

  <!-- BPMN Diagram -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_patient_access_main">
    <bpmndi:BPMNPlane id="BPMNPlane_patient_access_main" bpmnElement="patient_access_main">

      <!-- Start Event -->
      <bpmndi:BPMNShape id="shape_start_patient_contact" bpmnElement="start_patient_contact">
        <dc:Bounds x="152" y="232" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="134" y="275" width="72" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Call Activity: SP-PA-001 -->
      <bpmndi:BPMNShape id="shape_call_SP_PA_001" bpmnElement="call_SP_PA_001">
        <dc:Bounds x="240" y="210" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- Error Boundary: SP-PA-001 -->
      <bpmndi:BPMNShape id="shape_error_SP_PA_001" bpmnElement="error_SP_PA_001">
        <dc:Bounds x="322" y="272" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="358" y="283" width="64" height="27"/>
