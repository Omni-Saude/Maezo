<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="{{ rule_id }}_def"
             name="{{ rule_name }}"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    WHITELIST archetype template.
    Authorizes specific codes (procedures, materials, exams) against a known list.
    Non-whitelisted items fall through to the catch-all rule returning false.
    Payer: {{ rule.payer_id }}
    Category: {{ rule.category.value if rule.category else 'unknown' }}
    Archetype: {{ rule.archetype.value if rule.archetype else 'WHITELIST' }}
    Rule ID: {{ rule.id }}
    Hit Policy FIRST: first match wins; catch-all at end handles unlisted items.
  -->
  <decision id="decision_{{ rule_id }}" name="{{ rule_name }}">
    <decisionTable id="dt_{{ rule_id }}" hitPolicy="{{ hit_policy }}">
      <input id="in_{{ rule_id }}_1" label="code">
        <inputExpression id="inExpr_{{ rule_id }}_1" typeRef="string">
          <text>code</text>
        </inputExpression>
      </input>
      <output id="out_{{ rule_id }}_1" label="authorized" name="authorized" typeRef="boolean"/>
      <output id="out_{{ rule_id }}_2" label="item_name" name="item_name" typeRef="string"/>
      <output id="out_{{ rule_id }}_3" label="reference_table" name="reference_table" typeRef="string"/>
{%- for cond in conditions %}
      <rule id="r_{{ rule_id }}_{{ loop.index }}">
        <description>{{ cond.description | default('Whitelist entry ' ~ loop.index) }}</description>
        <inputEntry id="ie_{{ rule_id }}_{{ loop.index }}_1"><text>{{ cond.input_entries[0] if cond.input_entries is defined and cond.input_entries | length > 0 else '' }}</text></inputEntry>
        <outputEntry id="oe_{{ rule_id }}_{{ loop.index }}_1"><text>{{ cond.output_entries[0] if cond.output_entries is defined and cond.output_entries | length > 0 else 'true' }}</text></outputEntry>
        <outputEntry id="oe_{{ rule_id }}_{{ loop.index }}_2"><text>{{ cond.output_entries[1] if cond.output_entries is defined and cond.output_entries | length > 1 else '""' }}</text></outputEntry>
        <outputEntry id="oe_{{ rule_id }}_{{ loop.index }}_3"><text>{{ cond.output_entries[2] if cond.output_entries is defined and cond.output_entries | length > 2 else '"SIGTAP"' }}</text></outputEntry>
      </rule>
{%- endfor %}
      <rule id="r_{{ rule_id }}_catchall">
        <description>Item not in whitelist - not automatically authorized, requires supervisor review</description>
        <inputEntry id="ie_{{ rule_id }}_catchall_1"><text></text></inputEntry>
        <outputEntry id="oe_{{ rule_id }}_catchall_1"><text>false</text></outputEntry>
        <outputEntry id="oe_{{ rule_id }}_catchall_2"><text>"Item not in whitelist - requires supervisor authorization"</text></outputEntry>
        <outputEntry id="oe_{{ rule_id }}_catchall_3"><text>"N/A"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
