<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="authorization_request_flow_def"
             name="AUTHORIZATION Rule authorization_request_flow"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    AUTHORIZATION archetype template.
    Validates authorization requests based on item type, submission deadline, and channel.
    Payer: SES-DF
    Category: AUTHORIZATION
    Archetype: AUTHORIZATION
    Rule ID: authorization_request_flow
    Source: RN-022, Contract 055374/2025, Section 4.3.7.14.2
    Hit Policy UNIQUE: exactly one rule matches for any given input combination.
  -->
  <decision id="decision_authorization_request_flow" name="AUTHORIZATION Rule authorization_request_flow">
    <decisionTable id="dt_authorization_request_flow" hitPolicy="UNIQUE">
      <input id="in_authorization_request_flow_1" label="item_requer_autorizacao">
        <inputExpression id="inExpr_authorization_request_flow_1" typeRef="boolean">
          <text>item_requer_autorizacao</text>
        </inputExpression>
      </input>
      <input id="in_authorization_request_flow_2" label="horas_desde_prescricao">
        <inputExpression id="inExpr_authorization_request_flow_2" typeRef="number">
          <text>horas_desde_prescricao</text>
        </inputExpression>
      </input>
      <input id="in_authorization_request_flow_3" label="canal">
        <inputExpression id="inExpr_authorization_request_flow_3" typeRef="string">
          <text>canal</text>
        </inputExpression>
      </input>
      <output id="out_authorization_request_flow_1" label="solicitacao_valida" name="solicitacao_valida" typeRef="boolean"/>
      <output id="out_authorization_request_flow_2" label="prazo_restante_horas" name="prazo_restante_horas" typeRef="number"/>
      <output id="out_authorization_request_flow_3" label="conteudo_minimo_ok" name="conteudo_minimo_ok" typeRef="boolean"/>
      <rule id="r_authorization_request_flow_1">
        <description>Solicitacao de autorizacao (clausula 4.3.7.14.2): item que requer autorizacao deve ser solicitado em ate 24h por meio eletronico com nome do paciente e relatorio medico.</description>
        <inputEntry id="ie_authorization_request_flow_1_1"><text>true</text></inputEntry>
        <inputEntry id="ie_authorization_request_flow_1_2"><text>&lt;= 24</text></inputEntry>
        <inputEntry id="ie_authorization_request_flow_1_3"><text>"ELETRONICO"</text></inputEntry>
        <outputEntry id="oe_authorization_request_flow_1_1"><text>true</text></outputEntry>
        <outputEntry id="oe_authorization_request_flow_1_2"><text>24 - horas_desde_prescricao</text></outputEntry>
        <outputEntry id="oe_authorization_request_flow_1_3"><text>true</text></outputEntry>
      </rule>
      <rule id="r_authorization_request_flow_2">
        <description>Solicitacao expirada: prazo de 24h para submissao de autorizacao excedido.</description>
        <inputEntry id="ie_authorization_request_flow_2_1"><text>true</text></inputEntry>
        <inputEntry id="ie_authorization_request_flow_2_2"><text>&gt; 24</text></inputEntry>
        <inputEntry id="ie_authorization_request_flow_2_3"><text>-</text></inputEntry>
        <outputEntry id="oe_authorization_request_flow_2_1"><text>false</text></outputEntry>
        <outputEntry id="oe_authorization_request_flow_2_2"><text>0</text></outputEntry>
        <outputEntry id="oe_authorization_request_flow_2_3"><text>false</text></outputEntry>
      </rule>
      <rule id="r_authorization_request_flow_3">
        <description>Item nao requer autorizacao previa: aprovacao automatica.</description>
        <inputEntry id="ie_authorization_request_flow_3_1"><text>false</text></inputEntry>
        <inputEntry id="ie_authorization_request_flow_3_2"><text>-</text></inputEntry>
        <inputEntry id="ie_authorization_request_flow_3_3"><text>-</text></inputEntry>
        <outputEntry id="oe_authorization_request_flow_3_1"><text>true</text></outputEntry>
        <outputEntry id="oe_authorization_request_flow_3_2"><text>0</text></outputEntry>
        <outputEntry id="oe_authorization_request_flow_3_3"><text>true</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
