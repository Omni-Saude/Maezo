<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="medication_high_cost_billing_def"
             name="PRICING Rule medication_high_cost_billing"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    PRICING archetype template.
    Classifies medications as high-cost based on unit value relative to minimum wage threshold.
    Payer: SES-DF
    Category: PRICING
    Archetype: PRICING
    Rule ID: medication_high_cost_billing
    Source: RN-015, Contract 055374/2025, Section 4.3.7.5.6
    Hit Policy UNIQUE: exactly one rule matches for any given input combination.
  -->
  <decision id="decision_medication_high_cost_billing" name="PRICING Rule medication_high_cost_billing">
    <decisionTable id="dt_medication_high_cost_billing" hitPolicy="UNIQUE">
      <input id="in_medication_high_cost_billing_1" label="medicamento_valor_unitario">
        <inputExpression id="inExpr_medication_high_cost_billing_1" typeRef="number">
          <text>medicamento_valor_unitario</text>
        </inputExpression>
      </input>
      <input id="in_medication_high_cost_billing_2" label="salario_minimo_metade">
        <inputExpression id="inExpr_medication_high_cost_billing_2" typeRef="number">
          <text>salario_minimo_metade</text>
        </inputExpression>
      </input>
      <output id="out_medication_high_cost_billing_1" label="classificacao" name="classificacao" typeRef="string"/>
      <output id="out_medication_high_cost_billing_2" label="autorizacao_requerida" name="autorizacao_requerida" typeRef="boolean"/>
      <output id="out_medication_high_cost_billing_3" label="glosa_urgencializacao_pct" name="glosa_urgencializacao_pct" typeRef="number"/>
      <rule id="r_medication_high_cost_billing_1">
        <description>Medicamento de alto custo (clausula 4.3.7.5.6): valor unitario >= metade do salario minimo requer autorizacao previa por escrito. Em urgencia, autorizar em ate 72h a posteriori. Glosa de 50% por urgencializacao indevida.</description>
        <inputEntry id="ie_medication_high_cost_billing_1_1"><text>>= salario_minimo_metade</text></inputEntry>
        <inputEntry id="ie_medication_high_cost_billing_1_2"><text>-</text></inputEntry>
        <outputEntry id="oe_medication_high_cost_billing_1_1"><text>"ALTO_CUSTO"</text></outputEntry>
        <outputEntry id="oe_medication_high_cost_billing_1_2"><text>true</text></outputEntry>
        <outputEntry id="oe_medication_high_cost_billing_1_3"><text>50</text></outputEntry>
      </rule>
      <rule id="r_medication_high_cost_billing_2">
        <description>Medicamento padrao: valor unitario abaixo do limiar de alto custo, sem necessidade de autorizacao previa.</description>
        <inputEntry id="ie_medication_high_cost_billing_2_1"><text>&lt; salario_minimo_metade</text></inputEntry>
        <inputEntry id="ie_medication_high_cost_billing_2_2"><text>-</text></inputEntry>
        <outputEntry id="oe_medication_high_cost_billing_2_1"><text>"PADRAO"</text></outputEntry>
        <outputEntry id="oe_medication_high_cost_billing_2_2"><text>false</text></outputEntry>
        <outputEntry id="oe_medication_high_cost_billing_2_3"><text>0</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
