<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="companion_authorization_def"
             name="AUTHORIZATION Rule companion_authorization"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    AUTHORIZATION archetype template.
    Determines whether a procedure requires prior authorization and the type/urgency.
    Payer: SES-DF
    Category: AUTHORIZATION
    Archetype: AUTHORIZATION
    Rule ID: companion_authorization
    Hit Policy FIRST: returns the first matching authorization rule.
  -->
  <decision id="decision_companion_authorization" name="AUTHORIZATION Rule companion_authorization">
    <decisionTable id="dt_companion_authorization" hitPolicy="FIRST">
      <input id="in_companion_authorization_1" label="procedure_code">
        <inputExpression id="inExpr_companion_authorization_1" typeRef="string">
          <text>procedure_code</text>
        </inputExpression>
      </input>
      <input id="in_companion_authorization_2" label="amount">
        <inputExpression id="inExpr_companion_authorization_2" typeRef="number">
          <text>amount</text>
        </inputExpression>
      </input>
      <input id="in_companion_authorization_3" label="payer_id">
        <inputExpression id="inExpr_companion_authorization_3" typeRef="string">
          <text>payer_id</text>
        </inputExpression>
      </input>
      <output id="out_companion_authorization_1" label="requires_auth" name="requires_auth" typeRef="boolean"/>
      <output id="out_companion_authorization_2" label="auth_type" name="auth_type" typeRef="string"/>
      <output id="out_companion_authorization_3" label="urgency_level" name="urgency_level" typeRef="string"/>
      <rule id="r_companion_authorization_1">
        <description>Autorizacao de acompanhante em UTI (clausula 4.3.7.2.1): elegivel para criancas (cod. 08.02.01.002-4), gestantes/puerperas (08.02.01.003-2), idosos (08.02.01.004-0) e PcD (08.02.01.005-9). Autorizacao concedida pelo profissional de saude responsavel pelo tratamento.</description>
        <inputEntry id="ie_companion_authorization_1_1"><text>"08.02.01.002-4"</text></inputEntry>
        <inputEntry id="ie_companion_authorization_1_2"><text>&gt;= 0</text></inputEntry>
        <inputEntry id="ie_companion_authorization_1_3"><text>"SES-DF"</text></inputEntry>
        <outputEntry id="oe_companion_authorization_1_1"><text>true</text></outputEntry>
        <outputEntry id="oe_companion_authorization_1_2"><text>"PROFISSIONAL_RESPONSAVEL"</text></outputEntry>
        <outputEntry id="oe_companion_authorization_1_3"><text>"ELETIVO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
