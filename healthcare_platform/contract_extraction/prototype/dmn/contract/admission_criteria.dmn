<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="admission_criteria_def"
             name="AUTHORIZATION Rule admission_criteria"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    AUTHORIZATION archetype template.
    Determines whether a procedure requires prior authorization and the type/urgency.
    Payer: SES-DF
    Category: AUTHORIZATION
    Archetype: AUTHORIZATION
    Rule ID: admission_criteria
    Hit Policy FIRST: returns the first matching authorization rule.
  -->
  <decision id="decision_admission_criteria" name="AUTHORIZATION Rule admission_criteria">
    <decisionTable id="dt_admission_criteria" hitPolicy="FIRST">
      <input id="in_admission_criteria_1" label="procedure_code">
        <inputExpression id="inExpr_admission_criteria_1" typeRef="string">
          <text>procedure_code</text>
        </inputExpression>
      </input>
      <input id="in_admission_criteria_2" label="amount">
        <inputExpression id="inExpr_admission_criteria_2" typeRef="number">
          <text>amount</text>
        </inputExpression>
      </input>
      <input id="in_admission_criteria_3" label="payer_id">
        <inputExpression id="inExpr_admission_criteria_3" typeRef="string">
          <text>payer_id</text>
        </inputExpression>
      </input>
      <output id="out_admission_criteria_1" label="requires_auth" name="requires_auth" typeRef="boolean"/>
      <output id="out_admission_criteria_2" label="auth_type" name="auth_type" typeRef="string"/>
      <output id="out_admission_criteria_3" label="urgency_level" name="urgency_level" typeRef="string"/>
      <rule id="r_admission_criteria_1">
        <description>Criterios de admissao UTI (clausula 4.3.4): adulto>=18anos; pediatrico 29d-17a11m29d; neonatal 0-28d. Admissao via CERIH conforme Resolucao CFM 2.156/2016 e Portaria SES/DF 200/2015.</description>
        <inputEntry id="ie_admission_criteria_1_1"><text>"08.02.01.008-3"</text></inputEntry>
        <inputEntry id="ie_admission_criteria_1_2"><text>&gt;= 0</text></inputEntry>
        <inputEntry id="ie_admission_criteria_1_3"><text>"SES-DF"</text></inputEntry>
        <outputEntry id="oe_admission_criteria_1_1"><text>true</text></outputEntry>
        <outputEntry id="oe_admission_criteria_1_2"><text>"CERIH_REGULACAO"</text></outputEntry>
        <outputEntry id="oe_admission_criteria_1_3"><text>"ELETIVO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
