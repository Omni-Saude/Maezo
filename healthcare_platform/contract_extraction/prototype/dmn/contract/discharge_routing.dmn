<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="discharge_routing_def"
             name="AUTHORIZATION Rule discharge_routing"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    ROUTING archetype template.
    Routes requests to the appropriate handler, formula, or service pathway.
    Payer: SES-DF
    Category: AUTHORIZATION
    Archetype: ROUTING
    Rule ID: discharge_routing
    Hit Policy FIRST: returns the first matching route.
  -->
  <decision id="decision_discharge_routing" name="AUTHORIZATION Rule discharge_routing">
    <decisionTable id="dt_discharge_routing" hitPolicy="FIRST">
      <rule id="r_discharge_routing_1">
        <description>Roteamento de alta UTI (clausula 4.3.5): alta comunicada imediatamente a CERIH; relatorio de alta enviado e atualizado a cada 24h ate alta administrativa. CERIH define leito de menor complexidade (enfermaria/cuid.intermediarios/prolongados).</description>
      </rule>
    </decisionTable>
  </decision>
</definitions>
