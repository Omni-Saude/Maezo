<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="billing_cycle_def"
             name="AUTHORIZATION Rule billing_cycle"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    ROUTING archetype template.
    Routes requests to the appropriate handler, formula, or service pathway.
    Payer: SES-DF
    Category: AUTHORIZATION
    Archetype: ROUTING
    Rule ID: billing_cycle
    Hit Policy FIRST: returns the first matching route.
  -->
  <decision id="decision_billing_cycle" name="AUTHORIZATION Rule billing_cycle">
    <decisionTable id="dt_billing_cycle" hitPolicy="FIRST">
      <rule id="r_billing_cycle_1">
        <description>Ciclo de faturamento (clausula 4.3.8): competencia encerrada -> prestador envia conta em ate 5 dias uteis a CEAN (Portaria 460/2024). Conta nao conforme: notificacao + reapresentacao em 72h ou risco de atraso de pagamento. Documentacao obrigatoria: AIH, RAH, relatorio admissao UTI, evolucoes medicas, resumo de alta.</description>
      </rule>
    </decisionTable>
  </decision>
</definitions>
