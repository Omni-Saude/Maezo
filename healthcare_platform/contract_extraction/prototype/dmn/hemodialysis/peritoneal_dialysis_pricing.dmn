<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="peritoneal_dialysis_pricing_def"
             name="Peritoneal Dialysis Pricing"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    Dialise Peritoneal pricing from Apendice VIII (Terapia Renal Substitutiva):
    SIGTAP 03.05.01.003-4
    Duas modalidades:
    - DPA (Dialise Peritoneal Automatizada)
    - CAPD (Dialise Peritoneal Ambulatorial Continua)
    Ambas incluem: enfermagem Nefrologia, honorarios medicos, aluguel maquina,
    equipamentos e materiais de consumo.
    Exclui: cateter Tenckhoff 2 cuff, visita medica.
  -->
  <decision id="decision_dp_pricing" name="Peritoneal Dialysis Pricing">
    <decisionTable id="dt_dp_pricing" hitPolicy="FIRST">
      <input id="in_session_type_dpp" label="Session Type">
        <inputExpression id="inExpr_session_type_dpp" typeRef="string">
          <text>session_type</text>
        </inputExpression>
      </input>
      <input id="in_modality_dpp" label="Modality">
        <inputExpression id="inExpr_modality_dpp" typeRef="string">
          <text>modality</text>
        </inputExpression>
      </input>
      <output id="out_package_code_dpp" label="Package SIGTAP Code" name="package_code" typeRef="string"/>
      <output id="out_billing_basis_dpp" label="Billing Basis" name="billing_basis" typeRef="string"/>
      <output id="out_machine_rental_dpp" label="Machine Rental Included" name="machine_rental_included" typeRef="boolean"/>
      <!-- Rule 1: DPA - Dialise Peritoneal Automatizada -->
      <rule id="r_dpp_dpa">
        <description>Dialise Peritoneal Automatizada (DPA): inclui enfermagem Nefrologia, honorarios medicos, aluguel maquina, equipamentos e materiais. SIGTAP 03.05.01.003-4 (Apendice VIII)</description>
        <inputEntry id="ie_dpp_dpa_1"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dpp_dpa_2"><text>"DPA"</text></inputEntry>
        <outputEntry id="oe_dpp_dpa_1"><text>"03.05.01.003-4"</text></outputEntry>
        <outputEntry id="oe_dpp_dpa_2"><text>"Dialise Peritoneal Automatizada (DPA): inclui enfermagem Nefrologia, honorarios medicos, aluguel maquina, equipamentos, mascaras descartaveis (04), prep kit (01), wippers (02) e materiais de consumo. Exclui cateter Tenckhoff e visita medica (Apendice VIII)"</text></outputEntry>
        <outputEntry id="oe_dpp_dpa_3"><text>true</text></outputEntry>
      </rule>
      <!-- Rule 2: CAPD - Dialise Peritoneal Ambulatorial Continua -->
      <rule id="r_dpp_capd">
        <description>Dialise Peritoneal Ambulatorial Continua (CAPD): inclui enfermagem Nefrologia, honorarios medicos, aluguel maquina, equipamentos e materiais. SIGTAP 03.05.01.003-4 (Apendice VIII)</description>
        <inputEntry id="ie_dpp_capd_1"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dpp_capd_2"><text>"CAPD"</text></inputEntry>
        <outputEntry id="oe_dpp_capd_1"><text>"03.05.01.003-4"</text></outputEntry>
        <outputEntry id="oe_dpp_capd_2"><text>"Dialise Peritoneal Ambulatorial Continua (CAPD): inclui enfermagem Nefrologia, honorarios medicos, aluguel maquina, equipamentos, mascaras descartaveis (10), prep kit (05), wippers (05) e materiais de consumo. Exclui cateter Tenckhoff e visita medica (Apendice VIII)"</text></outputEntry>
        <outputEntry id="oe_dpp_capd_3"><text>true</text></outputEntry>
      </rule>
      <!-- Rule 3: Fallback - unknown modality -->
      <rule id="r_dpp_fallback">
        <description>Dialise Peritoneal modalidade nao especificada: requer classificacao DPA ou CAPD (Apendice VIII)</description>
        <inputEntry id="ie_dpp_fb_1"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dpp_fb_2"><text></text></inputEntry>
        <outputEntry id="oe_dpp_fb_1"><text>"03.05.01.003-4"</text></outputEntry>
        <outputEntry id="oe_dpp_fb_2"><text>"Dialise Peritoneal - modalidade nao especificada: classificar como DPA ou CAPD para definir quantidades de materiais"</text></outputEntry>
        <outputEntry id="oe_dpp_fb_3"><text>true</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
