<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="peritoneal_dialysis_bundle_def"
             name="Peritoneal Dialysis Bundle Items"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    Dialise Peritoneal bundle items from Apendice VIII (Terapia Renal Substitutiva):
    SIGTAP 03.05.01.003-4
    Modalidades: DPA (Dialise Peritoneal Automatizada) e CAPD (Dialise Peritoneal
    Ambulatorial Continua). Inclui enfermagem Nefrologia, equipamentos + aluguel maquina,
    materiais de consumo. Exclui cateter Tenckhoff 2 cuff e visita medica.
    Hit Policy COLLECT: retorna TODOS os itens correspondentes (incluidos e excluidos).
  -->
  <decision id="decision_dp_bundle" name="Peritoneal Dialysis Bundle Items">
    <decisionTable id="dt_dp_bundle" hitPolicy="COLLECT">
      <input id="in_session_type_dpb" label="Session Type">
        <inputExpression id="inExpr_session_type_dpb" typeRef="string">
          <text>session_type</text>
        </inputExpression>
      </input>
      <input id="in_item_category_dpb" label="Item Category">
        <inputExpression id="inExpr_item_category_dpb" typeRef="string">
          <text>item_category</text>
        </inputExpression>
      </input>
      <output id="out_item_included_dpb" label="Item Included" name="item_included" typeRef="boolean"/>
      <output id="out_item_name_dpb" label="Item Name" name="item_name" typeRef="string"/>
      <output id="out_qty_dpb" label="Quantity per Session" name="quantity_per_session" typeRef="number"/>
      <!-- Included items common to both DPA and CAPD -->
      <rule id="r_dp_enfermagem">
        <description>Dialise Peritoneal: enfermagem Nefrologia incluida (Apendice VIII)</description>
        <inputEntry id="ie_dp_enf_1"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_enf_2"><text></text></inputEntry>
        <outputEntry id="oe_dp_enf_1"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_enf_2"><text>"Enfermagem Nefrologia"</text></outputEntry>
        <outputEntry id="oe_dp_enf_3"><text>1</text></outputEntry>
      </rule>
      <rule id="r_dp_equipamentos">
        <description>Dialise Peritoneal: equipamentos + aluguel maquina incluidos (Apendice VIII)</description>
        <inputEntry id="ie_dp_eq_1"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_eq_2"><text></text></inputEntry>
        <outputEntry id="oe_dp_eq_1"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_eq_2"><text>"Equipamentos + aluguel maquina"</text></outputEntry>
        <outputEntry id="oe_dp_eq_3"><text>1</text></outputEntry>
      </rule>
      <rule id="r_dp_mascaras_dpa">
        <description>Dialise Peritoneal DPA: 04 mascaras descartaveis (Apendice VIII)</description>
        <inputEntry id="ie_dp_md_1"><text>"DIALISE_PERITONEAL_DPA"</text></inputEntry>
        <inputEntry id="ie_dp_md_2"><text></text></inputEntry>
        <outputEntry id="oe_dp_md_1"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_md_2"><text>"Mascaras descartaveis (DPA)"</text></outputEntry>
        <outputEntry id="oe_dp_md_3"><text>4</text></outputEntry>
      </rule>
      <rule id="r_dp_mascaras_capd">
        <description>Dialise Peritoneal CAPD: 10 mascaras descartaveis (Apendice VIII)</description>
        <inputEntry id="ie_dp_mc_1"><text>"DIALISE_PERITONEAL_CAPD"</text></inputEntry>
        <inputEntry id="ie_dp_mc_2"><text></text></inputEntry>
        <outputEntry id="oe_dp_mc_1"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_mc_2"><text>"Mascaras descartaveis (CAPD)"</text></outputEntry>
        <outputEntry id="oe_dp_mc_3"><text>10</text></outputEntry>
      </rule>
      <rule id="r_dp_clamps">
        <description>Dialise Peritoneal: 02 clamps plasticos bolsa incluidos (Apendice VIII)</description>
        <inputEntry id="ie_dp_cl_1"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_cl_2"><text></text></inputEntry>
        <outputEntry id="oe_dp_cl_1"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_cl_2"><text>"Clamps plasticos bolsa"</text></outputEntry>
        <outputEntry id="oe_dp_cl_3"><text>2</text></outputEntry>
      </rule>
      <rule id="r_dp_equipocassete">
        <description>Dialise Peritoneal: 01 equipocassete Homechoice 3 entradas incluido (Apendice VIII)</description>
        <inputEntry id="ie_dp_ec_1"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_ec_2"><text></text></inputEntry>
        <outputEntry id="oe_dp_ec_1"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_ec_2"><text>"Equipocassete Homechoice 3 entradas"</text></outputEntry>
        <outputEntry id="oe_dp_ec_3"><text>1</text></outputEntry>
      </rule>
      <rule id="r_dp_equipo_drenagem">
        <description>Dialise Peritoneal: 01 equipo drenagem incluido (Apendice VIII)</description>
        <inputEntry id="ie_dp_ed_1"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_ed_2"><text></text></inputEntry>
        <outputEntry id="oe_dp_ed_1"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_ed_2"><text>"Equipo drenagem"</text></outputEntry>
        <outputEntry id="oe_dp_ed_3"><text>1</text></outputEntry>
      </rule>
      <rule id="r_dp_prepkit_dpa">
        <description>Dialise Peritoneal DPA: 01 prep kit incluido (Apendice VIII)</description>
        <inputEntry id="ie_dp_pk_1"><text>"DIALISE_PERITONEAL_DPA"</text></inputEntry>
        <inputEntry id="ie_dp_pk_2"><text></text></inputEntry>
        <outputEntry id="oe_dp_pk_1"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_pk_2"><text>"Prep Kit (DPA)"</text></outputEntry>
        <outputEntry id="oe_dp_pk_3"><text>1</text></outputEntry>
      </rule>
      <rule id="r_dp_prepkit_capd">
        <description>Dialise Peritoneal CAPD: 05 prep kits incluidos (Apendice VIII)</description>
        <inputEntry id="ie_dp_pkc_1"><text>"DIALISE_PERITONEAL_CAPD"</text></inputEntry>
        <inputEntry id="ie_dp_pkc_2"><text></text></inputEntry>
        <outputEntry id="oe_dp_pkc_1"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_pkc_2"><text>"Prep Kit (CAPD)"</text></outputEntry>
        <outputEntry id="oe_dp_pkc_3"><text>5</text></outputEntry>
      </rule>
      <rule id="r_dp_bolsa_simples">
        <description>Dialise Peritoneal: 01 bolsa simples 1,5/2,5/4,25% 2500ml incluida (Apendice VIII)</description>
        <inputEntry id="ie_dp_bs_1"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_bs_2"><text></text></inputEntry>
        <outputEntry id="oe_dp_bs_1"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_bs_2"><text>"Bolsa simples 1,5/2,5/4,25% 2500ml"</text></outputEntry>
        <outputEntry id="oe_dp_bs_3"><text>1</text></outputEntry>
      </rule>
      <rule id="r_dp_bolsas_6000">
        <description>Dialise Peritoneal: 02 bolsas simples 6000ml incluidas (Apendice VIII)</description>
        <inputEntry id="ie_dp_b6_1"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_b6_2"><text></text></inputEntry>
        <outputEntry id="oe_dp_b6_1"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_b6_2"><text>"Bolsas simples 6000ml"</text></outputEntry>
        <outputEntry id="oe_dp_b6_3"><text>2</text></outputEntry>
      </rule>
      <rule id="r_dp_ultrabag_2000">
        <description>Dialise Peritoneal: 05 bolsas Ultrabag 2000ml incluidas (Apendice VIII)</description>
        <inputEntry id="ie_dp_u2_1"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_u2_2"><text></text></inputEntry>
        <outputEntry id="oe_dp_u2_1"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_u2_2"><text>"Bolsas Ultrabag 2000ml"</text></outputEntry>
        <outputEntry id="oe_dp_u2_3"><text>5</text></outputEntry>
      </rule>
      <rule id="r_dp_ultrabag_2500">
        <description>Dialise Peritoneal: 05 bolsas Ultrabag 2500ml incluidas (Apendice VIII)</description>
        <inputEntry id="ie_dp_u25_1"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_u25_2"><text></text></inputEntry>
        <outputEntry id="oe_dp_u25_1"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_u25_2"><text>"Bolsas Ultrabag 2500ml"</text></outputEntry>
        <outputEntry id="oe_dp_u25_3"><text>5</text></outputEntry>
      </rule>
      <rule id="r_dp_alcool">
        <description>Dialise Peritoneal: alcool 70% 100ml incluido (Apendice VIII)</description>
        <inputEntry id="ie_dp_al_1"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_al_2"><text></text></inputEntry>
        <outputEntry id="oe_dp_al_1"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_al_2"><text>"Alcool 70% 100ml"</text></outputEntry>
        <outputEntry id="oe_dp_al_3"><text>1</text></outputEntry>
      </rule>
      <rule id="r_dp_wipper_dpa">
        <description>Dialise Peritoneal DPA: 02 wippers incluidos (Apendice VIII)</description>
        <inputEntry id="ie_dp_wd_1"><text>"DIALISE_PERITONEAL_DPA"</text></inputEntry>
        <inputEntry id="ie_dp_wd_2"><text></text></inputEntry>
        <outputEntry id="oe_dp_wd_1"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_wd_2"><text>"Wipper (DPA)"</text></outputEntry>
        <outputEntry id="oe_dp_wd_3"><text>2</text></outputEntry>
      </rule>
      <rule id="r_dp_wipper_capd">
        <description>Dialise Peritoneal CAPD: 05 wippers incluidos (Apendice VIII)</description>
        <inputEntry id="ie_dp_wc_1"><text>"DIALISE_PERITONEAL_CAPD"</text></inputEntry>
        <inputEntry id="ie_dp_wc_2"><text></text></inputEntry>
        <outputEntry id="oe_dp_wc_1"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_wc_2"><text>"Wipper (CAPD)"</text></outputEntry>
        <outputEntry id="oe_dp_wc_3"><text>5</text></outputEntry>
      </rule>
      <rule id="r_dp_minicaps">
        <description>Dialise Peritoneal: mini caps incluidos (Apendice VIII)</description>
        <inputEntry id="ie_dp_mi_1"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_mi_2"><text></text></inputEntry>
        <outputEntry id="oe_dp_mi_1"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_mi_2"><text>"Mini caps"</text></outputEntry>
        <outputEntry id="oe_dp_mi_3"><text>1</text></outputEntry>
      </rule>
      <rule id="r_dp_luvas_estereis">
        <description>Dialise Peritoneal: 02 pares luvas estereis incluidos (Apendice VIII)</description>
        <inputEntry id="ie_dp_le_1"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_le_2"><text></text></inputEntry>
        <outputEntry id="oe_dp_le_1"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_le_2"><text>"Luvas estereis (pares)"</text></outputEntry>
        <outputEntry id="oe_dp_le_3"><text>2</text></outputEntry>
      </rule>
      <rule id="r_dp_mascara_cirurgica">
        <description>Dialise Peritoneal: 01 mascara cirurgica incluida (Apendice VIII)</description>
        <inputEntry id="ie_dp_mci_1"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_mci_2"><text></text></inputEntry>
        <outputEntry id="oe_dp_mci_1"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_mci_2"><text>"Mascara cirurgica"</text></outputEntry>
        <outputEntry id="oe_dp_mci_3"><text>1</text></outputEntry>
      </rule>
      <rule id="r_dp_compressa">
        <description>Dialise Peritoneal: 02 pacotes compressa esteril incluidos (Apendice VIII)</description>
        <inputEntry id="ie_dp_co_1"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_co_2"><text></text></inputEntry>
        <outputEntry id="oe_dp_co_1"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_co_2"><text>"Compressa esteril (pacotes)"</text></outputEntry>
        <outputEntry id="oe_dp_co_3"><text>2</text></outputEntry>
      </rule>
      <rule id="r_dp_luvas_procedimento">
        <description>Dialise Peritoneal: 02 pares luvas procedimento incluidos (Apendice VIII)</description>
        <inputEntry id="ie_dp_lp_1"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_lp_2"><text></text></inputEntry>
        <outputEntry id="oe_dp_lp_1"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_lp_2"><text>"Luvas procedimento (pares)"</text></outputEntry>
        <outputEntry id="oe_dp_lp_3"><text>2</text></outputEntry>
      </rule>
      <!-- Excluded items -->
      <rule id="r_dp_excl_cateter_tenckhoff">
        <description>Dialise Peritoneal: cateter Tenckhoff 2 cuff EXCLUIDO do pacote (Apendice VIII)</description>
        <inputEntry id="ie_dp_ext_1"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_ext_2"><text>"cateter_tenckhoff"</text></inputEntry>
        <outputEntry id="oe_dp_ext_1"><text>false</text></outputEntry>
        <outputEntry id="oe_dp_ext_2"><text>"Cateter Tenckhoff 2 cuff (EXCLUIDO do pacote)"</text></outputEntry>
        <outputEntry id="oe_dp_ext_3"><text>0</text></outputEntry>
      </rule>
      <rule id="r_dp_excl_visita_medica">
        <description>Dialise Peritoneal: visita medica EXCLUIDA do pacote (Apendice VIII)</description>
        <inputEntry id="ie_dp_exv_1"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_exv_2"><text>"visita_medica"</text></inputEntry>
        <outputEntry id="oe_dp_exv_1"><text>false</text></outputEntry>
        <outputEntry id="oe_dp_exv_2"><text>"Visita medica (EXCLUIDA do pacote)"</text></outputEntry>
        <outputEntry id="oe_dp_exv_3"><text>0</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
