      <!-- Catch-all: material not in whitelist -->
      <rule id="r_m_catchall">
        <description>Material nao padronizado na SES/DF - requer autorizacao medico supervisor (Contrato 4.3.7.12)</description>
        <inputEntry id="ie_m_catchall"><text></text></inputEntry>
        <outputEntry id="oe_m_catchall_1"><text>false</text></outputEntry>
        <outputEntry id="oe_m_catchall_2"><text>"Material nao padronizado na SES/DF - submeter avaliacao/autorizacao medico supervisor (Contrato 4.3.7.12)"</text></outputEntry>
