<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="material_whitelist_def"
             name="Material Whitelist"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    Materiais padronizados na SES/DF conforme Apendice XI do contrato.
    Codigos SES (codigo_ses) e codigos BR (codigo_br) extraidos diretamente do arquivo.
    Materiais nao listados podem ser utilizados se tiverem descritivo similar a padronizado
    (Contrato 4.3.7.12). Materiais nao padronizados requerem autorizacao do medico supervisor.
  -->
  <decision id="decision_material_whitelist" name="Material Whitelist">
    <decisionTable id="dt_material_whitelist" hitPolicy="FIRST">
      <input id="in_codigo_ses" label="Codigo SES do Material">
        <inputExpression id="inExpr_codigo_ses" typeRef="string">
          <text>codigo_ses</text>
        </inputExpression>
      </input>
      <output id="out_authorized_m" label="Authorized" name="authorized" typeRef="boolean"/>
      <output id="out_material_name" label="Material Name" name="material_name" typeRef="string"/>
      <output id="out_codigo_br" label="Codigo BR" name="codigo_br" typeRef="string"/>
      <!-- Rule 1 -->
      <rule id="r_m_01">
        <description>Abaixador de lingua convencional em madeira (Apendice XI)</description>
        <inputEntry id="ie_m_01"><text>"91180"</text></inputEntry>
        <outputEntry id="oe_m_01_1"><text>true</text></outputEntry>
        <outputEntry id="oe_m_01_2"><text>"ABAIXADOR DE LINGUA CONVENCIONAL EM MADEIRA, PACOTE COM 100 UND"</text></outputEntry>
        <outputEntry id="oe_m_01_3"><text>"348807"</text></outputEntry>
      </rule>
      <!-- Rule 2 -->
      <rule id="r_m_02">
        <description>Absorvente higienico hospitalar (Apendice XI)</description>
        <inputEntry id="ie_m_02"><text>"3527"</text></inputEntry>
        <outputEntry id="oe_m_02_1"><text>true</text></outputEntry>
        <outputEntry id="oe_m_02_2"><text>"ABSORVENTE HIGIENICO TAMANHO HOSPITALAR"</text></outputEntry>
        <outputEntry id="oe_m_02_3"><text>"279373"</text></outputEntry>
      </rule>
      <!-- Rule 3 -->
      <rule id="r_m_03">
        <description>Acidos graxos essenciais (acelerador cicatrizacao) (Apendice XI)</description>
        <inputEntry id="ie_m_03"><text>"3365"</text></inputEntry>
        <outputEntry id="oe_m_03_1"><text>true</text></outputEntry>
        <outputEntry id="oe_m_03_2"><text>"ACIDOS GRAXOS ESSENCIAIS + TRIGLICERIDEOS (ACELERADOR DE CICATRIZACAO), SOLUCAO"</text></outputEntry>
        <outputEntry id="oe_m_03_3"><text>"348002"</text></outputEntry>
      </rule>
      <!-- Rule 4 -->
      <rule id="r_m_04">
        <description>Agulha anestesica raquidiana 25Gx3 1/2 (Apendice XI)</description>
        <inputEntry id="ie_m_04"><text>"91036"</text></inputEntry>
        <outputEntry id="oe_m_04_1"><text>true</text></outputEntry>
        <outputEntry id="oe_m_04_2"><text>"AGULHA ANESTESICA APLICACAO PARA RAQUIDIANA 25G X 3 1/2 (90MM)"</text></outputEntry>
        <outputEntry id="oe_m_04_3"><text>"38218"</text></outputEntry>
      </rule>
      <!-- Rule 5 -->
      <rule id="r_m_05">
        <description>Agulha anestesica Quincke 20G para puncao lombar (Apendice XI)</description>
        <inputEntry id="ie_m_05"><text>"34590"</text></inputEntry>
        <outputEntry id="oe_m_05_1"><text>true</text></outputEntry>
        <outputEntry id="oe_m_05_2"><text>"AGULHA ANESTESICA TIPO PONTA QUINCKE 20G PARA PUNCAO LOMBAR DIAGNOSTICA"</text></outputEntry>
