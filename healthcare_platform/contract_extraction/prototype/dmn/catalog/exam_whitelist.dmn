<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="exam_whitelist_def"
             name="Exam Whitelist"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    Exames padronizados na SES/DF conforme Apendice VII do Edital/Contrato.
    Includes: bioquimica, hormonios, marcadores cardiacos, microbiologia,
              hematologia, parasitologia, urinalise, testes rapidos, radiologia,
              anatomia patologica.
    For SADT de alto custo (>R$450,00) autorizacao pelo medico supervisor requerida
    (Edital 2.8.6.5, Contrato 4.3.7.6.5).
  -->
  <decision id="decision_exam_whitelist" name="Exam Whitelist">
    <decisionTable id="dt_exam_whitelist" hitPolicy="FIRST">
      <input id="in_codigo_sigtap_e" label="Codigo SIGTAP do Exame">
        <inputExpression id="inExpr_codigo_sigtap_e" typeRef="string">
          <text>codigo_sigtap</text>
        </inputExpression>
      </input>
      <output id="out_authorized_e" label="Authorized" name="authorized" typeRef="boolean"/>
      <output id="out_exam_name" label="Exam Name" name="exam_name" typeRef="string"/>
      <output id="out_tabela_ref" label="Reference Table" name="tabela_ref" typeRef="string"/>
      <!-- BIOQUIMICA -->
      <rule id="r_e_01">
        <description>Lactato (Apendice VII - Bioquimica)</description>
        <inputEntry id="ie_e_01"><text>"02.02.01.053-8"</text></inputEntry>
        <outputEntry id="oe_e_01_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_01_2"><text>"LACTATO"</text></outputEntry>
        <outputEntry id="oe_e_01_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_02">
        <description>Sodio em sangue total, soro e urina (Apendice VII)</description>
        <inputEntry id="ie_e_02"><text>"02.02.01.063-5"</text></inputEntry>
        <outputEntry id="oe_e_02_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_02_2"><text>"SODIO EM SANGUE TOTAL, SORO E URINA"</text></outputEntry>
        <outputEntry id="oe_e_02_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_03">
        <description>Potassio e Cloretos (Apendice VII)</description>
        <inputEntry id="ie_e_03"><text>"02.02.01.060-0"</text></inputEntry>
        <outputEntry id="oe_e_03_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_03_2"><text>"POTASSIO E CLORETOS EM SANGUE TOTAL, SORO E URINA"</text></outputEntry>
        <outputEntry id="oe_e_03_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_04">
        <description>Glicose Enzimatica (Apendice VII)</description>
        <inputEntry id="ie_e_04"><text>"02.02.01.047-3"</text></inputEntry>
        <outputEntry id="oe_e_04_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_04_2"><text>"GLICOSE ENZIMATICA"</text></outputEntry>
        <outputEntry id="oe_e_04_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_05">
        <description>Ureia Enzimatica (Apendice VII)</description>
        <inputEntry id="ie_e_05"><text>"02.02.01.069-4"</text></inputEntry>
        <outputEntry id="oe_e_05_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_05_2"><text>"UREIA ENZIMATICA"</text></outputEntry>
        <outputEntry id="oe_e_05_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_06">
        <description>Creatinina (Apendice VII)</description>
        <inputEntry id="ie_e_06"><text>"02.02.01.031-7"</text></inputEntry>
        <outputEntry id="oe_e_06_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_06_2"><text>"CREATININA"</text></outputEntry>
        <outputEntry id="oe_e_06_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_07">
        <description>TGO Cinetico - Transaminase Oxalacetica (Apendice VII)</description>
        <inputEntry id="ie_e_07"><text>"02.02.01.064-3"</text></inputEntry>
        <outputEntry id="oe_e_07_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_07_2"><text>"TGO CINETICO (AST)"</text></outputEntry>
        <outputEntry id="oe_e_07_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_08">
        <description>TGP Cinetico - Transaminase Piruvica (Apendice VII)</description>
        <inputEntry id="ie_e_08"><text>"02.02.01.065-1"</text></inputEntry>
        <outputEntry id="oe_e_08_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_08_2"><text>"TGP CINETICO (ALT)"</text></outputEntry>
        <outputEntry id="oe_e_08_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_09">
        <description>Bilirrubina Total e Fracoes (Apendice VII)</description>
        <inputEntry id="ie_e_09"><text>"02.02.01.020-1"</text></inputEntry>
        <outputEntry id="oe_e_09_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_09_2"><text>"BILIRRUBINA TOTAL E FRACOES"</text></outputEntry>
        <outputEntry id="oe_e_09_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_10">
        <description>Calcio (Apendice VII)</description>
        <inputEntry id="ie_e_10"><text>"02.02.01.021-0"</text></inputEntry>
        <outputEntry id="oe_e_10_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_10_2"><text>"CALCIO"</text></outputEntry>
        <outputEntry id="oe_e_10_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_11">
        <description>Gasometria Arterial (Apendice VII)</description>
        <inputEntry id="ie_e_11"><text>"02.02.01.073-2"</text></inputEntry>
        <outputEntry id="oe_e_11_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_11_2"><text>"GASOMETRIA ARTERIAL (pH, pCO2, PO2, HCO3, excesso base, satO2)"</text></outputEntry>
        <outputEntry id="oe_e_11_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_12">
        <description>Hemograma Completo (Apendice VII - Hematologia)</description>
        <inputEntry id="ie_e_12"><text>"02.02.02.038-0"</text></inputEntry>
        <outputEntry id="oe_e_12_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_12_2"><text>"HEMOGRAMA COMPLETO"</text></outputEntry>
        <outputEntry id="oe_e_12_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_13">
        <description>TAP - Tempo de Atividade de Protrombina (Apendice VII)</description>
        <inputEntry id="ie_e_13"><text>"02.02.02.014-2"</text></inputEntry>
        <outputEntry id="oe_e_13_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_13_2"><text>"TAP (TEMPO DE ATIVIDADE DE PROTROMBINA / RNI)"</text></outputEntry>
        <outputEntry id="oe_e_13_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_14">
        <description>TTPA - Tempo de Tromboplastina Parcial Ativada (Apendice VII)</description>
        <inputEntry id="ie_e_14"><text>"02.02.02.013-4"</text></inputEntry>
        <outputEntry id="oe_e_14_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_14_2"><text>"TTPA (TEMPO DE TROMBOPLASTINA PARCIAL ATIVADA)"</text></outputEntry>
        <outputEntry id="oe_e_14_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_15">
        <description>Hemocultura (Apendice VII - Microbiologia)</description>
        <inputEntry id="ie_e_15"><text>"02.02.08.015-3"</text></inputEntry>
        <outputEntry id="oe_e_15_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_15_2"><text>"HEMOCULTURA"</text></outputEntry>
        <outputEntry id="oe_e_15_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_16">
        <description>Antibiograma (Apendice VII)</description>
        <inputEntry id="ie_e_16"><text>"02.02.08.002-1"</text></inputEntry>
        <outputEntry id="oe_e_16_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_16_2"><text>"ANTIBIOGRAMA"</text></outputEntry>
        <outputEntry id="oe_e_16_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_17">
        <description>PCR - Proteina C Reativa (Apendice VII)</description>
        <inputEntry id="ie_e_17"><text>"02.02.03.008-3"</text></inputEntry>
        <outputEntry id="oe_e_17_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_17_2"><text>"PCR (PROTEINA C REATIVA)"</text></outputEntry>
        <outputEntry id="oe_e_17_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_18">
        <description>Troponina (Apendice VII - Marcadores Cardiacos)</description>
        <inputEntry id="ie_e_18"><text>"02.02.03.120-9"</text></inputEntry>
        <outputEntry id="oe_e_18_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_18_2"><text>"TROPONINA"</text></outputEntry>
        <outputEntry id="oe_e_18_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_19">
        <description>EAS - Exame de Urina Tipo 1 (Apendice VII - Urinalise)</description>
        <inputEntry id="ie_e_19"><text>"02.02.05.001-7"</text></inputEntry>
        <outputEntry id="oe_e_19_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_19_2"><text>"EAS (EXAME DE URINA TIPO 1)"</text></outputEntry>
        <outputEntry id="oe_e_19_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_20">
        <description>TSH (Apendice VII - Hormonios)</description>
        <inputEntry id="ie_e_20"><text>"02.02.06.025-0"</text></inputEntry>
        <outputEntry id="oe_e_20_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_20_2"><text>"TSH (TIROTROPINA)"</text></outputEntry>
        <outputEntry id="oe_e_20_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_21">
        <description>Fosfatase Alcalina (Apendice VII)</description>
        <inputEntry id="ie_e_21"><text>"02.02.01.042-2"</text></inputEntry>
        <outputEntry id="oe_e_21_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_21_2"><text>"FOSFATASE ALCALINA"</text></outputEntry>
        <outputEntry id="oe_e_21_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_22">
        <description>Magnesio (Apendice VII)</description>
        <inputEntry id="ie_e_22"><text>"02.02.01.056-2"</text></inputEntry>
        <outputEntry id="oe_e_22_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_22_2"><text>"MAGNESIO"</text></outputEntry>
        <outputEntry id="oe_e_22_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_23">
        <description>CK - Creatina Kinase (Apendice VII)</description>
        <inputEntry id="ie_e_23"><text>"02.02.01.032-5"</text></inputEntry>
        <outputEntry id="oe_e_23_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_23_2"><text>"CK (CREATINA KINASE TOTAL)"</text></outputEntry>
        <outputEntry id="oe_e_23_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_24">
        <description>Ultrassonografia Abdome Total (Apendice VII - Radiologia)</description>
        <inputEntry id="ie_e_24"><text>"02.05.02.004-6"</text></inputEntry>
        <outputEntry id="oe_e_24_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_24_2"><text>"ULTRASSONOGRAFIA DE ABDOME TOTAL"</text></outputEntry>
        <outputEntry id="oe_e_24_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_25">
        <description>Teste Rapido Dengue IGG/IGM (Apendice VII - Testes Rapidos)</description>
        <inputEntry id="ie_e_25"><text>"02.14.01.012-0"</text></inputEntry>
        <outputEntry id="oe_e_25_1"><text>true</text></outputEntry>
        <outputEntry id="oe_e_25_2"><text>"TESTE RAPIDO DENGUE IGG/IGM / DENGUE NS1"</text></outputEntry>
        <outputEntry id="oe_e_25_3"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <!-- Catch-all: exam not in whitelist -->
      <rule id="r_e_catchall">
        <description>Exame nao padronizado na SES/DF - nao autorizado automaticamente (Apendice VII)</description>
        <inputEntry id="ie_e_catchall"><text></text></inputEntry>
        <outputEntry id="oe_e_catchall_1"><text>false</text></outputEntry>
        <outputEntry id="oe_e_catchall_2"><text>"Exame nao padronizado na SES/DF - requer avaliacao pelo medico supervisor (Contrato 4.3.7.6)"</text></outputEntry>
        <outputEntry id="oe_e_catchall_3"><text>"N/A"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
