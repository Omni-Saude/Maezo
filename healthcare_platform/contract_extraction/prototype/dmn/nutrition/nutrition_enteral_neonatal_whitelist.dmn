<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="nutrition_enteral_neonatal_whitelist_def"
             name="Nutrition Enteral Neonatal Whitelist"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    Whitelist de formulas enterais neonatais conforme Apendice VI.
    Subconjunto neonatal das formulas infantis (secao 6) e enteral infantil (secao 3).
    Fonte: SES/SAIS/COASIS/DASIS/GESNUT 166054889
  -->
  <decision id="decision_nutrition_enteral_neonatal_whitelist" name="Nutrition Enteral Neonatal Whitelist">
    <decisionTable id="dt_nutrition_enteral_neonatal_whitelist" hitPolicy="FIRST">
      <input id="in_code_nenw" label="Code">
        <inputExpression id="inExpr_code_nenw" typeRef="string">
          <text>code</text>
        </inputExpression>
      </input>
      <output id="out_authorized_nenw" label="Authorized" name="authorized" typeRef="boolean"/>
      <output id="out_item_name_nenw" label="Item Name" name="item_name" typeRef="string"/>
      <output id="out_ref_table_nenw" label="Reference Table" name="reference_table" typeRef="string"/>
      <rule id="r_nenw_01">
        <description>Formula para prematuro RN pre-termo e/ou alto risco, po</description>
        <inputEntry id="ie_nenw_01_1"><text>"FI_PREMATURO"</text></inputEntry>
        <outputEntry id="oe_nenw_01_1"><text>true</text></outputEntry>
        <outputEntry id="oe_nenw_01_2"><text>"Formula infantil para RN pre-termo e/ou alto risco, base leite de vaca, com LC-PUFAS, isenta sacarose/gluten, po"</text></outputEntry>
        <outputEntry id="oe_nenw_01_3"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <rule id="r_nenw_02">
        <description>Formula lactea 0-6 meses para neonatos a termo, po</description>
        <inputEntry id="ie_nenw_02_1"><text>"FI_LACTEA_0_6M"</text></inputEntry>
        <outputEntry id="oe_nenw_02_1"><text>true</text></outputEntry>
        <outputEntry id="oe_nenw_02_2"><text>"Formula infantil para lactentes 0-6 meses, base leite de vaca, com DHA/ARA, po"</text></outputEntry>
        <outputEntry id="oe_nenw_02_3"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <rule id="r_nenw_03">
        <description>Formula de nutrientes para RN alto risco, po</description>
        <inputEntry id="ie_nenw_03_1"><text>"FI_NUTRIENTES_NEONATAL"</text></inputEntry>
        <outputEntry id="oe_nenw_03_1"><text>true</text></outputEntry>
        <outputEntry id="oe_nenw_03_2"><text>"Formula de nutrientes para RN alto risco, maltodextrina, gorduras, proteina soro parcialmente hidrolisada, po"</text></outputEntry>
        <outputEntry id="oe_nenw_03_3"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <rule id="r_nenw_04">
        <description>Formula elementar base aminoacidos livres para APLV neonatal, po</description>
        <inputEntry id="ie_nenw_04_1"><text>"FI_ELEMENTAR"</text></inputEntry>
        <outputEntry id="oe_nenw_04_1"><text>true</text></outputEntry>
        <outputEntry id="oe_nenw_04_2"><text>"Formula infantil base aminoacidos livres para APLV, sem sacarose, isenta lactose/gluten, po"</text></outputEntry>
        <outputEntry id="oe_nenw_04_3"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <rule id="r_nenw_05">
        <description>Formula semielementar com lactose para APLV neonatal sem sintomas GI, po</description>
        <inputEntry id="ie_nenw_05_1"><text>"FI_SEMIELEMENTAR_COM_LACTOSE"</text></inputEntry>
        <outputEntry id="oe_nenw_05_1"><text>true</text></outputEntry>
        <outputEntry id="oe_nenw_05_2"><text>"Formula infantil proteina extensamente hidrolisada, com lactose, sem sacarose/frutose, isenta gluten, po"</text></outputEntry>
        <outputEntry id="oe_nenw_05_3"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <rule id="r_nenw_06">
        <description>Formula semielementar sem lactose para APLV neonatal, po</description>
        <inputEntry id="ie_nenw_06_1"><text>"FI_SEMIELEMENTAR_SEM_LACTOSE"</text></inputEntry>
        <outputEntry id="oe_nenw_06_1"><text>true</text></outputEntry>
        <outputEntry id="oe_nenw_06_2"><text>"Formula infantil proteina extensamente hidrolisada, sem lactose/sacarose/frutose, isenta gluten, po"</text></outputEntry>
        <outputEntry id="oe_nenw_06_3"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <rule id="r_nenw_07">
        <description>Formula lactea sem lactose para intolerancia neonatal, po</description>
        <inputEntry id="ie_nenw_07_1"><text>"FI_SEM_LACTOSE"</text></inputEntry>
        <outputEntry id="oe_nenw_07_1"><text>true</text></outputEntry>
        <outputEntry id="oe_nenw_07_2"><text>"Formula infantil 0-12 meses sem lactose, base leite de vaca, isenta sacarose/lactose/gluten, po"</text></outputEntry>
        <outputEntry id="oe_nenw_07_3"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <!-- Catch-all -->
      <rule id="r_nenw_catchall">
        <description>Formula enteral neonatal nao autorizada - requer avaliacao neonatologista e nutricionista</description>
        <inputEntry id="ie_nenw_catchall_1"><text></text></inputEntry>
        <outputEntry id="oe_nenw_catchall_1"><text>false</text></outputEntry>
        <outputEntry id="oe_nenw_catchall_2"><text>"Formula nao encontrada no Apendice VI neonatal - requer avaliacao neonatologista e nutricionista"</text></outputEntry>
        <outputEntry id="oe_nenw_catchall_3"><text>"N/A"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
