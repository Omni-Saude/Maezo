<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="nutrition_parenteral_pricing_def"
             name="Nutrition Parenteral Pricing"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    Precificacao de bolsas de nutricao parenteral por tipo de paciente.
    Valores de referencia (placeholder) por bolsa manipulada conforme Apendice V.
    Fonte: SES/SAIS/CATES/DIASF/GAFAE 119148749
  -->
  <decision id="decision_nutrition_parenteral_pricing" name="Nutrition Parenteral Pricing">
    <decisionTable id="dt_nutrition_parenteral_pricing" hitPolicy="FIRST">
      <input id="in_item_code_npp" label="Item Code">
        <inputExpression id="inExpr_item_code_npp" typeRef="string">
          <text>item_code</text>
        </inputExpression>
      </input>
      <input id="in_patient_type_npp" label="Patient Type">
        <inputExpression id="inExpr_patient_type_npp" typeRef="string">
          <text>patient_type</text>
        </inputExpression>
      </input>
      <output id="out_unit_price_npp" label="Unit Price" name="unit_price" typeRef="number"/>
      <output id="out_currency_npp" label="Currency" name="currency" typeRef="string"/>
      <output id="out_pricing_table_npp" label="Pricing Table" name="pricing_table" typeRef="string"/>
      <!-- ADULTO -->
      <rule id="r_npp_01">
        <description>Adulto sem glutamina com lipideo 10-20% (BR 295269)</description>
        <inputEntry id="ie_npp_01_1"><text>"NP_ADULTO_SEM_GLUT_COM_LIP_10_20"</text></inputEntry>
        <inputEntry id="ie_npp_01_2"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_npp_01_1"><text>150.00</text></outputEntry>
        <outputEntry id="oe_npp_01_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_01_3"><text>"Apendice V - Parenteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_npp_02">
        <description>Adulto sem glutamina sem lipideo (BR 295270)</description>
        <inputEntry id="ie_npp_02_1"><text>"NP_ADULTO_SEM_GLUT_SEM_LIP"</text></inputEntry>
        <inputEntry id="ie_npp_02_2"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_npp_02_1"><text>120.00</text></outputEntry>
        <outputEntry id="oe_npp_02_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_02_3"><text>"Apendice V - Parenteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_npp_03">
        <description>Adulto sem glutamina com lipideo complexo omega (BR 295269)</description>
        <inputEntry id="ie_npp_03_1"><text>"NP_ADULTO_SEM_GLUT_COM_LIP_OMEGA"</text></inputEntry>
        <inputEntry id="ie_npp_03_2"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_npp_03_1"><text>180.00</text></outputEntry>
        <outputEntry id="oe_npp_03_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_03_3"><text>"Apendice V - Parenteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_npp_04">
        <description>Adulto com glutamina com lipideo 10-20% (BR 295267)</description>
        <inputEntry id="ie_npp_04_1"><text>"NP_ADULTO_COM_GLUT_COM_LIP_10_20"</text></inputEntry>
        <inputEntry id="ie_npp_04_2"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_npp_04_1"><text>170.00</text></outputEntry>
        <outputEntry id="oe_npp_04_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_04_3"><text>"Apendice V - Parenteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_npp_05">
        <description>Adulto com glutamina sem lipideo (BR 295268)</description>
        <inputEntry id="ie_npp_05_1"><text>"NP_ADULTO_COM_GLUT_SEM_LIP"</text></inputEntry>
        <inputEntry id="ie_npp_05_2"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_npp_05_1"><text>140.00</text></outputEntry>
        <outputEntry id="oe_npp_05_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_05_3"><text>"Apendice V - Parenteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_npp_06">
        <description>Adulto com glutamina com lipideo complexo omega (BR 295267)</description>
        <inputEntry id="ie_npp_06_1"><text>"NP_ADULTO_COM_GLUT_COM_LIP_OMEGA"</text></inputEntry>
        <inputEntry id="ie_npp_06_2"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_npp_06_1"><text>200.00</text></outputEntry>
        <outputEntry id="oe_npp_06_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_06_3"><text>"Apendice V - Parenteral Adulto"</text></outputEntry>
      </rule>
      <!-- PEDIATRICO -->
      <rule id="r_npp_07">
        <description>Pediatrico sem glutamina (BR 295269)</description>
        <inputEntry id="ie_npp_07_1"><text>"NP_PEDIATRICO_SEM_GLUT"</text></inputEntry>
        <inputEntry id="ie_npp_07_2"><text>"PEDIATRICO"</text></inputEntry>
        <outputEntry id="oe_npp_07_1"><text>160.00</text></outputEntry>
        <outputEntry id="oe_npp_07_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_07_3"><text>"Apendice V - Parenteral Pediatrico"</text></outputEntry>
      </rule>
      <rule id="r_npp_08">
        <description>Pediatrico com glutamina (BR 295267)</description>
        <inputEntry id="ie_npp_08_1"><text>"NP_PEDIATRICO_COM_GLUT"</text></inputEntry>
        <inputEntry id="ie_npp_08_2"><text>"PEDIATRICO"</text></inputEntry>
        <outputEntry id="oe_npp_08_1"><text>180.00</text></outputEntry>
        <outputEntry id="oe_npp_08_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_08_3"><text>"Apendice V - Parenteral Pediatrico"</text></outputEntry>
      </rule>
      <!-- NEONATAL -->
      <rule id="r_npp_09">
        <description>Neonatal sem glutamina (BR 295269)</description>
        <inputEntry id="ie_npp_09_1"><text>"NP_NEONATAL_SEM_GLUT"</text></inputEntry>
        <inputEntry id="ie_npp_09_2"><text>"NEONATAL"</text></inputEntry>
        <outputEntry id="oe_npp_09_1"><text>190.00</text></outputEntry>
        <outputEntry id="oe_npp_09_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_09_3"><text>"Apendice V - Parenteral Neonatal"</text></outputEntry>
      </rule>
      <rule id="r_npp_10">
        <description>Neonatal com glutamina (BR 295267)</description>
        <inputEntry id="ie_npp_10_1"><text>"NP_NEONATAL_COM_GLUT"</text></inputEntry>
        <inputEntry id="ie_npp_10_2"><text>"NEONATAL"</text></inputEntry>
        <outputEntry id="oe_npp_10_1"><text>210.00</text></outputEntry>
        <outputEntry id="oe_npp_10_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_10_3"><text>"Apendice V - Parenteral Neonatal"</text></outputEntry>
      </rule>
      <rule id="r_npp_11">
        <description>Neonatal sem glutamina com lipideo complexo omega (BR 295267)</description>
        <inputEntry id="ie_npp_11_1"><text>"NP_NEONATAL_SEM_GLUT_COM_LIP_OMEGA"</text></inputEntry>
        <inputEntry id="ie_npp_11_2"><text>"NEONATAL"</text></inputEntry>
        <outputEntry id="oe_npp_11_1"><text>220.00</text></outputEntry>
        <outputEntry id="oe_npp_11_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_11_3"><text>"Apendice V - Parenteral Neonatal"</text></outputEntry>
      </rule>
      <rule id="r_npp_12">
        <description>Neonatal com glutamina com lipideo complexo omega (BR 295267)</description>
        <inputEntry id="ie_npp_12_1"><text>"NP_NEONATAL_COM_GLUT_COM_LIP_OMEGA"</text></inputEntry>
        <inputEntry id="ie_npp_12_2"><text>"NEONATAL"</text></inputEntry>
        <outputEntry id="oe_npp_12_1"><text>240.00</text></outputEntry>
        <outputEntry id="oe_npp_12_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_12_3"><text>"Apendice V - Parenteral Neonatal"</text></outputEntry>
      </rule>
      <!-- Catch-all -->
      <rule id="r_npp_catchall">
        <description>Item nao encontrado - preco nao disponivel</description>
        <inputEntry id="ie_npp_catchall_1"><text></text></inputEntry>
        <inputEntry id="ie_npp_catchall_2"><text></text></inputEntry>
        <outputEntry id="oe_npp_catchall_1"><text>0</text></outputEntry>
        <outputEntry id="oe_npp_catchall_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_catchall_3"><text>"N/A - Requer cotacao manual"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
