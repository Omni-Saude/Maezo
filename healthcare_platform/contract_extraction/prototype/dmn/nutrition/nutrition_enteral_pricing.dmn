<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="nutrition_enteral_pricing_def"
             name="Nutrition Enteral Pricing"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    Precificacao de formulas enterais por categoria e tipo de paciente.
    Valores de referencia (placeholder) conforme Apendice VI.
    Fonte: SES/SAIS/COASIS/DASIS/GESNUT 166054889
  -->
  <decision id="decision_nutrition_enteral_pricing" name="Nutrition Enteral Pricing">
    <decisionTable id="dt_nutrition_enteral_pricing" hitPolicy="FIRST">
      <input id="in_item_code_nep" label="Item Code">
        <inputExpression id="inExpr_item_code_nep" typeRef="string">
          <text>item_code</text>
        </inputExpression>
      </input>
      <input id="in_patient_type_nep" label="Patient Type">
        <inputExpression id="inExpr_patient_type_nep" typeRef="string">
          <text>patient_type</text>
        </inputExpression>
      </input>
      <output id="out_unit_price_nep" label="Unit Price" name="unit_price" typeRef="number"/>
      <output id="out_currency_nep" label="Currency" name="currency" typeRef="string"/>
      <output id="out_pricing_table_nep" label="Pricing Table" name="pricing_table" typeRef="string"/>
      <!-- ADULTO PADRAO -->
      <rule id="r_nep_01">
        <description>Formula padrao adulto po</description>
        <inputEntry id="ie_nep_01_1"><text>"NE_ADULTO_PADRAO_PO"</text></inputEntry>
        <inputEntry id="ie_nep_01_2"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_nep_01_1"><text>35.00</text></outputEntry>
        <outputEntry id="oe_nep_01_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_01_3"><text>"Apendice VI - Enteral Adulto Padrao"</text></outputEntry>
      </rule>
      <rule id="r_nep_02">
        <description>Formula padrao adulto com fibras liquida</description>
        <inputEntry id="ie_nep_02_1"><text>"NE_ADULTO_PADRAO_FIBRAS_LIQ"</text></inputEntry>
        <inputEntry id="ie_nep_02_2"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_nep_02_1"><text>42.00</text></outputEntry>
        <outputEntry id="oe_nep_02_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_02_3"><text>"Apendice VI - Enteral Adulto Padrao"</text></outputEntry>
      </rule>
      <rule id="r_nep_03">
        <description>Formula hipercalorica adulto liquida</description>
        <inputEntry id="ie_nep_03_1"><text>"NE_ADULTO_HIPERCALORICA_LIQ"</text></inputEntry>
        <inputEntry id="ie_nep_03_2"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_nep_03_1"><text>55.00</text></outputEntry>
        <outputEntry id="oe_nep_03_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_03_3"><text>"Apendice VI - Enteral Adulto Modificada"</text></outputEntry>
      </rule>
      <rule id="r_nep_04">
        <description>Formula hiperproteica adulto liquida</description>
        <inputEntry id="ie_nep_04_1"><text>"NE_ADULTO_HIPERPROTEICA_LIQ"</text></inputEntry>
        <inputEntry id="ie_nep_04_2"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_nep_04_1"><text>58.00</text></outputEntry>
        <outputEntry id="oe_nep_04_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_04_3"><text>"Apendice VI - Enteral Adulto Modificada"</text></outputEntry>
      </rule>
      <rule id="r_nep_05">
        <description>Formula semielementar adulto liquida</description>
        <inputEntry id="ie_nep_05_1"><text>"NE_ADULTO_SEMIELEMENTAR_LIQ"</text></inputEntry>
        <inputEntry id="ie_nep_05_2"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_nep_05_1"><text>75.00</text></outputEntry>
        <outputEntry id="oe_nep_05_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_05_3"><text>"Apendice VI - Enteral Adulto Modificada"</text></outputEntry>
      </rule>
      <!-- ADULTO ESPECIALIZADA -->
      <rule id="r_nep_06">
        <description>Formula imunomoduladora adulto</description>
        <inputEntry id="ie_nep_06_1"><text>"NE_ADULTO_IMUNOMODULADORA"</text></inputEntry>
        <inputEntry id="ie_nep_06_2"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_nep_06_1"><text>95.00</text></outputEntry>
        <outputEntry id="oe_nep_06_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_06_3"><text>"Apendice VI - Especializada Adulto"</text></outputEntry>
      </rule>
      <rule id="r_nep_07">
        <description>Formula nefropatia dialitico adulto</description>
        <inputEntry id="ie_nep_07_1"><text>"NE_ADULTO_NEFROPATIA_DIALITICO"</text></inputEntry>
        <inputEntry id="ie_nep_07_2"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_nep_07_1"><text>88.00</text></outputEntry>
        <outputEntry id="oe_nep_07_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_07_3"><text>"Apendice VI - Especializada Adulto"</text></outputEntry>
      </rule>
      <rule id="r_nep_08">
        <description>Formula lesao por pressao adulto</description>
        <inputEntry id="ie_nep_08_1"><text>"NE_ADULTO_LESAO_PRESSAO"</text></inputEntry>
        <inputEntry id="ie_nep_08_2"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_nep_08_1"><text>82.00</text></outputEntry>
        <outputEntry id="oe_nep_08_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_08_3"><text>"Apendice VI - Especializada Adulto"</text></outputEntry>
      </rule>
      <!-- PEDIATRICO -->
      <rule id="r_nep_09">
        <description>Formula padrao infantil 0-1 ano</description>
        <inputEntry id="ie_nep_09_1"><text>"NE_INFANTIL_0_1ANO"</text></inputEntry>
        <inputEntry id="ie_nep_09_2"><text>"PEDIATRICO"</text></inputEntry>
        <outputEntry id="oe_nep_09_1"><text>45.00</text></outputEntry>
        <outputEntry id="oe_nep_09_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_09_3"><text>"Apendice VI - Enteral Infantil"</text></outputEntry>
      </rule>
      <rule id="r_nep_10">
        <description>Formula padrao pediatrica acima 1 ano</description>
        <inputEntry id="ie_nep_10_1"><text>"NE_PEDIATRICO_PADRAO_PO"</text></inputEntry>
        <inputEntry id="ie_nep_10_2"><text>"PEDIATRICO"</text></inputEntry>
        <outputEntry id="oe_nep_10_1"><text>48.00</text></outputEntry>
        <outputEntry id="oe_nep_10_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_10_3"><text>"Apendice VI - Enteral Infantil"</text></outputEntry>
      </rule>
      <rule id="r_nep_11">
        <description>Formula cetogenica pediatrica</description>
        <inputEntry id="ie_nep_11_1"><text>"NE_PEDIATRICO_CETOGENICA"</text></inputEntry>
        <inputEntry id="ie_nep_11_2"><text>"PEDIATRICO"</text></inputEntry>
        <outputEntry id="oe_nep_11_1"><text>120.00</text></outputEntry>
        <outputEntry id="oe_nep_11_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_11_3"><text>"Apendice VI - Enteral Infantil Especializada"</text></outputEntry>
      </rule>
      <!-- NEONATAL -->
      <rule id="r_nep_12">
        <description>Formula prematuro neonatal</description>
        <inputEntry id="ie_nep_12_1"><text>"FI_PREMATURO"</text></inputEntry>
        <inputEntry id="ie_nep_12_2"><text>"NEONATAL"</text></inputEntry>
        <outputEntry id="oe_nep_12_1"><text>65.00</text></outputEntry>
        <outputEntry id="oe_nep_12_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_12_3"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <rule id="r_nep_13">
        <description>Formula elementar base aminoacidos livres</description>
        <inputEntry id="ie_nep_13_1"><text>"FI_ELEMENTAR"</text></inputEntry>
        <inputEntry id="ie_nep_13_2"><text>"NEONATAL"</text></inputEntry>
        <outputEntry id="oe_nep_13_1"><text>135.00</text></outputEntry>
        <outputEntry id="oe_nep_13_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_13_3"><text>"Apendice VI - Formulas Infantis Especializada"</text></outputEntry>
      </rule>
      <rule id="r_nep_14">
        <description>Formula nutrientes para RN alto risco</description>
        <inputEntry id="ie_nep_14_1"><text>"FI_NUTRIENTES_NEONATAL"</text></inputEntry>
        <inputEntry id="ie_nep_14_2"><text>"NEONATAL"</text></inputEntry>
        <outputEntry id="oe_nep_14_1"><text>55.00</text></outputEntry>
        <outputEntry id="oe_nep_14_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_14_3"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <!-- Catch-all -->
      <rule id="r_nep_catchall">
        <description>Item nao encontrado - preco nao disponivel</description>
        <inputEntry id="ie_nep_catchall_1"><text></text></inputEntry>
        <inputEntry id="ie_nep_catchall_2"><text></text></inputEntry>
        <outputEntry id="oe_nep_catchall_1"><text>0</text></outputEntry>
        <outputEntry id="oe_nep_catchall_2"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_catchall_3"><text>"N/A - Requer cotacao manual"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
