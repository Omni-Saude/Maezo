<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="nutrition_enteral_authorization_def"
             name="Nutrition Enteral Authorization"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    Regras de autorizacao para terapia nutricional enteral.
    Contrato 4.3.7.5.11: nutricao requer autorizacao em ate 6h da prescricao.
    Reavaliacao a cada 72h ou troca de tipo de terapia.
    Formulas especializadas requerem aprovacao supervisor.
    Fonte: SES/SAIS/COASIS/DASIS/GESNUT 166054889
  -->
  <decision id="decision_nutrition_enteral_authorization" name="Nutrition Enteral Authorization">
    <decisionTable id="dt_nutrition_enteral_authorization" hitPolicy="FIRST">
      <input id="in_proc_code_nea" label="Procedure Code">
        <inputExpression id="inExpr_proc_code_nea" typeRef="string">
          <text>procedure_code</text>
        </inputExpression>
      </input>
      <input id="in_amount_nea" label="Amount">
        <inputExpression id="inExpr_amount_nea" typeRef="number">
          <text>amount</text>
        </inputExpression>
      </input>
      <input id="in_payer_id_nea" label="Payer ID">
        <inputExpression id="inExpr_payer_id_nea" typeRef="string">
          <text>payer_id</text>
        </inputExpression>
      </input>
      <output id="out_requires_auth_nea" label="Requires Auth" name="requires_auth" typeRef="boolean"/>
      <output id="out_auth_type_nea" label="Auth Type" name="auth_type" typeRef="string"/>
      <output id="out_urgency_nea" label="Urgency Level" name="urgency_level" typeRef="string"/>
      <!-- Formulas especializadas alto custo - pre-autorizacao obrigatoria -->
      <rule id="r_nea_01">
        <description>Formula imunomoduladora - requer pre-autorizacao supervisor</description>
        <inputEntry id="ie_nea_01_1"><text>"NE_ADULTO_IMUNOMODULADORA"</text></inputEntry>
        <inputEntry id="ie_nea_01_2"><text></text></inputEntry>
        <inputEntry id="ie_nea_01_3"><text></text></inputEntry>
        <outputEntry id="oe_nea_01_1"><text>true</text></outputEntry>
        <outputEntry id="oe_nea_01_2"><text>"PRE_AUTORIZACAO_SUPERVISOR"</text></outputEntry>
        <outputEntry id="oe_nea_01_3"><text>"URGENTE_6H"</text></outputEntry>
      </rule>
      <rule id="r_nea_02">
        <description>Formula para DII - requer pre-autorizacao supervisor</description>
        <inputEntry id="ie_nea_02_1"><text>"NE_ADULTO_DII"</text></inputEntry>
        <inputEntry id="ie_nea_02_2"><text></text></inputEntry>
        <inputEntry id="ie_nea_02_3"><text></text></inputEntry>
        <outputEntry id="oe_nea_02_1"><text>true</text></outputEntry>
        <outputEntry id="oe_nea_02_2"><text>"PRE_AUTORIZACAO_SUPERVISOR"</text></outputEntry>
        <outputEntry id="oe_nea_02_3"><text>"URGENTE_6H"</text></outputEntry>
      </rule>
      <rule id="r_nea_03">
        <description>Formula nefropatia dialitico - requer pre-autorizacao</description>
        <inputEntry id="ie_nea_03_1"><text>"NE_ADULTO_NEFROPATIA_DIALITICO"</text></inputEntry>
        <inputEntry id="ie_nea_03_2"><text></text></inputEntry>
        <inputEntry id="ie_nea_03_3"><text></text></inputEntry>
        <outputEntry id="oe_nea_03_1"><text>true</text></outputEntry>
        <outputEntry id="oe_nea_03_2"><text>"PRE_AUTORIZACAO_SUPERVISOR"</text></outputEntry>
        <outputEntry id="oe_nea_03_3"><text>"URGENTE_6H"</text></outputEntry>
      </rule>
      <rule id="r_nea_04">
        <description>Formula nefropatia conservador - requer pre-autorizacao</description>
        <inputEntry id="ie_nea_04_1"><text>"NE_ADULTO_NEFROPATIA_CONSERVADOR"</text></inputEntry>
        <inputEntry id="ie_nea_04_2"><text></text></inputEntry>
        <inputEntry id="ie_nea_04_3"><text></text></inputEntry>
        <outputEntry id="oe_nea_04_1"><text>true</text></outputEntry>
        <outputEntry id="oe_nea_04_2"><text>"PRE_AUTORIZACAO_SUPERVISOR"</text></outputEntry>
        <outputEntry id="oe_nea_04_3"><text>"URGENTE_6H"</text></outputEntry>
      </rule>
      <rule id="r_nea_05">
        <description>Formula cetogenica pediatrica - requer pre-autorizacao neuropediatria</description>
        <inputEntry id="ie_nea_05_1"><text>"NE_PEDIATRICO_CETOGENICA"</text></inputEntry>
        <inputEntry id="ie_nea_05_2"><text></text></inputEntry>
        <inputEntry id="ie_nea_05_3"><text></text></inputEntry>
        <outputEntry id="oe_nea_05_1"><text>true</text></outputEntry>
        <outputEntry id="oe_nea_05_2"><text>"PRE_AUTORIZACAO_NEUROPEDIATRIA"</text></outputEntry>
        <outputEntry id="oe_nea_05_3"><text>"URGENTE_6H"</text></outputEntry>
      </rule>
      <rule id="r_nea_06">
        <description>Formula elementar (aminoacidos livres) - requer pre-autorizacao alergista</description>
        <inputEntry id="ie_nea_06_1"><text>"FI_ELEMENTAR"</text></inputEntry>
        <inputEntry id="ie_nea_06_2"><text></text></inputEntry>
        <inputEntry id="ie_nea_06_3"><text></text></inputEntry>
        <outputEntry id="oe_nea_06_1"><text>true</text></outputEntry>
        <outputEntry id="oe_nea_06_2"><text>"PRE_AUTORIZACAO_ALERGISTA"</text></outputEntry>
        <outputEntry id="oe_nea_06_3"><text>"URGENTE_6H"</text></outputEntry>
      </rule>
      <!-- Formulas padrao com valor alto - requer autorizacao por valor -->
      <rule id="r_nea_07">
        <description>Qualquer formula enteral com valor acima de 5000 BRL - requer autorizacao financeira</description>
        <inputEntry id="ie_nea_07_1"><text></text></inputEntry>
        <inputEntry id="ie_nea_07_2"><text>&gt; 5000</text></inputEntry>
        <inputEntry id="ie_nea_07_3"><text></text></inputEntry>
        <outputEntry id="oe_nea_07_1"><text>true</text></outputEntry>
        <outputEntry id="oe_nea_07_2"><text>"AUTORIZACAO_FINANCEIRA"</text></outputEntry>
        <outputEntry id="oe_nea_07_3"><text>"NORMAL_24H"</text></outputEntry>
      </rule>
      <!-- Formulas padrao dentro do limite - autorizacao automatica -->
      <rule id="r_nea_08">
        <description>Formula padrao adulto dentro do limite - autorizacao automatica em 6h</description>
        <inputEntry id="ie_nea_08_1"><text></text></inputEntry>
        <inputEntry id="ie_nea_08_2"><text>&lt;= 5000</text></inputEntry>
        <inputEntry id="ie_nea_08_3"><text>"SES_DF"</text></inputEntry>
        <outputEntry id="oe_nea_08_1"><text>true</text></outputEntry>
        <outputEntry id="oe_nea_08_2"><text>"AUTORIZACAO_AUTOMATICA"</text></outputEntry>
        <outputEntry id="oe_nea_08_3"><text>"URGENTE_6H"</text></outputEntry>
      </rule>
      <!-- Catch-all -->
      <rule id="r_nea_catchall">
        <description>Caso nao coberto - requer avaliacao manual do gestor de contratos</description>
        <inputEntry id="ie_nea_catchall_1"><text></text></inputEntry>
        <inputEntry id="ie_nea_catchall_2"><text></text></inputEntry>
        <inputEntry id="ie_nea_catchall_3"><text></text></inputEntry>
        <outputEntry id="oe_nea_catchall_1"><text>true</text></outputEntry>
        <outputEntry id="oe_nea_catchall_2"><text>"AVALIACAO_MANUAL"</text></outputEntry>
        <outputEntry id="oe_nea_catchall_3"><text>"NORMAL_24H"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
