<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="nutrition_enteral_adult_whitelist_def"
             name="Nutrition Enteral Adult Whitelist"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    Whitelist de formulas enterais adulto conforme Apendice VI secoes 1 e 2.
    Secao 1: Formulas para terapia nutricional enteral adulto (9 itens)
    Secao 2: Formulas especializadas adulto (6 itens)
    Fonte: SES/SAIS/COASIS/DASIS/GESNUT 166054889
  -->
  <decision id="decision_nutrition_enteral_adult_whitelist" name="Nutrition Enteral Adult Whitelist">
    <decisionTable id="dt_nutrition_enteral_adult_whitelist" hitPolicy="FIRST">
      <input id="in_code_neaw" label="Code">
        <inputExpression id="inExpr_code_neaw" typeRef="string">
          <text>code</text>
        </inputExpression>
      </input>
      <output id="out_authorized_neaw" label="Authorized" name="authorized" typeRef="boolean"/>
      <output id="out_item_name_neaw" label="Item Name" name="item_name" typeRef="string"/>
      <output id="out_ref_table_neaw" label="Reference Table" name="reference_table" typeRef="string"/>
      <!-- Secao 1: Formulas padrao adulto -->
      <rule id="r_neaw_01">
        <description>Padrao adulto polimerica sem fibras, normocalorica, po</description>
        <inputEntry id="ie_neaw_01_1"><text>"NE_ADULTO_PADRAO_PO"</text></inputEntry>
        <outputEntry id="oe_neaw_01_1"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_01_2"><text>"Formula padrao enteral adulto polimerica sem fibras, normocalorica 0,9-1,2 kcal/ml, normoproteica, sem sacarose, isenta gluten, po"</text></outputEntry>
        <outputEntry id="oe_neaw_01_3"><text>"Apendice VI - Enteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_02">
        <description>Padrao adulto com fibras, liquida</description>
        <inputEntry id="ie_neaw_02_1"><text>"NE_ADULTO_PADRAO_FIBRAS_LIQ"</text></inputEntry>
        <outputEntry id="oe_neaw_02_1"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_02_2"><text>"Formula padrao enteral adulto com fibras, normocalorica, normoproteica, sem sacarose, isenta gluten, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_02_3"><text>"Apendice VI - Enteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_03">
        <description>Padrao adulto com fibras, sistema fechado</description>
        <inputEntry id="ie_neaw_03_1"><text>"NE_ADULTO_PADRAO_FIBRAS_SF"</text></inputEntry>
        <outputEntry id="oe_neaw_03_1"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_03_2"><text>"Formula padrao enteral adulto com fibras, normocalorica, normoproteica, sistema fechado, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_03_3"><text>"Apendice VI - Enteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_04">
        <description>Hipercalorica adulto, liquida</description>
        <inputEntry id="ie_neaw_04_1"><text>"NE_ADULTO_HIPERCALORICA_LIQ"</text></inputEntry>
        <outputEntry id="oe_neaw_04_1"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_04_2"><text>"Formula hipercalorica adulto &gt;=1,5 kcal/ml, normoproteica, com ou sem fibras, sem sacarose, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_04_3"><text>"Apendice VI - Enteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_05">
        <description>Hipercalorica adulto, sistema fechado</description>
        <inputEntry id="ie_neaw_05_1"><text>"NE_ADULTO_HIPERCALORICA_SF"</text></inputEntry>
        <outputEntry id="oe_neaw_05_1"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_05_2"><text>"Formula hipercalorica adulto &gt;=1,5 kcal/ml, normoproteica, com ou sem fibras, sistema fechado, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_05_3"><text>"Apendice VI - Enteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_06">
        <description>Hiperproteica adulto, liquida</description>
        <inputEntry id="ie_neaw_06_1"><text>"NE_ADULTO_HIPERPROTEICA_LIQ"</text></inputEntry>
        <outputEntry id="oe_neaw_06_1"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_06_2"><text>"Formula hiperproteica adulto &gt;=20% VET, sem sacarose, sem fibras, isenta lactose/gluten, &gt;=0,9 kcal/ml, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_06_3"><text>"Apendice VI - Enteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_07">
        <description>Hiperproteica adulto, sistema fechado</description>
        <inputEntry id="ie_neaw_07_1"><text>"NE_ADULTO_HIPERPROTEICA_SF"</text></inputEntry>
        <outputEntry id="oe_neaw_07_1"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_07_2"><text>"Formula hiperproteica adulto &gt;=20% VET, hipercalorica &gt;=1,2 kcal/ml, com ou sem fibras, sistema fechado, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_07_3"><text>"Apendice VI - Enteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_08">
        <description>Semielementar adulto, liquida</description>
        <inputEntry id="ie_neaw_08_1"><text>"NE_ADULTO_SEMIELEMENTAR_LIQ"</text></inputEntry>
        <outputEntry id="oe_neaw_08_1"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_08_2"><text>"Formula oligomerica adulto para sindromes disabsortivas, isenta lactose/gluten, sem fibras, &gt;=0,9 kcal/ml, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_08_3"><text>"Apendice VI - Enteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_09">
        <description>Semielementar adulto, sistema fechado</description>
        <inputEntry id="ie_neaw_09_1"><text>"NE_ADULTO_SEMIELEMENTAR_SF"</text></inputEntry>
        <outputEntry id="oe_neaw_09_1"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_09_2"><text>"Formula oligomerica adulto para disturbios disabsortivos, isenta lactose/gluten, &gt;=20% proteina, sistema fechado, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_09_3"><text>"Apendice VI - Enteral Adulto"</text></outputEntry>
      </rule>
      <!-- Secao 2: Formulas especializadas adulto -->
      <rule id="r_neaw_10">
        <description>Imunomoduladora adulto, po</description>
        <inputEntry id="ie_neaw_10_1"><text>"NE_ADULTO_IMUNOMODULADORA"</text></inputEntry>
        <outputEntry id="oe_neaw_10_1"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_10_2"><text>"Formula imunomoduladora adulto com arginina e nucleotideos, hiperproteica &gt;=20% VET, &gt;=0,9 kcal/ml, po"</text></outputEntry>
        <outputEntry id="oe_neaw_10_3"><text>"Apendice VI - Especializada Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_11">
        <description>Doenca inflamatoria intestinal adulto, po</description>
        <inputEntry id="ie_neaw_11_1"><text>"NE_ADULTO_DII"</text></inputEntry>
        <outputEntry id="oe_neaw_11_1"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_11_2"><text>"Formula para DII fase ativa, polimerica, isenta lactose/gluten, com TCM, &gt;=0,9 kcal/ml, &gt;=10% proteina, po"</text></outputEntry>
        <outputEntry id="oe_neaw_11_3"><text>"Apendice VI - Especializada Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_12">
        <description>Nefropatia tratamento conservador adulto, liquida</description>
        <inputEntry id="ie_neaw_12_1"><text>"NE_ADULTO_NEFROPATIA_CONSERVADOR"</text></inputEntry>
        <outputEntry id="oe_neaw_12_1"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_12_2"><text>"Formula para DRC tratamento conservador, &gt;1,2 kcal/ml, proteina &lt;10% VET, baixo Na/K, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_12_3"><text>"Apendice VI - Especializada Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_13">
        <description>Nefropatia dialitico adulto, liquida</description>
        <inputEntry id="ie_neaw_13_1"><text>"NE_ADULTO_NEFROPATIA_DIALITICO"</text></inputEntry>
        <outputEntry id="oe_neaw_13_1"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_13_2"><text>"Formula para DRC em dialise, &gt;=1,5 kcal/ml, proteina &gt;=15% VET, baixo Na/K/P, isenta gluten, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_13_3"><text>"Apendice VI - Especializada Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_14">
        <description>Lesao por pressao adulto, liquida</description>
        <inputEntry id="ie_neaw_14_1"><text>"NE_ADULTO_LESAO_PRESSAO"</text></inputEntry>
        <outputEntry id="oe_neaw_14_1"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_14_2"><text>"Formula para lesao por pressao/cicatrizacao, com arginina, alto teor vit A/C/E/Zn/Cu/Se, &gt;=20% proteina, &gt;=0,9 kcal/ml, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_14_3"><text>"Apendice VI - Especializada Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_15">
        <description>Controle glicemico adulto, sistema fechado</description>
        <inputEntry id="ie_neaw_15_1"><text>"NE_ADULTO_CONTROLE_GLICEMICO"</text></inputEntry>
        <outputEntry id="oe_neaw_15_1"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_15_2"><text>"Formula para diabeticos/controle glicemico, com fibras, normocalorica, CHO &lt;50% VET, MUFAS &gt;=20% VET, sistema fechado, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_15_3"><text>"Apendice VI - Especializada Adulto"</text></outputEntry>
      </rule>
      <!-- Catch-all -->
      <rule id="r_neaw_catchall">
        <description>Formula enteral adulto nao autorizada - requer analise nutricional</description>
        <inputEntry id="ie_neaw_catchall_1"><text></text></inputEntry>
        <outputEntry id="oe_neaw_catchall_1"><text>false</text></outputEntry>
        <outputEntry id="oe_neaw_catchall_2"><text>"Formula nao encontrada no Apendice VI adulto - requer analise do nutricionista"</text></outputEntry>
        <outputEntry id="oe_neaw_catchall_3"><text>"N/A"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
