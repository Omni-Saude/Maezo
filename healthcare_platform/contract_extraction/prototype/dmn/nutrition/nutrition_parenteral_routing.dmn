<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="nutrition_parenteral_routing_def"
             name="Nutrition Parenteral Routing"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    Roteamento de nutricao parenteral por tipo de paciente, glutamina e composicao lipidica.
    Baseado no Apendice V - codigos BR 295267, 295268, 295269, 295270.
    Fonte: SES/SAIS/CATES/DIASF/GAFAE 119148749
  -->
  <decision id="decision_nutrition_parenteral_routing" name="Nutrition Parenteral Routing">
    <decisionTable id="dt_nutrition_parenteral_routing" hitPolicy="FIRST">
      <input id="in_patient_type_npr" label="Patient Type">
        <inputExpression id="inExpr_patient_type_npr" typeRef="string">
          <text>patient_type</text>
        </inputExpression>
      </input>
      <input id="in_glutamine_npr" label="Glutamine">
        <inputExpression id="inExpr_glutamine_npr" typeRef="string">
          <text>glutamine</text>
        </inputExpression>
      </input>
      <input id="in_lipid_type_npr" label="Lipid Type">
        <inputExpression id="inExpr_lipid_type_npr" typeRef="string">
          <text>lipid_type</text>
        </inputExpression>
      </input>
      <output id="out_formula_code_npr" label="Formula Code" name="formula_code" typeRef="string"/>
      <output id="out_bag_desc_npr" label="Bag Description" name="bag_description" typeRef="string"/>
      <output id="out_volume_range_npr" label="Volume Range" name="volume_range" typeRef="string"/>
      <!-- ADULTO -->
      <rule id="r_npr_01">
        <description>Adulto sem glutamina com lipideo 10-20%</description>
        <inputEntry id="ie_npr_01_1"><text>"ADULTO"</text></inputEntry>
        <inputEntry id="ie_npr_01_2"><text>"SEM"</text></inputEntry>
        <inputEntry id="ie_npr_01_3"><text>"LIPIDEO_10_20"</text></inputEntry>
        <outputEntry id="oe_npr_01_1"><text>"NP_ADULTO_SEM_GLUT_COM_LIP_10_20"</text></outputEntry>
        <outputEntry id="oe_npr_01_2"><text>"Bolsa manipulada adulto, aminoacidos sem glutamina, emulsao lipidica 10-20% (BR 295269)"</text></outputEntry>
        <outputEntry id="oe_npr_01_3"><text>"1000-3000 mL"</text></outputEntry>
      </rule>
      <rule id="r_npr_02">
        <description>Adulto sem glutamina sem lipideo</description>
        <inputEntry id="ie_npr_02_1"><text>"ADULTO"</text></inputEntry>
        <inputEntry id="ie_npr_02_2"><text>"SEM"</text></inputEntry>
        <inputEntry id="ie_npr_02_3"><text>"SEM_LIPIDEO"</text></inputEntry>
        <outputEntry id="oe_npr_02_1"><text>"NP_ADULTO_SEM_GLUT_SEM_LIP"</text></outputEntry>
        <outputEntry id="oe_npr_02_2"><text>"Bolsa manipulada adulto, aminoacidos sem glutamina, sem emulsao lipidica (BR 295270)"</text></outputEntry>
        <outputEntry id="oe_npr_02_3"><text>"1000-3000 mL"</text></outputEntry>
      </rule>
      <rule id="r_npr_03">
        <description>Adulto sem glutamina com lipideo complexo omega</description>
        <inputEntry id="ie_npr_03_1"><text>"ADULTO"</text></inputEntry>
        <inputEntry id="ie_npr_03_2"><text>"SEM"</text></inputEntry>
        <inputEntry id="ie_npr_03_3"><text>"LIPIDEO_OMEGA"</text></inputEntry>
        <outputEntry id="oe_npr_03_1"><text>"NP_ADULTO_SEM_GLUT_COM_LIP_OMEGA"</text></outputEntry>
        <outputEntry id="oe_npr_03_2"><text>"Bolsa manipulada adulto, aminoacidos sem glutamina, emulsao lipidica complexa omega 3,6,9 (BR 295269)"</text></outputEntry>
        <outputEntry id="oe_npr_03_3"><text>"1000-3000 mL"</text></outputEntry>
      </rule>
      <rule id="r_npr_04">
        <description>Adulto com glutamina com lipideo 10-20%</description>
        <inputEntry id="ie_npr_04_1"><text>"ADULTO"</text></inputEntry>
        <inputEntry id="ie_npr_04_2"><text>"COM"</text></inputEntry>
        <inputEntry id="ie_npr_04_3"><text>"LIPIDEO_10_20"</text></inputEntry>
        <outputEntry id="oe_npr_04_1"><text>"NP_ADULTO_COM_GLUT_COM_LIP_10_20"</text></outputEntry>
        <outputEntry id="oe_npr_04_2"><text>"Bolsa manipulada adulto, aminoacidos com glutamina, emulsao lipidica 10-20% (BR 295267)"</text></outputEntry>
        <outputEntry id="oe_npr_04_3"><text>"1000-3000 mL"</text></outputEntry>
      </rule>
      <rule id="r_npr_05">
        <description>Adulto com glutamina sem lipideo</description>
        <inputEntry id="ie_npr_05_1"><text>"ADULTO"</text></inputEntry>
        <inputEntry id="ie_npr_05_2"><text>"COM"</text></inputEntry>
        <inputEntry id="ie_npr_05_3"><text>"SEM_LIPIDEO"</text></inputEntry>
        <outputEntry id="oe_npr_05_1"><text>"NP_ADULTO_COM_GLUT_SEM_LIP"</text></outputEntry>
        <outputEntry id="oe_npr_05_2"><text>"Bolsa manipulada adulto, aminoacidos com glutamina, sem emulsao lipidica (BR 295268)"</text></outputEntry>
        <outputEntry id="oe_npr_05_3"><text>"1000-3000 mL"</text></outputEntry>
      </rule>
      <rule id="r_npr_06">
        <description>Adulto com glutamina com lipideo complexo omega</description>
        <inputEntry id="ie_npr_06_1"><text>"ADULTO"</text></inputEntry>
        <inputEntry id="ie_npr_06_2"><text>"COM"</text></inputEntry>
        <inputEntry id="ie_npr_06_3"><text>"LIPIDEO_OMEGA"</text></inputEntry>
        <outputEntry id="oe_npr_06_1"><text>"NP_ADULTO_COM_GLUT_COM_LIP_OMEGA"</text></outputEntry>
        <outputEntry id="oe_npr_06_2"><text>"Bolsa manipulada adulto, aminoacidos com glutamina, emulsao lipidica complexa omega 3,6,9 (BR 295267)"</text></outputEntry>
        <outputEntry id="oe_npr_06_3"><text>"1000-3000 mL"</text></outputEntry>
      </rule>
      <!-- PEDIATRICO -->
      <rule id="r_npr_07">
        <description>Pediatrico sem glutamina</description>
        <inputEntry id="ie_npr_07_1"><text>"PEDIATRICO"</text></inputEntry>
        <inputEntry id="ie_npr_07_2"><text>"SEM"</text></inputEntry>
        <inputEntry id="ie_npr_07_3"><text></text></inputEntry>
        <outputEntry id="oe_npr_07_1"><text>"NP_PEDIATRICO_SEM_GLUT"</text></outputEntry>
        <outputEntry id="oe_npr_07_2"><text>"Bolsa manipulada pediatrica, aminoacidos sem glutamina, com ou sem lipideo 10-20% (BR 295269)"</text></outputEntry>
        <outputEntry id="oe_npr_07_3"><text>"500-2000 mL"</text></outputEntry>
      </rule>
      <rule id="r_npr_08">
        <description>Pediatrico com glutamina</description>
        <inputEntry id="ie_npr_08_1"><text>"PEDIATRICO"</text></inputEntry>
        <inputEntry id="ie_npr_08_2"><text>"COM"</text></inputEntry>
        <inputEntry id="ie_npr_08_3"><text></text></inputEntry>
        <outputEntry id="oe_npr_08_1"><text>"NP_PEDIATRICO_COM_GLUT"</text></outputEntry>
        <outputEntry id="oe_npr_08_2"><text>"Bolsa manipulada pediatrica, aminoacidos com glutamina, com ou sem lipideo 10-20% (BR 295267)"</text></outputEntry>
        <outputEntry id="oe_npr_08_3"><text>"500-2000 mL"</text></outputEntry>
      </rule>
      <!-- NEONATAL -->
      <rule id="r_npr_09">
        <description>Neonatal sem glutamina padrao</description>
        <inputEntry id="ie_npr_09_1"><text>"NEONATAL"</text></inputEntry>
        <inputEntry id="ie_npr_09_2"><text>"SEM"</text></inputEntry>
        <inputEntry id="ie_npr_09_3"><text>"LIPIDEO_10_20"</text></inputEntry>
        <outputEntry id="oe_npr_09_1"><text>"NP_NEONATAL_SEM_GLUT"</text></outputEntry>
        <outputEntry id="oe_npr_09_2"><text>"Bolsa manipulada neonatal, aminoacidos sem glutamina, com ou sem lipideo 10-20% (BR 295269)"</text></outputEntry>
        <outputEntry id="oe_npr_09_3"><text>"ate 500 mL"</text></outputEntry>
      </rule>
      <rule id="r_npr_10">
        <description>Neonatal com glutamina padrao</description>
        <inputEntry id="ie_npr_10_1"><text>"NEONATAL"</text></inputEntry>
        <inputEntry id="ie_npr_10_2"><text>"COM"</text></inputEntry>
        <inputEntry id="ie_npr_10_3"><text>"LIPIDEO_10_20"</text></inputEntry>
        <outputEntry id="oe_npr_10_1"><text>"NP_NEONATAL_COM_GLUT"</text></outputEntry>
        <outputEntry id="oe_npr_10_2"><text>"Bolsa manipulada neonatal, aminoacidos com glutamina, com ou sem lipideo 10-20% (BR 295267)"</text></outputEntry>
        <outputEntry id="oe_npr_10_3"><text>"ate 500 mL"</text></outputEntry>
      </rule>
      <rule id="r_npr_11">
        <description>Neonatal sem glutamina com lipideo complexo omega</description>
        <inputEntry id="ie_npr_11_1"><text>"NEONATAL"</text></inputEntry>
        <inputEntry id="ie_npr_11_2"><text>"SEM"</text></inputEntry>
        <inputEntry id="ie_npr_11_3"><text>"LIPIDEO_OMEGA"</text></inputEntry>
        <outputEntry id="oe_npr_11_1"><text>"NP_NEONATAL_SEM_GLUT_COM_LIP_OMEGA"</text></outputEntry>
        <outputEntry id="oe_npr_11_2"><text>"Bolsa manipulada neonatal, aminoacidos sem glutamina, emulsao lipidica complexa omega 3,6,9 (BR 295267)"</text></outputEntry>
        <outputEntry id="oe_npr_11_3"><text>"ate 500 mL"</text></outputEntry>
      </rule>
      <rule id="r_npr_12">
        <description>Neonatal com glutamina com lipideo complexo omega</description>
        <inputEntry id="ie_npr_12_1"><text>"NEONATAL"</text></inputEntry>
        <inputEntry id="ie_npr_12_2"><text>"COM"</text></inputEntry>
        <inputEntry id="ie_npr_12_3"><text>"LIPIDEO_OMEGA"</text></inputEntry>
        <outputEntry id="oe_npr_12_1"><text>"NP_NEONATAL_COM_GLUT_COM_LIP_OMEGA"</text></outputEntry>
        <outputEntry id="oe_npr_12_2"><text>"Bolsa manipulada neonatal, aminoacidos com glutamina, emulsao lipidica complexa omega 3,6,9 (BR 295267)"</text></outputEntry>
        <outputEntry id="oe_npr_12_3"><text>"ate 500 mL"</text></outputEntry>
      </rule>
      <!-- Catch-all -->
      <rule id="r_npr_catchall">
        <description>Combinacao nao padronizada - requer avaliacao do farmaceutico e autorizacao medica</description>
        <inputEntry id="ie_npr_catchall_1"><text></text></inputEntry>
        <inputEntry id="ie_npr_catchall_2"><text></text></inputEntry>
        <inputEntry id="ie_npr_catchall_3"><text></text></inputEntry>
        <outputEntry id="oe_npr_catchall_1"><text>"NP_NAO_PADRONIZADA"</text></outputEntry>
        <outputEntry id="oe_npr_catchall_2"><text>"Combinacao nao padronizada - requer avaliacao farmaceutica e autorizacao medico supervisor em ate 6h (Contrato 4.3.7.5.11)"</text></outputEntry>
        <outputEntry id="oe_npr_catchall_3"><text>"N/A"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
