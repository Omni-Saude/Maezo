<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="nutrition_parenteral_whitelist_def"
             name="Nutrition Parenteral Whitelist"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    Whitelist de bolsas de nutricao parenteral autorizadas conforme Apendice V.
    Codigos BR referencia: 295267, 295268, 295269, 295270.
    Fonte: SES/SAIS/CATES/DIASF/GAFAE 119148749
  -->
  <decision id="decision_nutrition_parenteral_whitelist" name="Nutrition Parenteral Whitelist">
    <decisionTable id="dt_nutrition_parenteral_whitelist" hitPolicy="FIRST">
      <input id="in_code_npw" label="BR Code">
        <inputExpression id="inExpr_code_npw" typeRef="string">
          <text>code</text>
        </inputExpression>
      </input>
      <output id="out_authorized_npw" label="Authorized" name="authorized" typeRef="boolean"/>
      <output id="out_item_name_npw" label="Item Name" name="item_name" typeRef="string"/>
      <output id="out_ref_table_npw" label="Reference Table" name="reference_table" typeRef="string"/>
      <!-- Adulto sem glutamina, com emulsao lipidica 10-20% -->
      <rule id="r_npw_01">
        <description>Adulto, aminoacidos sem glutamina, com emulsao lipidica 10-20% (BR 295269)</description>
        <inputEntry id="ie_npw_01_1"><text>"NP_ADULTO_SEM_GLUT_COM_LIP_10_20"</text></inputEntry>
        <outputEntry id="oe_npw_01_1"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_01_2"><text>"NP adulto sem glutamina com emulsao lipidica 10-20%, bolsa 1000-3000mL"</text></outputEntry>
        <outputEntry id="oe_npw_01_3"><text>"Apendice V - BR 295269"</text></outputEntry>
      </rule>
      <!-- Adulto sem glutamina, sem emulsao lipidica -->
      <rule id="r_npw_02">
        <description>Adulto, aminoacidos sem glutamina, sem emulsao lipidica (BR 295270)</description>
        <inputEntry id="ie_npw_02_1"><text>"NP_ADULTO_SEM_GLUT_SEM_LIP"</text></inputEntry>
        <outputEntry id="oe_npw_02_1"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_02_2"><text>"NP adulto sem glutamina sem emulsao lipidica, bolsa 1000-3000mL"</text></outputEntry>
        <outputEntry id="oe_npw_02_3"><text>"Apendice V - BR 295270"</text></outputEntry>
      </rule>
      <!-- Adulto sem glutamina, com emulsao lipidica complexa omega 3,6,9 -->
      <rule id="r_npw_03">
        <description>Adulto, aminoacidos sem glutamina, com emulsao lipidica complexa omega 3,6,9 (BR 295269)</description>
        <inputEntry id="ie_npw_03_1"><text>"NP_ADULTO_SEM_GLUT_COM_LIP_OMEGA"</text></inputEntry>
        <outputEntry id="oe_npw_03_1"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_03_2"><text>"NP adulto sem glutamina com emulsao lipidica complexa omega 3,6,9, bolsa 1000-3000mL"</text></outputEntry>
        <outputEntry id="oe_npw_03_3"><text>"Apendice V - BR 295269"</text></outputEntry>
      </rule>
      <!-- Adulto com glutamina, com emulsao lipidica 10-20% -->
      <rule id="r_npw_04">
        <description>Adulto, aminoacidos com glutamina, com emulsao lipidica 10-20% (BR 295267)</description>
        <inputEntry id="ie_npw_04_1"><text>"NP_ADULTO_COM_GLUT_COM_LIP_10_20"</text></inputEntry>
        <outputEntry id="oe_npw_04_1"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_04_2"><text>"NP adulto com glutamina com emulsao lipidica 10-20%, bolsa 1000-3000mL"</text></outputEntry>
        <outputEntry id="oe_npw_04_3"><text>"Apendice V - BR 295267"</text></outputEntry>
      </rule>
      <!-- Adulto com glutamina, sem emulsao lipidica -->
      <rule id="r_npw_05">
        <description>Adulto, aminoacidos com glutamina, sem emulsao lipidica (BR 295268)</description>
        <inputEntry id="ie_npw_05_1"><text>"NP_ADULTO_COM_GLUT_SEM_LIP"</text></inputEntry>
        <outputEntry id="oe_npw_05_1"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_05_2"><text>"NP adulto com glutamina sem emulsao lipidica, bolsa 1000-3000mL"</text></outputEntry>
        <outputEntry id="oe_npw_05_3"><text>"Apendice V - BR 295268"</text></outputEntry>
      </rule>
      <!-- Adulto com glutamina, com emulsao lipidica complexa omega 3,6,9 -->
      <rule id="r_npw_06">
        <description>Adulto, aminoacidos com glutamina, com emulsao lipidica complexa omega 3,6,9 (BR 295267)</description>
        <inputEntry id="ie_npw_06_1"><text>"NP_ADULTO_COM_GLUT_COM_LIP_OMEGA"</text></inputEntry>
        <outputEntry id="oe_npw_06_1"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_06_2"><text>"NP adulto com glutamina com emulsao lipidica complexa omega 3,6,9, bolsa 1000-3000mL"</text></outputEntry>
        <outputEntry id="oe_npw_06_3"><text>"Apendice V - BR 295267"</text></outputEntry>
      </rule>
      <!-- Pediatrico sem glutamina -->
      <rule id="r_npw_07">
        <description>Pediatrico, aminoacidos sem glutamina, com ou sem lipideo (BR 295269)</description>
        <inputEntry id="ie_npw_07_1"><text>"NP_PEDIATRICO_SEM_GLUT"</text></inputEntry>
        <outputEntry id="oe_npw_07_1"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_07_2"><text>"NP pediatrico sem glutamina com ou sem emulsao lipidica 10-20%, bolsa 500-2000mL"</text></outputEntry>
        <outputEntry id="oe_npw_07_3"><text>"Apendice V - BR 295269"</text></outputEntry>
      </rule>
      <!-- Pediatrico com glutamina -->
      <rule id="r_npw_08">
        <description>Pediatrico, aminoacidos com glutamina, com ou sem lipideo (BR 295267)</description>
        <inputEntry id="ie_npw_08_1"><text>"NP_PEDIATRICO_COM_GLUT"</text></inputEntry>
        <outputEntry id="oe_npw_08_1"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_08_2"><text>"NP pediatrico com glutamina com ou sem emulsao lipidica 10-20%, bolsa 500-2000mL"</text></outputEntry>
        <outputEntry id="oe_npw_08_3"><text>"Apendice V - BR 295267"</text></outputEntry>
      </rule>
      <!-- Neonatal sem glutamina -->
      <rule id="r_npw_09">
        <description>Neonatal, aminoacidos sem glutamina, com ou sem lipideo (BR 295269)</description>
        <inputEntry id="ie_npw_09_1"><text>"NP_NEONATAL_SEM_GLUT"</text></inputEntry>
        <outputEntry id="oe_npw_09_1"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_09_2"><text>"NP neonatal sem glutamina com ou sem emulsao lipidica 10-20%, bolsa ate 500mL"</text></outputEntry>
        <outputEntry id="oe_npw_09_3"><text>"Apendice V - BR 295269"</text></outputEntry>
      </rule>
      <!-- Neonatal com glutamina -->
      <rule id="r_npw_10">
        <description>Neonatal, aminoacidos com glutamina, com ou sem lipideo (BR 295267)</description>
        <inputEntry id="ie_npw_10_1"><text>"NP_NEONATAL_COM_GLUT"</text></inputEntry>
        <outputEntry id="oe_npw_10_1"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_10_2"><text>"NP neonatal com glutamina com ou sem emulsao lipidica 10-20%, bolsa ate 500mL"</text></outputEntry>
        <outputEntry id="oe_npw_10_3"><text>"Apendice V - BR 295267"</text></outputEntry>
      </rule>
      <!-- Neonatal sem glutamina, com lipideo complexo omega -->
      <rule id="r_npw_11">
        <description>Neonatal, aminoacidos sem glutamina, com emulsao lipidica complexa omega 3,6,9 (BR 295267)</description>
        <inputEntry id="ie_npw_11_1"><text>"NP_NEONATAL_SEM_GLUT_COM_LIP_OMEGA"</text></inputEntry>
        <outputEntry id="oe_npw_11_1"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_11_2"><text>"NP neonatal sem glutamina com emulsao lipidica complexa omega 3,6,9, bolsa ate 500mL"</text></outputEntry>
        <outputEntry id="oe_npw_11_3"><text>"Apendice V - BR 295267"</text></outputEntry>
      </rule>
      <!-- Neonatal com glutamina, com lipideo complexo omega -->
      <rule id="r_npw_12">
        <description>Neonatal, aminoacidos com glutamina, com emulsao lipidica complexa omega 3,6,9 (BR 295267)</description>
        <inputEntry id="ie_npw_12_1"><text>"NP_NEONATAL_COM_GLUT_COM_LIP_OMEGA"</text></inputEntry>
        <outputEntry id="oe_npw_12_1"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_12_2"><text>"NP neonatal com glutamina com emulsao lipidica complexa omega 3,6,9, bolsa ate 500mL"</text></outputEntry>
        <outputEntry id="oe_npw_12_3"><text>"Apendice V - BR 295267"</text></outputEntry>
      </rule>
      <!-- Catch-all -->
      <rule id="r_npw_catchall">
        <description>Codigo nao autorizado - item parenteral fora do Apendice V</description>
        <inputEntry id="ie_npw_catchall_1"><text></text></inputEntry>
        <outputEntry id="oe_npw_catchall_1"><text>false</text></outputEntry>
        <outputEntry id="oe_npw_catchall_2"><text>"Item nao encontrado no Apendice V - requer analise manual"</text></outputEntry>
        <outputEntry id="oe_npw_catchall_3"><text>"N/A"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
