<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="hemotherapy_cryo_bundle_def"
             name="Hemotherapy Cryo Bundle Items"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    Bundle inclusion for Crioprecipitado (SIGTAP 03.06.02.008-4)
    based on Apendice IX (Hemoterapia).
    Hit Policy COLLECT: returns ALL matching rows.

    Included: Custo operacional, Selecao pre-transfusional I (Tipagem ABO, Rh)
  -->
  <decision id="decision_hemotherapy_cryo_bundle" name="Hemotherapy Cryo Bundle Items">
    <decisionTable id="dt_hemotherapy_cryo_bundle" hitPolicy="COLLECT">
      <input id="in_product_type_cryo" label="Product Type">
        <inputExpression id="inExpr_product_type_cryo" typeRef="string">
          <text>product_type</text>
        </inputExpression>
      </input>
      <input id="in_service_category_cryo" label="Service Category">
        <inputExpression id="inExpr_service_category_cryo" typeRef="string">
          <text>service_category</text>
        </inputExpression>
      </input>
      <output id="out_item_included_cryo" label="Item Included" name="item_included" typeRef="boolean"/>
      <output id="out_item_name_cryo" label="Item Name" name="item_name" typeRef="string"/>
      <rule id="r_cryo_custo_operacional">
        <description>Crioprecipitado: custo operacional incluido (Apendice IX)</description>
        <inputEntry id="ie_cryo_co_1"><text>"CRIOPRECIPITADO"</text></inputEntry>
        <inputEntry id="ie_cryo_co_2"><text></text></inputEntry>
        <outputEntry id="oe_cryo_co_1"><text>true</text></outputEntry>
        <outputEntry id="oe_cryo_co_2"><text>"Custo operacional"</text></outputEntry>
      </rule>
      <rule id="r_cryo_selecao_i_tipagem">
        <description>Crioprecipitado: Selecao pre-transfusional I - Tipagem ABO incluida (Apendice IX)</description>
        <inputEntry id="ie_cryo_s1t_1"><text>"CRIOPRECIPITADO"</text></inputEntry>
        <inputEntry id="ie_cryo_s1t_2"><text></text></inputEntry>
        <outputEntry id="oe_cryo_s1t_1"><text>true</text></outputEntry>
        <outputEntry id="oe_cryo_s1t_2"><text>"Selecao pre-transfusional I - Tipagem ABO"</text></outputEntry>
      </rule>
      <rule id="r_cryo_selecao_i_rh">
        <description>Crioprecipitado: Selecao pre-transfusional I - Rh incluida (Apendice IX)</description>
        <inputEntry id="ie_cryo_s1r_1"><text>"CRIOPRECIPITADO"</text></inputEntry>
        <inputEntry id="ie_cryo_s1r_2"><text></text></inputEntry>
        <outputEntry id="oe_cryo_s1r_1"><text>true</text></outputEntry>
        <outputEntry id="oe_cryo_s1r_2"><text>"Selecao pre-transfusional I - Rh"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
