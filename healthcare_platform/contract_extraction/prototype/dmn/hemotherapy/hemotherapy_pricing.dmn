<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="hemotherapy_pricing_def"
             name="Hemotherapy Pricing"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    Per-product pricing with SIGTAP codes from Apendice IX (Hemoterapia).
    Hit Policy FIRST: first matching rule wins.

    Products and SIGTAP codes:
    - Concentrado de Hemacias: 03.06.02.006-8 (includes Selecao I + II)
    - Plaquetas Randomico: 03.06.02.007-6 (includes Selecao I)
    - Plaquetas por Aferese: 03.06.02.009-2 (includes Selecao I)
    - Plasma Fresco Congelado: 03.06.02.010-6 (includes Selecao 1)
    - Crioprecipitado: 03.06.02.008-4 (includes Selecao I)
    - Aferese Terapeutica: 03.06.02.001-7 (includes honorarios, kit, SF 0,9%)
    - Exsanguineotransfusao: 03.06.02.013-0 (includes Selecao I + III + Aliquotagem)
  -->
  <decision id="decision_hemotherapy_pricing" name="Hemotherapy Pricing">
    <decisionTable id="dt_hemotherapy_pricing" hitPolicy="FIRST">
      <input id="in_product_type_htp" label="Product Type">
        <inputExpression id="inExpr_product_type_htp" typeRef="string">
          <text>product_type</text>
        </inputExpression>
      </input>
      <input id="in_is_special_processing" label="Is Special Processing">
        <inputExpression id="inExpr_is_special_processing" typeRef="boolean">
          <text>is_special_processing</text>
        </inputExpression>
      </input>
      <output id="out_package_code_htp" label="Package SIGTAP Code" name="package_code" typeRef="string"/>
      <output id="out_billing_basis_htp" label="Billing Basis" name="billing_basis" typeRef="string"/>
      <output id="out_includes_pre_transfusion" label="Includes Pre-Transfusion" name="includes_pre_transfusion" typeRef="string"/>
      <!-- Concentrado de Hemacias with special processing -->
      <rule id="r_ht_hemacias_special">
        <description>Concentrado de Hemacias com processamento especial: codigo base + complementar (Apendice IX)</description>
        <inputEntry id="ie_ht_hs_1"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_ht_hs_2"><text>true</text></inputEntry>
        <outputEntry id="oe_ht_hs_1"><text>"03.06.02.006-8"</text></outputEntry>
        <outputEntry id="oe_ht_hs_2"><text>"Concentrado de Hemacias com processamento especial - pacote base + servicos complementares cobrados separadamente (irradiacao/deleucotizacao/lavagem/fenotipagem/aliquotagem) (Apendice IX)"</text></outputEntry>
        <outputEntry id="oe_ht_hs_3"><text>"Selecao I (Tipagem/Retipagem ABO, Rh/PAI) + Selecao II (Prova compatibilidade)"</text></outputEntry>
      </rule>
      <!-- Concentrado de Hemacias standard -->
      <rule id="r_ht_hemacias_standard">
        <description>Concentrado de Hemacias padrao: SIGTAP 03.06.02.006-8 (Apendice IX)</description>
        <inputEntry id="ie_ht_hstd_1"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_ht_hstd_2"><text>false</text></inputEntry>
        <outputEntry id="oe_ht_hstd_1"><text>"03.06.02.006-8"</text></outputEntry>
        <outputEntry id="oe_ht_hstd_2"><text>"Concentrado de Hemacias - custo operacional, selecao pre-transfusional incluida (Apendice IX)"</text></outputEntry>
        <outputEntry id="oe_ht_hstd_3"><text>"Selecao I (Tipagem/Retipagem ABO, Rh/PAI) + Selecao II (Prova compatibilidade)"</text></outputEntry>
      </rule>
      <!-- Plaquetas Randomico -->
      <rule id="r_ht_plaq_randomico">
        <description>Plaquetas Randomico: SIGTAP 03.06.02.007-6 (Apendice IX)</description>
        <inputEntry id="ie_ht_pr_1"><text>"PLAQUETAS_RANDOMICO"</text></inputEntry>
        <inputEntry id="ie_ht_pr_2"><text></text></inputEntry>
        <outputEntry id="oe_ht_pr_1"><text>"03.06.02.007-6"</text></outputEntry>
        <outputEntry id="oe_ht_pr_2"><text>"Plaquetas Randomico - custo operacional, selecao pre-transfusional incluida (Apendice IX)"</text></outputEntry>
        <outputEntry id="oe_ht_pr_3"><text>"Selecao I (Tipagem ABO, Rh/PAI)"</text></outputEntry>
      </rule>
      <!-- Plaquetas por Aferese -->
      <rule id="r_ht_plaq_aferese">
        <description>Plaquetas por Aferese: SIGTAP 03.06.02.009-2 (Apendice IX)</description>
        <inputEntry id="ie_ht_pa_1"><text>"PLAQUETAS_AFERESE"</text></inputEntry>
        <inputEntry id="ie_ht_pa_2"><text></text></inputEntry>
        <outputEntry id="oe_ht_pa_1"><text>"03.06.02.009-2"</text></outputEntry>
        <outputEntry id="oe_ht_pa_2"><text>"Plaquetas por Aferese - custo operacional, selecao pre-transfusional incluida (Apendice IX)"</text></outputEntry>
        <outputEntry id="oe_ht_pa_3"><text>"Selecao I (Tipagem/Retipagem ABO, Rh/PAI)"</text></outputEntry>
      </rule>
      <!-- Plasma Fresco Congelado -->
      <rule id="r_ht_plasma">
        <description>Plasma Fresco Congelado: SIGTAP 03.06.02.010-6 (Apendice IX)</description>
        <inputEntry id="ie_ht_pfc_1"><text>"PLASMA_FRESCO_CONGELADO"</text></inputEntry>
        <inputEntry id="ie_ht_pfc_2"><text></text></inputEntry>
        <outputEntry id="oe_ht_pfc_1"><text>"03.06.02.010-6"</text></outputEntry>
        <outputEntry id="oe_ht_pfc_2"><text>"Plasma Fresco Congelado - custo operacional, selecao pre-transfusional incluida (Apendice IX)"</text></outputEntry>
        <outputEntry id="oe_ht_pfc_3"><text>"Selecao 1 (Tipagem ABO, Rh)"</text></outputEntry>
      </rule>
      <!-- Crioprecipitado -->
      <rule id="r_ht_crioprecipitado">
        <description>Crioprecipitado: SIGTAP 03.06.02.008-4 (Apendice IX)</description>
        <inputEntry id="ie_ht_cryo_1"><text>"CRIOPRECIPITADO"</text></inputEntry>
        <inputEntry id="ie_ht_cryo_2"><text></text></inputEntry>
        <outputEntry id="oe_ht_cryo_1"><text>"03.06.02.008-4"</text></outputEntry>
        <outputEntry id="oe_ht_cryo_2"><text>"Crioprecipitado - custo operacional, selecao pre-transfusional incluida (Apendice IX)"</text></outputEntry>
        <outputEntry id="oe_ht_cryo_3"><text>"Selecao I (Tipagem ABO, Rh)"</text></outputEntry>
      </rule>
      <!-- Aferese Terapeutica -->
      <rule id="r_ht_aferese_terapeutica">
        <description>Aferese Terapeutica: SIGTAP 03.06.02.001-7. Inclui honorarios medico e operador, kit descartaveis, SF 0,9%. Exclui cateter duplo lumen, PFC/Albumina 20% (Apendice IX)</description>
        <inputEntry id="ie_ht_at_1"><text>"AFERESE_TERAPEUTICA"</text></inputEntry>
        <inputEntry id="ie_ht_at_2"><text></text></inputEntry>
        <outputEntry id="oe_ht_at_1"><text>"03.06.02.001-7"</text></outputEntry>
        <outputEntry id="oe_ht_at_2"><text>"Aferese Terapeutica - inclui honorario medico e operador, kit completo descartaveis, SF 0,9%. Exclui cateter duplo lumen e PFC ou Albumina 20% (Apendice IX)"</text></outputEntry>
        <outputEntry id="oe_ht_at_3"><text>"N/A - procedimento terapeutico sem selecao pre-transfusional"</text></outputEntry>
      </rule>
      <!-- Exsanguineotransfusao -->
      <rule id="r_ht_exsanguineo">
        <description>Exsanguineotransfusao: SIGTAP 03.06.02.013-0. Inclui honorarios medicos, hemocomponente/procedimentos especiais, materiais descartaveis, Selecao I, Selecao III, Aliquotagem (Apendice IX)</description>
        <inputEntry id="ie_ht_ex_1"><text>"EXSANGUINEOTRANSFUSAO"</text></inputEntry>
        <inputEntry id="ie_ht_ex_2"><text></text></inputEntry>
        <outputEntry id="oe_ht_ex_1"><text>"03.06.02.013-0"</text></outputEntry>
        <outputEntry id="oe_ht_ex_2"><text>"Exsanguineotransfusao - inclui honorarios medicos, hemocomponente (sangue total)/procedimentos especiais, materiais descartaveis (Apendice IX)"</text></outputEntry>
        <outputEntry id="oe_ht_ex_3"><text>"Selecao I + Selecao III + Aliquotagem (todos incluidos)"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
