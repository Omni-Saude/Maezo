<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="hemotherapy_rbc_bundle_def"
             name="Hemotherapy RBC Bundle Items"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    Bundle inclusion/exclusion for Concentrado de Hemacias (SIGTAP 03.06.02.006-8)
    based on Apendice IX (Hemoterapia).
    Hit Policy COLLECT: returns ALL matching rows (included + complementary items).

    Included: Custo operacional, Selecao pre-transfusional I (Tipagem/Retipagem ABO, Rh/PAI),
              Selecao pre-transfusional II (prova de compatibilidade)
    Excluded (complementary at extra cost): Selecao III (criancas <=4m), Aliquotagem,
              Deleucotizacao, Irradiacao, Lavagem (aberto/fechado),
              Fenotipagem (2 sistemas / 3+ sistemas)
  -->
  <decision id="decision_hemotherapy_rbc_bundle" name="Hemotherapy RBC Bundle Items">
    <decisionTable id="dt_hemotherapy_rbc_bundle" hitPolicy="COLLECT">
      <input id="in_product_type_rbc" label="Product Type">
        <inputExpression id="inExpr_product_type_rbc" typeRef="string">
          <text>product_type</text>
        </inputExpression>
      </input>
      <input id="in_service_category_rbc" label="Service Category">
        <inputExpression id="inExpr_service_category_rbc" typeRef="string">
          <text>service_category</text>
        </inputExpression>
      </input>
      <output id="out_item_included_rbc" label="Item Included" name="item_included" typeRef="boolean"/>
      <output id="out_item_name_rbc" label="Item Name" name="item_name" typeRef="string"/>
      <output id="out_is_complementary_rbc" label="Is Complementary" name="is_complementary" typeRef="boolean"/>
      <!-- Included items -->
      <rule id="r_rbc_custo_operacional">
        <description>Concentrado de Hemacias: custo operacional incluido no pacote (Apendice IX)</description>
        <inputEntry id="ie_rbc_co_1"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_co_2"><text></text></inputEntry>
        <outputEntry id="oe_rbc_co_1"><text>true</text></outputEntry>
        <outputEntry id="oe_rbc_co_2"><text>"Custo operacional"</text></outputEntry>
        <outputEntry id="oe_rbc_co_3"><text>false</text></outputEntry>
      </rule>
      <rule id="r_rbc_selecao_i_tipagem">
        <description>Concentrado de Hemacias: Selecao pre-transfusional I - Tipagem/Retipagem ABO incluida (Apendice IX)</description>
        <inputEntry id="ie_rbc_s1t_1"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_s1t_2"><text></text></inputEntry>
        <outputEntry id="oe_rbc_s1t_1"><text>true</text></outputEntry>
        <outputEntry id="oe_rbc_s1t_2"><text>"Selecao pre-transfusional I - Tipagem/Retipagem ABO"</text></outputEntry>
        <outputEntry id="oe_rbc_s1t_3"><text>false</text></outputEntry>
      </rule>
      <rule id="r_rbc_selecao_i_rh_pai">
        <description>Concentrado de Hemacias: Selecao pre-transfusional I - Rh/PAI incluida (Apendice IX)</description>
        <inputEntry id="ie_rbc_s1r_1"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_s1r_2"><text></text></inputEntry>
        <outputEntry id="oe_rbc_s1r_1"><text>true</text></outputEntry>
        <outputEntry id="oe_rbc_s1r_2"><text>"Selecao pre-transfusional I - Rh/PAI"</text></outputEntry>
        <outputEntry id="oe_rbc_s1r_3"><text>false</text></outputEntry>
      </rule>
      <rule id="r_rbc_selecao_ii">
        <description>Concentrado de Hemacias: Selecao pre-transfusional II - Prova de compatibilidade incluida (Apendice IX)</description>
        <inputEntry id="ie_rbc_s2_1"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_s2_2"><text></text></inputEntry>
        <outputEntry id="oe_rbc_s2_1"><text>true</text></outputEntry>
        <outputEntry id="oe_rbc_s2_2"><text>"Selecao pre-transfusional II - Prova de compatibilidade"</text></outputEntry>
        <outputEntry id="oe_rbc_s2_3"><text>false</text></outputEntry>
      </rule>
      <!-- Excluded items (complementary services available at extra cost) -->
      <rule id="r_rbc_excl_selecao_iii">
        <description>Concentrado de Hemacias: Selecao pre-transfusional III (criancas &lt;=4 meses) EXCLUIDA - servico complementar (Apendice IX)</description>
        <inputEntry id="ie_rbc_s3_1"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_s3_2"><text>"selecao_iii"</text></inputEntry>
        <outputEntry id="oe_rbc_s3_1"><text>false</text></outputEntry>
        <outputEntry id="oe_rbc_s3_2"><text>"Selecao pre-transfusional III - criancas &lt;=4 meses (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_rbc_s3_3"><text>true</text></outputEntry>
      </rule>
      <rule id="r_rbc_excl_aliquotagem">
        <description>Concentrado de Hemacias: Aliquotagem EXCLUIDA - servico complementar (Apendice IX)</description>
        <inputEntry id="ie_rbc_aliq_1"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_aliq_2"><text>"aliquotagem"</text></inputEntry>
        <outputEntry id="oe_rbc_aliq_1"><text>false</text></outputEntry>
        <outputEntry id="oe_rbc_aliq_2"><text>"Aliquotagem (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_rbc_aliq_3"><text>true</text></outputEntry>
      </rule>
      <rule id="r_rbc_excl_deleucotizacao">
        <description>Concentrado de Hemacias: Deleucotizacao EXCLUIDA - servico complementar (Apendice IX)</description>
        <inputEntry id="ie_rbc_deleu_1"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_deleu_2"><text>"deleucotizacao"</text></inputEntry>
        <outputEntry id="oe_rbc_deleu_1"><text>false</text></outputEntry>
        <outputEntry id="oe_rbc_deleu_2"><text>"Deleucotizacao (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_rbc_deleu_3"><text>true</text></outputEntry>
      </rule>
      <rule id="r_rbc_excl_irradiacao">
        <description>Concentrado de Hemacias: Irradiacao EXCLUIDA - servico complementar (Apendice IX)</description>
        <inputEntry id="ie_rbc_irr_1"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_irr_2"><text>"irradiacao"</text></inputEntry>
        <outputEntry id="oe_rbc_irr_1"><text>false</text></outputEntry>
        <outputEntry id="oe_rbc_irr_2"><text>"Irradiacao (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_rbc_irr_3"><text>true</text></outputEntry>
      </rule>
      <rule id="r_rbc_excl_lavagem_aberto">
        <description>Concentrado de Hemacias: Lavagem sistema aberto EXCLUIDA - servico complementar (Apendice IX)</description>
        <inputEntry id="ie_rbc_lava_1"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_lava_2"><text>"lavagem_aberto"</text></inputEntry>
        <outputEntry id="oe_rbc_lava_1"><text>false</text></outputEntry>
        <outputEntry id="oe_rbc_lava_2"><text>"Lavagem sistema aberto (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_rbc_lava_3"><text>true</text></outputEntry>
      </rule>
      <rule id="r_rbc_excl_lavagem_fechado">
        <description>Concentrado de Hemacias: Lavagem sistema fechado EXCLUIDA - servico complementar (Apendice IX)</description>
        <inputEntry id="ie_rbc_lavf_1"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_lavf_2"><text>"lavagem_fechado"</text></inputEntry>
        <outputEntry id="oe_rbc_lavf_1"><text>false</text></outputEntry>
        <outputEntry id="oe_rbc_lavf_2"><text>"Lavagem sistema fechado (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_rbc_lavf_3"><text>true</text></outputEntry>
      </rule>
      <rule id="r_rbc_excl_fenotipagem_2">
        <description>Concentrado de Hemacias: Fenotipagem 2 sistemas (Rh e Kell) EXCLUIDA - servico complementar (Apendice IX)</description>
        <inputEntry id="ie_rbc_fen2_1"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_fen2_2"><text>"fenotipagem_2_sistemas"</text></inputEntry>
        <outputEntry id="oe_rbc_fen2_1"><text>false</text></outputEntry>
        <outputEntry id="oe_rbc_fen2_2"><text>"Fenotipagem 2 sistemas - Rh e Kell (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_rbc_fen2_3"><text>true</text></outputEntry>
      </rule>
      <rule id="r_rbc_excl_fenotipagem_3">
        <description>Concentrado de Hemacias: Fenotipagem 3+ sistemas EXCLUIDA - servico complementar (Apendice IX)</description>
        <inputEntry id="ie_rbc_fen3_1"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_fen3_2"><text>"fenotipagem_3_sistemas"</text></inputEntry>
        <outputEntry id="oe_rbc_fen3_1"><text>false</text></outputEntry>
        <outputEntry id="oe_rbc_fen3_2"><text>"Fenotipagem 3+ sistemas (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_rbc_fen3_3"><text>true</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
