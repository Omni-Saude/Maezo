<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="hemotherapy_complement_routing_def"
             name="Hemotherapy Complement Routing"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    Routing rules for complementary hemotherapy services based on Apendice IX (Hemoterapia).
    Hit Policy FIRST: first matching rule wins.

    Complementary services available for specific products:
    - Irradiacao (por bolsa): hemacias, plaquetas
    - Deleucotizacao: hemacias, plaquetas randomico
    - Lavagem sistema aberto: hemacias
    - Lavagem sistema fechado: hemacias
    - Fenotipagem 2 sistemas (Rh e Kell): hemacias
    - Fenotipagem 3+ sistemas: hemacias
    - Aliquotagem: hemacias, plaquetas randomico
  -->
  <decision id="decision_hemotherapy_complement_routing" name="Hemotherapy Complement Routing">
    <decisionTable id="dt_hemotherapy_complement_routing" hitPolicy="FIRST">
      <input id="in_product_type_htc" label="Product Type">
        <inputExpression id="inExpr_product_type_htc" typeRef="string">
          <text>product_type</text>
        </inputExpression>
      </input>
      <input id="in_clinical_indication" label="Clinical Indication">
        <inputExpression id="inExpr_clinical_indication" typeRef="string">
          <text>clinical_indication</text>
        </inputExpression>
      </input>
      <output id="out_complement_service" label="Complement Service" name="complement_service" typeRef="string"/>
      <output id="out_sigtap_complement" label="SIGTAP Complement" name="sigtap_complement" typeRef="string"/>
      <output id="out_description_htc" label="Description" name="description" typeRef="string"/>
      <!-- Irradiacao -->
      <rule id="r_htc_irradiacao_hemacias">
        <description>Irradiacao por bolsa para Concentrado de Hemacias (Apendice IX)</description>
        <inputEntry id="ie_htc_irh_1"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_htc_irh_2"><text>"IRRADIACAO"</text></inputEntry>
        <outputEntry id="oe_htc_irh_1"><text>"IRRADIACAO"</text></outputEntry>
        <outputEntry id="oe_htc_irh_2"><text>"03.06.02.006-8_IRRAD"</text></outputEntry>
        <outputEntry id="oe_htc_irh_3"><text>"Irradiacao por bolsa - servico complementar para Concentrado de Hemacias. Indicado para prevencao de doenca enxerto versus hospedeiro (Apendice IX)"</text></outputEntry>
      </rule>
      <rule id="r_htc_irradiacao_plaq_rand">
        <description>Irradiacao por bolsa para Plaquetas Randomico (Apendice IX)</description>
        <inputEntry id="ie_htc_irpr_1"><text>"PLAQUETAS_RANDOMICO"</text></inputEntry>
        <inputEntry id="ie_htc_irpr_2"><text>"IRRADIACAO"</text></inputEntry>
        <outputEntry id="oe_htc_irpr_1"><text>"IRRADIACAO"</text></outputEntry>
        <outputEntry id="oe_htc_irpr_2"><text>"03.06.02.007-6_IRRAD"</text></outputEntry>
        <outputEntry id="oe_htc_irpr_3"><text>"Irradiacao por bolsa - servico complementar para Plaquetas Randomico (Apendice IX)"</text></outputEntry>
      </rule>
      <rule id="r_htc_irradiacao_plaq_afer">
        <description>Irradiacao por bolsa para Plaquetas por Aferese (Apendice IX)</description>
        <inputEntry id="ie_htc_irpa_1"><text>"PLAQUETAS_AFERESE"</text></inputEntry>
        <inputEntry id="ie_htc_irpa_2"><text>"IRRADIACAO"</text></inputEntry>
        <outputEntry id="oe_htc_irpa_1"><text>"IRRADIACAO"</text></outputEntry>
        <outputEntry id="oe_htc_irpa_2"><text>"03.06.02.009-2_IRRAD"</text></outputEntry>
        <outputEntry id="oe_htc_irpa_3"><text>"Irradiacao por bolsa - servico complementar para Plaquetas por Aferese (Apendice IX)"</text></outputEntry>
      </rule>
      <!-- Deleucotizacao -->
      <rule id="r_htc_deleuco_hemacias">
        <description>Deleucotizacao para Concentrado de Hemacias (Apendice IX)</description>
        <inputEntry id="ie_htc_dlh_1"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_htc_dlh_2"><text>"DELEUCOTIZACAO"</text></inputEntry>
        <outputEntry id="oe_htc_dlh_1"><text>"DELEUCOTIZACAO"</text></outputEntry>
        <outputEntry id="oe_htc_dlh_2"><text>"03.06.02.006-8_DELEU"</text></outputEntry>
        <outputEntry id="oe_htc_dlh_3"><text>"Deleucotizacao - servico complementar para Concentrado de Hemacias. Remocao de leucocitos por filtracao (Apendice IX)"</text></outputEntry>
      </rule>
      <rule id="r_htc_deleuco_plaq_rand">
        <description>Deleucotizacao para Plaquetas Randomico (Apendice IX)</description>
        <inputEntry id="ie_htc_dlpr_1"><text>"PLAQUETAS_RANDOMICO"</text></inputEntry>
        <inputEntry id="ie_htc_dlpr_2"><text>"DELEUCOTIZACAO"</text></inputEntry>
        <outputEntry id="oe_htc_dlpr_1"><text>"DELEUCOTIZACAO"</text></outputEntry>
        <outputEntry id="oe_htc_dlpr_2"><text>"03.06.02.007-6_DELEU"</text></outputEntry>
        <outputEntry id="oe_htc_dlpr_3"><text>"Deleucotizacao - servico complementar para Plaquetas Randomico (Apendice IX)"</text></outputEntry>
      </rule>
      <!-- Lavagem -->
      <rule id="r_htc_lavagem_aberto">
        <description>Lavagem sistema aberto para Concentrado de Hemacias (Apendice IX)</description>
        <inputEntry id="ie_htc_lsa_1"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_htc_lsa_2"><text>"LAVAGEM_ABERTO"</text></inputEntry>
        <outputEntry id="oe_htc_lsa_1"><text>"LAVAGEM_SISTEMA_ABERTO"</text></outputEntry>
        <outputEntry id="oe_htc_lsa_2"><text>"03.06.02.006-8_LAV_AB"</text></outputEntry>
        <outputEntry id="oe_htc_lsa_3"><text>"Lavagem sistema aberto - servico complementar para Concentrado de Hemacias. Remocao de plasma residual (Apendice IX)"</text></outputEntry>
      </rule>
      <rule id="r_htc_lavagem_fechado">
        <description>Lavagem sistema fechado para Concentrado de Hemacias (Apendice IX)</description>
        <inputEntry id="ie_htc_lsf_1"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_htc_lsf_2"><text>"LAVAGEM_FECHADO"</text></inputEntry>
        <outputEntry id="oe_htc_lsf_1"><text>"LAVAGEM_SISTEMA_FECHADO"</text></outputEntry>
        <outputEntry id="oe_htc_lsf_2"><text>"03.06.02.006-8_LAV_FE"</text></outputEntry>
        <outputEntry id="oe_htc_lsf_3"><text>"Lavagem sistema fechado - servico complementar para Concentrado de Hemacias. Remocao de plasma com sistema fechado esteril (Apendice IX)"</text></outputEntry>
      </rule>
      <!-- Fenotipagem -->
      <rule id="r_htc_fenotipagem_2">
        <description>Fenotipagem 2 sistemas (Rh e Kell) para Concentrado de Hemacias (Apendice IX)</description>
        <inputEntry id="ie_htc_fen2_1"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_htc_fen2_2"><text>"FENOTIPAGEM_2_SISTEMAS"</text></inputEntry>
        <outputEntry id="oe_htc_fen2_1"><text>"FENOTIPAGEM_2_SISTEMAS"</text></outputEntry>
        <outputEntry id="oe_htc_fen2_2"><text>"03.06.02.006-8_FEN2"</text></outputEntry>
        <outputEntry id="oe_htc_fen2_3"><text>"Fenotipagem 2 sistemas (Rh e Kell) - servico complementar para Concentrado de Hemacias. Para pacientes politransfundidos ou com aloanticorpos (Apendice IX)"</text></outputEntry>
      </rule>
      <rule id="r_htc_fenotipagem_3">
        <description>Fenotipagem 3+ sistemas para Concentrado de Hemacias (Apendice IX)</description>
        <inputEntry id="ie_htc_fen3_1"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_htc_fen3_2"><text>"FENOTIPAGEM_3_SISTEMAS"</text></inputEntry>
        <outputEntry id="oe_htc_fen3_1"><text>"FENOTIPAGEM_3_SISTEMAS"</text></outputEntry>
        <outputEntry id="oe_htc_fen3_2"><text>"03.06.02.006-8_FEN3"</text></outputEntry>
        <outputEntry id="oe_htc_fen3_3"><text>"Fenotipagem 3+ sistemas - servico complementar para Concentrado de Hemacias. Fenotipagem estendida para pacientes com multiplos aloanticorpos (Apendice IX)"</text></outputEntry>
      </rule>
      <!-- Aliquotagem -->
      <rule id="r_htc_aliquotagem_hemacias">
        <description>Aliquotagem para Concentrado de Hemacias (Apendice IX)</description>
        <inputEntry id="ie_htc_aliqh_1"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_htc_aliqh_2"><text>"ALIQUOTAGEM"</text></inputEntry>
        <outputEntry id="oe_htc_aliqh_1"><text>"ALIQUOTAGEM"</text></outputEntry>
        <outputEntry id="oe_htc_aliqh_2"><text>"03.06.02.006-8_ALIQ"</text></outputEntry>
        <outputEntry id="oe_htc_aliqh_3"><text>"Aliquotagem - servico complementar para Concentrado de Hemacias. Divisao do hemocomponente em volumes menores (Apendice IX)"</text></outputEntry>
      </rule>
      <rule id="r_htc_aliquotagem_plaq_rand">
        <description>Aliquotagem para Plaquetas Randomico (Apendice IX)</description>
        <inputEntry id="ie_htc_aliqp_1"><text>"PLAQUETAS_RANDOMICO"</text></inputEntry>
        <inputEntry id="ie_htc_aliqp_2"><text>"ALIQUOTAGEM"</text></inputEntry>
        <outputEntry id="oe_htc_aliqp_1"><text>"ALIQUOTAGEM"</text></outputEntry>
        <outputEntry id="oe_htc_aliqp_2"><text>"03.06.02.007-6_ALIQ"</text></outputEntry>
        <outputEntry id="oe_htc_aliqp_3"><text>"Aliquotagem - servico complementar para Plaquetas Randomico. Divisao do hemocomponente em volumes menores (Apendice IX)"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
