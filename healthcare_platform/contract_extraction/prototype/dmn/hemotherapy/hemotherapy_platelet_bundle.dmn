<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="hemotherapy_platelet_bundle_def"
             name="Hemotherapy Platelet Bundle Items"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    Bundle inclusion/exclusion for Plaquetas based on Apendice IX (Hemoterapia).
    Hit Policy COLLECT: returns ALL matching rows.

    Plaquetas Randomico (SIGTAP 03.06.02.007-6):
      Included: Custo operacional, Selecao I (Tipagem ABO, Rh/PAI)
      Excluded: Selecao III (criancas <=4m), Aliquotagem, Deleucotizacao, Irradiacao

    Plaquetas por Aferese (SIGTAP 03.06.02.009-2):
      Included: Custo operacional, Selecao I (Tipagem/Retipagem ABO, Rh/PAI)
      Excluded: Selecao III (criancas <=4m), Irradiacao
  -->
  <decision id="decision_hemotherapy_platelet_bundle" name="Hemotherapy Platelet Bundle Items">
    <decisionTable id="dt_hemotherapy_platelet_bundle" hitPolicy="COLLECT">
      <input id="in_platelet_type" label="Platelet Type">
        <inputExpression id="inExpr_platelet_type" typeRef="string">
          <text>platelet_type</text>
        </inputExpression>
      </input>
      <input id="in_service_category_plt" label="Service Category">
        <inputExpression id="inExpr_service_category_plt" typeRef="string">
          <text>service_category</text>
        </inputExpression>
      </input>
      <output id="out_item_included_plt" label="Item Included" name="item_included" typeRef="boolean"/>
      <output id="out_item_name_plt" label="Item Name" name="item_name" typeRef="string"/>
      <output id="out_is_complementary_plt" label="Is Complementary" name="is_complementary" typeRef="boolean"/>
      <!-- RANDOMICO - Included -->
      <rule id="r_plt_rand_custo_op">
        <description>Plaquetas Randomico: custo operacional incluido (Apendice IX)</description>
        <inputEntry id="ie_plt_rco_1"><text>"RANDOMICO"</text></inputEntry>
        <inputEntry id="ie_plt_rco_2"><text></text></inputEntry>
        <outputEntry id="oe_plt_rco_1"><text>true</text></outputEntry>
        <outputEntry id="oe_plt_rco_2"><text>"Custo operacional"</text></outputEntry>
        <outputEntry id="oe_plt_rco_3"><text>false</text></outputEntry>
      </rule>
      <rule id="r_plt_rand_selecao_i_tipagem">
        <description>Plaquetas Randomico: Selecao pre-transfusional I - Tipagem ABO incluida (Apendice IX)</description>
        <inputEntry id="ie_plt_rs1t_1"><text>"RANDOMICO"</text></inputEntry>
        <inputEntry id="ie_plt_rs1t_2"><text></text></inputEntry>
        <outputEntry id="oe_plt_rs1t_1"><text>true</text></outputEntry>
        <outputEntry id="oe_plt_rs1t_2"><text>"Selecao pre-transfusional I - Tipagem ABO"</text></outputEntry>
        <outputEntry id="oe_plt_rs1t_3"><text>false</text></outputEntry>
      </rule>
      <rule id="r_plt_rand_selecao_i_rh">
        <description>Plaquetas Randomico: Selecao pre-transfusional I - Rh/PAI incluida (Apendice IX)</description>
        <inputEntry id="ie_plt_rs1r_1"><text>"RANDOMICO"</text></inputEntry>
        <inputEntry id="ie_plt_rs1r_2"><text></text></inputEntry>
        <outputEntry id="oe_plt_rs1r_1"><text>true</text></outputEntry>
        <outputEntry id="oe_plt_rs1r_2"><text>"Selecao pre-transfusional I - Rh/PAI"</text></outputEntry>
        <outputEntry id="oe_plt_rs1r_3"><text>false</text></outputEntry>
      </rule>
      <!-- RANDOMICO - Excluded (complementary) -->
      <rule id="r_plt_rand_excl_selecao_iii">
        <description>Plaquetas Randomico: Selecao III (criancas &lt;=4m) EXCLUIDA - complementar (Apendice IX)</description>
        <inputEntry id="ie_plt_rs3_1"><text>"RANDOMICO"</text></inputEntry>
        <inputEntry id="ie_plt_rs3_2"><text>"selecao_iii"</text></inputEntry>
        <outputEntry id="oe_plt_rs3_1"><text>false</text></outputEntry>
        <outputEntry id="oe_plt_rs3_2"><text>"Selecao pre-transfusional III - criancas &lt;=4 meses (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_plt_rs3_3"><text>true</text></outputEntry>
      </rule>
      <rule id="r_plt_rand_excl_aliquotagem">
        <description>Plaquetas Randomico: Aliquotagem EXCLUIDA - complementar (Apendice IX)</description>
        <inputEntry id="ie_plt_raliq_1"><text>"RANDOMICO"</text></inputEntry>
        <inputEntry id="ie_plt_raliq_2"><text>"aliquotagem"</text></inputEntry>
        <outputEntry id="oe_plt_raliq_1"><text>false</text></outputEntry>
        <outputEntry id="oe_plt_raliq_2"><text>"Aliquotagem (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_plt_raliq_3"><text>true</text></outputEntry>
      </rule>
      <rule id="r_plt_rand_excl_deleucotizacao">
        <description>Plaquetas Randomico: Deleucotizacao EXCLUIDA - complementar (Apendice IX)</description>
        <inputEntry id="ie_plt_rdeleu_1"><text>"RANDOMICO"</text></inputEntry>
        <inputEntry id="ie_plt_rdeleu_2"><text>"deleucotizacao"</text></inputEntry>
        <outputEntry id="oe_plt_rdeleu_1"><text>false</text></outputEntry>
        <outputEntry id="oe_plt_rdeleu_2"><text>"Deleucotizacao (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_plt_rdeleu_3"><text>true</text></outputEntry>
      </rule>
      <rule id="r_plt_rand_excl_irradiacao">
        <description>Plaquetas Randomico: Irradiacao EXCLUIDA - complementar (Apendice IX)</description>
        <inputEntry id="ie_plt_rirr_1"><text>"RANDOMICO"</text></inputEntry>
        <inputEntry id="ie_plt_rirr_2"><text>"irradiacao"</text></inputEntry>
        <outputEntry id="oe_plt_rirr_1"><text>false</text></outputEntry>
        <outputEntry id="oe_plt_rirr_2"><text>"Irradiacao (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_plt_rirr_3"><text>true</text></outputEntry>
      </rule>
      <!-- AFERESE - Included -->
      <rule id="r_plt_afer_custo_op">
        <description>Plaquetas Aferese: custo operacional incluido (Apendice IX)</description>
        <inputEntry id="ie_plt_aco_1"><text>"AFERESE"</text></inputEntry>
        <inputEntry id="ie_plt_aco_2"><text></text></inputEntry>
        <outputEntry id="oe_plt_aco_1"><text>true</text></outputEntry>
        <outputEntry id="oe_plt_aco_2"><text>"Custo operacional"</text></outputEntry>
        <outputEntry id="oe_plt_aco_3"><text>false</text></outputEntry>
      </rule>
      <rule id="r_plt_afer_selecao_i_tipagem">
        <description>Plaquetas Aferese: Selecao pre-transfusional I - Tipagem/Retipagem ABO incluida (Apendice IX)</description>
        <inputEntry id="ie_plt_as1t_1"><text>"AFERESE"</text></inputEntry>
        <inputEntry id="ie_plt_as1t_2"><text></text></inputEntry>
        <outputEntry id="oe_plt_as1t_1"><text>true</text></outputEntry>
        <outputEntry id="oe_plt_as1t_2"><text>"Selecao pre-transfusional I - Tipagem/Retipagem ABO"</text></outputEntry>
        <outputEntry id="oe_plt_as1t_3"><text>false</text></outputEntry>
      </rule>
      <rule id="r_plt_afer_selecao_i_rh">
        <description>Plaquetas Aferese: Selecao pre-transfusional I - Rh/PAI incluida (Apendice IX)</description>
        <inputEntry id="ie_plt_as1r_1"><text>"AFERESE"</text></inputEntry>
        <inputEntry id="ie_plt_as1r_2"><text></text></inputEntry>
        <outputEntry id="oe_plt_as1r_1"><text>true</text></outputEntry>
        <outputEntry id="oe_plt_as1r_2"><text>"Selecao pre-transfusional I - Rh/PAI"</text></outputEntry>
        <outputEntry id="oe_plt_as1r_3"><text>false</text></outputEntry>
      </rule>
      <!-- AFERESE - Excluded (complementary) -->
      <rule id="r_plt_afer_excl_selecao_iii">
        <description>Plaquetas Aferese: Selecao III (criancas &lt;=4m) EXCLUIDA - complementar (Apendice IX)</description>
        <inputEntry id="ie_plt_as3_1"><text>"AFERESE"</text></inputEntry>
        <inputEntry id="ie_plt_as3_2"><text>"selecao_iii"</text></inputEntry>
        <outputEntry id="oe_plt_as3_1"><text>false</text></outputEntry>
        <outputEntry id="oe_plt_as3_2"><text>"Selecao pre-transfusional III - criancas &lt;=4 meses (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_plt_as3_3"><text>true</text></outputEntry>
      </rule>
      <rule id="r_plt_afer_excl_irradiacao">
        <description>Plaquetas Aferese: Irradiacao EXCLUIDA - complementar (Apendice IX)</description>
        <inputEntry id="ie_plt_airr_1"><text>"AFERESE"</text></inputEntry>
        <inputEntry id="ie_plt_airr_2"><text>"irradiacao"</text></inputEntry>
        <outputEntry id="oe_plt_airr_1"><text>false</text></outputEntry>
        <outputEntry id="oe_plt_airr_2"><text>"Irradiacao (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_plt_airr_3"><text>true</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
