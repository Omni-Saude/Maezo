<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="hemotherapy_plasma_bundle_def"
             name="Hemotherapy Plasma Bundle Items"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    Bundle inclusion for Plasma Fresco Congelado (SIGTAP 03.06.02.010-6)
    based on Apendice IX (Hemoterapia).
    Hit Policy COLLECT: returns ALL matching rows.

    Included: Custo operacional, Selecao pre-transfusional 1 (Tipagem ABO, Rh)
  -->
  <decision id="decision_hemotherapy_plasma_bundle" name="Hemotherapy Plasma Bundle Items">
    <decisionTable id="dt_hemotherapy_plasma_bundle" hitPolicy="COLLECT">
      <input id="in_product_type_pfc" label="Product Type">
        <inputExpression id="inExpr_product_type_pfc" typeRef="string">
          <text>product_type</text>
        </inputExpression>
      </input>
      <input id="in_service_category_pfc" label="Service Category">
        <inputExpression id="inExpr_service_category_pfc" typeRef="string">
          <text>service_category</text>
        </inputExpression>
      </input>
      <output id="out_item_included_pfc" label="Item Included" name="item_included" typeRef="boolean"/>
      <output id="out_item_name_pfc" label="Item Name" name="item_name" typeRef="string"/>
      <rule id="r_pfc_custo_operacional">
        <description>Plasma Fresco Congelado: custo operacional incluido (Apendice IX)</description>
        <inputEntry id="ie_pfc_co_1"><text>"PLASMA_FRESCO_CONGELADO"</text></inputEntry>
        <inputEntry id="ie_pfc_co_2"><text></text></inputEntry>
        <outputEntry id="oe_pfc_co_1"><text>true</text></outputEntry>
        <outputEntry id="oe_pfc_co_2"><text>"Custo operacional"</text></outputEntry>
      </rule>
      <rule id="r_pfc_selecao_i_tipagem">
        <description>Plasma Fresco Congelado: Selecao pre-transfusional 1 - Tipagem ABO incluida (Apendice IX)</description>
        <inputEntry id="ie_pfc_s1t_1"><text>"PLASMA_FRESCO_CONGELADO"</text></inputEntry>
        <inputEntry id="ie_pfc_s1t_2"><text></text></inputEntry>
        <outputEntry id="oe_pfc_s1t_1"><text>true</text></outputEntry>
        <outputEntry id="oe_pfc_s1t_2"><text>"Selecao pre-transfusional 1 - Tipagem ABO"</text></outputEntry>
      </rule>
      <rule id="r_pfc_selecao_i_rh">
        <description>Plasma Fresco Congelado: Selecao pre-transfusional 1 - Rh incluida (Apendice IX)</description>
        <inputEntry id="ie_pfc_s1r_1"><text>"PLASMA_FRESCO_CONGELADO"</text></inputEntry>
        <inputEntry id="ie_pfc_s1r_2"><text></text></inputEntry>
        <outputEntry id="oe_pfc_s1r_1"><text>true</text></outputEntry>
        <outputEntry id="oe_pfc_s1r_2"><text>"Selecao pre-transfusional 1 - Rh"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
