<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="uti_type_routing_def"
             name="UTI Type Routing"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <decision id="decision_uti_type_routing" name="UTI Type Routing">
    <decisionTable id="dt_uti_type_routing" hitPolicy="FIRST">
      <input id="in_age_days" label="Patient Age (Days)">
        <inputExpression id="inExpr_age_days" typeRef="number">
          <text>patient_age_days</text>
        </inputExpression>
      </input>
      <input id="in_weight_grams" label="Patient Weight (Grams)">
        <inputExpression id="inExpr_weight_grams" typeRef="number">
          <text>patient_weight_grams</text>
        </inputExpression>
      </input>
      <input id="in_gestational_age" label="Gestational Age (Weeks)">
        <inputExpression id="inExpr_gestational_age" typeRef="number">
          <text>gestational_age_weeks</text>
        </inputExpression>
      </input>
      <output id="out_uti_type" label="UTI Type" name="uti_type" typeRef="string"/>
      <output id="out_sigtap" label="SIGTAP Code" name="sigtap_code" typeRef="string"/>
      <output id="out_approved" label="Approved" name="approved" typeRef="boolean"/>
      <!-- Rule 1: Neonatal 0-28 days -->
      <rule id="r_neonatal">
        <description>UTI Neonatal: faixa etaria 0 a 28 dias (Edital 2.5, Contrato 4.3.4)</description>
        <inputEntry id="ie_n_1"><text>[0..28]</text></inputEntry>
        <inputEntry id="ie_n_2"><text></text></inputEntry>
        <inputEntry id="ie_n_3"><text></text></inputEntry>
        <outputEntry id="oe_n_1"><text>"UTI_NEONATAL"</text></outputEntry>
        <outputEntry id="oe_n_2"><text>"03.01.01.007-2"</text></outputEntry>
        <outputEntry id="oe_n_3"><text>true</text></outputEntry>
      </rule>
      <!-- Rule 2: Neonatal above 28 days if weight < 2500g OR gestational age < 40w -->
      <rule id="r_neonatal_extended">
        <description>UTI Neonatal: acima de 28 dias com peso inferior a 2500g OU idade gestacional corrigida inferior a 40 semanas (Contrato 4.3.4)</description>
        <inputEntry id="ie_ne_1"><text>&gt; 28</text></inputEntry>
        <inputEntry id="ie_ne_2"><text>&lt; 2500</text></inputEntry>
        <inputEntry id="ie_ne_3"><text></text></inputEntry>
        <outputEntry id="oe_ne_1"><text>"UTI_NEONATAL"</text></outputEntry>
        <outputEntry id="oe_ne_2"><text>"03.01.01.007-2"</text></outputEntry>
        <outputEntry id="oe_ne_3"><text>true</text></outputEntry>
      </rule>
      <!-- Rule 3: Neonatal above 28 days if gestational age < 40w (regardless of weight) -->
      <rule id="r_neonatal_low_gest">
        <description>UTI Neonatal: acima de 28 dias com idade gestacional corrigida inferior a 40 semanas (Contrato 4.3.4)</description>
        <inputEntry id="ie_nlg_1"><text>&gt; 28</text></inputEntry>
        <inputEntry id="ie_nlg_2"><text></text></inputEntry>
        <inputEntry id="ie_nlg_3"><text>&lt; 40</text></inputEntry>
        <outputEntry id="oe_nlg_1"><text>"UTI_NEONATAL"</text></outputEntry>
        <outputEntry id="oe_nlg_2"><text>"03.01.01.007-2"</text></outputEntry>
        <outputEntry id="oe_nlg_3"><text>true</text></outputEntry>
      </rule>
      <!-- Rule 4: Pediatric 29 days to 17y11m29d -->
      <rule id="r_pediatrica">
        <description>UTI Pediatrica: de 29 dias a 17 anos 11 meses 29 dias (Edital 2.5, Contrato 4.3.4)</description>
        <inputEntry id="ie_p_1"><text>[29..6569]</text></inputEntry>
        <inputEntry id="ie_p_2"><text></text></inputEntry>
        <inputEntry id="ie_p_3"><text></text></inputEntry>
        <outputEntry id="oe_p_1"><text>"UTI_PEDIATRICA"</text></outputEntry>
        <outputEntry id="oe_p_2"><text>"03.01.04.016-8"</text></outputEntry>
        <outputEntry id="oe_p_3"><text>true</text></outputEntry>
      </rule>
      <!-- Rule 5: Adult 18+ years -->
      <rule id="r_adulto">
        <description>UTI Adulto: acima de 18 anos (6570+ dias) (Edital 2.5, Contrato 4.3.4)</description>
        <inputEntry id="ie_a_1"><text>&gt;= 6570</text></inputEntry>
        <inputEntry id="ie_a_2"><text></text></inputEntry>
        <inputEntry id="ie_a_3"><text></text></inputEntry>
        <outputEntry id="oe_a_1"><text>"UTI_ADULTO"</text></outputEntry>
        <outputEntry id="oe_a_2"><text>"04.09.01.059-2"</text></outputEntry>
        <outputEntry id="oe_a_3"><text>true</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
