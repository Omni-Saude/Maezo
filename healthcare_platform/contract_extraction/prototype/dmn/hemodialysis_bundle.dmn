<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="hemodialysis_bundle_def"
             name="Hemodialysis Bundle Items"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    Bundle inclusion/exclusion based on Apendice VIII (Terapia Renal Substitutiva).
    Hit Policy COLLECT: returns ALL matching rows (list of included/excluded items per session type).
  -->
  <decision id="decision_hemodialysis_bundle" name="Hemodialysis Bundle Items">
    <decisionTable id="dt_hemodialysis_bundle" hitPolicy="COLLECT">
      <input id="in_session_type_b" label="Session Type">
        <inputExpression id="inExpr_session_type_b" typeRef="string">
          <text>session_type</text>
        </inputExpression>
      </input>
      <input id="in_item_category" label="Item Category">
        <inputExpression id="inExpr_item_category" typeRef="string">
          <text>item_category</text>
        </inputExpression>
      </input>
      <output id="out_item_included_b" label="Item Included" name="item_included" typeRef="boolean"/>
      <output id="out_item_name" label="Item Name" name="item_name" typeRef="string"/>
      <output id="out_qty" label="Quantity per Session" name="quantity_per_session" typeRef="number"/>
      <!-- CONTINUA_PRIMEIRAS_24H - Included items (kit a cada 72h + materiais diarios) -->
      <rule id="r_b_c24_kit_maquina">
        <description>Continua primeiras 24h: kit especifico maquina hemodiálise contínua incluido (a cada 72h) (Apendice VIII)</description>
        <inputEntry id="ie_b_c24k_1"><text>"CONTINUA_PRIMEIRAS_24H"</text></inputEntry>
        <inputEntry id="ie_b_c24k_2"><text></text></inputEntry>
        <outputEntry id="oe_b_c24k_1"><text>true</text></outputEntry>
        <outputEntry id="oe_b_c24k_2"><text>"Kit especifico para maquina de hemodialise continua (troca a cada 72h)"</text></outputEntry>
        <outputEntry id="oe_b_c24k_3"><text>1</text></outputEntry>
      </rule>
      <rule id="r_b_c24_bolsa_drenagem">
        <description>Continua primeiras 24h: bolsa de drenagem HP SP 354 incluida (a cada 72h)</description>
        <inputEntry id="ie_b_c24b_1"><text>"CONTINUA_PRIMEIRAS_24H"</text></inputEntry>
        <inputEntry id="ie_b_c24b_2"><text></text></inputEntry>
        <outputEntry id="oe_b_c24b_1"><text>true</text></outputEntry>
        <outputEntry id="oe_b_c24b_2"><text>"Bolsa de drenagem HP SP 354 (a cada 72h)"</text></outputEntry>
        <outputEntry id="oe_b_c24b_3"><text>1</text></outputEntry>
      </rule>
      <rule id="r_b_c24_tubo_extensor">
        <description>Continua primeiras 24h: tubo extensor incluido (a cada 72h)</description>
        <inputEntry id="ie_b_c24te_1"><text>"CONTINUA_PRIMEIRAS_24H"</text></inputEntry>
        <inputEntry id="ie_b_c24te_2"><text></text></inputEntry>
        <outputEntry id="oe_b_c24te_1"><text>true</text></outputEntry>
        <outputEntry id="oe_b_c24te_2"><text>"Tubo extensor (a cada 72h)"</text></outputEntry>
        <outputEntry id="oe_b_c24te_3"><text>1</text></outputEntry>
      </rule>
      <rule id="r_b_c24_sol_eletro">
        <description>Continua primeiras 24h: solucao eletrolitica 0,61% 5000ml - 10 bolsas/24h</description>
        <inputEntry id="ie_b_c24se_1"><text>"CONTINUA_PRIMEIRAS_24H"</text></inputEntry>
        <inputEntry id="ie_b_c24se_2"><text></text></inputEntry>
        <outputEntry id="oe_b_c24se_1"><text>true</text></outputEntry>
        <outputEntry id="oe_b_c24se_2"><text>"Solucao eletrolitica 0,61% 5000ml"</text></outputEntry>
        <outputEntry id="oe_b_c24se_3"><text>10</text></outputEntry>
      </rule>
      <rule id="r_b_c24_citrato">
        <description>Continua primeiras 24h: citrato de sodio 4% 3000ml - 2 bolsas/24h</description>
        <inputEntry id="ie_b_c24ci_1"><text>"CONTINUA_PRIMEIRAS_24H"</text></inputEntry>
        <inputEntry id="ie_b_c24ci_2"><text></text></inputEntry>
        <outputEntry id="oe_b_c24ci_1"><text>true</text></outputEntry>
        <outputEntry id="oe_b_c24ci_2"><text>"Citrato de sodio 4% 3000ml"</text></outputEntry>
        <outputEntry id="oe_b_c24ci_3"><text>2</text></outputEntry>
      </rule>
      <rule id="r_b_c24_heparina">
        <description>Continua primeiras 24h: frasco heparina sodica 5ml - 1/24h</description>
        <inputEntry id="ie_b_c24h_1"><text>"CONTINUA_PRIMEIRAS_24H"</text></inputEntry>
        <inputEntry id="ie_b_c24h_2"><text></text></inputEntry>
        <outputEntry id="oe_b_c24h_1"><text>true</text></outputEntry>
        <outputEntry id="oe_b_c24h_2"><text>"Heparina sodica 5ml (frasco)"</text></outputEntry>
        <outputEntry id="oe_b_c24h_3"><text>1</text></outputEntry>
      </rule>
      <!-- CONTINUA_PRIMEIRAS_24H - Excluded items -->
      <rule id="r_b_c24_excl_cateter_medico">
        <description>Continua primeiras 24h: honorarios medicos para acesso hemodialise EXCLUIDOS</description>
        <inputEntry id="ie_b_c24ex1_1"><text>"CONTINUA_PRIMEIRAS_24H"</text></inputEntry>
        <inputEntry id="ie_b_c24ex1_2"><text>"acesso_cateter"</text></inputEntry>
        <outputEntry id="oe_b_c24ex1_1"><text>false</text></outputEntry>
        <outputEntry id="oe_b_c24ex1_2"><text>"Honorarios medicos para acesso para hemodialise (EXCLUIDO do pacote)"</text></outputEntry>
        <outputEntry id="oe_b_c24ex1_3"><text>0</text></outputEntry>
      </rule>
      <rule id="r_b_c24_excl_cateter_luminal">
        <description>Continua primeiras 24h: cateter de duplo ou triplo lumen EXCLUIDO</description>
        <inputEntry id="ie_b_c24ex2_1"><text>"CONTINUA_PRIMEIRAS_24H"</text></inputEntry>
        <inputEntry id="ie_b_c24ex2_2"><text>"cateter_luminal"</text></inputEntry>
        <outputEntry id="oe_b_c24ex2_1"><text>false</text></outputEntry>
        <outputEntry id="oe_b_c24ex2_2"><text>"Cateter de duplo ou triplo lumen para hemodialise (EXCLUIDO do pacote)"</text></outputEntry>
        <outputEntry id="oe_b_c24ex2_3"><text>0</text></outputEntry>
      </rule>
      <!-- CONTINUA_SUBSEQUENTE - Kit excluded (main difference vs first 24h) -->
      <rule id="r_b_cs_kit_excluido">
        <description>Continua subsequente: kit especifico maquina EXCLUIDO do pacote (Apendice VIII)</description>
        <inputEntry id="ie_b_csk_1"><text>"CONTINUA_SUBSEQUENTE"</text></inputEntry>
        <inputEntry id="ie_b_csk_2"><text>"kit_maquina"</text></inputEntry>
        <outputEntry id="oe_b_csk_1"><text>false</text></outputEntry>
        <outputEntry id="oe_b_csk_2"><text>"Kit especifico para maquina de hemodialise continua (EXCLUIDO nas 24h subsequentes)"</text></outputEntry>
        <outputEntry id="oe_b_csk_3"><text>0</text></outputEntry>
      </rule>
      <rule id="r_b_cs_sol_eletro">
        <description>Continua subsequente: solucao eletrolitica incluida - 10 bolsas/24h</description>
        <inputEntry id="ie_b_csse_1"><text>"CONTINUA_SUBSEQUENTE"</text></inputEntry>
        <inputEntry id="ie_b_csse_2"><text></text></inputEntry>
        <outputEntry id="oe_b_csse_1"><text>true</text></outputEntry>
        <outputEntry id="oe_b_csse_2"><text>"Solucao eletrolitica 0,61% 5000ml"</text></outputEntry>
        <outputEntry id="oe_b_csse_3"><text>10</text></outputEntry>
      </rule>
      <!-- INTERMITENTE - Included items (kit completo por sessao) -->
      <rule id="r_b_int_capilar">
        <description>Intermitente: capilar (dialyzer) incluido por sessao - sem reuso</description>
        <inputEntry id="ie_b_ic_1"><text>"INTERMITENTE"</text></inputEntry>
        <inputEntry id="ie_b_ic_2"><text></text></inputEntry>
        <outputEntry id="oe_b_ic_1"><text>true</text></outputEntry>
        <outputEntry id="oe_b_ic_2"><text>"Capilar (dialyzer) - sem reuso"</text></outputEntry>
        <outputEntry id="oe_b_ic_3"><text>1</text></outputEntry>
      </rule>
      <rule id="r_b_int_linha_arterial">
        <description>Intermitente: linha arterial incluida por sessao - sem reuso</description>
        <inputEntry id="ie_b_ila_1"><text>"INTERMITENTE"</text></inputEntry>
        <inputEntry id="ie_b_ila_2"><text></text></inputEntry>
        <outputEntry id="oe_b_ila_1"><text>true</text></outputEntry>
        <outputEntry id="oe_b_ila_2"><text>"Linha arterial - sem reuso"</text></outputEntry>
        <outputEntry id="oe_b_ila_3"><text>1</text></outputEntry>
      </rule>
      <rule id="r_b_int_linha_venosa">
        <description>Intermitente: linha venosa incluida por sessao - sem reuso</description>
        <inputEntry id="ie_b_ilv_1"><text>"INTERMITENTE"</text></inputEntry>
        <inputEntry id="ie_b_ilv_2"><text></text></inputEntry>
        <outputEntry id="oe_b_ilv_1"><text>true</text></outputEntry>
        <outputEntry id="oe_b_ilv_2"><text>"Linha venosa - sem reuso"</text></outputEntry>
        <outputEntry id="oe_b_ilv_3"><text>1</text></outputEntry>
      </rule>
      <rule id="r_b_int_sol_acida">
        <description>Intermitente: frasco solucao acida (concentrado A) incluido</description>
        <inputEntry id="ie_b_isa_1"><text>"INTERMITENTE"</text></inputEntry>
        <inputEntry id="ie_b_isa_2"><text></text></inputEntry>
        <outputEntry id="oe_b_isa_1"><text>true</text></outputEntry>
        <outputEntry id="oe_b_isa_2"><text>"Frasco de solucao acida (concentrado A)"</text></outputEntry>
        <outputEntry id="oe_b_isa_3"><text>1</text></outputEntry>
      </rule>
      <rule id="r_b_int_sol_basica">
        <description>Intermitente: frascos solucao basica (concentrado B) incluidos</description>
        <inputEntry id="ie_b_isb_1"><text>"INTERMITENTE"</text></inputEntry>
        <inputEntry id="ie_b_isb_2"><text></text></inputEntry>
        <outputEntry id="oe_b_isb_1"><text>true</text></outputEntry>
        <outputEntry id="oe_b_isb_2"><text>"Frascos de solucao basica (concentrado B)"</text></outputEntry>
        <outputEntry id="oe_b_isb_3"><text>2</text></outputEntry>
      </rule>
      <!-- INTERMITENTE - Excluded items -->
      <rule id="r_b_int_excl_acesso">
        <description>Intermitente: honorarios medicos para acesso EXCLUIDOS</description>
        <inputEntry id="ie_b_iex1_1"><text>"INTERMITENTE"</text></inputEntry>
        <inputEntry id="ie_b_iex1_2"><text>"acesso_cateter"</text></inputEntry>
        <outputEntry id="oe_b_iex1_1"><text>false</text></outputEntry>
        <outputEntry id="oe_b_iex1_2"><text>"Honorarios medicos para acesso para hemodialise (EXCLUIDO do pacote)"</text></outputEntry>
        <outputEntry id="oe_b_iex1_3"><text>0</text></outputEntry>
      </rule>
      <rule id="r_b_int_excl_cateter">
        <description>Intermitente: cateter duplo ou triplo lumen EXCLUIDO</description>
        <inputEntry id="ie_b_iex2_1"><text>"INTERMITENTE"</text></inputEntry>
        <inputEntry id="ie_b_iex2_2"><text>"cateter_luminal"</text></inputEntry>
        <outputEntry id="oe_b_iex2_1"><text>false</text></outputEntry>
        <outputEntry id="oe_b_iex2_2"><text>"Cateter de duplo ou triplo lumen para hemodialise (EXCLUIDO do pacote)"</text></outputEntry>
        <outputEntry id="oe_b_iex2_3"><text>0</text></outputEntry>
      </rule>
      <!-- INTERMITENTE_ESTENDIDA - sol acida e basica extras -->
      <rule id="r_b_ie_sol_acida">
        <description>Intermitente Estendida: 2 frascos solucao acida incluidos (sessao 6-8h)</description>
        <inputEntry id="ie_b_iesa_1"><text>"INTERMITENTE_ESTENDIDA"</text></inputEntry>
        <inputEntry id="ie_b_iesa_2"><text></text></inputEntry>
        <outputEntry id="oe_b_iesa_1"><text>true</text></outputEntry>
        <outputEntry id="oe_b_iesa_2"><text>"Frascos de solucao acida (concentrado A) - sessao estendida"</text></outputEntry>
        <outputEntry id="oe_b_iesa_3"><text>2</text></outputEntry>
      </rule>
      <rule id="r_b_ie_sol_basica">
        <description>Intermitente Estendida: 3 frascos solucao basica incluidos (sessao 6-8h)</description>
        <inputEntry id="ie_b_iesb_1"><text>"INTERMITENTE_ESTENDIDA"</text></inputEntry>
        <inputEntry id="ie_b_iesb_2"><text></text></inputEntry>
        <outputEntry id="oe_b_iesb_1"><text>true</text></outputEntry>
        <outputEntry id="oe_b_iesb_2"><text>"Frascos de solucao basica (concentrado B) - sessao estendida"</text></outputEntry>
        <outputEntry id="oe_b_iesb_3"><text>3</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
