{
  "name": "opme_supplier",
  "archetype": "LOOKUP",
  "description": "OPME supplier material lookup and price validation",
  "version": "1.0.0",
  "hit_policy": "FIRST",
  "inputs": [
    {"name": "material_code", "type": "string", "required": true},
    {"name": "supplier", "type": "string", "required": true},
    {"name": "unit_price", "type": "number", "required": true},
    {"name": "reference_table", "type": "string", "required": false}
  ],
  "outputs": [
    {"name": "approved", "type": "boolean"},
    {"name": "max_price", "type": "number"},
    {"name": "requires_auth", "type": "boolean"},
    {"name": "justification", "type": "string"}
  ],
  "required_inputs": ["material_code", "supplier", "unit_price"],
  "example_rules": []
}
