<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="clinical_safety_quality_metrics" name="Quality Metrics"
             namespace="http://healthcare.platform/dmn/clinical_safety">
  <decision id="decision_quality_metrics" name="Métricas de Qualidade">
    <decisionTable id="dt_quality_metrics" hitPolicy="FIRST">
      <input id="qm_in1" label="Percentil Benchmark">
        <inputExpression typeRef="double"><text>benchmarkPercentile</text></inputExpression>
      </input>
      <input id="qm_in2" label="Metas Atingidas (%)">
        <inputExpression typeRef="double"><text>goalAchievementPct</text></inputExpression>
      </input>
      <output id="qm_out1" label="action" name="action" typeRef="string"/>
      <output id="qm_out2" label="qualityTier" name="qualityTier" typeRef="string"/>
      <output id="qm_out3" label="justificativa" name="justificativa" typeRef="string"/>

      <rule id="qm_r1">
        <inputEntry><text>&gt;= 75</text></inputEntry>
        <inputEntry><text>&gt;= 80</text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"tier_1"</text></outputEntry>
        <outputEntry><text>"Qualidade excelente - elegível para programas de valor"</text></outputEntry>
      </rule>
      <rule id="qm_r2">
        <inputEntry><text>[50..75)</text></inputEntry>
        <inputEntry><text>&gt;= 60</text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"tier_2"</text></outputEntry>
        <outputEntry><text>"Qualidade adequada - manter monitoramento"</text></outputEntry>
      </rule>
      <rule id="qm_r3">
        <inputEntry><text>[25..50)</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"tier_3"</text></outputEntry>
        <outputEntry><text>"Qualidade abaixo da média - plano de melhoria necessário"</text></outputEntry>
      </rule>
      <rule id="qm_r4">
        <inputEntry><text>&lt; 25</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"tier_4"</text></outputEntry>
        <outputEntry><text>"Qualidade crítica - intervenção imediata"</text></outputEntry>
      </rule>
      <rule id="qm_r5">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"unclassified"</text></outputEntry>
        <outputEntry><text>"Dados insuficientes para classificação"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
