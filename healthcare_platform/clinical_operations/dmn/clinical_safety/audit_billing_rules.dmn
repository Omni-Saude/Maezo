<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="clinical_safety_audit_billing" name="Audit Billing Rules"
             namespace="http://healthcare.platform/dmn/clinical_safety">
  <decision id="decision_audit_billing" name="Regras de Auditoria de Faturamento">
    <decisionTable id="dt_audit_billing" hitPolicy="FIRST">
      <input id="ab_in1" label="Discrepância de Cobrança (%)">
        <inputExpression typeRef="double"><text>billingDiscrepancy</text></inputExpression>
      </input>
      <output id="ab_out1" label="action" name="action" typeRef="string"/>
      <output id="ab_out2" label="billingAuditStatus" name="billingAuditStatus" typeRef="string"/>
      <output id="ab_out3" label="justificativa" name="justificativa" typeRef="string"/>

      <rule id="ab_r1">
        <inputEntry><text>&lt;= 2</text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"within_tolerance"</text></outputEntry>
        <outputEntry><text>"Faturamento dentro da tolerância"</text></outputEntry>
      </rule>
      <rule id="ab_r2">
        <inputEntry><text>(2..10]</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"minor_discrepancy"</text></outputEntry>
        <outputEntry><text>"Discrepância menor - verificar lançamentos"</text></outputEntry>
      </rule>
      <rule id="ab_r3">
        <inputEntry><text>&gt; 10</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"major_discrepancy"</text></outputEntry>
        <outputEntry><text>"Discrepância significativa - auditoria detalhada obrigatória"</text></outputEntry>
      </rule>
      <rule id="ab_r4">
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"not_assessed"</text></outputEntry>
        <outputEntry><text>"Auditoria de faturamento não realizada"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
