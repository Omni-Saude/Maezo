<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="clinical_safety_readmission_risk" name="Readmission Risk"
             namespace="http://healthcare.platform/dmn/clinical_safety">
  <decision id="decision_readmission_risk" name="Risco de Readmissão">
    <decisionTable id="dt_readmission_risk" hitPolicy="FIRST">
      <input id="rr_in1" label="Tendência de Melhoria">
        <inputExpression typeRef="string"><text>improvementTrend</text></inputExpression>
      </input>
      <input id="rr_in2" label="Score de Desfecho">
        <inputExpression typeRef="double"><text>outcomeScore</text></inputExpression>
      </input>
      <output id="rr_out1" label="action" name="action" typeRef="string"/>
      <output id="rr_out2" label="riskLevel" name="riskLevel" typeRef="string"/>
      <output id="rr_out3" label="justificativa" name="justificativa" typeRef="string"/>

      <rule id="rr_r1">
        <inputEntry><text>"declining"</text></inputEntry>
        <inputEntry><text>&lt; 50</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"high"</text></outputEntry>
        <outputEntry><text>"Alto risco de readmissão - intensificar acompanhamento pós-alta"</text></outputEntry>
      </rule>
      <rule id="rr_r2">
        <inputEntry><text>"declining"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"moderate"</text></outputEntry>
        <outputEntry><text>"Risco moderado de readmissão - revisar plano de alta"</text></outputEntry>
      </rule>
      <rule id="rr_r3">
        <inputEntry><text>"stable"</text></inputEntry>
        <inputEntry><text>&lt; 60</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"moderate"</text></outputEntry>
        <outputEntry><text>"Estabilidade com score baixo - avaliar barreiras à melhora"</text></outputEntry>
      </rule>
      <rule id="rr_r4">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"low"</text></outputEntry>
        <outputEntry><text>"Baixo risco de readmissão"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
