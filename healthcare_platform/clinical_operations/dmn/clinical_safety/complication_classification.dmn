<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="clinical_safety_complication_class" name="Complication Classification"
             namespace="http://healthcare.platform/dmn/clinical_safety">
  <decision id="decision_complication_classification" name="Classificação de Complicações">
    <decisionTable id="dt_complication_classification" hitPolicy="FIRST">
      <input id="cc_in1" label="Significância Clínica">
        <inputExpression typeRef="string"><text>clinicalSignificance</text></inputExpression>
      </input>
      <input id="cc_in2" label="Tendência">
        <inputExpression typeRef="string"><text>improvementTrend</text></inputExpression>
      </input>
      <output id="cc_out1" label="action" name="action" typeRef="string"/>
      <output id="cc_out2" label="complicationGrade" name="complicationGrade" typeRef="string"/>
      <output id="cc_out3" label="justificativa" name="justificativa" typeRef="string"/>

      <rule id="cc_r1">
        <inputEntry><text>"decline"</text></inputEntry>
        <inputEntry><text>"declining"</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"severe"</text></outputEntry>
        <outputEntry><text>"Declínio clínico progressivo - intervenção urgente"</text></outputEntry>
      </rule>
      <rule id="cc_r2">
        <inputEntry><text>"decline"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"moderate"</text></outputEntry>
        <outputEntry><text>"Declínio detectado - avaliar causa"</text></outputEntry>
      </rule>
      <rule id="cc_r3">
        <inputEntry><text>"no_change"</text></inputEntry>
        <inputEntry><text>"declining"</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"mild"</text></outputEntry>
        <outputEntry><text>"Sem melhora com tendência negativa - ajustar tratamento"</text></outputEntry>
      </rule>
      <rule id="cc_r4">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"none"</text></outputEntry>
        <outputEntry><text>"Sem complicações detectadas"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
