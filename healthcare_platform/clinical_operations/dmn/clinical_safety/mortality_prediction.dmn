<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="clinical_safety_mortality_prediction" name="Mortality Prediction"
             namespace="http://healthcare.platform/dmn/clinical_safety">
  <decision id="decision_mortality_prediction" name="Predição de Mortalidade">
    <decisionTable id="dt_mortality_prediction" hitPolicy="FIRST">
      <input id="mp_in1" label="Score de Desfecho">
        <inputExpression typeRef="double"><text>outcomeScore</text></inputExpression>
      </input>
      <input id="mp_in2" label="Significância Clínica">
        <inputExpression typeRef="string"><text>clinicalSignificance</text></inputExpression>
      </input>
      <input id="mp_in3" label="Tendência">
        <inputExpression typeRef="string"><text>improvementTrend</text></inputExpression>
      </input>
      <output id="mp_out1" label="action" name="action" typeRef="string"/>
      <output id="mp_out2" label="mortalityRisk" name="mortalityRisk" typeRef="string"/>
      <output id="mp_out3" label="justificativa" name="justificativa" typeRef="string"/>

      <rule id="mp_r1">
        <inputEntry><text>&lt; 30</text></inputEntry>
        <inputEntry><text>"decline"</text></inputEntry>
        <inputEntry><text>"declining"</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"high"</text></outputEntry>
        <outputEntry><text>"Risco elevado de mortalidade - cuidados paliativos ou UTI"</text></outputEntry>
      </rule>
      <rule id="mp_r2">
        <inputEntry><text>&lt; 40</text></inputEntry>
        <inputEntry><text>"decline"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"moderate"</text></outputEntry>
        <outputEntry><text>"Risco moderado - intensificar monitoramento"</text></outputEntry>
      </rule>
      <rule id="mp_r3">
        <inputEntry><text>&lt; 50</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"declining"</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"moderate"</text></outputEntry>
        <outputEntry><text>"Score baixo com declínio - avaliar prognóstico"</text></outputEntry>
      </rule>
      <rule id="mp_r4">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"low"</text></outputEntry>
        <outputEntry><text>"Baixo risco de mortalidade"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
