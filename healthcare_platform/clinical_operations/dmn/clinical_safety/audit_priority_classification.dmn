<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="clinical_safety_audit_priority" name="Audit Priority Classification"
             namespace="http://healthcare.platform/dmn/clinical_safety">
  <decision id="decision_audit_priority" name="Classificação de Prioridade de Auditoria">
    <decisionTable id="dt_audit_priority" hitPolicy="FIRST">
      <input id="apc_in1" label="Tipo de Auditoria">
        <inputExpression typeRef="string"><text>auditType</text></inputExpression>
      </input>
      <input id="apc_in2" label="Severidade do Achado">
        <inputExpression typeRef="string"><text>findingSeverity</text></inputExpression>
      </input>
      <output id="apc_out1" label="action" name="action" typeRef="string"/>
      <output id="apc_out2" label="priority" name="priority" typeRef="string"/>
      <output id="apc_out3" label="dueDays" name="dueDays" typeRef="integer"/>
      <output id="apc_out4" label="justificativa" name="justificativa" typeRef="string"/>

      <rule id="apc_r1">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"critical"</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"urgent"</text></outputEntry>
        <outputEntry><text>1</text></outputEntry>
        <outputEntry><text>"Achado crítico - resolução em 24h"</text></outputEntry>
      </rule>
      <rule id="apc_r2">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"high"</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"high"</text></outputEntry>
        <outputEntry><text>3</text></outputEntry>
        <outputEntry><text>"Achado de alta severidade - resolução em 72h"</text></outputEntry>
      </rule>
      <rule id="apc_r3">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"medium"</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"medium"</text></outputEntry>
        <outputEntry><text>7</text></outputEntry>
        <outputEntry><text>"Achado moderado - resolução em 7 dias"</text></outputEntry>
      </rule>
      <rule id="apc_r4">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"low"</text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"low"</text></outputEntry>
        <outputEntry><text>30</text></outputEntry>
        <outputEntry><text>"Achado de baixa severidade - resolução em 30 dias"</text></outputEntry>
      </rule>
      <rule id="apc_r5">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"medium"</text></outputEntry>
        <outputEntry><text>7</text></outputEntry>
        <outputEntry><text>"Severidade não classificada - tratar como média"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
