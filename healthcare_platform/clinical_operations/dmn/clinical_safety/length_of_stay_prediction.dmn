<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="clinical_safety_los_prediction" name="Length of Stay Prediction"
             namespace="http://healthcare.platform/dmn/clinical_safety">
  <decision id="decision_los_prediction" name="Predição de Tempo de Internação">
    <decisionTable id="dt_los_prediction" hitPolicy="FIRST">
      <input id="los_in1" label="Score de Desfecho">
        <inputExpression typeRef="double"><text>outcomeScore</text></inputExpression>
      </input>
      <input id="los_in2" label="Tipo de Avaliação">
        <inputExpression typeRef="string"><text>assessmentType</text></inputExpression>
      </input>
      <output id="los_out1" label="action" name="action" typeRef="string"/>
      <output id="los_out2" label="losCategory" name="losCategory" typeRef="string"/>
      <output id="los_out3" label="nextAssessmentDays" name="nextAssessmentDays" typeRef="integer"/>
      <output id="los_out4" label="justificativa" name="justificativa" typeRef="string"/>

      <rule id="los_r1">
        <inputEntry><text>&gt;= 80</text></inputEntry>
        <inputEntry><text>"interim","final"</text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"early_discharge"</text></outputEntry>
        <outputEntry><text>90</text></outputEntry>
        <outputEntry><text>"Candidato a alta precoce"</text></outputEntry>
      </rule>
      <rule id="los_r2">
        <inputEntry><text>[60..80)</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"expected"</text></outputEntry>
        <outputEntry><text>30</text></outputEntry>
        <outputEntry><text>"Tempo de internação dentro do esperado"</text></outputEntry>
      </rule>
      <rule id="los_r3">
        <inputEntry><text>[40..60)</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"extended"</text></outputEntry>
        <outputEntry><text>14</text></outputEntry>
        <outputEntry><text>"Possível prolongamento - revisar plano"</text></outputEntry>
      </rule>
      <rule id="los_r4">
        <inputEntry><text>&lt; 40</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"prolonged"</text></outputEntry>
        <outputEntry><text>7</text></outputEntry>
        <outputEntry><text>"Internação prolongada prevista - avaliar barreiras"</text></outputEntry>
      </rule>
      <rule id="los_r5">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"baseline"</text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"initial"</text></outputEntry>
        <outputEntry><text>14</text></outputEntry>
        <outputEntry><text>"Avaliação inicial - acompanhamento em 14 dias"</text></outputEntry>
      </rule>
      <rule id="los_r6">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"unknown"</text></outputEntry>
        <outputEntry><text>14</text></outputEntry>
        <outputEntry><text>"Dados insuficientes para predição"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
