<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns='https://www.omg.org/spec/DMN/20191111/MODEL/'
  id='clinical_safety_vit_threshold_001' name='Vital Sign Threshold Classification'
  namespace='http://healthcare.platform/dmn/clinical_safety'>
  <decision id='decision_vit_threshold_001' name='Vital Sign Threshold Classification'>
    <decisionTable id='dt_vit_threshold_001' hitPolicy='FIRST'>
      <input id='input_1' label='vitalSignType'>
        <inputExpression typeRef='string'><text>vitalSignType</text></inputExpression>
      </input>
      <input id='input_2' label='value'>
        <inputExpression typeRef='double'><text>value</text></inputExpression>
      </input>
      <!-- CRITICAL LOW -->
      <output id='output_1' label='severity' typeRef='string'/>
      <output id='output_2' label='classification' typeRef='string'/>
      <output id='output_3' label='action' typeRef='string'/>
      <!-- HR critical low -->
      <rule id='rule_1'>
        <inputEntry><text>"heart_rate"</text></inputEntry>
        <inputEntry><text>&lt; 40</text></inputEntry>
        <outputEntry><text>"CRITICAL"</text></outputEntry>
        <outputEntry><text>"Bradicardia severa"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
      </rule>
      <!-- HR low -->
      <rule id='rule_2'>
        <inputEntry><text>"heart_rate"</text></inputEntry>
        <inputEntry><text>[40..60)</text></inputEntry>
        <outputEntry><text>"WARNING"</text></outputEntry>
        <outputEntry><text>"Bradicardia"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
      <!-- HR normal -->
      <rule id='rule_3'>
        <inputEntry><text>"heart_rate"</text></inputEntry>
        <inputEntry><text>[60..100]</text></inputEntry>
        <outputEntry><text>"INFO"</text></outputEntry>
        <outputEntry><text>"Normal"</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
      <!-- HR high -->
      <rule id='rule_4'>
        <inputEntry><text>"heart_rate"</text></inputEntry>
        <inputEntry><text>(100..130]</text></inputEntry>
        <outputEntry><text>"WARNING"</text></outputEntry>
        <outputEntry><text>"Taquicardia"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
      <!-- HR critical high -->
      <rule id='rule_5'>
        <inputEntry><text>"heart_rate"</text></inputEntry>
        <inputEntry><text>&gt; 130</text></inputEntry>
        <outputEntry><text>"CRITICAL"</text></outputEntry>
        <outputEntry><text>"Taquicardia severa"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
      </rule>
      <!-- SpO2 critical -->
      <rule id='rule_6'>
        <inputEntry><text>"oxygen_saturation"</text></inputEntry>
        <inputEntry><text>&lt; 90</text></inputEntry>
        <outputEntry><text>"CRITICAL"</text></outputEntry>
        <outputEntry><text>"Hipoxemia severa"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
      </rule>
      <!-- SpO2 low -->
      <rule id='rule_7'>
        <inputEntry><text>"oxygen_saturation"</text></inputEntry>
        <inputEntry><text>[90..95)</text></inputEntry>
        <outputEntry><text>"WARNING"</text></outputEntry>
        <outputEntry><text>"Hipoxemia"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
      <!-- SpO2 normal -->
      <rule id='rule_8'>
        <inputEntry><text>"oxygen_saturation"</text></inputEntry>
        <inputEntry><text>[95..100]</text></inputEntry>
        <outputEntry><text>"INFO"</text></outputEntry>
        <outputEntry><text>"Normal"</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
      <!-- Temp critical low -->
      <rule id='rule_9'>
        <inputEntry><text>"temperature_celsius"</text></inputEntry>
        <inputEntry><text>&lt; 35.0</text></inputEntry>
        <outputEntry><text>"CRITICAL"</text></outputEntry>
        <outputEntry><text>"Hipotermia severa"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
      </rule>
      <!-- Temp low -->
      <rule id='rule_10'>
        <inputEntry><text>"temperature_celsius"</text></inputEntry>
        <inputEntry><text>[35.0..36.0)</text></inputEntry>
        <outputEntry><text>"WARNING"</text></outputEntry>
        <outputEntry><text>"Hipotermia"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
      <!-- Temp normal -->
      <rule id='rule_11'>
        <inputEntry><text>"temperature_celsius"</text></inputEntry>
        <inputEntry><text>[36.0..37.5]</text></inputEntry>
        <outputEntry><text>"INFO"</text></outputEntry>
        <outputEntry><text>"Normal"</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
      <!-- Temp high -->
      <rule id='rule_12'>
        <inputEntry><text>"temperature_celsius"</text></inputEntry>
        <inputEntry><text>(37.5..39.0]</text></inputEntry>
        <outputEntry><text>"WARNING"</text></outputEntry>
        <outputEntry><text>"Febre"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
      <!-- Temp critical high -->
      <rule id='rule_13'>
        <inputEntry><text>"temperature_celsius"</text></inputEntry>
        <inputEntry><text>&gt; 39.0</text></inputEntry>
        <outputEntry><text>"CRITICAL"</text></outputEntry>
        <outputEntry><text>"Febre alta"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
      </rule>
      <!-- Systolic BP critical low -->
      <rule id='rule_14'>
        <inputEntry><text>"systolic_bp"</text></inputEntry>
        <inputEntry><text>&lt; 80</text></inputEntry>
        <outputEntry><text>"CRITICAL"</text></outputEntry>
        <outputEntry><text>"Hipotensao severa"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
      </rule>
      <!-- Systolic BP low -->
      <rule id='rule_15'>
        <inputEntry><text>"systolic_bp"</text></inputEntry>
        <inputEntry><text>[80..90)</text></inputEntry>
        <outputEntry><text>"WARNING"</text></outputEntry>
        <outputEntry><text>"Hipotensao"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
      <!-- Systolic BP normal -->
      <rule id='rule_16'>
        <inputEntry><text>"systolic_bp"</text></inputEntry>
        <inputEntry><text>[90..140]</text></inputEntry>
        <outputEntry><text>"INFO"</text></outputEntry>
        <outputEntry><text>"Normal"</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
      <!-- Systolic BP high -->
      <rule id='rule_17'>
        <inputEntry><text>"systolic_bp"</text></inputEntry>
        <inputEntry><text>(140..180]</text></inputEntry>
        <outputEntry><text>"WARNING"</text></outputEntry>
        <outputEntry><text>"Hipertensao"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
      <!-- Systolic BP critical high -->
      <rule id='rule_18'>
        <inputEntry><text>"systolic_bp"</text></inputEntry>
        <inputEntry><text>&gt; 180</text></inputEntry>
        <outputEntry><text>"CRITICAL"</text></outputEntry>
        <outputEntry><text>"Crise hipertensiva"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
      </rule>
      <!-- RR critical low -->
      <rule id='rule_19'>
        <inputEntry><text>"respiratory_rate"</text></inputEntry>
        <inputEntry><text>&lt; 8</text></inputEntry>
        <outputEntry><text>"CRITICAL"</text></outputEntry>
        <outputEntry><text>"Bradipneia severa"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
      </rule>
      <!-- RR low -->
      <rule id='rule_20'>
        <inputEntry><text>"respiratory_rate"</text></inputEntry>
        <inputEntry><text>[8..12)</text></inputEntry>
        <outputEntry><text>"WARNING"</text></outputEntry>
        <outputEntry><text>"Bradipneia"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
      <!-- RR normal -->
      <rule id='rule_21'>
        <inputEntry><text>"respiratory_rate"</text></inputEntry>
        <inputEntry><text>[12..20]</text></inputEntry>
        <outputEntry><text>"INFO"</text></outputEntry>
        <outputEntry><text>"Normal"</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
      <!-- RR high -->
      <rule id='rule_22'>
        <inputEntry><text>"respiratory_rate"</text></inputEntry>
        <inputEntry><text>(20..30]</text></inputEntry>
        <outputEntry><text>"WARNING"</text></outputEntry>
        <outputEntry><text>"Taquipneia"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
      <!-- RR critical high -->
      <rule id='rule_23'>
        <inputEntry><text>"respiratory_rate"</text></inputEntry>
        <inputEntry><text>&gt; 30</text></inputEntry>
        <outputEntry><text>"CRITICAL"</text></outputEntry>
        <outputEntry><text>"Taquipneia severa"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
      </rule>
      <!-- Fallback -->
      <rule id='rule_99'>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <outputEntry><text>"WARNING"</text></outputEntry>
        <outputEntry><text>"Parametro desconhecido"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
