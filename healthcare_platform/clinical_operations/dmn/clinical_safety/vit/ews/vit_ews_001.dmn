<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns='https://www.omg.org/spec/DMN/20191111/MODEL/'
  id='clinical_safety_vit_ews_001' name='Early Warning Score Triggers'
  namespace='http://healthcare.platform/dmn/clinical_safety'>
  <decision id='decision_vit_ews_001' name='Early Warning Score Triggers'>
    <decisionTable id='dt_vit_ews_001' hitPolicy='FIRST'>
      <input id='input_1' label='ewsScore'>
        <inputExpression typeRef='integer'><text>ewsScore</text></inputExpression>
      </input>
      <output id='output_1' label='riskLevel' typeRef='string'/>
      <output id='output_2' label='action' typeRef='string'/>
      <output id='output_3' label='escalationInterval' typeRef='string'/>
      <!-- NEWS2/MEWS score thresholds -->
      <rule id='rule_1'>
        <inputEntry><text>&gt;= 7</text></inputEntry>
        <outputEntry><text>"CRITICAL"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"Imediato - Time de resposta rapida"</text></outputEntry>
      </rule>
      <rule id='rule_2'>
        <inputEntry><text>[5..7)</text></inputEntry>
        <outputEntry><text>"HIGH"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"30min - Avaliacao medica urgente"</text></outputEntry>
      </rule>
      <rule id='rule_3'>
        <inputEntry><text>[3..5)</text></inputEntry>
        <outputEntry><text>"MEDIUM"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"1h - Aumentar frequencia de monitorizacao"</text></outputEntry>
      </rule>
      <rule id='rule_4'>
        <inputEntry><text>[1..3)</text></inputEntry>
        <outputEntry><text>"LOW"</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"4h - Monitorizacao de rotina"</text></outputEntry>
      </rule>
      <rule id='rule_5'>
        <inputEntry><text>0</text></inputEntry>
        <outputEntry><text>"NONE"</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"12h - Monitorizacao padrao"</text></outputEntry>
      </rule>
      <rule id='rule_99'>
        <inputEntry><text></text></inputEntry>
        <outputEntry><text>"MEDIUM"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"1h - Score indeterminado"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
