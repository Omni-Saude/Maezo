<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns='https://www.omg.org/spec/DMN/20191111/MODEL/'
  id='clinical_safety_vit_escalation_001' name='Vital Signs Escalation Rules'
  namespace='http://healthcare.platform/dmn/clinical_safety'>
  <decision id='decision_vit_escalation_001' name='Vital Signs Escalation Rules'>
    <decisionTable id='dt_vit_escalation_001' hitPolicy='FIRST'>
      <input id='input_1' label='severityLevel'>
        <inputExpression typeRef='string'><text>severityLevel</text></inputExpression>
      </input>
      <input id='input_2' label='criticalCount'>
        <inputExpression typeRef='integer'><text>criticalCount</text></inputExpression>
      </input>
      <output id='output_1' label='action' typeRef='string'/>
      <output id='output_2' label='notifyTeam' typeRef='string'/>
      <output id='output_3' label='requiresImmediate' typeRef='boolean'/>
      <!-- Multiple critical signs -->
      <rule id='rule_1'>
        <inputEntry><text>"CRITICAL"</text></inputEntry>
        <inputEntry><text>&gt;= 2</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"RRT,medico_plantonista,enfermeiro_chefe"</text></outputEntry>
        <outputEntry><text>true</text></outputEntry>
      </rule>
      <!-- Single critical -->
      <rule id='rule_2'>
        <inputEntry><text>"CRITICAL"</text></inputEntry>
        <inputEntry><text>1</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"medico_plantonista,enfermeiro"</text></outputEntry>
        <outputEntry><text>true</text></outputEntry>
      </rule>
      <!-- Warning -->
      <rule id='rule_3'>
        <inputEntry><text>"WARNING"</text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"enfermeiro"</text></outputEntry>
        <outputEntry><text>false</text></outputEntry>
      </rule>
      <!-- Normal -->
      <rule id='rule_4'>
        <inputEntry><text>"INFO"</text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>""</text></outputEntry>
        <outputEntry><text>false</text></outputEntry>
      </rule>
      <!-- Fallback -->
      <rule id='rule_99'>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"enfermeiro"</text></outputEntry>
        <outputEntry><text>false</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
