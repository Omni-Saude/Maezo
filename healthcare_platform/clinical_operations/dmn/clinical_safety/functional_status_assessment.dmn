<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="clinical_safety_functional_status" name="Functional Status Assessment"
             namespace="http://healthcare.platform/dmn/clinical_safety">
  <decision id="decision_functional_status" name="Avaliação de Status Funcional">
    <decisionTable id="dt_functional_status" hitPolicy="FIRST">
      <input id="fs_in1" label="Score Funcional">
        <inputExpression typeRef="double"><text>functionalScore</text></inputExpression>
      </input>
      <input id="fs_in2" label="Mudança vs Baseline (%)">
        <inputExpression typeRef="double"><text>changeFromBaseline</text></inputExpression>
      </input>
      <output id="fs_out1" label="action" name="action" typeRef="string"/>
      <output id="fs_out2" label="functionalStatus" name="functionalStatus" typeRef="string"/>
      <output id="fs_out3" label="justificativa" name="justificativa" typeRef="string"/>

      <rule id="fs_r1">
        <inputEntry><text>&gt;= 80</text></inputEntry>
        <inputEntry><text>&gt;= 10</text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"independent"</text></outputEntry>
        <outputEntry><text>"Funcionalidade preservada com melhora significativa"</text></outputEntry>
      </rule>
      <rule id="fs_r2">
        <inputEntry><text>[60..80)</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"moderate_dependency"</text></outputEntry>
        <outputEntry><text>"Dependência moderada - manter reabilitação"</text></outputEntry>
      </rule>
      <rule id="fs_r3">
        <inputEntry><text>[40..60)</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"significant_dependency"</text></outputEntry>
        <outputEntry><text>"Dependência significativa - intensificar reabilitação"</text></outputEntry>
      </rule>
      <rule id="fs_r4">
        <inputEntry><text>&lt; 40</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"severe_dependency"</text></outputEntry>
        <outputEntry><text>"Dependência severa - avaliar necessidade de cuidados especializados"</text></outputEntry>
      </rule>
      <rule id="fs_r5">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"not_assessed"</text></outputEntry>
        <outputEntry><text>"Status funcional não avaliado"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
