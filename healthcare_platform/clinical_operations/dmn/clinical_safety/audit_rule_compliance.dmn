<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="clinical_safety_audit_rule" name="Audit Rule Compliance"
             namespace="http://healthcare.platform/dmn/clinical_safety">
  <decision id="decision_audit_rule_compliance" name="Conformidade de Regras de Auditoria">
    <decisionTable id="dt_audit_rule_compliance" hitPolicy="FIRST">
      <input id="arc_in1" label="Score de Conformidade (%)">
        <inputExpression typeRef="double"><text>complianceScore</text></inputExpression>
      </input>
      <input id="arc_in2" label="Achados com Severidade Crítica">
        <inputExpression typeRef="integer"><text>criticalFindingsCount</text></inputExpression>
      </input>
      <output id="arc_out1" label="action" name="action" typeRef="string"/>
      <output id="arc_out2" label="overallStatus" name="overallStatus" typeRef="string"/>
      <output id="arc_out3" label="nextAuditDays" name="nextAuditDays" typeRef="integer"/>
      <output id="arc_out4" label="justificativa" name="justificativa" typeRef="string"/>

      <rule id="arc_r1">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>&gt; 0</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"non_compliant"</text></outputEntry>
        <outputEntry><text>7</text></outputEntry>
        <outputEntry><text>"Achados críticos requerem ação corretiva imediata"</text></outputEntry>
      </rule>
      <rule id="arc_r2">
        <inputEntry><text>&gt;= 90</text></inputEntry>
        <inputEntry><text>0</text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"compliant"</text></outputEntry>
        <outputEntry><text>90</text></outputEntry>
        <outputEntry><text>"Conforme - próxima auditoria trimestral"</text></outputEntry>
      </rule>
      <rule id="arc_r3">
        <inputEntry><text>[70..90)</text></inputEntry>
        <inputEntry><text>0</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"needs_review"</text></outputEntry>
        <outputEntry><text>30</text></outputEntry>
        <outputEntry><text>"Necessita revisão - próxima auditoria mensal"</text></outputEntry>
      </rule>
      <rule id="arc_r4">
        <inputEntry><text>&lt; 70</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"non_compliant"</text></outputEntry>
        <outputEntry><text>7</text></outputEntry>
        <outputEntry><text>"Não conforme - auditoria semanal até resolução"</text></outputEntry>
      </rule>
      <rule id="arc_r5">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"not_assessed"</text></outputEntry>
        <outputEntry><text>14</text></outputEntry>
        <outputEntry><text>"Conformidade não avaliada"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
