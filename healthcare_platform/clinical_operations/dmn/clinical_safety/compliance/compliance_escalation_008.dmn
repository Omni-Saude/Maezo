<?xml version="1.0" encoding="UTF-8"?>
<!--
  COMPLIANCE_ESCALATION_008: Escalation Rules
  Clinical Compliance DMN - Extracted from clinical_compliance_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_compliance_escalation_008"
             name="Escalation Rules"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_compliance_escalation_008" name="Escalation Rules">
    <decisionTable id="DecisionTable_compliance_escalation_008" hitPolicy="FIRST">

      <input id="Input_1" label="violationSeverity">
        <inputExpression id="InputExpression_1" typeRef="string">
          <text>violationSeverity</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="criticalCount">
        <inputExpression id="InputExpression_2" typeRef="string">
          <text>criticalCount</text>
        </inputExpression>
      </input>

      <output id="Output_1" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1">
        <inputEntry id="IE_1_1"><text>"critical"</text></inputEntry>
        <inputEntry id="IE_1_2"><text>>= 1</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"Violacao critica. Escalar para diretoria medica imediatamente."</text></outputEntry>
        <outputEntry id="OE_1_4"><text>"Violacoes criticas requerem notificacao da alta direcao e plano de acao."</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <inputEntry id="IE_2_1"><text>"major"</text></inputEntry>
        <inputEntry id="IE_2_2"><text>>= 3</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"URGENTE"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"Multiplas violacoes maiores. Escalar para gerencia."</text></outputEntry>
        <outputEntry id="OE_2_4"><text>"Acumulo de violacoes maiores indica falha sistemica."</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <inputEntry id="IE_3_1"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"Sem necessidade de escalacao. Tratar via processo padrao."</text></outputEntry>
        <outputEntry id="OE_3_4"><text>"Violacoes menores tratadas pela equipe de qualidade local."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"Verificar dados de entrada e reavaliar conformidade."</text></outputEntry>
        <outputEntry id="OE_F_4"><text>"Dados insuficientes para avaliacao automatica de conformidade."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_compliance_escalation_008">
      <dmndi:DMNShape id="DMNShape_compliance_escalation_008" dmnElementRef="Decision_compliance_escalation_008">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
