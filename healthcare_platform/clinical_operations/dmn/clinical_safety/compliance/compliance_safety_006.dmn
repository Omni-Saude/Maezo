<?xml version="1.0" encoding="UTF-8"?>
<!--
  COMPLIANCE_SAFETY_006: Safety Protocol Compliance
  Clinical Compliance DMN - Extracted from clinical_compliance_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_compliance_safety_006"
             name="Safety Protocol Compliance"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_compliance_safety_006" name="Safety Protocol Compliance">
    <decisionTable id="DecisionTable_compliance_safety_006" hitPolicy="FIRST">

      <input id="Input_1" label="safetyDomain">
        <inputExpression id="InputExpression_1" typeRef="string">
          <text>safetyDomain</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="adherenceRate">
        <inputExpression id="InputExpression_2" typeRef="string">
          <text>adherenceRate</text>
        </inputExpression>
      </input>

      <output id="Output_1" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1">
        <inputEntry id="IE_1_1"><text>-</text></inputEntry>
        <inputEntry id="IE_1_2"><text>< 90.0</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"Adesao ao protocolo de seguranca critica (< 90%). Acoes imediatas."</text></outputEntry>
        <outputEntry id="OE_1_4"><text>"Adesao < 90% aos protocolos de seguranca representa risco ao paciente."</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <inputEntry id="IE_2_1"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2"><text>[90.0..95.0)</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"URGENTE"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"Adesao ao protocolo abaixo da meta. Reforcar treinamento."</text></outputEntry>
        <outputEntry id="OE_2_4"><text>"Adesao entre 90-95% indica necessidade de reforco nas praticas."</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <inputEntry id="IE_3_1"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2"><text>>= 95.0</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"Adesao ao protocolo de seguranca adequada."</text></outputEntry>
        <outputEntry id="OE_3_4"><text>"Adesao >= 95% atende as metas de seguranca do paciente."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"Verificar dados de entrada e reavaliar conformidade."</text></outputEntry>
        <outputEntry id="OE_F_4"><text>"Dados insuficientes para avaliacao automatica de conformidade."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_compliance_safety_006">
      <dmndi:DMNShape id="DMNShape_compliance_safety_006" dmnElementRef="Decision_compliance_safety_006">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
