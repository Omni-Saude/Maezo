<?xml version="1.0" encoding="UTF-8"?>
<!--
  COMPLIANCE_INFECT_005: Infection Control Compliance
  Clinical Compliance DMN - Extracted from clinical_compliance_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_compliance_infect_005"
             name="Infection Control Compliance"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_compliance_infect_005" name="Infection Control Compliance">
    <decisionTable id="DecisionTable_compliance_infect_005" hitPolicy="FIRST">

      <input id="Input_1" label="infectionMetric">
        <inputExpression id="InputExpression_1" typeRef="string">
          <text>infectionMetric</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="metricValue">
        <inputExpression id="InputExpression_2" typeRef="string">
          <text>metricValue</text>
        </inputExpression>
      </input>

      <output id="Output_1" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1">
        <inputEntry id="IE_1_1"><text>"hand_hygiene"</text></inputEntry>
        <inputEntry id="IE_1_2"><text>< 80.0</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"Adesao a higiene de maos critica (< 80%). Acionar CCIH."</text></outputEntry>
        <outputEntry id="OE_1_4"><text>"Higiene de maos < 80% aumenta significativamente risco de IRAS."</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <inputEntry id="IE_2_1"><text>"iras_rate"</text></inputEntry>
        <inputEntry id="IE_2_2"><text>>= 5.0</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"Taxa de IRAS elevada (>= 5%). Investigacao epidemiologica."</text></outputEntry>
        <outputEntry id="OE_2_4"><text>"IRAS >= 5% indica falhas nos protocolos de controle de infeccao."</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <inputEntry id="IE_3_1"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"Indicadores de controle de infeccao adequados."</text></outputEntry>
        <outputEntry id="OE_3_4"><text>"Metricas de infeccao dentro dos parametros aceitaveis."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"Verificar dados de entrada e reavaliar conformidade."</text></outputEntry>
        <outputEntry id="OE_F_4"><text>"Dados insuficientes para avaliacao automatica de conformidade."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_compliance_infect_005">
      <dmndi:DMNShape id="DMNShape_compliance_infect_005" dmnElementRef="Decision_compliance_infect_005">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
