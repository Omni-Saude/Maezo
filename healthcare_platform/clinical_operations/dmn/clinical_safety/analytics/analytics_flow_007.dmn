<?xml version="1.0" encoding="UTF-8"?>
<!--
  ANALYTICS_FLOW_007: Patient Flow Analytics
  Clinical Analytics DMN - Extracted from clinical_analytics_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_analytics_flow_007"
             name="Patient Flow Analytics"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_analytics_flow_007" name="Patient Flow Analytics">
    <decisionTable id="DecisionTable_analytics_flow_007" hitPolicy="FIRST">

      <input id="Input_1" label="flowMetric">
        <inputExpression id="InputExpression_1" typeRef="string">
          <text>flowMetric</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="flowValue">
        <inputExpression id="InputExpression_2" typeRef="number">
          <text>flowValue</text>
        </inputExpression>
      </input>

      <output id="Output_1" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1">
        <inputEntry id="IE_1_1"><text>"wait_time"</text></inputEntry>
        <inputEntry id="IE_1_2"><text>>= 120.0</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"Tempo de espera critico (>= 2h). Redistribuir recursos."</text></outputEntry>
        <outputEntry id="OE_1_4"><text>"Espera >= 120 min impacta satisfacao do paciente e desfechos clinicos."</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <inputEntry id="IE_2_1"><text>"boarding_time"</text></inputEntry>
        <inputEntry id="IE_2_2"><text>>= 240.0</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"Boarding time excessivo (>= 4h). Acionar plano de leitos."</text></outputEntry>
        <outputEntry id="OE_2_4"><text>"Boarding >= 4h associado a aumento de mortalidade e eventos adversos."</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <inputEntry id="IE_3_1"><text>"discharge_delay"</text></inputEntry>
        <inputEntry id="IE_3_2"><text>>= 60.0</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"URGENTE"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"Atraso na alta >= 1h. Revisar processo de desospitalizacao."</text></outputEntry>
        <outputEntry id="OE_3_4"><text>"Atrasos na alta reduzem throughput e aumentam custos desnecessarios."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"Verificar dados de entrada e recalcular metricas."</text></outputEntry>
        <outputEntry id="OE_F_4"><text>"Dados insuficientes para avaliacao automatica. Revisao manual necessaria."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_analytics_flow_007">
      <dmndi:DMNShape id="DMNShape_analytics_flow_007" dmnElementRef="Decision_analytics_flow_007">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
