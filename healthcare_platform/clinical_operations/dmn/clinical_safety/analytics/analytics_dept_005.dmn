<?xml version="1.0" encoding="UTF-8"?>
<!--
  ANALYTICS_DEPT_005: Department Performance Scoring
  Clinical Analytics DMN - Extracted from clinical_analytics_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_analytics_dept_005"
             name="Department Performance Scoring"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_analytics_dept_005" name="Department Performance Scoring">
    <decisionTable id="DecisionTable_analytics_dept_005" hitPolicy="FIRST">

      <input id="Input_1" label="department">
        <inputExpression id="InputExpression_1" typeRef="string">
          <text>department</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="performanceScore">
        <inputExpression id="InputExpression_2" typeRef="number">
          <text>performanceScore</text>
        </inputExpression>
      </input>

      <output id="Output_1" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1">
        <inputEntry id="IE_1_1"><text>"-"</text></inputEntry>
        <inputEntry id="IE_1_2"><text>< 60.0</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"Departamento com performance critica. Intervencao gerencial."</text></outputEntry>
        <outputEntry id="OE_1_4"><text>"Score < 60 indica deficiencias operacionais graves no departamento."</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <inputEntry id="IE_2_1"><text>"-"</text></inputEntry>
        <inputEntry id="IE_2_2"><text>[60.0..80.0)</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"URGENTE"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"Performance departamental abaixo da meta. Plano de melhoria."</text></outputEntry>
        <outputEntry id="OE_2_4"><text>"Score entre 60-80 indica necessidade de acoes corretivas especificas."</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <inputEntry id="IE_3_1"><text>"-"</text></inputEntry>
        <inputEntry id="IE_3_2"><text>>= 80.0</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"Departamento com performance adequada. Manter monitoramento."</text></outputEntry>
        <outputEntry id="OE_3_4"><text>"Score >= 80 indica operacao dentro dos parametros de qualidade."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"Verificar dados de entrada e recalcular metricas."</text></outputEntry>
        <outputEntry id="OE_F_4"><text>"Dados insuficientes para avaliacao automatica. Revisao manual necessaria."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_analytics_dept_005">
      <dmndi:DMNShape id="DMNShape_analytics_dept_005" dmnElementRef="Decision_analytics_dept_005">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
