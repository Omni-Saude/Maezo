<?xml version="1.0" encoding="UTF-8"?>
<!--
  ANALYTICS_TREND_002: Trend Analysis Rules
  Clinical Analytics DMN - Extracted from clinical_analytics_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_analytics_trend_002"
             name="Trend Analysis Rules"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_analytics_trend_002" name="Trend Analysis Rules">
    <decisionTable id="DecisionTable_analytics_trend_002" hitPolicy="FIRST">

      <input id="Input_1" label="trendDirection">
        <inputExpression id="InputExpression_1" typeRef="string">
          <text>trendDirection</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="trendMagnitude">
        <inputExpression id="InputExpression_2" typeRef="number">
          <text>trendMagnitude</text>
        </inputExpression>
      </input>

      <output id="Output_1" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1">
        <inputEntry id="IE_1_1"><text>"deteriorating"</text></inputEntry>
        <inputEntry id="IE_1_2"><text>>= 10.0</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"Tendencia de deterioracao significativa detectada. Investigar causas."</text></outputEntry>
        <outputEntry id="OE_1_4"><text>"Variacao >= 10% em direcao desfavoravel requer intervencao imediata."</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <inputEntry id="IE_2_1"><text>"improving"</text></inputEntry>
        <inputEntry id="IE_2_2"><text>>= 5.0</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"INFORMATIVA"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"Tendencia positiva identificada. Manter monitoramento."</text></outputEntry>
        <outputEntry id="OE_2_4"><text>"Melhoria >= 5% indica efetividade das acoes implementadas."</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <inputEntry id="IE_3_1"><text>"stable"</text></inputEntry>
        <inputEntry id="IE_3_2"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"Indicadores estaveis. Manter rotina de monitoramento."</text></outputEntry>
        <outputEntry id="OE_3_4"><text>"Estabilidade nos indicadores dentro dos limites aceitaveis."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"Verificar dados de entrada e recalcular metricas."</text></outputEntry>
        <outputEntry id="OE_F_4"><text>"Dados insuficientes para avaliacao automatica. Revisao manual necessaria."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_analytics_trend_002">
      <dmndi:DMNShape id="DMNShape_analytics_trend_002" dmnElementRef="Decision_analytics_trend_002">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
