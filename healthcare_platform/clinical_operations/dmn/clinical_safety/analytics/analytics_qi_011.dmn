<?xml version="1.0" encoding="UTF-8"?>
<!--
  ANALYTICS_QI_011: Quality Indicator Scoring
  Clinical Analytics DMN - Extracted from clinical_analytics_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_analytics_qi_011"
             name="Quality Indicator Scoring"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_analytics_qi_011" name="Quality Indicator Scoring">
    <decisionTable id="DecisionTable_analytics_qi_011" hitPolicy="FIRST">

      <input id="Input_1" label="indicatorType">
        <inputExpression id="InputExpression_1" typeRef="string">
          <text>indicatorType</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="indicatorValue">
        <inputExpression id="InputExpression_2" typeRef="number">
          <text>indicatorValue</text>
        </inputExpression>
      </input>

      <output id="Output_1" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1">
        <inputEntry id="IE_1_1"><text>"readmission_rate"</text></inputEntry>
        <inputEntry id="IE_1_2"><text>>= 15.0</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"Taxa de readmissao critica (>= 15%). Revisar processo de alta."</text></outputEntry>
        <outputEntry id="OE_1_4"><text>"Readmissao >= 15% indica falhas no planejamento de alta e follow-up."</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <inputEntry id="IE_2_1"><text>"infection_rate"</text></inputEntry>
        <inputEntry id="IE_2_2"><text>>= 5.0</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"Taxa de infeccao acima do aceitavel (>= 5%). Acionar CCIH."</text></outputEntry>
        <outputEntry id="OE_2_4"><text>"Taxa de IRAS >= 5% requer intervencao imediata da CCIH."</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <inputEntry id="IE_3_1"><text>"mortality_rate"</text></inputEntry>
        <inputEntry id="IE_3_2"><text>>= 3.0</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"Taxa de mortalidade elevada. Comite de obitos imediato."</text></outputEntry>
        <outputEntry id="OE_3_4"><text>"Mortalidade >= 3% requer analise detalhada pelo comite de obitos."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"Verificar dados de entrada e recalcular metricas."</text></outputEntry>
        <outputEntry id="OE_F_4"><text>"Dados insuficientes para avaliacao automatica. Revisao manual necessaria."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_analytics_qi_011">
      <dmndi:DMNShape id="DMNShape_analytics_qi_011" dmnElementRef="Decision_analytics_qi_011">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
