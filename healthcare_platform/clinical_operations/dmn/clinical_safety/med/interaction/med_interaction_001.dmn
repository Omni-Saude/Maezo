<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns='https://www.omg.org/spec/DMN/20191111/MODEL/'
  id='clinical_safety_med_interaction_001' name='Drug Interaction Severity'
  namespace='http://healthcare.platform/dmn/clinical_safety'>
  <decision id='decision_med_interaction_001' name='Drug Interaction Severity'>
    <decisionTable id='dt_med_interaction_001' hitPolicy='FIRST'>
      <input id='input_1' label='drug1Class'>
        <inputExpression typeRef='string'><text>drug1Class</text></inputExpression>
      </input>
      <input id='input_2' label='drug2Class'>
        <inputExpression typeRef='string'><text>drug2Class</text></inputExpression>
      </input>
      <output id='output_1' label='severity' typeRef='string'/>
      <output id='output_2' label='action' typeRef='string'/>
      <output id='output_3' label='description' typeRef='string'/>
      <rule id='rule_1'>
        <inputEntry><text>"ANTICOAGULANT"</text></inputEntry>
        <inputEntry><text>"NSAID"</text></inputEntry>
        <outputEntry><text>"MAJOR"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"Risco sangramento - contraindicado"</text></outputEntry>
      </rule>
      <rule id='rule_2'>
        <inputEntry><text>"SSRI"</text></inputEntry>
        <inputEntry><text>"MAOI"</text></inputEntry>
        <outputEntry><text>"CONTRAINDICATED"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"Sindrome serotoninergica - contraindicado"</text></outputEntry>
      </rule>
      <rule id='rule_3'>
        <inputEntry><text>"ACE_INHIBITOR"</text></inputEntry>
        <inputEntry><text>"POTASSIUM_SPARING"</text></inputEntry>
        <outputEntry><text>"MODERATE"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"Risco hipercalemia - monitorar potassio"</text></outputEntry>
      </rule>
      <rule id='rule_4'>
        <inputEntry><text>"STATIN"</text></inputEntry>
        <inputEntry><text>"MACROLIDE"</text></inputEntry>
        <outputEntry><text>"MAJOR"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"Risco rabdomiolise"</text></outputEntry>
      </rule>
      <rule id='rule_99'>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <outputEntry><text>"NONE"</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"Sem interacao conhecida"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
