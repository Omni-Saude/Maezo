<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns='https://www.omg.org/spec/DMN/20191111/MODEL/'
  id='clinical_safety_med_route_001' name='Administration Route Validation'
  namespace='http://healthcare.platform/dmn/clinical_safety'>
  <decision id='decision_med_route_001' name='Administration Route Validation'>
    <decisionTable id='dt_med_route_001' hitPolicy='FIRST'>
      <input id='input_1' label='medicationForm'>
        <inputExpression typeRef='string'><text>medicationForm</text></inputExpression>
      </input>
      <input id='input_2' label='prescribedRoute'>
        <inputExpression typeRef='string'><text>prescribedRoute</text></inputExpression>
      </input>
      <output id='output_1' label='action' typeRef='string'/>
      <output id='output_2' label='reason' typeRef='string'/>
      <!-- Oral medication via IV = block -->
      <rule id='rule_1'>
        <inputEntry><text>"ORAL_TABLET"</text></inputEntry>
        <inputEntry><text>"IV"</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"Via incompativel - comprimido oral nao pode ser IV"</text></outputEntry>
      </rule>
      <!-- IV medication via oral = block -->
      <rule id='rule_2'>
        <inputEntry><text>"IV_SOLUTION"</text></inputEntry>
        <inputEntry><text>"ORAL"</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"Via incompativel - solucao IV nao pode ser oral"</text></outputEntry>
      </rule>
      <!-- Topical via IV = block -->
      <rule id='rule_3'>
        <inputEntry><text>"TOPICAL"</text></inputEntry>
        <inputEntry><text>"IV"</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"Via incompativel - topico nao pode ser IV"</text></outputEntry>
      </rule>
      <!-- Default pass -->
      <rule id='rule_99'>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"Via compativel"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
