<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns='https://www.omg.org/spec/DMN/20191111/MODEL/'
  id='clinical_safety_med_dose_001' name='Dose Validation Rules'
  namespace='http://healthcare.platform/dmn/clinical_safety'>
  <decision id='decision_med_dose_001' name='Dose Validation Rules'>
    <decisionTable id='dt_med_dose_001' hitPolicy='FIRST'>
      <input id='input_1' label='medicationClass'>
        <inputExpression typeRef='string'><text>medicationClass</text></inputExpression>
      </input>
      <input id='input_2' label='doseValue'>
        <inputExpression typeRef='double'><text>doseValue</text></inputExpression>
      </input>
      <input id='input_3' label='doseUnit'>
        <inputExpression typeRef='string'><text>doseUnit</text></inputExpression>
      </input>
      <output id='output_1' label='action' typeRef='string'/>
      <output id='output_2' label='reason' typeRef='string'/>
      <!-- Opioid max dose -->
      <rule id='rule_1'>
        <inputEntry><text>"OPIOID"</text></inputEntry>
        <inputEntry><text>&gt; 100</text></inputEntry>
        <inputEntry><text>"mg"</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"Dose opioide acima do maximo seguro"</text></outputEntry>
      </rule>
      <!-- Anticoagulant high dose -->
      <rule id='rule_2'>
        <inputEntry><text>"ANTICOAGULANT"</text></inputEntry>
        <inputEntry><text>&gt; 10</text></inputEntry>
        <inputEntry><text>"mg"</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"Dose anticoagulante elevada - verificar INR"</text></outputEntry>
      </rule>
      <!-- Insulin high dose -->
      <rule id='rule_3'>
        <inputEntry><text>"INSULIN"</text></inputEntry>
        <inputEntry><text>&gt; 50</text></inputEntry>
        <inputEntry><text>"UI"</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"Dose insulina elevada - confirmar prescricao"</text></outputEntry>
      </rule>
      <!-- Default pass -->
      <rule id='rule_99'>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"Dose dentro dos parametros"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
