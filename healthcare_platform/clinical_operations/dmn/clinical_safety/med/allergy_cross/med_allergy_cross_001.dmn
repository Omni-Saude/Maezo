<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns='https://www.omg.org/spec/DMN/20191111/MODEL/'
  id='clinical_safety_med_allergy_001' name='Allergy Cross-Reactivity'
  namespace='http://healthcare.platform/dmn/clinical_safety'>
  <decision id='decision_med_allergy_001' name='Allergy Cross-Reactivity'>
    <decisionTable id='dt_med_allergy_001' hitPolicy='FIRST'>
      <input id='input_1' label='allergyGroup'>
        <inputExpression typeRef='string'><text>allergyGroup</text></inputExpression>
      </input>
      <input id='input_2' label='medicationGroup'>
        <inputExpression typeRef='string'><text>medicationGroup</text></inputExpression>
      </input>
      <output id='output_1' label='crossReactive' typeRef='boolean'/>
      <output id='output_2' label='action' typeRef='string'/>
      <output id='output_3' label='riskLevel' typeRef='string'/>
      <rule id='rule_1'>
        <inputEntry><text>"PENICILLIN"</text></inputEntry>
        <inputEntry><text>"CEPHALOSPORIN"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"MODERATE"</text></outputEntry>
      </rule>
      <rule id='rule_2'>
        <inputEntry><text>"PENICILLIN"</text></inputEntry>
        <inputEntry><text>"PENICILLIN"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"HIGH"</text></outputEntry>
      </rule>
      <rule id='rule_3'>
        <inputEntry><text>"SULFA"</text></inputEntry>
        <inputEntry><text>"SULFONAMIDE"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"HIGH"</text></outputEntry>
      </rule>
      <rule id='rule_4'>
        <inputEntry><text>"NSAID"</text></inputEntry>
        <inputEntry><text>"NSAID"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"HIGH"</text></outputEntry>
      </rule>
      <rule id='rule_99'>
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <outputEntry><text>false</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"NONE"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
