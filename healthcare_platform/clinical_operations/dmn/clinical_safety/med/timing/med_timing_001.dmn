<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns='https://www.omg.org/spec/DMN/20191111/MODEL/'
  id='clinical_safety_med_timing_001' name='Medication Timing Rules'
  namespace='http://healthcare.platform/dmn/clinical_safety'>
  <decision id='decision_med_timing_001' name='Medication Timing Rules'>
    <decisionTable id='dt_med_timing_001' hitPolicy='FIRST'>
      <input id='input_1' label='frequency'>
        <inputExpression typeRef='string'><text>frequency</text></inputExpression>
      </input>
      <output id='output_1' label='scheduleTimes' typeRef='string'/>
      <output id='output_2' label='intervalHours' typeRef='integer'/>
      <output id='output_3' label='action' typeRef='string'/>
      <rule id='rule_1'>
        <inputEntry><text>"6/6h"</text></inputEntry>
        <outputEntry><text>"06:00,12:00,18:00,00:00"</text></outputEntry>
        <outputEntry><text>6</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
      <rule id='rule_2'>
        <inputEntry><text>"8/8h"</text></inputEntry>
        <outputEntry><text>"08:00,16:00,00:00"</text></outputEntry>
        <outputEntry><text>8</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
      <rule id='rule_3'>
        <inputEntry><text>"12/12h"</text></inputEntry>
        <outputEntry><text>"08:00,20:00"</text></outputEntry>
        <outputEntry><text>12</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
      <rule id='rule_4'>
        <inputEntry><text>"24/24h"</text></inputEntry>
        <outputEntry><text>"08:00"</text></outputEntry>
        <outputEntry><text>24</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
      <rule id='rule_99'>
        <inputEntry><text></text></inputEntry>
        <outputEntry><text>"08:00"</text></outputEntry>
        <outputEntry><text>24</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
