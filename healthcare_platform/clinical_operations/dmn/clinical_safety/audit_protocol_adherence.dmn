<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="clinical_safety_audit_protocol" name="Audit Protocol Adherence"
             namespace="http://healthcare.platform/dmn/clinical_safety">
  <decision id="decision_audit_protocol" name="Aderência a Protocolos Clínicos">
    <decisionTable id="dt_audit_protocol" hitPolicy="FIRST">
      <input id="ap_in1" label="Taxa de Aderência (%)">
        <inputExpression typeRef="double"><text>adherenceRate</text></inputExpression>
      </input>
      <input id="ap_in2" label="Protocolo Crítico">
        <inputExpression typeRef="boolean"><text>isCriticalProtocol</text></inputExpression>
      </input>
      <output id="ap_out1" label="action" name="action" typeRef="string"/>
      <output id="ap_out2" label="adherenceStatus" name="adherenceStatus" typeRef="string"/>
      <output id="ap_out3" label="justificativa" name="justificativa" typeRef="string"/>

      <rule id="ap_r1">
        <inputEntry><text>&lt; 80</text></inputEntry>
        <inputEntry><text>true</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"critical_non_adherence"</text></outputEntry>
        <outputEntry><text>"Não aderência a protocolo crítico - risco ao paciente"</text></outputEntry>
      </rule>
      <rule id="ap_r2">
        <inputEntry><text>&gt;= 90</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"adherent"</text></outputEntry>
        <outputEntry><text>"Aderência adequada ao protocolo"</text></outputEntry>
      </rule>
      <rule id="ap_r3">
        <inputEntry><text>[70..90)</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"partial_adherence"</text></outputEntry>
        <outputEntry><text>"Aderência parcial - reforçar protocolo com equipe"</text></outputEntry>
      </rule>
      <rule id="ap_r4">
        <inputEntry><text>&lt; 70</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"non_adherent"</text></outputEntry>
        <outputEntry><text>"Baixa aderência - treinamento obrigatório"</text></outputEntry>
      </rule>
      <rule id="ap_r5">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"not_assessed"</text></outputEntry>
        <outputEntry><text>"Aderência não avaliada"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
