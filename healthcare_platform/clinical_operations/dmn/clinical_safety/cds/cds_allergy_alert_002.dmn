<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns='https://www.omg.org/spec/DMN/20191111/MODEL/'
  id='clinical_safety_cds_002' name='Allergy Alert Rules'
  namespace='http://healthcare.platform/dmn/clinical_safety'>
  <decision id='decision_cds_002' name='Allergy Alert Rules'>
    <decisionTable id='dt_cds_002' hitPolicy='FIRST'>
      <input id='input_1' label='Allergy Class'>
        <inputExpression typeRef='string'><text>allergyClass</text></inputExpression>
      </input>
      <input id='input_2' label='Cross Reactivity'>
        <inputExpression typeRef='boolean'><text>crossReactivity</text></inputExpression>
      </input>
      <output id='output_1' label='severity' typeRef='string'/>
      <output id='output_2' label='action' typeRef='string'/>
      <output id='output_3' label='resultado' typeRef='string'/>
      <rule id='rule_1'>
        <inputEntry><text>"anaphylaxis"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"critical"</text></outputEntry>
        <outputEntry><text>"SUSPENDER imediatamente - risco de anafilaxia"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
      </rule>
      <rule id='rule_2'>
        <inputEntry><text>"severe"</text></inputEntry>
        <inputEntry><text>true</text></inputEntry>
        <outputEntry><text>"critical"</text></outputEntry>
        <outputEntry><text>"SUSPENDER - reacao cruzada com alergia conhecida"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
      </rule>
      <rule id='rule_3'>
        <inputEntry><text>"severe"</text></inputEntry>
        <inputEntry><text>false</text></inputEntry>
        <outputEntry><text>"high"</text></outputEntry>
        <outputEntry><text>"Avaliar alternativa terapeutica"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
      <rule id='rule_4'>
        <inputEntry><text>"moderate"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"medium"</text></outputEntry>
        <outputEntry><text>"Monitorar reacoes alergicas"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
      <rule id='rule_5'>
        <inputEntry><text>"mild"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"low"</text></outputEntry>
        <outputEntry><text>"Informar paciente sobre possivel reacao leve"</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
