<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns='https://www.omg.org/spec/DMN/20191111/MODEL/'
  id='clinical_safety_cds_004' name='Critical Value Thresholds'
  namespace='http://healthcare.platform/dmn/clinical_safety'>
  <decision id='decision_cds_004' name='Critical Value Thresholds'>
    <decisionTable id='dt_cds_004' hitPolicy='FIRST'>
      <input id='input_1' label='Lab Test'>
        <inputExpression typeRef='string'><text>labTest</text></inputExpression>
      </input>
      <input id='input_2' label='Value Status'>
        <inputExpression typeRef='string'><text>valueStatus</text></inputExpression>
      </input>
      <output id='output_1' label='severity' typeRef='string'/>
      <output id='output_2' label='action' typeRef='string'/>
      <output id='output_3' label='resultado' typeRef='string'/>
      <rule id='rule_1'>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"panic"</text></inputEntry>
        <outputEntry><text>"critical"</text></outputEntry>
        <outputEntry><text>"Valor de panico - notificar medico imediatamente"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
      </rule>
      <rule id='rule_2'>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"critical_high","critical_low"</text></inputEntry>
        <outputEntry><text>"high"</text></outputEntry>
        <outputEntry><text>"Valor critico - revisao medica urgente"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
      <rule id='rule_3'>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"abnormal_high","abnormal_low"</text></inputEntry>
        <outputEntry><text>"medium"</text></outputEntry>
        <outputEntry><text>"Valor anormal - monitorar evolucao"</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
      <rule id='rule_4'>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"normal"</text></inputEntry>
        <outputEntry><text>"info"</text></outputEntry>
        <outputEntry><text>"Resultado dentro da normalidade"</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
