<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns='https://www.omg.org/spec/DMN/20191111/MODEL/'
  id='clinical_safety_cds_006' name='Risk Stratification Rules'
  namespace='http://healthcare.platform/dmn/clinical_safety'>
  <decision id='decision_cds_006' name='Risk Stratification Rules'>
    <decisionTable id='dt_cds_006' hitPolicy='FIRST'>
      <input id='input_1' label='Risk Type'>
        <inputExpression typeRef='string'><text>riskType</text></inputExpression>
      </input>
      <input id='input_2' label='Age Years'>
        <inputExpression typeRef='number'><text>ageYears</text></inputExpression>
      </input>
      <input id='input_3' label='Comorbidity Count'>
        <inputExpression typeRef='number'><text>comorbidityCount</text></inputExpression>
      </input>
      <output id='output_1' label='riskLevel' typeRef='string'/>
      <output id='output_2' label='action' typeRef='string'/>
      <output id='output_3' label='resultado' typeRef='string'/>
      <rule id='rule_1'>
        <inputEntry><text>"vte"</text></inputEntry>
        <inputEntry><text>&gt; 65</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"high"</text></outputEntry>
        <outputEntry><text>"Aplicar escore de Padua/Wells e considerar profilaxia farmacologica"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
      <rule id='rule_2'>
        <inputEntry><text>"vte"</text></inputEntry>
        <inputEntry><text>&lt;= 65</text></inputEntry>
        <inputEntry><text>&gt;= 3</text></inputEntry>
        <outputEntry><text>"medium"</text></outputEntry>
        <outputEntry><text>"Avaliar fatores de risco adicionais para TEV"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
      <rule id='rule_3'>
        <inputEntry><text>"vte"</text></inputEntry>
        <inputEntry><text>&lt;= 65</text></inputEntry>
        <inputEntry><text>&lt; 3</text></inputEntry>
        <outputEntry><text>"low"</text></outputEntry>
        <outputEntry><text>"Profilaxia mecanica suficiente"</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
      <rule id='rule_4'>
        <inputEntry><text>"falls"</text></inputEntry>
        <inputEntry><text>&gt; 75</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"high"</text></outputEntry>
        <outputEntry><text>"Protocolo de prevencao de quedas obrigatorio"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
      <rule id='rule_5'>
        <inputEntry><text>"pressure_ulcer"</text></inputEntry>
        <inputEntry><text>&gt; 70</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"medium"</text></outputEntry>
        <outputEntry><text>"Aplicar escala de Braden e protocolo de prevencao"</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
