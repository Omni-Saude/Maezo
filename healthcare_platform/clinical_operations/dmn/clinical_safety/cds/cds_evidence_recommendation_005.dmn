<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns='https://www.omg.org/spec/DMN/20191111/MODEL/'
  id='clinical_safety_cds_005' name='Evidence-Based Recommendations'
  namespace='http://healthcare.platform/dmn/clinical_safety'>
  <decision id='decision_cds_005' name='Evidence-Based Recommendations'>
    <decisionTable id='dt_cds_005' hitPolicy='COLLECT'>
      <input id='input_1' label='Diagnosis Group'>
        <inputExpression typeRef='string'><text>diagnosisGroup</text></inputExpression>
      </input>
      <output id='output_1' label='recommendation' typeRef='string'/>
      <output id='output_2' label='evidenceLevel' typeRef='string'/>
      <output id='output_3' label='guidelineSource' typeRef='string'/>
      <output id='output_4' label='confidenceScore' typeRef='number'/>
      <rule id='rule_1'>
        <inputEntry><text>"hypertension"</text></inputEntry>
        <outputEntry><text>"Iniciar terapia anti-hipertensiva conforme diretrizes brasileiras"</text></outputEntry>
        <outputEntry><text>"A"</text></outputEntry>
        <outputEntry><text>"Diretriz Brasileira de Hipertensao 2020"</text></outputEntry>
        <outputEntry><text>0.92</text></outputEntry>
      </rule>
      <rule id='rule_2'>
        <inputEntry><text>"diabetes_type2"</text></inputEntry>
        <outputEntry><text>"Iniciar metformina e orientar mudanca de estilo de vida"</text></outputEntry>
        <outputEntry><text>"A"</text></outputEntry>
        <outputEntry><text>"Diretriz SBD 2023"</text></outputEntry>
        <outputEntry><text>0.90</text></outputEntry>
      </rule>
      <rule id='rule_3'>
        <inputEntry><text>"heart_failure"</text></inputEntry>
        <outputEntry><text>"IECA/BRA + betabloqueador conforme classe funcional"</text></outputEntry>
        <outputEntry><text>"A"</text></outputEntry>
        <outputEntry><text>"Diretriz SBC IC 2021"</text></outputEntry>
        <outputEntry><text>0.88</text></outputEntry>
      </rule>
      <rule id='rule_4'>
        <inputEntry><text>"pneumonia"</text></inputEntry>
        <outputEntry><text>"Antibioticoterapia empirica conforme CURB-65"</text></outputEntry>
        <outputEntry><text>"B"</text></outputEntry>
        <outputEntry><text>"Diretriz SBPT 2022"</text></outputEntry>
        <outputEntry><text>0.85</text></outputEntry>
      </rule>
      <rule id='rule_5'>
        <inputEntry><text>"sepsis"</text></inputEntry>
        <outputEntry><text>"Protocolo hora dourada - antibiotico em 1h e ressuscitacao volemica"</text></outputEntry>
        <outputEntry><text>"A"</text></outputEntry>
        <outputEntry><text>"Surviving Sepsis 2021"</text></outputEntry>
        <outputEntry><text>0.95</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
