<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns='https://www.omg.org/spec/DMN/20191111/MODEL/'
  id='clinical_safety_cds_012' name='Clinical Pathway Selection'
  namespace='http://healthcare.platform/dmn/clinical_safety'>
  <decision id='decision_cds_012' name='Clinical Pathway Selection'>
    <decisionTable id='dt_cds_012' hitPolicy='FIRST'>
      <input id='input_1' label='Decision Type'>
        <inputExpression typeRef='string'><text>decisionType</text></inputExpression>
      </input>
      <input id='input_2' label='Has Critical Alerts'>
        <inputExpression typeRef='boolean'><text>hasCriticalAlerts</text></inputExpression>
      </input>
      <input id='input_3' label='Requires Override'>
        <inputExpression typeRef='boolean'><text>requiresOverride</text></inputExpression>
      </input>
      <output id='output_1' label='pathway' typeRef='string'/>
      <output id='output_2' label='requiresPhysicianReview' typeRef='boolean'/>
      <output id='output_3' label='resultado' typeRef='string'/>
      <rule id='rule_1'>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>true</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"critical_review"</text></outputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
      </rule>
      <rule id='rule_2'>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>false</text></inputEntry>
        <inputEntry><text>true</text></inputEntry>
        <outputEntry><text>"override_review"</text></outputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
      <rule id='rule_3'>
        <inputEntry><text>"drug_safety"</text></inputEntry>
        <inputEntry><text>false</text></inputEntry>
        <inputEntry><text>false</text></inputEntry>
        <outputEntry><text>"drug_safety_standard"</text></outputEntry>
        <outputEntry><text>false</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
      <rule id='rule_4'>
        <inputEntry><text>"risk_assessment"</text></inputEntry>
        <inputEntry><text>false</text></inputEntry>
        <inputEntry><text>false</text></inputEntry>
        <outputEntry><text>"risk_assessment_standard"</text></outputEntry>
        <outputEntry><text>false</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
      <rule id='rule_5'>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>false</text></inputEntry>
        <inputEntry><text>false</text></inputEntry>
        <outputEntry><text>"standard"</text></outputEntry>
        <outputEntry><text>false</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
