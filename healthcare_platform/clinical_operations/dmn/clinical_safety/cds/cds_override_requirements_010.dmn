<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns='https://www.omg.org/spec/DMN/20191111/MODEL/'
  id='clinical_safety_cds_010' name='Override Documentation Requirements'
  namespace='http://healthcare.platform/dmn/clinical_safety'>
  <decision id='decision_cds_010' name='Override Documentation Requirements'>
    <decisionTable id='dt_cds_010' hitPolicy='FIRST'>
      <input id='input_1' label='Alert Type'>
        <inputExpression typeRef='string'><text>alertType</text></inputExpression>
      </input>
      <input id='input_2' label='Severity'>
        <inputExpression typeRef='string'><text>severity</text></inputExpression>
      </input>
      <output id='output_1' label='requiresOverride' typeRef='boolean'/>
      <output id='output_2' label='overrideLevel' typeRef='string'/>
      <output id='output_3' label='documentationRequired' typeRef='string'/>
      <rule id='rule_1'>
        <inputEntry><text>"allergy"</text></inputEntry>
        <inputEntry><text>"critical"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"attending_physician"</text></outputEntry>
        <outputEntry><text>"Justificativa clinica obrigatoria com assinatura digital"</text></outputEntry>
      </rule>
      <rule id='rule_2'>
        <inputEntry><text>"drug_interaction"</text></inputEntry>
        <inputEntry><text>"critical","high"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"prescriber"</text></outputEntry>
        <outputEntry><text>"Justificativa e plano de monitoramento"</text></outputEntry>
      </rule>
      <rule id='rule_3'>
        <inputEntry><text>"contraindication"</text></inputEntry>
        <inputEntry><text>"critical"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"attending_physician"</text></outputEntry>
        <outputEntry><text>"Justificativa clinica e consentimento informado"</text></outputEntry>
      </rule>
      <rule id='rule_4'>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"medium"</text></inputEntry>
        <outputEntry><text>false</text></outputEntry>
        <outputEntry><text>"none"</text></outputEntry>
        <outputEntry><text>"Registro automatico no prontuario"</text></outputEntry>
      </rule>
      <rule id='rule_5'>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"low","info"</text></inputEntry>
        <outputEntry><text>false</text></outputEntry>
        <outputEntry><text>"none"</text></outputEntry>
        <outputEntry><text>"Nenhuma documentacao adicional"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
