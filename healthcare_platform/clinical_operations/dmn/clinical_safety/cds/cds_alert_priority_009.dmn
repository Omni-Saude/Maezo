<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns='https://www.omg.org/spec/DMN/20191111/MODEL/'
  id='clinical_safety_cds_009' name='Alert Priority Classification'
  namespace='http://healthcare.platform/dmn/clinical_safety'>
  <decision id='decision_cds_009' name='Alert Priority Classification'>
    <decisionTable id='dt_cds_009' hitPolicy='FIRST'>
      <input id='input_1' label='Alert Type'>
        <inputExpression typeRef='string'><text>alertType</text></inputExpression>
      </input>
      <input id='input_2' label='Severity'>
        <inputExpression typeRef='string'><text>severity</text></inputExpression>
      </input>
      <output id='output_1' label='priority' typeRef='number'/>
      <output id='output_2' label='displayOrder' typeRef='string'/>
      <output id='output_3' label='resultado' typeRef='string'/>
      <rule id='rule_1'>
        <inputEntry><text>"allergy"</text></inputEntry>
        <inputEntry><text>"critical"</text></inputEntry>
        <outputEntry><text>1</text></outputEntry>
        <outputEntry><text>"modal_blocking"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
      </rule>
      <rule id='rule_2'>
        <inputEntry><text>"drug_interaction"</text></inputEntry>
        <inputEntry><text>"critical"</text></inputEntry>
        <outputEntry><text>2</text></outputEntry>
        <outputEntry><text>"modal_blocking"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
      </rule>
      <rule id='rule_3'>
        <inputEntry><text>"contraindication"</text></inputEntry>
        <inputEntry><text>"critical"</text></inputEntry>
        <outputEntry><text>3</text></outputEntry>
        <outputEntry><text>"modal_blocking"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
      </rule>
      <rule id='rule_4'>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"high"</text></inputEntry>
        <outputEntry><text>4</text></outputEntry>
        <outputEntry><text>"modal_warning"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
      <rule id='rule_5'>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"medium"</text></inputEntry>
        <outputEntry><text>5</text></outputEntry>
        <outputEntry><text>"inline_warning"</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
      <rule id='rule_6'>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"low","info"</text></inputEntry>
        <outputEntry><text>6</text></outputEntry>
        <outputEntry><text>"inline_info"</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
