<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns='https://www.omg.org/spec/DMN/20191111/MODEL/'
  id='clinical_safety_cds_011' name='Dismissibility Rules'
  namespace='http://healthcare.platform/dmn/clinical_safety'>
  <decision id='decision_cds_011' name='Dismissibility Rules'>
    <decisionTable id='dt_cds_011' hitPolicy='FIRST'>
      <input id='input_1' label='Alert Type'>
        <inputExpression typeRef='string'><text>alertType</text></inputExpression>
      </input>
      <input id='input_2' label='Severity'>
        <inputExpression typeRef='string'><text>severity</text></inputExpression>
      </input>
      <output id='output_1' label='dismissible' typeRef='boolean'/>
      <output id='output_2' label='dismissCondition' typeRef='string'/>
      <rule id='rule_1'>
        <inputEntry><text>"allergy"</text></inputEntry>
        <inputEntry><text>"critical"</text></inputEntry>
        <outputEntry><text>false</text></outputEntry>
        <outputEntry><text>"Alerta de alergia critica nao pode ser descartado"</text></outputEntry>
      </rule>
      <rule id='rule_2'>
        <inputEntry><text>"contraindication"</text></inputEntry>
        <inputEntry><text>"critical"</text></inputEntry>
        <outputEntry><text>false</text></outputEntry>
        <outputEntry><text>"Contraindicacao critica nao pode ser descartada"</text></outputEntry>
      </rule>
      <rule id='rule_3'>
        <inputEntry><text>"drug_interaction"</text></inputEntry>
        <inputEntry><text>"critical"</text></inputEntry>
        <outputEntry><text>false</text></outputEntry>
        <outputEntry><text>"Interacao critica requer override formal"</text></outputEntry>
      </rule>
      <rule id='rule_4'>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"high"</text></inputEntry>
        <outputEntry><text>false</text></outputEntry>
        <outputEntry><text>"Alerta de alta severidade requer justificativa"</text></outputEntry>
      </rule>
      <rule id='rule_5'>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"medium"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"Pode ser descartado com registro"</text></outputEntry>
      </rule>
      <rule id='rule_6'>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"low","info"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"Pode ser descartado livremente"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
