<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns='https://www.omg.org/spec/DMN/20191111/MODEL/'
  id='clinical_safety_cds_003' name='Contraindication Checks'
  namespace='http://healthcare.platform/dmn/clinical_safety'>
  <decision id='decision_cds_003' name='Contraindication Checks'>
    <decisionTable id='dt_cds_003' hitPolicy='FIRST'>
      <input id='input_1' label='Contraindication Type'>
        <inputExpression typeRef='string'><text>contraindicationType</text></inputExpression>
      </input>
      <input id='input_2' label='Organ Function'>
        <inputExpression typeRef='string'><text>organFunction</text></inputExpression>
      </input>
      <input id='input_3' label='Pregnancy Status'>
        <inputExpression typeRef='boolean'><text>pregnancyStatus</text></inputExpression>
      </input>
      <output id='output_1' label='severity' typeRef='string'/>
      <output id='output_2' label='action' typeRef='string'/>
      <output id='output_3' label='resultado' typeRef='string'/>
      <rule id='rule_1'>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>true</text></inputEntry>
        <outputEntry><text>"critical"</text></outputEntry>
        <outputEntry><text>"Medicamento contraindicado em gestacao - risco categoria D/X"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
      </rule>
      <rule id='rule_2'>
        <inputEntry><text>"absolute"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"critical"</text></outputEntry>
        <outputEntry><text>"Contraindicacao absoluta - substituir medicamento"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
      </rule>
      <rule id='rule_3'>
        <inputEntry><text>"relative"</text></inputEntry>
        <inputEntry><text>"severe"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"high"</text></outputEntry>
        <outputEntry><text>"Contraindicacao relativa com disfuncao organica grave"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
      <rule id='rule_4'>
        <inputEntry><text>"relative"</text></inputEntry>
        <inputEntry><text>"moderate"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"medium"</text></outputEntry>
        <outputEntry><text>"Ajustar dose conforme funcao organica"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
      <rule id='rule_5'>
        <inputEntry><text>"relative"</text></inputEntry>
        <inputEntry><text>"mild","normal"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"low"</text></outputEntry>
        <outputEntry><text>"Monitorar funcao organica periodicamente"</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
