<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns='https://www.omg.org/spec/DMN/20191111/MODEL/'
  id='clinical_safety_cds_001' name='Drug Interaction Severity Classification'
  namespace='http://healthcare.platform/dmn/clinical_safety'>
  <decision id='decision_cds_001' name='Drug Interaction Severity Classification'>
    <decisionTable id='dt_cds_001' hitPolicy='FIRST'>
      <input id='input_1' label='Interaction Category'>
        <inputExpression typeRef='string'><text>interactionCategory</text></inputExpression>
      </input>
      <input id='input_2' label='Organ Risk'>
        <inputExpression typeRef='string'><text>organRisk</text></inputExpression>
      </input>
      <output id='output_1' label='severity' typeRef='string'/>
      <output id='output_2' label='action' typeRef='string'/>
      <output id='output_3' label='resultado' typeRef='string'/>
      <rule id='rule_1'>
        <inputEntry><text>"contraindicated"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"critical"</text></outputEntry>
        <outputEntry><text>"SUSPENDER medicacao e prescrever alternativa"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
      </rule>
      <rule id='rule_2'>
        <inputEntry><text>"major"</text></inputEntry>
        <inputEntry><text>"cardiac","renal","hepatic"</text></inputEntry>
        <outputEntry><text>"critical"</text></outputEntry>
        <outputEntry><text>"Monitorar ECG e considerar alternativa"</text></outputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
      </rule>
      <rule id='rule_3'>
        <inputEntry><text>"major"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"high"</text></outputEntry>
        <outputEntry><text>"Monitorar paciente e ajustar dose"</text></outputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
      </rule>
      <rule id='rule_4'>
        <inputEntry><text>"moderate"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"medium"</text></outputEntry>
        <outputEntry><text>"Monitorar sinais clinicos"</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
      <rule id='rule_5'>
        <inputEntry><text>"minor"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"low"</text></outputEntry>
        <outputEntry><text>"Nenhuma acao necessaria"</text></outputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
