<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="clinical_safety_audit_checklist" name="Audit Safety Checklist"
             namespace="http://healthcare.platform/dmn/clinical_safety">
  <decision id="decision_audit_safety_checklist" name="Conformidade de Checklist de Segurança">
    <decisionTable id="dt_audit_safety_checklist" hitPolicy="FIRST">
      <input id="asc_in1" label="Itens Completos (%)">
        <inputExpression typeRef="double"><text>checklistCompletionPct</text></inputExpression>
      </input>
      <output id="asc_out1" label="action" name="action" typeRef="string"/>
      <output id="asc_out2" label="safetyStatus" name="safetyStatus" typeRef="string"/>
      <output id="asc_out3" label="justificativa" name="justificativa" typeRef="string"/>

      <rule id="asc_r1">
        <inputEntry><text>100</text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"complete"</text></outputEntry>
        <outputEntry><text>"Checklist de segurança 100% completo"</text></outputEntry>
      </rule>
      <rule id="asc_r2">
        <inputEntry><text>[90..100)</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"near_complete"</text></outputEntry>
        <outputEntry><text>"Checklist quase completo - finalizar itens pendentes"</text></outputEntry>
      </rule>
      <rule id="asc_r3">
        <inputEntry><text>&lt; 90</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"incomplete"</text></outputEntry>
        <outputEntry><text>"Checklist de segurança incompleto - risco ao paciente"</text></outputEntry>
      </rule>
      <rule id="asc_r4">
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"not_started"</text></outputEntry>
        <outputEntry><text>"Checklist não iniciado"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
