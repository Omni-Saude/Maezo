<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="clinical_safety_recovery_trajectory" name="Recovery Trajectory"
             namespace="http://healthcare.platform/dmn/clinical_safety">
  <decision id="decision_recovery_trajectory" name="Trajetória de Recuperação">
    <decisionTable id="dt_recovery_trajectory" hitPolicy="FIRST">
      <input id="rt_in1" label="Tendência">
        <inputExpression typeRef="string"><text>improvementTrend</text></inputExpression>
      </input>
      <input id="rt_in2" label="Significância Estatística">
        <inputExpression typeRef="boolean"><text>statisticallySignificant</text></inputExpression>
      </input>
      <output id="rt_out1" label="action" name="action" typeRef="string"/>
      <output id="rt_out2" label="trajectory" name="trajectory" typeRef="string"/>
      <output id="rt_out3" label="justificativa" name="justificativa" typeRef="string"/>

      <rule id="rt_r1">
        <inputEntry><text>"improving"</text></inputEntry>
        <inputEntry><text>true</text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"on_track"</text></outputEntry>
        <outputEntry><text>"Recuperação no ritmo esperado"</text></outputEntry>
      </rule>
      <rule id="rt_r2">
        <inputEntry><text>"improving"</text></inputEntry>
        <inputEntry><text>false</text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"early_improvement"</text></outputEntry>
        <outputEntry><text>"Melhora inicial detectada, aguardar confirmação"</text></outputEntry>
      </rule>
      <rule id="rt_r3">
        <inputEntry><text>"stable"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"plateau"</text></outputEntry>
        <outputEntry><text>"Platô atingido - avaliar necessidade de ajuste"</text></outputEntry>
      </rule>
      <rule id="rt_r4">
        <inputEntry><text>"declining"</text></inputEntry>
        <inputEntry><text>true</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"deteriorating"</text></outputEntry>
        <outputEntry><text>"Deterioração significativa - intervenção imediata"</text></outputEntry>
      </rule>
      <rule id="rt_r5">
        <inputEntry><text>"declining"</text></inputEntry>
        <inputEntry><text>false</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"possible_decline"</text></outputEntry>
        <outputEntry><text>"Possível declínio - monitorar de perto"</text></outputEntry>
      </rule>
      <rule id="rt_r6">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"unknown"</text></outputEntry>
        <outputEntry><text>"Trajetória indeterminada"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
