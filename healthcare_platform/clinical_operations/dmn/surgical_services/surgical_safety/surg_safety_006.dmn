<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_safety_006"
             name="Anesthesia Risk Assessment"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_safety_006" name="Anesthesia Risk Assessment">
    <decisionTable id="dt_surg_safety_006" hitPolicy="FIRST">
      <input id="input_1" label="ASA Class">
        <inputExpression id="inputExpr_1" typeRef="string">
          <text>asaClass</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Mallampati Score">
        <inputExpression id="inputExpr_2" typeRef="number">
          <text>mallampattiScore</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Allergy History">
        <inputExpression id="inputExpr_3" typeRef="string">
          <text>allergyHistory</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Airway Difficulty">
        <inputExpression id="inputExpr_4" typeRef="string">
          <text>airwayDifficulty</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>"I","II"</text></inputEntry>
        <inputEntry id="ie_1_2"><text>[1..2]</text></inputEntry>
        <inputEntry id="ie_1_3"><text>"none"</text></inputEntry>
        <inputEntry id="ie_1_4"><text>"none"</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"Low anesthesia risk - standard anesthesia protocol appropriate"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>"III"</text></inputEntry>
        <inputEntry id="ie_2_2"><text>[1..3]</text></inputEntry>
        <inputEntry id="ie_2_3"><text>"none","mild"</text></inputEntry>
        <inputEntry id="ie_2_4"><text>"none","mild"</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"Moderate anesthesia risk - prepare for potential complications and monitor closely"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>"IV","V"</text></inputEntry>
        <inputEntry id="ie_3_2"><text>-</text></inputEntry>
        <inputEntry id="ie_3_3"><text>-</text></inputEntry>
        <inputEntry id="ie_3_4"><text>-</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"High anesthesia risk - senior anesthesiologist required, ICU bed reserved, full monitoring"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>-</text></inputEntry>
        <inputEntry id="ie_4_2"><text>[3..4]</text></inputEntry>
        <inputEntry id="ie_4_3"><text>-</text></inputEntry>
        <inputEntry id="ie_4_4"><text>"predicted_difficult"</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"Difficult airway predicted - prepare fiberoptic equipment, experienced anesthesiologist required"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>-</text></inputEntry>
        <inputEntry id="ie_5_2"><text>-</text></inputEntry>
        <inputEntry id="ie_5_3"><text>"anesthesia_allergy"</text></inputEntry>
        <inputEntry id="ie_5_4"><text>-</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"CRITICAL: Anesthesia drug allergy - select alternative agents, allergy protocol in place"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
