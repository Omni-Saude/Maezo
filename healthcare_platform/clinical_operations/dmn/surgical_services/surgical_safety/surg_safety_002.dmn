<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_safety_002"
             name="WHO Time-Out Verification"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_safety_002" name="WHO Time-Out Verification">
    <decisionTable id="dt_surg_safety_002" hitPolicy="FIRST">
      <input id="input_1" label="Team Members Confirmed">
        <inputExpression id="inputExpr_1" typeRef="boolean">
          <text>teamMembersConfirmed</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Patient Identity Reconfirmed">
        <inputExpression id="inputExpr_2" typeRef="boolean">
          <text>patientIdentityReconfirmed</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Procedure Confirmed">
        <inputExpression id="inputExpr_3" typeRef="boolean">
          <text>procedureConfirmed</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Site Confirmed">
        <inputExpression id="inputExpr_4" typeRef="boolean">
          <text>siteConfirmed</text>
        </inputExpression>
      </input>
      <input id="input_5" label="Antibiotic Given">
        <inputExpression id="inputExpr_5" typeRef="string">
          <text>antibioticGiven</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>true</text></inputEntry>
        <inputEntry id="ie_1_2"><text>true</text></inputEntry>
        <inputEntry id="ie_1_3"><text>true</text></inputEntry>
        <inputEntry id="ie_1_4"><text>true</text></inputEntry>
        <inputEntry id="ie_1_5"><text>"given_within_60min"</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"Time-out complete - all criteria met, proceed with incision"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>-</text></inputEntry>
        <inputEntry id="ie_2_2"><text>false</text></inputEntry>
        <inputEntry id="ie_2_3"><text>-</text></inputEntry>
        <inputEntry id="ie_2_4"><text>-</text></inputEntry>
        <inputEntry id="ie_2_5"><text>-</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"CRITICAL: Patient identity not reconfirmed - verify patient before proceeding"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>-</text></inputEntry>
        <inputEntry id="ie_3_2"><text>true</text></inputEntry>
        <inputEntry id="ie_3_3"><text>false</text></inputEntry>
        <inputEntry id="ie_3_4"><text>-</text></inputEntry>
        <inputEntry id="ie_3_5"><text>-</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"Procedure not confirmed by all team members - team must reach consensus"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>true</text></inputEntry>
        <inputEntry id="ie_4_2"><text>true</text></inputEntry>
        <inputEntry id="ie_4_3"><text>true</text></inputEntry>
        <inputEntry id="ie_4_4"><text>true</text></inputEntry>
        <inputEntry id="ie_4_5"><text>"not_required"</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"Time-out complete - antibiotic not indicated for this procedure type"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>true</text></inputEntry>
        <inputEntry id="ie_5_2"><text>true</text></inputEntry>
        <inputEntry id="ie_5_3"><text>true</text></inputEntry>
        <inputEntry id="ie_5_4"><text>true</text></inputEntry>
        <inputEntry id="ie_5_5"><text>"not_given"</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"Prophylactic antibiotic not administered - verify if indicated and administer if required"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
