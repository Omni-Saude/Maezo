<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_safety_005"
             name="Consent Validation"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_safety_005" name="Consent Validation">
    <decisionTable id="dt_surg_safety_005" hitPolicy="FIRST">
      <input id="input_1" label="Consent Signed">
        <inputExpression id="inputExpr_1" typeRef="boolean">
          <text>consentSigned</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Procedure On Consent">
        <inputExpression id="inputExpr_2" typeRef="boolean">
          <text>procedureOnConsent</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Risks Disclosed">
        <inputExpression id="inputExpr_3" typeRef="boolean">
          <text>risksDisclosed</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Patient Competent">
        <inputExpression id="inputExpr_4" typeRef="boolean">
          <text>patientCompetent</text>
        </inputExpression>
      </input>
      <input id="input_5" label="Witness Present">
        <inputExpression id="inputExpr_5" typeRef="boolean">
          <text>witnessPresent</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>true</text></inputEntry>
        <inputEntry id="ie_1_2"><text>true</text></inputEntry>
        <inputEntry id="ie_1_3"><text>true</text></inputEntry>
        <inputEntry id="ie_1_4"><text>true</text></inputEntry>
        <inputEntry id="ie_1_5"><text>true</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"Valid informed consent obtained - all legal requirements met"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>false</text></inputEntry>
        <inputEntry id="ie_2_2"><text>-</text></inputEntry>
        <inputEntry id="ie_2_3"><text>-</text></inputEntry>
        <inputEntry id="ie_2_4"><text>-</text></inputEntry>
        <inputEntry id="ie_2_5"><text>-</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"CRITICAL: No signed consent - obtain informed consent before proceeding with surgery"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>true</text></inputEntry>
        <inputEntry id="ie_3_2"><text>false</text></inputEntry>
        <inputEntry id="ie_3_3"><text>-</text></inputEntry>
        <inputEntry id="ie_3_4"><text>-</text></inputEntry>
        <inputEntry id="ie_3_5"><text>-</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"CRITICAL: Consent does not match planned procedure - obtain new consent for correct procedure"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>true</text></inputEntry>
        <inputEntry id="ie_4_2"><text>true</text></inputEntry>
        <inputEntry id="ie_4_3"><text>false</text></inputEntry>
        <inputEntry id="ie_4_4"><text>-</text></inputEntry>
        <inputEntry id="ie_4_5"><text>-</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"Risks not adequately disclosed - surgeon must discuss risks and obtain new consent"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>true</text></inputEntry>
        <inputEntry id="ie_5_2"><text>true</text></inputEntry>
        <inputEntry id="ie_5_3"><text>true</text></inputEntry>
        <inputEntry id="ie_5_4"><text>false</text></inputEntry>
        <inputEntry id="ie_5_5"><text>false</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"Patient not competent and no witness present - obtain legal guardian consent with witness"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
