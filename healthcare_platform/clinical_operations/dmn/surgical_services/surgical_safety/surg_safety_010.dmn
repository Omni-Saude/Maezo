<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_safety_010"
             name="Fire Risk Assessment"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_safety_010" name="Fire Risk Assessment">
    <decisionTable id="dt_surg_safety_010" hitPolicy="FIRST">
      <input id="input_1" label="Oxygen In Use">
        <inputExpression id="inputExpr_1" typeRef="boolean">
          <text>oxygenInUse</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Alcohol Prep">
        <inputExpression id="inputExpr_2" typeRef="boolean">
          <text>alcoholPrep</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Electrosurgery Planned">
        <inputExpression id="inputExpr_3" typeRef="boolean">
          <text>electrosurgeryPlanned</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Laser In Use">
        <inputExpression id="inputExpr_4" typeRef="boolean">
          <text>laserInUse</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>false</text></inputEntry>
        <inputEntry id="ie_1_2"><text>false</text></inputEntry>
        <inputEntry id="ie_1_3"><text>false</text></inputEntry>
        <inputEntry id="ie_1_4"><text>false</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"Minimal fire risk - standard precautions sufficient"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>true</text></inputEntry>
        <inputEntry id="ie_2_2"><text>true</text></inputEntry>
        <inputEntry id="ie_2_3"><text>true</text></inputEntry>
        <inputEntry id="ie_2_4"><text>false</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"High fire risk - ensure alcohol prep completely dry before cautery, reduce O2 concentration if possible"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>true</text></inputEntry>
        <inputEntry id="ie_3_2"><text>-</text></inputEntry>
        <inputEntry id="ie_3_3"><text>-</text></inputEntry>
        <inputEntry id="ie_3_4"><text>true</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"CRITICAL: Laser with supplemental oxygen - reduce O2 to minimum safe level, wet drapes in place"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>true</text></inputEntry>
        <inputEntry id="ie_4_2"><text>true</text></inputEntry>
        <inputEntry id="ie_4_3"><text>true</text></inputEntry>
        <inputEntry id="ie_4_4"><text>true</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"CRITICAL: Multiple fire risks present - fire drill, extinguisher ready, reduce O2, ensure alcohol dry"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>false</text></inputEntry>
        <inputEntry id="ie_5_2"><text>true</text></inputEntry>
        <inputEntry id="ie_5_3"><text>true</text></inputEntry>
        <inputEntry id="ie_5_4"><text>false</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"Moderate fire risk - ensure alcohol prep dry, fire safety equipment accessible"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
