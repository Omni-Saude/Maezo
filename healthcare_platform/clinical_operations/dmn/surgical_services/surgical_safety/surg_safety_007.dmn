<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_safety_007"
             name="Blood Product Readiness"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_safety_007" name="Blood Product Readiness">
    <decisionTable id="dt_surg_safety_007" hitPolicy="FIRST">
      <input id="input_1" label="Cross Match Status">
        <inputExpression id="inputExpr_1" typeRef="string">
          <text>crossMatchStatus</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Blood Type">
        <inputExpression id="inputExpr_2" typeRef="string">
          <text>bloodType</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Antibody Screen">
        <inputExpression id="inputExpr_3" typeRef="string">
          <text>antibodyScreen</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Units Available">
        <inputExpression id="inputExpr_4" typeRef="number">
          <text>unitsAvailable</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>"not_required"</text></inputEntry>
        <inputEntry id="ie_1_2"><text>-</text></inputEntry>
        <inputEntry id="ie_1_3"><text>-</text></inputEntry>
        <inputEntry id="ie_1_4"><text>-</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"Blood products not required for this low-risk procedure"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>"completed"</text></inputEntry>
        <inputEntry id="ie_2_2"><text>-</text></inputEntry>
        <inputEntry id="ie_2_3"><text>"negative"</text></inputEntry>
        <inputEntry id="ie_2_4"><text>&gt;= 2</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"Blood products ready - crossmatched units available in blood bank"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>"type_and_screen"</text></inputEntry>
        <inputEntry id="ie_3_2"><text>-</text></inputEntry>
        <inputEntry id="ie_3_3"><text>"negative"</text></inputEntry>
        <inputEntry id="ie_3_4"><text>-</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"Type and screen complete - blood can be crossmatched quickly if needed during surgery"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>"completed"</text></inputEntry>
        <inputEntry id="ie_4_2"><text>-</text></inputEntry>
        <inputEntry id="ie_4_3"><text>"positive"</text></inputEntry>
        <inputEntry id="ie_4_4"><text>&gt;= 2</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"Antibody screen positive - crossmatched compatible blood available, monitor for reactions"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>"pending","not_done"</text></inputEntry>
        <inputEntry id="ie_5_2"><text>-</text></inputEntry>
        <inputEntry id="ie_5_3"><text>-</text></inputEntry>
        <inputEntry id="ie_5_4"><text>-</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"CRITICAL: Blood products required but not ready - delay surgery until crossmatch complete"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
