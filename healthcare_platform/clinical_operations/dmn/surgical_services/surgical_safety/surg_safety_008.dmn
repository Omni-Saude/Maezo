<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_safety_008"
             name="Allergy Alert Verification"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_safety_008" name="Allergy Alert Verification">
    <decisionTable id="dt_surg_safety_008" hitPolicy="FIRST">
      <input id="input_1" label="Allergies Documented">
        <inputExpression id="inputExpr_1" typeRef="boolean">
          <text>allergiesDocumented</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Bracelet Verified">
        <inputExpression id="inputExpr_2" typeRef="boolean">
          <text>braceletVerified</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Anesthesia Notified">
        <inputExpression id="inputExpr_3" typeRef="boolean">
          <text>anesthesiaNotified</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Latex Precaution">
        <inputExpression id="inputExpr_4" typeRef="string">
          <text>latexPrecaution</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>true</text></inputEntry>
        <inputEntry id="ie_1_2"><text>true</text></inputEntry>
        <inputEntry id="ie_1_3"><text>true</text></inputEntry>
        <inputEntry id="ie_1_4"><text>"not_required"</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"Allergy information complete - all team members aware of patient allergies"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>false</text></inputEntry>
        <inputEntry id="ie_2_2"><text>-</text></inputEntry>
        <inputEntry id="ie_2_3"><text>-</text></inputEntry>
        <inputEntry id="ie_2_4"><text>-</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"CRITICAL: Allergies not documented in chart - verify and document all allergies before proceeding"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>true</text></inputEntry>
        <inputEntry id="ie_3_2"><text>false</text></inputEntry>
        <inputEntry id="ie_3_3"><text>-</text></inputEntry>
        <inputEntry id="ie_3_4"><text>-</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"Allergy bracelet not verified - nursing must verify bracelet matches chart before surgery"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>true</text></inputEntry>
        <inputEntry id="ie_4_2"><text>true</text></inputEntry>
        <inputEntry id="ie_4_3"><text>false</text></inputEntry>
        <inputEntry id="ie_4_4"><text>-</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"Anesthesia team not notified of allergies - brief anesthesiologist on all documented allergies"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>true</text></inputEntry>
        <inputEntry id="ie_5_2"><text>true</text></inputEntry>
        <inputEntry id="ie_5_3"><text>true</text></inputEntry>
        <inputEntry id="ie_5_4"><text>"required"</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"Latex allergy present - ensure latex-free environment, all equipment and gloves latex-free"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"ALTO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
