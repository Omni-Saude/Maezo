<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_safety_011"
             name="Hypothermia Prevention"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_safety_011" name="Hypothermia Prevention">
    <decisionTable id="dt_surg_safety_011" hitPolicy="FIRST">
      <input id="input_1" label="Surgery Duration Estimate">
        <inputExpression id="inputExpr_1" typeRef="number">
          <text>surgeryDurationEstimate</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Body Exposure">
        <inputExpression id="inputExpr_2" typeRef="string">
          <text>bodyExposure</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Warming Device Available">
        <inputExpression id="inputExpr_3" typeRef="boolean">
          <text>warmingDeviceAvailable</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Room Temperature">
        <inputExpression id="inputExpr_4" typeRef="number">
          <text>roomTemperature</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>&lt; 60</text></inputEntry>
        <inputEntry id="ie_1_2"><text>"minimal"</text></inputEntry>
        <inputEntry id="ie_1_3"><text>-</text></inputEntry>
        <inputEntry id="ie_1_4"><text>&gt;= 21</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"Low hypothermia risk - standard warming blankets sufficient"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>&gt;= 120</text></inputEntry>
        <inputEntry id="ie_2_2"><text>"extensive"</text></inputEntry>
        <inputEntry id="ie_2_3"><text>true</text></inputEntry>
        <inputEntry id="ie_2_4"><text>&gt;= 21</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"High hypothermia risk - forced-air warming device active, warmed IV fluids, room temperature optimal"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>&gt;= 60</text></inputEntry>
        <inputEntry id="ie_3_2"><text>"moderate","extensive"</text></inputEntry>
        <inputEntry id="ie_3_3"><text>false</text></inputEntry>
        <inputEntry id="ie_3_4"><text>-</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"CRITICAL: Warming device required but not available - obtain forced-air warming before proceeding"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>&gt;= 90</text></inputEntry>
        <inputEntry id="ie_4_2"><text>-</text></inputEntry>
        <inputEntry id="ie_4_3"><text>true</text></inputEntry>
        <inputEntry id="ie_4_4"><text>&lt; 20</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"Room temperature too low - increase OR temperature to 21-24°C, activate warming devices"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>[60..120)</text></inputEntry>
        <inputEntry id="ie_5_2"><text>"moderate"</text></inputEntry>
        <inputEntry id="ie_5_3"><text>true</text></inputEntry>
        <inputEntry id="ie_5_4"><text>&gt;= 21</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"Moderate hypothermia risk - warming device ready, warmed fluids available, monitor temperature"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
