<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_sched_001"
             name="OR Allocation Priority"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_sched_001" name="OR Allocation Priority">
    <decisionTable id="dt_surg_sched_001" hitPolicy="FIRST">
      <input id="input_1" label="Urgency Level">
        <inputExpression id="inputExpr_1" typeRef="string">
          <text>urgencyLevel</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Specialty Type">
        <inputExpression id="inputExpr_2" typeRef="string">
          <text>specialtyType</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Estimated Duration">
        <inputExpression id="inputExpr_3" typeRef="number">
          <text>estimatedDuration</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Equipment Needs">
        <inputExpression id="inputExpr_4" typeRef="string">
          <text>equipmentNeeds</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>"emergent"</text></inputEntry>
        <inputEntry id="ie_1_2"><text>-</text></inputEntry>
        <inputEntry id="ie_1_3"><text>-</text></inputEntry>
        <inputEntry id="ie_1_4"><text>-</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"Emergent case - allocate next available OR immediately, bump elective cases if necessary"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>"urgent"</text></inputEntry>
        <inputEntry id="ie_2_2"><text>-</text></inputEntry>
        <inputEntry id="ie_2_3"><text>&lt; 120</text></inputEntry>
        <inputEntry id="ie_2_4"><text>"standard"</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"Urgent case - schedule within 24h in main OR suite with standard equipment"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>"elective"</text></inputEntry>
        <inputEntry id="ie_3_2"><text>"cardiac","neuro"</text></inputEntry>
        <inputEntry id="ie_3_3"><text>-</text></inputEntry>
        <inputEntry id="ie_3_4"><text>"specialized"</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"Elective specialty case - allocate to specialty OR with required equipment, schedule during regular hours"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>"elective"</text></inputEntry>
        <inputEntry id="ie_4_2"><text>"general"</text></inputEntry>
        <inputEntry id="ie_4_3"><text>&lt; 90</text></inputEntry>
        <inputEntry id="ie_4_4"><text>"standard"</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"Routine elective case - schedule in general OR based on availability, fill scheduling gaps"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>"elective"</text></inputEntry>
        <inputEntry id="ie_5_2"><text>-</text></inputEntry>
        <inputEntry id="ie_5_3"><text>&gt;= 240</text></inputEntry>
        <inputEntry id="ie_5_4"><text>-</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"Long elective case - schedule as first case of day, ensure adequate turnover time, reserve ICU bed"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
