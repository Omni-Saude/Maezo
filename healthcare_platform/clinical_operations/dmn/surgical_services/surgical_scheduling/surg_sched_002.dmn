<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_sched_002"
             name="Equipment Matching"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_sched_002" name="Equipment Matching">
    <decisionTable id="dt_surg_sched_002" hitPolicy="FIRST">
      <input id="input_1" label="Procedure Type">
        <inputExpression id="inputExpr_1" typeRef="string">
          <text>procedureType</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Special Equipment">
        <inputExpression id="inputExpr_2" typeRef="string">
          <text>specialEquipment</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Sterilization Status">
        <inputExpression id="inputExpr_3" typeRef="string">
          <text>sterilizationStatus</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Backup Available">
        <inputExpression id="inputExpr_4" typeRef="boolean">
          <text>backupAvailable</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>"laparoscopic"</text></inputEntry>
        <inputEntry id="ie_1_2"><text>"tower_available"</text></inputEntry>
        <inputEntry id="ie_1_3"><text>"sterile"</text></inputEntry>
        <inputEntry id="ie_1_4"><text>true</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"Laparoscopic equipment ready - tower, instruments sterile, backup instruments available"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>"robotic"</text></inputEntry>
        <inputEntry id="ie_2_2"><text>"robot_available"</text></inputEntry>
        <inputEntry id="ie_2_3"><text>"sterile"</text></inputEntry>
        <inputEntry id="ie_2_4"><text>-</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"Robotic system ready - robot calibrated, instruments sterile, technical support on call"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>-</text></inputEntry>
        <inputEntry id="ie_3_2"><text>"required"</text></inputEntry>
        <inputEntry id="ie_3_3"><text>"not_sterile"</text></inputEntry>
        <inputEntry id="ie_3_4"><text>-</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"CRITICAL: Required equipment not sterile - delay case until sterilization complete"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>-</text></inputEntry>
        <inputEntry id="ie_4_2"><text>"required"</text></inputEntry>
        <inputEntry id="ie_4_3"><text>"sterile"</text></inputEntry>
        <inputEntry id="ie_4_4"><text>false</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"No backup equipment - proceed with caution, have contingency plan ready for equipment failure"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>"open"</text></inputEntry>
        <inputEntry id="ie_5_2"><text>"standard"</text></inputEntry>
        <inputEntry id="ie_5_3"><text>"sterile"</text></inputEntry>
        <inputEntry id="ie_5_4"><text>-</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"Standard open surgery equipment ready - basic instrument sets sterile and available"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
