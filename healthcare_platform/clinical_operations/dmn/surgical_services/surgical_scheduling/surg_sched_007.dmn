<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_sched_007"
             name="Resource Conflict Resolution"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_sched_007" name="Resource Conflict Resolution">
    <decisionTable id="dt_surg_sched_007" hitPolicy="FIRST">
      <input id="input_1" label="Conflict Type">
        <inputExpression id="inputExpr_1" typeRef="string">
          <text>conflictType</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Priority A">
        <inputExpression id="inputExpr_2" typeRef="number">
          <text>priorityA</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Priority B">
        <inputExpression id="inputExpr_3" typeRef="number">
          <text>priorityB</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Alternative Available">
        <inputExpression id="inputExpr_4" typeRef="boolean">
          <text>alternativeAvailable</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>"or_room"</text></inputEntry>
        <inputEntry id="ie_1_2"><text>&gt;= 90</text></inputEntry>
        <inputEntry id="ie_1_3"><text>&lt; 90</text></inputEntry>
        <inputEntry id="ie_1_4"><text>-</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"Allocate OR to higher priority case (A), reschedule or find alternative OR for lower priority case"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>"surgeon"</text></inputEntry>
        <inputEntry id="ie_2_2"><text>-</text></inputEntry>
        <inputEntry id="ie_2_3"><text>-</text></inputEntry>
        <inputEntry id="ie_2_4"><text>true</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"Surgeon conflict - assign alternate qualified surgeon to lower complexity case"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>"equipment"</text></inputEntry>
        <inputEntry id="ie_3_2"><text>&gt;= 85</text></inputEntry>
        <inputEntry id="ie_3_3"><text>&lt; 85</text></inputEntry>
        <inputEntry id="ie_3_4"><text>false</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"Equipment conflict without alternative - delay lower priority case until equipment available"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>-</text></inputEntry>
        <inputEntry id="ie_4_2"><text>&gt;= 95</text></inputEntry>
        <inputEntry id="ie_4_3"><text>&gt;= 95</text></inputEntry>
        <inputEntry id="ie_4_4"><text>-</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"CRITICAL: Both cases high priority - escalate to OR director for resource allocation decision"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>"or_room"</text></inputEntry>
        <inputEntry id="ie_5_2"><text>-</text></inputEntry>
        <inputEntry id="ie_5_3"><text>-</text></inputEntry>
        <inputEntry id="ie_5_4"><text>true</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"OR conflict with alternative available - allocate alternative OR to maintain both schedules"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
