<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_sched_003"
             name="Team Assignment Rules"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_sched_003" name="Team Assignment Rules">
    <decisionTable id="dt_surg_sched_003" hitPolicy="FIRST">
      <input id="input_1" label="Procedure Complexity">
        <inputExpression id="inputExpr_1" typeRef="string">
          <text>procedureComplexity</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Specialty Required">
        <inputExpression id="inputExpr_2" typeRef="string">
          <text>specialtyRequired</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Surgeon Availability">
        <inputExpression id="inputExpr_3" typeRef="boolean">
          <text>surgeonAvailability</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Anesthesiologist Availability">
        <inputExpression id="inputExpr_4" typeRef="boolean">
          <text>anesthesiologistAvailability</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>"high"</text></inputEntry>
        <inputEntry id="ie_1_2"><text>"cardiac","neuro"</text></inputEntry>
        <inputEntry id="ie_1_3"><text>true</text></inputEntry>
        <inputEntry id="ie_1_4"><text>true</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"Complex specialty case - assign senior surgeon, specialized anesthesiologist, experienced OR team"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>"low"</text></inputEntry>
        <inputEntry id="ie_2_2"><text>"general"</text></inputEntry>
        <inputEntry id="ie_2_3"><text>true</text></inputEntry>
        <inputEntry id="ie_2_4"><text>true</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"Routine case - assign available surgeon, standard anesthesia team, regular OR staff"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>-</text></inputEntry>
        <inputEntry id="ie_3_2"><text>-</text></inputEntry>
        <inputEntry id="ie_3_3"><text>false</text></inputEntry>
        <inputEntry id="ie_3_4"><text>-</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"CRITICAL: Required surgeon not available - reschedule or find qualified alternate surgeon"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>-</text></inputEntry>
        <inputEntry id="ie_4_2"><text>-</text></inputEntry>
        <inputEntry id="ie_4_3"><text>true</text></inputEntry>
        <inputEntry id="ie_4_4"><text>false</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"CRITICAL: Anesthesiologist not available - reschedule or request on-call anesthesiologist"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>"medium"</text></inputEntry>
        <inputEntry id="ie_5_2"><text>"orthopedic","ent"</text></inputEntry>
        <inputEntry id="ie_5_3"><text>true</text></inputEntry>
        <inputEntry id="ie_5_4"><text>true</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"Moderate complexity - assign experienced surgeon, standard anesthesia, specialty-trained OR nurse"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
