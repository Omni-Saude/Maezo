<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_sched_006"
             name="Case Sequencing"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_sched_006" name="Case Sequencing">
    <decisionTable id="dt_surg_sched_006" hitPolicy="FIRST">
      <input id="input_1" label="Infection Risk">
        <inputExpression id="inputExpr_1" typeRef="string">
          <text>infectionRisk</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Procedure Type">
        <inputExpression id="inputExpr_2" typeRef="string">
          <text>procedureType</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Cleanliness Level">
        <inputExpression id="inputExpr_3" typeRef="string">
          <text>cleanlinessLevel</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Previous Case Contamination">
        <inputExpression id="inputExpr_4" typeRef="boolean">
          <text>previousCaseContamination</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>"clean"</text></inputEntry>
        <inputEntry id="ie_1_2"><text>"orthopedic_implant","cardiac"</text></inputEntry>
        <inputEntry id="ie_1_3"><text>-</text></inputEntry>
        <inputEntry id="ie_1_4"><text>false</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"Clean case with implant - schedule as first case of the day to minimize infection risk"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>"dirty_infected"</text></inputEntry>
        <inputEntry id="ie_2_2"><text>-</text></inputEntry>
        <inputEntry id="ie_2_3"><text>-</text></inputEntry>
        <inputEntry id="ie_2_4"><text>-</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"Dirty/infected case - schedule as last case of the day, terminal cleaning required after"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>"clean","clean_contaminated"</text></inputEntry>
        <inputEntry id="ie_3_2"><text>-</text></inputEntry>
        <inputEntry id="ie_3_3"><text>-</text></inputEntry>
        <inputEntry id="ie_3_4"><text>true</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"CRITICAL: Previous case contaminated - require terminal cleaning before clean case proceeds"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>"clean_contaminated"</text></inputEntry>
        <inputEntry id="ie_4_2"><text>"gi","urologic"</text></inputEntry>
        <inputEntry id="ie_4_3"><text>-</text></inputEntry>
        <inputEntry id="ie_4_4"><text>false</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"Clean-contaminated case - schedule after clean cases, standard turnover cleaning adequate"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>"contaminated"</text></inputEntry>
        <inputEntry id="ie_5_2"><text>-</text></inputEntry>
        <inputEntry id="ie_5_3"><text>-</text></inputEntry>
        <inputEntry id="ie_5_4"><text>false</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"Contaminated case - schedule late in day, enhanced cleaning protocol required after case"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
