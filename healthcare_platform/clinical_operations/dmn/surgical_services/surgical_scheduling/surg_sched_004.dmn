<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_sched_004"
             name="Priority Scoring"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_sched_004" name="Priority Scoring">
    <decisionTable id="dt_surg_sched_004" hitPolicy="FIRST">
      <input id="input_1" label="Clinical Urgency">
        <inputExpression id="inputExpr_1" typeRef="string">
          <text>clinicalUrgency</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Waiting Time">
        <inputExpression id="inputExpr_2" typeRef="number">
          <text>waitingTime</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Age Group">
        <inputExpression id="inputExpr_3" typeRef="string">
          <text>ageGroup</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Comorbidity Count">
        <inputExpression id="inputExpr_4" typeRef="number">
          <text>comorbidityCount</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>"emergent"</text></inputEntry>
        <inputEntry id="ie_1_2"><text>-</text></inputEntry>
        <inputEntry id="ie_1_3"><text>-</text></inputEntry>
        <inputEntry id="ie_1_4"><text>-</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"Priority score: 100 - Emergent case, immediate OR allocation required"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>"urgent"</text></inputEntry>
        <inputEntry id="ie_2_2"><text>&gt;= 30</text></inputEntry>
        <inputEntry id="ie_2_3"><text>"pediatric","geriatric"</text></inputEntry>
        <inputEntry id="ie_2_4"><text>&gt;= 3</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"Priority score: 85 - Urgent case with multiple risk factors, schedule within 24 hours"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>"semi_urgent"</text></inputEntry>
        <inputEntry id="ie_3_2"><text>&gt;= 60</text></inputEntry>
        <inputEntry id="ie_3_3"><text>-</text></inputEntry>
        <inputEntry id="ie_3_4"><text>[2..3]</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"Priority score: 70 - Semi-urgent with extended wait time, schedule within 7 days"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>"elective"</text></inputEntry>
        <inputEntry id="ie_4_2"><text>&gt;= 90</text></inputEntry>
        <inputEntry id="ie_4_3"><text>"geriatric"</text></inputEntry>
        <inputEntry id="ie_4_4"><text>&gt;= 4</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"Priority score: 60 - Elective but high risk profile, prioritize over routine electives"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>"elective"</text></inputEntry>
        <inputEntry id="ie_5_2"><text>&lt; 30</text></inputEntry>
        <inputEntry id="ie_5_3"><text>"adult"</text></inputEntry>
        <inputEntry id="ie_5_4"><text>[0..1]</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"Priority score: 30 - Routine elective case, schedule based on OR availability"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
