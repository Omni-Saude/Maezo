<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_outcome_004"
             name="Infection Risk Scoring"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_outcome_004" name="Infection Risk Scoring">
    <decisionTable id="dt_surg_outcome_004" hitPolicy="FIRST">
      <input id="input_1" label="Wound Class">
        <inputExpression id="inputExpr_1" typeRef="string">
          <text>woundClass</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Surgery Duration">
        <inputExpression id="inputExpr_2" typeRef="number">
          <text>surgeryDuration</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Implant Used">
        <inputExpression id="inputExpr_3" typeRef="boolean">
          <text>implantUsed</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Diabetes Present">
        <inputExpression id="inputExpr_4" typeRef="boolean">
          <text>diabetesPresent</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>"clean"</text></inputEntry>
        <inputEntry id="ie_1_2"><text>&lt; 120</text></inputEntry>
        <inputEntry id="ie_1_3"><text>false</text></inputEntry>
        <inputEntry id="ie_1_4"><text>false</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"Low SSI risk (&lt;2%) - standard wound care, routine post-op follow-up"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>"clean"</text></inputEntry>
        <inputEntry id="ie_2_2"><text>-</text></inputEntry>
        <inputEntry id="ie_2_3"><text>true</text></inputEntry>
        <inputEntry id="ie_2_4"><text>-</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"Moderate SSI risk (3-5%) with implant - extended antibiotic prophylaxis, monitor closely"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>"clean_contaminated"</text></inputEntry>
        <inputEntry id="ie_3_2"><text>&gt;= 180</text></inputEntry>
        <inputEntry id="ie_3_3"><text>-</text></inputEntry>
        <inputEntry id="ie_3_4"><text>true</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"Elevated SSI risk (8-12%) - glucose control critical, wound check POD2, consider VAC therapy"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>"contaminated","dirty_infected"</text></inputEntry>
        <inputEntry id="ie_4_2"><text>-</text></inputEntry>
        <inputEntry id="ie_4_3"><text>-</text></inputEntry>
        <inputEntry id="ie_4_4"><text>-</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"High SSI risk (15-40%) - therapeutic antibiotics, delayed primary closure consideration, daily wound assessment"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>"contaminated","dirty_infected"</text></inputEntry>
        <inputEntry id="ie_5_2"><text>&gt;= 240</text></inputEntry>
        <inputEntry id="ie_5_3"><text>true</text></inputEntry>
        <inputEntry id="ie_5_4"><text>true</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"CRITICAL: Very high SSI risk (&gt;40%) - wound left open, wound vac, ID consult, strict glucose control"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
