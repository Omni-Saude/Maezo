<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_outcome_003"
             name="Recovery Milestones"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_outcome_003" name="Recovery Milestones">
    <decisionTable id="dt_surg_outcome_003" hitPolicy="FIRST">
      <input id="input_1" label="Procedure Type">
        <inputExpression id="inputExpr_1" typeRef="string">
          <text>procedureType</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Post Op Day">
        <inputExpression id="inputExpr_2" typeRef="number">
          <text>postOpDay</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Pain Level">
        <inputExpression id="inputExpr_3" typeRef="number">
          <text>painLevel</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Mobility Status">
        <inputExpression id="inputExpr_4" typeRef="string">
          <text>mobilityStatus</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>"laparoscopic"</text></inputEntry>
        <inputEntry id="ie_1_2"><text>1</text></inputEntry>
        <inputEntry id="ie_1_3"><text>[0..4]</text></inputEntry>
        <inputEntry id="ie_1_4"><text>"ambulatory"</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"Meeting POD1 milestones - pain controlled, ambulating, advance diet, consider discharge"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>"open_abdominal"</text></inputEntry>
        <inputEntry id="ie_2_2"><text>3</text></inputEntry>
        <inputEntry id="ie_2_3"><text>[0..5]</text></inputEntry>
        <inputEntry id="ie_2_4"><text>"ambulatory_with_assist"</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"POD3 milestones met - tolerating diet, bowel sounds present, ambulating with assistance"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>-</text></inputEntry>
        <inputEntry id="ie_3_2"><text>-</text></inputEntry>
        <inputEntry id="ie_3_3"><text>&gt;= 7</text></inputEntry>
        <inputEntry id="ie_3_4"><text>-</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"Uncontrolled pain - pain service consult, multimodal analgesia, assess for complications"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>-</text></inputEntry>
        <inputEntry id="ie_4_2"><text>&gt;= 3</text></inputEntry>
        <inputEntry id="ie_4_3"><text>-</text></inputEntry>
        <inputEntry id="ie_4_4"><text>"bedbound","minimal_mobility"</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"Delayed mobility - PT consult, assess for complications, DVT prophylaxis verification"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>"orthopedic"</text></inputEntry>
        <inputEntry id="ie_5_2"><text>1</text></inputEntry>
        <inputEntry id="ie_5_3"><text>[0..6]</text></inputEntry>
        <inputEntry id="ie_5_4"><text>"weight_bearing_as_tolerated"</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"Orthopedic POD1 milestone - pain adequate for PT, WBAT achieved, continue mobilization"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
