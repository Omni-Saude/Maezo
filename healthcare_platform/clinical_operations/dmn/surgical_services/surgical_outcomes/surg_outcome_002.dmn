<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_outcome_002"
             name="Readmission Prediction"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_outcome_002" name="Readmission Prediction">
    <decisionTable id="dt_surg_outcome_002" hitPolicy="FIRST">
      <input id="input_1" label="Procedure Type">
        <inputExpression id="inputExpr_1" typeRef="string">
          <text>procedureType</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Discharge Day">
        <inputExpression id="inputExpr_2" typeRef="number">
          <text>dischargeDay</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Complications During Surgery">
        <inputExpression id="inputExpr_3" typeRef="boolean">
          <text>complicationsDuringSurgery</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Social Support">
        <inputExpression id="inputExpr_4" typeRef="string">
          <text>socialSupport</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>"orthopedic","general"</text></inputEntry>
        <inputEntry id="ie_1_2"><text>[2..4]</text></inputEntry>
        <inputEntry id="ie_1_3"><text>false</text></inputEntry>
        <inputEntry id="ie_1_4"><text>"good"</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"Low readmission risk (&lt;5%) - standard discharge planning, routine follow-up in 2 weeks"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>"cardiac","vascular"</text></inputEntry>
        <inputEntry id="ie_2_2"><text>-</text></inputEntry>
        <inputEntry id="ie_2_3"><text>false</text></inputEntry>
        <inputEntry id="ie_2_4"><text>"good"</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"Moderate risk (10-15%) - discharge phone call day 2, early follow-up in 1 week"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>-</text></inputEntry>
        <inputEntry id="ie_3_2"><text>&lt; 2</text></inputEntry>
        <inputEntry id="ie_3_3"><text>-</text></inputEntry>
        <inputEntry id="ie_3_4"><text>-</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"Early discharge - higher readmission risk, arrange 48hr home health visit, phone follow-up"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>-</text></inputEntry>
        <inputEntry id="ie_4_2"><text>-</text></inputEntry>
        <inputEntry id="ie_4_3"><text>true</text></inputEntry>
        <inputEntry id="ie_4_4"><text>-</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"Intraop complications - high risk (20-30%), extended monitoring before discharge, early clinic visit"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>-</text></inputEntry>
        <inputEntry id="ie_5_2"><text>-</text></inputEntry>
        <inputEntry id="ie_5_3"><text>-</text></inputEntry>
        <inputEntry id="ie_5_4"><text>"poor","none"</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"Poor social support - high readmission risk, social work consult, consider rehab facility"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"ALTO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
