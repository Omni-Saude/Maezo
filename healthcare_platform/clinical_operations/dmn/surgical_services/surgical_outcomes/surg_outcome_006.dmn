<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_outcome_006"
             name="Pain Management Protocol"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_outcome_006" name="Pain Management Protocol">
    <decisionTable id="dt_surg_outcome_006" hitPolicy="FIRST">
      <input id="input_1" label="Procedure Type">
        <inputExpression id="inputExpr_1" typeRef="string">
          <text>procedureType</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Pain Severity">
        <inputExpression id="inputExpr_2" typeRef="number">
          <text>painSeverity</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Opioid History">
        <inputExpression id="inputExpr_3" typeRef="string">
          <text>opioidHistory</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Kidney Function">
        <inputExpression id="inputExpr_4" typeRef="string">
          <text>kidneyFunction</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>"minor"</text></inputEntry>
        <inputEntry id="ie_1_2"><text>[0..3]</text></inputEntry>
        <inputEntry id="ie_1_3"><text>"none"</text></inputEntry>
        <inputEntry id="ie_1_4"><text>"normal"</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"Mild pain protocol - acetaminophen/NSAID combination, ice, early mobilization"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>"moderate"</text></inputEntry>
        <inputEntry id="ie_2_2"><text>[4..6]</text></inputEntry>
        <inputEntry id="ie_2_3"><text>"none","limited"</text></inputEntry>
        <inputEntry id="ie_2_4"><text>"normal"</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"Moderate pain - multimodal analgesia, short-acting opioid PRN, regional block if available"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>"major"</text></inputEntry>
        <inputEntry id="ie_3_2"><text>[7..10]</text></inputEntry>
        <inputEntry id="ie_3_3"><text>"none","limited"</text></inputEntry>
        <inputEntry id="ie_3_4"><text>"normal"</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"Severe pain - PCA or epidural, multimodal adjuncts, pain service consult"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>-</text></inputEntry>
        <inputEntry id="ie_4_2"><text>-</text></inputEntry>
        <inputEntry id="ie_4_3"><text>"chronic_opioid_use"</text></inputEntry>
        <inputEntry id="ie_4_4"><text>-</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"Opioid tolerant patient - continue home opioids, add 50-100% for acute pain, pain service consult required"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>-</text></inputEntry>
        <inputEntry id="ie_5_2"><text>-</text></inputEntry>
        <inputEntry id="ie_5_3"><text>-</text></inputEntry>
        <inputEntry id="ie_5_4"><text>"severe_ckd","dialysis"</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"Renal impairment - avoid NSAIDs, reduce opioid doses by 50%, prefer shorter-acting agents, nephrology input"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"ALTO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
