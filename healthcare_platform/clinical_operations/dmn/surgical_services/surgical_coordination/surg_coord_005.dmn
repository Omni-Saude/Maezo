<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_coord_005"
             name="OR Turnover Optimization"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_coord_005" name="OR Turnover Optimization">
    <decisionTable id="dt_surg_coord_005" hitPolicy="FIRST">
      <input id="input_1" label="Previous Case Complexity">
        <inputExpression id="inputExpr_1" typeRef="string">
          <text>previousCaseComplexity</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Cleaning Level">
        <inputExpression id="inputExpr_2" typeRef="string">
          <text>cleaningLevel</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Next Case Setup Needs">
        <inputExpression id="inputExpr_3" typeRef="string">
          <text>nextCaseSetupNeeds</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Turnaround Time Minutes">
        <inputExpression id="inputExpr_4" typeRef="number">
          <text>turnaroundTimeMinutes</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>"simple"</text></inputEntry>
        <inputEntry id="ie_1_2"><text>"standard"</text></inputEntry>
        <inputEntry id="ie_1_3"><text>"minimal"</text></inputEntry>
        <inputEntry id="ie_1_4"><text>&lt;= 30</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"Optimal turnover time - standard cleaning and setup completed within target"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>"complex"</text></inputEntry>
        <inputEntry id="ie_2_2"><text>"enhanced"</text></inputEntry>
        <inputEntry id="ie_2_3"><text>"extensive"</text></inputEntry>
        <inputEntry id="ie_2_4"><text>&lt;= 60</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"Complex case turnover - enhanced cleaning and extensive setup within acceptable time"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>-</text></inputEntry>
        <inputEntry id="ie_3_2"><text>"terminal"</text></inputEntry>
        <inputEntry id="ie_3_3"><text>-</text></inputEntry>
        <inputEntry id="ie_3_4"><text>&lt;= 90</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"Terminal cleaning required - extended turnover time acceptable for infection control"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>"simple"</text></inputEntry>
        <inputEntry id="ie_4_2"><text>"standard"</text></inputEntry>
        <inputEntry id="ie_4_3"><text>"minimal"</text></inputEntry>
        <inputEntry id="ie_4_4"><text>&gt; 45</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"Excessive turnover time - review workflow inefficiencies, staff training needed"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>-</text></inputEntry>
        <inputEntry id="ie_5_2"><text>-</text></inputEntry>
        <inputEntry id="ie_5_3"><text>"specialty_equipment"</text></inputEntry>
        <inputEntry id="ie_5_4"><text>&lt;= 75</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"Specialty equipment setup - extended turnover justified for complex equipment preparation"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
