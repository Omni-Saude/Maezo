<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_coord_003"
             name="ICU Transfer Rules"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_coord_003" name="ICU Transfer Rules">
    <decisionTable id="dt_surg_coord_003" hitPolicy="FIRST">
      <input id="input_1" label="Hemodynamic Stability">
        <inputExpression id="inputExpr_1" typeRef="string">
          <text>hemodynamicStability</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Ventilator Needed">
        <inputExpression id="inputExpr_2" typeRef="boolean">
          <text>ventilatorNeeded</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Vasoactive Agents">
        <inputExpression id="inputExpr_3" typeRef="boolean">
          <text>vasoactiveAgents</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Monitoring Level">
        <inputExpression id="inputExpr_4" typeRef="string">
          <text>monitoringLevel</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>"stable"</text></inputEntry>
        <inputEntry id="ie_1_2"><text>false</text></inputEntry>
        <inputEntry id="ie_1_3"><text>false</text></inputEntry>
        <inputEntry id="ie_1_4"><text>"standard"</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"No ICU required - transfer to surgical floor with standard monitoring"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>-</text></inputEntry>
        <inputEntry id="ie_2_2"><text>true</text></inputEntry>
        <inputEntry id="ie_2_3"><text>-</text></inputEntry>
        <inputEntry id="ie_2_4"><text>-</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"Ventilator support required - transfer to ICU, respiratory therapy consult, wean protocol"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>-</text></inputEntry>
        <inputEntry id="ie_3_2"><text>-</text></inputEntry>
        <inputEntry id="ie_3_3"><text>true</text></inputEntry>
        <inputEntry id="ie_3_4"><text>-</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"Vasopressor support needed - ICU admission for hemodynamic monitoring and titration"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>"unstable"</text></inputEntry>
        <inputEntry id="ie_4_2"><text>-</text></inputEntry>
        <inputEntry id="ie_4_3"><text>-</text></inputEntry>
        <inputEntry id="ie_4_4"><text>-</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"CRITICAL: Hemodynamically unstable - ICU admission mandatory, intensivist at bedside"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>"borderline"</text></inputEntry>
        <inputEntry id="ie_5_2"><text>false</text></inputEntry>
        <inputEntry id="ie_5_3"><text>false</text></inputEntry>
        <inputEntry id="ie_5_4"><text>"telemetry"</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"Borderline stability - stepdown unit with telemetry monitoring, reassess in 4 hours"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
