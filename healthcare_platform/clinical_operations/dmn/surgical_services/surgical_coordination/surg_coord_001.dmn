<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_coord_001"
             name="Handoff Protocol Validation"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_coord_001" name="Handoff Protocol Validation">
    <decisionTable id="dt_surg_coord_001" hitPolicy="FIRST">
      <input id="input_1" label="Handoff Type">
        <inputExpression id="inputExpr_1" typeRef="string">
          <text>handoffType</text>
        </inputExpression>
      </input>
      <input id="input_2" label="SBAR Complete">
        <inputExpression id="inputExpr_2" typeRef="boolean">
          <text>sbarComplete</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Receiving Unit Ready">
        <inputExpression id="inputExpr_3" typeRef="boolean">
          <text>receivingUnitReady</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Vital Signs Stable">
        <inputExpression id="inputExpr_4" typeRef="boolean">
          <text>vitalSignsStable</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>"OR_to_PACU"</text></inputEntry>
        <inputEntry id="ie_1_2"><text>true</text></inputEntry>
        <inputEntry id="ie_1_3"><text>true</text></inputEntry>
        <inputEntry id="ie_1_4"><text>true</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"PACU handoff complete - SBAR communicated, bed ready, patient stable for transfer"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>-</text></inputEntry>
        <inputEntry id="ie_2_2"><text>false</text></inputEntry>
        <inputEntry id="ie_2_3"><text>-</text></inputEntry>
        <inputEntry id="ie_2_4"><text>-</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"CRITICAL: SBAR not complete - complete structured handoff before patient transfer"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>-</text></inputEntry>
        <inputEntry id="ie_3_2"><text>true</text></inputEntry>
        <inputEntry id="ie_3_3"><text>false</text></inputEntry>
        <inputEntry id="ie_3_4"><text>-</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"Receiving unit not ready - delay transfer until bed assignment and staff available"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>-</text></inputEntry>
        <inputEntry id="ie_4_2"><text>true</text></inputEntry>
        <inputEntry id="ie_4_3"><text>true</text></inputEntry>
        <inputEntry id="ie_4_4"><text>false</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"Unstable vitals - stabilize patient before transfer, consider ICU instead of floor"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>"PACU_to_ICU"</text></inputEntry>
        <inputEntry id="ie_5_2"><text>true</text></inputEntry>
        <inputEntry id="ie_5_3"><text>true</text></inputEntry>
        <inputEntry id="ie_5_4"><text>-</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"ICU transfer - intensivist handoff complete, critical care bed ready, transport with monitoring"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
