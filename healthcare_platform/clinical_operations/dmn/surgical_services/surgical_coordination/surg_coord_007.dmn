<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_coord_007"
             name="Count Verification Rules"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_coord_007" name="Count Verification Rules">
    <decisionTable id="dt_surg_coord_007" hitPolicy="FIRST">
      <input id="input_1" label="Instrument Count Pre">
        <inputExpression id="inputExpr_1" typeRef="number">
          <text>instrumentCountPre</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Instrument Count Post">
        <inputExpression id="inputExpr_2" typeRef="number">
          <text>instrumentCountPost</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Sponge Count Pre">
        <inputExpression id="inputExpr_3" typeRef="number">
          <text>spongeCountPre</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Sponge Count Post">
        <inputExpression id="inputExpr_4" typeRef="number">
          <text>spongeCountPost</text>
        </inputExpression>
      </input>
      <input id="input_5" label="Needle Count Match">
        <inputExpression id="inputExpr_5" typeRef="boolean">
          <text>needleCountMatch</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>instrumentCountPre</text></inputEntry>
        <inputEntry id="ie_1_2"><text>instrumentCountPost</text></inputEntry>
        <inputEntry id="ie_1_3"><text>spongeCountPre</text></inputEntry>
        <inputEntry id="ie_1_4"><text>spongeCountPost</text></inputEntry>
        <inputEntry id="ie_1_5"><text>true</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"All counts correct - instruments, sponges, and needles match, proceed with closure"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>not(instrumentCountPre = instrumentCountPost)</text></inputEntry>
        <inputEntry id="ie_2_2"><text>-</text></inputEntry>
        <inputEntry id="ie_2_3"><text>-</text></inputEntry>
        <inputEntry id="ie_2_4"><text>-</text></inputEntry>
        <inputEntry id="ie_2_5"><text>-</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"CRITICAL: Instrument count incorrect - search surgical field, recount, X-ray if needed"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>-</text></inputEntry>
        <inputEntry id="ie_3_2"><text>-</text></inputEntry>
        <inputEntry id="ie_3_3"><text>not(spongeCountPre = spongeCountPost)</text></inputEntry>
        <inputEntry id="ie_3_4"><text>-</text></inputEntry>
        <inputEntry id="ie_3_5"><text>-</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"CRITICAL: Sponge count incorrect - search field thoroughly, obtain X-ray before closure"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>-</text></inputEntry>
        <inputEntry id="ie_4_2"><text>-</text></inputEntry>
        <inputEntry id="ie_4_3"><text>-</text></inputEntry>
        <inputEntry id="ie_4_4"><text>-</text></inputEntry>
        <inputEntry id="ie_4_5"><text>false</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"CRITICAL: Needle count incorrect - search drapes and field, account for all needles before closure"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>instrumentCountPre</text></inputEntry>
        <inputEntry id="ie_5_2"><text>instrumentCountPost</text></inputEntry>
        <inputEntry id="ie_5_3"><text>spongeCountPre</text></inputEntry>
        <inputEntry id="ie_5_4"><text>spongeCountPost</text></inputEntry>
        <inputEntry id="ie_5_5"><text>true</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"Final count verification complete - document correct counts in operative record"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
