<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_coord_004"
             name="Discharge Criteria Assessment"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_coord_004" name="Discharge Criteria Assessment">
    <decisionTable id="dt_surg_coord_004" hitPolicy="FIRST">
      <input id="input_1" label="Mobility Restored">
        <inputExpression id="inputExpr_1" typeRef="boolean">
          <text>mobilityRestored</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Pain Managed">
        <inputExpression id="inputExpr_2" typeRef="boolean">
          <text>painManaged</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Wound Clean">
        <inputExpression id="inputExpr_3" typeRef="boolean">
          <text>woundClean</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Instructions Given">
        <inputExpression id="inputExpr_4" typeRef="boolean">
          <text>instructionsGiven</text>
        </inputExpression>
      </input>
      <input id="input_5" label="Follow Up Scheduled">
        <inputExpression id="inputExpr_5" typeRef="boolean">
          <text>followUpScheduled</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>true</text></inputEntry>
        <inputEntry id="ie_1_2"><text>true</text></inputEntry>
        <inputEntry id="ie_1_3"><text>true</text></inputEntry>
        <inputEntry id="ie_1_4"><text>true</text></inputEntry>
        <inputEntry id="ie_1_5"><text>true</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"All discharge criteria met - patient ready for home discharge, prescriptions provided"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>false</text></inputEntry>
        <inputEntry id="ie_2_2"><text>-</text></inputEntry>
        <inputEntry id="ie_2_3"><text>-</text></inputEntry>
        <inputEntry id="ie_2_4"><text>-</text></inputEntry>
        <inputEntry id="ie_2_5"><text>-</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"Mobility not restored - PT assessment required, consider extended stay or rehab facility"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>-</text></inputEntry>
        <inputEntry id="ie_3_2"><text>false</text></inputEntry>
        <inputEntry id="ie_3_3"><text>-</text></inputEntry>
        <inputEntry id="ie_3_4"><text>-</text></inputEntry>
        <inputEntry id="ie_3_5"><text>-</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"Pain not controlled - optimize pain regimen, pain service consult, delay discharge"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>-</text></inputEntry>
        <inputEntry id="ie_4_2"><text>-</text></inputEntry>
        <inputEntry id="ie_4_3"><text>false</text></inputEntry>
        <inputEntry id="ie_4_4"><text>-</text></inputEntry>
        <inputEntry id="ie_4_5"><text>-</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"CRITICAL: Wound issues - surgical team evaluation, possible infection, delay discharge"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>true</text></inputEntry>
        <inputEntry id="ie_5_2"><text>true</text></inputEntry>
        <inputEntry id="ie_5_3"><text>true</text></inputEntry>
        <inputEntry id="ie_5_4"><text>-</text></inputEntry>
        <inputEntry id="ie_5_5"><text>false</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"No follow-up scheduled - schedule clinic appointment before discharge, cannot release without"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
