<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="definitions_surg_bill_002"
             name="Implant Tracking Rules"
             namespace="http://healthcare.platform/dmn/clinical_operations/surgical_services">
  <decision id="surg_bill_002" name="Implant Tracking Rules">
    <decisionTable id="dt_surg_bill_002" hitPolicy="FIRST">
      <input id="input_1" label="Implant Type">
        <inputExpression id="inputExpr_1" typeRef="string">
          <text>implantType</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Manufacturer">
        <inputExpression id="inputExpr_2" typeRef="string">
          <text>manufacturer</text>
        </inputExpression>
      </input>
      <input id="input_3" label="Lot Number">
        <inputExpression id="inputExpr_3" typeRef="boolean">
          <text>lotNumber</text>
        </inputExpression>
      </input>
      <input id="input_4" label="Expiration Valid">
        <inputExpression id="inputExpr_4" typeRef="boolean">
          <text>expirationValid</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie_1_1"><text>"orthopedic","cardiac","neurostimulator"</text></inputEntry>
        <inputEntry id="ie_1_2"><text>"approved_vendor"</text></inputEntry>
        <inputEntry id="ie_1_3"><text>true</text></inputEntry>
        <inputEntry id="ie_1_4"><text>true</text></inputEntry>
        <outputEntry id="oe_1_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao"><text>"Implant fully documented - lot number, expiration valid, proceed with implantation and billing"</text></outputEntry>
        <outputEntry id="oe_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie_2_1"><text>-</text></inputEntry>
        <inputEntry id="ie_2_2"><text>-</text></inputEntry>
        <inputEntry id="ie_2_3"><text>false</text></inputEntry>
        <inputEntry id="ie_2_4"><text>-</text></inputEntry>
        <outputEntry id="oe_2_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_2_acao"><text>"CRITICAL: Lot number not documented - obtain and document lot number before implantation"</text></outputEntry>
        <outputEntry id="oe_2_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie_3_1"><text>-</text></inputEntry>
        <inputEntry id="ie_3_2"><text>-</text></inputEntry>
        <inputEntry id="ie_3_3"><text>true</text></inputEntry>
        <inputEntry id="ie_3_4"><text>false</text></inputEntry>
        <outputEntry id="oe_3_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_3_acao"><text>"CRITICAL: Expired implant - do not implant, obtain replacement with valid expiration"</text></outputEntry>
        <outputEntry id="oe_3_risco"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie_4_1"><text>-</text></inputEntry>
        <inputEntry id="ie_4_2"><text>"non_approved_vendor"</text></inputEntry>
        <inputEntry id="ie_4_3"><text>true</text></inputEntry>
        <inputEntry id="ie_4_4"><text>true</text></inputEntry>
        <outputEntry id="oe_4_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_4_acao"><text>"Non-approved vendor - verify institutional approval and payer coverage before proceeding"</text></outputEntry>
        <outputEntry id="oe_4_risco"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie_5_1"><text>"mesh","suture"</text></inputEntry>
        <inputEntry id="ie_5_2"><text>"approved_vendor"</text></inputEntry>
        <inputEntry id="ie_5_3"><text>true</text></inputEntry>
        <inputEntry id="ie_5_4"><text>true</text></inputEntry>
        <outputEntry id="oe_5_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_5_acao"><text>"Standard implant documented - lot tracking complete, bill as surgical supply"</text></outputEntry>
        <outputEntry id="oe_5_risco"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
