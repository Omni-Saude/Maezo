<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  Surgical Safety Checklist - WHO Safe Surgery 3-Phase Validation
  ============================================================================
  Validates WHO Safe Surgery Checklist across three phases:
  SIGN_IN (before anesthesia), TIME_OUT (before incision), SIGN_OUT (before leaving OR).
  Hit Policy: COLLECT (gather all failed items per phase)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_surgical_safety_checklist"
             name="WHO Surgical Safety Checklist"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_surgical_safety_checklist" name="Surgical Safety Checklist Validation">
    <decisionTable id="DecisionTable_surgical_safety_checklist" hitPolicy="COLLECT">

      <!-- INPUT 1: Phase -->
      <input id="Input_sc_1" label="Checklist Phase">
        <inputExpression id="InputExpr_sc_1" typeRef="string">
          <text>phase</text>
        </inputExpression>
        <inputValues id="InputValues_sc_1">
          <text>"SIGN_IN", "TIME_OUT", "SIGN_OUT"</text>
        </inputValues>
      </input>

      <!-- INPUT 2: Patient Identity Confirmed -->
      <input id="Input_sc_2" label="Identity Confirmed">
        <inputExpression id="InputExpr_sc_2" typeRef="boolean">
          <text>identityConfirmed</text>
        </inputExpression>
      </input>

      <!-- INPUT 3: Site/Procedure Confirmed -->
      <input id="Input_sc_3" label="Site Procedure Confirmed">
        <inputExpression id="InputExpr_sc_3" typeRef="boolean">
          <text>siteProcedureConfirmed</text>
        </inputExpression>
      </input>

      <!-- INPUT 4: Consent Verified -->
      <input id="Input_sc_4" label="Consent Verified">
        <inputExpression id="InputExpr_sc_4" typeRef="boolean">
          <text>consentVerified</text>
        </inputExpression>
      </input>

      <!-- INPUT 5: Safety Equipment Check -->
      <input id="Input_sc_5" label="Equipment Check">
        <inputExpression id="InputExpr_sc_5" typeRef="boolean">
          <text>equipmentCheck</text>
        </inputExpression>
      </input>

      <!-- INPUT 6: Instrument Count Correct -->
      <input id="Input_sc_6" label="Instrument Count OK">
        <inputExpression id="InputExpr_sc_6" typeRef="boolean">
          <text>instrumentCountCorrect</text>
        </inputExpression>
      </input>

      <!-- OUTPUT 1: Phase Complete -->
      <output id="Output_sc_1" label="Phase Complete" name="phaseComplete" typeRef="boolean"/>

      <!-- OUTPUT 2: Failed Items -->
      <output id="Output_sc_2" label="Failed Items" name="failedItems" typeRef="string"/>

      <!-- OUTPUT 3: Safety Score (0-100) -->
      <output id="Output_sc_3" label="Safety Score" name="safetyScore" typeRef="number"/>

      <!-- OUTPUT 4: Can Proceed -->
      <output id="Output_sc_4" label="Can Proceed" name="canProceed" typeRef="boolean"/>

      <!-- ======== SIGN_IN PHASE (Before Anesthesia) ======== -->

      <!-- RULE 1: Sign-In - Identity not confirmed -->
      <rule id="Rule_sc_signin_no_identity">
        <description>SIGN_IN: Patient identity must be confirmed before anesthesia</description>
        <inputEntry id="IE_sc_1_1"><text>"SIGN_IN"</text></inputEntry>
        <inputEntry id="IE_sc_1_2"><text>false</text></inputEntry>
        <inputEntry id="IE_sc_1_3"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_1_4"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_1_5"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_1_6"><text>-</text></inputEntry>
        <outputEntry id="OE_sc_1_1"><text>false</text></outputEntry>
        <outputEntry id="OE_sc_1_2"><text>"Identidade do paciente nao confirmada (SIGN_IN)"</text></outputEntry>
        <outputEntry id="OE_sc_1_3"><text>0</text></outputEntry>
        <outputEntry id="OE_sc_1_4"><text>false</text></outputEntry>
      </rule>

      <!-- RULE 2: Sign-In - Consent not verified -->
      <rule id="Rule_sc_signin_no_consent">
        <description>SIGN_IN: Consent must be verified before anesthesia</description>
        <inputEntry id="IE_sc_2_1"><text>"SIGN_IN"</text></inputEntry>
        <inputEntry id="IE_sc_2_2"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_2_3"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_2_4"><text>false</text></inputEntry>
        <inputEntry id="IE_sc_2_5"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_2_6"><text>-</text></inputEntry>
        <outputEntry id="OE_sc_2_1"><text>false</text></outputEntry>
        <outputEntry id="OE_sc_2_2"><text>"Consentimento nao verificado (SIGN_IN)"</text></outputEntry>
        <outputEntry id="OE_sc_2_3"><text>0</text></outputEntry>
        <outputEntry id="OE_sc_2_4"><text>false</text></outputEntry>
      </rule>

      <!-- RULE 3: Sign-In - All checks passed -->
      <rule id="Rule_sc_signin_ok">
        <description>SIGN_IN: All sign-in checks passed</description>
        <inputEntry id="IE_sc_3_1"><text>"SIGN_IN"</text></inputEntry>
        <inputEntry id="IE_sc_3_2"><text>true</text></inputEntry>
        <inputEntry id="IE_sc_3_3"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_3_4"><text>true</text></inputEntry>
        <inputEntry id="IE_sc_3_5"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_3_6"><text>-</text></inputEntry>
        <outputEntry id="OE_sc_3_1"><text>true</text></outputEntry>
        <outputEntry id="OE_sc_3_2"><text>""</text></outputEntry>
        <outputEntry id="OE_sc_3_3"><text>100</text></outputEntry>
        <outputEntry id="OE_sc_3_4"><text>true</text></outputEntry>
      </rule>

      <!-- ======== TIME_OUT PHASE (Before Incision) ======== -->

      <!-- RULE 4: Time-Out - Site/procedure not confirmed -->
      <rule id="Rule_sc_timeout_no_site">
        <description>TIME_OUT: Surgical site and procedure must be confirmed by entire team</description>
        <inputEntry id="IE_sc_4_1"><text>"TIME_OUT"</text></inputEntry>
        <inputEntry id="IE_sc_4_2"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_4_3"><text>false</text></inputEntry>
        <inputEntry id="IE_sc_4_4"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_4_5"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_4_6"><text>-</text></inputEntry>
        <outputEntry id="OE_sc_4_1"><text>false</text></outputEntry>
        <outputEntry id="OE_sc_4_2"><text>"Sitio/procedimento nao confirmado pela equipe (TIME_OUT)"</text></outputEntry>
        <outputEntry id="OE_sc_4_3"><text>0</text></outputEntry>
        <outputEntry id="OE_sc_4_4"><text>false</text></outputEntry>
      </rule>

      <!-- RULE 5: Time-Out - Equipment check failed -->
      <rule id="Rule_sc_timeout_no_equipment">
        <description>TIME_OUT: Equipment and instruments must be verified</description>
        <inputEntry id="IE_sc_5_1"><text>"TIME_OUT"</text></inputEntry>
        <inputEntry id="IE_sc_5_2"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_5_3"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_5_4"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_5_5"><text>false</text></inputEntry>
        <inputEntry id="IE_sc_5_6"><text>-</text></inputEntry>
        <outputEntry id="OE_sc_5_1"><text>false</text></outputEntry>
        <outputEntry id="OE_sc_5_2"><text>"Verificacao de equipamentos falhou (TIME_OUT)"</text></outputEntry>
        <outputEntry id="OE_sc_5_3"><text>25</text></outputEntry>
        <outputEntry id="OE_sc_5_4"><text>false</text></outputEntry>
      </rule>

      <!-- RULE 6: Time-Out - All checks passed -->
      <rule id="Rule_sc_timeout_ok">
        <description>TIME_OUT: All time-out checks passed - safe to proceed</description>
        <inputEntry id="IE_sc_6_1"><text>"TIME_OUT"</text></inputEntry>
        <inputEntry id="IE_sc_6_2"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_6_3"><text>true</text></inputEntry>
        <inputEntry id="IE_sc_6_4"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_6_5"><text>true</text></inputEntry>
        <inputEntry id="IE_sc_6_6"><text>-</text></inputEntry>
        <outputEntry id="OE_sc_6_1"><text>true</text></outputEntry>
        <outputEntry id="OE_sc_6_2"><text>""</text></outputEntry>
        <outputEntry id="OE_sc_6_3"><text>100</text></outputEntry>
        <outputEntry id="OE_sc_6_4"><text>true</text></outputEntry>
      </rule>

      <!-- ======== SIGN_OUT PHASE (Before Leaving OR) ======== -->

      <!-- RULE 7: Sign-Out - Instrument count incorrect -->
      <rule id="Rule_sc_signout_no_count">
        <description>SIGN_OUT: Instrument and sponge count MUST be correct before closure</description>
        <inputEntry id="IE_sc_7_1"><text>"SIGN_OUT"</text></inputEntry>
        <inputEntry id="IE_sc_7_2"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_7_3"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_7_4"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_7_5"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_7_6"><text>false</text></inputEntry>
        <outputEntry id="OE_sc_7_1"><text>false</text></outputEntry>
        <outputEntry id="OE_sc_7_2"><text>"CRITICO: Contagem de instrumentais/compressas incorreta (SIGN_OUT)"</text></outputEntry>
        <outputEntry id="OE_sc_7_3"><text>0</text></outputEntry>
        <outputEntry id="OE_sc_7_4"><text>false</text></outputEntry>
      </rule>

      <!-- RULE 8: Sign-Out - All checks passed -->
      <rule id="Rule_sc_signout_ok">
        <description>SIGN_OUT: All sign-out checks passed - safe to transfer patient</description>
        <inputEntry id="IE_sc_8_1"><text>"SIGN_OUT"</text></inputEntry>
        <inputEntry id="IE_sc_8_2"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_8_3"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_8_4"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_8_5"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_8_6"><text>true</text></inputEntry>
        <outputEntry id="OE_sc_8_1"><text>true</text></outputEntry>
        <outputEntry id="OE_sc_8_2"><text>""</text></outputEntry>
        <outputEntry id="OE_sc_8_3"><text>100</text></outputEntry>
        <outputEntry id="OE_sc_8_4"><text>true</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_surgical_safety_checklist">
      <dmndi:DMNShape id="DMNShape_surgical_safety_checklist" dmnElementRef="Decision_surgical_safety_checklist">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
