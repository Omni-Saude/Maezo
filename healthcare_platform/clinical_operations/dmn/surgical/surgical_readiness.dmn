<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  Surgical Readiness Assessment - Pre-Operative Checklist Validation
  ============================================================================
  Validates all pre-operative requirements before allowing surgical procedure.
  Based on WHO Safe Surgery Saves Lives - Sign In phase.
  Hit Policy: COLLECT (gather all missing items)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_surgical_readiness"
             name="Surgical Readiness Assessment"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_surgical_readiness" name="Pre-Operative Readiness Evaluation">
    <decisionTable id="DecisionTable_surgical_readiness" hitPolicy="COLLECT">

      <!-- INPUT 1: Patient ID -->
      <input id="Input_sr_1" label="Patient ID">
        <inputExpression id="InputExpr_sr_1" typeRef="string">
          <text>patientId</text>
        </inputExpression>
      </input>

      <!-- INPUT 2: Informed Consent Signed -->
      <input id="Input_sr_2" label="Consent Signed">
        <inputExpression id="InputExpr_sr_2" typeRef="boolean">
          <text>consentSigned</text>
        </inputExpression>
      </input>

      <!-- INPUT 3: Surgical Site Marked -->
      <input id="Input_sr_3" label="Site Marked">
        <inputExpression id="InputExpr_sr_3" typeRef="boolean">
          <text>siteMarked</text>
        </inputExpression>
      </input>

      <!-- INPUT 4: Anesthesia Cleared -->
      <input id="Input_sr_4" label="Anesthesia Cleared">
        <inputExpression id="InputExpr_sr_4" typeRef="boolean">
          <text>anesthesiaCleared</text>
        </inputExpression>
      </input>

      <!-- INPUT 5: Allergies Reviewed -->
      <input id="Input_sr_5" label="Allergies Reviewed">
        <inputExpression id="InputExpr_sr_5" typeRef="boolean">
          <text>allergiesReviewed</text>
        </inputExpression>
      </input>

      <!-- INPUT 6: Fasting Confirmed -->
      <input id="Input_sr_6" label="Fasting Confirmed">
        <inputExpression id="InputExpr_sr_6" typeRef="boolean">
          <text>fastingConfirmed</text>
        </inputExpression>
      </input>

      <!-- OUTPUT 1: Readiness Status -->
      <output id="Output_sr_1" label="Readiness Status" name="readinessStatus" typeRef="string">
        <outputValues id="OutputValues_sr_1">
          <text>"READY", "NOT_READY", "NEEDS_REVIEW"</text>
        </outputValues>
      </output>

      <!-- OUTPUT 2: Missing Items -->
      <output id="Output_sr_2" label="Missing Items" name="missingItems" typeRef="string"/>

      <!-- OUTPUT 3: Can Proceed -->
      <output id="Output_sr_3" label="Can Proceed" name="canProceed" typeRef="boolean"/>

      <!-- RULE 1: Consent not signed -->
      <rule id="Rule_sr_no_consent">
        <description>Informed consent is mandatory - cannot proceed without</description>
        <inputEntry id="IE_sr_1_1"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_1_2"><text>false</text></inputEntry>
        <inputEntry id="IE_sr_1_3"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_1_4"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_1_5"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_1_6"><text>-</text></inputEntry>
        <outputEntry id="OE_sr_1_1"><text>"NOT_READY"</text></outputEntry>
        <outputEntry id="OE_sr_1_2"><text>"Consentimento informado nao assinado"</text></outputEntry>
        <outputEntry id="OE_sr_1_3"><text>false</text></outputEntry>
      </rule>

      <!-- RULE 2: Site not marked -->
      <rule id="Rule_sr_no_site_mark">
        <description>Surgical site marking is mandatory per WHO protocol</description>
        <inputEntry id="IE_sr_2_1"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_2_2"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_2_3"><text>false</text></inputEntry>
        <inputEntry id="IE_sr_2_4"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_2_5"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_2_6"><text>-</text></inputEntry>
        <outputEntry id="OE_sr_2_1"><text>"NOT_READY"</text></outputEntry>
        <outputEntry id="OE_sr_2_2"><text>"Sitio cirurgico nao demarcado"</text></outputEntry>
        <outputEntry id="OE_sr_2_3"><text>false</text></outputEntry>
      </rule>

      <!-- RULE 3: Anesthesia not cleared -->
      <rule id="Rule_sr_no_anesthesia">
        <description>Anesthesia clearance is required before procedure</description>
        <inputEntry id="IE_sr_3_1"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_3_2"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_3_3"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_3_4"><text>false</text></inputEntry>
        <inputEntry id="IE_sr_3_5"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_3_6"><text>-</text></inputEntry>
        <outputEntry id="OE_sr_3_1"><text>"NOT_READY"</text></outputEntry>
        <outputEntry id="OE_sr_3_2"><text>"Avaliacao anestesica nao liberada"</text></outputEntry>
        <outputEntry id="OE_sr_3_3"><text>false</text></outputEntry>
      </rule>

      <!-- RULE 4: Allergies not reviewed -->
      <rule id="Rule_sr_no_allergies">
        <description>Allergy review is mandatory for patient safety</description>
        <inputEntry id="IE_sr_4_1"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_4_2"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_4_3"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_4_4"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_4_5"><text>false</text></inputEntry>
        <inputEntry id="IE_sr_4_6"><text>-</text></inputEntry>
        <outputEntry id="OE_sr_4_1"><text>"NEEDS_REVIEW"</text></outputEntry>
        <outputEntry id="OE_sr_4_2"><text>"Revisao de alergias pendente"</text></outputEntry>
        <outputEntry id="OE_sr_4_3"><text>false</text></outputEntry>
      </rule>

      <!-- RULE 5: Fasting not confirmed -->
      <rule id="Rule_sr_no_fasting">
        <description>Fasting confirmation required for anesthesia safety</description>
        <inputEntry id="IE_sr_5_1"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_5_2"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_5_3"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_5_4"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_5_5"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_5_6"><text>false</text></inputEntry>
        <outputEntry id="OE_sr_5_1"><text>"NOT_READY"</text></outputEntry>
        <outputEntry id="OE_sr_5_2"><text>"Jejum nao confirmado"</text></outputEntry>
        <outputEntry id="OE_sr_5_3"><text>false</text></outputEntry>
      </rule>

      <!-- RULE 6: All checks passed -->
      <rule id="Rule_sr_all_ready">
        <description>All pre-operative checks passed - patient ready for surgery</description>
        <inputEntry id="IE_sr_6_1"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_6_2"><text>true</text></inputEntry>
        <inputEntry id="IE_sr_6_3"><text>true</text></inputEntry>
        <inputEntry id="IE_sr_6_4"><text>true</text></inputEntry>
        <inputEntry id="IE_sr_6_5"><text>true</text></inputEntry>
        <inputEntry id="IE_sr_6_6"><text>true</text></inputEntry>
        <outputEntry id="OE_sr_6_1"><text>"READY"</text></outputEntry>
        <outputEntry id="OE_sr_6_2"><text>"Todos os itens verificados"</text></outputEntry>
        <outputEntry id="OE_sr_6_3"><text>true</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_surgical_readiness">
      <dmndi:DMNShape id="DMNShape_surgical_readiness" dmnElementRef="Decision_surgical_readiness">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
