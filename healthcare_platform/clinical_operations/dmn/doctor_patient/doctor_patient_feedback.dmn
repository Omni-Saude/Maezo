<?xml version='1.0' encoding='UTF-8'?>
<!--
  ============================================================================
  DOCTOR-PATIENT-FEEDBACK - Processamento de Feedback do Paciente
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_DoctorPatientFeedback"
             name="Processamento de Feedback do Paciente"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">

  <decision id="Decision_DoctorPatientFeedback" name="Decisao Patient Feedback">
    <decisionTable id="DecisionTable_DoctorPatientFeedback" hitPolicy="FIRST">

      <input id="Input_feedbackScore" label="Score do Feedback (0-10)">
        <inputExpression id="InputExpr_feedbackScore" typeRef="number">
          <text>feedbackScore</text>
        </inputExpression>
      </input>

      <input id="Input_feedbackCategory" label="Categoria do Feedback">
        <inputExpression id="InputExpr_feedbackCategory" typeRef="string">
          <text>feedbackCategory</text>
        </inputExpression>
        <inputValues><text>"ATENDIMENTO","COMUNICACAO","INSTALACOES","MEDICACAO","OUTROS"</text></inputValues>
      </input>

      <input id="Input_responseTime" label="Tempo para Resposta (horas)">
        <inputExpression id="InputExpr_responseTime" typeRef="number">
          <text>responseTime</text>
        </inputExpression>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_PatFeed_1">
        <description>Bloqueio: Feedback crítico sem resposta</description>
        <inputEntry id="InputEntry_PatFeed_1_1"><text>&lt;= 3</text></inputEntry>
        <inputEntry id="InputEntry_PatFeed_1_2"><text>"ATENDIMENTO","MEDICACAO"</text></inputEntry>
        <inputEntry id="InputEntry_PatFeed_1_3"><text>&gt; 24</text></inputEntry>
        <outputEntry id="OutputEntry_PatFeed_1_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_PatFeed_1_acao"><text>"URGENTE: Feedback crítico sem resposta em 24h. Acionar gerência imediatamente."</text></outputEntry>
        <outputEntry id="OutputEntry_PatFeed_1_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_PatFeed_2">
        <description>Alerta: Score baixo</description>
        <inputEntry id="InputEntry_PatFeed_2_1"><text>&lt;= 5</text></inputEntry>
        <inputEntry id="InputEntry_PatFeed_2_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PatFeed_2_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_PatFeed_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_PatFeed_2_acao"><text>"Feedback negativo. Contatar paciente em até 12h para entender queixa."</text></outputEntry>
        <outputEntry id="OutputEntry_PatFeed_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_PatFeed_3">
        <description>Alerta: Resposta atrasada</description>
        <inputEntry id="InputEntry_PatFeed_3_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PatFeed_3_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PatFeed_3_3"><text>&gt; 48</text></inputEntry>
        <outputEntry id="OutputEntry_PatFeed_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_PatFeed_3_acao"><text>"Resposta atrasada. Priorizar contato com paciente."</text></outputEntry>
        <outputEntry id="OutputEntry_PatFeed_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_PatFeed_4">
        <description>Aprovado: Feedback positivo</description>
        <inputEntry id="InputEntry_PatFeed_4_1"><text>&gt;= 8</text></inputEntry>
        <inputEntry id="InputEntry_PatFeed_4_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PatFeed_4_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_PatFeed_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_PatFeed_4_acao"><text>"Feedback positivo. Agradecer paciente e documentar."</text></outputEntry>
        <outputEntry id="OutputEntry_PatFeed_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_PatFeed_Fallback">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_PatFeed_F_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PatFeed_F_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PatFeed_F_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_PatFeed_F_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_PatFeed_F_acao"><text>"Registrar feedback e avaliar necessidade de resposta."</text></outputEntry>
        <outputEntry id="OutputEntry_PatFeed_F_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorPatientFeedback">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorPatientFeedback" dmnElementRef="Decision_DoctorPatientFeedback">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
