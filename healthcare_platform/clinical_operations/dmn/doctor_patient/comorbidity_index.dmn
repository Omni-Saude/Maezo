<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_ComorbidityIndex"
             name="Comorbidity Index Calculation"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">
  <decision id="Decision_ComorbidityIndex" name="Comorbidity Index Calculation">
    <decisionTable id="DecisionTable_ComorbidityIndex" hitPolicy="FIRST">
      <input id="Input_comorbidity_1" label="Charlson Comorbidity Index">
        <inputExpression id="InputExpr_comorbidity_1" typeRef="number"><text>charlsonIndex</text></inputExpression>
      </input>
      <input id="Input_comorbidity_2" label="Active Comorbidities">
        <inputExpression id="InputExpr_comorbidity_2" typeRef="number"><text>activeComorbidities</text></inputExpression>
      </input>
      <output id="Output_comorbidity_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_comorbidity_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_comorbidity_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>
      <rule id="Rule_comorbidity_1">
        <inputEntry id="IE_comorbidity_1_1"><text>&gt; 5</text></inputEntry>
        <inputEntry id="IE_comorbidity_1_2"><text>&gt; 4</text></inputEntry>
        <outputEntry id="OE_comorbidity_1_r"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_comorbidity_1_a"><text>"Alto índice de comorbidade - cuidado multidisciplinar obrigatório"</text></outputEntry>
        <outputEntry id="OE_comorbidity_1_ri"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_comorbidity_2">
        <inputEntry id="IE_comorbidity_2_1"><text>[3..5]</text></inputEntry>
        <inputEntry id="IE_comorbidity_2_2"><text>[2..4]</text></inputEntry>
        <outputEntry id="OE_comorbidity_2_r"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_comorbidity_2_a"><text>"Comorbidades moderadas - ajustar plano terapêutico"</text></outputEntry>
        <outputEntry id="OE_comorbidity_2_ri"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_comorbidity_3">
        <inputEntry id="IE_comorbidity_3_1"><text></text></inputEntry>
        <inputEntry id="IE_comorbidity_3_2"><text></text></inputEntry>
        <outputEntry id="OE_comorbidity_3_r"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_comorbidity_3_a"><text>"Baixo índice de comorbidade - protocolo padrão"</text></outputEntry>
        <outputEntry id="OE_comorbidity_3_ri"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
