<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_DischargeReadinessScore"
             name="Discharge Readiness Score"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">
  <decision id="Decision_DischargeReadinessScore" name="Discharge Readiness Score">
    <decisionTable id="DecisionTable_DischargeReadinessScore" hitPolicy="FIRST">
      <input id="Input_readiness_1" label="Readiness Score (%)">
        <inputExpression id="InputExpr_readiness_1" typeRef="number"><text>readinessScore</text></inputExpression>
      </input>
      <input id="Input_readiness_2" label="Pending Tasks">
        <inputExpression id="InputExpr_readiness_2" typeRef="number"><text>pendingTasks</text></inputExpression>
      </input>
      <input id="Input_readiness_3" label="Follow-up Scheduled">
        <inputExpression id="InputExpr_readiness_3" typeRef="boolean"><text>followupScheduled</text></inputExpression>
      </input>
      <output id="Output_readiness_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_readiness_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_readiness_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>
      <rule id="Rule_readiness_1">
        <inputEntry id="IE_readiness_1_1"><text>&lt; 70</text></inputEntry>
        <inputEntry id="IE_readiness_1_2"><text>&gt; 3</text></inputEntry>
        <inputEntry id="IE_readiness_1_3"><text>false</text></inputEntry>
        <outputEntry id="OE_readiness_1_r"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_readiness_1_a"><text>"Prontidão insuficiente - completar pendências antes da alta"</text></outputEntry>
        <outputEntry id="OE_readiness_1_ri"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_readiness_2">
        <inputEntry id="IE_readiness_2_1"><text>[70..90]</text></inputEntry>
        <inputEntry id="IE_readiness_2_2"><text>[1..3]</text></inputEntry>
        <inputEntry id="IE_readiness_2_3"><text></text></inputEntry>
        <outputEntry id="OE_readiness_2_r"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_readiness_2_a"><text>"Prontidão parcial - finalizar tarefas e agendar acompanhamento"</text></outputEntry>
        <outputEntry id="OE_readiness_2_ri"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_readiness_3">
        <inputEntry id="IE_readiness_3_1"><text>&gt; 90</text></inputEntry>
        <inputEntry id="IE_readiness_3_2"><text>0</text></inputEntry>
        <inputEntry id="IE_readiness_3_3"><text>true</text></inputEntry>
        <outputEntry id="OE_readiness_3_r"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_readiness_3_a"><text>"Paciente pronto para alta - processar documentação"</text></outputEntry>
        <outputEntry id="OE_readiness_3_ri"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
