<?xml version='1.0' encoding='UTF-8'?>
<!--
  ============================================================================
  DOCTOR-DISCHARGE-READINESS - Avaliacao de Prontidao para Alta
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_DoctorDischargeReadiness"
             name="Avaliacao de Prontidao para Alta"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">

  <decision id="Decision_DoctorDischargeReadiness" name="Decisao Prontidao Alta">
    <decisionTable id="DecisionTable_DoctorDischargeReadiness" hitPolicy="FIRST">

      <input id="Input_clinicalScore" label="Score Clinico">
        <inputExpression id="InputExpr_clinicalScore" typeRef="number">
          <text>clinicalScore</text>
        </inputExpression>
      </input>

      <input id="Input_pendingOrders" label="Pedidos Pendentes">
        <inputExpression id="InputExpr_pendingOrders" typeRef="number">
          <text>pendingOrders</text>
        </inputExpression>
      </input>

      <input id="Input_daysAdmitted" label="Dias Internado">
        <inputExpression id="InputExpr_daysAdmitted" typeRef="number">
          <text>daysAdmitted</text>
        </inputExpression>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_DischReady_1">
        <description>Bloqueio: Score baixo com pedidos pendentes</description>
        <inputEntry id="InputEntry_DischReady_1_1"><text>&lt; 70</text></inputEntry>
        <inputEntry id="InputEntry_DischReady_1_2"><text>&gt; 3</text></inputEntry>
        <inputEntry id="InputEntry_DischReady_1_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DischReady_1_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_DischReady_1_acao"><text>"Paciente não está pronto para alta. Aguardar melhora clínica e conclusão de pedidos."</text></outputEntry>
        <outputEntry id="OutputEntry_DischReady_1_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_DischReady_2">
        <description>Alerta: Internação prolongada</description>
        <inputEntry id="InputEntry_DischReady_2_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DischReady_2_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DischReady_2_3"><text>&gt; 14</text></inputEntry>
        <outputEntry id="OutputEntry_DischReady_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_DischReady_2_acao"><text>"Revisar plano de alta. Internação prolongada (&gt;14 dias). Avaliar barreiras."</text></outputEntry>
        <outputEntry id="OutputEntry_DischReady_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_DischReady_3">
        <description>Alerta: Pedidos pendentes</description>
        <inputEntry id="InputEntry_DischReady_3_1"><text>&gt;= 70</text></inputEntry>
        <inputEntry id="InputEntry_DischReady_3_2"><text>&gt; 0</text></inputEntry>
        <inputEntry id="InputEntry_DischReady_3_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DischReady_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_DischReady_3_acao"><text>"Condição clínica adequada. Aguardar conclusão de pedidos pendentes."</text></outputEntry>
        <outputEntry id="OutputEntry_DischReady_3_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_DischReady_4">
        <description>Aprovado: Pronto para alta</description>
        <inputEntry id="InputEntry_DischReady_4_1"><text>&gt;= 80</text></inputEntry>
        <inputEntry id="InputEntry_DischReady_4_2"><text>= 0</text></inputEntry>
        <inputEntry id="InputEntry_DischReady_4_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DischReady_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_DischReady_4_acao"><text>"Paciente pronto para alta. Iniciar processo de alta hospitalar."</text></outputEntry>
        <outputEntry id="OutputEntry_DischReady_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_DischReady_Fallback">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_DischReady_F_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DischReady_F_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DischReady_F_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DischReady_F_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_DischReady_F_acao"><text>"Avaliar prontidão para alta manualmente."</text></outputEntry>
        <outputEntry id="OutputEntry_DischReady_F_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorDischargeReadiness">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorDischargeReadiness" dmnElementRef="Decision_DoctorDischargeReadiness">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
