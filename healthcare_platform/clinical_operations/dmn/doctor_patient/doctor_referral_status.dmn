<?xml version='1.0' encoding='UTF-8'?>
<!--
  ============================================================================
  DOCTOR-REFERRAL-STATUS - Status de Encaminhamento para Especialista
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_DoctorReferralStatus"
             name="Status de Encaminhamento para Especialista"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">

  <decision id="Decision_DoctorReferralStatus" name="Decisao Referral Status">
    <decisionTable id="DecisionTable_DoctorReferralStatus" hitPolicy="FIRST">

      <input id="Input_referralAge" label="Idade do Encaminhamento (dias)">
        <inputExpression id="InputExpr_referralAge" typeRef="number">
          <text>referralAge</text>
        </inputExpression>
      </input>

      <input id="Input_urgencyLevel" label="Nivel de Urgencia">
        <inputExpression id="InputExpr_urgencyLevel" typeRef="string">
          <text>urgencyLevel</text>
        </inputExpression>
        <inputValues><text>"EMERGENCIA","URGENTE","PROGRAMADO","ELETIVO"</text></inputValues>
      </input>

      <input id="Input_specialtyAvailability" label="Disponibilidade Especialista (dias)">
        <inputExpression id="InputExpr_specialtyAvailability" typeRef="number">
          <text>specialtyAvailability</text>
        </inputExpression>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_Referral_1">
        <description>Bloqueio: Emergência sem atendimento</description>
        <inputEntry id="InputEntry_Referral_1_1"><text>&gt; 1</text></inputEntry>
        <inputEntry id="InputEntry_Referral_1_2"><text>"EMERGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_Referral_1_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_Referral_1_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Referral_1_acao"><text>"EMERGÊNCIA: Encaminhamento urgente sem resposta. Acionar plantão de especialidade."</text></outputEntry>
        <outputEntry id="OutputEntry_Referral_1_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Referral_2">
        <description>Alerta: Urgente com espera longa</description>
        <inputEntry id="InputEntry_Referral_2_1"><text>&gt; 7</text></inputEntry>
        <inputEntry id="InputEntry_Referral_2_2"><text>"URGENTE"</text></inputEntry>
        <inputEntry id="InputEntry_Referral_2_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_Referral_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Referral_2_acao"><text>"Encaminhamento urgente com espera &gt;7 dias. Contatar especialista ou buscar alternativa."</text></outputEntry>
        <outputEntry id="OutputEntry_Referral_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Referral_3">
        <description>Alerta: Disponibilidade limitada</description>
        <inputEntry id="InputEntry_Referral_3_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Referral_3_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Referral_3_3"><text>&gt; 30</text></inputEntry>
        <outputEntry id="OutputEntry_Referral_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Referral_3_acao"><text>"Disponibilidade de especialista limitada (&gt;30 dias). Avaliar alternativas."</text></outputEntry>
        <outputEntry id="OutputEntry_Referral_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Referral_4">
        <description>Aprovado: Encaminhamento em andamento</description>
        <inputEntry id="InputEntry_Referral_4_1"><text>&lt;= 7</text></inputEntry>
        <inputEntry id="InputEntry_Referral_4_2"><text>"PROGRAMADO","ELETIVO"</text></inputEntry>
        <inputEntry id="InputEntry_Referral_4_3"><text>&lt;= 30</text></inputEntry>
        <outputEntry id="OutputEntry_Referral_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_Referral_4_acao"><text>"Encaminhamento em andamento. Aguardar agendamento."</text></outputEntry>
        <outputEntry id="OutputEntry_Referral_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Referral_Fallback">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_Referral_F_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Referral_F_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Referral_F_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_Referral_F_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Referral_F_acao"><text>"Verificar status do encaminhamento."</text></outputEntry>
        <outputEntry id="OutputEntry_Referral_F_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorReferralStatus">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorReferralStatus" dmnElementRef="Decision_DoctorReferralStatus">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
