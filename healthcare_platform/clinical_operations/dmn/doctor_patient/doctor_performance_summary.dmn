<?xml version='1.0' encoding='UTF-8'?>
<!--
  ============================================================================
  DOCTOR-PERFORMANCE-SUMMARY - Resumo de Performance do Medico
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_DoctorPerformanceSummary"
             name="Resumo de Performance do Medico"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">

  <decision id="Decision_DoctorPerformanceSummary" name="Decisao Performance Summary">
    <decisionTable id="DecisionTable_DoctorPerformanceSummary" hitPolicy="FIRST">

      <input id="Input_patientVolume" label="Volume de Pacientes">
        <inputExpression id="InputExpr_patientVolume" typeRef="number">
          <text>patientVolume</text>
        </inputExpression>
      </input>

      <input id="Input_outcomeScore" label="Score de Desfecho (0-100)">
        <inputExpression id="InputExpr_outcomeScore" typeRef="number">
          <text>outcomeScore</text>
        </inputExpression>
      </input>

      <input id="Input_complianceRate" label="Taxa de Conformidade (%)">
        <inputExpression id="InputExpr_complianceRate" typeRef="number">
          <text>complianceRate</text>
        </inputExpression>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_PerfSumm_1">
        <description>Bloqueio: Performance crítica</description>
        <inputEntry id="InputEntry_PerfSumm_1_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PerfSumm_1_2"><text>&lt; 60</text></inputEntry>
        <inputEntry id="InputEntry_PerfSumm_1_3"><text>&lt; 70</text></inputEntry>
        <outputEntry id="OutputEntry_PerfSumm_1_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_PerfSumm_1_acao"><text>"CRÍTICO: Performance abaixo do aceitável. Acionar coordenação médica para plano de melhoria."</text></outputEntry>
        <outputEntry id="OutputEntry_PerfSumm_1_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_PerfSumm_2">
        <description>Alerta: Volume excessivo com queda de qualidade</description>
        <inputEntry id="InputEntry_PerfSumm_2_1"><text>&gt; 50</text></inputEntry>
        <inputEntry id="InputEntry_PerfSumm_2_2"><text>&lt; 75</text></inputEntry>
        <inputEntry id="InputEntry_PerfSumm_2_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_PerfSumm_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_PerfSumm_2_acao"><text>"Volume alto com queda de qualidade. Avaliar redistribuição de carga."</text></outputEntry>
        <outputEntry id="OutputEntry_PerfSumm_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_PerfSumm_3">
        <description>Alerta: Conformidade baixa</description>
        <inputEntry id="InputEntry_PerfSumm_3_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PerfSumm_3_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PerfSumm_3_3"><text>&lt; 80</text></inputEntry>
        <outputEntry id="OutputEntry_PerfSumm_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_PerfSumm_3_acao"><text>"Taxa de conformidade abaixo da meta. Revisar protocolos e oferecer treinamento."</text></outputEntry>
        <outputEntry id="OutputEntry_PerfSumm_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_PerfSumm_4">
        <description>Aprovado: Performance excelente</description>
        <inputEntry id="InputEntry_PerfSumm_4_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PerfSumm_4_2"><text>&gt;= 85</text></inputEntry>
        <inputEntry id="InputEntry_PerfSumm_4_3"><text>&gt;= 90</text></inputEntry>
        <outputEntry id="OutputEntry_PerfSumm_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_PerfSumm_4_acao"><text>"Performance excelente. Reconhecer boas práticas."</text></outputEntry>
        <outputEntry id="OutputEntry_PerfSumm_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_PerfSumm_Fallback">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_PerfSumm_F_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PerfSumm_F_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PerfSumm_F_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_PerfSumm_F_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_PerfSumm_F_acao"><text>"Performance adequada. Manter monitoramento."</text></outputEntry>
        <outputEntry id="OutputEntry_PerfSumm_F_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorPerformanceSummary">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorPerformanceSummary" dmnElementRef="Decision_DoctorPerformanceSummary">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
