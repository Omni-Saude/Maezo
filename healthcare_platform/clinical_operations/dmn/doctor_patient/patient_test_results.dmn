<?xml version='1.0' encoding='UTF-8'?>
<!--
  ============================================================================
  PATIENT-TEST-RESULTS - Notificacao de Resultados de Exames ao Paciente
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: PACIENTE (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_PatientTestResults"
             name="Notificacao de Resultados de Exames ao Paciente"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">

  <decision id="Decision_PatientTestResults" name="Decisao Test Results">
    <decisionTable id="DecisionTable_PatientTestResults" hitPolicy="FIRST">

      <input id="Input_testUrgency" label="Urgencia do Exame">
        <inputExpression id="InputExpr_testUrgency" typeRef="string">
          <text>testUrgency</text>
        </inputExpression>
        <inputValues><text>"STAT","URGENTE","ROTINA"</text></inputValues>
      </input>

      <input id="Input_abnormalFlags" label="Numero de Resultados Alterados">
        <inputExpression id="InputExpr_abnormalFlags" typeRef="number">
          <text>abnormalFlags</text>
        </inputExpression>
      </input>

      <input id="Input_resultAge" label="Idade do Resultado (horas)">
        <inputExpression id="InputExpr_resultAge" typeRef="number">
          <text>resultAge</text>
        </inputExpression>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_TestRes_1">
        <description>Bloqueio: Resultado crítico STAT não notificado</description>
        <inputEntry id="InputEntry_TestRes_1_1"><text>"STAT"</text></inputEntry>
        <inputEntry id="InputEntry_TestRes_1_2"><text>&gt; 0</text></inputEntry>
        <inputEntry id="InputEntry_TestRes_1_3"><text>&gt; 2</text></inputEntry>
        <outputEntry id="OutputEntry_TestRes_1_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_TestRes_1_acao"><text>"CRÍTICO: Resultado STAT alterado sem notificação há &gt;2h. Contatar paciente e médico urgentemente."</text></outputEntry>
        <outputEntry id="OutputEntry_TestRes_1_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_TestRes_2">
        <description>Alerta: Múltiplos resultados alterados</description>
        <inputEntry id="InputEntry_TestRes_2_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_TestRes_2_2"><text>&gt; 3</text></inputEntry>
        <inputEntry id="InputEntry_TestRes_2_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_TestRes_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_TestRes_2_acao"><text>"Múltiplos resultados alterados. Médico deve revisar antes de notificar paciente."</text></outputEntry>
        <outputEntry id="OutputEntry_TestRes_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_TestRes_3">
        <description>Alerta: Resultado urgente atrasado</description>
        <inputEntry id="InputEntry_TestRes_3_1"><text>"URGENTE"</text></inputEntry>
        <inputEntry id="InputEntry_TestRes_3_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_TestRes_3_3"><text>&gt; 24</text></inputEntry>
        <outputEntry id="OutputEntry_TestRes_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_TestRes_3_acao"><text>"Resultado urgente não notificado há &gt;24h. Priorizar contato com paciente."</text></outputEntry>
        <outputEntry id="OutputEntry_TestRes_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_TestRes_4">
        <description>Aprovado: Resultado de rotina normal</description>
        <inputEntry id="InputEntry_TestRes_4_1"><text>"ROTINA"</text></inputEntry>
        <inputEntry id="InputEntry_TestRes_4_2"><text>= 0</text></inputEntry>
        <inputEntry id="InputEntry_TestRes_4_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_TestRes_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_TestRes_4_acao"><text>"Notificar paciente sobre resultados normais via portal ou mensagem."</text></outputEntry>
        <outputEntry id="OutputEntry_TestRes_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_TestRes_Fallback">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_TestRes_F_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_TestRes_F_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_TestRes_F_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_TestRes_F_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_TestRes_F_acao"><text>"Avaliar forma de notificação ao paciente."</text></outputEntry>
        <outputEntry id="OutputEntry_TestRes_F_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PatientTestResults">
      <dmndi:DMNShape id="DMNShape_Decision_PatientTestResults" dmnElementRef="Decision_PatientTestResults">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
