<?xml version='1.0' encoding='UTF-8'?>
<!--
  ============================================================================
  DOCTOR-BED-AVAILABILITY - Notificacao de Disponibilidade de Leito
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_DoctorBedAvailability"
             name="Notificacao de Disponibilidade de Leito"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">

  <decision id="Decision_DoctorBedAvailability" name="Decisao Disponibilidade Leito">
    <decisionTable id="DecisionTable_DoctorBedAvailability" hitPolicy="FIRST">

      <input id="Input_bedType" label="Tipo de Leito">
        <inputExpression id="InputExpr_bedType" typeRef="string">
          <text>bedType</text>
        </inputExpression>
        <inputValues><text>"UTI","SEMI_UTI","ENFERMARIA","ISOLAMENTO"</text></inputValues>
      </input>

      <input id="Input_unitOccupancy" label="Ocupacao da Unidade (%)">
        <inputExpression id="InputExpr_unitOccupancy" typeRef="number">
          <text>unitOccupancy</text>
        </inputExpression>
      </input>

      <input id="Input_waitHours" label="Horas de Espera">
        <inputExpression id="InputExpr_waitHours" typeRef="number">
          <text>waitHours</text>
        </inputExpression>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_BedAvail_1">
        <description>Bloqueio: UTI lotada com espera crítica</description>
        <inputEntry id="InputEntry_BedAvail_1_1"><text>"UTI"</text></inputEntry>
        <inputEntry id="InputEntry_BedAvail_1_2"><text>&gt;= 95</text></inputEntry>
        <inputEntry id="InputEntry_BedAvail_1_3"><text>&gt; 6</text></inputEntry>
        <outputEntry id="OutputEntry_BedAvail_1_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_BedAvail_1_acao"><text>"Acionar coordenação médica urgente. UTI em capacidade crítica."</text></outputEntry>
        <outputEntry id="OutputEntry_BedAvail_1_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_BedAvail_2">
        <description>Alerta: Isolamento com ocupação elevada</description>
        <inputEntry id="InputEntry_BedAvail_2_1"><text>"ISOLAMENTO"</text></inputEntry>
        <inputEntry id="InputEntry_BedAvail_2_2"><text>&gt;= 80</text></inputEntry>
        <inputEntry id="InputEntry_BedAvail_2_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_BedAvail_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_BedAvail_2_acao"><text>"Revisar protocolos de isolamento. Considerar leitos alternativos."</text></outputEntry>
        <outputEntry id="OutputEntry_BedAvail_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_BedAvail_3">
        <description>Alerta: Espera prolongada em qualquer unidade</description>
        <inputEntry id="InputEntry_BedAvail_3_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_BedAvail_3_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_BedAvail_3_3"><text>&gt; 12</text></inputEntry>
        <outputEntry id="OutputEntry_BedAvail_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_BedAvail_3_acao"><text>"Notificar médico assistente. Avaliar transferência para outra unidade."</text></outputEntry>
        <outputEntry id="OutputEntry_BedAvail_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_BedAvail_4">
        <description>Aprovado: Disponibilidade normal</description>
        <inputEntry id="InputEntry_BedAvail_4_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_BedAvail_4_2"><text>&lt; 80</text></inputEntry>
        <inputEntry id="InputEntry_BedAvail_4_3"><text>&lt;= 6</text></inputEntry>
        <outputEntry id="OutputEntry_BedAvail_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_BedAvail_4_acao"><text>"Notificar médico sobre disponibilidade de leito."</text></outputEntry>
        <outputEntry id="OutputEntry_BedAvail_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_BedAvail_Fallback">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_BedAvail_F_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_BedAvail_F_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_BedAvail_F_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_BedAvail_F_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_BedAvail_F_acao"><text>"Avaliar disponibilidade manualmente."</text></outputEntry>
        <outputEntry id="OutputEntry_BedAvail_F_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorBedAvailability">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorBedAvailability" dmnElementRef="Decision_DoctorBedAvailability">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
