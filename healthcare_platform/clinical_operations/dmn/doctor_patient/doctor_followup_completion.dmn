<?xml version='1.0' encoding='UTF-8'?>
<!--
  ============================================================================
  DOCTOR-FOLLOWUP-COMPLETION - Conclusao de Acompanhamento Pos-Alta
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_DoctorFollowupCompletion"
             name="Conclusao de Acompanhamento Pos-Alta"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">

  <decision id="Decision_DoctorFollowupCompletion" name="Decisao Followup Completion">
    <decisionTable id="DecisionTable_DoctorFollowupCompletion" hitPolicy="FIRST">

      <input id="Input_daysSinceDischarge" label="Dias Desde Alta">
        <inputExpression id="InputExpr_daysSinceDischarge" typeRef="number">
          <text>daysSinceDischarge</text>
        </inputExpression>
      </input>

      <input id="Input_followupType" label="Tipo de Acompanhamento">
        <inputExpression id="InputExpr_followupType" typeRef="string">
          <text>followupType</text>
        </inputExpression>
        <inputValues><text>"CIRURGIA","INTERNACAO","URGENCIA","ROTINA"</text></inputValues>
      </input>

      <input id="Input_riskLevel" label="Nivel de Risco">
        <inputExpression id="InputExpr_riskLevel" typeRef="string">
          <text>riskLevel</text>
        </inputExpression>
        <inputValues><text>"ALTO","MEDIO","BAIXO"</text></inputValues>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_FollowComp_1">
        <description>Bloqueio: Cirurgia de alto risco sem followup</description>
        <inputEntry id="InputEntry_FollowComp_1_1"><text>&gt; 14</text></inputEntry>
        <inputEntry id="InputEntry_FollowComp_1_2"><text>"CIRURGIA"</text></inputEntry>
        <inputEntry id="InputEntry_FollowComp_1_3"><text>"ALTO"</text></inputEntry>
        <outputEntry id="OutputEntry_FollowComp_1_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_FollowComp_1_acao"><text>"CRÍTICO: Cirurgia de alto risco sem followup há &gt;14 dias. Contatar paciente urgentemente."</text></outputEntry>
        <outputEntry id="OutputEntry_FollowComp_1_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_FollowComp_2">
        <description>Alerta: Followup atrasado</description>
        <inputEntry id="InputEntry_FollowComp_2_1"><text>&gt; 30</text></inputEntry>
        <inputEntry id="InputEntry_FollowComp_2_2"><text>"INTERNACAO","URGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_FollowComp_2_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_FollowComp_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_FollowComp_2_acao"><text>"Followup atrasado. Tentar contato com paciente. Avaliar necessidade de visita."</text></outputEntry>
        <outputEntry id="OutputEntry_FollowComp_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_FollowComp_3">
        <description>Alerta: Aproximando prazo ideal</description>
        <inputEntry id="InputEntry_FollowComp_3_1"><text>&gt; 7, &lt;= 14</text></inputEntry>
        <inputEntry id="InputEntry_FollowComp_3_2"><text>"CIRURGIA"</text></inputEntry>
        <inputEntry id="InputEntry_FollowComp_3_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_FollowComp_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_FollowComp_3_acao"><text>"Agendar followup pós-cirúrgico. Prazo ideal em 7-14 dias."</text></outputEntry>
        <outputEntry id="OutputEntry_FollowComp_3_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_FollowComp_4">
        <description>Aprovado: Followup no prazo</description>
        <inputEntry id="InputEntry_FollowComp_4_1"><text>&lt;= 7</text></inputEntry>
        <inputEntry id="InputEntry_FollowComp_4_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_FollowComp_4_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_FollowComp_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_FollowComp_4_acao"><text>"Followup realizado no prazo. Documentar evolução."</text></outputEntry>
        <outputEntry id="OutputEntry_FollowComp_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_FollowComp_Fallback">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_FollowComp_F_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_FollowComp_F_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_FollowComp_F_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_FollowComp_F_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_FollowComp_F_acao"><text>"Avaliar necessidade de followup manualmente."</text></outputEntry>
        <outputEntry id="OutputEntry_FollowComp_F_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorFollowupCompletion">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorFollowupCompletion" dmnElementRef="Decision_DoctorFollowupCompletion">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
