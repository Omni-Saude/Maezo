<?xml version='1.0' encoding='UTF-8'?>
<!--
  ============================================================================
  PATIENT-RECOVERY-CHECKIN - Checkin de Recuperacao do Paciente
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: PACIENTE (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_PatientRecoveryCheckin"
             name="Checkin de Recuperacao do Paciente"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">

  <decision id="Decision_PatientRecoveryCheckin" name="Decisao Recovery Checkin">
    <decisionTable id="DecisionTable_PatientRecoveryCheckin" hitPolicy="FIRST">

      <input id="Input_painScore" label="Score de Dor (0-10)">
        <inputExpression id="InputExpr_painScore" typeRef="number">
          <text>painScore</text>
        </inputExpression>
      </input>

      <input id="Input_mobilityScore" label="Score de Mobilidade (0-100)">
        <inputExpression id="InputExpr_mobilityScore" typeRef="number">
          <text>mobilityScore</text>
        </inputExpression>
      </input>

      <input id="Input_daysSinceSurgery" label="Dias Desde Cirurgia">
        <inputExpression id="InputExpr_daysSinceSurgery" typeRef="number">
          <text>daysSinceSurgery</text>
        </inputExpression>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_RecovCheck_1">
        <description>Bloqueio: Dor severa pós-operatória</description>
        <inputEntry id="InputEntry_RecovCheck_1_1"><text>&gt; 7</text></inputEntry>
        <inputEntry id="InputEntry_RecovCheck_1_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RecovCheck_1_3"><text>&lt; 7</text></inputEntry>
        <outputEntry id="OutputEntry_RecovCheck_1_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_RecovCheck_1_acao"><text>"URGENTE: Dor severa pós-operatória. Contatar equipe médica para ajuste de analgesia."</text></outputEntry>
        <outputEntry id="OutputEntry_RecovCheck_1_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_RecovCheck_2">
        <description>Alerta: Mobilidade reduzida</description>
        <inputEntry id="InputEntry_RecovCheck_2_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RecovCheck_2_2"><text>&lt; 40</text></inputEntry>
        <inputEntry id="InputEntry_RecovCheck_2_3"><text>&gt; 5</text></inputEntry>
        <outputEntry id="OutputEntry_RecovCheck_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_RecovCheck_2_acao"><text>"Mobilidade abaixo do esperado. Avaliar necessidade de fisioterapia intensificada."</text></outputEntry>
        <outputEntry id="OutputEntry_RecovCheck_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_RecovCheck_3">
        <description>Alerta: Dor moderada persistente</description>
        <inputEntry id="InputEntry_RecovCheck_3_1"><text>&gt; 4</text></inputEntry>
        <inputEntry id="InputEntry_RecovCheck_3_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RecovCheck_3_3"><text>&gt; 3</text></inputEntry>
        <outputEntry id="OutputEntry_RecovCheck_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_RecovCheck_3_acao"><text>"Dor moderada persistente. Verificar adesão a analgésicos e considerar ajuste."</text></outputEntry>
        <outputEntry id="OutputEntry_RecovCheck_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_RecovCheck_4">
        <description>Aprovado: Recuperação adequada</description>
        <inputEntry id="InputEntry_RecovCheck_4_1"><text>&lt;= 3</text></inputEntry>
        <inputEntry id="InputEntry_RecovCheck_4_2"><text>&gt;= 60</text></inputEntry>
        <inputEntry id="InputEntry_RecovCheck_4_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RecovCheck_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_RecovCheck_4_acao"><text>"Recuperação dentro do esperado. Encorajar paciente a continuar."</text></outputEntry>
        <outputEntry id="OutputEntry_RecovCheck_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_RecovCheck_Fallback">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_RecovCheck_F_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RecovCheck_F_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RecovCheck_F_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RecovCheck_F_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_RecovCheck_F_acao"><text>"Monitorar evolução da recuperação."</text></outputEntry>
        <outputEntry id="OutputEntry_RecovCheck_F_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PatientRecoveryCheckin">
      <dmndi:DMNShape id="DMNShape_Decision_PatientRecoveryCheckin" dmnElementRef="Decision_PatientRecoveryCheckin">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
