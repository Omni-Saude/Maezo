<?xml version='1.0' encoding='UTF-8'?>
<!--
  ============================================================================
  DOCTOR-READMISSION-RISK - Avaliacao de Risco de Readmissao
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_DoctorReadmissionRisk"
             name="Avaliacao de Risco de Readmissao"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">

  <decision id="Decision_DoctorReadmissionRisk" name="Decisao Readmission Risk">
    <decisionTable id="DecisionTable_DoctorReadmissionRisk" hitPolicy="FIRST">

      <input id="Input_riskScore" label="Score de Risco (0-100)">
        <inputExpression id="InputExpr_riskScore" typeRef="number">
          <text>riskScore</text>
        </inputExpression>
      </input>

      <input id="Input_daysPostDischarge" label="Dias Pos-Alta">
        <inputExpression id="InputExpr_daysPostDischarge" typeRef="number">
          <text>daysPostDischarge</text>
        </inputExpression>
      </input>

      <input id="Input_diagnosisCategory" label="Categoria Diagnostica">
        <inputExpression id="InputExpr_diagnosisCategory" typeRef="string">
          <text>diagnosisCategory</text>
        </inputExpression>
        <inputValues><text>"CARDIO","RESPIRATORIO","NEURO","GASTRO","OUTROS"</text></inputValues>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_Readm_1">
        <description>Bloqueio: Alto risco em período crítico</description>
        <inputEntry id="InputEntry_Readm_1_1"><text>&gt; 75</text></inputEntry>
        <inputEntry id="InputEntry_Readm_1_2"><text>&lt; 30</text></inputEntry>
        <inputEntry id="InputEntry_Readm_1_3"><text>"CARDIO","RESPIRATORIO"</text></inputEntry>
        <outputEntry id="OutputEntry_Readm_1_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Readm_1_acao"><text>"CRÍTICO: Alto risco de readmissão em 30 dias. Intensificar acompanhamento ambulatorial."</text></outputEntry>
        <outputEntry id="OutputEntry_Readm_1_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Readm_2">
        <description>Alerta: Risco moderado</description>
        <inputEntry id="InputEntry_Readm_2_1"><text>&gt; 50</text></inputEntry>
        <inputEntry id="InputEntry_Readm_2_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Readm_2_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_Readm_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Readm_2_acao"><text>"Risco moderado de readmissão. Agendar consulta de followup e orientação."</text></outputEntry>
        <outputEntry id="OutputEntry_Readm_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Readm_3">
        <description>Alerta: Janela crítica pós-alta</description>
        <inputEntry id="InputEntry_Readm_3_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Readm_3_2"><text>&lt; 7</text></inputEntry>
        <inputEntry id="InputEntry_Readm_3_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_Readm_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Readm_3_acao"><text>"Período crítico pós-alta. Contactar paciente para verificar evolução."</text></outputEntry>
        <outputEntry id="OutputEntry_Readm_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Readm_4">
        <description>Aprovado: Baixo risco</description>
        <inputEntry id="InputEntry_Readm_4_1"><text>&lt;= 40</text></inputEntry>
        <inputEntry id="InputEntry_Readm_4_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Readm_4_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_Readm_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_Readm_4_acao"><text>"Baixo risco de readmissão. Acompanhamento de rotina."</text></outputEntry>
        <outputEntry id="OutputEntry_Readm_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Readm_Fallback">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_Readm_F_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Readm_F_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Readm_F_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_Readm_F_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Readm_F_acao"><text>"Avaliar risco de readmissão manualmente."</text></outputEntry>
        <outputEntry id="OutputEntry_Readm_F_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorReadmissionRisk">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorReadmissionRisk" dmnElementRef="Decision_DoctorReadmissionRisk">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
