<?xml version='1.0' encoding='UTF-8'?>
<!--
  ============================================================================
  PATIENT-MEDICATION-REMINDER - Lembrete de Medicacao ao Paciente
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: PACIENTE (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_PatientMedicationReminder"
             name="Lembrete de Medicacao ao Paciente"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">

  <decision id="Decision_PatientMedicationReminder" name="Decisao Medication Reminder">
    <decisionTable id="DecisionTable_PatientMedicationReminder" hitPolicy="FIRST">

      <input id="Input_medicationPriority" label="Prioridade da Medicacao">
        <inputExpression id="InputExpr_medicationPriority" typeRef="string">
          <text>medicationPriority</text>
        </inputExpression>
        <inputValues><text>"CRITICA","ALTA","MEDIA","BAIXA"</text></inputValues>
      </input>

      <input id="Input_hoursUntilDose" label="Horas ate Proxima Dose">
        <inputExpression id="InputExpr_hoursUntilDose" typeRef="number">
          <text>hoursUntilDose</text>
        </inputExpression>
      </input>

      <input id="Input_interactionRisk" label="Risco de Interacao">
        <inputExpression id="InputExpr_interactionRisk" typeRef="string">
          <text>interactionRisk</text>
        </inputExpression>
        <inputValues><text>"ALTO","MEDIO","BAIXO"</text></inputValues>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_MedRem_1">
        <description>Bloqueio: Medicação crítica atrasada</description>
        <inputEntry id="InputEntry_MedRem_1_1"><text>"CRITICA"</text></inputEntry>
        <inputEntry id="InputEntry_MedRem_1_2"><text>&lt; 0</text></inputEntry>
        <inputEntry id="InputEntry_MedRem_1_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_MedRem_1_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MedRem_1_acao"><text>"URGENTE: Medicação crítica atrasada. Notificar paciente e equipe médica imediatamente."</text></outputEntry>
        <outputEntry id="OutputEntry_MedRem_1_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_MedRem_2">
        <description>Alerta: Alto risco de interação</description>
        <inputEntry id="InputEntry_MedRem_2_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MedRem_2_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MedRem_2_3"><text>"ALTO"</text></inputEntry>
        <outputEntry id="OutputEntry_MedRem_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MedRem_2_acao"><text>"Lembrete com aviso sobre interações. Orientar intervalo adequado entre medicações."</text></outputEntry>
        <outputEntry id="OutputEntry_MedRem_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_MedRem_3">
        <description>Alerta: Medicação de alta prioridade próxima</description>
        <inputEntry id="InputEntry_MedRem_3_1"><text>"ALTA"</text></inputEntry>
        <inputEntry id="InputEntry_MedRem_3_2"><text>&lt; 2</text></inputEntry>
        <inputEntry id="InputEntry_MedRem_3_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_MedRem_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MedRem_3_acao"><text>"Lembrete urgente. Medicação de alta prioridade em menos de 2 horas."</text></outputEntry>
        <outputEntry id="OutputEntry_MedRem_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_MedRem_4">
        <description>Aprovado: Lembrete de rotina</description>
        <inputEntry id="InputEntry_MedRem_4_1"><text>"MEDIA","BAIXA"</text></inputEntry>
        <inputEntry id="InputEntry_MedRem_4_2"><text>&gt;= 1</text></inputEntry>
        <inputEntry id="InputEntry_MedRem_4_3"><text>"BAIXO"</text></inputEntry>
        <outputEntry id="OutputEntry_MedRem_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_MedRem_4_acao"><text>"Enviar lembrete de medicação conforme horário programado."</text></outputEntry>
        <outputEntry id="OutputEntry_MedRem_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_MedRem_Fallback">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_MedRem_F_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MedRem_F_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MedRem_F_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_MedRem_F_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MedRem_F_acao"><text>"Avaliar necessidade de lembrete."</text></outputEntry>
        <outputEntry id="OutputEntry_MedRem_F_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PatientMedicationReminder">
      <dmndi:DMNShape id="DMNShape_Decision_PatientMedicationReminder" dmnElementRef="Decision_PatientMedicationReminder">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
