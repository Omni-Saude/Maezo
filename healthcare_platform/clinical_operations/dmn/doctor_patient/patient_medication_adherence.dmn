<?xml version='1.0' encoding='UTF-8'?>
<!--
  ============================================================================
  PATIENT-MEDICATION-ADHERENCE - Aderencia a Medicacao do Paciente
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: PACIENTE (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_PatientMedicationAdherence"
             name="Aderencia a Medicacao do Paciente"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">

  <decision id="Decision_PatientMedicationAdherence" name="Decisao Medication Adherence">
    <decisionTable id="DecisionTable_PatientMedicationAdherence" hitPolicy="FIRST">

      <input id="Input_adherenceScore" label="Score de Aderencia (%)">
        <inputExpression id="InputExpr_adherenceScore" typeRef="number">
          <text>adherenceScore</text>
        </inputExpression>
      </input>

      <input id="Input_missedDoses" label="Doses Perdidas (ultimos 7 dias)">
        <inputExpression id="InputExpr_missedDoses" typeRef="number">
          <text>missedDoses</text>
        </inputExpression>
      </input>

      <input id="Input_medicationCount" label="Numero de Medicacoes">
        <inputExpression id="InputExpr_medicationCount" typeRef="number">
          <text>medicationCount</text>
        </inputExpression>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_MedAdher_1">
        <description>Bloqueio: Baixa aderência crítica</description>
        <inputEntry id="InputEntry_MedAdher_1_1"><text>&lt; 50</text></inputEntry>
        <inputEntry id="InputEntry_MedAdher_1_2"><text>&gt; 5</text></inputEntry>
        <inputEntry id="InputEntry_MedAdher_1_3"><text>&gt; 5</text></inputEntry>
        <outputEntry id="OutputEntry_MedAdher_1_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MedAdher_1_acao"><text>"CRÍTICO: Baixa aderência com múltiplas medicações. Contatar paciente e revisar esquema terapêutico."</text></outputEntry>
        <outputEntry id="OutputEntry_MedAdher_1_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_MedAdher_2">
        <description>Alerta: Aderência moderada</description>
        <inputEntry id="InputEntry_MedAdher_2_1"><text>&lt; 70</text></inputEntry>
        <inputEntry id="InputEntry_MedAdher_2_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MedAdher_2_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_MedAdher_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MedAdher_2_acao"><text>"Aderência abaixo do ideal. Oferecer suporte educacional e estratégias de adesão."</text></outputEntry>
        <outputEntry id="OutputEntry_MedAdher_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_MedAdher_3">
        <description>Alerta: Polifarmácia</description>
        <inputEntry id="InputEntry_MedAdher_3_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MedAdher_3_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MedAdher_3_3"><text>&gt; 8</text></inputEntry>
        <outputEntry id="OutputEntry_MedAdher_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MedAdher_3_acao"><text>"Polifarmácia identificada. Avaliar simplificação de esquema para melhorar aderência."</text></outputEntry>
        <outputEntry id="OutputEntry_MedAdher_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_MedAdher_4">
        <description>Aprovado: Boa aderência</description>
        <inputEntry id="InputEntry_MedAdher_4_1"><text>&gt;= 80</text></inputEntry>
        <inputEntry id="InputEntry_MedAdher_4_2"><text>&lt;= 2</text></inputEntry>
        <inputEntry id="InputEntry_MedAdher_4_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_MedAdher_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_MedAdher_4_acao"><text>"Boa aderência medicamentosa. Reforçar positivamente comportamento."</text></outputEntry>
        <outputEntry id="OutputEntry_MedAdher_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_MedAdher_Fallback">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_MedAdher_F_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MedAdher_F_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MedAdher_F_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_MedAdher_F_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MedAdher_F_acao"><text>"Monitorar aderência medicamentosa."</text></outputEntry>
        <outputEntry id="OutputEntry_MedAdher_F_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PatientMedicationAdherence">
      <dmndi:DMNShape id="DMNShape_Decision_PatientMedicationAdherence" dmnElementRef="Decision_PatientMedicationAdherence">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
