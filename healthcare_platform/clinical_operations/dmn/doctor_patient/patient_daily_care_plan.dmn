<?xml version='1.0' encoding='UTF-8'?>
<!--
  ============================================================================
  PATIENT-DAILY-CARE-PLAN - Plano de Cuidados Diario do Paciente
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: PACIENTE (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_PatientDailyCarePlan"
             name="Plano de Cuidados Diario do Paciente"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">

  <decision id="Decision_PatientDailyCarePlan" name="Decisao Daily Care Plan">
    <decisionTable id="DecisionTable_PatientDailyCarePlan" hitPolicy="FIRST">

      <input id="Input_planComplexity" label="Complexidade do Plano">
        <inputExpression id="InputExpr_planComplexity" typeRef="string">
          <text>planComplexity</text>
        </inputExpression>
        <inputValues><text>"ALTA","MEDIA","BAIXA"</text></inputValues>
      </input>

      <input id="Input_activeMedications" label="Medicacoes Ativas">
        <inputExpression id="InputExpr_activeMedications" typeRef="number">
          <text>activeMedications</text>
        </inputExpression>
      </input>

      <input id="Input_pendingTests" label="Exames Pendentes">
        <inputExpression id="InputExpr_pendingTests" typeRef="number">
          <text>pendingTests</text>
        </inputExpression>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_DailyCare_1">
        <description>Bloqueio: Plano complexo com muitos pendentes</description>
        <inputEntry id="InputEntry_DailyCare_1_1"><text>"ALTA"</text></inputEntry>
        <inputEntry id="InputEntry_DailyCare_1_2"><text>&gt; 10</text></inputEntry>
        <inputEntry id="InputEntry_DailyCare_1_3"><text>&gt; 5</text></inputEntry>
        <outputEntry id="OutputEntry_DailyCare_1_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_DailyCare_1_acao"><text>"Plano de cuidados complexo. Revisar com equipe multiprofissional antes de compartilhar."</text></outputEntry>
        <outputEntry id="OutputEntry_DailyCare_1_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_DailyCare_2">
        <description>Alerta: Muitas medicações</description>
        <inputEntry id="InputEntry_DailyCare_2_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DailyCare_2_2"><text>&gt; 8</text></inputEntry>
        <inputEntry id="InputEntry_DailyCare_2_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DailyCare_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_DailyCare_2_acao"><text>"Polifarmácia detectada. Revisar interações e simplificar plano se possível."</text></outputEntry>
        <outputEntry id="OutputEntry_DailyCare_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_DailyCare_3">
        <description>Alerta: Muitos exames pendentes</description>
        <inputEntry id="InputEntry_DailyCare_3_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DailyCare_3_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DailyCare_3_3"><text>&gt; 4</text></inputEntry>
        <outputEntry id="OutputEntry_DailyCare_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_DailyCare_3_acao"><text>"Muitos exames pendentes. Priorizar e agendar conforme urgência."</text></outputEntry>
        <outputEntry id="OutputEntry_DailyCare_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_DailyCare_4">
        <description>Aprovado: Plano simples</description>
        <inputEntry id="InputEntry_DailyCare_4_1"><text>"BAIXA","MEDIA"</text></inputEntry>
        <inputEntry id="InputEntry_DailyCare_4_2"><text>&lt;= 5</text></inputEntry>
        <inputEntry id="InputEntry_DailyCare_4_3"><text>&lt;= 2</text></inputEntry>
        <outputEntry id="OutputEntry_DailyCare_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_DailyCare_4_acao"><text>"Compartilhar plano de cuidados diário com paciente."</text></outputEntry>
        <outputEntry id="OutputEntry_DailyCare_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_DailyCare_Fallback">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_DailyCare_F_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DailyCare_F_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DailyCare_F_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DailyCare_F_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_DailyCare_F_acao"><text>"Avaliar plano de cuidados antes de compartilhar."</text></outputEntry>
        <outputEntry id="OutputEntry_DailyCare_F_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PatientDailyCarePlan">
      <dmndi:DMNShape id="DMNShape_Decision_PatientDailyCarePlan" dmnElementRef="Decision_PatientDailyCarePlan">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
