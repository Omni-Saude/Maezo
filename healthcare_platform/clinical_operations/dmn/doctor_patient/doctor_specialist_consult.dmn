<?xml version='1.0' encoding='UTF-8'?>
<!--
  ============================================================================
  DOCTOR-SPECIALIST-CONSULT - Solicitacao de Parecer de Especialista
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_DoctorSpecialistConsult"
             name="Solicitacao de Parecer de Especialista"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">

  <decision id="Decision_DoctorSpecialistConsult" name="Decisao Specialist Consult">
    <decisionTable id="DecisionTable_DoctorSpecialistConsult" hitPolicy="FIRST">

      <input id="Input_consultUrgency" label="Urgencia do Parecer">
        <inputExpression id="InputExpr_consultUrgency" typeRef="string">
          <text>consultUrgency</text>
        </inputExpression>
        <inputValues><text>"EMERGENCIA","URGENTE","PROGRAMADO"</text></inputValues>
      </input>

      <input id="Input_specialtyType" label="Tipo de Especialidade">
        <inputExpression id="InputExpr_specialtyType" typeRef="string">
          <text>specialtyType</text>
        </inputExpression>
        <inputValues><text>"CARDIO","NEURO","ONCO","CIRURGIA","OUTROS"</text></inputValues>
      </input>

      <input id="Input_waitDays" label="Dias de Espera">
        <inputExpression id="InputExpr_waitDays" typeRef="number">
          <text>waitDays</text>
        </inputExpression>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_SpecConsult_1">
        <description>Bloqueio: Emergência sem resposta</description>
        <inputEntry id="InputEntry_SpecConsult_1_1"><text>"EMERGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_SpecConsult_1_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_SpecConsult_1_3"><text>&gt; 0.5</text></inputEntry>
        <outputEntry id="OutputEntry_SpecConsult_1_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_SpecConsult_1_acao"><text>"EMERGÊNCIA: Parecer urgente sem resposta. Acionar especialista de plantão imediatamente."</text></outputEntry>
        <outputEntry id="OutputEntry_SpecConsult_1_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_SpecConsult_2">
        <description>Alerta: Urgente com espera prolongada</description>
        <inputEntry id="InputEntry_SpecConsult_2_1"><text>"URGENTE"</text></inputEntry>
        <inputEntry id="InputEntry_SpecConsult_2_2"><text>"CARDIO","NEURO","ONCO"</text></inputEntry>
        <inputEntry id="InputEntry_SpecConsult_2_3"><text>&gt; 2</text></inputEntry>
        <outputEntry id="OutputEntry_SpecConsult_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_SpecConsult_2_acao"><text>"Parecer urgente aguardando &gt;2 dias. Acionar coordenação médica."</text></outputEntry>
        <outputEntry id="OutputEntry_SpecConsult_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_SpecConsult_3">
        <description>Alerta: Programado atrasado</description>
        <inputEntry id="InputEntry_SpecConsult_3_1"><text>"PROGRAMADO"</text></inputEntry>
        <inputEntry id="InputEntry_SpecConsult_3_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_SpecConsult_3_3"><text>&gt; 7</text></inputEntry>
        <outputEntry id="OutputEntry_SpecConsult_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_SpecConsult_3_acao"><text>"Parecer programado atrasado. Verificar disponibilidade de especialista."</text></outputEntry>
        <outputEntry id="OutputEntry_SpecConsult_3_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_SpecConsult_4">
        <description>Aprovado: Solicitação no prazo</description>
        <inputEntry id="InputEntry_SpecConsult_4_1"><text>"PROGRAMADO","URGENTE"</text></inputEntry>
        <inputEntry id="InputEntry_SpecConsult_4_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_SpecConsult_4_3"><text>&lt;= 2</text></inputEntry>
        <outputEntry id="OutputEntry_SpecConsult_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_SpecConsult_4_acao"><text>"Solicitação de parecer em andamento. Aguardar resposta do especialista."</text></outputEntry>
        <outputEntry id="OutputEntry_SpecConsult_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_SpecConsult_Fallback">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_SpecConsult_F_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_SpecConsult_F_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_SpecConsult_F_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_SpecConsult_F_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_SpecConsult_F_acao"><text>"Verificar status da solicitação de parecer."</text></outputEntry>
        <outputEntry id="OutputEntry_SpecConsult_F_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorSpecialistConsult">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorSpecialistConsult" dmnElementRef="Decision_DoctorSpecialistConsult">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
