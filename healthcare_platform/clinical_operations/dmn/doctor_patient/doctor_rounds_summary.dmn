<?xml version='1.0' encoding='UTF-8'?>
<!--
  ============================================================================
  DOCTOR-ROUNDS-SUMMARY - Resumo de Visitas Medicas
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_DoctorRoundsSummary"
             name="Resumo de Visitas Medicas"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">

  <decision id="Decision_DoctorRoundsSummary" name="Decisao Rounds Summary">
    <decisionTable id="DecisionTable_DoctorRoundsSummary" hitPolicy="FIRST">

      <input id="Input_patientCount" label="Total de Pacientes">
        <inputExpression id="InputExpr_patientCount" typeRef="number">
          <text>patientCount</text>
        </inputExpression>
      </input>

      <input id="Input_criticalPatients" label="Pacientes Criticos">
        <inputExpression id="InputExpr_criticalPatients" typeRef="number">
          <text>criticalPatients</text>
        </inputExpression>
      </input>

      <input id="Input_pendingDecisions" label="Decisoes Pendentes">
        <inputExpression id="InputExpr_pendingDecisions" typeRef="number">
          <text>pendingDecisions</text>
        </inputExpression>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_Rounds_1">
        <description>Bloqueio: Muitos críticos com decisões pendentes</description>
        <inputEntry id="InputEntry_Rounds_1_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Rounds_1_2"><text>&gt; 5</text></inputEntry>
        <inputEntry id="InputEntry_Rounds_1_3"><text>&gt; 10</text></inputEntry>
        <outputEntry id="OutputEntry_Rounds_1_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Rounds_1_acao"><text>"CRÍTICO: Múltiplos pacientes críticos com decisões pendentes. Priorizar rounds urgentes."</text></outputEntry>
        <outputEntry id="OutputEntry_Rounds_1_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Rounds_2">
        <description>Alerta: Volume alto de pacientes</description>
        <inputEntry id="InputEntry_Rounds_2_1"><text>&gt; 30</text></inputEntry>
        <inputEntry id="InputEntry_Rounds_2_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Rounds_2_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_Rounds_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Rounds_2_acao"><text>"Volume alto de pacientes. Considerar redistribuição ou suporte adicional."</text></outputEntry>
        <outputEntry id="OutputEntry_Rounds_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Rounds_3">
        <description>Alerta: Decisões pendentes acumuladas</description>
        <inputEntry id="InputEntry_Rounds_3_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Rounds_3_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Rounds_3_3"><text>&gt; 15</text></inputEntry>
        <outputEntry id="OutputEntry_Rounds_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Rounds_3_acao"><text>"Muitas decisões pendentes. Revisar casos e priorizar ações."</text></outputEntry>
        <outputEntry id="OutputEntry_Rounds_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Rounds_4">
        <description>Aprovado: Rounds em dia</description>
        <inputEntry id="InputEntry_Rounds_4_1"><text>&lt;= 20</text></inputEntry>
        <inputEntry id="InputEntry_Rounds_4_2"><text>&lt;= 3</text></inputEntry>
        <inputEntry id="InputEntry_Rounds_4_3"><text>&lt;= 5</text></inputEntry>
        <outputEntry id="OutputEntry_Rounds_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_Rounds_4_acao"><text>"Rounds em dia. Volume gerenciável de pacientes e decisões."</text></outputEntry>
        <outputEntry id="OutputEntry_Rounds_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Rounds_Fallback">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_Rounds_F_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Rounds_F_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Rounds_F_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_Rounds_F_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Rounds_F_acao"><text>"Avaliar status de rounds manualmente."</text></outputEntry>
        <outputEntry id="OutputEntry_Rounds_F_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorRoundsSummary">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorRoundsSummary" dmnElementRef="Decision_DoctorRoundsSummary">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
