<?xml version='1.0' encoding='UTF-8'?>
<!--
  ============================================================================
  DOCTOR-CME-REMINDER - Lembrete de Educacao Medica Continuada
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_DoctorCMEReminder"
             name="Lembrete de Educacao Medica Continuada"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">

  <decision id="Decision_DoctorCMEReminder" name="Decisao CME Reminder">
    <decisionTable id="DecisionTable_DoctorCMEReminder" hitPolicy="FIRST">

      <input id="Input_daysSinceLastCME" label="Dias Desde Ultimo CME">
        <inputExpression id="InputExpr_daysSinceLastCME" typeRef="number">
          <text>daysSinceLastCME</text>
        </inputExpression>
      </input>

      <input id="Input_credentialExpiry" label="Dias para Vencimento Credencial">
        <inputExpression id="InputExpr_credentialExpiry" typeRef="number">
          <text>credentialExpiry</text>
        </inputExpression>
      </input>

      <input id="Input_specialtyReq" label="Requisito Especialidade Atendido">
        <inputExpression id="InputExpr_specialtyReq" typeRef="boolean">
          <text>specialtyReq</text>
        </inputExpression>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_CME_1">
        <description>Bloqueio: Credencial vencendo sem requisitos</description>
        <inputEntry id="InputEntry_CME_1_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CME_1_2"><text>&lt; 30</text></inputEntry>
        <inputEntry id="InputEntry_CME_1_3"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_CME_1_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CME_1_acao"><text>"URGENTE: Credencial vence em menos de 30 dias. Completar CME obrigatório."</text></outputEntry>
        <outputEntry id="OutputEntry_CME_1_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_CME_2">
        <description>Alerta: CME atrasado</description>
        <inputEntry id="InputEntry_CME_2_1"><text>&gt; 365</text></inputEntry>
        <inputEntry id="InputEntry_CME_2_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CME_2_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_CME_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CME_2_acao"><text>"Lembrete: Último CME há mais de 1 ano. Agendar treinamento."</text></outputEntry>
        <outputEntry id="OutputEntry_CME_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_CME_3">
        <description>Alerta: Credencial próxima do vencimento</description>
        <inputEntry id="InputEntry_CME_3_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CME_3_2"><text>&lt; 60</text></inputEntry>
        <inputEntry id="InputEntry_CME_3_3"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_CME_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CME_3_acao"><text>"Lembrete: Credencial vence em menos de 60 dias. Iniciar renovação."</text></outputEntry>
        <outputEntry id="OutputEntry_CME_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_CME_4">
        <description>Aprovado: CME em dia</description>
        <inputEntry id="InputEntry_CME_4_1"><text>&lt;= 365</text></inputEntry>
        <inputEntry id="InputEntry_CME_4_2"><text>&gt;= 60</text></inputEntry>
        <inputEntry id="InputEntry_CME_4_3"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_CME_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_CME_4_acao"><text>"CME e credenciais em dia. Nenhuma ação necessária."</text></outputEntry>
        <outputEntry id="OutputEntry_CME_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_CME_Fallback">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_CME_F_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CME_F_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CME_F_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_CME_F_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CME_F_acao"><text>"Verificar status de CME manualmente."</text></outputEntry>
        <outputEntry id="OutputEntry_CME_F_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorCMEReminder">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorCMEReminder" dmnElementRef="Decision_DoctorCMEReminder">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
