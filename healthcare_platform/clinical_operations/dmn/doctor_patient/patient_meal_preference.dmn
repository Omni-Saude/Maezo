<?xml version='1.0' encoding='UTF-8'?>
<!--
  ============================================================================
  PATIENT-MEAL-PREFERENCE - Preferencia Alimentar do Paciente
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: PACIENTE (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_PatientMealPreference"
             name="Preferencia Alimentar do Paciente"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">

  <decision id="Decision_PatientMealPreference" name="Decisao Meal Preference">
    <decisionTable id="DecisionTable_PatientMealPreference" hitPolicy="FIRST">

      <input id="Input_dietaryRestrictions" label="Restricoes Dieteticas">
        <inputExpression id="InputExpr_dietaryRestrictions" typeRef="string">
          <text>dietaryRestrictions</text>
        </inputExpression>
        <inputValues><text>"DIABETICO","HIPOSODICO","RENAL","HEPATICO","NENHUMA"</text></inputValues>
      </input>

      <input id="Input_allergyCount" label="Numero de Alergias">
        <inputExpression id="InputExpr_allergyCount" typeRef="number">
          <text>allergyCount</text>
        </inputExpression>
      </input>

      <input id="Input_mealType" label="Tipo de Refeicao">
        <inputExpression id="InputExpr_mealType" typeRef="string">
          <text>mealType</text>
        </inputExpression>
        <inputValues><text>"ORAL","ENTERAL","PARENTERAL","MISTA"</text></inputValues>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_MealPref_1">
        <description>Bloqueio: Múltiplas alergias sem revisão nutricional</description>
        <inputEntry id="InputEntry_MealPref_1_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MealPref_1_2"><text>&gt; 3</text></inputEntry>
        <inputEntry id="InputEntry_MealPref_1_3"><text>"ORAL","MISTA"</text></inputEntry>
        <outputEntry id="OutputEntry_MealPref_1_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MealPref_1_acao"><text>"CRÍTICO: Paciente com múltiplas alergias. Avaliar com nutricionista antes de liberar dieta."</text></outputEntry>
        <outputEntry id="OutputEntry_MealPref_1_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_MealPref_2">
        <description>Alerta: Dieta restritiva complexa</description>
        <inputEntry id="InputEntry_MealPref_2_1"><text>"RENAL","HEPATICO"</text></inputEntry>
        <inputEntry id="InputEntry_MealPref_2_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MealPref_2_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_MealPref_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MealPref_2_acao"><text>"Dieta complexa. Confirmar restrições com equipe de nutrição."</text></outputEntry>
        <outputEntry id="OutputEntry_MealPref_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_MealPref_3">
        <description>Alerta: Nutrição enteral/parenteral</description>
        <inputEntry id="InputEntry_MealPref_3_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MealPref_3_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MealPref_3_3"><text>"ENTERAL","PARENTERAL"</text></inputEntry>
        <outputEntry id="OutputEntry_MealPref_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MealPref_3_acao"><text>"Nutrição especial. Verificar prescrição médica e fórmula adequada."</text></outputEntry>
        <outputEntry id="OutputEntry_MealPref_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_MealPref_4">
        <description>Aprovado: Dieta padrão</description>
        <inputEntry id="InputEntry_MealPref_4_1"><text>"NENHUMA","DIABETICO","HIPOSODICO"</text></inputEntry>
        <inputEntry id="InputEntry_MealPref_4_2"><text>&lt;= 1</text></inputEntry>
        <inputEntry id="InputEntry_MealPref_4_3"><text>"ORAL"</text></inputEntry>
        <outputEntry id="OutputEntry_MealPref_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_MealPref_4_acao"><text>"Liberar dieta conforme preferências e restrições registradas."</text></outputEntry>
        <outputEntry id="OutputEntry_MealPref_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_MealPref_Fallback">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_MealPref_F_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MealPref_F_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MealPref_F_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_MealPref_F_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MealPref_F_acao"><text>"Avaliar preferências alimentares manualmente."</text></outputEntry>
        <outputEntry id="OutputEntry_MealPref_F_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PatientMealPreference">
      <dmndi:DMNShape id="DMNShape_Decision_PatientMealPreference" dmnElementRef="Decision_PatientMealPreference">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
