<?xml version='1.0' encoding='UTF-8'?>
<!--
  ============================================================================
  DOCTOR-PATIENT-RECOVERY-ALERT - Alerta de Recuperacao do Paciente
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_DoctorPatientRecoveryAlert"
             name="Alerta de Recuperacao do Paciente"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">

  <decision id="Decision_DoctorPatientRecoveryAlert" name="Decisao Recovery Alert">
    <decisionTable id="DecisionTable_DoctorPatientRecoveryAlert" hitPolicy="FIRST">

      <input id="Input_recoveryScore" label="Score de Recuperacao (0-100)">
        <inputExpression id="InputExpr_recoveryScore" typeRef="number">
          <text>recoveryScore</text>
        </inputExpression>
      </input>

      <input id="Input_daysPostOp" label="Dias Pos-Operatorio">
        <inputExpression id="InputExpr_daysPostOp" typeRef="number">
          <text>daysPostOp</text>
        </inputExpression>
      </input>

      <input id="Input_complicationRisk" label="Risco de Complicacao">
        <inputExpression id="InputExpr_complicationRisk" typeRef="string">
          <text>complicationRisk</text>
        </inputExpression>
        <inputValues><text>"ALTO","MEDIO","BAIXO"</text></inputValues>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_RecovAlert_1">
        <description>Bloqueio: Recuperação crítica em paciente de alto risco</description>
        <inputEntry id="InputEntry_RecovAlert_1_1"><text>&lt; 40</text></inputEntry>
        <inputEntry id="InputEntry_RecovAlert_1_2"><text>&gt; 3</text></inputEntry>
        <inputEntry id="InputEntry_RecovAlert_1_3"><text>"ALTO"</text></inputEntry>
        <outputEntry id="OutputEntry_RecovAlert_1_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_RecovAlert_1_acao"><text>"CRÍTICO: Recuperação insatisfatória em paciente alto risco. Avaliar intercorrências."</text></outputEntry>
        <outputEntry id="OutputEntry_RecovAlert_1_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_RecovAlert_2">
        <description>Alerta: Recuperação lenta</description>
        <inputEntry id="InputEntry_RecovAlert_2_1"><text>&lt; 60</text></inputEntry>
        <inputEntry id="InputEntry_RecovAlert_2_2"><text>&gt; 7</text></inputEntry>
        <inputEntry id="InputEntry_RecovAlert_2_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RecovAlert_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_RecovAlert_2_acao"><text>"Recuperação abaixo do esperado. Revisar plano terapêutico."</text></outputEntry>
        <outputEntry id="OutputEntry_RecovAlert_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_RecovAlert_3">
        <description>Alerta: Período crítico pós-op</description>
        <inputEntry id="InputEntry_RecovAlert_3_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RecovAlert_3_2"><text>&lt;= 3</text></inputEntry>
        <inputEntry id="InputEntry_RecovAlert_3_3"><text>"ALTO","MEDIO"</text></inputEntry>
        <outputEntry id="OutputEntry_RecovAlert_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_RecovAlert_3_acao"><text>"Período crítico pós-operatório. Monitorar sinais vitais de perto."</text></outputEntry>
        <outputEntry id="OutputEntry_RecovAlert_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_RecovAlert_4">
        <description>Aprovado: Recuperação adequada</description>
        <inputEntry id="InputEntry_RecovAlert_4_1"><text>&gt;= 70</text></inputEntry>
        <inputEntry id="InputEntry_RecovAlert_4_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RecovAlert_4_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RecovAlert_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_RecovAlert_4_acao"><text>"Recuperação dentro do esperado. Manter acompanhamento de rotina."</text></outputEntry>
        <outputEntry id="OutputEntry_RecovAlert_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_RecovAlert_Fallback">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_RecovAlert_F_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RecovAlert_F_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RecovAlert_F_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RecovAlert_F_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_RecovAlert_F_acao"><text>"Avaliar status de recuperação manualmente."</text></outputEntry>
        <outputEntry id="OutputEntry_RecovAlert_F_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorPatientRecoveryAlert">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorPatientRecoveryAlert" dmnElementRef="Decision_DoctorPatientRecoveryAlert">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
