<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_DoctorTriageEscalation"
             name="Doctor Triage Escalation"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">
  <decision id="Decision_DoctorTriageEscalation" name="Doctor Triage Escalation">
    <decisionTable id="DecisionTable_DoctorTriageEscalation" hitPolicy="FIRST">
      <input id="Input_triage_1" label="Severity Level">
        <inputExpression id="InputExpr_triage_1" typeRef="string"><text>severityLevel</text></inputExpression>
      </input>
      <input id="Input_triage_2" label="Waiting Time (min)">
        <inputExpression id="InputExpr_triage_2" typeRef="number"><text>waitingTimeMinutes</text></inputExpression>
      </input>
      <input id="Input_triage_3" label="Vital Signs Unstable">
        <inputExpression id="InputExpr_triage_3" typeRef="boolean"><text>vitalSignsUnstable</text></inputExpression>
      </input>
      <output id="Output_triage_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_triage_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_triage_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>
      <rule id="Rule_triage_1">
        <inputEntry id="IE_triage_1_1"><text>"CRITICO","EMERGENCIA"</text></inputEntry>
        <inputEntry id="IE_triage_1_2"><text>&gt; 15</text></inputEntry>
        <inputEntry id="IE_triage_1_3"><text>true</text></inputEntry>
        <outputEntry id="OE_triage_1_r"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_triage_1_a"><text>"Escalar imediatamente para especialista sênior"</text></outputEntry>
        <outputEntry id="OE_triage_1_ri"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_triage_2">
        <inputEntry id="IE_triage_2_1"><text>"URGENTE"</text></inputEntry>
        <inputEntry id="IE_triage_2_2"><text>&gt; 30</text></inputEntry>
        <inputEntry id="IE_triage_2_3"><text></text></inputEntry>
        <outputEntry id="OE_triage_2_r"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_triage_2_a"><text>"Notificar supervisor e rever priorização"</text></outputEntry>
        <outputEntry id="OE_triage_2_ri"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_triage_3">
        <inputEntry id="IE_triage_3_1"><text></text></inputEntry>
        <inputEntry id="IE_triage_3_2"><text></text></inputEntry>
        <inputEntry id="IE_triage_3_3"><text></text></inputEntry>
        <outputEntry id="OE_triage_3_r"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_triage_3_a"><text>"Manter em fila normal de atendimento"</text></outputEntry>
        <outputEntry id="OE_triage_3_ri"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
