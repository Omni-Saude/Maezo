<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_EscalationRules"
             name="Escalation Rules"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">
  <decision id="Decision_EscalationRules" name="Escalation Rules">
    <decisionTable id="DecisionTable_EscalationRules" hitPolicy="FIRST">
      <input id="Input_esc_1" label="Escalation Type">
        <inputExpression id="InputExpr_esc_1" typeRef="string"><text>escalationType</text></inputExpression>
        <inputValues><text>"CLINICO","OPERACIONAL","SEGURANCA","FAMILIAR"</text></inputValues>
      </input>
      <input id="Input_esc_2" label="Response Severity">
        <inputExpression id="InputExpr_esc_2" typeRef="string"><text>responseSeverity</text></inputExpression>
        <inputValues><text>"IMEDIATA","URGENTE","PROGRAMADA"</text></inputValues>
      </input>
      <input id="Input_esc_3" label="Time Elapsed (hours)">
        <inputExpression id="InputExpr_esc_3" typeRef="number"><text>timeElapsed</text></inputExpression>
      </input>
      <output id="Output_esc_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_esc_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_esc_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>
      <rule id="Rule_esc_1">
        <inputEntry id="IE_esc_1_1"><text>"CLINICO","SEGURANCA"</text></inputEntry>
        <inputEntry id="IE_esc_1_2"><text>"IMEDIATA"</text></inputEntry>
        <inputEntry id="IE_esc_1_3"><text>&gt; 1</text></inputEntry>
        <outputEntry id="OE_esc_1_r"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_esc_1_a"><text>"Escalação crítica atrasada - acionar diretoria médica"</text></outputEntry>
        <outputEntry id="OE_esc_1_ri"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_esc_2">
        <inputEntry id="IE_esc_2_1"><text>"OPERACIONAL","FAMILIAR"</text></inputEntry>
        <inputEntry id="IE_esc_2_2"><text>"URGENTE"</text></inputEntry>
        <inputEntry id="IE_esc_2_3"><text>&gt; 8</text></inputEntry>
        <outputEntry id="OE_esc_2_r"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_esc_2_a"><text>"Escalação pendente - notificar supervisor"</text></outputEntry>
        <outputEntry id="OE_esc_2_ri"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_esc_3">
        <inputEntry id="IE_esc_3_1"><text></text></inputEntry>
        <inputEntry id="IE_esc_3_2"><text>"PROGRAMADA"</text></inputEntry>
        <inputEntry id="IE_esc_3_3"><text>&lt;= 24</text></inputEntry>
        <outputEntry id="OE_esc_3_r"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_esc_3_a"><text>"Processar escalação conforme fluxo"</text></outputEntry>
        <outputEntry id="OE_esc_3_ri"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
