<?xml version='1.0' encoding='UTF-8'?>
<!--
  ============================================================================
  DOCTOR-CRITICAL-VALUE - Notificacao de Valor Critico Laboratorial
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_DoctorCriticalValue"
             name="Notificacao de Valor Critico Laboratorial"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">

  <decision id="Decision_DoctorCriticalValue" name="Decisao Valor Critico">
    <decisionTable id="DecisionTable_DoctorCriticalValue" hitPolicy="FIRST">

      <input id="Input_labValueType" label="Tipo de Valor Laboratorial">
        <inputExpression id="InputExpr_labValueType" typeRef="string">
          <text>labValueType</text>
        </inputExpression>
        <inputValues><text>"POTASSIO","GLICOSE","HEMOGLOBINA","TROPONINA","CREATININA","SODIO"</text></inputValues>
      </input>

      <input id="Input_deviationPercent" label="Desvio do Normal (%)">
        <inputExpression id="InputExpr_deviationPercent" typeRef="number">
          <text>deviationPercent</text>
        </inputExpression>
      </input>

      <input id="Input_patientAcuity" label="Acuidade do Paciente">
        <inputExpression id="InputExpr_patientAcuity" typeRef="string">
          <text>patientAcuity</text>
        </inputExpression>
        <inputValues><text>"CRITICO","GRAVE","MODERADO","ESTAVEL"</text></inputValues>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_CritVal_1">
        <description>Bloqueio: Valor crítico em paciente crítico</description>
        <inputEntry id="InputEntry_CritVal_1_1"><text>"POTASSIO","TROPONINA"</text></inputEntry>
        <inputEntry id="InputEntry_CritVal_1_2"><text>&gt; 50</text></inputEntry>
        <inputEntry id="InputEntry_CritVal_1_3"><text>"CRITICO"</text></inputEntry>
        <outputEntry id="OutputEntry_CritVal_1_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CritVal_1_acao"><text>"EMERGÊNCIA: Notificar médico IMEDIATAMENTE. Valor crítico em paciente crítico."</text></outputEntry>
        <outputEntry id="OutputEntry_CritVal_1_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_CritVal_2">
        <description>Alerta: Desvio severo</description>
        <inputEntry id="InputEntry_CritVal_2_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CritVal_2_2"><text>&gt; 40</text></inputEntry>
        <inputEntry id="InputEntry_CritVal_2_3"><text>"GRAVE","MODERADO"</text></inputEntry>
        <outputEntry id="OutputEntry_CritVal_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CritVal_2_acao"><text>"Notificar médico em até 30 minutos. Desvio significativo detectado."</text></outputEntry>
        <outputEntry id="OutputEntry_CritVal_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_CritVal_3">
        <description>Alerta: Glicose ou sódio alterado</description>
        <inputEntry id="InputEntry_CritVal_3_1"><text>"GLICOSE","SODIO"</text></inputEntry>
        <inputEntry id="InputEntry_CritVal_3_2"><text>&gt; 30</text></inputEntry>
        <inputEntry id="InputEntry_CritVal_3_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_CritVal_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CritVal_3_acao"><text>"Notificar médico. Avaliar necessidade de intervenção."</text></outputEntry>
        <outputEntry id="OutputEntry_CritVal_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_CritVal_4">
        <description>Aprovado: Desvio leve em paciente estável</description>
        <inputEntry id="InputEntry_CritVal_4_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CritVal_4_2"><text>&lt;= 30</text></inputEntry>
        <inputEntry id="InputEntry_CritVal_4_3"><text>"ESTAVEL"</text></inputEntry>
        <outputEntry id="OutputEntry_CritVal_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_CritVal_4_acao"><text>"Registrar resultado. Notificação de rotina ao médico."</text></outputEntry>
        <outputEntry id="OutputEntry_CritVal_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_CritVal_Fallback">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_CritVal_F_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CritVal_F_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CritVal_F_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_CritVal_F_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CritVal_F_acao"><text>"Avaliar resultado manualmente."</text></outputEntry>
        <outputEntry id="OutputEntry_CritVal_F_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorCriticalValue">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorCriticalValue" dmnElementRef="Decision_DoctorCriticalValue">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
