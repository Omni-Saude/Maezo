<?xml version='1.0' encoding='UTF-8'?>
<!--
  ============================================================================
  PATIENT-CARE-TEAM-INTRO - Introducao da Equipe de Cuidados ao Paciente
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: PACIENTE (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_PatientCareTeamIntro"
             name="Introducao da Equipe de Cuidados ao Paciente"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">

  <decision id="Decision_PatientCareTeamIntro" name="Decisao Care Team Intro">
    <decisionTable id="DecisionTable_PatientCareTeamIntro" hitPolicy="FIRST">

      <input id="Input_admissionType" label="Tipo de Admissao">
        <inputExpression id="InputExpr_admissionType" typeRef="string">
          <text>admissionType</text>
        </inputExpression>
        <inputValues><text>"UTI","INTERNACAO","AMBULATORIO","EMERGENCIA"</text></inputValues>
      </input>

      <input id="Input_acuityLevel" label="Nivel de Acuidade">
        <inputExpression id="InputExpr_acuityLevel" typeRef="string">
          <text>acuityLevel</text>
        </inputExpression>
        <inputValues><text>"CRITICO","GRAVE","MODERADO","ESTAVEL"</text></inputValues>
      </input>

      <input id="Input_languagePreference" label="Idioma Preferencial">
        <inputExpression id="InputExpr_languagePreference" typeRef="string">
          <text>languagePreference</text>
        </inputExpression>
        <inputValues><text>"PT","EN","ES","OUTROS"</text></inputValues>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_CareTeam_1">
        <description>Bloqueio: UTI sem apresentação da equipe</description>
        <inputEntry id="InputEntry_CareTeam_1_1"><text>"UTI"</text></inputEntry>
        <inputEntry id="InputEntry_CareTeam_1_2"><text>"CRITICO"</text></inputEntry>
        <inputEntry id="InputEntry_CareTeam_1_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_CareTeam_1_resultado"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CareTeam_1_acao"><text>"URGENTE: Paciente crítico em UTI. Apresentar equipe multiprofissional imediatamente."</text></outputEntry>
        <outputEntry id="OutputEntry_CareTeam_1_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_CareTeam_2">
        <description>Alerta: Barreira de idioma</description>
        <inputEntry id="InputEntry_CareTeam_2_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CareTeam_2_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CareTeam_2_3"><text>"EN","ES","OUTROS"</text></inputEntry>
        <outputEntry id="OutputEntry_CareTeam_2_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CareTeam_2_acao"><text>"Providenciar intérprete ou material de apresentação no idioma preferencial."</text></outputEntry>
        <outputEntry id="OutputEntry_CareTeam_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_CareTeam_3">
        <description>Alerta: Admissão grave</description>
        <inputEntry id="InputEntry_CareTeam_3_1"><text>"INTERNACAO","EMERGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_CareTeam_3_2"><text>"GRAVE"</text></inputEntry>
        <inputEntry id="InputEntry_CareTeam_3_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_CareTeam_3_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CareTeam_3_acao"><text>"Apresentar equipe e plano de cuidados em até 2 horas da admissão."</text></outputEntry>
        <outputEntry id="OutputEntry_CareTeam_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_CareTeam_4">
        <description>Aprovado: Admissão eletiva</description>
        <inputEntry id="InputEntry_CareTeam_4_1"><text>"AMBULATORIO","INTERNACAO"</text></inputEntry>
        <inputEntry id="InputEntry_CareTeam_4_2"><text>"ESTAVEL","MODERADO"</text></inputEntry>
        <inputEntry id="InputEntry_CareTeam_4_3"><text>"PT"</text></inputEntry>
        <outputEntry id="OutputEntry_CareTeam_4_resultado"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_CareTeam_4_acao"><text>"Apresentar equipe de cuidados conforme rotina padrão."</text></outputEntry>
        <outputEntry id="OutputEntry_CareTeam_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_CareTeam_Fallback">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_CareTeam_F_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CareTeam_F_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CareTeam_F_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_CareTeam_F_resultado"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CareTeam_F_acao"><text>"Avaliar necessidade de apresentação da equipe."</text></outputEntry>
        <outputEntry id="OutputEntry_CareTeam_F_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PatientCareTeamIntro">
      <dmndi:DMNShape id="DMNShape_Decision_PatientCareTeamIntro" dmnElementRef="Decision_PatientCareTeamIntro">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
