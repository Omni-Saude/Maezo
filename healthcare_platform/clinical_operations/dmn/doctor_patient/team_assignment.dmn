<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_TeamAssignment"
             name="Team Assignment"
             namespace="http://healthcare.platform/dmn/clinical_operations/doctor_patient">
  <decision id="Decision_TeamAssignment" name="Team Assignment">
    <decisionTable id="DecisionTable_TeamAssignment" hitPolicy="FIRST">
      <input id="Input_team_1" label="Patient Acuity">
        <inputExpression id="InputExpr_team_1" typeRef="string"><text>patientAcuity</text></inputExpression>
        <inputValues><text>"CRITICO","GRAVE","MODERADO","ESTAVEL"</text></inputValues>
      </input>
      <input id="Input_team_2" label="Specialty Needed">
        <inputExpression id="InputExpr_team_2" typeRef="string"><text>specialtyNeeded</text></inputExpression>
      </input>
      <input id="Input_team_3" label="Staff Availability">
        <inputExpression id="InputExpr_team_3" typeRef="boolean"><text>staffAvailability</text></inputExpression>
      </input>
      <output id="Output_team_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_team_acao" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_team_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>
      <rule id="Rule_team_1">
        <inputEntry id="IE_team_1_1"><text>"CRITICO"</text></inputEntry>
        <inputEntry id="IE_team_1_2"><text></text></inputEntry>
        <inputEntry id="IE_team_1_3"><text>false</text></inputEntry>
        <outputEntry id="OE_team_1_r"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_team_1_a"><text>"Paciente crítico sem equipe - acionar plantão urgente"</text></outputEntry>
        <outputEntry id="OE_team_1_ri"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_team_2">
        <inputEntry id="IE_team_2_1"><text>"GRAVE"</text></inputEntry>
        <inputEntry id="IE_team_2_2"><text>"CARDIO","NEURO","TRAUMA"</text></inputEntry>
        <inputEntry id="IE_team_2_3"><text>true</text></inputEntry>
        <outputEntry id="OE_team_2_r"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_team_2_a"><text>"Alocar equipe especializada com intensivista"</text></outputEntry>
        <outputEntry id="OE_team_2_ri"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_team_3">
        <inputEntry id="IE_team_3_1"><text>"MODERADO","ESTAVEL"</text></inputEntry>
        <inputEntry id="IE_team_3_2"><text></text></inputEntry>
        <inputEntry id="IE_team_3_3"><text>true</text></inputEntry>
        <outputEntry id="OE_team_3_r"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_team_3_a"><text>"Alocar equipe clínica padrão"</text></outputEntry>
        <outputEntry id="OE_team_3_ri"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
