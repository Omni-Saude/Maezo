<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  id="Definitions_clinical_alerts"
                  targetNamespace="http://cib7.healthcare/clinical-alerts"
                  exporter="CIB Seven 2.1.3"
                  exporterVersion="2.1.3">

  <!-- Error Definitions -->
  <bpmn:error id="Error_ClinicalAlert" name="CLINICAL_ALERT_ERROR" errorCode="CA_ERROR"/>
  <bpmn:error id="Error_SepsisTimeout" name="SEPSIS_TIMEOUT" errorCode="CA_SEPSIS_TIMEOUT"/>

  <!-- Message Definitions -->
  <bpmn:message id="msg_vital_signs_received" name="msg_vital_signs_received"/>
  <bpmn:message id="msg_clinical_escalation" name="msg_clinical_escalation"/>
  <bpmn:message id="msg_sepsis_alert" name="msg_sepsis_alert"/>

  <!-- Signal Definitions -->
  <bpmn:signal id="signal_code_blue" name="signal_code_blue"/>

  <!-- Main Process -->
  <bpmn:process id="clinical_alerts_main" name="Clinical Alerts Orchestrator" isExecutable="true">

    <!-- Start Event: Message Start -->
    <bpmn:startEvent id="start_vital_signs" name="Vital Signs Received">
      <bpmn:outgoing>flow_to_classify</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="msg_vital_signs_received"/>
    </bpmn:startEvent>

    <!-- Service Task: Classify Alert Type -->
    <bpmn:serviceTask id="task_classify_alert" name="Classify Alert Type"
                      camunda:type="external" camunda:topic="clinical.alert_classification">
      <bpmn:incoming>flow_to_classify</bpmn:incoming>
      <bpmn:outgoing>flow_to_alert_type_gateway</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Exclusive Gateway: Alert Type Decision -->
    <bpmn:exclusiveGateway id="gateway_alert_type" name="Alert Type?" default="flow_to_unclassified">
      <bpmn:incoming>flow_to_alert_type_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_to_sepsis</bpmn:outgoing>
      <bpmn:outgoing>flow_to_early_warning</bpmn:outgoing>
      <bpmn:outgoing>flow_to_unclassified</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Call Activity: Sepsis Detection (SP-CA-001) -->
    <bpmn:callActivity id="call_SP_CA_001" name="Sepsis Detection&#10;(qSOFA/SOFA)" calledElement="SP_CA_001_Sepsis_Detection" camunda:calledElement="SP_CA_001_Sepsis_Detection">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="patientFhirId" target="patientFhirId"/>
        <camunda:in source="encounterFhirId" target="encounterFhirId"/>
        <camunda:in source="vitalSignsFhirId" target="vitalSignsFhirId"/>
        <camunda:out source="alertScore" target="alertScore"/>
        <camunda:out source="qsofaScore" target="qsofaScore"/>
        <camunda:out source="escalationRequired" target="escalationRequired"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_sepsis</bpmn:incoming>
      <bpmn:outgoing>flow_from_sepsis</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Timer Boundary Event: Sepsis Critical Timeout (5 min, interrupting) -->
    <bpmn:boundaryEvent id="timer_sepsis_critical" name="5 min timeout&#10;(CRITICAL)" attachedToRef="call_SP_CA_001" cancelActivity="true">
      <bpmn:outgoing>flow_sepsis_timeout</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT5M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- Service Task: Escalate Sepsis Timeout -->
    <bpmn:serviceTask id="task_escalate_sepsis_timeout" name="Escalate to Chief&#10;Intensivist + Admin"
                      camunda:type="external" camunda:topic="clinical.sepsis_timeout_escalation">
      <bpmn:incoming>flow_sepsis_timeout</bpmn:incoming>
      <bpmn:outgoing>flow_sepsis_timeout_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Error Boundary Event: Sepsis Error -->
    <bpmn:boundaryEvent id="error_sepsis" name="Sepsis Error" attachedToRef="call_SP_CA_001">
      <bpmn:outgoing>flow_sepsis_error</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_ClinicalAlert" camunda:errorCodeVariable="errorCode"/>
    </bpmn:boundaryEvent>

    <!-- Call Activity: NEWS2 Early Warning (SP-CA-002) -->
    <bpmn:callActivity id="call_SP_CA_002" name="NEWS2 Early Warning&#10;Score" calledElement="SP_CA_002_NEWS2_Early_Warning" camunda:calledElement="SP_CA_002_NEWS2_Early_Warning">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="patientFhirId" target="patientFhirId"/>
        <camunda:in source="encounterFhirId" target="encounterFhirId"/>
        <camunda:in source="vitalSignsFhirId" target="vitalSignsFhirId"/>
        <camunda:out source="alertScore" target="alertScore"/>
        <camunda:out source="news2Score" target="news2Score"/>
        <camunda:out source="escalationRequired" target="escalationRequired"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_early_warning</bpmn:incoming>
      <bpmn:outgoing>flow_from_early_warning</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Timer Boundary Event: NEWS2 Timeout (15 min, non-interrupting) -->
    <bpmn:boundaryEvent id="timer_news2" name="15 min timeout&#10;(alert nursing)" attachedToRef="call_SP_CA_002" cancelActivity="false">
      <bpmn:outgoing>flow_news2_timeout</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT15M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- Service Task: Alert Nursing Station -->
    <bpmn:serviceTask id="task_alert_nursing" name="Alert Nursing&#10;Station"
                      camunda:type="external" camunda:topic="clinical.nursing_alert">
      <bpmn:incoming>flow_news2_timeout</bpmn:incoming>
      <bpmn:outgoing>flow_nursing_alert_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Error Boundary Event: NEWS2 Error -->
    <bpmn:boundaryEvent id="error_news2" name="NEWS2 Error" attachedToRef="call_SP_CA_002">
      <bpmn:outgoing>flow_news2_error</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_ClinicalAlert" camunda:errorCodeVariable="errorCode"/>
    </bpmn:boundaryEvent>

    <!-- Service Task: Log Unclassified Alert -->
    <bpmn:serviceTask id="task_log_unclassified" name="Log Unclassified&#10;Alert"
                      camunda:type="external" camunda:topic="clinical.alert_logging">
      <bpmn:incoming>flow_to_unclassified</bpmn:incoming>
      <bpmn:outgoing>flow_from_unclassified</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Exclusive Gateway: Join after call activities -->
    <bpmn:exclusiveGateway id="gateway_join_alerts">
      <bpmn:incoming>flow_from_sepsis</bpmn:incoming>
      <bpmn:incoming>flow_from_early_warning</bpmn:incoming>
      <bpmn:incoming>flow_from_unclassified</bpmn:incoming>
      <bpmn:outgoing>flow_to_escalation_check</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Exclusive Gateway: Escalation Required? -->
    <bpmn:exclusiveGateway id="gateway_escalation_required" name="Escalation&#10;Required?" default="flow_to_resolution">
      <bpmn:incoming>flow_to_escalation_check</bpmn:incoming>
      <bpmn:outgoing>flow_to_escalation</bpmn:outgoing>
      <bpmn:outgoing>flow_to_resolution</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Exclusive Gateway: Is Sepsis Alert? -->
    <bpmn:exclusiveGateway id="gateway_sepsis_alert_check" name="Is Sepsis&#10;Alert?" default="flow_to_general_escalation">
      <bpmn:incoming>flow_to_escalation</bpmn:incoming>
      <bpmn:outgoing>flow_to_sepsis_alert</bpmn:outgoing>
      <bpmn:outgoing>flow_to_general_escalation</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Message Intermediate Throw Event: Sepsis Alert -->
    <bpmn:intermediateThrowEvent id="throw_sepsis_alert" name="Throw Sepsis Alert&#10;to Clinical Ops">
      <bpmn:incoming>flow_to_sepsis_alert</bpmn:incoming>
      <bpmn:outgoing>flow_from_sepsis_alert</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="msg_sepsis_alert"/>
    </bpmn:intermediateThrowEvent>

    <!-- Message Intermediate Throw Event: Clinical Escalation -->
    <bpmn:intermediateThrowEvent id="throw_escalation_message" name="Send Clinical&#10;Escalation">
      <bpmn:incoming>flow_to_general_escalation</bpmn:incoming>
      <bpmn:incoming>flow_from_sepsis_alert</bpmn:incoming>
      <bpmn:outgoing>flow_to_notify</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="msg_clinical_escalation"/>
    </bpmn:intermediateThrowEvent>

    <!-- Service Task: Notify Care Team -->
    <bpmn:serviceTask id="task_notify_care_team" name="Notify Care Team"
                      camunda:type="external" camunda:topic="clinical.alert_notification">
      <bpmn:incoming>flow_to_notify</bpmn:incoming>
      <bpmn:outgoing>flow_to_code_blue_check</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Exclusive Gateway: Code Blue Required? -->
    <bpmn:exclusiveGateway id="gateway_code_blue" name="Critical Alert?" default="flow_from_code_blue_no">
      <bpmn:incoming>flow_to_code_blue_check</bpmn:incoming>
      <bpmn:outgoing>flow_to_code_blue_signal</bpmn:outgoing>
      <bpmn:outgoing>flow_from_code_blue_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Signal Intermediate Throw Event: Code Blue -->
    <bpmn:intermediateThrowEvent id="throw_code_blue_signal" name="Broadcast&#10;Code Blue">
      <bpmn:incoming>flow_to_code_blue_signal</bpmn:incoming>
      <bpmn:outgoing>flow_from_code_blue_signal</bpmn:outgoing>
      <bpmn:signalEventDefinition signalRef="signal_code_blue"/>
    </bpmn:intermediateThrowEvent>

    <!-- Exclusive Gateway: Join after escalation -->
    <bpmn:exclusiveGateway id="gateway_join_escalation">
      <bpmn:incoming>flow_from_code_blue_signal</bpmn:incoming>
      <bpmn:incoming>flow_from_code_blue_no</bpmn:incoming>
      <bpmn:outgoing>flow_to_final_resolution</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Service Task: Record Alert Resolution -->
    <bpmn:serviceTask id="task_record_resolution" name="Record Alert&#10;Resolution"
                      camunda:type="external" camunda:topic="clinical.alert_resolution">
      <bpmn:incoming>flow_to_resolution</bpmn:incoming>
      <bpmn:incoming>flow_to_final_resolution</bpmn:incoming>
      <bpmn:outgoing>flow_to_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- End Event: Normal End -->
    <bpmn:endEvent id="end_normal" name="Alert Processing&#10;Complete">
      <bpmn:incoming>flow_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- End Event: Sepsis Timeout End -->
    <bpmn:endEvent id="end_sepsis_timeout" name="Sepsis Timeout&#10;Escalated">
      <bpmn:incoming>flow_sepsis_timeout_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- End Event: Nursing Alert End -->
    <bpmn:endEvent id="end_nursing_alert" name="Nursing Station&#10;Alerted">
      <bpmn:incoming>flow_nursing_alert_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- End Event: Error Handling -->
    <bpmn:endEvent id="end_error" name="Error Logged">
      <bpmn:incoming>flow_sepsis_error</bpmn:incoming>
      <bpmn:incoming>flow_news2_error</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="flow_to_classify" sourceRef="start_vital_signs" targetRef="task_classify_alert"/>
    <bpmn:sequenceFlow id="flow_to_alert_type_gateway" sourceRef="task_classify_alert" targetRef="gateway_alert_type"/>

    <bpmn:sequenceFlow id="flow_to_sepsis" name="sepsis" sourceRef="gateway_alert_type" targetRef="call_SP_CA_001">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${alertType == 'sepsis'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="flow_to_early_warning" name="early_warning" sourceRef="gateway_alert_type" targetRef="call_SP_CA_002">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${alertType == 'early_warning'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="flow_to_unclassified" name="other" sourceRef="gateway_alert_type" targetRef="task_log_unclassified"/>

    <bpmn:sequenceFlow id="flow_from_sepsis" sourceRef="call_SP_CA_001" targetRef="gateway_join_alerts"/>
    <bpmn:sequenceFlow id="flow_from_early_warning" sourceRef="call_SP_CA_002" targetRef="gateway_join_alerts"/>
    <bpmn:sequenceFlow id="flow_from_unclassified" sourceRef="task_log_unclassified" targetRef="gateway_join_alerts"/>

    <bpmn:sequenceFlow id="flow_to_escalation_check" sourceRef="gateway_join_alerts" targetRef="gateway_escalation_required"/>

    <bpmn:sequenceFlow id="flow_to_escalation" name="yes" sourceRef="gateway_escalation_required" targetRef="gateway_sepsis_alert_check">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${escalationRequired == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="flow_to_resolution" name="no" sourceRef="gateway_escalation_required" targetRef="task_record_resolution"/>

    <bpmn:sequenceFlow id="flow_to_sepsis_alert" name="sepsis" sourceRef="gateway_sepsis_alert_check" targetRef="throw_sepsis_alert">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${alertType == 'sepsis'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="flow_to_general_escalation" name="other" sourceRef="gateway_sepsis_alert_check" targetRef="throw_escalation_message"/>

    <bpmn:sequenceFlow id="flow_from_sepsis_alert" sourceRef="throw_sepsis_alert" targetRef="throw_escalation_message"/>

    <bpmn:sequenceFlow id="flow_to_notify" sourceRef="throw_escalation_message" targetRef="task_notify_care_team"/>
    <bpmn:sequenceFlow id="flow_to_code_blue_check" sourceRef="task_notify_care_team" targetRef="gateway_code_blue"/>

    <bpmn:sequenceFlow id="flow_to_code_blue_signal" name="yes" sourceRef="gateway_code_blue" targetRef="throw_code_blue_signal">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${alertScore &gt;= 9 or qsofaScore &gt;= 3}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="flow_from_code_blue_no" name="no" sourceRef="gateway_code_blue" targetRef="gateway_join_escalation"/>
    <bpmn:sequenceFlow id="flow_from_code_blue_signal" sourceRef="throw_code_blue_signal" targetRef="gateway_join_escalation"/>
    <bpmn:sequenceFlow id="flow_to_final_resolution" sourceRef="gateway_join_escalation" targetRef="task_record_resolution"/>

    <bpmn:sequenceFlow id="flow_to_end" sourceRef="task_record_resolution" targetRef="end_normal"/>

    <!-- Boundary Event Flows -->
    <bpmn:sequenceFlow id="flow_sepsis_timeout" sourceRef="timer_sepsis_critical" targetRef="task_escalate_sepsis_timeout"/>
    <bpmn:sequenceFlow id="flow_sepsis_timeout_end" sourceRef="task_escalate_sepsis_timeout" targetRef="end_sepsis_timeout"/>
    <bpmn:sequenceFlow id="flow_sepsis_error" sourceRef="error_sepsis" targetRef="end_error"/>

    <bpmn:sequenceFlow id="flow_news2_timeout" sourceRef="timer_news2" targetRef="task_alert_nursing"/>
    <bpmn:sequenceFlow id="flow_nursing_alert_end" sourceRef="task_alert_nursing" targetRef="end_nursing_alert"/>
    <bpmn:sequenceFlow id="flow_news2_error" sourceRef="error_news2" targetRef="end_error"/>

    <!-- Event Sub-Process: Continuous Monitoring -->
    <bpmn:subProcess id="event_sub_continuous_monitoring" name="Continuous Vital Signs Monitoring" triggeredByEvent="true">

      <!-- Start Event: Timer (Every 5 Minutes, Non-interrupting) -->
      <bpmn:startEvent id="start_monitoring_timer" name="Every 5 Minutes" isInterrupting="false">
        <bpmn:outgoing>flow_to_fetch_vitals</bpmn:outgoing>
        <bpmn:timerEventDefinition>
          <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/PT5M</bpmn:timeCycle>
        </bpmn:timerEventDefinition>
      </bpmn:startEvent>

      <!-- Service Task: Fetch Latest Vitals -->
      <bpmn:serviceTask id="task_fetch_vitals" name="Fetch Latest Vitals"
                        camunda:type="external" camunda:topic="clinical.fetch_vitals">
        <bpmn:incoming>flow_to_fetch_vitals</bpmn:incoming>
        <bpmn:outgoing>flow_to_evaluate_trends</bpmn:outgoing>
      </bpmn:serviceTask>

      <!-- Service Task: Evaluate Trends -->
      <bpmn:serviceTask id="task_evaluate_trends" name="Evaluate Trends"
                        camunda:type="external" camunda:topic="clinical.evaluate_trends">
        <bpmn:incoming>flow_to_evaluate_trends</bpmn:incoming>
        <bpmn:outgoing>flow_to_end_monitoring</bpmn:outgoing>
      </bpmn:serviceTask>

      <!-- End Event: Monitoring Cycle Complete -->
      <bpmn:endEvent id="end_monitoring_cycle" name="Cycle Complete">
        <bpmn:incoming>flow_to_end_monitoring</bpmn:incoming>
      </bpmn:endEvent>

      <!-- Sequence Flows -->
      <bpmn:sequenceFlow id="flow_to_fetch_vitals" sourceRef="start_monitoring_timer" targetRef="task_fetch_vitals"/>
      <bpmn:sequenceFlow id="flow_to_evaluate_trends" sourceRef="task_fetch_vitals" targetRef="task_evaluate_trends"/>
      <bpmn:sequenceFlow id="flow_to_end_monitoring" sourceRef="task_evaluate_trends" targetRef="end_monitoring_cycle"/>
    </bpmn:subProcess>

  </bpmn:process>

  <!-- BPMN Diagram -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_clinical_alerts">
    <bpmndi:BPMNPlane id="BPMNPlane_clinical_alerts" bpmnElement="clinical_alerts_main">

      <!-- Start Event -->
      <bpmndi:BPMNShape id="start_vital_signs_di" bpmnElement="start_vital_signs">
        <dc:Bounds x="152" y="192" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="144" y="235" width="52" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Service Task: Classify -->
      <bpmndi:BPMNShape id="task_classify_alert_di" bpmnElement="task_classify_alert">
        <dc:Bounds x="240" y="170" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- Gateway: Alert Type -->
      <bpmndi:BPMNShape id="gateway_alert_type_di" bpmnElement="gateway_alert_type" isMarkerVisible="true">
        <dc:Bounds x="395" y="185" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="391" y="155" width="58" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Call Activity: Sepsis -->
      <bpmndi:BPMNShape id="call_SP_CA_001_di" bpmnElement="call_SP_CA_001">
        <dc:Bounds x="510" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- Timer Boundary: Sepsis -->
      <bpmndi:BPMNShape id="timer_sepsis_critical_di" bpmnElement="timer_sepsis_critical">
        <dc:Bounds x="592" y="142" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="625" y="143" width="70" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Error Boundary: Sepsis -->
      <bpmndi:BPMNShape id="error_sepsis_di" bpmnElement="error_sepsis">
        <dc:Bounds x="542" y="142" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="523" y="185" width="62" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Call Activity: NEWS2 -->
      <bpmndi:BPMNShape id="call_SP_CA_002_di" bpmnElement="call_SP_CA_002">
        <dc:Bounds x="510" y="240" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- Timer Boundary: NEWS2 -->
      <bpmndi:BPMNShape id="timer_news2_di" bpmnElement="timer_news2">
        <dc:Bounds x="592" y="302" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="625" y="313" width="70" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Error Boundary: NEWS2 -->
      <bpmndi:BPMNShape id="error_news2_di" bpmnElement="error_news2">
        <dc:Bounds x="542" y="302" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="523" y="345" width="67" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Service Task: Unclassified -->
      <bpmndi:BPMNShape id="task_log_unclassified_di" bpmnElement="task_log_unclassified">
        <dc:Bounds x="510" y="390" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- Service Task: Escalate Timeout -->
      <bpmndi:BPMNShape id="task_escalate_sepsis_timeout_di" bpmnElement="task_escalate_sepsis_timeout">
        <dc:Bounds x="720" y="30" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- Service Task: Alert Nursing -->
      <bpmndi:BPMNShape id="task_alert_nursing_di" bpmnElement="task_alert_nursing">
        <dc:Bounds x="720" y="360" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <!-- Gateway: Join Alerts -->
      <bpmndi:BPMNShape id="gateway_join_alerts_di" bpmnElement="gateway_join_alerts" isMarkerVisible="true">
        <dc:Bounds x="675" y="185" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <!-- Gateway: Escalation Required -->
      <bpmndi:BPMNShape id="gateway_escalation_required_di" bpmnElement="gateway_escalation_required" isMarkerVisible="true">
        <dc:Bounds x="785" y="185" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="779" y="155" width="63" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Gateway: Sepsis Alert Check -->
      <bpmndi:BPMNShape id="gateway_sepsis_alert_check_di" bpmnElement="gateway_sepsis_alert_check" isMarkerVisible="true">
        <dc:Bounds x="875" y="105" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="870" y="75" width="60" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Throw Event: Sepsis Alert -->
      <bpmndi:BPMNShape id="throw_sepsis_alert_di" bpmnElement="throw_sepsis_alert">
        <dc:Bounds x="882" y="32" width="36" height="36"/>
