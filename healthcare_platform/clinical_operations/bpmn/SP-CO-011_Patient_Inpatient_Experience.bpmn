<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                   xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                   xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                   xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                   xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   id="Definitions_SP_CO_011"
                   targetNamespace="http://cib7.healthcare/clinical-operations/inpatient"
                   exporter="CIB Seven 2.1.3"
                   exporterVersion="2.1.3">

  <!-- ================================================================ -->
  <!-- SP-PA-011: Patient Inpatient Experience Process                 -->
  <!-- Purpose: Orchestrate daily patient engagement during admission   -->
  <!-- ================================================================ -->

  <bpmn:error id="Error_InpatientNotification" name="INPATIENT_NOTIFICATION_ERROR" errorCode="INPATIENT_NOTIFICATION_ERROR" />
  <bpmn:error id="Error_InpatientMedication" name="INPATIENT_MEDICATION_ERROR" errorCode="INPATIENT_MEDICATION_ERROR" />

  <bpmn:message id="Message_DischargeInitiated" name="msg_discharge_initiated" />
  <bpmn:message id="Message_PatientResponse" name="msg_patient_response" />

  <bpmn:process id="SP_CO_011_Patient_Inpatient_Experience" name="Patient Inpatient Experience" isExecutable="true">

    <!-- Process Variables:
         - tenantId: string
         - patientId: string
         - admissionId: string
         - channelPreference: string (email|sms|app)
         - dischargeDate: date
         - dailyCycleCount: integer
         - dischargePlanned: boolean
    -->

    <!-- ============================================================ -->
    <!-- Start Event: Admission Trigger                               -->
    <!-- ============================================================ -->
    <bpmn:startEvent id="StartEvent_AdmissionTrigger" name="Admission Trigger">
      <bpmn:outgoing>Flow_AdmissionToInit</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- ============================================================ -->
    <!-- Initialize Patient Context                                   -->
    <!-- ============================================================ -->
    <bpmn:serviceTask id="ServiceTask_InitPatientContext"
                      name="Initialize Patient Context"
                      camunda:type="external"
                      camunda:topic="inpatient.init_context">
      <bpmn:incoming>Flow_AdmissionToInit</bpmn:incoming>
      <bpmn:outgoing>Flow_InitToTeamIntro</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ============================================================ -->
    <!-- Send Care Team Introduction                                  -->
    <!-- ============================================================ -->
    <bpmn:serviceTask id="ServiceTask_TeamIntroduction"
                      name="Send Care Team Introduction"
                      camunda:type="external"
                      camunda:topic="inpatient.team_intro">
      <bpmn:incoming>Flow_InitToTeamIntro</bpmn:incoming>
      <bpmn:outgoing>Flow_TeamIntroToDailyCycle</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ============================================================ -->
    <!-- Daily Cycle Subprocess (Loop)                                -->
    <!-- ============================================================ -->
    <bpmn:subProcess id="SubProcess_DailyCycle" name="Daily Cycle">
      <bpmn:incoming>Flow_TeamIntroToDailyCycle</bpmn:incoming>
      <bpmn:incoming>Flow_ContinueDailyCycle</bpmn:incoming>
      <bpmn:outgoing>Flow_DailyCycleToDischargePrep</bpmn:outgoing>

      <!-- Daily Cycle Start -->
      <bpmn:startEvent id="StartEvent_DailyCycle" name="Daily Start">
        <bpmn:outgoing>Flow_DailyStartToTimer</bpmn:outgoing>
      </bpmn:startEvent>

      <!-- Timer: Start Each Morning (24 hour cycle) -->
      <bpmn:intermediateCatchEvent id="IntermediateTimer_MorningStart" name="Morning Start (PT24H)">
        <bpmn:incoming>Flow_DailyStartToTimer</bpmn:incoming>
        <bpmn:outgoing>Flow_TimerToDailyPlan</bpmn:outgoing>
        <bpmn:timerEventDefinition>
          <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT24H</bpmn:timeDuration>
        </bpmn:timerEventDefinition>
      </bpmn:intermediateCatchEvent>

      <!-- Send Daily Plan -->
      <bpmn:serviceTask id="ServiceTask_DailyPlan"
                        name="Send Daily Plan"
                        camunda:type="external"
                        camunda:topic="inpatient.daily_plan">
        <bpmn:incoming>Flow_TimerToDailyPlan</bpmn:incoming>
        <bpmn:outgoing>Flow_DailyPlanToParallelSplit</bpmn:outgoing>
      </bpmn:serviceTask>

      <!-- Parallel Gateway Split -->
      <bpmn:parallelGateway id="ParallelGateway_DailySplit" name="Parallel Activities">
        <bpmn:incoming>Flow_DailyPlanToParallelSplit</bpmn:incoming>
        <bpmn:outgoing>Flow_SplitToMedication</bpmn:outgoing>
        <bpmn:outgoing>Flow_SplitToMeal</bpmn:outgoing>
        <bpmn:outgoing>Flow_SplitToFamily</bpmn:outgoing>
      </bpmn:parallelGateway>

      <!-- Medication Reminder with Timer Boundary -->
      <bpmn:serviceTask id="ServiceTask_MedicationReminder"
                        name="Medication Reminder"
                        camunda:type="external"
                        camunda:topic="inpatient.medication_reminder">
        <bpmn:incoming>Flow_SplitToMedication</bpmn:incoming>
        <bpmn:outgoing>Flow_MedicationToJoin</bpmn:outgoing>
      </bpmn:serviceTask>

      <bpmn:boundaryEvent id="BoundaryTimer_MedicationRetry"
                          name="Retry After 1 Hour"
                          attachedToRef="ServiceTask_MedicationReminder">
        <bpmn:outgoing>Flow_MedicationRetryToJoin</bpmn:outgoing>
        <bpmn:timerEventDefinition>
          <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT1H</bpmn:timeDuration>
        </bpmn:timerEventDefinition>
      </bpmn:boundaryEvent>

      <!-- Meal Choice Notification with Message Catch -->
      <bpmn:serviceTask id="ServiceTask_MealChoice"
                        name="Meal Choice Notification"
                        camunda:type="external"
                        camunda:topic="inpatient.meal_choice">
        <bpmn:incoming>Flow_SplitToMeal</bpmn:incoming>
        <bpmn:outgoing>Flow_MealToMessageCatch</bpmn:outgoing>
      </bpmn:serviceTask>

      <bpmn:intermediateCatchEvent id="IntermediateMessage_PatientMealResponse"
                                    name="Patient Meal Response">
        <bpmn:incoming>Flow_MealToMessageCatch</bpmn:incoming>
        <bpmn:outgoing>Flow_MealResponseToJoin</bpmn:outgoing>
        <bpmn:messageEventDefinition messageRef="Message_PatientResponse" />
      </bpmn:intermediateCatchEvent>

      <!-- Family Update -->
      <bpmn:serviceTask id="ServiceTask_FamilyUpdate"
                        name="Family Update"
                        camunda:type="external"
                        camunda:topic="inpatient.family_update">
        <bpmn:incoming>Flow_SplitToFamily</bpmn:incoming>
        <bpmn:outgoing>Flow_FamilyToJoin</bpmn:outgoing>
      </bpmn:serviceTask>

      <!-- Parallel Gateway Join -->
      <bpmn:parallelGateway id="ParallelGateway_DailyJoin" name="Synchronize">
        <bpmn:incoming>Flow_MedicationToJoin</bpmn:incoming>
        <bpmn:incoming>Flow_MedicationRetryToJoin</bpmn:incoming>
        <bpmn:incoming>Flow_MealResponseToJoin</bpmn:incoming>
        <bpmn:incoming>Flow_FamilyToJoin</bpmn:incoming>
        <bpmn:outgoing>Flow_JoinToEveningSummary</bpmn:outgoing>
      </bpmn:parallelGateway>

      <!-- Evening Summary -->
      <bpmn:serviceTask id="ServiceTask_EveningSummary"
                        name="Evening Summary"
                        camunda:type="external"
                        camunda:topic="inpatient.evening_summary">
        <bpmn:incoming>Flow_JoinToEveningSummary</bpmn:incoming>
        <bpmn:outgoing>Flow_EveningToDischargeCheck</bpmn:outgoing>
      </bpmn:serviceTask>

      <!-- Discharge Planned Check -->
      <bpmn:exclusiveGateway id="ExclusiveGateway_DischargePlanned"
                             name="Discharge Planned?"
                             default="Flow_ContinueCycle">
        <bpmn:incoming>Flow_EveningToDischargeCheck</bpmn:incoming>
        <bpmn:outgoing>Flow_ExitCycle</bpmn:outgoing>
        <bpmn:outgoing>Flow_ContinueCycle</bpmn:outgoing>
      </bpmn:exclusiveGateway>

      <!-- End Daily Cycle -->
      <bpmn:endEvent id="EndEvent_DailyCycle" name="Daily End">
        <bpmn:incoming>Flow_ExitCycle</bpmn:incoming>
      </bpmn:endEvent>

      <!-- Continue to Next Day -->
      <bpmn:endEvent id="EndEvent_ContinueCycle" name="Continue to Next Day">
        <bpmn:incoming>Flow_ContinueCycle</bpmn:incoming>
      </bpmn:endEvent>

      <!-- Sequence Flows within Daily Cycle -->
      <bpmn:sequenceFlow id="Flow_DailyStartToTimer" sourceRef="StartEvent_DailyCycle" targetRef="IntermediateTimer_MorningStart" />
      <bpmn:sequenceFlow id="Flow_TimerToDailyPlan" sourceRef="IntermediateTimer_MorningStart" targetRef="ServiceTask_DailyPlan" />
      <bpmn:sequenceFlow id="Flow_DailyPlanToParallelSplit" sourceRef="ServiceTask_DailyPlan" targetRef="ParallelGateway_DailySplit" />
      <bpmn:sequenceFlow id="Flow_SplitToMedication" sourceRef="ParallelGateway_DailySplit" targetRef="ServiceTask_MedicationReminder" />
      <bpmn:sequenceFlow id="Flow_SplitToMeal" sourceRef="ParallelGateway_DailySplit" targetRef="ServiceTask_MealChoice" />
      <bpmn:sequenceFlow id="Flow_SplitToFamily" sourceRef="ParallelGateway_DailySplit" targetRef="ServiceTask_FamilyUpdate" />
      <bpmn:sequenceFlow id="Flow_MedicationToJoin" sourceRef="ServiceTask_MedicationReminder" targetRef="ParallelGateway_DailyJoin" />
      <bpmn:sequenceFlow id="Flow_MedicationRetryToJoin" sourceRef="BoundaryTimer_MedicationRetry" targetRef="ParallelGateway_DailyJoin" />
      <bpmn:sequenceFlow id="Flow_MealToMessageCatch" sourceRef="ServiceTask_MealChoice" targetRef="IntermediateMessage_PatientMealResponse" />
      <bpmn:sequenceFlow id="Flow_MealResponseToJoin" sourceRef="IntermediateMessage_PatientMealResponse" targetRef="ParallelGateway_DailyJoin" />
      <bpmn:sequenceFlow id="Flow_FamilyToJoin" sourceRef="ServiceTask_FamilyUpdate" targetRef="ParallelGateway_DailyJoin" />
      <bpmn:sequenceFlow id="Flow_JoinToEveningSummary" sourceRef="ParallelGateway_DailyJoin" targetRef="ServiceTask_EveningSummary" />
      <bpmn:sequenceFlow id="Flow_EveningToDischargeCheck" sourceRef="ServiceTask_EveningSummary" targetRef="ExclusiveGateway_DischargePlanned" />
      <bpmn:sequenceFlow id="Flow_ExitCycle" name="Yes" sourceRef="ExclusiveGateway_DischargePlanned" targetRef="EndEvent_DailyCycle">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${dischargePlanned == true}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_ContinueCycle" name="No" sourceRef="ExclusiveGateway_DischargePlanned" targetRef="EndEvent_ContinueCycle" />

    </bpmn:subProcess>

    <!-- Loop Boundary Event for Daily Cycle -->
    <bpmn:boundaryEvent id="BoundaryEvent_LoopDailyCycle"
                        name="Loop Daily Cycle"
                        attachedToRef="SubProcess_DailyCycle"
                        cancelActivity="false">
      <bpmn:outgoing>Flow_ContinueDailyCycle</bpmn:outgoing>
      <bpmn:conditionalEventDefinition>
        <bpmn:condition xsi:type="bpmn:tFormalExpression">${dischargePlanned == false}</bpmn:condition>
      </bpmn:conditionalEventDefinition>
    </bpmn:boundaryEvent>

    <!-- ============================================================ -->
    <!-- Discharge Preparation Notification                           -->
    <!-- ============================================================ -->
    <bpmn:serviceTask id="ServiceTask_DischargePrep"
                      name="Discharge Preparation Notification"
                      camunda:type="external"
                      camunda:topic="inpatient.discharge_prep">
      <bpmn:incoming>Flow_DailyCycleToDischargePrep</bpmn:incoming>
      <bpmn:outgoing>Flow_DischargePrepToMessage</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ============================================================ -->
    <!-- Message Throw Event: Discharge Initiated                     -->
    <!-- ============================================================ -->
    <bpmn:intermediateThrowEvent id="IntermediateThrow_DischargeInitiated"
                                  name="Discharge Initiated">
      <bpmn:incoming>Flow_DischargePrepToMessage</bpmn:incoming>
      <bpmn:outgoing>Flow_MessageToEnd</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_DischargeInitiated" />
    </bpmn:intermediateThrowEvent>

    <!-- ============================================================ -->
    <!-- End Event                                                    -->
    <!-- ============================================================ -->
    <bpmn:endEvent id="EndEvent_InpatientComplete" name="Inpatient Experience Complete">
      <bpmn:incoming>Flow_MessageToEnd</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ============================================================ -->
    <!-- Main Process Sequence Flows                                  -->
    <!-- ============================================================ -->
    <bpmn:sequenceFlow id="Flow_AdmissionToInit" sourceRef="StartEvent_AdmissionTrigger" targetRef="ServiceTask_InitPatientContext" />
    <bpmn:sequenceFlow id="Flow_InitToTeamIntro" sourceRef="ServiceTask_InitPatientContext" targetRef="ServiceTask_TeamIntroduction" />
    <bpmn:sequenceFlow id="Flow_TeamIntroToDailyCycle" sourceRef="ServiceTask_TeamIntroduction" targetRef="SubProcess_DailyCycle" />
    <bpmn:sequenceFlow id="Flow_ContinueDailyCycle" sourceRef="BoundaryEvent_LoopDailyCycle" targetRef="SubProcess_DailyCycle" />
    <bpmn:sequenceFlow id="Flow_DailyCycleToDischargePrep" sourceRef="SubProcess_DailyCycle" targetRef="ServiceTask_DischargePrep" />
    <bpmn:sequenceFlow id="Flow_DischargePrepToMessage" sourceRef="ServiceTask_DischargePrep" targetRef="IntermediateThrow_DischargeInitiated" />
    <bpmn:sequenceFlow id="Flow_MessageToEnd" sourceRef="IntermediateThrow_DischargeInitiated" targetRef="EndEvent_InpatientComplete" />

  </bpmn:process>

  <!-- ================================================================ -->
  <!-- BPMN Diagram Interchange (DI)                                    -->
  <!-- ================================================================ -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_SP_CO_011">
    <bpmndi:BPMNPlane id="BPMNPlane_SP_CO_011" bpmnElement="SP_CO_011_Patient_Inpatient_Experience">

      <!-- Start Event -->
      <bpmndi:BPMNShape id="Shape_StartEvent_AdmissionTrigger" bpmnElement="StartEvent_AdmissionTrigger">
        <dc:Bounds x="152" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="129" y="145" width="82" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Init Patient Context -->
      <bpmndi:BPMNShape id="Shape_ServiceTask_InitPatientContext" bpmnElement="ServiceTask_InitPatientContext">
        <dc:Bounds x="240" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Team Introduction -->
      <bpmndi:BPMNShape id="Shape_ServiceTask_TeamIntroduction" bpmnElement="ServiceTask_TeamIntroduction">
        <dc:Bounds x="390" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Daily Cycle Subprocess -->
      <bpmndi:BPMNShape id="Shape_SubProcess_DailyCycle" bpmnElement="SubProcess_DailyCycle" isExpanded="true">
        <dc:Bounds x="540" y="20" width="900" height="400" />
      </bpmndi:BPMNShape>

      <!-- Daily Cycle Inner Elements -->
      <bpmndi:BPMNShape id="Shape_StartEvent_DailyCycle" bpmnElement="StartEvent_DailyCycle">
        <dc:Bounds x="572" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="562" y="145" width="56" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_IntermediateTimer_MorningStart" bpmnElement="IntermediateTimer_MorningStart">
        <dc:Bounds x="652" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="634" y="145" width="72" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_ServiceTask_DailyPlan" bpmnElement="ServiceTask_DailyPlan">
        <dc:Bounds x="730" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_ParallelGateway_DailySplit" bpmnElement="ParallelGateway_DailySplit">
        <dc:Bounds x="875" y="95" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="858" y="152" width="84" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_ServiceTask_MedicationReminder" bpmnElement="ServiceTask_MedicationReminder">
        <dc:Bounds x="970" y="50" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_BoundaryTimer_MedicationRetry" bpmnElement="BoundaryTimer_MedicationRetry">
        <dc:Bounds x="1052" y="112" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1088" y="143" width="84" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_ServiceTask_MealChoice" bpmnElement="ServiceTask_MealChoice">
        <dc:Bounds x="970" y="150" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_IntermediateMessage_PatientMealResponse" bpmnElement="IntermediateMessage_PatientMealResponse">
        <dc:Bounds x="1102" y="172" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1076" y="215" width="88" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_ServiceTask_FamilyUpdate" bpmnElement="ServiceTask_FamilyUpdate">
        <dc:Bounds x="970" y="250" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_ParallelGateway_DailyJoin" bpmnElement="ParallelGateway_DailyJoin">
        <dc:Bounds x="1195" y="165" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1182" y="222" width="76" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_ServiceTask_EveningSummary" bpmnElement="ServiceTask_EveningSummary">
        <dc:Bounds x="1280" y="150" width="100" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_ExclusiveGateway_DischargePlanned" bpmnElement="ExclusiveGateway_DischargePlanned" isMarkerVisible="true">
        <dc:Bounds x="1305" y="295" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1291" y="352" width="78" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_EndEvent_DailyCycle" bpmnElement="EndEvent_DailyCycle">
        <dc:Bounds x="1392" y="302" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1384" y="345" width="52" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_EndEvent_ContinueCycle" bpmnElement="EndEvent_ContinueCycle">
        <dc:Bounds x="1312" y="372" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1296" y="415" width="68" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Daily Cycle Edges -->
      <bpmndi:BPMNEdge id="Edge_DailyStartToTimer" bpmnElement="Flow_DailyStartToTimer">
        <di:waypoint x="608" y="120" />
        <di:waypoint x="652" y="120" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_TimerToDailyPlan" bpmnElement="Flow_TimerToDailyPlan">
        <di:waypoint x="688" y="120" />
        <di:waypoint x="730" y="120" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_DailyPlanToParallelSplit" bpmnElement="Flow_DailyPlanToParallelSplit">
        <di:waypoint x="830" y="120" />
        <di:waypoint x="875" y="120" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_SplitToMedication" bpmnElement="Flow_SplitToMedication">
        <di:waypoint x="900" y="95" />
        <di:waypoint x="900" y="90" />
        <di:waypoint x="970" y="90" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_SplitToMeal" bpmnElement="Flow_SplitToMeal">
        <di:waypoint x="900" y="145" />
        <di:waypoint x="900" y="190" />
        <di:waypoint x="970" y="190" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_SplitToFamily" bpmnElement="Flow_SplitToFamily">
        <di:waypoint x="900" y="145" />
        <di:waypoint x="900" y="290" />
        <di:waypoint x="970" y="290" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_MedicationToJoin" bpmnElement="Flow_MedicationToJoin">
        <di:waypoint x="1070" y="90" />
        <di:waypoint x="1220" y="90" />
        <di:waypoint x="1220" y="165" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_MedicationRetryToJoin" bpmnElement="Flow_MedicationRetryToJoin">
        <di:waypoint x="1088" y="130" />
        <di:waypoint x="1220" y="130" />
        <di:waypoint x="1220" y="165" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_MealToMessageCatch" bpmnElement="Flow_MealToMessageCatch">
        <di:waypoint x="1070" y="190" />
        <di:waypoint x="1102" y="190" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_MealResponseToJoin" bpmnElement="Flow_MealResponseToJoin">
        <di:waypoint x="1138" y="190" />
        <di:waypoint x="1195" y="190" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_FamilyToJoin" bpmnElement="Flow_FamilyToJoin">
        <di:waypoint x="1070" y="290" />
        <di:waypoint x="1220" y="290" />
        <di:waypoint x="1220" y="215" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_JoinToEveningSummary" bpmnElement="Flow_JoinToEveningSummary">
        <di:waypoint x="1245" y="190" />
        <di:waypoint x="1280" y="190" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_EveningToDischargeCheck" bpmnElement="Flow_EveningToDischargeCheck">
        <di:waypoint x="1330" y="230" />
        <di:waypoint x="1330" y="295" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_ExitCycle" bpmnElement="Flow_ExitCycle">
        <di:waypoint x="1355" y="320" />
        <di:waypoint x="1392" y="320" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1361" y="302" width="18" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_ContinueCycle" bpmnElement="Flow_ContinueCycle">
        <di:waypoint x="1330" y="345" />
        <di:waypoint x="1330" y="372" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1339" y="356" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- Discharge Prep -->
      <bpmndi:BPMNShape id="Shape_ServiceTask_DischargePrep" bpmnElement="ServiceTask_DischargePrep">
        <dc:Bounds x="1490" y="80" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Message Throw -->
      <bpmndi:BPMNShape id="Shape_IntermediateThrow_DischargeInitiated" bpmnElement="IntermediateThrow_DischargeInitiated">
        <dc:Bounds x="1642" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1622" y="145" width="76" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- End Event -->
      <bpmndi:BPMNShape id="Shape_EndEvent_InpatientComplete" bpmnElement="EndEvent_InpatientComplete">
        <dc:Bounds x="1732" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1712" y="145" width="76" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Loop Boundary Event -->
