<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                   xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                   xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                   xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                   xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   id="Definitions_clinical_ops_main"
                   targetNamespace="http://cib7.healthcare/clinical-operations"
                   exporter="CIB Seven 2.1.3"
                   exporterVersion="1.0">

  <!-- Error Definitions -->
  <bpmn:error id="Error_ClinicalOps" name="CLINICAL_OPS_ERROR" errorCode="CO_ERROR"/>
  <bpmn:error id="Error_SurgicalTimeout" name="SURGICAL_TIMEOUT" errorCode="CO_SURGICAL_TIMEOUT"/>

  <!-- Message Definitions -->
  <bpmn:message id="msg_patient_ready_for_care" name="msg_patient_ready_for_care"/>
  <bpmn:message id="msg_clinical_documentation_ready" name="msg_clinical_documentation_ready"/>
  <bpmn:message id="msg_discharge_completed" name="msg_discharge_completed"/>
  <bpmn:message id="msg_lab_results_ready" name="msg_lab_results_ready"/>
  <bpmn:message id="msg_sepsis_alert" name="msg_sepsis_alert"/>
  <bpmn:message id="msg_procedures_completed" name="msg_procedures_completed"/>

  <!-- Main Process -->
  <bpmn:process id="clinical_ops_main" name="Clinical Operations Orchestrator" isExecutable="true">

    <!-- Start Event -->
    <bpmn:startEvent id="start_patient_ready" name="Patient Ready for Care">
      <bpmn:outgoing>flow_to_triage</bpmn:outgoing>
      <bpmn:messageEventDefinition id="msgEvtDef_start" messageRef="msg_patient_ready_for_care"/>
    </bpmn:startEvent>

    <!-- Call Activity: Triage & Routing -->
    <bpmn:callActivity id="call_SP_CO_001" name="Executar Triagem e Roteamento Clínico" calledElement="SP_CO_001_Triage_Routing">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="encounterFhirId" target="encounterFhirId"/>
        <camunda:in source="patientFhirId" target="patientFhirId"/>
        <camunda:out source="triageCategory" target="triageCategory"/>
        <camunda:out source="assignedLocation" target="assignedLocation"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_triage</bpmn:incoming>
      <bpmn:outgoing>flow_to_admission_gateway</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Error Boundary: Triage -->
    <bpmn:boundaryEvent id="error_SP_CO_001" name="Triage Error" attachedToRef="call_SP_CO_001">
      <bpmn:outgoing>flow_to_error_end_1</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_CO_001" errorRef="Error_ClinicalOps"/>
    </bpmn:boundaryEvent>

    <!-- Exclusive Gateway: Admission Required? -->
    <bpmn:exclusiveGateway id="gateway_admission_required" name="Admission required?">
      <bpmn:incoming>flow_to_admission_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_admission_yes</bpmn:outgoing>
      <bpmn:outgoing>flow_admission_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Call Activity: Admission & Beds (Inpatient) -->
    <bpmn:callActivity id="call_SP_CO_002" name="Gerenciar Admissão e Alocação de Leitos" calledElement="SP_CO_002_Admission_Beds">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="encounterFhirId" target="encounterFhirId"/>
        <camunda:in source="patientFhirId" target="patientFhirId"/>
        <camunda:in source="triageCategory" target="triageCategory"/>
        <camunda:out source="bedFhirId" target="bedFhirId"/>
        <camunda:out source="admissionComplete" target="admissionComplete"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_admission_yes</bpmn:incoming>
      <bpmn:outgoing>flow_to_merge_admission</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Error Boundary: Admission -->
    <bpmn:boundaryEvent id="error_SP_CO_002" name="Admission Error" attachedToRef="call_SP_CO_002">
      <bpmn:outgoing>flow_to_error_end_2</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_CO_002" errorRef="Error_ClinicalOps"/>
    </bpmn:boundaryEvent>

    <!-- Exclusive Gateway: Merge Admission -->
    <bpmn:exclusiveGateway id="gateway_merge_admission" name="Merge">
      <bpmn:incoming>flow_to_merge_admission</bpmn:incoming>
      <bpmn:incoming>flow_admission_no</bpmn:incoming>
      <bpmn:outgoing>flow_to_care_team</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Call Activity: Care Team Orchestration -->
    <bpmn:callActivity id="call_SP_CO_003" name="Orquestrar Equipe de Cuidado e Tarefas" calledElement="SP_CO_003_Care_Team">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="encounterFhirId" target="encounterFhirId"/>
        <camunda:in source="patientFhirId" target="patientFhirId"/>
        <camunda:in source="triageCategory" target="triageCategory"/>
        <camunda:out source="careTeamFhirId" target="careTeamFhirId"/>
        <camunda:out source="carePlanFhirId" target="carePlanFhirId"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_care_team</bpmn:incoming>
      <bpmn:outgoing>flow_to_parallel_fork</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Error Boundary: Care Team -->
    <bpmn:boundaryEvent id="error_SP_CO_003" name="Care Team Error" attachedToRef="call_SP_CO_003">
      <bpmn:outgoing>flow_to_error_end_3</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_CO_003" errorRef="Error_ClinicalOps"/>
    </bpmn:boundaryEvent>

    <!-- MSG-003: SepsisAlert catch (interrupting) - activates sepsis protocol -->
    <bpmn:boundaryEvent id="catch_sepsis_alert" name="Sepsis Alert" cancelActivity="true" attachedToRef="call_SP_CO_003">
      <bpmn:outgoing>flow_sepsis_alert_to_handler</bpmn:outgoing>
      <bpmn:messageEventDefinition id="msgEvtDef_sepsis_alert" messageRef="msg_sepsis_alert"/>
    </bpmn:boundaryEvent>

    <!-- Service Task: Activate Sepsis Protocol -->
    <bpmn:serviceTask id="task_activate_sepsis_protocol" name="Activate Sepsis Protocol (Hour-1 Bundle)" camunda:class="com.cib7.healthcare.delegates.SepsisProtocolDelegate">
      <bpmn:incoming>flow_sepsis_alert_to_handler</bpmn:incoming>
      <bpmn:outgoing>flow_sepsis_protocol_to_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- End Event: Sepsis Protocol Activated -->
    <bpmn:endEvent id="end_sepsis_protocol" name="Sepsis Protocol Activated">
      <bpmn:incoming>flow_sepsis_protocol_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Parallel Gateway: Fork Clinical Activities -->
    <bpmn:parallelGateway id="gateway_parallel_fork" name="Fork Clinical Activities">
      <bpmn:incoming>flow_to_parallel_fork</bpmn:incoming>
      <bpmn:outgoing>flow_to_prescriptions</bpmn:outgoing>
      <bpmn:outgoing>flow_to_diagnostics</bpmn:outgoing>
      <bpmn:outgoing>flow_to_medication</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- Call Activity: Prescriptions & CDS (Multi-Instance Sequential) -->
    <bpmn:callActivity id="call_SP_CO_004" name="Processar Prescrições e Suporte à Decisão" calledElement="SP_CO_004_Prescriptions_CDS">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="encounterFhirId" target="encounterFhirId"/>
        <camunda:in source="patientFhirId" target="patientFhirId"/>
        <camunda:in source="carePlanFhirId" target="carePlanFhirId"/>
        <camunda:out source="prescriptionFhirId" target="prescriptionFhirId"/>
        <camunda:out source="cdsAlerts" target="cdsAlerts"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_prescriptions</bpmn:incoming>
      <bpmn:outgoing>flow_prescriptions_to_join</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics isSequential="true">
        <bpmn:loopCardinality xsi:type="bpmn:tFormalExpression">${prescriptionCount}</bpmn:loopCardinality>
      </bpmn:multiInstanceLoopCharacteristics>
    </bpmn:callActivity>

    <!-- Error Boundary: Prescriptions -->
    <bpmn:boundaryEvent id="error_SP_CO_004" name="Prescription Error" attachedToRef="call_SP_CO_004">
      <bpmn:outgoing>flow_to_error_end_4</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_CO_004" errorRef="Error_ClinicalOps"/>
    </bpmn:boundaryEvent>

    <!-- Intermediate Message Catch: Lab Results Ready -->
    <bpmn:intermediateCatchEvent id="event_lab_results_ready" name="Lab Results Ready">
      <bpmn:incoming>flow_to_diagnostics</bpmn:incoming>
      <bpmn:outgoing>flow_lab_to_diagnostics</bpmn:outgoing>
      <bpmn:messageEventDefinition id="msgEvtDef_lab" messageRef="msg_lab_results_ready"/>
    </bpmn:intermediateCatchEvent>

    <!-- Call Activity: Diagnostics & Results (Multi-Instance Parallel) -->
    <bpmn:callActivity id="call_SP_CO_005" name="Gerenciar Diagnósticos e Resultados" calledElement="SP_CO_005_Diagnostics_Results">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="encounterFhirId" target="encounterFhirId"/>
        <camunda:in source="patientFhirId" target="patientFhirId"/>
        <camunda:in source="carePlanFhirId" target="carePlanFhirId"/>
        <camunda:out source="diagnosticReportFhirId" target="diagnosticReportFhirId"/>
        <camunda:out source="observationFhirIds" target="observationFhirIds"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_lab_to_diagnostics</bpmn:incoming>
      <bpmn:outgoing>flow_diagnostics_to_join</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics isSequential="false">
        <bpmn:loopCardinality xsi:type="bpmn:tFormalExpression">${diagnosticOrderCount}</bpmn:loopCardinality>
      </bpmn:multiInstanceLoopCharacteristics>
    </bpmn:callActivity>

    <!-- Error Boundary: Diagnostics -->
    <bpmn:boundaryEvent id="error_SP_CO_005" name="Diagnostics Error" attachedToRef="call_SP_CO_005">
      <bpmn:outgoing>flow_to_error_end_5</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_CO_005" errorRef="Error_ClinicalOps"/>
    </bpmn:boundaryEvent>

    <!-- Call Activity: Medication Management -->
    <bpmn:callActivity id="call_SP_CO_006" name="Executar Gestão de Medicamentos" calledElement="SP_CO_006_Medication_Management">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="encounterFhirId" target="encounterFhirId"/>
        <camunda:in source="patientFhirId" target="patientFhirId"/>
        <camunda:in source="prescriptionFhirId" target="prescriptionFhirId"/>
        <camunda:out source="medicationAdministrationFhirId" target="medicationAdministrationFhirId"/>
        <camunda:out source="dispensingStatus" target="dispensingStatus"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_medication</bpmn:incoming>
      <bpmn:outgoing>flow_medication_to_join</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Error Boundary: Medication -->
    <bpmn:boundaryEvent id="error_SP_CO_006" name="Medication Error" attachedToRef="call_SP_CO_006">
      <bpmn:outgoing>flow_to_error_end_6</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_CO_006" errorRef="Error_ClinicalOps"/>
    </bpmn:boundaryEvent>

    <!-- Parallel Gateway: Join Clinical Activities -->
    <bpmn:parallelGateway id="gateway_parallel_join" name="Join Clinical Activities">
      <bpmn:incoming>flow_prescriptions_to_join</bpmn:incoming>
      <bpmn:incoming>flow_diagnostics_to_join</bpmn:incoming>
      <bpmn:incoming>flow_medication_to_join</bpmn:incoming>
      <bpmn:outgoing>flow_to_surgical_gateway</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- Exclusive Gateway: Surgical Procedure Needed? -->
    <bpmn:exclusiveGateway id="gateway_surgical_required" name="Surgical procedure needed?">
      <bpmn:incoming>flow_to_surgical_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_surgical_yes</bpmn:outgoing>
      <bpmn:outgoing>flow_surgical_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Call Activity: Surgical Services -->
    <bpmn:callActivity id="call_SP_CO_007" name="Coordenar Serviços Cirúrgicos" calledElement="SP_CO_007_Surgical_Services">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="encounterFhirId" target="encounterFhirId"/>
        <camunda:in source="patientFhirId" target="patientFhirId"/>
        <camunda:in source="carePlanFhirId" target="carePlanFhirId"/>
        <camunda:out source="procedureFhirId" target="procedureFhirId"/>
        <camunda:out source="surgicalOutcome" target="surgicalOutcome"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_surgical_yes</bpmn:incoming>
      <bpmn:outgoing>flow_to_merge_surgical</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Timer Boundary: Surgical OR Scheduling SLA (30 minutes) -->
    <bpmn:boundaryEvent id="timer_SP_CO_007" name="OR Scheduling SLA" cancelActivity="true" attachedToRef="call_SP_CO_007">
      <bpmn:outgoing>flow_to_surgical_timeout_end</bpmn:outgoing>
      <bpmn:timerEventDefinition id="timerDef_CO_007">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT30M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- Error Boundary: Surgical -->
    <bpmn:boundaryEvent id="error_SP_CO_007" name="Surgical Error" attachedToRef="call_SP_CO_007">
      <bpmn:outgoing>flow_to_error_end_7</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_CO_007" errorRef="Error_ClinicalOps"/>
    </bpmn:boundaryEvent>

    <!-- Exclusive Gateway: Merge Surgical -->
    <bpmn:exclusiveGateway id="gateway_merge_surgical" name="Merge">
      <bpmn:incoming>flow_to_merge_surgical</bpmn:incoming>
      <bpmn:incoming>flow_surgical_no</bpmn:incoming>
      <bpmn:outgoing>flow_to_documentation_message</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- MSG-002: ProceduresCompleted throw (Clinical Ops → Revenue Cycle) -->
    <bpmn:intermediateThrowEvent id="throw_procedures_completed" name="Procedures Completed">
      <bpmn:incoming>flow_to_documentation_message</bpmn:incoming>
      <bpmn:outgoing>flow_procedures_to_documentation</bpmn:outgoing>
      <bpmn:messageEventDefinition id="msgEvtDef_procedures_completed" messageRef="msg_procedures_completed"/>
    </bpmn:intermediateThrowEvent>

    <!-- Intermediate Message Throw: Clinical Documentation Ready -->
    <bpmn:intermediateThrowEvent id="event_documentation_ready" name="Clinical Documentation Ready">
      <bpmn:incoming>flow_procedures_to_documentation</bpmn:incoming>
      <bpmn:outgoing>flow_to_discharge_message</bpmn:outgoing>
      <bpmn:messageEventDefinition id="msgEvtDef_documentation" messageRef="msg_clinical_documentation_ready"/>
    </bpmn:intermediateThrowEvent>

    <!-- Intermediate Message Throw: Discharge Completed -->
    <bpmn:intermediateThrowEvent id="event_discharge_completed" name="Discharge Completed">
      <bpmn:incoming>flow_to_discharge_message</bpmn:incoming>
      <bpmn:outgoing>flow_to_end</bpmn:outgoing>
      <bpmn:messageEventDefinition id="msgEvtDef_discharge" messageRef="msg_discharge_completed"/>
    </bpmn:intermediateThrowEvent>

    <!-- End Event: Success -->
    <bpmn:endEvent id="end_success" name="Clinical Operations Complete">
      <bpmn:incoming>flow_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- End Events: Errors -->
    <bpmn:endEvent id="error_end_1" name="Triage Error">
      <bpmn:incoming>flow_to_error_end_1</bpmn:incoming>
      <bpmn:errorEventDefinition id="errEvtDef_end_1" errorRef="Error_ClinicalOps"/>
    </bpmn:endEvent>

    <bpmn:endEvent id="error_end_2" name="Admission Error">
      <bpmn:incoming>flow_to_error_end_2</bpmn:incoming>
      <bpmn:errorEventDefinition id="errEvtDef_end_2" errorRef="Error_ClinicalOps"/>
    </bpmn:endEvent>

    <bpmn:endEvent id="error_end_3" name="Care Team Error">
      <bpmn:incoming>flow_to_error_end_3</bpmn:incoming>
      <bpmn:errorEventDefinition id="errEvtDef_end_3" errorRef="Error_ClinicalOps"/>
    </bpmn:endEvent>

    <bpmn:endEvent id="error_end_4" name="Prescription Error">
      <bpmn:incoming>flow_to_error_end_4</bpmn:incoming>
      <bpmn:errorEventDefinition id="errEvtDef_end_4" errorRef="Error_ClinicalOps"/>
    </bpmn:endEvent>

    <bpmn:endEvent id="error_end_5" name="Diagnostics Error">
      <bpmn:incoming>flow_to_error_end_5</bpmn:incoming>
      <bpmn:errorEventDefinition id="errEvtDef_end_5" errorRef="Error_ClinicalOps"/>
    </bpmn:endEvent>

    <bpmn:endEvent id="error_end_6" name="Medication Error">
      <bpmn:incoming>flow_to_error_end_6</bpmn:incoming>
      <bpmn:errorEventDefinition id="errEvtDef_end_6" errorRef="Error_ClinicalOps"/>
    </bpmn:endEvent>

    <bpmn:endEvent id="error_end_7" name="Surgical Error">
      <bpmn:incoming>flow_to_error_end_7</bpmn:incoming>
      <bpmn:errorEventDefinition id="errEvtDef_end_7" errorRef="Error_ClinicalOps"/>
    </bpmn:endEvent>

    <bpmn:endEvent id="surgical_timeout_end" name="Surgical Timeout">
      <bpmn:incoming>flow_to_surgical_timeout_end</bpmn:incoming>
      <bpmn:errorEventDefinition id="errEvtDef_timeout" errorRef="Error_SurgicalTimeout"/>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="flow_to_triage" sourceRef="start_patient_ready" targetRef="call_SP_CO_001"/>
    <bpmn:sequenceFlow id="flow_to_admission_gateway" sourceRef="call_SP_CO_001" targetRef="gateway_admission_required"/>
    <bpmn:sequenceFlow id="flow_admission_yes" name="Yes (Inpatient)" sourceRef="gateway_admission_required" targetRef="call_SP_CO_002">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${triageCategory == 'inpatient' || triageCategory == 'emergency_admission'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_admission_no" name="No (Outpatient)" sourceRef="gateway_admission_required" targetRef="gateway_merge_admission">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${triageCategory == 'outpatient' || triageCategory == 'urgent_care'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_to_merge_admission" sourceRef="call_SP_CO_002" targetRef="gateway_merge_admission"/>
    <bpmn:sequenceFlow id="flow_to_care_team" sourceRef="gateway_merge_admission" targetRef="call_SP_CO_003"/>
    <bpmn:sequenceFlow id="flow_to_parallel_fork" sourceRef="call_SP_CO_003" targetRef="gateway_parallel_fork"/>
    <bpmn:sequenceFlow id="flow_to_prescriptions" sourceRef="gateway_parallel_fork" targetRef="call_SP_CO_004"/>
    <bpmn:sequenceFlow id="flow_to_diagnostics" sourceRef="gateway_parallel_fork" targetRef="event_lab_results_ready"/>
    <bpmn:sequenceFlow id="flow_lab_to_diagnostics" sourceRef="event_lab_results_ready" targetRef="call_SP_CO_005"/>
    <bpmn:sequenceFlow id="flow_to_medication" sourceRef="gateway_parallel_fork" targetRef="call_SP_CO_006"/>
    <bpmn:sequenceFlow id="flow_prescriptions_to_join" sourceRef="call_SP_CO_004" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="flow_diagnostics_to_join" sourceRef="call_SP_CO_005" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="flow_medication_to_join" sourceRef="call_SP_CO_006" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="flow_to_surgical_gateway" sourceRef="gateway_parallel_join" targetRef="gateway_surgical_required"/>
    <bpmn:sequenceFlow id="flow_surgical_yes" name="Yes" sourceRef="gateway_surgical_required" targetRef="call_SP_CO_007">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${surgicalRequired == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_surgical_no" name="No" sourceRef="gateway_surgical_required" targetRef="gateway_merge_surgical">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${surgicalRequired == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_to_merge_surgical" sourceRef="call_SP_CO_007" targetRef="gateway_merge_surgical"/>
    <bpmn:sequenceFlow id="flow_to_documentation_message" sourceRef="gateway_merge_surgical" targetRef="throw_procedures_completed"/>
    <bpmn:sequenceFlow id="flow_procedures_to_documentation" sourceRef="throw_procedures_completed" targetRef="event_documentation_ready"/>
    <bpmn:sequenceFlow id="flow_to_discharge_message" sourceRef="event_documentation_ready" targetRef="event_discharge_completed"/>

    <!-- Sepsis Alert flows -->
    <bpmn:sequenceFlow id="flow_sepsis_alert_to_handler" sourceRef="catch_sepsis_alert" targetRef="task_activate_sepsis_protocol"/>
    <bpmn:sequenceFlow id="flow_sepsis_protocol_to_end" sourceRef="task_activate_sepsis_protocol" targetRef="end_sepsis_protocol"/>
    <bpmn:sequenceFlow id="flow_to_end" sourceRef="event_discharge_completed" targetRef="end_success"/>

    <!-- Error Flows -->
    <bpmn:sequenceFlow id="flow_to_error_end_1" sourceRef="error_SP_CO_001" targetRef="error_end_1"/>
    <bpmn:sequenceFlow id="flow_to_error_end_2" sourceRef="error_SP_CO_002" targetRef="error_end_2"/>
    <bpmn:sequenceFlow id="flow_to_error_end_3" sourceRef="error_SP_CO_003" targetRef="error_end_3"/>
    <bpmn:sequenceFlow id="flow_to_error_end_4" sourceRef="error_SP_CO_004" targetRef="error_end_4"/>
    <bpmn:sequenceFlow id="flow_to_error_end_5" sourceRef="error_SP_CO_005" targetRef="error_end_5"/>
    <bpmn:sequenceFlow id="flow_to_error_end_6" sourceRef="error_SP_CO_006" targetRef="error_end_6"/>
    <bpmn:sequenceFlow id="flow_to_error_end_7" sourceRef="error_SP_CO_007" targetRef="error_end_7"/>
    <bpmn:sequenceFlow id="flow_to_surgical_timeout_end" sourceRef="timer_SP_CO_007" targetRef="surgical_timeout_end"/>

  </bpmn:process>

  <!-- BPMN Diagram -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_clinical_ops_main">
    <bpmndi:BPMNPlane id="BPMNPlane_clinical_ops_main" bpmnElement="clinical_ops_main">

      <!-- Start Event -->
      <bpmndi:BPMNShape id="shape_start_patient_ready" bpmnElement="start_patient_ready">
        <dc:Bounds x="152" y="192" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="135" y="235" width="70" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Call Activity: Triage -->
      <bpmndi:BPMNShape id="shape_call_SP_CO_001" bpmnElement="call_SP_CO_001">
        <dc:Bounds x="240" y="170" width="100" height="80"/>
