<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_AdminAdjudication"
                  targetNamespace="http://cib7.healthcare/templates"
                  exporter="Camunda Modeler"
                  exporterVersion="5.20.0">

  <!--
    TEMPLATE: BPMN_ADMIN_ADJUDICATION v2.0
    Purpose: Administrative decision subprocess for eligibility, authorization, billing
    DMN Archetype: ADMIN_ADJUDICATION (3 outputs: resultado, acao, risco)
    Coverage: 95 workers across revenue cycle domain (largest pattern)
    ADR Compliance: ADR-002 (tenant resolution), ADR-007 (DMN federation)
    Migration Wave: Foundation (2026-Q1)
    
    Pattern:
      1. Fetch administrative/billing data
      2. Evaluate DMN adjudication rules
      3. Route based on decision (PROSSEGUIR/BLOQUEAR/REVISAR)
      4. Take automated action or escalate to human review
      5. Handle SLA breaches with escalation
    
    Variables:
      Input:  requestId, requestType, requestData, tenantId
      Output: resultado, acao, risco, decision_timestamp, approvalStatus
    
    Use Cases:
      - Eligibility verification (validate_eligibility worker)
      - Prior authorization (request_authorization worker)
      - Billing adjudication (adjudicate_claim worker)
      - Glosa analysis (analyze_glosa worker)
      - Coverage determination (determine_coverage worker)
  -->

  <bpmn:process id="TEMPLATE_Admin_Adjudication" name="[Admin Adjudication Template]" isExecutable="true">

    <!-- Start Event -->
    <bpmn:startEvent id="start_adjudication" name="Início Adjudicação">
      <bpmn:documentation>
        TENANT RESOLUTION (ADR-002):
        
        CIB Seven 2.1.3 resolves tenant markers at process instantiation:
        
        1. Read process variable `tenantId` from execution context
        2. Resolve tenant marker from environment variable mapping:
           - HOSPITAL_A_MARKER=hospital-a
           - AMH_SP_MORUMBI_MARKER=amh-sp-morumbi
           - AMH_SP_ALPHAVILLE_MARKER=amh-sp-alphaville
           - AMH_SP_LAPA_MARKER=amh-sp-lapa
        3. Available markers: hospital-a, amh-sp-morumbi, amh-sp-alphaville, amh-sp-lapa, 
           amh-rj-botafogo, amh-rj-barra, amh-bh-lourdes, amh-bh-savassi
        4. If `tenantId` unset: default to `hospital-a`
        
        Tenant marker affects:
        - DMN table resolution (ADR-007)
        - Database query tenant filters (ADR-002)
        - Worker topic subscription (e.g., hospital-a.revenue-cycle.validate-eligibility)
        - LGPD data hashing salt (ADR-011)
        
        Workers read tenant marker from TaskContext.tenant_id property.
      </bpmn:documentation>
      <bpmn:outgoing>flow_to_fetch</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Service Task: Fetch Administrative Data -->
    <bpmn:serviceTask id="task_fetch_admin_data" name="Buscar Dados Administrativos" camunda:type="external" camunda:topic="{domain}.{subdomain}.fetch-admin-data">
      <bpmn:documentation>
        Worker: {domain}.{subdomain}.fetch-admin-data
        Fetches: Coverage, claims, authorization history, payer rules
        Integration: TasyApiClient + Payer APIs
      </bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="requestId">${requestId}</camunda:inputParameter>
          <camunda:inputParameter name="requestType">${requestType}</camunda:inputParameter>
          <camunda:outputParameter name="adminContext">${context}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_fetch</bpmn:incoming>
      <bpmn:outgoing>flow_to_dmn_adjudication</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Business Rule Task: Evaluate DMN Adjudication -->
    <bpmn:businessRuleTask id="dmn_evaluate_adjudication" name="Avaliar Regra de Adjudicação">
      <bpmn:documentation>
        DMN FEDERATION (ADR-007):
        
        CIB Seven 2.1.3 resolves DMN tables using 2-level federation hierarchy:
        
        1. Decision key format: {category}/{subcategory}/{table_name}
           Example: revenue-cycle/eligibility/validate_eligibility
        
        2. Resolution order (tenant-first with global fallback):
           a) Try: /dmn/{tenant_marker}/{category}/{subcategory}/{table_name}.dmn
              Example: /dmn/amh-sp-morumbi/revenue-cycle/eligibility/validate_eligibility.dmn
           b) Fallback: /dmn/global/{category}/{subcategory}/{table_name}.dmn
              Example: /dmn/global/revenue-cycle/eligibility/validate_eligibility.dmn
        
        3. Tenant overrides use case:
           - amh-sp-morumbi: Stricter authorization thresholds (private hospital)
           - hospital-a: Standard public hospital rules (SUS guidelines)
           - amh-rj-botafogo: Local payer network rules (Rio de Janeiro)
        
        4. If both files missing: Process fails with DecisionDefinitionNotFoundException
        
        DMN ARCHETYPE: ADMIN_ADJUDICATION
        Inputs: requestId, requestType, adminContext (from previous task)
        Outputs: 
          - resultado: string (PROSSEGUIR|BLOQUEAR|REVISAR)
          - acao: string (approve|deny|review|escalate)
          - risco: string (ALTO|MEDIO|BAIXO)
        
        Workers implement DMN evaluation via BaseExternalTaskWorker.evaluate_dmn()
      </bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:decisionRef>{dmn_table_name}</camunda:decisionRef>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_dmn_adjudication</bpmn:incoming>
      <bpmn:outgoing>flow_to_decision_gateway</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <!-- Exclusive Gateway: Decision Routing -->
    <bpmn:exclusiveGateway id="gateway_decision" name="Resultado?" default="flow_review">
      <bpmn:incoming>flow_to_decision_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_proceed</bpmn:outgoing>
      <bpmn:outgoing>flow_block</bpmn:outgoing>
      <bpmn:outgoing>flow_review</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Proceed Path: Auto-Approve -->
    <bpmn:serviceTask id="task_auto_approve" name="Aprovar Automaticamente" camunda:type="external" camunda:topic="{domain}.{subdomain}.auto-approve">
      <bpmn:documentation>
        Worker: {domain}.{subdomain}.auto-approve
        Action: Update status, trigger billing/scheduling, notify requestor
      </bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="requestId">${requestId}</camunda:inputParameter>
          <camunda:inputParameter name="acao">${acao}</camunda:inputParameter>
          <camunda:outputParameter name="approvalTimestamp">${timestamp}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_proceed</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_approved</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Block Path: Auto-Deny -->
    <bpmn:serviceTask id="task_auto_deny" name="Negar Automaticamente" camunda:type="external" camunda:topic="{domain}.{subdomain}.auto-deny">
      <bpmn:documentation>
        Worker: {domain}.{subdomain}.auto-deny
        Action: Update status, generate denial notice, log reason
      </bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="requestId">${requestId}</camunda:inputParameter>
          <camunda:inputParameter name="acao">${acao}</camunda:inputParameter>
          <camunda:inputParameter name="risco">${risco}</camunda:inputParameter>
          <camunda:outputParameter name="denialReason">${reason}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_block</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_denied</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Review Path: Human Review Task -->
    <bpmn:userTask id="task_human_review" name="Revisão Humana">
      <bpmn:documentation>
        Assignee: Authorization Specialist or Billing Analyst
        Reason: Complex case requiring human judgment
        Context: DMN suggested REVISAR (ambiguous rules, high risk)
      </bpmn:documentation>
      <bpmn:extensionElements>
        <camunda:assignee>${reviewerUserId}</camunda:assignee>
        <camunda:formKey>form_adjudication_review</camunda:formKey>
        <camunda:inputOutput>
          <camunda:inputParameter name="requestId">${requestId}</camunda:inputParameter>
          <camunda:inputParameter name="adminContext">${adminContext}</camunda:inputParameter>
          <camunda:inputParameter name="dmnSuggestion">${acao}</camunda:inputParameter>
          <camunda:inputParameter name="risco">${risco}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_review</bpmn:incoming>
      <bpmn:outgoing>flow_to_review_gateway</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Timer Boundary: SLA Escalation -->
    <bpmn:boundaryEvent id="timer_sla_breach" name="SLA 24h" attachedToRef="task_human_review" cancelActivity="false">
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration>PT24H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
      <bpmn:outgoing>flow_to_escalate</bpmn:outgoing>
    </bpmn:boundaryEvent>

    <!-- Service Task: Escalate to Supervisor -->
    <bpmn:serviceTask id="task_escalate_supervisor" name="Escalar para Supervisor" camunda:type="external" camunda:topic="{domain}.{subdomain}.escalate-review">
      <bpmn:documentation>
        Worker: {domain}.{subdomain}.escalate-review
        Action: Notify supervisor, update priority, extend SLA
      </bpmn:documentation>
      <bpmn:incoming>flow_to_escalate</bpmn:incoming>
      <bpmn:outgoing>flow_escalation_complete</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Exclusive Gateway: Human Decision -->
    <bpmn:exclusiveGateway id="gateway_human_decision" name="Decisão do Revisor?" default="flow_human_deny">
      <bpmn:incoming>flow_to_review_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_human_approve</bpmn:outgoing>
      <bpmn:outgoing>flow_human_deny</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Service Task: Process Human Approval -->
    <bpmn:serviceTask id="task_process_approval" name="Processar Aprovação" camunda:type="external" camunda:topic="{domain}.{subdomain}.process-approval">
      <bpmn:incoming>flow_human_approve</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_reviewed_approved</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Service Task: Process Human Denial -->
    <bpmn:serviceTask id="task_process_denial" name="Processar Negação" camunda:type="external" camunda:topic="{domain}.{subdomain}.process-denial">
      <bpmn:incoming>flow_human_deny</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_reviewed_denied</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Error Boundary: Data Fetch Failure -->
    <bpmn:boundaryEvent id="error_fetch_failure" name="Erro ao Buscar Dados" attachedToRef="task_fetch_admin_data">
      <bpmn:errorEventDefinition errorRef="Error_DataFetchFailed"/>
      <bpmn:outgoing>flow_to_retry</bpmn:outgoing>
    </bpmn:boundaryEvent>

    <!-- Service Task: Retry Logic -->
    <bpmn:serviceTask id="task_retry_fetch" name="Retentar Busca" camunda:type="external" camunda:topic="{domain}.{subdomain}.retry-fetch">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="retryCount">${retryCount + 1}</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_retry</bpmn:incoming>
      <bpmn:outgoing>flow_retry_to_dmn</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- End Events -->
    <bpmn:endEvent id="end_approved" name="Auto-Aprovado">
      <bpmn:incoming>flow_to_end_approved</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="end_denied" name="Auto-Negado">
      <bpmn:incoming>flow_to_end_denied</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="end_reviewed_approved" name="Revisado - Aprovado">
      <bpmn:incoming>flow_to_end_reviewed_approved</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="end_reviewed_denied" name="Revisado - Negado">
      <bpmn:incoming>flow_to_end_reviewed_denied</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="end_escalated" name="Escalado">
      <bpmn:incoming>flow_escalation_complete</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="flow_to_fetch" sourceRef="start_adjudication" targetRef="task_fetch_admin_data"/>
    <bpmn:sequenceFlow id="flow_to_dmn_adjudication" sourceRef="task_fetch_admin_data" targetRef="dmn_evaluate_adjudication"/>
    <bpmn:sequenceFlow id="flow_to_decision_gateway" sourceRef="dmn_evaluate_adjudication" targetRef="gateway_decision"/>
    
    <bpmn:sequenceFlow id="flow_proceed" name="PROSSEGUIR" sourceRef="gateway_decision" targetRef="task_auto_approve">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${resultado == "PROSSEGUIR"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="flow_block" name="BLOQUEAR" sourceRef="gateway_decision" targetRef="task_auto_deny">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${resultado == "BLOQUEAR"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="flow_review" name="REVISAR" sourceRef="gateway_decision" targetRef="task_human_review">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${resultado == "REVISAR"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    
    <bpmn:sequenceFlow id="flow_to_end_approved" sourceRef="task_auto_approve" targetRef="end_approved"/>
    <bpmn:sequenceFlow id="flow_to_end_denied" sourceRef="task_auto_deny" targetRef="end_denied"/>
    <bpmn:sequenceFlow id="flow_to_review_gateway" sourceRef="task_human_review" targetRef="gateway_human_decision"/>
    <bpmn:sequenceFlow id="flow_to_escalate" sourceRef="timer_sla_breach" targetRef="task_escalate_supervisor"/>
    <bpmn:sequenceFlow id="flow_escalation_complete" sourceRef="task_escalate_supervisor" targetRef="end_escalated"/>
    
    <bpmn:sequenceFlow id="flow_human_approve" name="Aprovar" sourceRef="gateway_human_decision" targetRef="task_process_approval">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${humanDecision == "APPROVE"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="flow_human_deny" name="Negar" sourceRef="gateway_human_decision" targetRef="task_process_denial">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${humanDecision == "DENY"}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    
    <bpmn:sequenceFlow id="flow_to_end_reviewed_approved" sourceRef="task_process_approval" targetRef="end_reviewed_approved"/>
    <bpmn:sequenceFlow id="flow_to_end_reviewed_denied" sourceRef="task_process_denial" targetRef="end_reviewed_denied"/>
    <bpmn:sequenceFlow id="flow_to_retry" sourceRef="error_fetch_failure" targetRef="task_retry_fetch"/>
    <bpmn:sequenceFlow id="flow_retry_to_dmn" sourceRef="task_retry_fetch" targetRef="dmn_evaluate_adjudication"/>

  </bpmn:process>

  <!-- Error Definitions -->
  <bpmn:error id="Error_DataFetchFailed" name="DataFetchFailed" errorCode="ERR_DATA_FETCH"/>

  <!-- BPMNDI Visual Diagram -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_AdminAdjudication">
    <bpmndi:BPMNPlane id="BPMNPlane_AdminAdjudication" bpmnElement="TEMPLATE_Admin_Adjudication">
      
      <!-- Start Event -->
      <bpmndi:BPMNShape id="Shape_start_adjudication" bpmnElement="start_adjudication">
        <dc:Bounds x="152" y="242" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="136" y="285" width="68" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <!-- Service Task: Fetch Admin Data -->
      <bpmndi:BPMNShape id="Shape_task_fetch" bpmnElement="task_fetch_admin_data">
        <dc:Bounds x="250" y="220" width="100" height="80"/>
      </bpmndi:BPMNShape>
      
      <!-- Error Boundary on Fetch -->
      <bpmndi:BPMNShape id="Shape_error_fetch" bpmnElement="error_fetch_failure">
        <dc:Bounds x="302" y="282" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="282" y="325" width="76" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <!-- Service Task: Retry Fetch -->
      <bpmndi:BPMNShape id="Shape_task_retry" bpmnElement="task_retry_fetch">
        <dc:Bounds x="270" y="380" width="100" height="80"/>
      </bpmndi:BPMNShape>
      
      <!-- Business Rule Task: DMN Evaluation -->
      <bpmndi:BPMNShape id="Shape_dmn_evaluate" bpmnElement="dmn_evaluate_adjudication">
        <dc:Bounds x="410" y="220" width="100" height="80"/>
      </bpmndi:BPMNShape>
      
      <!-- Gateway: Decision Routing -->
      <bpmndi:BPMNShape id="Shape_gateway_decision" bpmnElement="gateway_decision" isMarkerVisible="true">
        <dc:Bounds x="565" y="235" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="560" y="292" width="60" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <!-- Service Task: Auto Approve (Proceed path) -->
      <bpmndi:BPMNShape id="Shape_task_approve" bpmnElement="task_auto_approve">
        <dc:Bounds x="680" y="100" width="100" height="80"/>
      </bpmndi:BPMNShape>
      
      <!-- Service Task: Auto Deny (Block path) -->
      <bpmndi:BPMNShape id="Shape_task_deny" bpmnElement="task_auto_deny">
        <dc:Bounds x="680" y="220" width="100" height="80"/>
      </bpmndi:BPMNShape>
      
      <!-- User Task: Human Review (Review path) -->
      <bpmndi:BPMNShape id="Shape_task_review" bpmnElement="task_human_review">
        <dc:Bounds x="680" y="360" width="100" height="80"/>
      </bpmndi:BPMNShape>
      
      <!-- Timer Boundary: SLA 24h -->
      <bpmndi:BPMNShape id="Shape_timer_sla" bpmnElement="timer_sla_breach">
        <dc:Bounds x="732" y="422" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="768" y="433" width="48" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <!-- Service Task: Escalate -->
      <bpmndi:BPMNShape id="Shape_task_escalate" bpmnElement="task_escalate_supervisor">
        <dc:Bounds x="700" y="510" width="100" height="80"/>
      </bpmndi:BPMNShape>
      
      <!-- Gateway: Human Decision -->
      <bpmndi:BPMNShape id="Shape_gateway_human" bpmnElement="gateway_human_decision" isMarkerVisible="true">
        <dc:Bounds x="845" y="375" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="832" y="432" width="76" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <!-- Service Task: Process Approval -->
      <bpmndi:BPMNShape id="Shape_task_process_approval" bpmnElement="task_process_approval">
        <dc:Bounds x="960" y="300" width="100" height="80"/>
      </bpmndi:BPMNShape>
      
      <!-- Service Task: Process Denial -->
      <bpmndi:BPMNShape id="Shape_task_process_denial" bpmnElement="task_process_denial">
        <dc:Bounds x="960" y="440" width="100" height="80"/>
      </bpmndi:BPMNShape>
      
      <!-- End Events -->
      <bpmndi:BPMNShape id="Shape_end_approved" bpmnElement="end_approved">
        <dc:Bounds x="842" y="122" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="823" y="165" width="74" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="Shape_end_denied" bpmnElement="end_denied">
        <dc:Bounds x="842" y="242" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="829" y="285" width="62" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="Shape_end_escalated" bpmnElement="end_escalated">
        <dc:Bounds x="842" y="532" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="835" y="575" width="50" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="Shape_end_reviewed_approved" bpmnElement="end_reviewed_approved">
        <dc:Bounds x="1132" y="322" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1113" y="365" width="74" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <bpmndi:BPMNShape id="Shape_end_reviewed_denied" bpmnElement="end_reviewed_denied">
        <dc:Bounds x="1132" y="462" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1113" y="505" width="74" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      
      <!-- Sequence Flow Edges -->
      <bpmndi:BPMNEdge id="Edge_flow_to_fetch" bpmnElement="flow_to_fetch">
        <di:waypoint x="188" y="260"/>
        <di:waypoint x="250" y="260"/>
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Edge_flow_to_dmn" bpmnElement="flow_to_dmn_adjudication">
        <di:waypoint x="350" y="260"/>
        <di:waypoint x="410" y="260"/>
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Edge_flow_to_gateway" bpmnElement="flow_to_decision_gateway">
        <di:waypoint x="510" y="260"/>
        <di:waypoint x="565" y="260"/>
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Edge_flow_proceed" bpmnElement="flow_proceed">
        <di:waypoint x="590" y="235"/>
        <di:waypoint x="590" y="140"/>
        <di:waypoint x="680" y="140"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="595" y="185" width="70" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Edge_flow_block" bpmnElement="flow_block">
        <di:waypoint x="615" y="260"/>
        <di:waypoint x="680" y="260"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="625" y="242" width="65" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      
      <bpmndi:BPMNEdge id="Edge_flow_review" bpmnElement="flow_review">
        <di:waypoint x="590" y="285"/>
        <di:waypoint x="590" y="400"/>
        <di:waypoint x="680" y="400"/>
