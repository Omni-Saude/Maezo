<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                   xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                   xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                   xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                   xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                   id="Definitions_SUB_10"
                   targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="revenue_optimization_process" name="SUB_10: Revenue Optimization" isExecutable="true">
    <bpmn:startEvent id="start_revenue_optimization" name="Start Revenue Optimization">
      <bpmn:outgoing>flow_to_identify_coding</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="identify_coding_opportunities" name="Identify Coding Opportunities" camunda:type="external" camunda:topic="platform.identify_coding_opportunities">
      <bpmn:incoming>flow_to_identify_coding</bpmn:incoming>
      <bpmn:outgoing>flow_to_suggest_documentation</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="suggest_documentation_improvements" name="Suggest Documentation Improvements" camunda:type="external" camunda:topic="platform.suggest_documentation_improvements">
      <bpmn:incoming>flow_to_suggest_documentation</bpmn:incoming>
      <bpmn:outgoing>flow_to_analyze_denial</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="analyze_denial_patterns" name="Analyze Denial Patterns" camunda:type="external" camunda:topic="platform.analyze_denial_patterns">
      <bpmn:incoming>flow_to_analyze_denial</bpmn:incoming>
      <bpmn:outgoing>flow_to_optimize_pricing</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="optimize_pricing_strategy" name="Optimize Pricing Strategy" camunda:type="external" camunda:topic="platform.optimize_pricing_strategy">
      <bpmn:incoming>flow_to_optimize_pricing</bpmn:incoming>
      <bpmn:outgoing>flow_to_identify_gaps</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="identify_contract_gaps" name="Identify Contract Gaps" camunda:type="external" camunda:topic="platform.identify_contract_gaps">
      <bpmn:incoming>flow_to_identify_gaps</bpmn:incoming>
      <bpmn:outgoing>flow_to_recommend_bundles</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="recommend_procedure_bundles" name="Recommend Procedure Bundles" camunda:type="external" camunda:topic="platform.recommend_procedure_bundles">
      <bpmn:incoming>flow_to_recommend_bundles</bpmn:incoming>
      <bpmn:outgoing>flow_to_calculate_potential</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="calculate_revenue_potential" name="Calculate Revenue Potential" camunda:type="external" camunda:topic="platform.calculate_revenue_potential">
      <bpmn:incoming>flow_to_calculate_potential</bpmn:incoming>
      <bpmn:outgoing>flow_to_prioritize_cases</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="prioritize_high_value_cases" name="Prioritize High Value Cases" camunda:type="external" camunda:topic="platform.prioritize_high_value_cases">
      <bpmn:incoming>flow_to_prioritize_cases</bpmn:incoming>
      <bpmn:outgoing>flow_to_detect_leakage</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="detect_revenue_leakage" name="Detect Revenue Leakage" camunda:type="external" camunda:topic="platform.detect_revenue_leakage">
      <bpmn:incoming>flow_to_detect_leakage</bpmn:incoming>
      <bpmn:outgoing>flow_to_optimize_resources</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="optimize_resource_utilization" name="Optimize Resource Utilization" camunda:type="external" camunda:topic="platform.optimize_resource_utilization">
      <bpmn:incoming>flow_to_optimize_resources</bpmn:incoming>
      <bpmn:outgoing>flow_to_forecast_trends</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="forecast_revenue_trends" name="Forecast Revenue Trends" camunda:type="external" camunda:topic="platform.forecast_revenue_trends">
      <bpmn:incoming>flow_to_forecast_trends</bpmn:incoming>
      <bpmn:outgoing>flow_to_benchmark_payer</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="benchmark_payer_performance" name="Benchmark Payer Performance" camunda:type="external" camunda:topic="platform.benchmark_payer_performance">
      <bpmn:incoming>flow_to_benchmark_payer</bpmn:incoming>
      <bpmn:outgoing>flow_to_generate_report</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="generate_optimization_report" name="Generate Optimization Report" camunda:type="external" camunda:topic="platform.generate_optimization_report">
      <bpmn:incoming>flow_to_generate_report</bpmn:incoming>
      <bpmn:outgoing>flow_to_track_roi</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="track_optimization_roi" name="Track Optimization ROI" camunda:type="external" camunda:topic="platform.track_optimization_roi">
      <bpmn:incoming>flow_to_track_roi</bpmn:incoming>
      <bpmn:outgoing>flow_to_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="end_revenue_optimization" name="End Revenue Optimization">
      <bpmn:incoming>flow_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="flow_to_identify_coding" sourceRef="start_revenue_optimization" targetRef="identify_coding_opportunities" />
    <bpmn:sequenceFlow id="flow_to_suggest_documentation" sourceRef="identify_coding_opportunities" targetRef="suggest_documentation_improvements" />
    <bpmn:sequenceFlow id="flow_to_analyze_denial" sourceRef="suggest_documentation_improvements" targetRef="analyze_denial_patterns" />
    <bpmn:sequenceFlow id="flow_to_optimize_pricing" sourceRef="analyze_denial_patterns" targetRef="optimize_pricing_strategy" />
    <bpmn:sequenceFlow id="flow_to_identify_gaps" sourceRef="optimize_pricing_strategy" targetRef="identify_contract_gaps" />
    <bpmn:sequenceFlow id="flow_to_recommend_bundles" sourceRef="identify_contract_gaps" targetRef="recommend_procedure_bundles" />
    <bpmn:sequenceFlow id="flow_to_calculate_potential" sourceRef="recommend_procedure_bundles" targetRef="calculate_revenue_potential" />
    <bpmn:sequenceFlow id="flow_to_prioritize_cases" sourceRef="calculate_revenue_potential" targetRef="prioritize_high_value_cases" />
    <bpmn:sequenceFlow id="flow_to_detect_leakage" sourceRef="prioritize_high_value_cases" targetRef="detect_revenue_leakage" />
    <bpmn:sequenceFlow id="flow_to_optimize_resources" sourceRef="detect_revenue_leakage" targetRef="optimize_resource_utilization" />
    <bpmn:sequenceFlow id="flow_to_forecast_trends" sourceRef="optimize_resource_utilization" targetRef="forecast_revenue_trends" />
    <bpmn:sequenceFlow id="flow_to_benchmark_payer" sourceRef="forecast_revenue_trends" targetRef="benchmark_payer_performance" />
    <bpmn:sequenceFlow id="flow_to_generate_report" sourceRef="benchmark_payer_performance" targetRef="generate_optimization_report" />
    <bpmn:sequenceFlow id="flow_to_track_roi" sourceRef="generate_optimization_report" targetRef="track_optimization_roi" />
    <bpmn:sequenceFlow id="flow_to_end" sourceRef="track_optimization_roi" targetRef="end_revenue_optimization" />
  </bpmn:process>
</bpmn:definitions>
