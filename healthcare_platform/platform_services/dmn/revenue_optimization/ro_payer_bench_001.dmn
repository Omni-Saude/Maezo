<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_RO_PAYER_BENCH_001"
             name="RO_PAYER_BENCH_001"
             targetNamespace="http://healthcare.platform/dmn/platform_services/revenue_optimization">
  <decision id="Decision_RO_PAYER_BENCH_001" name="Payer Benchmark Thresholds By Type">
    <decisionTable id="DecisionTable_RO_PAYER_BENCH_001" hitPolicy="FIRST">
      <input id="Input_payerType" label="Payer Type">
        <inputExpression id="InputExpression_payerType" typeRef="string">
          <text>payerType</text>
        </inputExpression>
      </input>
      <input id="Input_paymentDays" label="Payment Days">
        <inputExpression id="InputExpression_paymentDays" typeRef="number">
          <text>paymentDays</text>
        </inputExpression>
      </input>
      <input id="Input_denialRate" label="Denial Rate">
        <inputExpression id="InputExpression_denialRate" typeRef="number">
          <text>denialRate</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string" />
      <output id="Output_observacao" label="Observação" name="observacao" typeRef="string" />
      <output id="Output_acaoRecomendada" label="Ação Recomendada" name="acaoRecomendada" typeRef="string" />
      <output id="Output_alertasConformidade" label="Alertas Conformidade" name="alertasConformidade" typeRef="string" />
      <output id="Output_riscoDenial" label="Risco Denial" name="riscoDenial" typeRef="string" />
      <rule id="Rule_RO_PAYER_BENCH_001_1">
        <inputEntry id="InputEntry_RO_PAYER_BENCH_001_1_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_001_1_2"><text>&gt; 90</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_001_1_3"><text>&gt; 0.3</text></inputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_1_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_1_2"><text>"Operadora com atraso crítico (&gt;90d) e alta glosa (&gt;30%)"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_1_3"><text>"Suspender autorizações e renegociar contrato"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_1_4"><text>"CONTRATO"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_1_5"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_PAYER_BENCH_001_2">
        <inputEntry id="InputEntry_RO_PAYER_BENCH_001_2_1"><text>"PRIVATE"</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_001_2_2"><text>&gt; 60</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_001_2_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_2_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_2_2"><text>"Operadora privada com atraso acima do benchmark (&gt;60d)"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_2_3"><text>"Acionar juridicamente e notificar ANS"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_2_4"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_2_5"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_PAYER_BENCH_001_3">
        <inputEntry id="InputEntry_RO_PAYER_BENCH_001_3_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_001_3_2"><text>[45..90]</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_001_3_3"><text>[0.15..0.3]</text></inputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_3_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_3_2"><text>"Operadora com performance abaixo da média (45-90d, 15-30% glosa)"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_3_3"><text>"Iniciar negociação para melhoria de indicadores"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_3_4"><text>"CONTRATO"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_3_5"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_PAYER_BENCH_001_4">
        <inputEntry id="InputEntry_RO_PAYER_BENCH_001_4_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_001_4_2"><text>&lt; 45</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_001_4_3"><text>&lt; 0.15</text></inputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_4_1"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_4_2"><text>"Operadora dentro do benchmark (&lt;45d, &lt;15% glosa)"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_4_3"><text>"Manter relacionamento e monitorar tendências"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_4_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_4_5"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_PAYER_BENCH_001_5">
        <inputEntry id="InputEntry_RO_PAYER_BENCH_001_5_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_001_5_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_001_5_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_5_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_5_2"><text>"Dados insuficientes ou operadora não categorizada"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_5_3"><text>"Coletar histórico e estabelecer baseline"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_5_4"><text>"CONTRATO"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_001_5_5"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RO_PAYER_BENCH_001">
      <dmndi:DMNShape id="DMNShape_RO_PAYER_BENCH_001" dmnElementRef="Decision_RO_PAYER_BENCH_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
