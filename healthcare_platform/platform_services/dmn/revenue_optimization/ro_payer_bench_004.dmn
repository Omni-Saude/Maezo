<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_RO_PAYER_BENCH_004"
             name="RO_PAYER_BENCH_004"
             targetNamespace="http://healthcare.platform/dmn/platform_services/revenue_optimization">
  <decision id="Decision_RO_PAYER_BENCH_004" name="Payer Renegotiation Eligibility">
    <decisionTable id="DecisionTable_RO_PAYER_BENCH_004" hitPolicy="FIRST">
      <input id="Input_contractAge" label="Contract Age (months)">
        <inputExpression id="InputExpression_contractAge" typeRef="number">
          <text>contractAge</text>
        </inputExpression>
      </input>
      <input id="Input_performanceScore" label="Performance Score">
        <inputExpression id="InputExpression_performanceScore" typeRef="number">
          <text>performanceScore</text>
        </inputExpression>
      </input>
      <input id="Input_belowMarket" label="Below Market">
        <inputExpression id="InputExpression_belowMarket" typeRef="boolean">
          <text>belowMarket</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string" />
      <output id="Output_observacao" label="Observação" name="observacao" typeRef="string" />
      <output id="Output_acaoRecomendada" label="Ação Recomendada" name="acaoRecomendada" typeRef="string" />
      <output id="Output_alertasConformidade" label="Alertas Conformidade" name="alertasConformidade" typeRef="string" />
      <output id="Output_riscoDenial" label="Risco Denial" name="riscoDenial" typeRef="string" />
      <rule id="Rule_RO_PAYER_BENCH_004_1">
        <inputEntry id="InputEntry_RO_PAYER_BENCH_004_1_1"><text>&gt; 24</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_004_1_2"><text>&lt; 0.5</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_004_1_3"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_1_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_1_2"><text>"Contrato antigo (&gt;24m), baixa performance e valores defasados"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_1_3"><text>"Renegociação urgente ou rescisão contratual"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_1_4"><text>"CONTRATO"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_1_5"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_PAYER_BENCH_004_2">
        <inputEntry id="InputEntry_RO_PAYER_BENCH_004_2_1"><text>&gt; 36</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_004_2_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_004_2_3"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_2_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_2_2"><text>"Contrato muito antigo (&gt;36m) com valores abaixo do mercado"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_2_3"><text>"Iniciar processo formal de renegociação"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_2_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_2_5"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_PAYER_BENCH_004_3">
        <inputEntry id="InputEntry_RO_PAYER_BENCH_004_3_1"><text>[18..36]</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_004_3_2"><text>[0.5..0.7)</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_004_3_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_3_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_3_2"><text>"Contrato maduro (18-36m) com performance mediana"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_3_3"><text>"Avaliar janela de renegociação nos próximos 6 meses"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_3_4"><text>"CONTRATO"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_3_5"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_PAYER_BENCH_004_4">
        <inputEntry id="InputEntry_RO_PAYER_BENCH_004_4_1"><text>&lt; 18</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_004_4_2"><text>&gt; 0.7</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_004_4_3"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_4_1"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_4_2"><text>"Contrato recente (&lt;18m) com boa performance e valores adequados"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_4_3"><text>"Manter contrato e monitorar satisfação mútua"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_4_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_4_5"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_PAYER_BENCH_004_5">
        <inputEntry id="InputEntry_RO_PAYER_BENCH_004_5_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_004_5_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_004_5_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_5_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_5_2"><text>"Dados contratuais incompletos para análise"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_5_3"><text>"Revisar cláusulas e indicadores de performance"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_5_4"><text>"CONTRATO"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_004_5_5"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RO_PAYER_BENCH_004">
      <dmndi:DMNShape id="DMNShape_RO_PAYER_BENCH_004" dmnElementRef="Decision_RO_PAYER_BENCH_004">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
