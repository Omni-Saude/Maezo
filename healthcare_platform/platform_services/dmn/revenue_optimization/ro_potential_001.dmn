<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_RO_POTENTIAL_001"
             name="RO_POTENTIAL_001"
             targetNamespace="http://healthcare.platform/dmn/platform_services/revenue_optimization">
  <decision id="Decision_RO_POTENTIAL_001" name="Revenue Potential Opportunity Scoring">
    <decisionTable id="DecisionTable_RO_POTENTIAL_001" hitPolicy="FIRST">
      <input id="Input_scenarioType" label="Scenario Type">
        <inputExpression id="InputExpression_scenarioType" typeRef="string">
          <text>scenarioType</text>
        </inputExpression>
      </input>
      <input id="Input_impactPercentage" label="Impact Percentage">
        <inputExpression id="InputExpression_impactPercentage" typeRef="number">
          <text>impactPercentage</text>
        </inputExpression>
      </input>
      <input id="Input_implementationDifficulty" label="Implementation Difficulty">
        <inputExpression id="InputExpression_implementationDifficulty" typeRef="string">
          <text>implementationDifficulty</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string" />
      <output id="Output_observacao" label="Observação" name="observacao" typeRef="string" />
      <output id="Output_acaoRecomendada" label="Ação Recomendada" name="acaoRecomendada" typeRef="string" />
      <output id="Output_alertasConformidade" label="Alertas Conformidade" name="alertasConformidade" typeRef="string" />
      <output id="Output_riscoDenial" label="Risco Denial" name="riscoDenial" typeRef="string" />
      <rule id="Rule_RO_POTENTIAL_001_1">
        <inputEntry id="InputEntry_RO_POTENTIAL_001_1_1"><text>"PAYER_RENEGOTIATION"</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_001_1_2"><text>&gt; 0.15</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_001_1_3"><text>"HIGH"</text></inputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_1_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_1_2"><text>"Alto potencial (&gt;15%) mas difícil implementação - risco elevado"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_1_3"><text>"Avaliar viabilidade jurídica e impacto relacional"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_1_4"><text>"CONTRATO"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_1_5"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_POTENTIAL_001_2">
        <inputEntry id="InputEntry_RO_POTENTIAL_001_2_1"><text>"GLOSA_REDUCTION"</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_001_2_2"><text>&gt; 0.2</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_001_2_3"><text>"LOW"</text></inputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_2_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_2_2"><text>"Oportunidade excepcional (&gt;20%) com baixa dificuldade"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_2_3"><text>"Priorizar implementação imediata"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_2_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_2_5"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_POTENTIAL_001_3">
        <inputEntry id="InputEntry_RO_POTENTIAL_001_3_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_001_3_2"><text>[0.05..0.15]</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_001_3_3"><text>"MEDIUM"</text></inputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_3_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_3_2"><text>"Impacto moderado (5-15%) com dificuldade média"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_3_3"><text>"Incluir no roadmap trimestral de otimização"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_3_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_3_5"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_POTENTIAL_001_4">
        <inputEntry id="InputEntry_RO_POTENTIAL_001_4_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_001_4_2"><text>&gt; 0.1</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_001_4_3"><text>"LOW"</text></inputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_4_1"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_4_2"><text>"Bom impacto (&gt;10%) e fácil implementação - quick win"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_4_3"><text>"Implementar no próximo sprint"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_4_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_4_5"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_POTENTIAL_001_5">
        <inputEntry id="InputEntry_RO_POTENTIAL_001_5_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_001_5_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_001_5_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_5_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_5_2"><text>"Cenário não categorizado ou análise incompleta"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_5_3"><text>"Completar análise de impacto e esforço"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_5_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_001_5_5"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RO_POTENTIAL_001">
      <dmndi:DMNShape id="DMNShape_RO_POTENTIAL_001" dmnElementRef="Decision_RO_POTENTIAL_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
