<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_RO_POTENTIAL_002"
             name="RO_POTENTIAL_002"
             targetNamespace="http://healthcare.platform/dmn/platform_services/revenue_optimization">
  <decision id="Decision_RO_POTENTIAL_002" name="Revenue Gap Analysis Rules">
    <decisionTable id="DecisionTable_RO_POTENTIAL_002" hitPolicy="FIRST">
      <input id="Input_gapCategory" label="Gap Category">
        <inputExpression id="InputExpression_gapCategory" typeRef="string">
          <text>gapCategory</text>
        </inputExpression>
      </input>
      <input id="Input_gapAmount" label="Gap Amount">
        <inputExpression id="InputExpression_gapAmount" typeRef="number">
          <text>gapAmount</text>
        </inputExpression>
      </input>
      <input id="Input_isRecoverable" label="Is Recoverable">
        <inputExpression id="InputExpression_isRecoverable" typeRef="boolean">
          <text>isRecoverable</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string" />
      <output id="Output_observacao" label="Observação" name="observacao" typeRef="string" />
      <output id="Output_acaoRecomendada" label="Ação Recomendada" name="acaoRecomendada" typeRef="string" />
      <output id="Output_alertasConformidade" label="Alertas Conformidade" name="alertasConformidade" typeRef="string" />
      <output id="Output_riscoDenial" label="Risco Denial" name="riscoDenial" typeRef="string" />
      <rule id="Rule_RO_POTENTIAL_002_1">
        <inputEntry id="InputEntry_RO_POTENTIAL_002_1_1"><text>"UNDERCODING"</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_002_1_2"><text>&gt; 100000</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_002_1_3"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_1_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_1_2"><text>"Gap crítico de subcodificação (&gt;R$100k) recuperável"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_1_3"><text>"Iniciar recurso de glosas e auditoria retrospectiva"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_1_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_1_5"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_POTENTIAL_002_2">
        <inputEntry id="InputEntry_RO_POTENTIAL_002_2_1"><text>"UNBILLED_SERVICES"</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_002_2_2"><text>&gt; 50000</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_002_2_3"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_2_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_2_2"><text>"Serviços não faturados (&gt;R$50k) dentro do prazo"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_2_3"><text>"Gerar e submeter faturamento retroativo urgente"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_2_4"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_2_5"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_POTENTIAL_002_3">
        <inputEntry id="InputEntry_RO_POTENTIAL_002_3_1"><text>"CONTRACT_UNDERPAYMENT"</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_002_3_2"><text>[20000..100000]</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_002_3_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_3_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_3_2"><text>"Gap de pagamento contratual moderado (R$20-100k)"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_3_3"><text>"Notificar operadora e cobrar diferenças"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_3_4"><text>"CONTRATO"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_3_5"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_POTENTIAL_002_4">
        <inputEntry id="InputEntry_RO_POTENTIAL_002_4_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_002_4_2"><text>&lt; 20000</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_002_4_3"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_4_1"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_4_2"><text>"Gap pequeno (&lt;R$20k) não recuperável"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_4_3"><text>"Documentar aprendizado e prevenir recorrência"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_4_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_4_5"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_POTENTIAL_002_5">
        <inputEntry id="InputEntry_RO_POTENTIAL_002_5_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_002_5_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_002_5_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_5_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_5_2"><text>"Gap não categorizado ou análise incompleta"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_5_3"><text>"Classificar gap e determinar recuperabilidade"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_5_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_002_5_5"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RO_POTENTIAL_002">
      <dmndi:DMNShape id="DMNShape_RO_POTENTIAL_002" dmnElementRef="Decision_RO_POTENTIAL_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
