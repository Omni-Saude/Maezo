<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_RO_PAYER_BENCH_003"
             name="RO_PAYER_BENCH_003"
             targetNamespace="http://healthcare.platform/dmn/platform_services/revenue_optimization">
  <decision id="Decision_RO_PAYER_BENCH_003" name="Payer Tier Classification">
    <decisionTable id="DecisionTable_RO_PAYER_BENCH_003" hitPolicy="FIRST">
      <input id="Input_overallScore" label="Overall Score">
        <inputExpression id="InputExpression_overallScore" typeRef="number">
          <text>overallScore</text>
        </inputExpression>
      </input>
      <input id="Input_revenueContribution" label="Revenue Contribution">
        <inputExpression id="InputExpression_revenueContribution" typeRef="number">
          <text>revenueContribution</text>
        </inputExpression>
      </input>
      <input id="Input_riskLevel" label="Risk Level">
        <inputExpression id="InputExpression_riskLevel" typeRef="string">
          <text>riskLevel</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string" />
      <output id="Output_observacao" label="Observação" name="observacao" typeRef="string" />
      <output id="Output_acaoRecomendada" label="Ação Recomendada" name="acaoRecomendada" typeRef="string" />
      <output id="Output_alertasConformidade" label="Alertas Conformidade" name="alertasConformidade" typeRef="string" />
      <output id="Output_riscoDenial" label="Risco Denial" name="riscoDenial" typeRef="string" />
      <rule id="Rule_RO_PAYER_BENCH_003_1">
        <inputEntry id="InputEntry_RO_PAYER_BENCH_003_1_1"><text>&lt; 0.4</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_003_1_2"><text>&gt; 0.2</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_003_1_3"><text>"HIGH"</text></inputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_1_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_1_2"><text>"Operadora Tier D - performance crítica com alta receita"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_1_3"><text>"Plano de ação urgente para recuperação ou migração"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_1_4"><text>"CONTRATO"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_1_5"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_PAYER_BENCH_003_2">
        <inputEntry id="InputEntry_RO_PAYER_BENCH_003_2_1"><text>&lt; 0.5</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_003_2_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_003_2_3"><text>"HIGH", "CRITICAL"</text></inputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_2_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_2_2"><text>"Operadora Tier D - alto risco operacional"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_2_3"><text>"Reduzir exposição e buscar alternativas"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_2_4"><text>"CRED"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_2_5"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_PAYER_BENCH_003_3">
        <inputEntry id="InputEntry_RO_PAYER_BENCH_003_3_1"><text>[0.5..0.7)</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_003_3_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_003_3_3"><text>"MEDIUM"</text></inputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_3_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_3_2"><text>"Operadora Tier C - performance mediana"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_3_3"><text>"Definir metas trimestrais de melhoria"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_3_4"><text>"CONTRATO"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_3_5"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_PAYER_BENCH_003_4">
        <inputEntry id="InputEntry_RO_PAYER_BENCH_003_4_1"><text>&gt;= 0.8</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_003_4_2"><text>&gt; 0.15</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_003_4_3"><text>"LOW"</text></inputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_4_1"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_4_2"><text>"Operadora Tier A - parceiro estratégico"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_4_3"><text>"Buscar expansão de portfólio e volume"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_4_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_4_5"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_PAYER_BENCH_003_5">
        <inputEntry id="InputEntry_RO_PAYER_BENCH_003_5_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_003_5_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_PAYER_BENCH_003_5_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_5_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_5_2"><text>"Operadora não classificada - dados insuficientes"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_5_3"><text>"Completar análise de performance e risco"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_5_4"><text>"CONTRATO"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_PAYER_BENCH_003_5_5"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RO_PAYER_BENCH_003">
      <dmndi:DMNShape id="DMNShape_RO_PAYER_BENCH_003" dmnElementRef="Decision_RO_PAYER_BENCH_003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
