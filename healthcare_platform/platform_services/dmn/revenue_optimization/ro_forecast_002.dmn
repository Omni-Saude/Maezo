<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_RO_FORECAST_002"
             name="RO_FORECAST_002"
             targetNamespace="http://healthcare.platform/dmn/platform_services/revenue_optimization">
  <decision id="Decision_RO_FORECAST_002" name="Forecast Risk Factor Classification">
    <decisionTable id="DecisionTable_RO_FORECAST_002" hitPolicy="FIRST">
      <input id="Input_riskType" label="Risk Type">
        <inputExpression id="InputExpression_riskType" typeRef="string">
          <text>riskType</text>
        </inputExpression>
      </input>
      <input id="Input_impactLevel" label="Impact Level">
        <inputExpression id="InputExpression_impactLevel" typeRef="string">
          <text>impactLevel</text>
        </inputExpression>
      </input>
      <input id="Input_mitigationExists" label="Mitigation Exists">
        <inputExpression id="InputExpression_mitigationExists" typeRef="boolean">
          <text>mitigationExists</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string" />
      <output id="Output_observacao" label="Observação" name="observacao" typeRef="string" />
      <output id="Output_acaoRecomendada" label="Ação Recomendada" name="acaoRecomendada" typeRef="string" />
      <output id="Output_alertasConformidade" label="Alertas Conformidade" name="alertasConformidade" typeRef="string" />
      <output id="Output_riscoDenial" label="Risco Denial" name="riscoDenial" typeRef="string" />
      <rule id="Rule_RO_FORECAST_002_1">
        <inputEntry id="InputEntry_RO_FORECAST_002_1_1"><text>"PAYER_DEFAULT"</text></inputEntry>
        <inputEntry id="InputEntry_RO_FORECAST_002_1_2"><text>"HIGH"</text></inputEntry>
        <inputEntry id="InputEntry_RO_FORECAST_002_1_3"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_1_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_1_2"><text>"Risco de inadimplência de operadora sem plano de mitigação"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_1_3"><text>"Desenvolver estratégia de diversificação urgente"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_1_4"><text>"CRED"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_1_5"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_FORECAST_002_2">
        <inputEntry id="InputEntry_RO_FORECAST_002_2_1"><text>"REGULATORY_CHANGE"</text></inputEntry>
        <inputEntry id="InputEntry_RO_FORECAST_002_2_2"><text>"HIGH"</text></inputEntry>
        <inputEntry id="InputEntry_RO_FORECAST_002_2_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_2_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_2_2"><text>"Alto risco de mudança regulatória impactante"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_2_3"><text>"Monitorar ANS e ajustar forecast trimestralmente"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_2_4"><text>"CONTRATO"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_2_5"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_FORECAST_002_3">
        <inputEntry id="InputEntry_RO_FORECAST_002_3_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_FORECAST_002_3_2"><text>"MEDIUM"</text></inputEntry>
        <inputEntry id="InputEntry_RO_FORECAST_002_3_3"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_3_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_3_2"><text>"Risco médio sem plano de contingência"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_3_3"><text>"Desenvolver plano de mitigação em 30 dias"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_3_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_3_5"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_FORECAST_002_4">
        <inputEntry id="InputEntry_RO_FORECAST_002_4_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_FORECAST_002_4_2"><text>"LOW"</text></inputEntry>
        <inputEntry id="InputEntry_RO_FORECAST_002_4_3"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_4_1"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_4_2"><text>"Baixo risco com mitigação implementada"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_4_3"><text>"Monitorar periodicamente e ajustar se necessário"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_4_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_4_5"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_FORECAST_002_5">
        <inputEntry id="InputEntry_RO_FORECAST_002_5_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_FORECAST_002_5_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_FORECAST_002_5_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_5_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_5_2"><text>"Risco não categorizado ou avaliação incompleta"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_5_3"><text>"Completar análise de riscos e impactos"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_5_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_FORECAST_002_5_5"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RO_FORECAST_002">
      <dmndi:DMNShape id="DMNShape_RO_FORECAST_002" dmnElementRef="Decision_RO_FORECAST_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
