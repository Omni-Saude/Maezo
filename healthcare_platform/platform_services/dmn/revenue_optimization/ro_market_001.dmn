<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_RO_MARKET_001"
             name="RO_MARKET_001"
             targetNamespace="http://healthcare.platform/dmn/platform_services/revenue_optimization">
  <decision id="Decision_RO_MARKET_001" name="Market Rate Comparison Rules">
    <decisionTable id="DecisionTable_RO_MARKET_001" hitPolicy="FIRST">
      <input id="Input_contractedRate" label="Contracted Rate">
        <inputExpression id="InputExpression_contractedRate" typeRef="number">
          <text>contractedRate</text>
        </inputExpression>
      </input>
      <input id="Input_marketRate" label="Market Rate">
        <inputExpression id="InputExpression_marketRate" typeRef="number">
          <text>marketRate</text>
        </inputExpression>
      </input>
      <input id="Input_variancePercentage" label="Variance Percentage">
        <inputExpression id="InputExpression_variancePercentage" typeRef="number">
          <text>variancePercentage</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string" />
      <output id="Output_observacao" label="Observação" name="observacao" typeRef="string" />
      <output id="Output_acaoRecomendada" label="Ação Recomendada" name="acaoRecomendada" typeRef="string" />
      <output id="Output_alertasConformidade" label="Alertas Conformidade" name="alertasConformidade" typeRef="string" />
      <output id="Output_riscoDenial" label="Risco Denial" name="riscoDenial" typeRef="string" />
      <rule id="Rule_RO_MARKET_001_1">
        <inputEntry id="InputEntry_RO_MARKET_001_1_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_MARKET_001_1_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_MARKET_001_1_3"><text>&lt; -0.3</text></inputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_1_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_1_2"><text>"Valor contratado crítico (&gt;30%) abaixo do mercado"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_1_3"><text>"Renegociação urgente ou suspensão de serviços"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_1_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_1_5"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_MARKET_001_2">
        <inputEntry id="InputEntry_RO_MARKET_001_2_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_MARKET_001_2_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_MARKET_001_2_3"><text>&gt; 0.25</text></inputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_2_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_2_2"><text>"Valor contratado excessivo (&gt;25%) acima do mercado"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_2_3"><text>"Avaliar risco de questionamento e auditoria da operadora"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_2_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_2_5"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_MARKET_001_3">
        <inputEntry id="InputEntry_RO_MARKET_001_3_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_MARKET_001_3_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_MARKET_001_3_3"><text>[-0.3..-0.15], [0.15..0.25]</text></inputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_3_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_3_2"><text>"Variância moderada (15-30%) em relação ao mercado"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_3_3"><text>"Monitorar e considerar ajustes na próxima janela"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_3_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_3_5"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_MARKET_001_4">
        <inputEntry id="InputEntry_RO_MARKET_001_4_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_MARKET_001_4_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_MARKET_001_4_3"><text>[-0.15..0.15]</text></inputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_4_1"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_4_2"><text>"Valor alinhado ao mercado (variância &lt;15%)"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_4_3"><text>"Manter contrato e revisar anualmente"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_4_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_4_5"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_MARKET_001_5">
        <inputEntry id="InputEntry_RO_MARKET_001_5_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_MARKET_001_5_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_MARKET_001_5_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_5_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_5_2"><text>"Dados de mercado incompletos ou desatualizados"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_5_3"><text>"Atualizar pesquisa de mercado e benchmarking"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_5_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_MARKET_001_5_5"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RO_MARKET_001">
      <dmndi:DMNShape id="DMNShape_RO_MARKET_001" dmnElementRef="Decision_RO_MARKET_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
