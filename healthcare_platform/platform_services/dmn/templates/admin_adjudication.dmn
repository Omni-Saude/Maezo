<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_ADMIN_ADJUDICATION_TEMPLATE"
             name="ADMIN_ADJUDICATION Template"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- TEMPLATE: ADMIN_ADJUDICATION v1.0.0
       Archetype: "Should this administrative/financial request proceed?"
       Outputs: 3 (resultado, acao, risco)
       Hit Policy: FIRST (blocking rules before approval)
       Inputs: Domain-specific. Replace placeholders below.

       Covers: authorization, billing validation, glosa prevention,
               coding audit, compliance, credentialing, pricing.
  -->

  <decision id="Decision_TEMPLATE_ID" name="TEMPLATE_NAME">
    <decisionTable id="DecisionTable_TEMPLATE_ID" hitPolicy="FIRST">

      <!-- === INPUTS (replace with domain-specific) === -->

      <input id="Input_1" label="Input 1">
        <inputExpression id="InputExpr_1" typeRef="string">
          <text>inputVariable1</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Input 2">
        <inputExpression id="InputExpr_2" typeRef="string">
          <text>inputVariable2</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS (standardized — do not modify) === -->

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES (ordered: block first, review middle, proceed last, fallback bottom) === -->

      <!-- Rule 1: Hard block -->
      <rule id="Rule_block">
        <description>CUSTOMIZE: blocking condition</description>
        <inputEntry id="IE_block_1"><text></text></inputEntry>
        <inputEntry id="IE_block_2"><text></text></inputEntry>
        <outputEntry id="OE_block_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_block_acao"><text>"CUSTOMIZE: corrective action required"</text></outputEntry>
        <outputEntry id="OE_block_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Needs review -->
      <rule id="Rule_review">
        <description>CUSTOMIZE: review condition</description>
        <inputEntry id="IE_rev_1"><text></text></inputEntry>
        <inputEntry id="IE_rev_2"><text></text></inputEntry>
        <outputEntry id="OE_rev_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_rev_acao"><text>"CUSTOMIZE: what to review/attach"</text></outputEntry>
        <outputEntry id="OE_rev_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Proceed -->
      <rule id="Rule_proceed">
        <description>CUSTOMIZE: approval condition</description>
        <inputEntry id="IE_proc_1"><text></text></inputEntry>
        <inputEntry id="IE_proc_2"><text></text></inputEntry>
        <outputEntry id="OE_proc_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_proc_acao"><text>"Nenhuma acao adicional"</text></outputEntry>
        <outputEntry id="OE_proc_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Fallback: Cannot determine — force review -->
      <rule id="Rule_fallback">
        <description>Caso nao enquadrado — revisao obrigatoria</description>
        <inputEntry id="IE_fb_1"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao"><text>"Caso requer avaliacao manual"</text></outputEntry>
        <outputEntry id="OE_fb_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_TEMPLATE_ID">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
