<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:biodi="http://bpmn.io/schema/dmn/biodi/2.0"
             id="Definitions_selfservice_eligibility"
             name="Self-Service Eligibility Rules"
             namespace="http://healthcare.platform/dmn/communication">

  <decision id="selfservice_eligibility_rules" name="Self-Service Eligibility Rules">
    <informationRequirement>
      <requiredInput href="#InputData_actionType"/>
    </informationRequirement>
    <informationRequirement>
      <requiredInput href="#InputData_patientRiskLevel"/>
    </informationRequirement>
    <informationRequirement>
      <requiredInput href="#InputData_timeWindowHours"/>
    </informationRequirement>
    <informationRequirement>
      <requiredInput href="#InputData_complexityScore"/>
    </informationRequirement>

    <decisionTable id="DecisionTable_selfservice" hitPolicy="FIRST">
      <input id="Input_actionType" label="Action Type" camunda:inputVariable="actionType">
        <inputExpression id="InputExpression_actionType" typeRef="string">
          <text>actionType</text>
        </inputExpression>
        <inputValues id="UnaryTests_actionType">
          <text>"confirm","cancel","reschedule","pay","question"</text>
        </inputValues>
      </input>

      <input id="Input_patientRiskLevel" label="Patient Risk Level" camunda:inputVariable="patientRiskLevel">
        <inputExpression id="InputExpression_patientRiskLevel" typeRef="string">
          <text>patientRiskLevel</text>
        </inputExpression>
        <inputValues id="UnaryTests_patientRiskLevel">
          <text>"low","medium","high"</text>
        </inputValues>
      </input>

      <input id="Input_timeWindowHours" label="Time Window Hours" camunda:inputVariable="timeWindowHours">
        <inputExpression id="InputExpression_timeWindowHours" typeRef="integer">
          <text>timeWindowHours</text>
        </inputExpression>
      </input>

      <input id="Input_complexityScore" label="Complexity Score (0-100)" camunda:inputVariable="complexityScore">
        <inputExpression id="InputExpression_complexityScore" typeRef="integer">
          <text>complexityScore</text>
        </inputExpression>
      </input>

      <output id="Output_allowSelfService" label="Allow Self Service" name="allowSelfService" typeRef="boolean"/>
      <output id="Output_requiresApproval" label="Requires Approval" name="requiresApproval" typeRef="boolean"/>
      <output id="Output_escalateToStaff" label="Escalate To Staff" name="escalateToStaff" typeRef="boolean"/>

      <!-- Rule 1: High risk patients always escalate to staff -->
      <rule id="Rule_high_risk_escalate">
        <description>High-risk patients: always escalate any action to staff for review and approval</description>
        <inputEntry id="InputEntry_r1_actionType">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r1_patientRiskLevel">
          <text>"high"</text>
        </inputEntry>
        <inputEntry id="InputEntry_r1_timeWindowHours">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r1_complexityScore">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r1_allowSelfService">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r1_requiresApproval">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r1_escalateToStaff">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: Cancel within 24 hours requires approval -->
      <rule id="Rule_cancel_short_notice">
        <description>Cancel appointment within 24 hours: requires manual approval due to scheduling impact</description>
        <inputEntry id="InputEntry_r2_actionType">
          <text>"cancel"</text>
        </inputEntry>
        <inputEntry id="InputEntry_r2_patientRiskLevel">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r2_timeWindowHours">
          <text>&lt; 24</text>
        </inputEntry>
        <inputEntry id="InputEntry_r2_complexityScore">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r2_allowSelfService">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r2_requiresApproval">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r2_escalateToStaff">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 3: Cancel with 24+ hours - low risk -->
      <rule id="Rule_cancel_low_risk">
        <description>Cancel appointment 24+ hours in advance for low-risk patients: allow self-service</description>
        <inputEntry id="InputEntry_r3_actionType">
          <text>"cancel"</text>
        </inputEntry>
        <inputEntry id="InputEntry_r3_patientRiskLevel">
          <text>"low"</text>
        </inputEntry>
        <inputEntry id="InputEntry_r3_timeWindowHours">
          <text>&gt;= 24</text>
        </inputEntry>
        <inputEntry id="InputEntry_r3_complexityScore">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r3_allowSelfService">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r3_requiresApproval">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r3_escalateToStaff">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 4: Cancel with 24+ hours - medium risk needs approval -->
      <rule id="Rule_cancel_medium_risk">
        <description>Cancel appointment 24+ hours in advance for medium-risk: allow but requires follow-up approval</description>
        <inputEntry id="InputEntry_r4_actionType">
          <text>"cancel"</text>
        </inputEntry>
        <inputEntry id="InputEntry_r4_patientRiskLevel">
          <text>"medium"</text>
        </inputEntry>
        <inputEntry id="InputEntry_r4_timeWindowHours">
          <text>&gt;= 24</text>
        </inputEntry>
        <inputEntry id="InputEntry_r4_complexityScore">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r4_allowSelfService">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r4_requiresApproval">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r4_escalateToStaff">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 5: Confirm appointment - always allow -->
      <rule id="Rule_confirm_always">
        <description>Confirm appointment: always allow self-service for any risk level</description>
        <inputEntry id="InputEntry_r5_actionType">
          <text>"confirm"</text>
        </inputEntry>
        <inputEntry id="InputEntry_r5_patientRiskLevel">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r5_timeWindowHours">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r5_complexityScore">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r5_allowSelfService">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r5_requiresApproval">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r5_escalateToStaff">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 6: Reschedule within 48 hours requires approval -->
      <rule id="Rule_reschedule_short_notice">
        <description>Reschedule appointment within 48 hours: requires approval due to complex scheduling</description>
        <inputEntry id="InputEntry_r6_actionType">
          <text>"reschedule"</text>
        </inputEntry>
        <inputEntry id="InputEntry_r6_patientRiskLevel">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r6_timeWindowHours">
          <text>&lt; 48</text>
        </inputEntry>
        <inputEntry id="InputEntry_r6_complexityScore">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r6_allowSelfService">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r6_requiresApproval">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r6_escalateToStaff">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 7: Reschedule 48+ hours - low risk -->
      <rule id="Rule_reschedule_low_risk">
        <description>Reschedule appointment 48+ hours in advance for low-risk: allow self-service</description>
        <inputEntry id="InputEntry_r7_actionType">
          <text>"reschedule"</text>
        </inputEntry>
        <inputEntry id="InputEntry_r7_patientRiskLevel">
          <text>"low"</text>
        </inputEntry>
        <inputEntry id="InputEntry_r7_timeWindowHours">
          <text>&gt;= 48</text>
        </inputEntry>
        <inputEntry id="InputEntry_r7_complexityScore">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r7_allowSelfService">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r7_requiresApproval">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r7_escalateToStaff">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 8: Reschedule 48+ hours - medium risk needs approval -->
      <rule id="Rule_reschedule_medium_risk">
        <description>Reschedule appointment 48+ hours in advance for medium-risk: allow but needs review</description>
        <inputEntry id="InputEntry_r8_actionType">
          <text>"reschedule"</text>
        </inputEntry>
        <inputEntry id="InputEntry_r8_patientRiskLevel">
          <text>"medium"</text>
        </inputEntry>
        <inputEntry id="InputEntry_r8_timeWindowHours">
          <text>&gt;= 48</text>
        </inputEntry>
        <inputEntry id="InputEntry_r8_complexityScore">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r8_allowSelfService">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r8_requiresApproval">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r8_escalateToStaff">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 9: Payment - always allow for non-high risk -->
      <rule id="Rule_pay_non_high">
        <description>Payment action: always allow self-service for low and medium risk patients</description>
        <inputEntry id="InputEntry_r9_actionType">
          <text>"pay"</text>
        </inputEntry>
        <inputEntry id="InputEntry_r9_patientRiskLevel">
          <text>"low","medium"</text>
        </inputEntry>
        <inputEntry id="InputEntry_r9_timeWindowHours">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r9_complexityScore">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r9_allowSelfService">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r9_requiresApproval">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r9_escalateToStaff">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 10: Simple questions via FAQ bot -->
      <rule id="Rule_question_simple">
        <description>Simple questions (complexity &lt; 30): handle via automated FAQ bot</description>
        <inputEntry id="InputEntry_r10_actionType">
          <text>"question"</text>
        </inputEntry>
        <inputEntry id="InputEntry_r10_patientRiskLevel">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r10_timeWindowHours">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r10_complexityScore">
          <text>&lt; 30</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r10_allowSelfService">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r10_requiresApproval">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r10_escalateToStaff">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 11: Moderate complexity questions -->
      <rule id="Rule_question_moderate">
        <description>Moderate complexity questions (30-70): allow self-service but flag for review</description>
        <inputEntry id="InputEntry_r11_actionType">
          <text>"question"</text>
        </inputEntry>
        <inputEntry id="InputEntry_r11_patientRiskLevel">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r11_timeWindowHours">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r11_complexityScore">
          <text>[30..70]</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r11_allowSelfService">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r11_requiresApproval">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r11_escalateToStaff">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 12: Complex questions escalate to staff -->
      <rule id="Rule_question_complex">
        <description>Complex questions (complexity &gt; 70): escalate to staff for personalized response</description>
        <inputEntry id="InputEntry_r12_actionType">
          <text>"question"</text>
        </inputEntry>
        <inputEntry id="InputEntry_r12_patientRiskLevel">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r12_timeWindowHours">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r12_complexityScore">
          <text>&gt; 70</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r12_allowSelfService">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r12_requiresApproval">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r12_escalateToStaff">
          <text>true</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <inputData id="InputData_actionType" name="Action Type"/>
  <inputData id="InputData_patientRiskLevel" name="Patient Risk Level"/>
  <inputData id="InputData_timeWindowHours" name="Time Window Hours"/>
  <inputData id="InputData_complexityScore" name="Complexity Score"/>

</definitions>
