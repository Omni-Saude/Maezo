<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_DQ_FRESHNESS_001"
             name="DQ_FRESHNESS_001"
             targetNamespace="http://healthcare.platform/dmn/platform_services/analytics">
  <decision id="Decision_DQ_FRESHNESS_001" name="Data Freshness Rules">
    <decisionTable id="DecisionTable_DQ_FRESHNESS_001" hitPolicy="FIRST">
      <input id="Input_dataSource" label="Data Source">
        <inputExpression id="InputExpression_dataSource" typeRef="string">
          <text>dataSource</text>
        </inputExpression>
      </input>
      <input id="Input_hoursSinceUpdate" label="Hours Since Update">
        <inputExpression id="InputExpression_hoursSinceUpdate" typeRef="number">
          <text>hoursSinceUpdate</text>
        </inputExpression>
      </input>
      <input id="Input_entityType" label="Entity Type">
        <inputExpression id="InputExpression_entityType" typeRef="string">
          <text>entityType</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string" />
      <output id="Output_observacao" label="Observação" name="observacao" typeRef="string" />
      <output id="Output_acaoRecomendada" label="Ação Recomendada" name="acaoRecomendada" typeRef="string" />
      <output id="Output_alertasConformidade" label="Alertas Conformidade" name="alertasConformidade" typeRef="string" />
      <output id="Output_riscoDenial" label="Risco Denial" name="riscoDenial" typeRef="string" />
      <rule id="Rule_DQ_FRESHNESS_001_1">
        <inputEntry id="InputEntry_DQ_FRESHNESS_001_1_1"><text>"LAB_RESULTS"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_FRESHNESS_001_1_2"><text>&gt; 48</text></inputEntry>
        <inputEntry id="InputEntry_DQ_FRESHNESS_001_1_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_1_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_1_2"><text>"Resultados laboratoriais desatualizados (&gt;48h)"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_1_3"><text>"Forçar sincronização imediata com laboratório"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_1_4"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_1_5"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_FRESHNESS_001_2">
        <inputEntry id="InputEntry_DQ_FRESHNESS_001_2_1"><text>"VITAL_SIGNS"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_FRESHNESS_001_2_2"><text>&gt; 6</text></inputEntry>
        <inputEntry id="InputEntry_DQ_FRESHNESS_001_2_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_2_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_2_2"><text>"Sinais vitais desatualizados (&gt;6h)"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_2_3"><text>"Solicitar nova coleta de sinais vitais"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_2_4"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_2_5"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_FRESHNESS_001_3">
        <inputEntry id="InputEntry_DQ_FRESHNESS_001_3_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_FRESHNESS_001_3_2"><text>[24..72]</text></inputEntry>
        <inputEntry id="InputEntry_DQ_FRESHNESS_001_3_3"><text>"PATIENT", "ENCOUNTER"</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_3_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_3_2"><text>"Dados com atualização atrasada (24-72h)"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_3_3"><text>"Verificar conectividade e agendar sincronização"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_3_4"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_3_5"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_FRESHNESS_001_4">
        <inputEntry id="InputEntry_DQ_FRESHNESS_001_4_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_FRESHNESS_001_4_2"><text>&lt; 24</text></inputEntry>
        <inputEntry id="InputEntry_DQ_FRESHNESS_001_4_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_4_1"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_4_2"><text>"Dados dentro do prazo de atualização (&lt;24h)"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_4_3"><text>"Continuar sincronização normal"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_4_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_4_5"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_FRESHNESS_001_5">
        <inputEntry id="InputEntry_DQ_FRESHNESS_001_5_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_FRESHNESS_001_5_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_FRESHNESS_001_5_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_5_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_5_2"><text>"Fonte ou tipo não mapeado para regras de freshness"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_5_3"><text>"Definir política de atualização para este tipo"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_5_4"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_001_5_5"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DQ_FRESHNESS_001">
      <dmndi:DMNShape id="DMNShape_DQ_FRESHNESS_001" dmnElementRef="Decision_DQ_FRESHNESS_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
