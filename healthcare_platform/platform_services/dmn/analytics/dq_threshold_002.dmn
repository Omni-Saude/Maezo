<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_DQ_THRESHOLD_002"
             name="DQ_THRESHOLD_002"
             targetNamespace="http://healthcare.platform/dmn/platform_services/analytics">
  <decision id="Decision_DQ_THRESHOLD_002" name="Data Quality Scoring By Entity Type">
    <decisionTable id="DecisionTable_DQ_THRESHOLD_002" hitPolicy="FIRST">
      <input id="Input_entityType" label="Entity Type">
        <inputExpression id="InputExpression_entityType" typeRef="string">
          <text>entityType</text>
        </inputExpression>
      </input>
      <input id="Input_qualityDimension" label="Quality Dimension">
        <inputExpression id="InputExpression_qualityDimension" typeRef="string">
          <text>qualityDimension</text>
        </inputExpression>
      </input>
      <input id="Input_scoreValue" label="Score Value">
        <inputExpression id="InputExpression_scoreValue" typeRef="number">
          <text>scoreValue</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string" />
      <output id="Output_observacao" label="Observação" name="observacao" typeRef="string" />
      <output id="Output_acaoRecomendada" label="Ação Recomendada" name="acaoRecomendada" typeRef="string" />
      <output id="Output_alertasConformidade" label="Alertas Conformidade" name="alertasConformidade" typeRef="string" />
      <output id="Output_riscoDenial" label="Risco Denial" name="riscoDenial" typeRef="string" />
      <rule id="Rule_DQ_THRESHOLD_002_1">
        <inputEntry id="InputEntry_DQ_THRESHOLD_002_1_1"><text>"PATIENT"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_THRESHOLD_002_1_2"><text>"COMPLETENESS"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_THRESHOLD_002_1_3"><text>&lt; 0.85</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_1_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_1_2"><text>"Dados de paciente com completude crítica"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_1_3"><text>"Solicitar complementação cadastral"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_1_4"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_1_5"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_THRESHOLD_002_2">
        <inputEntry id="InputEntry_DQ_THRESHOLD_002_2_1"><text>"ENCOUNTER"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_THRESHOLD_002_2_2"><text>"ACCURACY"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_THRESHOLD_002_2_3"><text>&lt; 0.7</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_2_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_2_2"><text>"Atendimento com acurácia inadequada"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_2_3"><text>"Validar dados clínicos com prontuário"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_2_4"><text>"DUP"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_2_5"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_THRESHOLD_002_3">
        <inputEntry id="InputEntry_DQ_THRESHOLD_002_3_1"><text>"LAB_RESULT"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_THRESHOLD_002_3_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_THRESHOLD_002_3_3"><text>[0.6..0.8)</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_3_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_3_2"><text>"Resultado laboratorial com qualidade mediana"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_3_3"><text>"Auditar integração com sistema de laboratório"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_3_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_3_5"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_THRESHOLD_002_4">
        <inputEntry id="InputEntry_DQ_THRESHOLD_002_4_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_THRESHOLD_002_4_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_THRESHOLD_002_4_3"><text>&gt;= 0.85</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_4_1"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_4_2"><text>"Qualidade adequada para a entidade"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_4_3"><text>"Continuar monitoramento padrão"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_4_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_4_5"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_THRESHOLD_002_5">
        <inputEntry id="InputEntry_DQ_THRESHOLD_002_5_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_THRESHOLD_002_5_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_THRESHOLD_002_5_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_5_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_5_2"><text>"Cenário não mapeado - revisão necessária"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_5_3"><text>"Encaminhar para analista de dados"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_5_4"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_002_5_5"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DQ_THRESHOLD_002">
      <dmndi:DMNShape id="DMNShape_DQ_THRESHOLD_002" dmnElementRef="Decision_DQ_THRESHOLD_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
