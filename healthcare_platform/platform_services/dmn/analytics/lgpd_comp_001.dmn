<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             id="lgpd_comp_001"
             name="LGPD Compliance Check"
             namespace="https://healthcare-platform/platform_services">
  <decision id="decision_lgpd_comp_001" name="LGPD Data Privacy Compliance">
    <decisionTable id="dt_lgpd_comp_001" hitPolicy="FIRST">
      <input id="input_1" label="Consent Status">
        <inputExpression id="ie_1" typeRef="string">
          <text>consent_status</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Data Sensitivity">
        <inputExpression id="ie_2" typeRef="string">
          <text>data_sensitivity</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="resultado" typeRef="string"/>
      <output id="output_acao" label="acao" typeRef="string"/>
      <output id="output_risco" label="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie1_1"><text>"revoked"</text></inputEntry>
        <inputEntry id="ie1_2"><text>-</text></inputEntry>
        <outputEntry id="oe1_1"><text>"BLOQUEADO"</text></outputEntry>
        <outputEntry id="oe1_2"><text>"Consentimento revogado - anonimizar dados"</text></outputEntry>
        <outputEntry id="oe1_3"><text>"critico"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie2_1"><text>"missing"</text></inputEntry>
        <inputEntry id="ie2_2"><text>"sensitive"</text></inputEntry>
        <outputEntry id="oe2_1"><text>"NAO_AUTORIZADO"</text></outputEntry>
        <outputEntry id="oe2_2"><text>"Dados sensíveis sem consentimento"</text></outputEntry>
        <outputEntry id="oe2_3"><text>"critico"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie3_1"><text>"expired"</text></inputEntry>
        <inputEntry id="ie3_2"><text>-</text></inputEntry>
        <outputEntry id="oe3_1"><text>"RENOVAR"</text></outputEntry>
        <outputEntry id="oe3_2"><text>"Solicitar renovação de consentimento"</text></outputEntry>
        <outputEntry id="oe3_3"><text>"alto"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie4_1"><text>"pending"</text></inputEntry>
        <inputEntry id="ie4_2"><text>-</text></inputEntry>
        <outputEntry id="oe4_1"><text>"AGUARDANDO"</text></outputEntry>
        <outputEntry id="oe4_2"><text>"Aguardar confirmação de consentimento"</text></outputEntry>
        <outputEntry id="oe4_3"><text>"medio"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie5_1"><text>"active"</text></inputEntry>
        <inputEntry id="ie5_2"><text>-</text></inputEntry>
        <outputEntry id="oe5_1"><text>"AUTORIZADO"</text></outputEntry>
        <outputEntry id="oe5_2"><text>"Consentimento válido"</text></outputEntry>
        <outputEntry id="oe5_3"><text>"baixo"</text></outputEntry>
      </rule>
      <rule id="rule_6">
        <inputEntry id="ie6_1"><text>-</text></inputEntry>
        <inputEntry id="ie6_2"><text>-</text></inputEntry>
        <outputEntry id="oe6_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe6_2"><text>"Processar normalmente"</text></outputEntry>
        <outputEntry id="oe6_3"><text>"baixo"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
