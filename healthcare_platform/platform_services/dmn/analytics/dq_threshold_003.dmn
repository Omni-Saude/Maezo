<?xml version='1.0' encoding='UTF-8'?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_DQ_THRESHOLD_003"
             name="DQ_THRESHOLD_003"
             targetNamespace="http://healthcare.platform/dmn/platform_services/analytics">
  <decision id="Decision_DQ_THRESHOLD_003" name="Data Quality Remediation Actions">
    <decisionTable id="DecisionTable_DQ_THRESHOLD_003" hitPolicy="FIRST">
      <input id="Input_severityLevel" label="Severity Level">
        <inputExpression id="InputExpression_severityLevel" typeRef="string">
          <text>severityLevel</text>
        </inputExpression>
      </input>
      <input id="Input_dimensionAffected" label="Dimension Affected">
        <inputExpression id="InputExpression_dimensionAffected" typeRef="string">
          <text>dimensionAffected</text>
        </inputExpression>
      </input>
      <input id="Input_affectedRecords" label="Affected Records">
        <inputExpression id="InputExpression_affectedRecords" typeRef="number">
          <text>affectedRecords</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string" />
      <output id="Output_observacao" label="Observação" name="observacao" typeRef="string" />
      <output id="Output_acaoRecomendada" label="Ação Recomendada" name="acaoRecomendada" typeRef="string" />
      <output id="Output_alertasConformidade" label="Alertas Conformidade" name="alertasConformidade" typeRef="string" />
      <output id="Output_riscoDenial" label="Risco Denial" name="riscoDenial" typeRef="string" />
      <rule id="Rule_DQ_THRESHOLD_003_1">
        <inputEntry id="InputEntry_DQ_THRESHOLD_003_1_1"><text>"CRITICAL"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_THRESHOLD_003_1_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_THRESHOLD_003_1_3"><text>&gt; 1000</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_1_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_1_2"><text>"Problema crítico afetando mais de 1000 registros"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_1_3"><text>"Iniciar remediação emergencial em lote"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_1_4"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_1_5"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_THRESHOLD_003_2">
        <inputEntry id="InputEntry_DQ_THRESHOLD_003_2_1"><text>"CRITICAL"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_THRESHOLD_003_2_2"><text>"ACCURACY"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_THRESHOLD_003_2_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_2_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_2_2"><text>"Acurácia crítica comprometida"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_2_3"><text>"Recalcular e validar contra fonte primária"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_2_4"><text>"DUP"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_2_5"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_THRESHOLD_003_3">
        <inputEntry id="InputEntry_DQ_THRESHOLD_003_3_1"><text>"HIGH"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_THRESHOLD_003_3_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_THRESHOLD_003_3_3"><text>[100..1000]</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_3_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_3_2"><text>"Problema de alta severidade com impacto moderado"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_3_3"><text>"Agendar correção prioritária em 24h"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_3_4"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_3_5"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_THRESHOLD_003_4">
        <inputEntry id="InputEntry_DQ_THRESHOLD_003_4_1"><text>"LOW", "MEDIUM"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_THRESHOLD_003_4_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_THRESHOLD_003_4_3"><text>&lt; 100</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_4_1"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_4_2"><text>"Problema de baixa severidade e impacto limitado"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_4_3"><text>"Incluir em próximo ciclo de limpeza"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_4_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_4_5"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_THRESHOLD_003_5">
        <inputEntry id="InputEntry_DQ_THRESHOLD_003_5_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_THRESHOLD_003_5_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_THRESHOLD_003_5_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_5_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_5_2"><text>"Situação não categorizada - análise necessária"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_5_3"><text>"Escalar para gestor de qualidade"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_5_4"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_THRESHOLD_003_5_5"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DQ_THRESHOLD_003">
      <dmndi:DMNShape id="DMNShape_DQ_THRESHOLD_003" dmnElementRef="Decision_DQ_THRESHOLD_003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
