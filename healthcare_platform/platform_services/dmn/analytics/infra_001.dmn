<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             id="infra_001"
             name="Infrastructure Health Check"
             namespace="https://healthcare-platform/platform_services">
  <decision id="decision_infra_001" name="Infrastructure Status Decision">
    <decisionTable id="dt_infra_001" hitPolicy="FIRST">
      <input id="input_1" label="CPU Usage">
        <inputExpression id="ie_1" typeRef="number">
          <text>cpu_usage</text>
        </inputExpression>
      </input>
      <input id="input_2" label="Memory Usage">
        <inputExpression id="ie_2" typeRef="number">
          <text>memory_usage</text>
        </inputExpression>
      </input>
      <output id="output_resultado" label="resultado" typeRef="string"/>
      <output id="output_acao" label="acao" typeRef="string"/>
      <output id="output_risco" label="risco" typeRef="string"/>
      <rule id="rule_1">
        <inputEntry id="ie1_1"><text>&gt; 90</text></inputEntry>
        <inputEntry id="ie1_2"><text>&gt; 90</text></inputEntry>
        <outputEntry id="oe1_1"><text>"CRITICO"</text></outputEntry>
        <outputEntry id="oe1_2"><text>"Recursos críticos - escalar imediatamente"</text></outputEntry>
        <outputEntry id="oe1_3"><text>"critico"</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <inputEntry id="ie2_1"><text>&gt; 85</text></inputEntry>
        <inputEntry id="ie2_2"><text>-</text></inputEntry>
        <outputEntry id="oe2_1"><text>"ALTO_USO_CPU"</text></outputEntry>
        <outputEntry id="oe2_2"><text>"CPU alta - avaliar escalamento"</text></outputEntry>
        <outputEntry id="oe2_3"><text>"alto"</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <inputEntry id="ie3_1"><text>-</text></inputEntry>
        <inputEntry id="ie3_2"><text>&gt; 85</text></inputEntry>
        <outputEntry id="oe3_1"><text>"ALTO_USO_MEM"</text></outputEntry>
        <outputEntry id="oe3_2"><text>"Memória alta - verificar vazamentos"</text></outputEntry>
        <outputEntry id="oe3_3"><text>"alto"</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <inputEntry id="ie4_1"><text>&gt; 70</text></inputEntry>
        <inputEntry id="ie4_2"><text>&gt; 70</text></inputEntry>
        <outputEntry id="oe4_1"><text>"ATENCAO"</text></outputEntry>
        <outputEntry id="oe4_2"><text>"Monitorar recursos de perto"</text></outputEntry>
        <outputEntry id="oe4_3"><text>"medio"</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <inputEntry id="ie5_1"><text>&lt;= 70</text></inputEntry>
        <inputEntry id="ie5_2"><text>&lt;= 70</text></inputEntry>
        <outputEntry id="oe5_1"><text>"SAUDAVEL"</text></outputEntry>
        <outputEntry id="oe5_2"><text>"Recursos operando normalmente"</text></outputEntry>
        <outputEntry id="oe5_3"><text>"baixo"</text></outputEntry>
      </rule>
      <rule id="rule_6">
        <inputEntry id="ie6_1"><text>-</text></inputEntry>
        <inputEntry id="ie6_2"><text>-</text></inputEntry>
        <outputEntry id="oe6_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe6_2"><text>"Processar normalmente"</text></outputEntry>
        <outputEntry id="oe6_3"><text>"baixo"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
