<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  WRITEOFF-POLICY - Politica de Baixa de Divida Incobravel
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_ESCALATION
  Archetype: THRESHOLD | Source: write_off_bad_debt_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_WRITEOFF_POLICY"
             name="Politica de Baixa de Divida Incobravel"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_WRITEOFF_POLICY" name="Politica de Baixa de Divida Incobravel">
    <decisionTable id="DecisionTable_WRITEOFF_POLICY" hitPolicy="FIRST">

      <input id="Input_1" label="Valor Divida">
        <inputExpression id="InputExpression_1" typeRef="number">
          <text>debtAmount</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Dias em Atraso">
        <inputExpression id="InputExpression_2" typeRef="number">
          <text>daysOverdue</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Motivo Baixa">
        <inputExpression id="InputExpression_3" typeRef="string">
          <text>writeoffReason</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1">
        <description>Valor alto requer aprovacao diretoria</description>
        <inputEntry id="IE_1_1"><text>&gt;= 10000</text></inputEntry>
        <inputEntry id="IE_1_2"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"Valor acima de R$10k requer aprovacao da diretoria financeira"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <description>Obito do paciente - baixa automatica</description>
        <inputEntry id="IE_2_1"><text>&lt; 10000</text></inputEntry>
        <inputEntry id="IE_2_2"><text>-</text></inputEntry>
        <inputEntry id="IE_2_3"><text>"PATIENT_DECEASED"</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"Baixa automatica por obito - registrar na contabilidade"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <description>Insolvencia comprovada</description>
        <inputEntry id="IE_3_1"><text>&lt; 10000</text></inputEntry>
        <inputEntry id="IE_3_2"><text>&gt;= 365</text></inputEntry>
        <inputEntry id="IE_3_3"><text>"INSOLVENCY"</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"Insolvencia documentada - aprovar baixa com registro fiscal"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_4">
        <description>Atraso insuficiente para baixa</description>
        <inputEntry id="IE_4_1"><text>-</text></inputEntry>
        <inputEntry id="IE_4_2"><text>&lt; 180</text></inputEntry>
        <inputEntry id="IE_4_3"><text>not("PATIENT_DECEASED","INSOLVENCY")</text></inputEntry>
        <outputEntry id="OE_4_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_4_2"><text>"Minimo 180 dias de atraso para baixa - continuar cobranca"</text></outputEntry>
        <outputEntry id="OE_4_3"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_5">
        <description>Valor baixo com atraso longo - baixa operacional</description>
        <inputEntry id="IE_5_1"><text>&lt; 500</text></inputEntry>
        <inputEntry id="IE_5_2"><text>&gt;= 180</text></inputEntry>
        <inputEntry id="IE_5_3"><text>-</text></inputEntry>
        <outputEntry id="OE_5_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_2"><text>"Valor residual com atraso longo - aprovacao automatica de baixa"</text></outputEntry>
        <outputEntry id="OE_5_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_6">
        <description>Valor medio com atraso longo - aprovacao gerencial</description>
        <inputEntry id="IE_6_1"><text>[500..10000]</text></inputEntry>
        <inputEntry id="IE_6_2"><text>&gt;= 365</text></inputEntry>
        <inputEntry id="IE_6_3"><text>-</text></inputEntry>
        <outputEntry id="OE_6_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_6_2"><text>"Baixa requer aprovacao do gerente financeiro"</text></outputEntry>
        <outputEntry id="OE_6_3"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Fallback</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"Avaliar politica de baixa manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_WRITEOFF_POLICY">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_WRITEOFF_POLICY">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
