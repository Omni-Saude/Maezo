<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  LEGAL-THRESHOLD - Limites para Escalacao Juridica
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_ESCALATION
  Archetype: THRESHOLD | Source: escalate_to_legal_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_LEGAL_THRESHOLD"
             name="Limites para Escalacao Juridica"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_LEGAL_THRESHOLD" name="Limites para Escalacao Juridica">
    <decisionTable id="DecisionTable_LEGAL_THRESHOLD" hitPolicy="FIRST">

      <input id="Input_1" label="Dias em Atraso">
        <inputExpression id="InputExpression_1" typeRef="number">
          <text>daysOverdue</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Valor Devedor">
        <inputExpression id="InputExpression_2" typeRef="number">
          <text>amountDue</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Tentativas Cobranca">
        <inputExpression id="InputExpression_3" typeRef="number">
          <text>collectionAttempts</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1">
        <description>180+ dias e valor alto - escalacao juridica imediata</description>
        <inputEntry id="IE_1_1"><text>&gt;= 180</text></inputEntry>
        <inputEntry id="IE_1_2"><text>&gt;= 50000</text></inputEntry>
        <inputEntry id="IE_1_3"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"Criterios de escalacao juridica atingidos - encaminhar ao departamento legal"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <description>360+ dias qualquer valor - prescricao iminente</description>
        <inputEntry id="IE_2_1"><text>&gt;= 360</text></inputEntry>
        <inputEntry id="IE_2_2"><text>-</text></inputEntry>
        <inputEntry id="IE_2_3"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"Risco de prescricao - escalacao juridica urgente independente do valor"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <description>Muitas tentativas sem sucesso</description>
        <inputEntry id="IE_3_1"><text>[90..180]</text></inputEntry>
        <inputEntry id="IE_3_2"><text>&gt;= 20000</text></inputEntry>
        <inputEntry id="IE_3_3"><text>&gt;= 5</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"Esgotamento de tentativas administrativas - avaliar escalacao juridica"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_4">
        <description>Valor baixo - nao justifica custo juridico</description>
        <inputEntry id="IE_4_1"><text>-</text></inputEntry>
        <inputEntry id="IE_4_2"><text>&lt; 5000</text></inputEntry>
        <inputEntry id="IE_4_3"><text>-</text></inputEntry>
        <outputEntry id="OE_4_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_4_2"><text>"Valor abaixo de R$5k - custo juridico nao justifica a acao"</text></outputEntry>
        <outputEntry id="OE_4_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_5">
        <description>Atraso moderado - continuar cobranca administrativa</description>
        <inputEntry id="IE_5_1"><text>&lt; 90</text></inputEntry>
        <inputEntry id="IE_5_2"><text>-</text></inputEntry>
        <inputEntry id="IE_5_3"><text>&lt; 3</text></inputEntry>
        <outputEntry id="OE_5_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_5_2"><text>"Prazo e tentativas insuficientes - manter cobranca administrativa"</text></outputEntry>
        <outputEntry id="OE_5_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Fallback</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"Avaliar necessidade de escalacao juridica"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_LEGAL_THRESHOLD">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_LEGAL_THRESHOLD">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
