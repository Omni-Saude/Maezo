<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" id="Definitions_legal_escalation_threshold" name="Legal Escalation Threshold" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: escalate_to_legal_worker.py -->
  <decision id="Decision_legal_escalation_threshold" name="Legal Escalation Threshold">
    <decisionTable id="DecisionTable_legal_escalation_threshold" hitPolicy="FIRST">
      <input id="Input_attempts" label="Tentativas Cobranca"><inputExpression id="IE_att" typeRef="integer"><text>collection_attempts</text></inputExpression></input>
      <input id="Input_has_reason" label="Razao Explicita"><inputExpression id="IE_reason" typeRef="boolean"><text>has_explicit_reason</text></inputExpression></input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1"><inputEntry id="U1a"><text></text></inputEntry><inputEntry id="U1b"><text>true</text></inputEntry><outputEntry id="L1"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L1a"><text>"Escalacao por razao explicita - processar"</text></outputEntry><outputEntry id="L1b"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2"><inputEntry id="U2a"><text>>= 10</text></inputEntry><inputEntry id="U2b"><text></text></inputEntry><outputEntry id="L2"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L2a"><text>"Esgotadas tentativas de cobranca"</text></outputEntry><outputEntry id="L2b"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_3"><inputEntry id="U3a"><text>[5..10)</text></inputEntry><inputEntry id="U3b"><text></text></inputEntry><outputEntry id="L3"><text>"REVISAR"</text></outputEntry><outputEntry id="L3a"><text>"Muitas tentativas - considerar juridico"</text></outputEntry><outputEntry id="L3b"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_4"><inputEntry id="U4a"><text>[3..5)</text></inputEntry><inputEntry id="U4b"><text></text></inputEntry><outputEntry id="L4"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a"><text>"Continuar tentativas de cobranca"</text></outputEntry><outputEntry id="L4b"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_5"><inputEntry id="U5a"><text>&lt; 3</text></inputEntry><inputEntry id="U5b"><text></text></inputEntry><outputEntry id="L5"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a"><text>"Poucas tentativas - insistir"</text></outputEntry><outputEntry id="L5b"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>
</definitions>
