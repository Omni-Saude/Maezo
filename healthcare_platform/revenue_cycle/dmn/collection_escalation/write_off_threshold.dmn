<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" id="Definitions_write_off_threshold" name="Write Off Threshold" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: write_off_bad_debt_worker.py -->
  <decision id="Decision_write_off_threshold" name="Write Off Threshold">
    <decisionTable id="DecisionTable_write_off_threshold" hitPolicy="FIRST">
      <input id="Input_amount_due_t" label="Valor Devido"><inputExpression id="IE_amount_due_t" typeRef="double"><text>amount_due</text></inputExpression></input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1"><inputEntry id="U1"><text>>= 50000</text></inputEntry><outputEntry id="L1"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L1a"><text>"Write-off alto - aprovacao diretoria"</text></outputEntry><outputEntry id="L1b"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2"><inputEntry id="U2"><text>[10000..50000)</text></inputEntry><outputEntry id="L2"><text>"REVISAR"</text></outputEntry><outputEntry id="L2a"><text>"Write-off medio - aprovacao gerencial"</text></outputEntry><outputEntry id="L2b"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_3"><inputEntry id="U3"><text>[5000..10000)</text></inputEntry><outputEntry id="L3"><text>"REVISAR"</text></outputEntry><outputEntry id="L3a"><text>"Write-off - aprovacao supervisor"</text></outputEntry><outputEntry id="L3b"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_4"><inputEntry id="U4"><text>[1000..5000)</text></inputEntry><outputEntry id="L4"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a"><text>"Write-off baixo - auto-aprovado"</text></outputEntry><outputEntry id="L4b"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_5"><inputEntry id="U5"><text>&lt; 1000</text></inputEntry><outputEntry id="L5"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a"><text>"Write-off minimo - auto-aprovado"</text></outputEntry><outputEntry id="L5b"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>
</definitions>
