<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" id="Definitions_collection_call_threshold" name="Collection Call Threshold" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: schedule_collection_call_worker.py -->
  <decision id="Decision_collection_call_threshold" name="Collection Call Threshold">
    <decisionTable id="DecisionTable_collection_call_threshold" hitPolicy="FIRST">
      <input id="Input_days_overdue_t" label="Dias Vencidos"><inputExpression id="IE_days_overdue_t" typeRef="integer"><text>days_overdue</text></inputExpression></input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1"><inputEntry id="U1"><text>> 90</text></inputEntry><outputEntry id="L1"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L1a"><text>"Ligacao com SLA minimo"</text></outputEntry><outputEntry id="L1b"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2"><inputEntry id="U2"><text>(60..90]</text></inputEntry><outputEntry id="L2"><text>"REVISAR"</text></outputEntry><outputEntry id="L2a"><text>"Agendar ligacao prioritaria"</text></outputEntry><outputEntry id="L2b"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_3"><inputEntry id="U3"><text>(30..60]</text></inputEntry><outputEntry id="L3"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L3a"><text>"Agendar ligacao normal"</text></outputEntry><outputEntry id="L3b"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_4"><inputEntry id="U4"><text>(7..30]</text></inputEntry><outputEntry id="L4"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a"><text>"Fila normal de ligacoes"</text></outputEntry><outputEntry id="L4b"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_5"><inputEntry id="U5"><text>&lt;= 7</text></inputEntry><outputEntry id="L5"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a"><text>"Enviar lembrete antes de ligar"</text></outputEntry><outputEntry id="L5b"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>
</definitions>
