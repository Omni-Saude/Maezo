<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_reconcile_weekly_validation"
             name="Reconcile Weekly Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: reconcile_weekly_worker.py -->
  <decision id="Decision_reconcile_weekly_validation" name="Reconcile Weekly Validation">
    <decisionTable id="DecisionTable_reconcile_weekly_validation" hitPolicy="FIRST">
      <input id="Input_week_start_valid" label="Inicio Semana Valido">
        <inputExpression id="InputExpression_week_start_valid" typeRef="boolean">
          <text>week_start_valid</text>
        </inputExpression>
      </input>
      <input id="Input_daily_recons" label="Reconciliacoes Diarias">
        <inputExpression id="InputExpression_daily_recons" typeRef="integer">
          <text>daily_reconciliations</text>
        </inputExpression>
      </input>
      <input id="Input_has_previous_week" label="Tem Semana Anterior">
        <inputExpression id="InputExpression_has_previous_week" typeRef="boolean">
          <text>has_previous_week</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="Input_1_1"><text>true</text></inputEntry>
        <inputEntry id="Input_1_2"><text>7</text></inputEntry>
        <inputEntry id="Input_1_3"><text>true</text></inputEntry>
        <outputEntry id="Output_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2"><text>"Semana completa com baseline para comparacao"</text></outputEntry>
        <outputEntry id="Output_1_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="Input_2_1"><text>true</text></inputEntry>
        <inputEntry id="Input_2_2"><text>[5..6]</text></inputEntry>
        <inputEntry id="Input_2_3"><text></text></inputEntry>
        <outputEntry id="Output_2_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_2_2"><text>"Semana parcial - dias uteis apenas"</text></outputEntry>
        <outputEntry id="Output_2_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="Input_3_1"><text>true</text></inputEntry>
        <inputEntry id="Input_3_2"><text>&lt; 5</text></inputEntry>
        <inputEntry id="Input_3_3"><text></text></inputEntry>
        <outputEntry id="Output_3_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_3_2"><text>"Menos de 5 reconciliacoes diarias - semana incompleta"</text></outputEntry>
        <outputEntry id="Output_3_3"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="Input_4_1"><text>true</text></inputEntry>
        <inputEntry id="Input_4_2"><text></text></inputEntry>
        <inputEntry id="Input_4_3"><text>false</text></inputEntry>
        <outputEntry id="Output_4_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_4_2"><text>"Sem semana anterior - tendencia indisponivel"</text></outputEntry>
        <outputEntry id="Output_4_3"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="Input_5_1"><text>false</text></inputEntry>
        <inputEntry id="Input_5_2"><text></text></inputEntry>
        <inputEntry id="Input_5_3"><text></text></inputEntry>
        <outputEntry id="Output_5_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_5_2"><text>"Data de inicio da semana invalida"</text></outputEntry>
        <outputEntry id="Output_5_3"><text>"ALTO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
