<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_finalize_allocation_routing"
             name="Finalize Allocation Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: finalize_allocation_worker.py -->
  <decision id="Decision_finalize_allocation_routing" name="Finalize Allocation Routing">
    <decisionTable id="DecisionTable_finalize_allocation_routing" hitPolicy="FIRST">
      <input id="Input_already_locked" label="Ja Bloqueado">
        <inputExpression id="InputExpression_already_locked" typeRef="boolean">
          <text>already_locked</text>
        </inputExpression>
      </input>
      <input id="Input_force_lock" label="Forcar Bloqueio">
        <inputExpression id="InputExpression_force_lock" typeRef="boolean">
          <text>force_lock</text>
        </inputExpression>
      </input>
      <input id="Input_allocation_status" label="Status Alocacao">
        <inputExpression id="InputExpression_allocation_status" typeRef="string">
          <text>allocation_status</text>
        </inputExpression>
        <inputValues><text>"fully_allocated","partially_allocated","escalated","auto_matched"</text></inputValues>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="Input_1_1"><text>false</text></inputEntry>
        <inputEntry id="Input_1_2"><text></text></inputEntry>
        <inputEntry id="Input_1_3"><text>"fully_allocated"</text></inputEntry>
        <outputEntry id="Output_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2"><text>"Alocacao completa - finalizar e bloquear"</text></outputEntry>
        <outputEntry id="Output_1_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="Input_2_1"><text>false</text></inputEntry>
        <inputEntry id="Input_2_2"><text></text></inputEntry>
        <inputEntry id="Input_2_3"><text>"auto_matched"</text></inputEntry>
        <outputEntry id="Output_2_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_2_2"><text>"Auto-matched - finalizar alocacao"</text></outputEntry>
        <outputEntry id="Output_2_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="Input_3_1"><text>false</text></inputEntry>
        <inputEntry id="Input_3_2"><text></text></inputEntry>
        <inputEntry id="Input_3_3"><text>"partially_allocated"</text></inputEntry>
        <outputEntry id="Output_3_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_3_2"><text>"Alocacao parcial - verificar saldo antes de finalizar"</text></outputEntry>
        <outputEntry id="Output_3_3"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="Input_4_1"><text>true</text></inputEntry>
        <inputEntry id="Input_4_2"><text>false</text></inputEntry>
        <inputEntry id="Input_4_3"><text></text></inputEntry>
        <outputEntry id="Output_4_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_4_2"><text>"Alocacao ja bloqueada - nao pode modificar"</text></outputEntry>
        <outputEntry id="Output_4_3"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="Input_5_1"><text>true</text></inputEntry>
        <inputEntry id="Input_5_2"><text>true</text></inputEntry>
        <inputEntry id="Input_5_3"><text></text></inputEntry>
        <outputEntry id="Output_5_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_5_2"><text>"Force lock solicitado - requer aprovacao especial"</text></outputEntry>
        <outputEntry id="Output_5_3"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_6">
        <inputEntry id="Input_6_1"><text>false</text></inputEntry>
        <inputEntry id="Input_6_2"><text></text></inputEntry>
        <inputEntry id="Input_6_3"><text>"escalated"</text></inputEntry>
        <outputEntry id="Output_6_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_6_2"><text>"Alocacao escalada - resolver antes de finalizar"</text></outputEntry>
        <outputEntry id="Output_6_3"><text>"CRITICO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
