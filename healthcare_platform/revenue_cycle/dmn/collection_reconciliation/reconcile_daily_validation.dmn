<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_reconcile_daily_validation"
             name="Reconcile Daily Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: reconcile_daily_worker.py -->
  <decision id="Decision_reconcile_daily_validation" name="Reconcile Daily Validation">
    <decisionTable id="DecisionTable_reconcile_daily_validation" hitPolicy="FIRST">
      <input id="Input_recon_date_valid" label="Data Reconciliacao Valida">
        <inputExpression id="InputExpression_recon_date_valid" typeRef="boolean">
          <text>recon_date_valid</text>
        </inputExpression>
      </input>
      <input id="Input_tasy_available" label="TASY Disponivel">
        <inputExpression id="InputExpression_tasy_available" typeRef="boolean">
          <text>tasy_available</text>
        </inputExpression>
      </input>
      <input id="Input_variance_threshold" label="Threshold Variacao">
        <inputExpression id="InputExpression_variance_threshold" typeRef="double">
          <text>variance_threshold</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="Input_1_1"><text>true</text></inputEntry>
        <inputEntry id="Input_1_2"><text>true</text></inputEntry>
        <inputEntry id="Input_1_3"><text>[0.001..0.05]</text></inputEntry>
        <outputEntry id="Output_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2"><text>"Configuracao valida com TASY ativo"</text></outputEntry>
        <outputEntry id="Output_1_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="Input_2_1"><text>true</text></inputEntry>
        <inputEntry id="Input_2_2"><text>false</text></inputEntry>
        <inputEntry id="Input_2_3"><text></text></inputEntry>
        <outputEntry id="Output_2_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_2_2"><text>"TASY indisponivel - usar dados de fallback"</text></outputEntry>
        <outputEntry id="Output_2_3"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="Input_3_1"><text>false</text></inputEntry>
        <inputEntry id="Input_3_2"><text></text></inputEntry>
        <inputEntry id="Input_3_3"><text></text></inputEntry>
        <outputEntry id="Output_3_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_3_2"><text>"Data de reconciliacao invalida"</text></outputEntry>
        <outputEntry id="Output_3_3"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="Input_4_1"><text>true</text></inputEntry>
        <inputEntry id="Input_4_2"><text></text></inputEntry>
        <inputEntry id="Input_4_3"><text>&gt; 0.05</text></inputEntry>
        <outputEntry id="Output_4_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_4_2"><text>"Threshold de variacao muito alto - verificar config"</text></outputEntry>
        <outputEntry id="Output_4_3"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="Input_5_1"><text>true</text></inputEntry>
        <inputEntry id="Input_5_2"><text></text></inputEntry>
        <inputEntry id="Input_5_3"><text>&lt;= 0</text></inputEntry>
        <outputEntry id="Output_5_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_5_2"><text>"Threshold de variacao invalido"</text></outputEntry>
        <outputEntry id="Output_5_3"><text>"ALTO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
