<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_partial_allocation_routing"
             name="Partial Allocation Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: partial_allocation_worker.py -->
  <decision id="Decision_partial_allocation_routing" name="Partial Allocation Routing">
    <decisionTable id="DecisionTable_partial_allocation_routing" hitPolicy="FIRST">
      <input id="Input_claims_count" label="Claims Disponiveis">
        <inputExpression id="InputExpression_claims_count" typeRef="integer">
          <text>claims_count</text>
        </inputExpression>
      </input>
      <input id="Input_remaining_pct" label="Pct Remanescente">
        <inputExpression id="InputExpression_remaining_pct" typeRef="double">
          <text>remaining_pct</text>
        </inputExpression>
      </input>
      <input id="Input_claims_partial" label="Claims Parciais">
        <inputExpression id="InputExpression_claims_partial" typeRef="integer">
          <text>claims_partial</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="Input_1_1"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_1_2"><text>0</text></inputEntry>
        <inputEntry id="Input_1_3"><text>0</text></inputEntry>
        <outputEntry id="Output_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2"><text>"Pagamento totalmente alocado entre claims"</text></outputEntry>
        <outputEntry id="Output_1_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="Input_2_1"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_2_2"><text>(0..10]</text></inputEntry>
        <inputEntry id="Input_2_3"><text></text></inputEntry>
        <outputEntry id="Output_2_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_2_2"><text>"Pequeno remanescente - considerar ajuste contratual"</text></outputEntry>
        <outputEntry id="Output_2_3"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="Input_3_1"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_3_2"><text>(10..50]</text></inputEntry>
        <inputEntry id="Input_3_3"><text></text></inputEntry>
        <outputEntry id="Output_3_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_3_2"><text>"Remanescente significativo - revisar alocacao"</text></outputEntry>
        <outputEntry id="Output_3_3"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="Input_4_1"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_4_2"><text>&gt; 50</text></inputEntry>
        <inputEntry id="Input_4_3"><text></text></inputEntry>
        <outputEntry id="Output_4_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_4_2"><text>"Mais de 50% nao alocado - verificar claims"</text></outputEntry>
        <outputEntry id="Output_4_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="Input_5_1"><text>0</text></inputEntry>
        <inputEntry id="Input_5_2"><text></text></inputEntry>
        <inputEntry id="Input_5_3"><text></text></inputEntry>
        <outputEntry id="Output_5_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_5_2"><text>"Nenhum claim disponivel para alocacao parcial"</text></outputEntry>
        <outputEntry id="Output_5_3"><text>"CRITICO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
