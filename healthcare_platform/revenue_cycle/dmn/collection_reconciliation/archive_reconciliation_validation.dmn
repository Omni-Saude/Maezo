<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_archive_reconciliation_validation"
             name="Archive Reconciliation Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: archive_reconciliation_worker.py -->
  <decision id="Decision_archive_reconciliation_validation" name="Archive Reconciliation Validation">
    <decisionTable id="DecisionTable_archive_reconciliation_validation" hitPolicy="FIRST">
      <input id="Input_status" label="Status Reconciliacao">
        <inputExpression id="InputExpression_status" typeRef="string">
          <text>reconciliation_status</text>
        </inputExpression>
        <inputValues><text>"closed","balanced","unbalanced"</text></inputValues>
      </input>
      <input id="Input_batch_size" label="Tamanho Lote">
        <inputExpression id="InputExpression_batch_size" typeRef="integer">
          <text>batch_size</text>
        </inputExpression>
      </input>
      <input id="Input_has_archived_at" label="Ja Arquivado">
        <inputExpression id="InputExpression_has_archived_at" typeRef="boolean">
          <text>already_archived</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="Input_1_1"><text>"closed"</text></inputEntry>
        <inputEntry id="Input_1_2"><text>[1..500]</text></inputEntry>
        <inputEntry id="Input_1_3"><text>false</text></inputEntry>
        <outputEntry id="Output_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2"><text>"Reconciliacao fechada pronta para arquivar"</text></outputEntry>
        <outputEntry id="Output_1_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="Input_2_1"><text>"unbalanced"</text></inputEntry>
        <inputEntry id="Input_2_2"><text></text></inputEntry>
        <inputEntry id="Input_2_3"><text>false</text></inputEntry>
        <outputEntry id="Output_2_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_2_2"><text>"Reconciliacao desbalanceada - nao arquivar"</text></outputEntry>
        <outputEntry id="Output_2_3"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="Input_3_1"><text></text></inputEntry>
        <inputEntry id="Input_3_2"><text></text></inputEntry>
        <inputEntry id="Input_3_3"><text>true</text></inputEntry>
        <outputEntry id="Output_3_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_3_2"><text>"Ja arquivado - ignorar"</text></outputEntry>
        <outputEntry id="Output_3_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="Input_4_1"><text>"balanced"</text></inputEntry>
        <inputEntry id="Input_4_2"><text></text></inputEntry>
        <inputEntry id="Input_4_3"><text>false</text></inputEntry>
        <outputEntry id="Output_4_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_4_2"><text>"Reconciliacao balanceada mas nao fechada formalmente"</text></outputEntry>
        <outputEntry id="Output_4_3"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="Input_5_1"><text></text></inputEntry>
        <inputEntry id="Input_5_2"><text>&gt; 500</text></inputEntry>
        <inputEntry id="Input_5_3"><text></text></inputEntry>
        <outputEntry id="Output_5_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_5_2"><text>"Lote muito grande - reduzir para evitar timeout"</text></outputEntry>
        <outputEntry id="Output_5_3"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
