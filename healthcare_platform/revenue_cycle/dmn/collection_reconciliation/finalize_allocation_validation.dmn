<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_finalize_allocation_validation"
             name="Finalize Allocation Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: finalize_allocation_worker.py -->
  <decision id="Decision_finalize_allocation_validation" name="Finalize Allocation Validation">
    <decisionTable id="DecisionTable_finalize_allocation_validation" hitPolicy="FIRST">
      <input id="Input_allocation_id_present" label="Allocation ID Presente">
        <inputExpression id="InputExpression_allocation_id_present" typeRef="boolean">
          <text>allocation_id_present</text>
        </inputExpression>
      </input>
      <input id="Input_locked_by_present" label="Locked By Presente">
        <inputExpression id="InputExpression_locked_by_present" typeRef="boolean">
          <text>locked_by_present</text>
        </inputExpression>
      </input>
      <input id="Input_allocation_exists" label="Alocacao Existe">
        <inputExpression id="InputExpression_allocation_exists" typeRef="boolean">
          <text>allocation_exists</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="Input_1_1"><text>true</text></inputEntry>
        <inputEntry id="Input_1_2"><text>true</text></inputEntry>
        <inputEntry id="Input_1_3"><text>true</text></inputEntry>
        <outputEntry id="Output_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2"><text>"Dados completos para finalizacao"</text></outputEntry>
        <outputEntry id="Output_1_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="Input_2_1"><text>false</text></inputEntry>
        <inputEntry id="Input_2_2"><text></text></inputEntry>
        <inputEntry id="Input_2_3"><text></text></inputEntry>
        <outputEntry id="Output_2_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_2_2"><text>"Allocation ID obrigatorio"</text></outputEntry>
        <outputEntry id="Output_2_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="Input_3_1"><text>true</text></inputEntry>
        <inputEntry id="Input_3_2"><text>false</text></inputEntry>
        <inputEntry id="Input_3_3"><text>true</text></inputEntry>
        <outputEntry id="Output_3_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_3_2"><text>"Identificacao do responsavel ausente"</text></outputEntry>
        <outputEntry id="Output_3_3"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="Input_4_1"><text>true</text></inputEntry>
        <inputEntry id="Input_4_2"><text>true</text></inputEntry>
        <inputEntry id="Input_4_3"><text>false</text></inputEntry>
        <outputEntry id="Output_4_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_4_2"><text>"Alocacao nao encontrada no banco"</text></outputEntry>
        <outputEntry id="Output_4_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="Input_5_1"><text>false</text></inputEntry>
        <inputEntry id="Input_5_2"><text>false</text></inputEntry>
        <inputEntry id="Input_5_3"><text></text></inputEntry>
        <outputEntry id="Output_5_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_5_2"><text>"Dados insuficientes para finalizacao"</text></outputEntry>
        <outputEntry id="Output_5_3"><text>"CRITICO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
