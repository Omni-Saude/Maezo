<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_reconcile_monthly_validation"
             name="Reconcile Monthly Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: reconcile_monthly_worker.py -->
  <decision id="Decision_reconcile_monthly_validation" name="Reconcile Monthly Validation">
    <decisionTable id="DecisionTable_reconcile_monthly_validation" hitPolicy="FIRST">
      <input id="Input_month" label="Mes">
        <inputExpression id="InputExpression_month" typeRef="integer">
          <text>month</text>
        </inputExpression>
      </input>
      <input id="Input_year" label="Ano">
        <inputExpression id="InputExpression_year" typeRef="integer">
          <text>year</text>
        </inputExpression>
      </input>
      <input id="Input_closed_by" label="Fechado Por">
        <inputExpression id="InputExpression_closed_by" typeRef="boolean">
          <text>closed_by_present</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="Input_1_1"><text>[1..12]</text></inputEntry>
        <inputEntry id="Input_1_2"><text>[2020..2030]</text></inputEntry>
        <inputEntry id="Input_1_3"><text>true</text></inputEntry>
        <outputEntry id="Output_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2"><text>"Dados validos para fechamento mensal"</text></outputEntry>
        <outputEntry id="Output_1_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="Input_2_1"><text>[1..12]</text></inputEntry>
        <inputEntry id="Input_2_2"><text>[2020..2030]</text></inputEntry>
        <inputEntry id="Input_2_3"><text>false</text></inputEntry>
        <outputEntry id="Output_2_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_2_2"><text>"Fechamento sem identificacao do responsavel"</text></outputEntry>
        <outputEntry id="Output_2_3"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="Input_3_1"><text>not([1..12])</text></inputEntry>
        <inputEntry id="Input_3_2"><text></text></inputEntry>
        <inputEntry id="Input_3_3"><text></text></inputEntry>
        <outputEntry id="Output_3_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_3_2"><text>"Mes invalido - deve ser entre 1 e 12"</text></outputEntry>
        <outputEntry id="Output_3_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="Input_4_1"><text></text></inputEntry>
        <inputEntry id="Input_4_2"><text>not([2020..2030])</text></inputEntry>
        <inputEntry id="Input_4_3"><text></text></inputEntry>
        <outputEntry id="Output_4_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_4_2"><text>"Ano fora do intervalo valido"</text></outputEntry>
        <outputEntry id="Output_4_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="Input_5_1"><text>[1..12]</text></inputEntry>
        <inputEntry id="Input_5_2"><text>[2020..2030]</text></inputEntry>
        <inputEntry id="Input_5_3"><text>true</text></inputEntry>
        <outputEntry id="Output_5_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_5_2"><text>"Parametros validos - iniciar fechamento"</text></outputEntry>
        <outputEntry id="Output_5_3"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
