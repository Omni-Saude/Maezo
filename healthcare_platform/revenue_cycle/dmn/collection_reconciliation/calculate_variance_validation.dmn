<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_calculate_variance_validation"
             name="Calculate Variance Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: calculate_variance_worker.py -->
  <decision id="Decision_calculate_variance_validation" name="Calculate Variance Validation">
    <decisionTable id="DecisionTable_calculate_variance_validation" hitPolicy="FIRST">
      <input id="Input_expected" label="Valor Esperado">
        <inputExpression id="InputExpression_expected" typeRef="double">
          <text>expected_amount</text>
        </inputExpression>
      </input>
      <input id="Input_actual" label="Valor Real">
        <inputExpression id="InputExpression_actual" typeRef="double">
          <text>actual_amount</text>
        </inputExpression>
      </input>
      <input id="Input_currency" label="Moeda">
        <inputExpression id="InputExpression_currency" typeRef="string">
          <text>currency</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="Input_1_1"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_1_2"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_1_3"><text>"BRL"</text></inputEntry>
        <outputEntry id="Output_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2"><text>"Dados validos para calculo de variacao"</text></outputEntry>
        <outputEntry id="Output_1_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="Input_2_1"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_2_2"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_2_3"><text>not("BRL")</text></inputEntry>
        <outputEntry id="Output_2_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_2_2"><text>"Moeda nao BRL - converter antes de calcular"</text></outputEntry>
        <outputEntry id="Output_2_3"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="Input_3_1"><text>&lt;= 0</text></inputEntry>
        <inputEntry id="Input_3_2"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_3_3"><text></text></inputEntry>
        <outputEntry id="Output_3_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_3_2"><text>"Valor esperado invalido - divisao por zero"</text></outputEntry>
        <outputEntry id="Output_3_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="Input_4_1"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_4_2"><text>&lt;= 0</text></inputEntry>
        <inputEntry id="Input_4_3"><text></text></inputEntry>
        <outputEntry id="Output_4_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_4_2"><text>"Valor real zerado ou negativo"</text></outputEntry>
        <outputEntry id="Output_4_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="Input_5_1"><text>&lt;= 0</text></inputEntry>
        <inputEntry id="Input_5_2"><text>&lt;= 0</text></inputEntry>
        <inputEntry id="Input_5_3"><text></text></inputEntry>
        <outputEntry id="Output_5_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_5_2"><text>"Ambos valores invalidos"</text></outputEntry>
        <outputEntry id="Output_5_3"><text>"CRITICO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
