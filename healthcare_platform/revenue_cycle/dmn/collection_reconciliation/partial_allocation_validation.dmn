<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_partial_allocation_validation"
             name="Partial Allocation Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: partial_allocation_worker.py -->
  <decision id="Decision_partial_allocation_validation" name="Partial Allocation Validation">
    <decisionTable id="DecisionTable_partial_allocation_validation" hitPolicy="FIRST">
      <input id="Input_payment_amount" label="Valor Pagamento">
        <inputExpression id="InputExpression_payment_amount" typeRef="double">
          <text>payment_amount</text>
        </inputExpression>
      </input>
      <input id="Input_claims_sorted" label="Claims Ordenados">
        <inputExpression id="InputExpression_claims_sorted" typeRef="boolean">
          <text>claims_sorted_by_date</text>
        </inputExpression>
      </input>
      <input id="Input_total_outstanding" label="Total Pendente">
        <inputExpression id="InputExpression_total_outstanding" typeRef="double">
          <text>total_outstanding</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="Input_1_1"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_1_2"><text>true</text></inputEntry>
        <inputEntry id="Input_1_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2"><text>"Dados validos para alocacao parcial"</text></outputEntry>
        <outputEntry id="Output_1_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="Input_2_1"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_2_2"><text>false</text></inputEntry>
        <inputEntry id="Input_2_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_2_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_2_2"><text>"Claims nao ordenados por vencimento - pode afetar prioridade"</text></outputEntry>
        <outputEntry id="Output_2_3"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="Input_3_1"><text>&lt;= 0</text></inputEntry>
        <inputEntry id="Input_3_2"><text></text></inputEntry>
        <inputEntry id="Input_3_3"><text></text></inputEntry>
        <outputEntry id="Output_3_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_3_2"><text>"Valor de pagamento invalido para alocacao"</text></outputEntry>
        <outputEntry id="Output_3_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="Input_4_1"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_4_2"><text></text></inputEntry>
        <inputEntry id="Input_4_3"><text>&lt;= 0</text></inputEntry>
        <outputEntry id="Output_4_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_4_2"><text>"Nenhum valor pendente nos claims"</text></outputEntry>
        <outputEntry id="Output_4_3"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="Input_5_1"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_5_2"><text>true</text></inputEntry>
        <inputEntry id="Input_5_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_5_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_5_2"><text>"Iniciar alocacao por antiguidade (oldest first)"</text></outputEntry>
        <outputEntry id="Output_5_3"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
