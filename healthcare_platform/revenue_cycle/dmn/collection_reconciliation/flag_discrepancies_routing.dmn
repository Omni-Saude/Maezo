<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_flag_discrepancies_routing"
             name="Flag Discrepancies Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: flag_discrepancies_worker.py -->
  <decision id="Decision_flag_discrepancies_routing" name="Flag Discrepancies Routing">
    <decisionTable id="DecisionTable_flag_discrepancies_routing" hitPolicy="FIRST">
      <input id="Input_is_duplicate" label="E Duplicata">
        <inputExpression id="InputExpression_is_duplicate" typeRef="boolean">
          <text>is_duplicate</text>
        </inputExpression>
      </input>
      <input id="Input_variance" label="Variacao Valor">
        <inputExpression id="InputExpression_variance" typeRef="double">
          <text>variance</text>
        </inputExpression>
      </input>
      <input id="Input_has_claim" label="Tem Claim">
        <inputExpression id="InputExpression_has_claim" typeRef="boolean">
          <text>has_claim</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="Input_1_1"><text>true</text></inputEntry>
        <inputEntry id="Input_1_2"><text></text></inputEntry>
        <inputEntry id="Input_1_3"><text></text></inputEntry>
        <outputEntry id="Output_1_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_1_2"><text>"Pagamento duplicado detectado - bloquear processamento"</text></outputEntry>
        <outputEntry id="Output_1_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="Input_2_1"><text>false</text></inputEntry>
        <inputEntry id="Input_2_2"><text></text></inputEntry>
        <inputEntry id="Input_2_3"><text>false</text></inputEntry>
        <outputEntry id="Output_2_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_2_2"><text>"Pagamento sem claim correspondente - wrong claim"</text></outputEntry>
        <outputEntry id="Output_2_3"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="Input_3_1"><text>false</text></inputEntry>
        <inputEntry id="Input_3_2"><text>&gt; 10.0</text></inputEntry>
        <inputEntry id="Input_3_3"><text>true</text></inputEntry>
        <outputEntry id="Output_3_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_3_2"><text>"Sobrepagamento significativo - verificar overpayment"</text></outputEntry>
        <outputEntry id="Output_3_3"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="Input_4_1"><text>false</text></inputEntry>
        <inputEntry id="Input_4_2"><text>&lt; -10.0</text></inputEntry>
        <inputEntry id="Input_4_3"><text>true</text></inputEntry>
        <outputEntry id="Output_4_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_4_2"><text>"Subpagamento significativo - verificar underpayment"</text></outputEntry>
        <outputEntry id="Output_4_3"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="Input_5_1"><text>false</text></inputEntry>
        <inputEntry id="Input_5_2"><text>[-10.0..10.0]</text></inputEntry>
        <inputEntry id="Input_5_3"><text>true</text></inputEntry>
        <outputEntry id="Output_5_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_5_2"><text>"Variacao pequena - ajuste contratual aceitavel"</text></outputEntry>
        <outputEntry id="Output_5_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_6">
        <inputEntry id="Input_6_1"><text>false</text></inputEntry>
        <inputEntry id="Input_6_2"><text>[-0.01..0.01]</text></inputEntry>
        <inputEntry id="Input_6_3"><text>true</text></inputEntry>
        <outputEntry id="Output_6_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_6_2"><text>"Sem discrepancia - pagamento exato"</text></outputEntry>
        <outputEntry id="Output_6_3"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
