<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_convert_currency_routing"
             name="Convert Currency Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: convert_currency_worker.py -->
  <decision id="Decision_convert_currency_routing" name="Convert Currency Routing">
    <decisionTable id="DecisionTable_convert_currency_routing" hitPolicy="FIRST">
      <input id="Input_currency" label="Moeda Origem">
        <inputExpression id="InputExpression_currency" typeRef="string">
          <text>currency</text>
        </inputExpression>
        <inputValues><text>"BRL","USD","EUR","GBP"</text></inputValues>
      </input>
      <input id="Input_rate_available" label="Taxa Disponivel">
        <inputExpression id="InputExpression_rate_available" typeRef="boolean">
          <text>rate_available</text>
        </inputExpression>
      </input>
      <input id="Input_amount" label="Valor">
        <inputExpression id="InputExpression_amount" typeRef="double">
          <text>amount</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="Input_1_1"><text>"BRL"</text></inputEntry>
        <inputEntry id="Input_1_2"><text></text></inputEntry>
        <inputEntry id="Input_1_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2"><text>"Ja em BRL - nenhuma conversao necessaria"</text></outputEntry>
        <outputEntry id="Output_1_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="Input_2_1"><text>"USD","EUR","GBP"</text></inputEntry>
        <inputEntry id="Input_2_2"><text>true</text></inputEntry>
        <inputEntry id="Input_2_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_2_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_2_2"><text>"Moeda suportada com taxa - converter para BRL"</text></outputEntry>
        <outputEntry id="Output_2_3"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="Input_3_1"><text>"USD","EUR","GBP"</text></inputEntry>
        <inputEntry id="Input_3_2"><text>false</text></inputEntry>
        <inputEntry id="Input_3_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_3_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_3_2"><text>"Taxa de cambio indisponivel - usar taxa padrao com alerta"</text></outputEntry>
        <outputEntry id="Output_3_3"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="Input_4_1"><text>not("BRL","USD","EUR","GBP")</text></inputEntry>
        <inputEntry id="Input_4_2"><text></text></inputEntry>
        <inputEntry id="Input_4_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_4_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_4_2"><text>"Moeda nao suportada - requer configuracao manual"</text></outputEntry>
        <outputEntry id="Output_4_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="Input_5_1"><text></text></inputEntry>
        <inputEntry id="Input_5_2"><text></text></inputEntry>
        <inputEntry id="Input_5_3"><text>&lt;= 0</text></inputEntry>
        <outputEntry id="Output_5_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_5_2"><text>"Valor invalido para conversao"</text></outputEntry>
        <outputEntry id="Output_5_3"><text>"CRITICO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
