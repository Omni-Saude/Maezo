<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_appeal_eligibility_adjudication"
             name="Appeal Eligibility Adjudication"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Appeal Eligibility Adjudication
       For: check_appeal_eligibility_worker
       Archetype: ADMIN_ADJUDICATION
       Purpose: Determine if glosa is eligible for appeal based on type, reason, and deadline
  -->

  <decision id="Decision_appeal_eligibility_adjudication" name="Appeal Eligibility Adjudication">
    <decisionTable id="DecisionTable_appeal_eligibility_adjudication" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_1" label="Glosa Type">
        <inputExpression id="InputExpr_1" typeRef="string">
          <text>glosaType</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Reason Code">
        <inputExpression id="InputExpr_2" typeRef="string">
          <text>reasonCode</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Days Remaining">
        <inputExpression id="InputExpr_3" typeRef="number">
          <text>daysRemaining</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Glosa total não passível de recurso -->
      <rule id="Rule_1">
        <description>Glosa total não passível de recurso</description>
        <inputEntry id="IE_1_1"><text>"TOTAL"</text></inputEntry>
        <inputEntry id="IE_1_2"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3"><text>-</text></inputEntry>
        <outputEntry id="OE_1_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_acao"><text>"Glosa total não passível de recurso"</text></outputEntry>
        <outputEntry id="OE_1_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Prazo expirado -->
      <rule id="Rule_2">
        <description>Prazo expirado conforme ANS RN 424/2017</description>
        <inputEntry id="IE_2_1"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2"><text>-</text></inputEntry>
        <inputEntry id="IE_2_3"><text>&lt; 0</text></inputEntry>
        <outputEntry id="OE_2_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_2_acao"><text>"Prazo expirado conforme ANS RN 424/2017"</text></outputEntry>
        <outputEntry id="OE_2_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Prazo crítico -->
      <rule id="Rule_3">
        <description>Prazo crítico - submeter urgente</description>
        <inputEntry id="IE_3_1"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2"><text>-</text></inputEntry>
        <inputEntry id="IE_3_3"><text>&lt;= 5</text></inputEntry>
        <outputEntry id="OE_3_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_3_acao"><text>"Prazo crítico - submeter urgente"</text></outputEntry>
        <outputEntry id="OE_3_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Missing signature - elegível -->
      <rule id="Rule_4">
        <description>Recurso elegível - assinatura</description>
        <inputEntry id="IE_4_1"><text>-</text></inputEntry>
        <inputEntry id="IE_4_2"><text>"MISSING_SIGNATURE"</text></inputEntry>
        <inputEntry id="IE_4_3"><text>-</text></inputEntry>
        <outputEntry id="OE_4_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_acao"><text>"Recurso elegível - assinatura"</text></outputEntry>
        <outputEntry id="OE_4_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Missing justification - elegível -->
      <rule id="Rule_5">
        <description>Recurso elegível - justificativa</description>
        <inputEntry id="IE_5_1"><text>-</text></inputEntry>
        <inputEntry id="IE_5_2"><text>"MISSING_CLINICAL_JUSTIFICATION"</text></inputEntry>
        <inputEntry id="IE_5_3"><text>-</text></inputEntry>
        <outputEntry id="OE_5_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_acao"><text>"Recurso elegível - justificativa"</text></outputEntry>
        <outputEntry id="OE_5_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 6: Invalid code - elegível -->
      <rule id="Rule_6">
        <description>Recurso elegível - código</description>
        <inputEntry id="IE_6_1"><text>-</text></inputEntry>
        <inputEntry id="IE_6_2"><text>"INVALID_CODE"</text></inputEntry>
        <inputEntry id="IE_6_3"><text>-</text></inputEntry>
        <outputEntry id="OE_6_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_6_acao"><text>"Recurso elegível - código"</text></outputEntry>
        <outputEntry id="OE_6_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 7: Duplicate billing - verificar -->
      <rule id="Rule_7">
        <description>Verificar duplicidade antes de recurso</description>
        <inputEntry id="IE_7_1"><text>-</text></inputEntry>
        <inputEntry id="IE_7_2"><text>"DUPLICATE_BILLING"</text></inputEntry>
        <inputEntry id="IE_7_3"><text>-</text></inputEntry>
        <outputEntry id="OE_7_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_7_acao"><text>"Verificar duplicidade antes de recurso"</text></outputEntry>
        <outputEntry id="OE_7_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 8: Not covered - verificar cobertura -->
      <rule id="Rule_8">
        <description>Verificar cobertura contratual</description>
        <inputEntry id="IE_8_1"><text>-</text></inputEntry>
        <inputEntry id="IE_8_2"><text>"NOT_COVERED_PROCEDURE"</text></inputEntry>
        <inputEntry id="IE_8_3"><text>-</text></inputEntry>
        <outputEntry id="OE_8_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_8_acao"><text>"Verificar cobertura contratual"</text></outputEntry>
        <outputEntry id="OE_8_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 9: Lack of authorization - emergência -->
      <rule id="Rule_9">
        <description>Recurso elegível - emergência</description>
        <inputEntry id="IE_9_1"><text>-</text></inputEntry>
        <inputEntry id="IE_9_2"><text>"LACK_OF_PRIOR_AUTHORIZATION"</text></inputEntry>
        <inputEntry id="IE_9_3"><text>-</text></inputEntry>
        <outputEntry id="OE_9_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_9_acao"><text>"Recurso elegível - emergência"</text></outputEntry>
        <outputEntry id="OE_9_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="Rule_fallback">
        <description>Caso não enquadrado — revisão obrigatória</description>
        <inputEntry id="IE_fb_1"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_3"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao"><text>"Avaliar elegibilidade manualmente"</text></outputEntry>
        <outputEntry id="OE_fb_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_appeal_eligibility_adjudication">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
