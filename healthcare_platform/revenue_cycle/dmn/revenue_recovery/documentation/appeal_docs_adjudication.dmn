<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_appeal_docs_adjudication"
             name="Appeal Documentation Adjudication"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Appeal Documentation Adjudication
       For: generate_appeal_documentation_worker
       Archetype: ADMIN_ADJUDICATION
       Purpose: Determine required documentation templates based on reason code
  -->

  <decision id="Decision_appeal_docs_adjudication" name="Appeal Documentation Adjudication">
    <decisionTable id="DecisionTable_appeal_docs_adjudication" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_1" label="Reason Code">
        <inputExpression id="InputExpr_1" typeRef="string">
          <text>reasonCode</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Glosa Type">
        <inputExpression id="InputExpr_2" typeRef="string">
          <text>glosaType</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Missing signature -->
      <rule id="Rule_1">
        <description>Template assinatura + docs originais</description>
        <inputEntry id="IE_1_1"><text>"MISSING_SIGNATURE"</text></inputEntry>
        <inputEntry id="IE_1_2"><text>-</text></inputEntry>
        <outputEntry id="OE_1_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_1_acao"><text>"Template assinatura + docs originais"</text></outputEntry>
        <outputEntry id="OE_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Missing clinical justification -->
      <rule id="Rule_2">
        <description>Template justificativa clínica + relatório médico</description>
        <inputEntry id="IE_2_1"><text>"MISSING_CLINICAL_JUSTIFICATION"</text></inputEntry>
        <inputEntry id="IE_2_2"><text>-</text></inputEntry>
        <outputEntry id="OE_2_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_acao"><text>"Template justificativa clínica + relatório médico"</text></outputEntry>
        <outputEntry id="OE_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Invalid code -->
      <rule id="Rule_3">
        <description>Template código + TUSS/CBHPM</description>
        <inputEntry id="IE_3_1"><text>"INVALID_CODE"</text></inputEntry>
        <inputEntry id="IE_3_2"><text>-</text></inputEntry>
        <outputEntry id="OE_3_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_3_acao"><text>"Template código + TUSS/CBHPM"</text></outputEntry>
        <outputEntry id="OE_3_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Duplicate billing -->
      <rule id="Rule_4">
        <description>Template duplicidade + NF original + registro</description>
        <inputEntry id="IE_4_1"><text>"DUPLICATE_BILLING"</text></inputEntry>
        <inputEntry id="IE_4_2"><text>-</text></inputEntry>
        <outputEntry id="OE_4_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_4_acao"><text>"Template duplicidade + NF original + registro"</text></outputEntry>
        <outputEntry id="OE_4_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Not covered procedure -->
      <rule id="Rule_5">
        <description>Template cobertura + contrato + Rol ANS</description>
        <inputEntry id="IE_5_1"><text>"NOT_COVERED_PROCEDURE"</text></inputEntry>
        <inputEntry id="IE_5_2"><text>-</text></inputEntry>
        <outputEntry id="OE_5_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_5_acao"><text>"Template cobertura + contrato + Rol ANS"</text></outputEntry>
        <outputEntry id="OE_5_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 6: Lack of prior authorization -->
      <rule id="Rule_6">
        <description>Template emergência + relatório admissão</description>
        <inputEntry id="IE_6_1"><text>"LACK_OF_PRIOR_AUTHORIZATION"</text></inputEntry>
        <inputEntry id="IE_6_2"><text>-</text></inputEntry>
        <outputEntry id="OE_6_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_6_acao"><text>"Template emergência + relatório admissão"</text></outputEntry>
        <outputEntry id="OE_6_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="Rule_fallback">
        <description>Caso não enquadrado — revisão obrigatória</description>
        <inputEntry id="IE_fb_1"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao"><text>"Template genérico - revisão manual"</text></outputEntry>
        <outputEntry id="OE_fb_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_appeal_docs_adjudication">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
