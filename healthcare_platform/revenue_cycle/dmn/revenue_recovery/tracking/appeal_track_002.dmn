<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  APPEAL-TRACK-002 - Taxa Sucesso por Tipo Recurso
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: APPEAL-TRACK
  Perspectiva: HOSPITAL (Receivables - Appeals Management)

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Lei 9.656/1998 (planos de saude)
  - RN ANS 395/2016 (recursos de glosa)
  - CPC 25 (provisoes)
  - IFRS 15 (reconhecimento de receita)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_APPEAL_TRACK_002"
             name="Taxa Sucesso por Tipo Recurso"
             targetNamespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: appeal_track_002_worker.py -->

  <decision id="Decision_APPEAL_TRACK_002" name="Taxa Sucesso por Tipo Recurso">
    <decisionTable id="DecisionTable_APPEAL_TRACK_002" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1" label="Taxa Sucesso">
        <inputExpression id="InputExpression_1" typeRef="number">
          <text>taxaSucesso</text>
        </inputExpression>
      </input>


      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA 1: Taxa excelente (>=80%) -->
      <rule id="Rule_P1_1">
        <description>Taxa de sucesso excelente.</description>
        <inputEntry id="InputEntry_P11_1"><text>taxaSucesso >= 0.8</text></inputEntry>
        <outputEntry id="OutputEntry_P11_1"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P11_2"><text>"Taxa de sucesso excelente (&gt;=80%). Continuar priorizando."</text></outputEntry>
        <outputEntry id="OutputEntry_P11_3"><text>"Priorizar recursos similares. Documentar argumentacao vencedora."</text></outputEntry>
        <outputEntry id="OutputEntry_P11_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P11_5"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA 2: Taxa boa (50-79%) -->
      <rule id="Rule_P1_2">
        <description>Taxa de sucesso boa.</description>
        <inputEntry id="InputEntry_P12_1"><text>taxaSucesso >= 0.5</text></inputEntry>
        <outputEntry id="OutputEntry_P12_1"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P12_2"><text>"Taxa de sucesso boa (50-79%). Margem para melhoria."</text></outputEntry>
        <outputEntry id="OutputEntry_P12_3"><text>"Analisar recursos negados para melhorar argumentacao."</text></outputEntry>
        <outputEntry id="OutputEntry_P12_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P12_5"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA 3: Taxa moderada (30-49%) -->
      <rule id="Rule_A1_1">
        <description>Taxa de sucesso moderada.</description>
        <inputEntry id="InputEntry_A11_1"><text>taxaSucesso >= 0.3</text></inputEntry>
        <outputEntry id="OutputEntry_A11_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A11_2"><text>"Taxa de sucesso moderada (30-49%). Custo-beneficio questionavel."</text></outputEntry>
        <outputEntry id="OutputEntry_A11_3"><text>"Reavaliar se vale recorrer. Focar em glosas de maior valor."</text></outputEntry>
        <outputEntry id="OutputEntry_A11_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_A11_5"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA 4: Taxa baixa (<30%) -->
      <rule id="Rule_A1_2">
        <description>Taxa de sucesso baixa para este tipo.</description>
        <inputEntry id="InputEntry_A12_1"><text>taxaSucesso &lt; 0.3</text></inputEntry>
        <outputEntry id="OutputEntry_A12_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A12_2"><text>"Taxa de sucesso baixa (&lt;30%). Considerar aceitacao."</text></outputEntry>
        <outputEntry id="OutputEntry_A12_3"><text>"Reavaliar estrategia. Considerar aceitar glosas deste tipo."</text></outputEntry>
        <outputEntry id="OutputEntry_A12_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_A12_5"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisao manual -->
      <rule id="Rule_Fallback_APPEAL_TRACK_002">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2"><text>"Situacao requer analise manual por nao corresponder a nenhum criterio automatico."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3"><text>"Encaminhar para auditoria administrativa para avaliacao caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_APPEAL_TRACK_002">
      <dmndi:DMNShape id="DMNShape_Decision_APPEAL_TRACK_002" dmnElementRef="Decision_APPEAL_TRACK_002">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
