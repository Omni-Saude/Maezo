<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_appeal_tracking_adjudication"
             name="Appeal Tracking Adjudication"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Appeal Tracking Adjudication
       For: track_appeal_status_worker
       Archetype: ADMIN_ADJUDICATION
       Purpose: Interpret payer status codes and determine follow-up actions
  -->

  <decision id="Decision_appeal_tracking_adjudication" name="Appeal Tracking Adjudication">
    <decisionTable id="DecisionTable_appeal_tracking_adjudication" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_1" label="Payer Status Code">
        <inputExpression id="InputExpr_1" typeRef="string">
          <text>payerStatusCode</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Elapsed Days">
        <inputExpression id="InputExpr_2" typeRef="number">
          <text>elapsedDays</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Approved -->
      <rule id="Rule_1">
        <description>Recurso aprovado - glosas revertidas</description>
        <inputEntry id="IE_1_1"><text>"APPROVED"</text></inputEntry>
        <inputEntry id="IE_1_2"><text>-</text></inputEntry>
        <outputEntry id="OE_1_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_1_acao"><text>"Recurso aprovado - glosas revertidas"</text></outputEntry>
        <outputEntry id="OE_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Partially approved -->
      <rule id="Rule_2">
        <description>Parcialmente aprovado - verificar itens</description>
        <inputEntry id="IE_2_1"><text>"PARTIALLY_APPROVED"</text></inputEntry>
        <inputEntry id="IE_2_2"><text>-</text></inputEntry>
        <outputEntry id="OE_2_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_2_acao"><text>"Parcialmente aprovado - verificar itens"</text></outputEntry>
        <outputEntry id="OE_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Denied -->
      <rule id="Rule_3">
        <description>Recurso negado - avaliar próximas ações</description>
        <inputEntry id="IE_3_1"><text>"DENIED"</text></inputEntry>
        <inputEntry id="IE_3_2"><text>-</text></inputEntry>
        <outputEntry id="OE_3_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_3_acao"><text>"Recurso negado - avaliar próximas ações"</text></outputEntry>
        <outputEntry id="OE_3_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Rejected -->
      <rule id="Rule_4">
        <description>Recurso rejeitado</description>
        <inputEntry id="IE_4_1"><text>"REJECTED"</text></inputEntry>
        <inputEntry id="IE_4_2"><text>-</text></inputEntry>
        <outputEntry id="OE_4_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_4_acao"><text>"Recurso rejeitado"</text></outputEntry>
        <outputEntry id="OE_4_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Pending info -->
      <rule id="Rule_5">
        <description>Informação adicional solicitada - acompanhar</description>
        <inputEntry id="IE_5_1"><text>"PENDING_INFO"</text></inputEntry>
        <inputEntry id="IE_5_2"><text>-</text></inputEntry>
        <outputEntry id="OE_5_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_5_acao"><text>"Informação adicional solicitada - acompanhar"</text></outputEntry>
        <outputEntry id="OE_5_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 6: In analysis - prazo excedido -->
      <rule id="Rule_6">
        <description>Prazo excedido - contatar operadora</description>
        <inputEntry id="IE_6_1"><text>"IN_ANALYSIS","RECEIVED"</text></inputEntry>
        <inputEntry id="IE_6_2"><text>&gt; 15</text></inputEntry>
        <outputEntry id="OE_6_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_6_acao"><text>"Prazo excedido - contatar operadora"</text></outputEntry>
        <outputEntry id="OE_6_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 7: In analysis - dentro do prazo -->
      <rule id="Rule_7">
        <description>Em análise - aguardar</description>
        <inputEntry id="IE_7_1"><text>"IN_ANALYSIS","RECEIVED"</text></inputEntry>
        <inputEntry id="IE_7_2"><text>&lt;= 15</text></inputEntry>
        <outputEntry id="OE_7_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_7_acao"><text>"Em análise - aguardar"</text></outputEntry>
        <outputEntry id="OE_7_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="Rule_fallback">
        <description>Caso não enquadrado — revisão obrigatória</description>
        <inputEntry id="IE_fb_1"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao"><text>"Status desconhecido - verificar manualmente"</text></outputEntry>
        <outputEntry id="OE_fb_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_appeal_tracking_adjudication">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
