<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  APPEAL-TRACK-004 - Provisao Financeira por Recurso
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: APPEAL-TRACK
  Perspectiva: HOSPITAL (Receivables - Appeals Management)

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Lei 9.656/1998 (planos de saude)
  - RN ANS 395/2016 (recursos de glosa)
  - CPC 25 (provisoes)
  - IFRS 15 (reconhecimento de receita)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_APPEAL_TRACK_004"
             name="Provisao Financeira por Recurso"
             targetNamespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: appeal_track_004_worker.py -->

  <decision id="Decision_APPEAL_TRACK_004" name="Provisao Financeira por Recurso">
    <decisionTable id="DecisionTable_APPEAL_TRACK_004" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1" label="Valor Provisao">
        <inputExpression id="InputExpression_1" typeRef="number">
          <text>valorProvisao</text>
        </inputExpression>
      </input>


      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA 1: Provisao alta (>50k) -->
      <rule id="Rule_B1_1">
        <description>Provisao alta constituida - impacto material.</description>
        <inputEntry id="InputEntry_B11_1"><text>valorProvisao &gt; 50000</text></inputEntry>
        <outputEntry id="OutputEntry_B11_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B11_2"><text>"Provisao alta (&gt;R$50k). Impacto material no resultado."</text></outputEntry>
        <outputEntry id="OutputEntry_B11_3"><text>"Priorizar recurso. Reuniao com diretoria financeira."</text></outputEntry>
        <outputEntry id="OutputEntry_B11_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_B11_5"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA 2: Provisao moderada (5k-50k) -->
      <rule id="Rule_A1_1">
        <description>Provisao moderada constituida.</description>
        <inputEntry id="InputEntry_A11_1"><text>valorProvisao &gt; 5000</text></inputEntry>
        <outputEntry id="OutputEntry_A11_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A11_2"><text>"Provisao moderada (R$5k-50k). Monitorar desfecho."</text></outputEntry>
        <outputEntry id="OutputEntry_A11_3"><text>"Monitorar desfecho e reverter provisao se ganho."</text></outputEntry>
        <outputEntry id="OutputEntry_A11_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_A11_5"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA 3: Provisao baixa (>0 ate 5k) -->
      <rule id="Rule_A1_2">
        <description>Provisao baixa constituida.</description>
        <inputEntry id="InputEntry_A12_1"><text>valorProvisao &gt; 0</text></inputEntry>
        <outputEntry id="OutputEntry_A12_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A12_2"><text>"Provisao baixa (&lt;=R$5k). Impacto menor."</text></outputEntry>
        <outputEntry id="OutputEntry_A12_3"><text>"Acompanhar recurso normalmente."</text></outputEntry>
        <outputEntry id="OutputEntry_A12_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_A12_5"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA 4: Sem provisao -->
      <rule id="Rule_P1_2">
        <description>Sem provisao constituida ainda.</description>
        <inputEntry id="InputEntry_P12_1"><text>valorProvisao == 0</text></inputEntry>
        <outputEntry id="OutputEntry_P12_1"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P12_2"><text>"Sem provisao constituida. Recurso em fase inicial."</text></outputEntry>
        <outputEntry id="OutputEntry_P12_3"><text>"Prosseguir com recurso normalmente."</text></outputEntry>
        <outputEntry id="OutputEntry_P12_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P12_5"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisao manual -->
      <rule id="Rule_Fallback_APPEAL_TRACK_004">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2"><text>"Situacao requer analise manual por nao corresponder a nenhum criterio automatico."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3"><text>"Encaminhar para auditoria administrativa para avaliacao caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_APPEAL_TRACK_004">
      <dmndi:DMNShape id="DMNShape_Decision_APPEAL_TRACK_004" dmnElementRef="Decision_APPEAL_TRACK_004">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
