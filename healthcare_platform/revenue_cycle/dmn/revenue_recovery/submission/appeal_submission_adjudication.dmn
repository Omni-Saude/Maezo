<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_appeal_submission_adjudication"
             name="Appeal Submission Adjudication"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Appeal Submission Adjudication
       For: submit_appeal_worker
       Archetype: ADMIN_ADJUDICATION
       Purpose: Determine action based on submission response and retry attempts
  -->

  <decision id="Decision_appeal_submission_adjudication" name="Appeal Submission Adjudication">
    <decisionTable id="DecisionTable_appeal_submission_adjudication" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_1" label="Response Code">
        <inputExpression id="InputExpr_1" typeRef="string">
          <text>responseCode</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Attempt Count">
        <inputExpression id="InputExpr_2" typeRef="number">
          <text>attemptCount</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Success -->
      <rule id="Rule_1">
        <description>Submissão aceita</description>
        <inputEntry id="IE_1_1"><text>"SUCCESS"</text></inputEntry>
        <inputEntry id="IE_1_2"><text>-</text></inputEntry>
        <outputEntry id="OE_1_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_1_acao"><text>"Submissão aceita"</text></outputEntry>
        <outputEntry id="OE_1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Validation error -->
      <rule id="Rule_2">
        <description>Erro de validação TISS</description>
        <inputEntry id="IE_2_1"><text>"VALIDATION_ERROR"</text></inputEntry>
        <inputEntry id="IE_2_2"><text>-</text></inputEntry>
        <outputEntry id="OE_2_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_2_acao"><text>"Erro de validação TISS"</text></outputEntry>
        <outputEntry id="OE_2_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Rejected by payer -->
      <rule id="Rule_3">
        <description>Recurso rejeitado pela operadora</description>
        <inputEntry id="IE_3_1"><text>"REJECTED"</text></inputEntry>
        <inputEntry id="IE_3_2"><text>-</text></inputEntry>
        <outputEntry id="OE_3_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_3_acao"><text>"Recurso rejeitado pela operadora"</text></outputEntry>
        <outputEntry id="OE_3_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Timeout/connection - max retries exceeded -->
      <rule id="Rule_4">
        <description>Falha após máximo de tentativas</description>
        <inputEntry id="IE_4_1"><text>"TIMEOUT","CONNECTION_ERROR"</text></inputEntry>
        <inputEntry id="IE_4_2"><text>&gt;= 3</text></inputEntry>
        <outputEntry id="OE_4_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_4_acao"><text>"Falha após máximo de tentativas"</text></outputEntry>
        <outputEntry id="OE_4_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Timeout/connection - retry available -->
      <rule id="Rule_5">
        <description>Erro transitório - retry</description>
        <inputEntry id="IE_5_1"><text>"TIMEOUT","CONNECTION_ERROR"</text></inputEntry>
        <inputEntry id="IE_5_2"><text>&lt; 3</text></inputEntry>
        <outputEntry id="OE_5_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_5_acao"><text>"Erro transitório - retry"</text></outputEntry>
        <outputEntry id="OE_5_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="Rule_fallback">
        <description>Caso não enquadrado — revisão obrigatória</description>
        <inputEntry id="IE_fb_1"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao"><text>"Resposta desconhecida - avaliar"</text></outputEntry>
        <outputEntry id="OE_fb_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_appeal_submission_adjudication">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
