<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_recovery_rate_adjudication"
             name="Recovery Rate Adjudication"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Recovery Rate Adjudication
       For: calculate_glosa_impact_worker
       Archetype: ADMIN_ADJUDICATION
       Purpose: Determine recovery viability based on glosa type and denial percentage
  -->

  <decision id="Decision_recovery_rate_adjudication" name="Recovery Rate Adjudication">
    <decisionTable id="DecisionTable_recovery_rate_adjudication" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_1" label="Glosa Type">
        <inputExpression id="InputExpr_1" typeRef="string">
          <text>glosaType</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Denial Percentage">
        <inputExpression id="InputExpr_2" typeRef="number">
          <text>denialPercentage</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Glosa total sem recuperação -->
      <rule id="Rule_1">
        <description>Glosa total sem recuperação</description>
        <inputEntry id="IE_1_1"><text>"TOTAL"</text></inputEntry>
        <inputEntry id="IE_1_2"><text>-</text></inputEntry>
        <outputEntry id="OE_1_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_acao"><text>"Glosa total sem recuperação"</text></outputEntry>
        <outputEntry id="OE_1_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Administrative - alto percentual -->
      <rule id="Rule_2">
        <description>Alto percentual administrativo - revisar</description>
        <inputEntry id="IE_2_1"><text>"ADMINISTRATIVE"</text></inputEntry>
        <inputEntry id="IE_2_2"><text>&gt;= 50</text></inputEntry>
        <outputEntry id="OE_2_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_acao"><text>"Alto percentual negado - revisar"</text></outputEntry>
        <outputEntry id="OE_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Administrative - recuperação viável -->
      <rule id="Rule_3">
        <description>Recuperação administrativa viável</description>
        <inputEntry id="IE_3_1"><text>"ADMINISTRATIVE"</text></inputEntry>
        <inputEntry id="IE_3_2"><text>&lt; 50</text></inputEntry>
        <outputEntry id="OE_3_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_3_acao"><text>"Recuperação administrativa viável"</text></outputEntry>
        <outputEntry id="OE_3_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Technical - alto percentual -->
      <rule id="Rule_4">
        <description>Percentual técnico alto - avaliar</description>
        <inputEntry id="IE_4_1"><text>"TECHNICAL"</text></inputEntry>
        <inputEntry id="IE_4_2"><text>&gt;= 30</text></inputEntry>
        <outputEntry id="OE_4_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_4_acao"><text>"Percentual técnico alto - avaliar"</text></outputEntry>
        <outputEntry id="OE_4_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Technical - recuperação viável -->
      <rule id="Rule_5">
        <description>Recuperação técnica viável</description>
        <inputEntry id="IE_5_1"><text>"TECHNICAL"</text></inputEntry>
        <inputEntry id="IE_5_2"><text>&lt; 30</text></inputEntry>
        <outputEntry id="OE_5_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_acao"><text>"Recuperação técnica viável"</text></outputEntry>
        <outputEntry id="OE_5_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 6: Linear - ajuste aplicável -->
      <rule id="Rule_6">
        <description>Ajuste linear aplicável</description>
        <inputEntry id="IE_6_1"><text>"LINEAR"</text></inputEntry>
        <inputEntry id="IE_6_2"><text>-</text></inputEntry>
        <outputEntry id="OE_6_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_6_acao"><text>"Ajuste linear aplicável"</text></outputEntry>
        <outputEntry id="OE_6_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 7: Partial - avaliação necessária -->
      <rule id="Rule_7">
        <description>Avaliação de recuperação parcial</description>
        <inputEntry id="IE_7_1"><text>"PARTIAL"</text></inputEntry>
        <inputEntry id="IE_7_2"><text>-</text></inputEntry>
        <outputEntry id="OE_7_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_7_acao"><text>"Avaliação de recuperação parcial"</text></outputEntry>
        <outputEntry id="OE_7_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="Rule_fallback">
        <description>Caso não enquadrado — revisão obrigatória</description>
        <inputEntry id="IE_fb_1"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao"><text>"Caso requer avaliação manual"</text></outputEntry>
        <outputEntry id="OE_fb_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_recovery_rate_adjudication">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
