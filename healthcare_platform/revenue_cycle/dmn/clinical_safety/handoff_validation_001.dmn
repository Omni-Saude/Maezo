<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/DMN/20151101/dmn.xsd"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_handoff_validation_001"
             name="Clinical Handoff Validation Rules"
             namespace="http://healthcare.platform/dmn/clinical_safety">
  <decision id="handoff_validation_001" name="Clinical Handoff Validation Rules">
    <decisionTable id="DecisionTable_handoff_validation_001" hitPolicy="COLLECT">
      <input id="input1" label="Handoff Type">
        <inputExpression typeRef="string">
          <text>handoff_type</text>
        </inputExpression>
      </input>
      <input id="input2" label="Required Field">
        <inputExpression typeRef="string">
          <text>field_name</text>
        </inputExpression>
      </input>
      <output id="output1" label="Is Required" name="is_required" typeRef="boolean"/>
      <output id="output2" label="Validation Rule" name="validation_rule" typeRef="string"/>
      <output id="output3" label="Error Message" name="error_message" typeRef="string"/>

      <!-- SBAR fields required for all handoff types -->
      <rule id="rule1">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"situation"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"not_empty"</text></outputEntry>
        <outputEntry><text>"SBAR: Situation field is required"</text></outputEntry>
      </rule>
      <rule id="rule2">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"background"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"not_empty"</text></outputEntry>
        <outputEntry><text>"SBAR: Background field is required"</text></outputEntry>
      </rule>
      <rule id="rule3">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"assessment"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"not_empty"</text></outputEntry>
        <outputEntry><text>"SBAR: Assessment field is required"</text></outputEntry>
      </rule>
      <rule id="rule4">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"recommendation"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"not_empty"</text></outputEntry>
        <outputEntry><text>"SBAR: Recommendation field is required"</text></outputEntry>
      </rule>

      <!-- Transfer handoffs require additional fields -->
      <rule id="rule5">
        <inputEntry><text>"transfer"</text></inputEntry>
        <inputEntry><text>"receiving_unit"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"valid_unit_code"</text></outputEntry>
        <outputEntry><text>"Receiving unit must be specified for transfers"</text></outputEntry>
      </rule>
      <rule id="rule6">
        <inputEntry><text>"transfer"</text></inputEntry>
        <inputEntry><text>"transport_mode"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"valid_transport_mode"</text></outputEntry>
        <outputEntry><text>"Transport mode is required for transfers"</text></outputEntry>
      </rule>

      <!-- Escalation handoffs require urgency documentation -->
      <rule id="rule7">
        <inputEntry><text>"escalation"</text></inputEntry>
        <inputEntry><text>"escalation_reason"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"not_empty"</text></outputEntry>
        <outputEntry><text>"Escalation reason must be documented"</text></outputEntry>
      </rule>
      <rule id="rule8">
        <inputEntry><text>"escalation"</text></inputEntry>
        <inputEntry><text>"target_provider"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"valid_provider_id"</text></outputEntry>
        <outputEntry><text>"Target provider must be specified for escalations"</text></outputEntry>
      </rule>

      <!-- Shift handoffs require patient status -->
      <rule id="rule9">
        <inputEntry><text>"shift"</text></inputEntry>
        <inputEntry><text>"current_status"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"not_empty"</text></outputEntry>
        <outputEntry><text>"Current patient status is required for shift handoffs"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
