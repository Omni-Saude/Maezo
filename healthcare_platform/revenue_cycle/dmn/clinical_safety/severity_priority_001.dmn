<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/DMN/20151101/dmn.xsd"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_severity_priority_001"
             name="Severity-Based Priority Assignment"
             namespace="http://healthcare.platform/dmn/clinical_safety">
  <decision id="severity_priority_001" name="Severity-Based Priority Assignment">
    <decisionTable id="DecisionTable_severity_priority_001" hitPolicy="UNIQUE">
      <input id="input1" label="Severity">
        <inputExpression typeRef="string">
          <text>severity</text>
        </inputExpression>
      </input>
      <output id="output1" label="Priority Number" name="priority_number" typeRef="integer"/>
      <output id="output2" label="Queue Position" name="queue_position" typeRef="string"/>
      <output id="output3" label="Escalation Required" name="escalation_required" typeRef="boolean"/>

      <!-- Critical severity gets highest priority -->
      <rule id="rule1">
        <inputEntry><text>"critical"</text></inputEntry>
        <outputEntry><text>1</text></outputEntry>
        <outputEntry><text>"front"</text></outputEntry>
        <outputEntry><text>true</text></outputEntry>
      </rule>

      <!-- High severity gets second priority -->
      <rule id="rule2">
        <inputEntry><text>"high"</text></inputEntry>
        <outputEntry><text>2</text></outputEntry>
        <outputEntry><text>"high_priority"</text></outputEntry>
        <outputEntry><text>false</text></outputEntry>
      </rule>

      <!-- Medium severity gets third priority -->
      <rule id="rule3">
        <inputEntry><text>"medium"</text></inputEntry>
        <outputEntry><text>3</text></outputEntry>
        <outputEntry><text>"standard"</text></outputEntry>
        <outputEntry><text>false</text></outputEntry>
      </rule>

      <!-- Low severity gets lowest priority -->
      <rule id="rule4">
        <inputEntry><text>"low"</text></inputEntry>
        <outputEntry><text>4</text></outputEntry>
        <outputEntry><text>"back"</text></outputEntry>
        <outputEntry><text>false</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
