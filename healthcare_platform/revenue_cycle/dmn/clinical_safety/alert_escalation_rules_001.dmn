<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/DMN/20151101/dmn.xsd"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_alert_escalation_rules_001"
             name="Alert Escalation Decision Rules"
             namespace="http://healthcare.platform/dmn/clinical_safety">
  <decision id="alert_escalation_rules_001" name="Alert Escalation Decision Rules">
    <decisionTable id="DecisionTable_alert_escalation_rules_001" hitPolicy="FIRST">
      <input id="input1" label="Alert Severity">
        <inputExpression typeRef="string">
          <text>severity</text>
        </inputExpression>
      </input>
      <input id="input2" label="Alert Type">
        <inputExpression typeRef="string">
          <text>alert_type</text>
        </inputExpression>
      </input>
      <input id="input3" label="Acknowledged">
        <inputExpression typeRef="boolean">
          <text>acknowledged</text>
        </inputExpression>
      </input>
      <input id="input4" label="Time Since Alert (minutes)">
        <inputExpression typeRef="integer">
          <text>time_since_alert</text>
        </inputExpression>
      </input>
      <output id="output1" label="Should Escalate" name="should_escalate" typeRef="boolean"/>
      <output id="output2" label="Escalation Reason" name="escalation_reason" typeRef="string"/>

      <!-- Critical severity always requires immediate escalation -->
      <rule id="rule1">
        <inputEntry><text>"critical"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"critical_severity"</text></outputEntry>
      </rule>

      <!-- High severity critical lab results require escalation -->
      <rule id="rule2">
        <inputEntry><text>"high"</text></inputEntry>
        <inputEntry><text>"critical_lab"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"critical_lab_high_severity"</text></outputEntry>
      </rule>

      <!-- High severity unacknowledged after 10 minutes -->
      <rule id="rule3">
        <inputEntry><text>"high"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>false</text></inputEntry>
        <inputEntry><text>&gt;= 10</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"unacknowledged_timeout"</text></outputEntry>
      </rule>

      <!-- Medium severity unacknowledged after 30 minutes -->
      <rule id="rule4">
        <inputEntry><text>"medium"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>false</text></inputEntry>
        <inputEntry><text>&gt;= 30</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"unacknowledged_timeout"</text></outputEntry>
      </rule>

      <!-- Vital sign alerts unacknowledged after 5 minutes -->
      <rule id="rule5">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"vital_sign"</text></inputEntry>
        <inputEntry><text>false</text></inputEntry>
        <inputEntry><text>&gt;= 5</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"vital_sign_timeout"</text></outputEntry>
      </rule>

      <!-- Default: no escalation needed -->
      <rule id="rule6">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>false</text></outputEntry>
        <outputEntry><text>"none"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
