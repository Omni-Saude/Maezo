<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/DMN/20151101/dmn.xsd"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_sbar_validation_001"
             name="SBAR Communication Validation"
             namespace="http://healthcare.platform/dmn/clinical_safety">
  <decision id="sbar_validation_001" name="SBAR Communication Validation">
    <decisionTable id="DecisionTable_sbar_validation_001" hitPolicy="COLLECT">
      <input id="input1" label="SBAR Field">
        <inputExpression typeRef="string">
          <text>sbar_field</text>
        </inputExpression>
      </input>
      <output id="output1" label="Is Required" name="is_required" typeRef="boolean"/>
      <output id="output2" label="Field Description" name="field_description" typeRef="string"/>
      <output id="output3" label="Validation Rule" name="validation_rule" typeRef="string"/>
      <output id="output4" label="Min Length" name="min_length" typeRef="integer"/>

      <!-- Situation field -->
      <rule id="rule1">
        <inputEntry><text>"situation"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"Current patient condition and reason for communication"</text></outputEntry>
        <outputEntry><text>"not_empty_and_descriptive"</text></outputEntry>
        <outputEntry><text>20</text></outputEntry>
      </rule>

      <!-- Background field -->
      <rule id="rule2">
        <inputEntry><text>"background"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"Relevant medical history and context"</text></outputEntry>
        <outputEntry><text>"not_empty_and_descriptive"</text></outputEntry>
        <outputEntry><text>30</text></outputEntry>
      </rule>

      <!-- Assessment field -->
      <rule id="rule3">
        <inputEntry><text>"assessment"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"Clinical assessment and analysis of situation"</text></outputEntry>
        <outputEntry><text>"not_empty_and_descriptive"</text></outputEntry>
        <outputEntry><text>25</text></outputEntry>
      </rule>

      <!-- Recommendation field -->
      <rule id="rule4">
        <inputEntry><text>"recommendation"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"Suggested actions or interventions needed"</text></outputEntry>
        <outputEntry><text>"not_empty_and_actionable"</text></outputEntry>
        <outputEntry><text>20</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
