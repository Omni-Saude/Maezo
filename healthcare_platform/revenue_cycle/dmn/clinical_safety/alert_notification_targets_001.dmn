<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/DMN/20151101/dmn.xsd"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_alert_notification_targets_001"
             name="Alert Notification Target Selection"
             namespace="http://healthcare.platform/dmn/clinical_safety">
  <decision id="alert_notification_targets_001" name="Alert Notification Target Selection">
    <decisionTable id="DecisionTable_alert_notification_targets_001" hitPolicy="COLLECT">
      <input id="input1" label="Alert Severity">
        <inputExpression typeRef="string">
          <text>severity</text>
        </inputExpression>
      </input>
      <input id="input2" label="Alert Type">
        <inputExpression typeRef="string">
          <text>alert_type</text>
        </inputExpression>
      </input>
      <input id="input3" label="Patient Location">
        <inputExpression typeRef="string">
          <text>patient_location</text>
        </inputExpression>
      </input>
      <output id="output1" label="Target Role" name="target_role" typeRef="string"/>
      <output id="output2" label="Notification Priority" name="notification_priority" typeRef="string"/>
      <output id="output3" label="Delivery Method" name="delivery_method" typeRef="string"/>

      <!-- Critical alerts notify attending physician -->
      <rule id="rule1">
        <inputEntry><text>"critical"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"attending_physician"</text></outputEntry>
        <outputEntry><text>"immediate"</text></outputEntry>
        <outputEntry><text>"phone_call"</text></outputEntry>
      </rule>

      <!-- Critical alerts also notify charge nurse -->
      <rule id="rule2">
        <inputEntry><text>"critical"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"charge_nurse"</text></outputEntry>
        <outputEntry><text>"immediate"</text></outputEntry>
        <outputEntry><text>"sms"</text></outputEntry>
      </rule>

      <!-- High severity alerts notify primary nurse -->
      <rule id="rule3">
        <inputEntry><text>"high"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"primary_nurse"</text></outputEntry>
        <outputEntry><text>"urgent"</text></outputEntry>
        <outputEntry><text>"ehr_notification"</text></outputEntry>
      </rule>

      <!-- Critical lab results notify lab physician -->
      <rule id="rule4">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"critical_lab"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"lab_physician"</text></outputEntry>
        <outputEntry><text>"urgent"</text></outputEntry>
        <outputEntry><text>"sms"</text></outputEntry>
      </rule>

      <!-- Medication alerts notify pharmacist -->
      <rule id="rule5">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"medication"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"pharmacist"</text></outputEntry>
        <outputEntry><text>"standard"</text></outputEntry>
        <outputEntry><text>"ehr_notification"</text></outputEntry>
      </rule>

      <!-- ICU patients always notify intensivist -->
      <rule id="rule6">
        <inputEntry><text>"high", "critical"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"icu"</text></inputEntry>
        <outputEntry><text>"intensivist"</text></outputEntry>
        <outputEntry><text>"immediate"</text></outputEntry>
        <outputEntry><text>"phone_call"</text></outputEntry>
      </rule>

      <!-- Allergy alerts notify all care team members -->
      <rule id="rule7">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"allergy"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"care_team"</text></outputEntry>
        <outputEntry><text>"urgent"</text></outputEntry>
        <outputEntry><text>"broadcast"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
