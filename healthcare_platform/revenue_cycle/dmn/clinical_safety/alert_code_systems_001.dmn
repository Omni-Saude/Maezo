<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/DMN/20151101/dmn.xsd"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_alert_code_systems_001"
             name="Clinical Alert Code System Mapping"
             namespace="http://healthcare.platform/dmn/clinical_safety">
  <decision id="alert_code_systems_001" name="Clinical Alert Code System Mapping">
    <decisionTable id="DecisionTable_alert_code_systems_001" hitPolicy="UNIQUE">
      <input id="input1" label="Alert Type">
        <inputExpression typeRef="string">
          <text>alert_type</text>
        </inputExpression>
      </input>
      <output id="output1" label="Code System" name="code_system" typeRef="string"/>
      <output id="output2" label="System URL" name="system_url" typeRef="string"/>
      <output id="output3" label="Display Field" name="display_field" typeRef="string"/>

      <!-- Critical lab code system -->
      <rule id="rule1">
        <inputEntry><text>"critical_lab"</text></inputEntry>
        <outputEntry><text>"LOINC"</text></outputEntry>
        <outputEntry><text>"http://loinc.org"</text></outputEntry>
        <outputEntry><text>"test_name"</text></outputEntry>
      </rule>

      <!-- Vital sign code system -->
      <rule id="rule2">
        <inputEntry><text>"vital_sign"</text></inputEntry>
        <outputEntry><text>"LOINC"</text></outputEntry>
        <outputEntry><text>"http://loinc.org"</text></outputEntry>
        <outputEntry><text>"vital_sign_name"</text></outputEntry>
      </rule>

      <!-- Medication code system -->
      <rule id="rule3">
        <inputEntry><text>"medication"</text></inputEntry>
        <outputEntry><text>"RxNorm"</text></outputEntry>
        <outputEntry><text>"http://www.nlm.nih.gov/research/umls/rxnorm"</text></outputEntry>
        <outputEntry><text>"medication_name"</text></outputEntry>
      </rule>

      <!-- Allergy code system -->
      <rule id="rule4">
        <inputEntry><text>"allergy"</text></inputEntry>
        <outputEntry><text>"SNOMED-CT"</text></outputEntry>
        <outputEntry><text>"http://snomed.info/sct"</text></outputEntry>
        <outputEntry><text>"allergen_name"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
