<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/DMN/20151101/dmn.xsd"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_severity_validation_001"
             name="Severity Level Validation"
             namespace="http://healthcare.platform/dmn/clinical_safety">
  <decision id="severity_validation_001" name="Severity Level Validation">
    <decisionTable id="DecisionTable_severity_validation_001" hitPolicy="UNIQUE">
      <input id="input1" label="Severity">
        <inputExpression typeRef="string">
          <text>severity</text>
        </inputExpression>
      </input>
      <output id="output1" label="Is Valid" name="is_valid" typeRef="boolean"/>
      <output id="output2" label="Numeric Level" name="numeric_level" typeRef="integer"/>
      <output id="output3" label="Color Code" name="color_code" typeRef="string"/>
      <output id="output4" label="Response Time (minutes)" name="response_time" typeRef="integer"/>

      <!-- Critical severity -->
      <rule id="rule1">
        <inputEntry><text>"critical"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>1</text></outputEntry>
        <outputEntry><text>"red"</text></outputEntry>
        <outputEntry><text>5</text></outputEntry>
      </rule>

      <!-- High severity -->
      <rule id="rule2">
        <inputEntry><text>"high"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>2</text></outputEntry>
        <outputEntry><text>"orange"</text></outputEntry>
        <outputEntry><text>15</text></outputEntry>
      </rule>

      <!-- Medium severity -->
      <rule id="rule3">
        <inputEntry><text>"medium"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>3</text></outputEntry>
        <outputEntry><text>"yellow"</text></outputEntry>
        <outputEntry><text>30</text></outputEntry>
      </rule>

      <!-- Low severity -->
      <rule id="rule4">
        <inputEntry><text>"low"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>4</text></outputEntry>
        <outputEntry><text>"green"</text></outputEntry>
        <outputEntry><text>60</text></outputEntry>
      </rule>

      <!-- Invalid severity -->
      <rule id="rule5">
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>false</text></outputEntry>
        <outputEntry><text>0</text></outputEntry>
        <outputEntry><text>"unknown"</text></outputEntry>
        <outputEntry><text>0</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
