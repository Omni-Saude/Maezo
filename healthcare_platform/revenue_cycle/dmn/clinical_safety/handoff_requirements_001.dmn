<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/DMN/20151101/dmn.xsd"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_handoff_requirements_001"
             name="Clinical Handoff Requirements"
             namespace="http://healthcare.platform/dmn/clinical_safety">
  <decision id="handoff_requirements_001" name="Clinical Handoff Requirements">
    <decisionTable id="DecisionTable_handoff_requirements_001" hitPolicy="COLLECT">
      <input id="input1" label="Handoff Type">
        <inputExpression typeRef="string">
          <text>handoff_type</text>
        </inputExpression>
      </input>
      <input id="input2" label="Patient Acuity">
        <inputExpression typeRef="string">
          <text>patient_acuity</text>
        </inputExpression>
      </input>
      <input id="input3" label="Care Setting">
        <inputExpression typeRef="string">
          <text>care_setting</text>
        </inputExpression>
      </input>
      <output id="output1" label="Required Element" name="required_element" typeRef="string"/>
      <output id="output2" label="Format" name="format" typeRef="string"/>
      <output id="output3" label="Verification Required" name="verification_required" typeRef="boolean"/>

      <!-- Shift handoffs require SBAR -->
      <rule id="rule1">
        <inputEntry><text>"shift"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"sbar_summary"</text></outputEntry>
        <outputEntry><text>"structured_sbar"</text></outputEntry>
        <outputEntry><text>true</text></outputEntry>
      </rule>

      <!-- Transfer handoffs require detailed documentation -->
      <rule id="rule2">
        <inputEntry><text>"transfer"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"complete_medical_record"</text></outputEntry>
        <outputEntry><text>"comprehensive"</text></outputEntry>
        <outputEntry><text>true</text></outputEntry>
      </rule>

      <!-- Escalation handoffs require urgency documentation -->
      <rule id="rule3">
        <inputEntry><text>"escalation"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"clinical_rationale"</text></outputEntry>
        <outputEntry><text>"urgent_sbar"</text></outputEntry>
        <outputEntry><text>true</text></outputEntry>
      </rule>

      <!-- High acuity patients require additional elements -->
      <rule id="rule4">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"high", "critical"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"current_vital_signs"</text></outputEntry>
        <outputEntry><text>"real_time"</text></outputEntry>
        <outputEntry><text>true</text></outputEntry>
      </rule>

      <!-- ICU transfers require specialized documentation -->
      <rule id="rule5">
        <inputEntry><text>"transfer"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"icu"</text></inputEntry>
        <outputEntry><text>"hemodynamic_status"</text></outputEntry>
        <outputEntry><text>"detailed"</text></outputEntry>
        <outputEntry><text>true</text></outputEntry>
      </rule>

      <!-- All handoffs require medication reconciliation -->
      <rule id="rule6">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"medication_list"</text></outputEntry>
        <outputEntry><text>"reconciled"</text></outputEntry>
        <outputEntry><text>true</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
