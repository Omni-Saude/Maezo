<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/DMN/20151101/dmn.xsd"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_alert_escalation_001"
             name="Clinical Alert Escalation Rules"
             namespace="http://healthcare.platform/dmn/clinical_safety">
  <decision id="alert_escalation_001" name="Clinical Alert Escalation Rules">
    <decisionTable id="DecisionTable_alert_escalation_001" hitPolicy="FIRST">
      <input id="input1" label="Alert Severity">
        <inputExpression typeRef="string">
          <text>severity</text>
        </inputExpression>
      </input>
      <input id="input2" label="Alert Type">
        <inputExpression typeRef="string">
          <text>alert_type</text>
        </inputExpression>
      </input>
      <input id="input3" label="Response Time (minutes)">
        <inputExpression typeRef="integer">
          <text>response_time_minutes</text>
        </inputExpression>
      </input>
      <output id="output1" label="Escalate" name="escalate" typeRef="boolean"/>
      <output id="output2" label="Escalation Level" name="escalation_level" typeRef="string"/>
      <output id="output3" label="Target Role" name="target_role" typeRef="string"/>
      <output id="output4" label="Notification Method" name="notification_method" typeRef="string"/>

      <!-- Critical alerts always escalate immediately -->
      <rule id="rule1">
        <inputEntry><text>"critical"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"immediate"</text></outputEntry>
        <outputEntry><text>"attending_physician"</text></outputEntry>
        <outputEntry><text>"phone_call"</text></outputEntry>
      </rule>

      <!-- High severity with critical lab type escalates -->
      <rule id="rule2">
        <inputEntry><text>"high"</text></inputEntry>
        <inputEntry><text>"critical_lab"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"urgent"</text></outputEntry>
        <outputEntry><text>"senior_nurse"</text></outputEntry>
        <outputEntry><text>"sms"</text></outputEntry>
      </rule>

      <!-- High severity unacknowledged after 15 minutes -->
      <rule id="rule3">
        <inputEntry><text>"high"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>&gt; 15</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"delayed_response"</text></outputEntry>
        <outputEntry><text>"charge_nurse"</text></outputEntry>
        <outputEntry><text>"phone_call"</text></outputEntry>
      </rule>

      <!-- Medium severity unacknowledged after 30 minutes -->
      <rule id="rule4">
        <inputEntry><text>"medium"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>&gt; 30</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"delayed_response"</text></outputEntry>
        <outputEntry><text>"team_lead"</text></outputEntry>
        <outputEntry><text>"ehr_notification"</text></outputEntry>
      </rule>

      <!-- No escalation needed for low severity or timely responses -->
      <rule id="rule5">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>false</text></outputEntry>
        <outputEntry><text>"none"</text></outputEntry>
        <outputEntry><text>"none"</text></outputEntry>
        <outputEntry><text>"none"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
