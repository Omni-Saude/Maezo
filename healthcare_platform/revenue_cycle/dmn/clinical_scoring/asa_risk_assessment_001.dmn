<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/DMN/20151101/dmn.xsd"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_asa_risk_assessment_001"
             name="ASA Physical Status Risk Assessment"
             namespace="http://healthcare.platform/dmn/clinical_scoring">
  <decision id="asa_risk_assessment_001" name="ASA Physical Status Risk Assessment">
    <decisionTable id="DecisionTable_asa_risk_assessment_001" hitPolicy="UNIQUE">
      <input id="input1" label="ASA Classification">
        <inputExpression typeRef="string">
          <text>asa_classification</text>
        </inputExpression>
      </input>
      <output id="output1" label="Risk Level" name="risk_level" typeRef="string"/>
      <output id="output2" label="Risk Score" name="risk_score" typeRef="integer"/>
      <output id="output3" label="Anesthesia Type" name="anesthesia_type" typeRef="string"/>
      <output id="output4" label="Monitoring Level" name="monitoring_level" typeRef="string"/>

      <!-- ASA I: Healthy patient -->
      <rule id="rule1">
        <inputEntry><text>"1"</text></inputEntry>
        <outputEntry><text>"minimal"</text></outputEntry>
        <outputEntry><text>1</text></outputEntry>
        <outputEntry><text>"general_or_regional"</text></outputEntry>
        <outputEntry><text>"standard"</text></outputEntry>
      </rule>

      <!-- ASA II: Mild systemic disease -->
      <rule id="rule2">
        <inputEntry><text>"2"</text></inputEntry>
        <outputEntry><text>"low"</text></outputEntry>
        <outputEntry><text>2</text></outputEntry>
        <outputEntry><text>"general_or_regional"</text></outputEntry>
        <outputEntry><text>"standard"</text></outputEntry>
      </rule>

      <!-- ASA III: Severe systemic disease -->
      <rule id="rule3">
        <inputEntry><text>"3"</text></inputEntry>
        <outputEntry><text>"moderate"</text></outputEntry>
        <outputEntry><text>3</text></outputEntry>
        <outputEntry><text>"general_with_precautions"</text></outputEntry>
        <outputEntry><text>"enhanced"</text></outputEntry>
      </rule>

      <!-- ASA IV: Severe disease that is a constant threat to life -->
      <rule id="rule4">
        <inputEntry><text>"4"</text></inputEntry>
        <outputEntry><text>"high"</text></outputEntry>
        <outputEntry><text>4</text></outputEntry>
        <outputEntry><text>"specialized_anesthesia"</text></outputEntry>
        <outputEntry><text>"intensive"</text></outputEntry>
      </rule>

      <!-- ASA V: Moribund patient not expected to survive without operation -->
      <rule id="rule5">
        <inputEntry><text>"5"</text></inputEntry>
        <outputEntry><text>"critical"</text></outputEntry>
        <outputEntry><text>5</text></outputEntry>
        <outputEntry><text>"emergency_protocol"</text></outputEntry>
        <outputEntry><text>"critical_care"</text></outputEntry>
      </rule>

      <!-- ASA VI: Brain-dead patient for organ donation -->
      <rule id="rule6">
        <inputEntry><text>"6"</text></inputEntry>
        <outputEntry><text>"organ_donation"</text></outputEntry>
        <outputEntry><text>6</text></outputEntry>
        <outputEntry><text>"donation_protocol"</text></outputEntry>
        <outputEntry><text>"specialized"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
