<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" id="Definitions_predict_collection_threshold" name="Predict Collection Threshold" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: predict_collection_date_worker.py -->
  <decision id="Decision_predict_collection_threshold" name="Predict Collection Threshold">
    <decisionTable id="DecisionTable_predict_collection_threshold" hitPolicy="FIRST">
      <input id="Input_historical_samples" label="Amostras Historicas"><inputExpression id="IE_hs" typeRef="integer"><text>historical_samples</text></inputExpression></input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1"><inputEntry id="U1"><text>&lt; 3</text></inputEntry><outputEntry id="L1"><text>"REVISAR"</text></outputEntry><outputEntry id="L1a"><text>"Dados insuficientes - usar media simples"</text></outputEntry><outputEntry id="L1b"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_2"><inputEntry id="U2"><text>[3..10)</text></inputEntry><outputEntry id="L2"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L2a"><text>"Modelo basico - confianca moderada"</text></outputEntry><outputEntry id="L2b"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_3"><inputEntry id="U3"><text>[10..30)</text></inputEntry><outputEntry id="L3"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L3a"><text>"Modelo confiavel"</text></outputEntry><outputEntry id="L3b"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_4"><inputEntry id="U4"><text>[30..100)</text></inputEntry><outputEntry id="L4"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a"><text>"Modelo robusto"</text></outputEntry><outputEntry id="L4b"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_5"><inputEntry id="U5"><text>>= 100</text></inputEntry><outputEntry id="L5"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a"><text>"Modelo altamente confiavel"</text></outputEntry><outputEntry id="L5b"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>
</definitions>
