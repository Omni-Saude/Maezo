<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" id="Definitions_predict_collection_scoring" name="Predict Collection Scoring" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: predict_collection_date_worker.py -->
  <decision id="Decision_predict_collection_scoring" name="Predict Collection Scoring">
    <decisionTable id="DecisionTable_predict_collection_scoring" hitPolicy="FIRST">
      <input id="Input_predicted_days" label="Dias Previstos"><inputExpression id="IE_pd" typeRef="integer"><text>predicted_days</text></inputExpression></input>
      <input id="Input_confidence" label="Confianca"><inputExpression id="IE_conf" typeRef="double"><text>confidence</text></inputExpression></input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1"><inputEntry id="U1a"><text>>= 150</text></inputEntry><inputEntry id="U1b"><text>>= 0.7</text></inputEntry><outputEntry id="L1"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L1a"><text>"Previsao de cobranca muito tardia - acao preventiva"</text></outputEntry><outputEntry id="L1b"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2"><inputEntry id="U2a"><text>[90..150)</text></inputEntry><inputEntry id="U2b"><text>>= 0.6</text></inputEntry><outputEntry id="L2"><text>"REVISAR"</text></outputEntry><outputEntry id="L2a"><text>"Previsao longa - intensificar cobranca"</text></outputEntry><outputEntry id="L2b"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_3"><inputEntry id="U3a"><text>[60..90)</text></inputEntry><inputEntry id="U3b"><text></text></inputEntry><outputEntry id="L3"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L3a"><text>"Previsao aceitavel - monitorar"</text></outputEntry><outputEntry id="L3b"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_4"><inputEntry id="U4a"><text>[30..60)</text></inputEntry><inputEntry id="U4b"><text></text></inputEntry><outputEntry id="L4"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a"><text>"Previsao boa - manter acompanhamento"</text></outputEntry><outputEntry id="L4b"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_5"><inputEntry id="U5a"><text>&lt; 30</text></inputEntry><inputEntry id="U5b"><text></text></inputEntry><outputEntry id="L5"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a"><text>"Cobranca rapida prevista"</text></outputEntry><outputEntry id="L5b"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>
</definitions>
