<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" id="Definitions_payment_plan_scoring" name="Payment Plan Scoring" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: negotiate_payment_plan_worker.py -->
  <decision id="Decision_payment_plan_scoring" name="Payment Plan Scoring">
    <decisionTable id="DecisionTable_payment_plan_scoring" hitPolicy="FIRST">
      <input id="Input_installments" label="Num Parcelas"><inputExpression id="IE_inst" typeRef="integer"><text>num_installments</text></inputExpression></input>
      <input id="Input_installment_amt" label="Valor Parcela R$"><inputExpression id="IE_ia" typeRef="double"><text>installment_amount</text></inputExpression></input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1"><inputEntry id="U1a"><text>> 12</text></inputEntry><inputEntry id="U1b"><text></text></inputEntry><outputEntry id="L1"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L1a"><text>"Excede maximo de parcelas permitido"</text></outputEntry><outputEntry id="L1b"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2"><inputEntry id="U2a"><text></text></inputEntry><inputEntry id="U2b"><text>&lt; 100</text></inputEntry><outputEntry id="L2"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L2a"><text>"Parcela abaixo do minimo R$100"</text></outputEntry><outputEntry id="L2b"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_3"><inputEntry id="U3a"><text>[10..12]</text></inputEntry><inputEntry id="U3b"><text>>= 100</text></inputEntry><outputEntry id="L3"><text>"REVISAR"</text></outputEntry><outputEntry id="L3a"><text>"Parcelamento longo - aprovacao gerencial"</text></outputEntry><outputEntry id="L3b"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_4"><inputEntry id="U4a"><text>[4..10)</text></inputEntry><inputEntry id="U4b"><text>>= 100</text></inputEntry><outputEntry id="L4"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a"><text>"Parcelamento padrao - aprovar"</text></outputEntry><outputEntry id="L4b"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_5"><inputEntry id="U5a"><text>[1..4)</text></inputEntry><inputEntry id="U5b"><text>>= 100</text></inputEntry><outputEntry id="L5"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a"><text>"Parcelamento curto - auto-aprovar"</text></outputEntry><outputEntry id="L5b"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>
</definitions>
