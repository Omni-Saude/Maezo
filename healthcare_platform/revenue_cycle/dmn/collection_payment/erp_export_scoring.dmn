<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" id="Definitions_erp_export_scoring" name="ERP Export Scoring" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: export_to_erp_worker.py -->
  <decision id="Decision_erp_export_scoring" name="ERP Export Scoring">
    <decisionTable id="DecisionTable_erp_export_scoring" hitPolicy="FIRST">
      <input id="Input_erp_system" label="Sistema ERP"><inputExpression id="IE_erp" typeRef="string"><text>erp_system</text></inputExpression></input>
      <input id="Input_operation" label="Operacao"><inputExpression id="IE_op" typeRef="string"><text>operation</text></inputExpression></input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1"><inputEntry id="U1a"><text></text></inputEntry><inputEntry id="U1b"><text>"delete"</text></inputEntry><outputEntry id="L1"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L1a"><text>"Exclusao no ERP requer aprovacao"</text></outputEntry><outputEntry id="L1b"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2"><inputEntry id="U2a"><text>not("tasy","mv_soul")</text></inputEntry><inputEntry id="U2b"><text></text></inputEntry><outputEntry id="L2"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L2a"><text>"Sistema ERP nao suportado"</text></outputEntry><outputEntry id="L2b"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_3"><inputEntry id="U3a"><text>"tasy","mv_soul"</text></inputEntry><inputEntry id="U3b"><text>"update"</text></inputEntry><outputEntry id="L3"><text>"REVISAR"</text></outputEntry><outputEntry id="L3a"><text>"Atualizacao no ERP - validar dados"</text></outputEntry><outputEntry id="L3b"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_4"><inputEntry id="U4a"><text>"tasy","mv_soul"</text></inputEntry><inputEntry id="U4b"><text>"insert"</text></inputEntry><outputEntry id="L4"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a"><text>"Insercao padrao no ERP"</text></outputEntry><outputEntry id="L4b"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_5"><inputEntry id="U5a"><text></text></inputEntry><inputEntry id="U5b"><text></text></inputEntry><outputEntry id="L5"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a"><text>"Operacao padrao"</text></outputEntry><outputEntry id="L5b"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>
</definitions>
