<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" id="Definitions_overpayment_scoring" name="Overpayment Scoring" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: handle_overpayment_worker.py -->
  <decision id="Decision_overpayment_scoring" name="Overpayment Scoring">
    <decisionTable id="DecisionTable_overpayment_scoring" hitPolicy="FIRST">
      <input id="Input_overpayment_pct" label="Sobrepagamento %"><inputExpression id="IE_op" typeRef="double"><text>overpayment_percentage</text></inputExpression></input>
      <input id="Input_overpayment_amt" label="Valor Sobrepagamento R$"><inputExpression id="IE_oa" typeRef="double"><text>overpayment_amount</text></inputExpression></input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1"><inputEntry id="U1a"><text>> 50</text></inputEntry><inputEntry id="U1b"><text>>= 10000</text></inputEntry><outputEntry id="L1"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L1a"><text>"Sobrepagamento anomalo - possivel erro de sistema"</text></outputEntry><outputEntry id="L1b"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2"><inputEntry id="U2a"><text>[20..50]</text></inputEntry><inputEntry id="U2b"><text>>= 5000</text></inputEntry><outputEntry id="L2"><text>"REVISAR"</text></outputEntry><outputEntry id="L2a"><text>"Sobrepagamento significativo - gerar nota credito"</text></outputEntry><outputEntry id="L2b"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_3"><inputEntry id="U3a"><text>[10..20)</text></inputEntry><inputEntry id="U3b"><text></text></inputEntry><outputEntry id="L3"><text>"REVISAR"</text></outputEntry><outputEntry id="L3a"><text>"Sobrepagamento moderado - nota credito"</text></outputEntry><outputEntry id="L3b"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_4"><inputEntry id="U4a"><text>[2..10)</text></inputEntry><inputEntry id="U4b"><text></text></inputEntry><outputEntry id="L4"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a"><text>"Sobrepagamento menor - creditar automatico"</text></outputEntry><outputEntry id="L4b"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_5"><inputEntry id="U5a"><text>&lt; 2</text></inputEntry><inputEntry id="U5b"><text></text></inputEntry><outputEntry id="L5"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a"><text>"Diferenca insignificante - absorver"</text></outputEntry><outputEntry id="L5b"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>
</definitions>
