<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  OVERPAYMENT-REFUND - Roteamento de Reembolso por Pagamento Excedente
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_PAYMENT
  Archetype: ROUTING | Source: handle_overpayment_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_OVERPAY_REFUND"
             name="Roteamento de Reembolso por Pagamento Excedente"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_OVERPAY_REFUND" name="Roteamento de Reembolso por Pagamento Excedente">
    <decisionTable id="DecisionTable_OVERPAY_REFUND" hitPolicy="FIRST">

      <input id="Input_1" label="Valor Excedente">
        <inputExpression id="InputExpression_1" typeRef="number">
          <text>overpaymentAmount</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Tipo Pagador">
        <inputExpression id="InputExpression_2" typeRef="string">
          <text>payerType</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Percentual Excedente">
        <inputExpression id="InputExpression_3" typeRef="number">
          <text>overpaymentPercent</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1">
        <description>Excedente muito alto - possivel erro de lancamento</description>
        <inputEntry id="IE_1_1"><text>-</text></inputEntry>
        <inputEntry id="IE_1_2"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3"><text>&gt; 50</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"Pagamento excede 50% do esperado - provavel erro de lancamento"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <description>Operadora - gerar nota de credito</description>
        <inputEntry id="IE_2_1"><text>&gt; 100</text></inputEntry>
        <inputEntry id="IE_2_2"><text>"OPERADORA"</text></inputEntry>
        <inputEntry id="IE_2_3"><text>&lt;= 50</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"Gerar nota de credito para operadora e compensar no proximo lote"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <description>Particular - reembolso direto</description>
        <inputEntry id="IE_3_1"><text>&gt; 50</text></inputEntry>
        <inputEntry id="IE_3_2"><text>"PARTICULAR"</text></inputEntry>
        <inputEntry id="IE_3_3"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"Processar reembolso direto ao paciente via transferencia bancaria"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_4">
        <description>Valor residual pequeno - credito em conta</description>
        <inputEntry id="IE_4_1"><text>&lt;= 50</text></inputEntry>
        <inputEntry id="IE_4_2"><text>-</text></inputEntry>
        <inputEntry id="IE_4_3"><text>-</text></inputEntry>
        <outputEntry id="OE_4_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2"><text>"Valor residual - registrar como credito para proxima consulta"</text></outputEntry>
        <outputEntry id="OE_4_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_5">
        <description>SUS - devolver ao fundo publico</description>
        <inputEntry id="IE_5_1"><text>-</text></inputEntry>
        <inputEntry id="IE_5_2"><text>"SUS"</text></inputEntry>
        <inputEntry id="IE_5_3"><text>-</text></inputEntry>
        <outputEntry id="OE_5_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_5_2"><text>"Pagamento SUS excedente - revisar AIH e gerar GRU de devolucao"</text></outputEntry>
        <outputEntry id="OE_5_3"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Fallback</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"Avaliar roteamento de reembolso manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_OVERPAY_REFUND">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_OVERPAY_REFUND">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
