<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/DMN/20151101/dmn.xsd"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_audit_type_dmn_routing_001"
             name="Clinical Audit Type DMN Routing"
             namespace="http://healthcare.platform/dmn/clinical_quality">
  <decision id="audit_type_dmn_routing_001" name="Clinical Audit Type DMN Routing">
    <decisionTable id="DecisionTable_audit_type_dmn_routing_001" hitPolicy="UNIQUE">
      <input id="input1" label="Audit Type">
        <inputExpression typeRef="string">
          <text>audit_type</text>
        </inputExpression>
      </input>
      <output id="output1" label="DMN Table" name="dmn_table" typeRef="string"/>
      <output id="output2" label="DMN Namespace" name="dmn_namespace" typeRef="string"/>
      <output id="output3" label="Audit Scope" name="audit_scope" typeRef="string"/>
      <output id="output4" label="Frequency" name="frequency" typeRef="string"/>

      <!-- Medication audit -->
      <rule id="rule1">
        <inputEntry><text>"medication_audit"</text></inputEntry>
        <outputEntry><text>"medication_safety_audit_001"</text></outputEntry>
        <outputEntry><text>"clinical_safety"</text></outputEntry>
        <outputEntry><text>"pharmacy_orders"</text></outputEntry>
        <outputEntry><text>"daily"</text></outputEntry>
      </rule>

      <!-- Documentation audit -->
      <rule id="rule2">
        <inputEntry><text>"documentation_audit"</text></inputEntry>
        <outputEntry><text>"documentation_completeness_001"</text></outputEntry>
        <outputEntry><text>"clinical_quality"</text></outputEntry>
        <outputEntry><text>"clinical_notes"</text></outputEntry>
        <outputEntry><text>"weekly"</text></outputEntry>
      </rule>

      <!-- Infection control audit -->
      <rule id="rule3">
        <inputEntry><text>"infection_control_audit"</text></inputEntry>
        <outputEntry><text>"infection_prevention_001"</text></outputEntry>
        <outputEntry><text>"clinical_safety"</text></outputEntry>
        <outputEntry><text>"infection_cases"</text></outputEntry>
        <outputEntry><text>"weekly"</text></outputEntry>
      </rule>

      <!-- Coding audit -->
      <rule id="rule4">
        <inputEntry><text>"coding_audit"</text></inputEntry>
        <outputEntry><text>"coding_accuracy_001"</text></outputEntry>
        <outputEntry><text>("revenue_cycle"</text></outputEntry>
        <outputEntry><text>"diagnosis_procedure_codes"</text></outputEntry>
        <outputEntry><text>"monthly"</text></outputEntry>
      </rule>

      <!-- Compliance audit -->
      <rule id="rule5">
        <inputEntry><text>"compliance_audit"</text></inputEntry>
        <outputEntry><text>"regulatory_compliance_001"</text></outputEntry>
        <outputEntry><text>"clinical_quality"</text></outputEntry>
        <outputEntry><text>"regulatory_requirements"</text></outputEntry>
        <outputEntry><text>"quarterly"</text></outputEntry>
      </rule>

      <!-- Patient safety audit -->
      <rule id="rule6">
        <inputEntry><text>"patient_safety_audit"</text></inputEntry>
        <outputEntry><text>"safety_event_review_001"</text></outputEntry>
        <outputEntry><text>"clinical_safety"</text></outputEntry>
        <outputEntry><text>"safety_events"</text></outputEntry>
        <outputEntry><text>"weekly"</text></outputEntry>
      </rule>

      <!-- Quality indicator audit -->
      <rule id="rule7">
        <inputEntry><text>"quality_indicator_audit"</text></inputEntry>
        <outputEntry><text>"quality_indicator_types_001"</text></outputEntry>
        <outputEntry><text>"clinical_quality"</text></outputEntry>
        <outputEntry><text>"quality_metrics"</text></outputEntry>
        <outputEntry><text>"monthly"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
