<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/DMN/20151101/dmn.xsd"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_auth_complexity_001"
             name="Authorization Complexity Assessment"
             namespace="http://healthcare.platform/dmn/authorization">
  <decision id="auth_complexity_001" name="Authorization Complexity Assessment">
    <decisionTable id="DecisionTable_auth_complexity_001" hitPolicy="FIRST">
      <input id="input1" label="Procedure Code">
        <inputExpression typeRef="string">
          <text>procedure_code</text>
        </inputExpression>
      </input>
      <input id="input2" label="Procedure Category">
        <inputExpression typeRef="string">
          <text>procedure_category</text>
        </inputExpression>
      </input>
      <output id="output1" label="Requires Authorization" name="requires_auth" typeRef="boolean"/>
      <output id="output2" label="Authorization Level" name="auth_level" typeRef="string"/>
      <output id="output3" label="Review Type" name="review_type" typeRef="string"/>

      <!-- High complexity procedures requiring authorization -->
      <rule id="rule1">
        <inputEntry><text>"31.1", "31.2", "31.3"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"high"</text></outputEntry>
        <outputEntry><text>"clinical_review"</text></outputEntry>
      </rule>
      <rule id="rule2">
        <inputEntry><text>"40.50", "40.51", "40.52"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"high"</text></outputEntry>
        <outputEntry><text>"clinical_review"</text></outputEntry>
      </rule>
      <rule id="rule3">
        <inputEntry><text>"36.10", "36.11", "36.12"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"medium"</text></outputEntry>
        <outputEntry><text>"standard_review"</text></outputEntry>
      </rule>

      <!-- Category-based rules -->
      <rule id="rule4">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"cardiovascular_surgery"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"high"</text></outputEntry>
        <outputEntry><text>"clinical_review"</text></outputEntry>
      </rule>
      <rule id="rule5">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"transplant"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"critical"</text></outputEntry>
        <outputEntry><text>"specialist_review"</text></outputEntry>
      </rule>
      <rule id="rule6">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"oncology"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"high"</text></outputEntry>
        <outputEntry><text>"clinical_review"</text></outputEntry>
      </rule>

      <!-- Default: no authorization required -->
      <rule id="rule7">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>false</text></outputEntry>
        <outputEntry><text>"none"</text></outputEntry>
        <outputEntry><text>"none"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
