<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  FORECAST-ACCURACY - Avaliacao de Precisao da Previsao
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_FORECASTING
  Archetype: CLINICAL_SCORE | Source: update_forecasts_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_FORECAST_ACCURACY"
             name="Avaliacao de Precisao da Previsao"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_FORECAST_ACCURACY" name="Avaliacao de Precisao da Previsao">
    <decisionTable id="DecisionTable_FORECAST_ACCURACY" hitPolicy="FIRST">

      <input id="Input_1" label="Confianca Media Semanal">
        <inputExpression id="InputExpression_1" typeRef="number">
          <text>avgWeeklyConfidence</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Total Previsao (R$)">
        <inputExpression id="InputExpression_2" typeRef="number">
          <text>totalForecast</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="AR Atual (R$)">
        <inputExpression id="InputExpression_3" typeRef="number">
          <text>currentAR</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1">
        <description>Previsao muito baixa vs AR - risco de fluxo de caixa</description>
        <inputEntry id="IE_1_1"><text>-</text></inputEntry>
        <inputEntry id="IE_1_2"><text>&lt; 50000</text></inputEntry>
        <inputEntry id="IE_1_3"><text>&gt; 500000</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"Previsao de arrecadacao muito abaixo do AR - risco de liquidez"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <description>Confianca muito baixa nas previsoes semanais</description>
        <inputEntry id="IE_2_1"><text>&lt; 0.5</text></inputEntry>
        <inputEntry id="IE_2_2"><text>-</text></inputEntry>
        <inputEntry id="IE_2_3"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"Confianca media abaixo de 50% - recalibrar modelos de previsao"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <description>Previsao saudavel com boa confianca</description>
        <inputEntry id="IE_3_1"><text>&gt;= 0.75</text></inputEntry>
        <inputEntry id="IE_3_2"><text>&gt;= 100000</text></inputEntry>
        <inputEntry id="IE_3_3"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"Previsao confiavel - fluxo de caixa dentro do esperado"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_4">
        <description>Confianca moderada</description>
        <inputEntry id="IE_4_1"><text>[0.5..0.75]</text></inputEntry>
        <inputEntry id="IE_4_2"><text>-</text></inputEntry>
        <inputEntry id="IE_4_3"><text>-</text></inputEntry>
        <outputEntry id="OE_4_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2"><text>"Confianca moderada - monitorar desvios semanalmente"</text></outputEntry>
        <outputEntry id="OE_4_3"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Fallback</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"Avaliar previsao manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_FORECAST_ACCURACY">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_FORECAST_ACCURACY">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
