<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  CYCLE-TIME-SCORING - Scoring de Tempo de Ciclo de Receita
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_FORECASTING
  Archetype: CLINICAL_SCORE | Source: calculate_revenue_cycle_time_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_CYCLE_TIME_SCORING"
             name="Scoring de Tempo de Ciclo de Receita"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_CYCLE_TIME_SCORING" name="Scoring de Tempo de Ciclo de Receita">
    <decisionTable id="DecisionTable_CYCLE_TIME_SCORING" hitPolicy="FIRST">

      <input id="Input_1" label="Tempo Medio Ciclo (dias)">
        <inputExpression id="InputExpression_1" typeRef="number">
          <text>avgCycleTimeDays</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Tempo Maximo Ciclo (dias)">
        <inputExpression id="InputExpression_2" typeRef="number">
          <text>maxCycleTimeDays</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Total Encounters">
        <inputExpression id="InputExpression_3" typeRef="number">
          <text>totalEncounters</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1">
        <description>Ciclo excessivamente longo - problemas sistemicos</description>
        <inputEntry id="IE_1_1"><text>&gt; 90</text></inputEntry>
        <inputEntry id="IE_1_2"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3"><text>&gt;= 10</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"Ciclo medio acima de 90 dias - investigar gargalos no processo"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <description>Ciclo longo com outliers extremos</description>
        <inputEntry id="IE_2_1"><text>[60..90]</text></inputEntry>
        <inputEntry id="IE_2_2"><text>&gt; 180</text></inputEntry>
        <inputEntry id="IE_2_3"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"Ciclo longo com outliers - analisar casos atipicos"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <description>Ciclo moderado</description>
        <inputEntry id="IE_3_1"><text>[45..60]</text></inputEntry>
        <inputEntry id="IE_3_2"><text>-</text></inputEntry>
        <inputEntry id="IE_3_3"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"Ciclo dentro do esperado para o mercado brasileiro"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_4">
        <description>Ciclo otimo</description>
        <inputEntry id="IE_4_1"><text>[30..45]</text></inputEntry>
        <inputEntry id="IE_4_2"><text>-</text></inputEntry>
        <inputEntry id="IE_4_3"><text>-</text></inputEntry>
        <outputEntry id="OE_4_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2"><text>"Ciclo otimo - manter praticas atuais"</text></outputEntry>
        <outputEntry id="OE_4_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_5">
        <description>Ciclo excelente</description>
        <inputEntry id="IE_5_1"><text>&lt; 30</text></inputEntry>
        <inputEntry id="IE_5_2"><text>-</text></inputEntry>
        <inputEntry id="IE_5_3"><text>&gt;= 5</text></inputEntry>
        <outputEntry id="OE_5_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_2"><text>"Ciclo excelente - benchmark positivo"</text></outputEntry>
        <outputEntry id="OE_5_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_6">
        <description>Amostra insuficiente</description>
        <inputEntry id="IE_6_1"><text>-</text></inputEntry>
        <inputEntry id="IE_6_2"><text>-</text></inputEntry>
        <inputEntry id="IE_6_3"><text>&lt; 3</text></inputEntry>
        <outputEntry id="OE_6_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_6_2"><text>"Poucos encounters - resultado estatisticamente insignificante"</text></outputEntry>
        <outputEntry id="OE_6_3"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Fallback</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"Avaliar tempo de ciclo manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_CYCLE_TIME_SCORING">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_CYCLE_TIME_SCORING">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
