<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  PREDICTION-SCORING - Scoring de Predicao de Data de Cobranca
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_FORECASTING
  Archetype: CLINICAL_SCORE | Source: predict_collection_date_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_PRED_SCORING"
             name="Scoring de Predicao de Data de Cobranca"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_PRED_SCORING" name="Scoring de Predicao de Data de Cobranca">
    <decisionTable id="DecisionTable_PRED_SCORING" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1" label="Dias Previstos">
        <inputExpression id="InputExpression_1" typeRef="number">
          <text>predictedDays</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Amostras Historicas">
        <inputExpression id="InputExpression_2" typeRef="number">
          <text>historicalSamples</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Tipo Modelo">
        <inputExpression id="InputExpression_3" typeRef="string">
          <text>modelType</text>
        </inputExpression>
        <inputValues id="InputValues_3">
          <text>"linear_regression","average","ensemble"</text>
        </inputValues>
      </input>

      <input id="Input_4" label="Valor Claim (R$)">
        <inputExpression id="InputExpression_4" typeRef="number">
          <text>claimAmount</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
      <rule id="Rule_1">
        <description>Predicao muito longa com alto valor - risco critico</description>
        <inputEntry id="IE_1_1"><text>&gt; 120</text></inputEntry>
        <inputEntry id="IE_1_2"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3"><text>-</text></inputEntry>
        <inputEntry id="IE_1_4"><text>&gt; 100000</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"Escalar para gestao - previsao superior a 120 dias com valor alto"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <description>Dados insuficientes para modelo confiavel</description>
        <inputEntry id="IE_2_1"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2"><text>&lt; 3</text></inputEntry>
        <inputEntry id="IE_2_3"><text>"average"</text></inputEntry>
        <inputEntry id="IE_2_4"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"Amostras insuficientes - usar estimativa manual ate acumular historico"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <description>Predicao longa (90-120 dias)</description>
        <inputEntry id="IE_3_1"><text>[90..120]</text></inputEntry>
        <inputEntry id="IE_3_2"><text>&gt;= 5</text></inputEntry>
        <inputEntry id="IE_3_3"><text>-</text></inputEntry>
        <inputEntry id="IE_3_4"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"Previsao entre 90-120 dias - monitorar pagador e considerar cobranca proativa"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_4">
        <description>Predicao normal (45-90 dias) com modelo ML</description>
        <inputEntry id="IE_4_1"><text>[45..90]</text></inputEntry>
        <inputEntry id="IE_4_2"><text>&gt;= 5</text></inputEntry>
        <inputEntry id="IE_4_3"><text>"linear_regression"</text></inputEntry>
        <inputEntry id="IE_4_4"><text>-</text></inputEntry>
        <outputEntry id="OE_4_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2"><text>"Previsao dentro do esperado - acompanhar normalmente"</text></outputEntry>
        <outputEntry id="OE_4_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_5">
        <description>Predicao rapida (abaixo de 45 dias)</description>
        <inputEntry id="IE_5_1"><text>&lt; 45</text></inputEntry>
        <inputEntry id="IE_5_2"><text>&gt;= 3</text></inputEntry>
        <inputEntry id="IE_5_3"><text>-</text></inputEntry>
        <inputEntry id="IE_5_4"><text>-</text></inputEntry>
        <outputEntry id="OE_5_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_2"><text>"Previsao otimista - pagador com bom historico"</text></outputEntry>
        <outputEntry id="OE_5_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Fallback - revisao manual</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <inputEntry id="IE_F_4"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"Requer analise manual da predicao"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PRED_SCORING">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_PRED_SCORING">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
