<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  CYCLE-TIME-BENCHMARK - Benchmark de Tempo de Ciclo por Pagador
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_FORECASTING
  Archetype: CLINICAL_SCORE | Source: calculate_revenue_cycle_time_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_CYCLE_BENCHMARK"
             name="Benchmark de Tempo de Ciclo por Pagador"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_CYCLE_BENCHMARK" name="Benchmark de Tempo de Ciclo por Pagador">
    <decisionTable id="DecisionTable_CYCLE_BENCHMARK" hitPolicy="FIRST">

      <input id="Input_1" label="Media Pagador (dias)">
        <inputExpression id="InputExpression_1" typeRef="number">
          <text>payerAvgDays</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Media Geral (dias)">
        <inputExpression id="InputExpression_2" typeRef="number">
          <text>overallAvgDays</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Variacao vs Media (%)">
        <inputExpression id="InputExpression_3" typeRef="number">
          <text>variationPct</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1">
        <description>Pagador muito acima da media geral</description>
        <inputEntry id="IE_1_1"><text>-</text></inputEntry>
        <inputEntry id="IE_1_2"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3"><text>&gt; 50</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"Pagador 50%+ acima da media - renegociar termos ou escalar"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <description>Pagador significativamente acima da media</description>
        <inputEntry id="IE_2_1"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2"><text>-</text></inputEntry>
        <inputEntry id="IE_2_3"><text>[25..50]</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"Pagador acima da media - monitorar e considerar acoes proativas"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <description>Pagador proximo da media</description>
        <inputEntry id="IE_3_1"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2"><text>-</text></inputEntry>
        <inputEntry id="IE_3_3"><text>[-10..25]</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"Pagador dentro da faixa normal - manter acompanhamento padrao"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_4">
        <description>Pagador abaixo da media - excelente</description>
        <inputEntry id="IE_4_1"><text>-</text></inputEntry>
        <inputEntry id="IE_4_2"><text>-</text></inputEntry>
        <inputEntry id="IE_4_3"><text>&lt; -10</text></inputEntry>
        <outputEntry id="OE_4_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2"><text>"Pagador acima do benchmark - considerar como parceiro preferencial"</text></outputEntry>
        <outputEntry id="OE_4_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Fallback</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"Avaliar benchmark de pagador manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_CYCLE_BENCHMARK">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_CYCLE_BENCHMARK">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
