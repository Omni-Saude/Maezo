<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_ProcedureCodeAdjudication"
             name="Procedure Code Adjudication"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: procedure_code_adjudication_worker.py -->

  <!-- Source: validate_procedure_worker.py
       Rules extracted from TASY/ANS validation and coverage type mismatch.
  -->

  <decision id="Decision_ProcCodeAdj" name="Procedure Code Adjudication">
    <decisionTable id="DecisionTable_ProcCodeAdj" hitPolicy="FIRST">

      <input id="Input_isValidTASY" label="Valid in TASY">
        <inputExpression id="InputExpr_isValidTASY" typeRef="boolean">
          <text>isValidTASY</text>
        </inputExpression>
      </input>

      <input id="Input_isValidANS" label="Valid in ANS">
        <inputExpression id="InputExpr_isValidANS" typeRef="boolean">
          <text>isValidANS</text>
        </inputExpression>
      </input>

      <input id="Input_coverageType" label="Coverage Type">
        <inputExpression id="InputExpr_coverageType" typeRef="string">
          <text>coverageType</text>
        </inputExpression>
      </input>

      <input id="Input_expectedCoverageType" label="Expected Coverage Type">
        <inputExpression id="InputExpr_expectedCoverageType" typeRef="string">
          <text>expectedCoverageType</text>
        </inputExpression>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- R1: Invalid in both TASY and ANS — block -->
      <rule id="Rule_invalid_both">
        <description>Invalid procedure code in both TASY and ANS</description>
        <inputEntry id="IE_ib_1"><text>false</text></inputEntry>
        <inputEntry id="IE_ib_2"><text>false</text></inputEntry>
        <inputEntry id="IE_ib_3"><text>-</text></inputEntry>
        <inputEntry id="IE_ib_4"><text>-</text></inputEntry>
        <outputEntry id="OE_ib_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_ib_acao"><text>"Invalid procedure code"</text></outputEntry>
        <outputEntry id="OE_ib_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- R2: Coverage type mismatch — review -->
      <rule id="Rule_coverage_mismatch">
        <description>Coverage type mismatch — needs review</description>
        <inputEntry id="IE_cm_1"><text>-</text></inputEntry>
        <inputEntry id="IE_cm_2"><text>-</text></inputEntry>
        <inputEntry id="IE_cm_3"><text>not(null)</text></inputEntry>
        <inputEntry id="IE_cm_4"><text>not(null)</text></inputEntry>
        <outputEntry id="OE_cm_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_cm_acao"><text>"Coverage type mismatch"</text></outputEntry>
        <outputEntry id="OE_cm_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- R3: Valid procedure — proceed -->
      
      <rule id="Rule_HighRisk">
        <description>Risco alto detectado - revisao obrigatoria</description>
        <inputEntry id="IE_HighRisk_1"><text>-</text></inputEntry>
        <inputEntry id="IE_HighRisk_2"><text>-</text></inputEntry>
        <inputEntry id="IE_HighRisk_3"><text>-</text></inputEntry>
        <inputEntry id="IE_HighRisk_4"><text>-</text></inputEntry>
        <outputEntry id="OE_HighRisk_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_HighRisk_acao"><text>"Situacao de risco alto identificada - avaliacao detalhada necessaria"</text></outputEntry>
        <outputEntry id="OE_HighRisk_risco"><text>"ALTO"</text></outputEntry>
      </rule>


      <rule id="Rule_MediumRisk">
        <description>Risco moderado - monitoramento</description>
        <inputEntry id="IE_MediumRisk_1"><text>-</text></inputEntry>
        <inputEntry id="IE_MediumRisk_2"><text>-</text></inputEntry>
        <inputEntry id="IE_MediumRisk_3"><text>-</text></inputEntry>
        <inputEntry id="IE_MediumRisk_4"><text>-</text></inputEntry>
        <outputEntry id="OE_MediumRisk_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_MediumRisk_acao"><text>"Risco moderado identificado - incluir em monitoramento"</text></outputEntry>
        <outputEntry id="OE_MediumRisk_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_valid">
        <description>Procedure code valid — proceed</description>
        <inputEntry id="IE_v_1"><text>-</text></inputEntry>
        <inputEntry id="IE_v_2"><text>-</text></inputEntry>
        <inputEntry id="IE_v_3"><text>-</text></inputEntry>
        <inputEntry id="IE_v_4"><text>-</text></inputEntry>
        <outputEntry id="OE_v_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_v_acao"><text>"Procedure code valid"</text></outputEntry>
        <outputEntry id="OE_v_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_ProcCodeAdj">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
