<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_PersistenceValidationAdjudication"
             name="Persistence Validation Adjudication"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: persistence_validation_adjudication_worker.py -->

  <!-- Source: persist_production_worker.py
       Rules extracted from empty procedures check and zero amount validation.
  -->

  <decision id="Decision_PersistValidAdj" name="Persistence Validation Adjudication">
    <decisionTable id="DecisionTable_PersistValidAdj" hitPolicy="FIRST">

      <input id="Input_procedureCount" label="Procedure Count">
        <inputExpression id="InputExpr_procedureCount" typeRef="number">
          <text>procedureCount</text>
        </inputExpression>
      </input>

      <input id="Input_totalAmount" label="Total Amount">
        <inputExpression id="InputExpr_totalAmount" typeRef="number">
          <text>totalAmount</text>
        </inputExpression>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- R1: No procedures — block -->
      <rule id="Rule_no_procs">
        <description>No procedures to persist — hard block</description>
        <inputEntry id="IE_np_1"><text>0</text></inputEntry>
        <inputEntry id="IE_np_2"><text>-</text></inputEntry>
        <outputEntry id="OE_np_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_np_acao"><text>"No procedures to persist"</text></outputEntry>
        <outputEntry id="OE_np_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- R2: Zero amount — block -->
      <rule id="Rule_zero_amount">
        <description>Zero amount billing — block</description>
        <inputEntry id="IE_za_1"><text>&gt; 0</text></inputEntry>
        <inputEntry id="IE_za_2"><text>0</text></inputEntry>
        <outputEntry id="OE_za_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_za_acao"><text>"Zero amount billing"</text></outputEntry>
        <outputEntry id="OE_za_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- R3: Valid — proceed -->
      <rule id="Rule_valid">
        <description>Persistence validated — proceed</description>
        <inputEntry id="IE_v_1"><text>&gt; 0</text></inputEntry>
        <inputEntry id="IE_v_2"><text>&gt; 0</text></inputEntry>
        <outputEntry id="OE_v_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_v_acao"><text>"Persistence validated"</text></outputEntry>
        <outputEntry id="OE_v_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      
      <rule id="Rule_HighRisk">
        <description>Risco alto detectado - revisao obrigatoria</description>
        <inputEntry id="IE_HighRisk_1"><text>-</text></inputEntry>
        <inputEntry id="IE_HighRisk_2"><text>-</text></inputEntry>
        <outputEntry id="OE_HighRisk_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_HighRisk_acao"><text>"Situacao de risco alto identificada - avaliacao detalhada necessaria"</text></outputEntry>
        <outputEntry id="OE_HighRisk_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_fallback">
        <description>Caso nao enquadrado — revisao obrigatoria</description>
        <inputEntry id="IE_fb_1"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao"><text>"Caso requer avaliacao manual"</text></outputEntry>
        <outputEntry id="OE_fb_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_PersistValidAdj">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
