<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_ERPSystemRouting"
             name="ERP System Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: erp_system_routing_worker.py -->

  <!-- Source: capture_procedure_worker.py
       Rules extracted from _TASY_TENANTS and _MV_SOUL_TENANTS routing.
  -->

  <decision id="Decision_ERPRouting" name="ERP System Routing">
    <decisionTable id="DecisionTable_ERPRouting" hitPolicy="FIRST">

      <input id="Input_tenantCode" label="Tenant Code">
        <inputExpression id="InputExpr_tenantCode" typeRef="string">
          <text>tenantCode</text>
        </inputExpression>
      </input>

      <output id="Output_destino" label="Destino" name="destino" typeRef="string"/>

      <output id="Output_prioridade" label="Prioridade" name="prioridade" typeRef="number"/>

      <output id="Output_restricao" label="Restricao" name="restricao" typeRef="string"/>

      <!-- R1: HOSPITAL_A → tasy -->
      <rule id="Rule_tasy">
        <description>HOSPITAL_A routes to TASY ERP</description>
        <inputEntry id="IE_t_1"><text>"HOSPITAL_A"</text></inputEntry>
        <outputEntry id="OE_t_dest"><text>"tasy"</text></outputEntry>
        <outputEntry id="OE_t_prio"><text>1</text></outputEntry>
        <outputEntry id="OE_t_restr"><text>"none"</text></outputEntry>
      </rule>

      <!-- R2: AMH units → mv_soul -->
      <rule id="Rule_mv_soul">
        <description>AMH units route to MV Soul ERP</description>
        <inputEntry id="IE_mv_1"><text>"AMH_SP","AMH_RJ","AMH_MG"</text></inputEntry>
        <outputEntry id="OE_mv_dest"><text>"mv_soul"</text></outputEntry>
        <outputEntry id="OE_mv_prio"><text>1</text></outputEntry>
        <outputEntry id="OE_mv_restr"><text>"none"</text></outputEntry>
      </rule>

      <!-- R3: HOSPITAL_B → tasy -->
      <rule id="Rule_tasy_b">
        <description>HOSPITAL_B routes to TASY ERP</description>
        <inputEntry id="IE_tb_1"><text>"HOSPITAL_B"</text></inputEntry>
        <outputEntry id="OE_tb_dest"><text>"tasy"</text></outputEntry>
        <outputEntry id="OE_tb_prio"><text>1</text></outputEntry>
        <outputEntry id="OE_tb_restr"><text>"none"</text></outputEntry>
      </rule>

      <!-- R4: Legacy tenants → legacy_erp with migration notice -->
      <rule id="Rule_legacy">
        <description>Legacy tenants route to legacy ERP with migration flag</description>
        <inputEntry id="IE_lg_1"><text>"LEGACY_01","LEGACY_02"</text></inputEntry>
        <outputEntry id="OE_lg_dest"><text>"legacy_erp"</text></outputEntry>
        <outputEntry id="OE_lg_prio"><text>2</text></outputEntry>
        <outputEntry id="OE_lg_restr"><text>"Migration pending to TASY"</text></outputEntry>
      </rule>

      <!-- R5: Unknown tenant — blocked -->
      <rule id="Rule_unknown">
        <description>Unknown tenant code — blocked</description>
        <inputEntry id="IE_uk_1"><text>-</text></inputEntry>
        <outputEntry id="OE_uk_dest"><text>"blocked"</text></outputEntry>
        <outputEntry id="OE_uk_prio"><text>5</text></outputEntry>
        <outputEntry id="OE_uk_restr"><text>"Unknown tenant code"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_ERPRouting">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
