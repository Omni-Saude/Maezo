<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_RiskThresholds"
             name="Risk Score Thresholds Decision"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: risk_thresholds_worker.py -->

  <!-- DMN: Fraud Risk Score Threshold Decision
       Based on: detect_fraud_worker.py lines 62-68, 193-198
       Rule: Determine action based on overall fraud risk score
  -->

  <decision id="Decision_RiskThresholds" name="Risk Score Thresholds">
    <decisionTable id="DecisionTable_RiskThresholds" hitPolicy="FIRST">

      <!-- === INPUTS === -->
      <input id="Input_riskScore" label="Risk Score">
        <inputExpression id="InputExpr_riskScore" typeRef="number">
          <text>risk_score</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Risk score >= 80 - flag for investigation -->
      <rule id="Rule_RiskCritical">
        <description>Pontuacao de risco critica: &gt;= 80</description>
        <inputEntry id="IE_Critical_1"><text>&gt;= 80</text></inputEntry>
        <outputEntry id="OE_Critical_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_Critical_acao"><text>"Fraude detectada: pontuacao de risco critica (&gt;= 80)"</text></outputEntry>
        <outputEntry id="OE_Critical_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Risk score >= 50 - review required -->
      <rule id="Rule_RiskHigh">
        <description>Pontuacao de risco alta: &gt;= 50</description>
        <inputEntry id="IE_High_1"><text>&gt;= 50</text></inputEntry>
        <outputEntry id="OE_High_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_High_acao"><text>"Risco de fraude alto: revisao obrigatoria (&gt;= 50)"</text></outputEntry>
        <outputEntry id="OE_High_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Risk score >= 30 - monitor -->
      <rule id="Rule_RiskMedium">
        <description>Pontuacao de risco media: &gt;= 30</description>
        <inputEntry id="IE_Medium_1"><text>&gt;= 30</text></inputEntry>
        <outputEntry id="OE_Medium_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_Medium_acao"><text>"Risco de fraude medio: monitoramento recomendado (&gt;= 30)"</text></outputEntry>
        <outputEntry id="OE_Medium_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Risk score < 30 - clear -->
      <rule id="Rule_RiskLow">
        <description>Pontuacao de risco baixa: &lt; 30</description>
        <inputEntry id="IE_Low_1"><text>&lt; 30</text></inputEntry>
        <outputEntry id="OE_Low_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Low_acao"><text>"Risco de fraude baixo: prosseguir"</text></outputEntry>
        <outputEntry id="OE_Low_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Fallback: Unknown risk score - review -->
      <rule id="Rule_Fallback">
        <description>Pontuacao de risco desconhecida - revisao obrigatoria</description>
        <inputEntry id="IE_fb_1"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao"><text>"Pontuacao de risco requer avaliacao manual"</text></outputEntry>
        <outputEntry id="OE_fb_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RiskThresholds">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_RiskThresholds">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
