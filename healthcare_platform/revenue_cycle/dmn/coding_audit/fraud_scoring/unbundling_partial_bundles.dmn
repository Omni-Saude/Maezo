<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_UnbundlingPartialBundles"
             name="Unbundling Partial Bundles Decision"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: unbundling_partial_bundles_worker.py -->

  <!-- DMN: Unbundling Partial Bundles Detection
       Based on: detect_fraud_worker.py lines 324-351
       Rule: Detect when bundle group codes are partially present (unbundling fraud)
  -->

  <decision id="Decision_UnbundlingPartialBundles" name="Unbundling Partial Bundles">
    <decisionTable id="DecisionTable_UnbundlingPartialBundles" hitPolicy="FIRST">

      <!-- === INPUTS === -->
      <input id="Input_tussCodesPresent" label="TUSS Codes Present">
        <inputExpression id="InputExpr_tussCodesPresent" typeRef="string">
          <text>tuss_codes</text>
        </inputExpression>
      </input>

      <input id="Input_bundleGroupId" label="Bundle Group ID">
        <inputExpression id="InputExpr_bundleGroupId" typeRef="string">
          <text>bundle_group_id</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Partial bundle detected - unbundling fraud -->
      <rule id="Rule_PartialBundle">
        <description>Possivel desagrupamento: codigos parciais de pacote identificados</description>
        <inputEntry id="IE_Partial_1"><text>-</text></inputEntry>
        <inputEntry id="IE_Partial_2"><text>"partial"</text></inputEntry>
        <outputEntry id="OE_Partial_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_Partial_acao"><text>"Possivel desagrupamento: codigos parciais de pacote identificados"</text></outputEntry>
        <outputEntry id="OE_Partial_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Complete bundle - proceed -->
      <rule id="Rule_CompleteBundle">
        <description>Pacote completo identificado</description>
        <inputEntry id="IE_Complete_1"><text>-</text></inputEntry>
        <inputEntry id="IE_Complete_2"><text>"complete"</text></inputEntry>
        <outputEntry id="OE_Complete_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Complete_acao"><text>"Pacote completo identificado"</text></outputEntry>
        <outputEntry id="OE_Complete_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 3: No bundle codes - proceed -->
      <rule id="Rule_NoBundle">
        <description>Nenhum codigo de pacote presente</description>
        <inputEntry id="IE_NoBundle_1"><text>-</text></inputEntry>
        <inputEntry id="IE_NoBundle_2"><text>"none"</text></inputEntry>
        <outputEntry id="OE_NoBundle_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_NoBundle_acao"><text>"Nenhum codigo de pacote presente"</text></outputEntry>
        <outputEntry id="OE_NoBundle_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Fallback: Unknown bundle status - review -->
      
      <rule id="Rule_HighRisk">
        <description>Risco alto detectado - revisao obrigatoria</description>
        <inputEntry id="IE_HighRisk_1"><text>-</text></inputEntry>
        <inputEntry id="IE_HighRisk_2"><text>-</text></inputEntry>
        <outputEntry id="OE_HighRisk_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_HighRisk_acao"><text>"Situacao de risco alto identificada - avaliacao detalhada necessaria"</text></outputEntry>
        <outputEntry id="OE_HighRisk_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Status de pacote desconhecido - revisao obrigatoria</description>
        <inputEntry id="IE_fb_1"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao"><text>"Status de pacote requer avaliacao manual"</text></outputEntry>
        <outputEntry id="OE_fb_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_UnbundlingPartialBundles">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_UnbundlingPartialBundles">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
