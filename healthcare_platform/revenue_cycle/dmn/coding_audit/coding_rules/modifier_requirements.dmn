<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_ModifierRequirements"
             name="Modifier Requirements Decision"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: modifier_requirements_worker.py -->

  <!-- DMN: Modifier Requirements
       Based on: apply_coding_rules_worker.py lines 118-123, 219-232
       Rule: TUSS codes requiring modifiers
  -->

  <decision id="Decision_ModifierRequirements" name="Modifier Requirements">
    <decisionTable id="DecisionTable_ModifierRequirements" hitPolicy="FIRST">

      <!-- === INPUTS === -->
      <input id="Input_tussCode" label="TUSS Code">
        <inputExpression id="InputExpr_tussCode" typeRef="string">
          <text>tuss_code</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Code 30101012: requires modifier -51 -->
      <rule id="Rule_Modifier_30101012">
        <description>Codigo 30101012 requer modificador -51</description>
        <inputEntry id="IE_M1_1"><text>"30101012"</text></inputEntry>
        <outputEntry id="OE_M1_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_M1_acao"><text>"Modificador -51 (multiplos procedimentos) obrigatorio"</text></outputEntry>
        <outputEntry id="OE_M1_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Code 40201010: requires modifier -59 -->
      <rule id="Rule_Modifier_40201010">
        <description>Codigo 40201010 requer modificador -59</description>
        <inputEntry id="IE_M2_1"><text>"40201010"</text></inputEntry>
        <outputEntry id="OE_M2_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_M2_acao"><text>"Modificador -59 (procedimento distinto) obrigatorio"</text></outputEntry>
        <outputEntry id="OE_M2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Code 40301010: requires modifier -26 -->
      <rule id="Rule_Modifier_40301010">
        <description>Codigo 40301010 requer modificador -26</description>
        <inputEntry id="IE_M3_1"><text>"40301010"</text></inputEntry>
        <outputEntry id="OE_M3_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_M3_acao"><text>"Modificador -26 (componente profissional) obrigatorio"</text></outputEntry>
        <outputEntry id="OE_M3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- No modifier required -->
      
      <rule id="Rule_HighRisk">
        <description>Risco alto detectado - revisao obrigatoria</description>
        <inputEntry id="IE_HighRisk_1"><text>-</text></inputEntry>
        <outputEntry id="OE_HighRisk_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_HighRisk_acao"><text>"Situacao de risco alto identificada - avaliacao detalhada necessaria"</text></outputEntry>
        <outputEntry id="OE_HighRisk_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_No_Modifier">
        <description>Nenhum modificador obrigatorio</description>
        <inputEntry id="IE_NM_1"><text>-</text></inputEntry>
        <outputEntry id="OE_NM_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_NM_acao"><text>"Nenhum modificador obrigatorio para este codigo"</text></outputEntry>
        <outputEntry id="OE_NM_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ModifierRequirements">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_ModifierRequirements">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
