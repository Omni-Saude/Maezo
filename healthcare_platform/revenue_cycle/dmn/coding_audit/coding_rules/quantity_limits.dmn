<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_QuantityLimits"
             name="Quantity Limits Decision"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: quantity_limits_worker.py -->

  <!-- DMN: Quantity Limits per Encounter Class
       Based on: apply_coding_rules_worker.py lines 126-131, 160-186
       Rule: Limit TUSS code quantity based on encounter class
  -->

  <decision id="Decision_QuantityLimits" name="Quantity Limits">
    <decisionTable id="DecisionTable_QuantityLimits" hitPolicy="FIRST">

      <!-- === INPUTS === -->
      <input id="Input_encounterClass" label="Encounter Class">
        <inputExpression id="InputExpr_encounterClass" typeRef="string">
          <text>encounter_class</text>
        </inputExpression>
      </input>

      <input id="Input_tussCount" label="TUSS Code Count">
        <inputExpression id="InputExpr_tussCount" typeRef="number">
          <text>tuss_count</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Ambulatorial: limit 5 -->
      <rule id="Rule_Ambulatorial_Exceed">
        <description>Ambulatorial excedeu limite de 5 procedimentos</description>
        <inputEntry id="IE_Amb_Ex_1"><text>"ambulatorial"</text></inputEntry>
        <inputEntry id="IE_Amb_Ex_2"><text>&gt; 5</text></inputEntry>
        <outputEntry id="OE_Amb_Ex_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_Amb_Ex_acao"><text>"Quantidade excede limite de 5 para ambulatorial"</text></outputEntry>
        <outputEntry id="OE_Amb_Ex_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Internacao: limit 20 -->
      <rule id="Rule_Internacao_Exceed">
        <description>Internacao excedeu limite de 20 procedimentos</description>
        <inputEntry id="IE_Int_Ex_1"><text>"internacao"</text></inputEntry>
        <inputEntry id="IE_Int_Ex_2"><text>&gt; 20</text></inputEntry>
        <outputEntry id="OE_Int_Ex_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_Int_Ex_acao"><text>"Quantidade excede limite de 20 para internacao"</text></outputEntry>
        <outputEntry id="OE_Int_Ex_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Pronto Socorro: limit 10 -->
      <rule id="Rule_ProntoSocorro_Exceed">
        <description>Pronto Socorro excedeu limite de 10 procedimentos</description>
        <inputEntry id="IE_PS_Ex_1"><text>"pronto_socorro"</text></inputEntry>
        <inputEntry id="IE_PS_Ex_2"><text>&gt; 10</text></inputEntry>
        <outputEntry id="OE_PS_Ex_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_PS_Ex_acao"><text>"Quantidade excede limite de 10 para pronto_socorro"</text></outputEntry>
        <outputEntry id="OE_PS_Ex_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Proceed: within limits -->
      
      <rule id="Rule_HighRisk">
        <description>Risco alto detectado - revisao obrigatoria</description>
        <inputEntry id="IE_HighRisk_1"><text>-</text></inputEntry>
        <inputEntry id="IE_HighRisk_2"><text>-</text></inputEntry>
        <outputEntry id="OE_HighRisk_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_HighRisk_acao"><text>"Situacao de risco alto identificada - avaliacao detalhada necessaria"</text></outputEntry>
        <outputEntry id="OE_HighRisk_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Within_Limits">
        <description>Quantidade dentro do limite permitido</description>
        <inputEntry id="IE_OK_1"><text>-</text></inputEntry>
        <inputEntry id="IE_OK_2"><text>-</text></inputEntry>
        <outputEntry id="OE_OK_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_OK_acao"><text>"Quantidade de procedimentos dentro do limite"</text></outputEntry>
        <outputEntry id="OE_OK_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_QuantityLimits">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_QuantityLimits">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
