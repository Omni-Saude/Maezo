<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_SpecialtyRestrictions"
             name="Specialty Restrictions Decision"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: specialty_restrictions_worker.py -->

  <!-- DMN: Specialty Restrictions
       Based on: apply_coding_rules_worker.py lines 138-140, 234-250
       Rule: Surgical prefixes (40, 41, 42) not allowed in ambulatorial without authorization
  -->

  <decision id="Decision_SpecialtyRestrictions" name="Specialty Restrictions">
    <decisionTable id="DecisionTable_SpecialtyRestrictions" hitPolicy="FIRST">

      <!-- === INPUTS === -->
      <input id="Input_encounterClass" label="Encounter Class">
        <inputExpression id="InputExpr_encounterClass" typeRef="string">
          <text>encounter_class</text>
        </inputExpression>
      </input>

      <input id="Input_tussPrefix" label="TUSS Prefix">
        <inputExpression id="InputExpr_tussPrefix" typeRef="string">
          <text>tuss_prefix</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Surgical code in ambulatorial: block -->
      <rule id="Rule_Surgical_Ambulatorial_40">
        <description>Procedimento cirurgico (40) nao permitido em ambulatorial</description>
        <inputEntry id="IE_SA40_1"><text>"ambulatorial"</text></inputEntry>
        <inputEntry id="IE_SA40_2"><text>"40"</text></inputEntry>
        <outputEntry id="OE_SA40_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_SA40_acao"><text>"Procedimento cirurgico nao permitido em ambulatorial sem autorizacao previa"</text></outputEntry>
        <outputEntry id="OE_SA40_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Surgical_Ambulatorial_41">
        <description>Procedimento cirurgico (41) nao permitido em ambulatorial</description>
        <inputEntry id="IE_SA41_1"><text>"ambulatorial"</text></inputEntry>
        <inputEntry id="IE_SA41_2"><text>"41"</text></inputEntry>
        <outputEntry id="OE_SA41_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_SA41_acao"><text>"Procedimento cirurgico nao permitido em ambulatorial sem autorizacao previa"</text></outputEntry>
        <outputEntry id="OE_SA41_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Surgical_Ambulatorial_42">
        <description>Procedimento cirurgico (42) nao permitido em ambulatorial</description>
        <inputEntry id="IE_SA42_1"><text>"ambulatorial"</text></inputEntry>
        <inputEntry id="IE_SA42_2"><text>"42"</text></inputEntry>
        <outputEntry id="OE_SA42_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_SA42_acao"><text>"Procedimento cirurgico nao permitido em ambulatorial sem autorizacao previa"</text></outputEntry>
        <outputEntry id="OE_SA42_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- No restriction -->
      
      <rule id="Rule_HighRisk">
        <description>Risco alto detectado - revisao obrigatoria</description>
        <inputEntry id="IE_HighRisk_1"><text>-</text></inputEntry>
        <inputEntry id="IE_HighRisk_2"><text>-</text></inputEntry>
        <outputEntry id="OE_HighRisk_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_HighRisk_acao"><text>"Situacao de risco alto identificada - avaliacao detalhada necessaria"</text></outputEntry>
        <outputEntry id="OE_HighRisk_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_No_Restriction">
        <description>Sem restricao de especialidade</description>
        <inputEntry id="IE_NR_1"><text>-</text></inputEntry>
        <inputEntry id="IE_NR_2"><text>-</text></inputEntry>
        <outputEntry id="OE_NR_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_NR_acao"><text>"Procedimento permitido para a classe de atendimento"</text></outputEntry>
        <outputEntry id="OE_NR_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_SpecialtyRestrictions">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_SpecialtyRestrictions">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
