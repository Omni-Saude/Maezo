<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_PrimaryDiagnosisPriority"
             name="Primary Diagnosis Priority Decision"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: primary_diagnosis_priority_worker.py -->

  <!-- DMN: Primary Diagnosis Priority Determination
       Based on: extract_clinical_data_worker.py lines 354-389
       Rule: Determine diagnosis priority based on rank, use code, and clinical status
  -->

  <decision id="Decision_PrimaryDiagnosisPriority" name="Primary Diagnosis Priority">
    <decisionTable id="DecisionTable_PrimaryDiagnosisPriority" hitPolicy="FIRST">

      <!-- === INPUTS === -->
      <input id="Input_rank" label="Diagnosis Rank">
        <inputExpression id="InputExpr_rank" typeRef="number">
          <text>rank</text>
        </inputExpression>
      </input>

      <input id="Input_useCode" label="Use Code">
        <inputExpression id="InputExpr_useCode" typeRef="string">
          <text>use_code</text>
        </inputExpression>
      </input>

      <input id="Input_clinicalStatus" label="Clinical Status">
        <inputExpression id="InputExpr_clinicalStatus" typeRef="string">
          <text>clinical_status</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Rank = 1 - highest priority -->
      <rule id="Rule_Rank1">
        <description>Diagnostico com rank 1 - prioridade maxima</description>
        <inputEntry id="IE_Rank1_1"><text>1</text></inputEntry>
        <inputEntry id="IE_Rank1_2"><text>-</text></inputEntry>
        <inputEntry id="IE_Rank1_3"><text>-</text></inputEntry>
        <outputEntry id="OE_Rank1_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Rank1_acao"><text>"priority_1"</text></outputEntry>
        <outputEntry id="OE_Rank1_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Use code = AD (Admitting Diagnosis) - highest priority -->
      <rule id="Rule_AdmittingDiagnosis">
        <description>Diagnostico de admissao (AD) - prioridade maxima</description>
        <inputEntry id="IE_AD_1"><text>-</text></inputEntry>
        <inputEntry id="IE_AD_2"><text>"AD"</text></inputEntry>
        <inputEntry id="IE_AD_3"><text>-</text></inputEntry>
        <outputEntry id="OE_AD_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_AD_acao"><text>"priority_1"</text></outputEntry>
        <outputEntry id="OE_AD_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Clinical status = active - high priority -->
      <rule id="Rule_ActiveStatus">
        <description>Status clinico ativo - alta prioridade</description>
        <inputEntry id="IE_Active_1"><text>-</text></inputEntry>
        <inputEntry id="IE_Active_2"><text>-</text></inputEntry>
        <inputEntry id="IE_Active_3"><text>"active"</text></inputEntry>
        <outputEntry id="OE_Active_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Active_acao"><text>"priority_2"</text></outputEntry>
        <outputEntry id="OE_Active_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Other conditions - lower priority -->
      
      <rule id="Rule_HighRisk">
        <description>Risco alto detectado - revisao obrigatoria</description>
        <inputEntry id="IE_HighRisk_1"><text>-</text></inputEntry>
        <inputEntry id="IE_HighRisk_2"><text>-</text></inputEntry>
        <inputEntry id="IE_HighRisk_3"><text>-</text></inputEntry>
        <outputEntry id="OE_HighRisk_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_HighRisk_acao"><text>"Situacao de risco alto identificada - avaliacao detalhada necessaria"</text></outputEntry>
        <outputEntry id="OE_HighRisk_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_OtherConditions">
        <description>Outras condicoes - prioridade baixa</description>
        <inputEntry id="IE_Other_1"><text>-</text></inputEntry>
        <inputEntry id="IE_Other_2"><text>-</text></inputEntry>
        <inputEntry id="IE_Other_3"><text>-</text></inputEntry>
        <outputEntry id="OE_Other_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Other_acao"><text>"priority_3"</text></outputEntry>
        <outputEntry id="OE_Other_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PrimaryDiagnosisPriority">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_PrimaryDiagnosisPriority">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
