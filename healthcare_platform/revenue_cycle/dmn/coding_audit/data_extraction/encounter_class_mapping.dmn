<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_EncounterClassMapping"
             name="Encounter Class Mapping Decision"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: encounter_class_mapping_worker.py -->

  <!-- DMN: Encounter Class Mapping
       Based on: extract_clinical_data_worker.py lines 197-210
       Rule: Map FHIR encounter class to Brazilian healthcare classification
  -->

  <decision id="Decision_EncounterClassMapping" name="Encounter Class Mapping">
    <decisionTable id="DecisionTable_EncounterClassMapping" hitPolicy="FIRST">

      <!-- === INPUTS === -->
      <input id="Input_fhirClassCode" label="FHIR Class Code">
        <inputExpression id="InputExpr_fhirClassCode" typeRef="string">
          <text>fhir_class_code</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: IMP - internacao -->
      <rule id="Rule_Internacao">
        <description>Mapeamento FHIR IMP para internacao</description>
        <inputEntry id="IE_Int_1"><text>"IMP"</text></inputEntry>
        <outputEntry id="OE_Int_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Int_acao"><text>"internacao"</text></outputEntry>
        <outputEntry id="OE_Int_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 2: AMB - ambulatorio -->
      <rule id="Rule_Ambulatorio">
        <description>Mapeamento FHIR AMB para ambulatorio</description>
        <inputEntry id="IE_Amb_1"><text>"AMB"</text></inputEntry>
        <outputEntry id="OE_Amb_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Amb_acao"><text>"ambulatorio"</text></outputEntry>
        <outputEntry id="OE_Amb_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 3: EMER - emergencia -->
      <rule id="Rule_Emergencia">
        <description>Mapeamento FHIR EMER para emergencia</description>
        <inputEntry id="IE_Emer_1"><text>"EMER"</text></inputEntry>
        <outputEntry id="OE_Emer_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Emer_acao"><text>"emergencia"</text></outputEntry>
        <outputEntry id="OE_Emer_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 4: SS - ambulatorio (Short Stay) -->
      <rule id="Rule_ShortStay">
        <description>Mapeamento FHIR SS para ambulatorio</description>
        <inputEntry id="IE_SS_1"><text>"SS"</text></inputEntry>
        <outputEntry id="OE_SS_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_SS_acao"><text>"ambulatorio"</text></outputEntry>
        <outputEntry id="OE_SS_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 5: HH - domiciliar (Home Health) -->
      <rule id="Rule_Domiciliar">
        <description>Mapeamento FHIR HH para domiciliar</description>
        <inputEntry id="IE_HH_1"><text>"HH"</text></inputEntry>
        <outputEntry id="OE_HH_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_HH_acao"><text>"domiciliar"</text></outputEntry>
        <outputEntry id="OE_HH_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 6: OBSENC - internacao (Obstetric Encounter) -->
      <rule id="Rule_Obstetric">
        <description>Mapeamento FHIR OBSENC para internacao</description>
        <inputEntry id="IE_Obs_1"><text>"OBSENC"</text></inputEntry>
        <outputEntry id="OE_Obs_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Obs_acao"><text>"internacao"</text></outputEntry>
        <outputEntry id="OE_Obs_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Fallback: Unknown class - default to ambulatorio -->
      <rule id="Rule_Fallback">
        <description>Classe FHIR desconhecida - padrao ambulatorio</description>
        <inputEntry id="IE_fb_1"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_fb_acao"><text>"ambulatorio"</text></outputEntry>
        <outputEntry id="OE_fb_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_EncounterClassMapping">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_EncounterClassMapping">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
