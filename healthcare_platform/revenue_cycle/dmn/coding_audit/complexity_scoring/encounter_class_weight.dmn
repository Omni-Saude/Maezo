<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_EncounterClassWeight"
             name="Encounter Class Weight"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: encounter_class_weight_worker.py -->

  <!-- DMN: Encounter Class Weight
       Based on: calculate_complexity_worker.py lines 102-107, 289-294
       Rule: Base weights by encounter class
  -->

  <decision id="Decision_EncounterClassWeight" name="Encounter Class Weight">
    <decisionTable id="DecisionTable_EncounterClassWeight" hitPolicy="FIRST">

      <input id="Input_encounterClass" label="Encounter Class">
        <inputExpression id="InputExpr_encounterClass" typeRef="string">
          <text>encounter_class</text>
        </inputExpression>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_Ambulatorio">
        <description>Ambulatorio: peso 0.5</description>
        <inputEntry id="IE_Amb_1"><text>"ambulatorio"</text></inputEntry>
        <outputEntry id="OE_Amb_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Amb_acao"><text>"Classe ambulatorio: peso complexidade 0.5"</text></outputEntry>
        <outputEntry id="OE_Amb_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Internacao">
        <description>Internacao: peso 2.0</description>
        <inputEntry id="IE_Int_1"><text>"internacao"</text></inputEntry>
        <outputEntry id="OE_Int_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Int_acao"><text>"Classe internacao: peso complexidade 2.0"</text></outputEntry>
        <outputEntry id="OE_Int_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Urgencia">
        <description>Urgencia: peso 1.5</description>
        <inputEntry id="IE_Urg_1"><text>"urgencia"</text></inputEntry>
        <outputEntry id="OE_Urg_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Urg_acao"><text>"Classe urgencia: peso complexidade 1.5"</text></outputEntry>
        <outputEntry id="OE_Urg_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_DayClinic">
        <description>Day Clinic: peso 1.0</description>
        <inputEntry id="IE_Day_1"><text>"day_clinic"</text></inputEntry>
        <outputEntry id="OE_Day_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Day_acao"><text>"Classe day_clinic: peso complexidade 1.0"</text></outputEntry>
        <outputEntry id="OE_Day_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Caso nao enquadrado</description>
        <inputEntry id="IE_FB_1"><text>-</text></inputEntry>
        <outputEntry id="OE_FB_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_FB_acao"><text>"Classe de atendimento nao reconhecida"</text></outputEntry>
        <outputEntry id="OE_FB_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_EncounterClassWeight">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_EncounterClassWeight">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
