<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_AgeFactors"
             name="Age Factors Scoring"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: age_factors_worker.py -->

  <!-- DMN: Age Factors
       Based on: calculate_complexity_worker.py lines 110-118, 339-345
       Rule: Age-based complexity multipliers
  -->

  <decision id="Decision_AgeFactors" name="Age Factors">
    <decisionTable id="DecisionTable_AgeFactors" hitPolicy="FIRST">

      <input id="Input_patientAge" label="Patient Age">
        <inputExpression id="InputExpr_patientAge" typeRef="number">
          <text>patient_age</text>
        </inputExpression>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_Age_Neonates">
        <description>Neonatos: fator 1.5</description>
        <inputEntry id="IE_Neo_1"><text>&lt;= 1</text></inputEntry>
        <outputEntry id="OE_Neo_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Neo_acao"><text>"Fator idade neonato: complexidade aumentada 1.5x"</text></outputEntry>
        <outputEntry id="OE_Neo_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Age_Infants">
        <description>Lactentes: fator 1.2</description>
        <inputEntry id="IE_Inf_1"><text>[2..5]</text></inputEntry>
        <outputEntry id="OE_Inf_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Inf_acao"><text>"Fator idade lactente: complexidade aumentada 1.2x"</text></outputEntry>
        <outputEntry id="OE_Inf_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Age_Children">
        <description>Criancas: fator 0.8</description>
        <inputEntry id="IE_Child_1"><text>[6..18]</text></inputEntry>
        <outputEntry id="OE_Child_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Child_acao"><text>"Fator idade crianca: complexidade 0.8x"</text></outputEntry>
        <outputEntry id="OE_Child_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Age_Adults">
        <description>Adultos: fator 1.0</description>
        <inputEntry id="IE_Adult_1"><text>[19..64]</text></inputEntry>
        <outputEntry id="OE_Adult_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Adult_acao"><text>"Fator idade adulto: complexidade 1.0x"</text></outputEntry>
        <outputEntry id="OE_Adult_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Age_Older">
        <description>Idosos: fator 1.3</description>
        <inputEntry id="IE_Older_1"><text>[65..79]</text></inputEntry>
        <outputEntry id="OE_Older_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Older_acao"><text>"Fator idade idoso: complexidade aumentada 1.3x"</text></outputEntry>
        <outputEntry id="OE_Older_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Age_VeryOld">
        <description>Muito idosos: fator 1.6-2.0</description>
        <inputEntry id="IE_VOld_1"><text>&gt;= 80</text></inputEntry>
        <outputEntry id="OE_VOld_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_VOld_acao"><text>"Fator idade muito idoso: complexidade aumentada 1.6-2.0x"</text></outputEntry>
        <outputEntry id="OE_VOld_risco"><text>"ALTO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AgeFactors">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_AgeFactors">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
