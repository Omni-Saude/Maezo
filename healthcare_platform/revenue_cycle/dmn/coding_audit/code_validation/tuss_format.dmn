<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_TUSS_FormatValidation_Strict"
             name="TUSS Format Validation (Strict) Decision"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: tuss_format_worker.py -->

  <!-- DMN: TUSS Format Validation (Strict)
       Based on: validate_codes_worker.py lines 32, 309-337
       Rule: Validate TUSS code format with strict error handling
  -->

  <decision id="Decision_TUSS_FormatValidation_Strict" name="TUSS Format Validation (Strict)">
    <decisionTable id="DecisionTable_TUSS_FormatValidation_Strict" hitPolicy="FIRST">

      <!-- === INPUTS === -->
      <input id="Input_code" label="Code">
        <inputExpression id="InputExpr_code" typeRef="string">
          <text>code</text>
        </inputExpression>
      </input>

      <input id="Input_codeLength" label="Code Length">
        <inputExpression id="InputExpr_codeLength" typeRef="number">
          <text>code_length</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Empty code → BLOCK HIGH -->
      <rule id="Rule_Empty_Code">
        <description>Codigo TUSS vazio ou nulo</description>
        <inputEntry id="IE_Empty_1"><text>"EMPTY"</text></inputEntry>
        <inputEntry id="IE_Empty_2"><text>0</text></inputEntry>
        <outputEntry id="OE_Empty_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_Empty_acao"><text>"Codigo TUSS obrigatorio esta vazio ou nulo"</text></outputEntry>
        <outputEntry id="OE_Empty_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Invalid format → BLOCK MEDIUM -->
      <rule id="Rule_Invalid_Format">
        <description>Formato TUSS invalido</description>
        <inputEntry id="IE_Invalid_1"><text>"INVALID"</text></inputEntry>
        <inputEntry id="IE_Invalid_2"><text>-</text></inputEntry>
        <outputEntry id="OE_Invalid_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_Invalid_acao"><text>"Formato TUSS invalido - esperado: codigo numerico de 8 digitos (ex: 40101010, 31003036)"</text></outputEntry>
        <outputEntry id="OE_Invalid_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Valid format → PROCEED LOW -->
      <rule id="Rule_Valid_Format">
        <description>Formato TUSS valido: 8 digitos</description>
        <inputEntry id="IE_Valid_1"><text>"VALID_TUSS"</text></inputEntry>
        <inputEntry id="IE_Valid_2"><text>8</text></inputEntry>
        <outputEntry id="OE_Valid_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Valid_acao"><text>"Codigo TUSS com formato valido aprovado (8 digitos)"</text></outputEntry>
        <outputEntry id="OE_Valid_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      
      <rule id="Rule_HighRisk">
        <description>Risco alto detectado - revisao obrigatoria</description>
        <inputEntry id="IE_HighRisk_1"><text>-</text></inputEntry>
        <inputEntry id="IE_HighRisk_2"><text>-</text></inputEntry>
        <outputEntry id="OE_HighRisk_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_HighRisk_acao"><text>"Situacao de risco alto identificada - avaliacao detalhada necessaria"</text></outputEntry>
        <outputEntry id="OE_HighRisk_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Caso nao enquadrado</description>
        <inputEntry id="IE_FB_1"><text>-</text></inputEntry>
        <inputEntry id="IE_FB_2"><text>-</text></inputEntry>
        <outputEntry id="OE_FB_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_FB_acao"><text>"Codigo TUSS requer validacao manual"</text></outputEntry>
        <outputEntry id="OE_FB_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_TUSS_FormatValidation_Strict">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_TUSS_FormatValidation_Strict">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
