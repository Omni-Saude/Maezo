<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_UnbundlingDetection"
             name="Unbundling Detection Decision"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: unbundling_detection_worker.py -->

  <!-- DMN: Unbundling Detection
       Based on: audit_coding_worker.py lines 124-129, 247-275
       Rule: Detect suspect unbundling pairs
  -->

  <decision id="Decision_UnbundlingDetection" name="Unbundling Detection">
    <decisionTable id="DecisionTable_UnbundlingDetection" hitPolicy="FIRST">

      <!-- === INPUTS === -->
      <input id="Input_tussCode1" label="TUSS Code 1">
        <inputExpression id="InputExpr_tussCode1" typeRef="string">
          <text>tuss_code_1</text>
        </inputExpression>
      </input>

      <input id="Input_tussCode2" label="TUSS Code 2">
        <inputExpression id="InputExpr_tussCode2" typeRef="string">
          <text>tuss_code_2</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Unbundling pair 1: 30101012 + 30101020 -->
      <rule id="Rule_Unbundle_Pair1">
        <description>Possivel unbundling: 30101012 + 30101020</description>
        <inputEntry id="IE_UB1_1"><text>"30101012","30101020"</text></inputEntry>
        <inputEntry id="IE_UB1_2"><text>"30101012","30101020"</text></inputEntry>
        <outputEntry id="OE_UB1_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_UB1_acao"><text>"Possivel unbundling: procedimentos 30101012 e 30101020 geralmente cobrados como procedimento unico"</text></outputEntry>
        <outputEntry id="OE_UB1_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Unbundling pair 2: 40201010 + 40201028 -->
      <rule id="Rule_Unbundle_Pair2">
        <description>Possivel unbundling: 40201010 + 40201028</description>
        <inputEntry id="IE_UB2_1"><text>"40201010","40201028"</text></inputEntry>
        <inputEntry id="IE_UB2_2"><text>"40201010","40201028"</text></inputEntry>
        <outputEntry id="OE_UB2_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_UB2_acao"><text>"Possivel unbundling: procedimentos 40201010 e 40201028 geralmente cobrados como procedimento unico"</text></outputEntry>
        <outputEntry id="OE_UB2_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Unbundling pair 3: 20101012 + 20101020 -->
      <rule id="Rule_Unbundle_Pair3">
        <description>Possivel unbundling: 20101012 + 20101020</description>
        <inputEntry id="IE_UB3_1"><text>"20101012","20101020"</text></inputEntry>
        <inputEntry id="IE_UB3_2"><text>"20101012","20101020"</text></inputEntry>
        <outputEntry id="OE_UB3_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_UB3_acao"><text>"Possivel unbundling: procedimentos 20101012 e 20101020 geralmente cobrados como procedimento unico"</text></outputEntry>
        <outputEntry id="OE_UB3_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- No unbundling -->
      
      <rule id="Rule_HighRisk">
        <description>Risco alto detectado - revisao obrigatoria</description>
        <inputEntry id="IE_HighRisk_1"><text>-</text></inputEntry>
        <inputEntry id="IE_HighRisk_2"><text>-</text></inputEntry>
        <outputEntry id="OE_HighRisk_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_HighRisk_acao"><text>"Situacao de risco alto identificada - avaliacao detalhada necessaria"</text></outputEntry>
        <outputEntry id="OE_HighRisk_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_No_Unbundling">
        <description>Nenhum unbundling suspeito detectado</description>
        <inputEntry id="IE_NoUB_1"><text>-</text></inputEntry>
        <inputEntry id="IE_NoUB_2"><text>-</text></inputEntry>
        <outputEntry id="OE_NoUB_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_NoUB_acao"><text>"Nenhum unbundling suspeito detectado"</text></outputEntry>
        <outputEntry id="OE_NoUB_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_UnbundlingDetection">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_UnbundlingDetection">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
