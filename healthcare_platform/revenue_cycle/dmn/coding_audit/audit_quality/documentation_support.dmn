<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_DocumentationSupport"
             name="Documentation Support Decision"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: documentation_support_worker.py -->

  <!-- DMN: Documentation Support Check
       Based on: audit_coding_worker.py lines 202-231
       Rule: Documentation score must be >= 75% to support codes
  -->

  <decision id="Decision_DocumentationSupport" name="Documentation Support">
    <decisionTable id="DecisionTable_DocumentationSupport" hitPolicy="FIRST">

      <!-- === INPUTS === -->
      <input id="Input_docScore" label="Documentation Score %">
        <inputExpression id="InputExpr_docScore" typeRef="number">
          <text>doc_score_pct</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Insufficient documentation: < 75% -->
      <rule id="Rule_Insufficient_Doc">
        <description>Documentacao clinica insuficiente</description>
        <inputEntry id="IE_InsuffDoc_1"><text>&lt; 75</text></inputEntry>
        <outputEntry id="OE_InsuffDoc_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_InsuffDoc_acao"><text>"Documentacao clinica insuficiente para suportar os codigos informados"</text></outputEntry>
        <outputEntry id="OE_InsuffDoc_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Adequate documentation: >= 75% -->
      <rule id="Rule_Adequate_Doc">
        <description>Documentacao clinica adequada</description>
        <inputEntry id="IE_AdeqDoc_1"><text>&gt;= 75</text></inputEntry>
        <outputEntry id="OE_AdeqDoc_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_AdeqDoc_acao"><text>"Documentacao clinica adequada"</text></outputEntry>
        <outputEntry id="OE_AdeqDoc_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      
      <rule id="Rule_NoDoc">
        <description>Documentacao totalmente ausente</description>
        <inputEntry id="IE_NoDoc_1"><text>-</text></inputEntry>
        <inputEntry id="IE_NoDoc_2"><text>0</text></inputEntry>
        <outputEntry id="OE_NoDoc_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_NoDoc_acao"><text>"Nenhuma documentacao de suporte encontrada - codificacao nao sustentavel"</text></outputEntry>
        <outputEntry id="OE_NoDoc_risco"><text>"CRITICO"</text></outputEntry>
      </rule>


      <rule id="Rule_MinimalDoc">
        <description>Documentacao minima presente</description>
        <inputEntry id="IE_MinimalDoc_1"><text>-</text></inputEntry>
        <inputEntry id="IE_MinimalDoc_2"><text>1</text></inputEntry>
        <outputEntry id="OE_MinimalDoc_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_MinimalDoc_acao"><text>"Apenas documentacao minima - reforcar evidencias clinicas"</text></outputEntry>
        <outputEntry id="OE_MinimalDoc_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Caso nao enquadrado - revisao obrigatoria</description>
        <inputEntry id="IE_FB_1"><text>-</text></inputEntry>
        <outputEntry id="OE_FB_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_FB_acao"><text>"Caso requer avaliacao manual"</text></outputEntry>
        <outputEntry id="OE_FB_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DocumentationSupport">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_DocumentationSupport">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
