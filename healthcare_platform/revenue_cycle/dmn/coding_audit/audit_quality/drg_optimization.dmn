<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_DRGOptimization"
             name="DRG Optimization Decision"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: drg_optimization_worker.py -->

  <!-- DMN: DRG Optimization Hints
       Based on: audit_coding_worker.py lines 131-145, 233-245
       Rule: Provide DRG optimization hints based on CID-10 chapter
  -->

  <decision id="Decision_DRGOptimization" name="DRG Optimization">
    <decisionTable id="DecisionTable_DRGOptimization" hitPolicy="FIRST">

      <!-- === INPUTS === -->
      <input id="Input_cid10Chapter" label="CID-10 Chapter">
        <inputExpression id="InputExpr_cid10Chapter" typeRef="string">
          <text>cid10_chapter</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Chapter I: Cardiovascular -->
      <rule id="Rule_DRG_Cardiovascular">
        <description>DRG optimization hint for cardiovascular</description>
        <inputEntry id="IE_DRG_I_1"><text>"I"</text></inputEntry>
        <outputEntry id="OE_DRG_I_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_DRG_I_acao"><text>"Diagnosticos cardiovasculares podem ser otimizados para DRG com codigo mais especifico (4o ou 5o digito)"</text></outputEntry>
        <outputEntry id="OE_DRG_I_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Chapter J: Respiratory -->
      <rule id="Rule_DRG_Respiratory">
        <description>DRG optimization hint for respiratory</description>
        <inputEntry id="IE_DRG_J_1"><text>"J"</text></inputEntry>
        <outputEntry id="OE_DRG_J_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_DRG_J_acao"><text>"Diagnosticos respiratorios: verificar se complicacoes estao documentadas para melhor classificacao DRG"</text></outputEntry>
        <outputEntry id="OE_DRG_J_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Chapter K: Digestive -->
      <rule id="Rule_DRG_Digestive">
        <description>DRG optimization hint for digestive</description>
        <inputEntry id="IE_DRG_K_1"><text>"K"</text></inputEntry>
        <outputEntry id="OE_DRG_K_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_DRG_K_acao"><text>"Diagnosticos digestivos: especificar localizacao anatomica para otimizacao DRG"</text></outputEntry>
        <outputEntry id="OE_DRG_K_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- No optimization hint -->
      
      <rule id="Rule_HighRisk">
        <description>Risco alto detectado - revisao obrigatoria</description>
        <inputEntry id="IE_HighRisk_1"><text>-</text></inputEntry>
        <outputEntry id="OE_HighRisk_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_HighRisk_acao"><text>"Situacao de risco alto identificada - avaliacao detalhada necessaria"</text></outputEntry>
        <outputEntry id="OE_HighRisk_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_No_DRG_Hint">
        <description>Sem hint de otimizacao DRG</description>
        <inputEntry id="IE_NoDRG_1"><text>-</text></inputEntry>
        <outputEntry id="OE_NoDRG_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_NoDRG_acao"><text>"Nenhuma acao adicional"</text></outputEntry>
        <outputEntry id="OE_NoDRG_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DRGOptimization">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_DRGOptimization">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
