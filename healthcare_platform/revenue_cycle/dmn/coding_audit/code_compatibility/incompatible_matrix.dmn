<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_IncompatibleMatrix"
             name="Incompatible Matrix"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: incompatible_matrix_worker.py -->

  <!-- DMN: CID-10/TUSS Incompatible Matrix
       Based on: check_code_compatibility_worker.py lines 109-118
       Rule: Deny-list of incompatible CID-10 chapters with TUSS prefixes
  -->

  <decision id="Decision_IncompatibleMatrix" name="Incompatible Matrix">
    <decisionTable id="DecisionTable_IncompatibleMatrix" hitPolicy="FIRST">

      <input id="Input_cid10Chapter" label="CID-10 Chapter">
        <inputExpression id="InputExpr_cid10Chapter" typeRef="string">
          <text>cid10_chapter</text>
        </inputExpression>
      </input>

      <input id="Input_tussPrefix" label="TUSS Prefix">
        <inputExpression id="InputExpr_tussPrefix" typeRef="string">
          <text>tuss_prefix</text>
        </inputExpression>
      </input>

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_F_40_41">
        <description>Cap F incompativel com proc cirurgicos cardiacos</description>
        <inputEntry id="IE_F40_1"><text>"F"</text></inputEntry>
        <inputEntry id="IE_F40_2"><text>"40","41"</text></inputEntry>
        <outputEntry id="OE_F40_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_F40_acao"><text>"CID-10 capitulo F incompativel com grupo TUSS 40/41 (cirurgico cardiaco)"</text></outputEntry>
        <outputEntry id="OE_F40_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_K_30_31">
        <description>Cap K incompativel com proc oftalmologicos</description>
        <inputEntry id="IE_K30_1"><text>"K"</text></inputEntry>
        <inputEntry id="IE_K30_2"><text>"30","31"</text></inputEntry>
        <outputEntry id="OE_K30_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_K30_acao"><text>"CID-10 capitulo K incompativel com grupo TUSS 30/31 (oftalmologico)"</text></outputEntry>
        <outputEntry id="OE_K30_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_H_40_41_42">
        <description>Cap H incompativel com proc ortopedicos</description>
        <inputEntry id="IE_H40_1"><text>"H"</text></inputEntry>
        <inputEntry id="IE_H40_2"><text>"40","41","42"</text></inputEntry>
        <outputEntry id="OE_H40_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_H40_acao"><text>"CID-10 capitulo H incompativel com grupo TUSS 40/41/42 (ortopedico)"</text></outputEntry>
        <outputEntry id="OE_H40_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_O_99">
        <description>Cap O incompativel com proc neonatais</description>
        <inputEntry id="IE_O99_1"><text>"O"</text></inputEntry>
        <inputEntry id="IE_O99_2"><text>"99"</text></inputEntry>
        <outputEntry id="OE_O99_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_O99_acao"><text>"CID-10 capitulo O incompativel com grupo TUSS 99 (neonatal)"</text></outputEntry>
        <outputEntry id="OE_O99_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_Compatible">
        <description>Codigos compativeis</description>
        <inputEntry id="IE_Compat_1"><text>-</text></inputEntry>
        <inputEntry id="IE_Compat_2"><text>-</text></inputEntry>
        <outputEntry id="OE_Compat_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Compat_acao"><text>"CID-10 compativel com procedimento TUSS"</text></outputEntry>
        <outputEntry id="OE_Compat_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_IncompatibleMatrix">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_IncompatibleMatrix">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
