<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/DMN/20151101/dmn.xsd"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_triage_priority_001"
             name="Emergency Triage Priority Assignment"
             namespace="http://healthcare.platform/dmn/patient_access_rules">
  <decision id="triage_priority_001" name="Emergency Triage Priority Assignment">
    <decisionTable id="DecisionTable_triage_priority_001" hitPolicy="UNIQUE">
      <input id="input1" label="Priority Level">
        <inputExpression typeRef="integer">
          <text>priority_level</text>
        </inputExpression>
      </input>
      <output id="output1" label="Priority Name" name="priority_name" typeRef="string"/>
      <output id="output2" label="Color Code" name="color_code" typeRef="string"/>
      <output id="output3" label="Max Wait Time (minutes)" name="max_wait_time" typeRef="integer"/>
      <output id="output4" label="Clinical Criteria" name="clinical_criteria" typeRef="string"/>

      <!-- Priority 1: Emergência (Emergency) - Red -->
      <rule id="rule1">
        <inputEntry><text>1</text></inputEntry>
        <outputEntry><text>"Emergência"</text></outputEntry>
        <outputEntry><text>"red"</text></outputEntry>
        <outputEntry><text>0</text></outputEntry>
        <outputEntry><text>"Immediate life threat requiring resuscitation"</text></outputEntry>
      </rule>

      <!-- Priority 2: Muito Urgente (Very Urgent) - Orange -->
      <rule id="rule2">
        <inputEntry><text>2</text></inputEntry>
        <outputEntry><text>"Muito Urgente"</text></outputEntry>
        <outputEntry><text>"orange"</text></outputEntry>
        <outputEntry><text>10</text></outputEntry>
        <outputEntry><text>"Potentially life-threatening requiring immediate intervention"</text></outputEntry>
      </rule>

      <!-- Priority 3: Urgente (Urgent) - Yellow -->
      <rule id="rule3">
        <inputEntry><text>3</text></inputEntry>
        <outputEntry><text>"Urgente"</text></outputEntry>
        <outputEntry><text>"yellow"</text></outputEntry>
        <outputEntry><text>60</text></outputEntry>
        <outputEntry><text>"Serious condition requiring prompt medical attention"</text></outputEntry>
      </rule>

      <!-- Priority 4: Pouco Urgente (Less Urgent) - Green -->
      <rule id="rule4">
        <inputEntry><text>4</text></inputEntry>
        <outputEntry><text>"Pouco Urgente"</text></outputEntry>
        <outputEntry><text>"green"</text></outputEntry>
        <outputEntry><text>120</text></outputEntry>
        <outputEntry><text>"Non-urgent condition with minimal risk of deterioration"</text></outputEntry>
      </rule>

      <!-- Priority 5: Não Urgente (Non-Urgent) - Blue -->
      <rule id="rule5">
        <inputEntry><text>5</text></inputEntry>
        <outputEntry><text>"Não Urgente"</text></outputEntry>
        <outputEntry><text>"blue"</text></outputEntry>
        <outputEntry><text>240</text></outputEntry>
        <outputEntry><text>"Minor condition that could be managed in primary care"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
