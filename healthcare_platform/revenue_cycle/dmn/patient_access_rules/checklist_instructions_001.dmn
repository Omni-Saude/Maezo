<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/DMN/20151101/dmn.xsd"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_checklist_instructions_001"
             name="Pre-Admission Checklist Instructions"
             namespace="http://healthcare.platform/dmn/patient_access_rules">
  <decision id="checklist_instructions_001" name="Pre-Admission Checklist Instructions">
    <decisionTable id="DecisionTable_checklist_instructions_001" hitPolicy="UNIQUE">
      <input id="input1" label="Appointment Type">
        <inputExpression typeRef="string">
          <text>appointment_type</text>
        </inputExpression>
      </input>
      <output id="output1" label="Instructions" name="instructions" typeRef="string"/>
      <output id="output2" label="Contact Information" name="contact_info" typeRef="string"/>
      <output id="output3" label="Preparation Time (hours)" name="preparation_time" typeRef="integer"/>

      <!-- Consulta (Consultation) instructions -->
      <rule id="rule1">
        <inputEntry><text>"consulta"</text></inputEntry>
        <outputEntry><text>"Comparecer 15 minutos antes do horário marcado. Trazer documentos de identidade, carteirinha do convênio e exames anteriores relacionados à consulta."</text></outputEntry>
        <outputEntry><text>"Recepção: (11) 1234-5678 | consultas@hospital.com.br"</text></outputEntry>
        <outputEntry><text>0</text></outputEntry>
      </rule>

      <!-- Internação (Hospitalization) instructions -->
      <rule id="rule2">
        <inputEntry><text>"internacao"</text></inputEntry>
        <outputEntry><text>"Apresentar-se no setor de internação com 2 horas de antecedência. Trazer: documentos pessoais, autorização do convênio, exames pré-internação, lista de medicamentos em uso, pertences pessoais básicos. Não trazer objetos de valor."</text></outputEntry>
        <outputEntry><text>"Central de Internação: (11) 1234-5679 | internacao@hospital.com.br"</text></outputEntry>
        <outputEntry><text>2</text></outputEntry>
      </rule>

      <!-- Cirurgia (Surgery) instructions -->
      <rule id="rule3">
        <inputEntry><text>"cirurgia"</text></inputEntry>
        <outputEntry><text>"JEJUM ABSOLUTO (inclusive água) por 8 horas antes da cirurgia. Comparecer 3 horas antes do procedimento. Trazer: documentos, autorização cirúrgica, exames pré-operatórios, acompanhante adulto. Banho com sabonete antisséptico. Retirar maquiagem, esmalte, joias e próteses dentárias. Usar roupas confortáveis."</text></outputEntry>
        <outputEntry><text>"Centro Cirúrgico: (11) 1234-5680 | cirurgia@hospital.com.br | Emergência: (11) 1234-5600"</text></outputEntry>
        <outputEntry><text>8</text></outputEntry>
      </rule>

      <!-- Exame (Diagnostic test) instructions -->
      <rule id="rule4">
        <inputEntry><text>"exame"</text></inputEntry>
        <outputEntry><text>"Seguir orientações específicas do exame solicitado. Comparecer 30 minutos antes. Trazer: pedido médico, documentos de identidade, carteirinha do convênio e exames anteriores se disponíveis. Informar sobre uso de medicamentos, alergias e condições especiais (gravidez, marca-passo, etc)."</text></outputEntry>
        <outputEntry><text>"Central de Exames: (11) 1234-5681 | exames@hospital.com.br"</text></outputEntry>
        <outputEntry><text>0</text></outputEntry>
      </rule>

      <!-- Procedimento (Procedure) instructions -->
      <rule id="rule5">
        <inputEntry><text>"procedimento"</text></inputEntry>
        <outputEntry><text>"Comparecer 1 hora antes do horário agendado. Trazer: documentos, autorização do convênio, exames solicitados. Verificar se há necessidade de jejum ou preparo específico conforme orientação médica. Acompanhante é recomendado."</text></outputEntry>
        <outputEntry><text>"Central de Procedimentos: (11) 1234-5682 | procedimentos@hospital.com.br"</text></outputEntry>
        <outputEntry><text>1</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
