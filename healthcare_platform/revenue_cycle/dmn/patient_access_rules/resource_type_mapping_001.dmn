<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/DMN/20151101/dmn.xsd"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_resource_type_mapping_001"
             name="FHIR Resource Type Mapping"
             namespace="http://healthcare.platform/dmn/patient_access_rules">
  <decision id="resource_type_mapping_001" name="FHIR Resource Type Mapping">
    <decisionTable id="DecisionTable_resource_type_mapping_001" hitPolicy="UNIQUE">
      <input id="input1" label="Internal Resource Type">
        <inputExpression typeRef="string">
          <text>internal_resource_type</text>
        </inputExpression>
      </input>
      <output id="output1" label="FHIR Resource Type" name="fhir_resource_type" typeRef="string"/>
      <output id="output2" label="FHIR Profile" name="fhir_profile" typeRef="string"/>
      <output id="output3" label="Required Fields" name="required_fields" typeRef="string"/>

      <!-- Room mapping -->
      <rule id="rule1">
        <inputEntry><text>"room"</text></inputEntry>
        <outputEntry><text>"Location"</text></outputEntry>
        <outputEntry><text>"http://hl7.org/fhir/StructureDefinition/Location"</text></outputEntry>
        <outputEntry><text>"identifier,status,name,physicalType"</text></outputEntry>
      </rule>

      <!-- Equipment mapping -->
      <rule id="rule2">
        <inputEntry><text>"equipment"</text></inputEntry>
        <outputEntry><text>"Device"</text></outputEntry>
        <outputEntry><text>"http://hl7.org/fhir/StructureDefinition/Device"</text></outputEntry>
        <outputEntry><text>"identifier,status,type,serialNumber"</text></outputEntry>
      </rule>

      <!-- Staff mapping -->
      <rule id="rule3">
        <inputEntry><text>"staff"</text></inputEntry>
        <outputEntry><text>"Practitioner"</text></outputEntry>
        <outputEntry><text>"http://hl7.org/fhir/StructureDefinition/Practitioner"</text></outputEntry>
        <outputEntry><text>"identifier,active,name,qualification"</text></outputEntry>
      </rule>

      <!-- Bed mapping -->
      <rule id="rule4">
        <inputEntry><text>"bed"</text></inputEntry>
        <outputEntry><text>"Location"</text></outputEntry>
        <outputEntry><text>"http://hl7.org/fhir/StructureDefinition/Location"</text></outputEntry>
        <outputEntry><text>"identifier,status,name,physicalType,partOf"</text></outputEntry>
      </rule>

      <!-- Operating room mapping -->
      <rule id="rule5">
        <inputEntry><text>"operating_room"</text></inputEntry>
        <outputEntry><text>"Location"</text></outputEntry>
        <outputEntry><text>"http://hl7.org/fhir/StructureDefinition/Location"</text></outputEntry>
        <outputEntry><text>"identifier,status,name,operationalStatus,type"</text></outputEntry>
      </rule>

      <!-- Medical device mapping -->
      <rule id="rule6">
        <inputEntry><text>"medical_device"</text></inputEntry>
        <outputEntry><text>"Device"</text></outputEntry>
        <outputEntry><text>"http://hl7.org/fhir/StructureDefinition/Device"</text></outputEntry>
        <outputEntry><text>"identifier,status,type,manufacturer,model"</text></outputEntry>
      </rule>

      <!-- Practitioner role mapping -->
      <rule id="rule7">
        <inputEntry><text>"practitioner_role"</text></inputEntry>
        <outputEntry><text>"PractitionerRole"</text></outputEntry>
        <outputEntry><text>"http://hl7.org/fhir/StructureDefinition/PractitionerRole"</text></outputEntry>
        <outputEntry><text>"identifier,active,practitioner,organization,code"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
