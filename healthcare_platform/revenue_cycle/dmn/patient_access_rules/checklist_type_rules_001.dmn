<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/DMN/20151101/dmn.xsd"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_checklist_type_rules_001"
             name="Pre-Admission Checklist Type Selection"
             namespace="http://healthcare.platform/dmn/patient_access_rules">
  <decision id="checklist_type_rules_001" name="Pre-Admission Checklist Type Selection">
    <decisionTable id="DecisionTable_checklist_type_rules_001" hitPolicy="COLLECT">
      <input id="input1" label="Appointment Type">
        <inputExpression typeRef="string">
          <text>appointment_type</text>
        </inputExpression>
      </input>
      <input id="input2" label="Procedure Category">
        <inputExpression typeRef="string">
          <text>procedure_category</text>
        </inputExpression>
      </input>
      <output id="output1" label="Checklist Item" name="checklist_item" typeRef="string"/>
      <output id="output2" label="Priority" name="priority" typeRef="string"/>
      <output id="output3" label="Due Days Before" name="due_days_before" typeRef="integer"/>

      <!-- Internação (Hospitalization) checklist items -->
      <rule id="rule1">
        <inputEntry><text>"internacao"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"complete_blood_count"</text></outputEntry>
        <outputEntry><text>"required"</text></outputEntry>
        <outputEntry><text>7</text></outputEntry>
      </rule>
      <rule id="rule2">
        <inputEntry><text>"internacao"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"basic_metabolic_panel"</text></outputEntry>
        <outputEntry><text>"required"</text></outputEntry>
        <outputEntry><text>7</text></outputEntry>
      </rule>
      <rule id="rule3">
        <inputEntry><text>"internacao"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"insurance_authorization"</text></outputEntry>
        <outputEntry><text>"mandatory"</text></outputEntry>
        <outputEntry><text>3</text></outputEntry>
      </rule>

      <!-- Cirurgia (Surgery) checklist items -->
      <rule id="rule4">
        <inputEntry><text>"cirurgia"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"pre_operative_clearance"</text></outputEntry>
        <outputEntry><text>"mandatory"</text></outputEntry>
        <outputEntry><text>7</text></outputEntry>
      </rule>
      <rule id="rule5">
        <inputEntry><text>"cirurgia"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"anesthesia_evaluation"</text></outputEntry>
        <outputEntry><text>"mandatory"</text></outputEntry>
        <outputEntry><text>5</text></outputEntry>
      </rule>
      <rule id="rule6">
        <inputEntry><text>"cirurgia"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"surgical_consent"</text></outputEntry>
        <outputEntry><text>"mandatory"</text></outputEntry>
        <outputEntry><text>1</text></outputEntry>
      </rule>
      <rule id="rule7">
        <inputEntry><text>"cirurgia"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"npo_instructions"</text></outputEntry>
        <outputEntry><text>"mandatory"</text></outputEntry>
        <outputEntry><text>1</text></outputEntry>
      </rule>

      <!-- Cardiovascular surgery specific -->
      <rule id="rule8">
        <inputEntry><text>"cirurgia"</text></inputEntry>
        <inputEntry><text>"cardiovascular"</text></inputEntry>
        <outputEntry><text>"cardiac_catheterization"</text></outputEntry>
        <outputEntry><text>"required"</text></outputEntry>
        <outputEntry><text>14</text></outputEntry>
      </rule>
      <rule id="rule9">
        <inputEntry><text>"cirurgia"</text></inputEntry>
        <inputEntry><text>"cardiovascular"</text></inputEntry>
        <outputEntry><text>"echocardiogram"</text></outputEntry>
        <outputEntry><text>"required"</text></outputEntry>
        <outputEntry><text>30</text></outputEntry>
      </rule>

      <!-- Consulta (Consultation) checklist items -->
      <rule id="rule10">
        <inputEntry><text>"consulta"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"insurance_verification"</text></outputEntry>
        <outputEntry><text>"required"</text></outputEntry>
        <outputEntry><text>1</text></outputEntry>
      </rule>
      <rule id="rule11">
        <inputEntry><text>"consulta"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"demographic_update"</text></outputEntry>
        <outputEntry><text>"recommended"</text></outputEntry>
        <outputEntry><text>1</text></outputEntry>
      </rule>

      <!-- Exame (Diagnostic test) checklist items -->
      <rule id="rule12">
        <inputEntry><text>"exame"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"test_preparation_instructions"</text></outputEntry>
        <outputEntry><text>"mandatory"</text></outputEntry>
        <outputEntry><text>1</text></outputEntry>
      </rule>
      <rule id="rule13">
        <inputEntry><text>"exame"</text></inputEntry>
        <inputEntry><text>"contrast_imaging"</text></inputEntry>
        <outputEntry><text>"renal_function_test"</text></outputEntry>
        <outputEntry><text>"mandatory"</text></outputEntry>
        <outputEntry><text>7</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
