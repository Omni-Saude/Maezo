<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_receive_notification_validation"
             name="Receive Payment Notification Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: receive_payment_notification_worker.py -->
  <decision id="Decision_receive_notification_validation" name="Receive Payment Notification Validation">
    <decisionTable id="DecisionTable_receive_notification_validation" hitPolicy="FIRST">
      <input id="Input_has_payload" label="Tem Payload">
        <inputExpression id="InputExpression_has_payload" typeRef="boolean">
          <text>has_payload</text>
        </inputExpression>
      </input>
      <input id="Input_has_signature" label="Tem Assinatura">
        <inputExpression id="InputExpression_has_signature" typeRef="boolean">
          <text>has_signature</text>
        </inputExpression>
      </input>
      <input id="Input_payload_parseable" label="Payload Parseavel">
        <inputExpression id="InputExpression_payload_parseable" typeRef="boolean">
          <text>payload_parseable</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="Input_1_1"><text>true</text></inputEntry>
        <inputEntry id="Input_1_2"><text>true</text></inputEntry>
        <inputEntry id="Input_1_3"><text>true</text></inputEntry>
        <outputEntry id="Output_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2"><text>"Webhook completo e valido"</text></outputEntry>
        <outputEntry id="Output_1_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="Input_2_1"><text>true</text></inputEntry>
        <inputEntry id="Input_2_2"><text>true</text></inputEntry>
        <inputEntry id="Input_2_3"><text>false</text></inputEntry>
        <outputEntry id="Output_2_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_2_2"><text>"Payload malformado - nao parseavel"</text></outputEntry>
        <outputEntry id="Output_2_3"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="Input_3_1"><text>true</text></inputEntry>
        <inputEntry id="Input_3_2"><text>false</text></inputEntry>
        <inputEntry id="Input_3_3"><text></text></inputEntry>
        <outputEntry id="Output_3_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_3_2"><text>"Assinatura ausente - webhook rejeitado"</text></outputEntry>
        <outputEntry id="Output_3_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="Input_4_1"><text>false</text></inputEntry>
        <inputEntry id="Input_4_2"><text></text></inputEntry>
        <inputEntry id="Input_4_3"><text></text></inputEntry>
        <outputEntry id="Output_4_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_4_2"><text>"Payload ausente - webhook vazio"</text></outputEntry>
        <outputEntry id="Output_4_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="Input_5_1"><text>true</text></inputEntry>
        <inputEntry id="Input_5_2"><text>true</text></inputEntry>
        <inputEntry id="Input_5_3"><text>true</text></inputEntry>
        <outputEntry id="Output_5_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_5_2"><text>"Validacao completa - encaminhar para processamento"</text></outputEntry>
        <outputEntry id="Output_5_3"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
