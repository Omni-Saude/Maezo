<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_detect_duplicate_validation"
             name="Detect Duplicate Payment Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: detect_duplicate_payment_worker.py -->
  <decision id="Decision_detect_duplicate_validation" name="Detect Duplicate Payment Validation">
    <decisionTable id="DecisionTable_detect_duplicate_validation" hitPolicy="FIRST">
      <input id="Input_has_transaction_id" label="Tem Transaction ID">
        <inputExpression id="InputExpression_has_transaction_id" typeRef="boolean">
          <text>has_transaction_id</text>
        </inputExpression>
      </input>
      <input id="Input_has_nosso_numero" label="Tem Nosso Numero">
        <inputExpression id="InputExpression_has_nosso_numero" typeRef="boolean">
          <text>has_nosso_numero</text>
        </inputExpression>
      </input>
      <input id="Input_has_composite_fields" label="Tem Campos Compostos">
        <inputExpression id="InputExpression_has_composite_fields" typeRef="boolean">
          <text>has_composite_fields</text>
        </inputExpression>
      </input>
      <input id="Input_repository_available" label="Repositorio Disponivel">
        <inputExpression id="InputExpression_repository_available" typeRef="boolean">
          <text>repository_available</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="Input_1_1"><text>true</text></inputEntry>
        <inputEntry id="Input_1_2"><text></text></inputEntry>
        <inputEntry id="Input_1_3"><text></text></inputEntry>
        <inputEntry id="Input_1_4"><text>true</text></inputEntry>
        <outputEntry id="Output_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2"><text>"Transaction ID disponivel - verificacao completa"</text></outputEntry>
        <outputEntry id="Output_1_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="Input_2_1"><text>false</text></inputEntry>
        <inputEntry id="Input_2_2"><text>true</text></inputEntry>
        <inputEntry id="Input_2_3"><text></text></inputEntry>
        <inputEntry id="Input_2_4"><text>true</text></inputEntry>
        <outputEntry id="Output_2_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_2_2"><text>"Nosso numero disponivel para verificacao"</text></outputEntry>
        <outputEntry id="Output_2_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="Input_3_1"><text>false</text></inputEntry>
        <inputEntry id="Input_3_2"><text>false</text></inputEntry>
        <inputEntry id="Input_3_3"><text>true</text></inputEntry>
        <inputEntry id="Input_3_4"><text>true</text></inputEntry>
        <outputEntry id="Output_3_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_3_2"><text>"Apenas chave composta - deteccao menos confiavel"</text></outputEntry>
        <outputEntry id="Output_3_3"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="Input_4_1"><text>false</text></inputEntry>
        <inputEntry id="Input_4_2"><text>false</text></inputEntry>
        <inputEntry id="Input_4_3"><text>false</text></inputEntry>
        <inputEntry id="Input_4_4"><text>true</text></inputEntry>
        <outputEntry id="Output_4_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_4_2"><text>"Sem campos para deteccao de duplicatas"</text></outputEntry>
        <outputEntry id="Output_4_3"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="Input_5_1"><text></text></inputEntry>
        <inputEntry id="Input_5_2"><text></text></inputEntry>
        <inputEntry id="Input_5_3"><text></text></inputEntry>
        <inputEntry id="Input_5_4"><text>false</text></inputEntry>
        <outputEntry id="Output_5_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_5_2"><text>"Repositorio indisponivel - verificacao de duplicatas ignorada"</text></outputEntry>
        <outputEntry id="Output_5_3"><text>"ALTO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
