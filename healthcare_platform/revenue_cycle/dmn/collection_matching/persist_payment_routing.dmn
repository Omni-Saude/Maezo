<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_persist_payment_routing"
             name="Persist Payment Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: persist_payment_worker.py -->
  <decision id="Decision_persist_payment_routing" name="Persist Payment Routing">
    <decisionTable id="DecisionTable_persist_payment_routing" hitPolicy="FIRST">
      <input id="Input_repository_configured" label="Repositorio Configurado">
        <inputExpression id="InputExpression_repository_configured" typeRef="boolean">
          <text>repository_configured</text>
        </inputExpression>
      </input>
      <input id="Input_payment_type" label="Tipo Pagamento">
        <inputExpression id="InputExpression_payment_type" typeRef="string">
          <text>payment_type</text>
        </inputExpression>
        <inputValues><text>"full","partial","advance"</text></inputValues>
      </input>
      <input id="Input_payment_method" label="Metodo Pagamento">
        <inputExpression id="InputExpression_payment_method" typeRef="string">
          <text>payment_method</text>
        </inputExpression>
        <inputValues><text>"pix","boleto","bank_transfer"</text></inputValues>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="Input_1_1"><text>true</text></inputEntry>
        <inputEntry id="Input_1_2"><text>"full"</text></inputEntry>
        <inputEntry id="Input_1_3"><text></text></inputEntry>
        <outputEntry id="Output_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2"><text>"Pagamento integral - persistir e atualizar status"</text></outputEntry>
        <outputEntry id="Output_1_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="Input_2_1"><text>true</text></inputEntry>
        <inputEntry id="Input_2_2"><text>"partial"</text></inputEntry>
        <inputEntry id="Input_2_3"><text></text></inputEntry>
        <outputEntry id="Output_2_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_2_2"><text>"Pagamento parcial - persistir e manter saldo aberto"</text></outputEntry>
        <outputEntry id="Output_2_3"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="Input_3_1"><text>true</text></inputEntry>
        <inputEntry id="Input_3_2"><text>"advance"</text></inputEntry>
        <inputEntry id="Input_3_3"><text></text></inputEntry>
        <outputEntry id="Output_3_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_3_2"><text>"Adiantamento sem claim - persistir e aguardar alocacao"</text></outputEntry>
        <outputEntry id="Output_3_3"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="Input_4_1"><text>false</text></inputEntry>
        <inputEntry id="Input_4_2"><text></text></inputEntry>
        <inputEntry id="Input_4_3"><text></text></inputEntry>
        <outputEntry id="Output_4_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_4_2"><text>"Repositorio nao configurado - impossivel persistir"</text></outputEntry>
        <outputEntry id="Output_4_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="Input_5_1"><text>true</text></inputEntry>
        <inputEntry id="Input_5_2"><text></text></inputEntry>
        <inputEntry id="Input_5_3"><text>"pix"</text></inputEntry>
        <outputEntry id="Output_5_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_5_2"><text>"PIX - persistir com prioridade alta"</text></outputEntry>
        <outputEntry id="Output_5_3"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
