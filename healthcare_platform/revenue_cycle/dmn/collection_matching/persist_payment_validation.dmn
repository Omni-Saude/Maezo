<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_persist_payment_validation"
             name="Persist Payment Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: persist_payment_worker.py -->
  <decision id="Decision_persist_payment_validation" name="Persist Payment Validation">
    <decisionTable id="DecisionTable_persist_payment_validation" hitPolicy="FIRST">
      <input id="Input_has_transaction_id" label="Tem Transaction ID">
        <inputExpression id="InputExpression_has_transaction_id" typeRef="boolean">
          <text>has_transaction_id</text>
        </inputExpression>
      </input>
      <input id="Input_net_amount" label="Valor Liquido">
        <inputExpression id="InputExpression_net_amount" typeRef="double">
          <text>net_amount</text>
        </inputExpression>
      </input>
      <input id="Input_tenant_valid" label="Tenant Valido">
        <inputExpression id="InputExpression_tenant_valid" typeRef="boolean">
          <text>tenant_valid</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="Input_1_1"><text>true</text></inputEntry>
        <inputEntry id="Input_1_2"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_1_3"><text>true</text></inputEntry>
        <outputEntry id="Output_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2"><text>"Dados completos para persistencia"</text></outputEntry>
        <outputEntry id="Output_1_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="Input_2_1"><text>false</text></inputEntry>
        <inputEntry id="Input_2_2"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_2_3"><text>true</text></inputEntry>
        <outputEntry id="Output_2_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_2_2"><text>"Transaction ID obrigatorio para persistencia"</text></outputEntry>
        <outputEntry id="Output_2_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="Input_3_1"><text>true</text></inputEntry>
        <inputEntry id="Input_3_2"><text>&lt;= 0</text></inputEntry>
        <inputEntry id="Input_3_3"><text>true</text></inputEntry>
        <outputEntry id="Output_3_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_3_2"><text>"Valor liquido zerado - verificar taxas"</text></outputEntry>
        <outputEntry id="Output_3_3"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="Input_4_1"><text>true</text></inputEntry>
        <inputEntry id="Input_4_2"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_4_3"><text>false</text></inputEntry>
        <outputEntry id="Output_4_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_4_2"><text>"Tenant invalido - nao pode persistir"</text></outputEntry>
        <outputEntry id="Output_4_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="Input_5_1"><text>false</text></inputEntry>
        <inputEntry id="Input_5_2"><text>&lt;= 0</text></inputEntry>
        <inputEntry id="Input_5_3"><text></text></inputEntry>
        <outputEntry id="Output_5_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_5_2"><text>"Dados insuficientes para persistencia"</text></outputEntry>
        <outputEntry id="Output_5_3"><text>"CRITICO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
