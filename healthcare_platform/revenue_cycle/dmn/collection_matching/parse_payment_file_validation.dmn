<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_parse_payment_file_validation"
             name="Parse Payment File Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: parse_payment_file_worker.py -->
  <decision id="Decision_parse_payment_file_validation" name="Parse Payment File Validation">
    <decisionTable id="DecisionTable_parse_payment_file_validation" hitPolicy="FIRST">
      <input id="Input_file_size" label="Tamanho Arquivo">
        <inputExpression id="InputExpression_file_size" typeRef="integer">
          <text>file_size</text>
        </inputExpression>
      </input>
      <input id="Input_has_header" label="Tem Header">
        <inputExpression id="InputExpression_has_header" typeRef="boolean">
          <text>has_header</text>
        </inputExpression>
      </input>
      <input id="Input_bank_code_valid" label="Codigo Banco Valido">
        <inputExpression id="InputExpression_bank_code_valid" typeRef="boolean">
          <text>bank_code_valid</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="Input_1_1"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_1_2"><text>true</text></inputEntry>
        <inputEntry id="Input_1_3"><text>true</text></inputEntry>
        <outputEntry id="Output_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2"><text>"Arquivo CNAB valido com header e banco reconhecido"</text></outputEntry>
        <outputEntry id="Output_1_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="Input_2_1"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_2_2"><text>true</text></inputEntry>
        <inputEntry id="Input_2_3"><text>false</text></inputEntry>
        <outputEntry id="Output_2_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_2_2"><text>"Codigo do banco nao reconhecido"</text></outputEntry>
        <outputEntry id="Output_2_3"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="Input_3_1"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_3_2"><text>false</text></inputEntry>
        <inputEntry id="Input_3_3"><text></text></inputEntry>
        <outputEntry id="Output_3_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_3_2"><text>"Arquivo sem header CNAB valido"</text></outputEntry>
        <outputEntry id="Output_3_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="Input_4_1"><text>0</text></inputEntry>
        <inputEntry id="Input_4_2"><text></text></inputEntry>
        <inputEntry id="Input_4_3"><text></text></inputEntry>
        <outputEntry id="Output_4_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_4_2"><text>"Conteudo do arquivo CNAB vazio"</text></outputEntry>
        <outputEntry id="Output_4_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="Input_5_1"><text>&gt; 10000000</text></inputEntry>
        <inputEntry id="Input_5_2"><text></text></inputEntry>
        <inputEntry id="Input_5_3"><text></text></inputEntry>
        <outputEntry id="Output_5_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_5_2"><text>"Arquivo muito grande - processar em lotes"</text></outputEntry>
        <outputEntry id="Output_5_3"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
