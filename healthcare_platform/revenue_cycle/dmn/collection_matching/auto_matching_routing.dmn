<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_auto_matching_routing"
             name="Auto Matching Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: auto_matching_worker.py -->
  <decision id="Decision_auto_matching_routing" name="Auto Matching Routing">
    <decisionTable id="DecisionTable_auto_matching_routing" hitPolicy="FIRST">
      <input id="Input_match_method" label="Metodo Correspondencia">
        <inputExpression id="InputExpression_match_method" typeRef="string">
          <text>match_method</text>
        </inputExpression>
        <inputValues><text>"protocol","invoice","patient","none"</text></inputValues>
      </input>
      <input id="Input_confidence_score" label="Score Confianca">
        <inputExpression id="InputExpression_confidence_score" typeRef="double">
          <text>confidence_score</text>
        </inputExpression>
      </input>
      <input id="Input_claims_count" label="Claims Disponiveis">
        <inputExpression id="InputExpression_claims_count" typeRef="integer">
          <text>claims_count</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <!-- Rule 1: Protocol match with high confidence -->
      <rule id="Rule_1">
        <inputEntry id="Input_1_1"><text>"protocol"</text></inputEntry>
        <inputEntry id="Input_1_2"><text>&gt;= 0.90</text></inputEntry>
        <inputEntry id="Input_1_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2"><text>"Alocar automaticamente por protocolo TISS"</text></outputEntry>
        <outputEntry id="Output_1_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <!-- Rule 2: Invoice match with high confidence -->
      <rule id="Rule_2">
        <inputEntry id="Input_2_1"><text>"invoice"</text></inputEntry>
        <inputEntry id="Input_2_2"><text>&gt;= 0.80</text></inputEntry>
        <inputEntry id="Input_2_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_2_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_2_2"><text>"Alocar automaticamente por fatura"</text></outputEntry>
        <outputEntry id="Output_2_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <!-- Rule 3: Patient match with good confidence -->
      <rule id="Rule_3">
        <inputEntry id="Input_3_1"><text>"patient"</text></inputEntry>
        <inputEntry id="Input_3_2"><text>&gt;= 0.60</text></inputEntry>
        <inputEntry id="Input_3_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_3_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_3_2"><text>"Verificar correspondencia por paciente antes de alocar"</text></outputEntry>
        <outputEntry id="Output_3_3"><text>"MEDIO"</text></outputEntry>
      </rule>
      <!-- Rule 4: Patient match with low confidence -->
      <rule id="Rule_4">
        <inputEntry id="Input_4_1"><text>"patient"</text></inputEntry>
        <inputEntry id="Input_4_2"><text>&lt; 0.60</text></inputEntry>
        <inputEntry id="Input_4_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_4_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_4_2"><text>"Confianca baixa - revisao manual obrigatoria"</text></outputEntry>
        <outputEntry id="Output_4_3"><text>"ALTO"</text></outputEntry>
      </rule>
      <!-- Rule 5: No match found with claims available -->
      <rule id="Rule_5">
        <inputEntry id="Input_5_1"><text>"none"</text></inputEntry>
        <inputEntry id="Input_5_2"><text></text></inputEntry>
        <inputEntry id="Input_5_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_5_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_5_2"><text>"Nenhuma correspondencia automatica - encaminhar para matching manual"</text></outputEntry>
        <outputEntry id="Output_5_3"><text>"ALTO"</text></outputEntry>
      </rule>
      <!-- Rule 6: No match and no claims -->
      <rule id="Rule_6">
        <inputEntry id="Input_6_1"><text>"none"</text></inputEntry>
        <inputEntry id="Input_6_2"><text></text></inputEntry>
        <inputEntry id="Input_6_3"><text>0</text></inputEntry>
        <outputEntry id="Output_6_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_6_2"><text>"Sem claims disponiveis para correspondencia"</text></outputEntry>
        <outputEntry id="Output_6_3"><text>"CRITICO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
