<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_classify_payment_type_routing"
             name="Classify Payment Type Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: classify_payment_type_worker.py -->
  <decision id="Decision_classify_payment_type_routing" name="Classify Payment Type Routing">
    <decisionTable id="DecisionTable_classify_payment_type_routing" hitPolicy="FIRST">
      <input id="Input_payment_ratio" label="Ratio Pagamento">
        <inputExpression id="InputExpression_payment_ratio" typeRef="double">
          <text>payment_ratio</text>
        </inputExpression>
      </input>
      <input id="Input_has_expected" label="Tem Valor Esperado">
        <inputExpression id="InputExpression_has_expected" typeRef="boolean">
          <text>has_expected_amount</text>
        </inputExpression>
      </input>
      <input id="Input_net_amount" label="Valor Liquido">
        <inputExpression id="InputExpression_net_amount" typeRef="double">
          <text>net_amount</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="Input_1_1"><text>&gt;= 0.95</text></inputEntry>
        <inputEntry id="Input_1_2"><text>true</text></inputEntry>
        <inputEntry id="Input_1_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2"><text>"Pagamento integral - classificar como FULL"</text></outputEntry>
        <outputEntry id="Output_1_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="Input_2_1"><text>[0.10..0.95)</text></inputEntry>
        <inputEntry id="Input_2_2"><text>true</text></inputEntry>
        <inputEntry id="Input_2_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_2_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_2_2"><text>"Pagamento parcial - classificar como PARTIAL"</text></outputEntry>
        <outputEntry id="Output_2_3"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="Input_3_1"><text>&lt; 0.10</text></inputEntry>
        <inputEntry id="Input_3_2"><text>true</text></inputEntry>
        <inputEntry id="Input_3_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_3_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_3_2"><text>"Pagamento minimo - verificar se parcial ou erro"</text></outputEntry>
        <outputEntry id="Output_3_3"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="Input_4_1"><text>&gt; 1.05</text></inputEntry>
        <inputEntry id="Input_4_2"><text>true</text></inputEntry>
        <inputEntry id="Input_4_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_4_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_4_2"><text>"Sobrepagamento detectado - verificar"</text></outputEntry>
        <outputEntry id="Output_4_3"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="Input_5_1"><text></text></inputEntry>
        <inputEntry id="Input_5_2"><text>false</text></inputEntry>
        <inputEntry id="Input_5_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_5_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_5_2"><text>"Sem valor esperado - classificar como ADVANCE"</text></outputEntry>
        <outputEntry id="Output_5_3"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_6">
        <inputEntry id="Input_6_1"><text></text></inputEntry>
        <inputEntry id="Input_6_2"><text></text></inputEntry>
        <inputEntry id="Input_6_3"><text>&lt;= 0</text></inputEntry>
        <outputEntry id="Output_6_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_6_2"><text>"Valor liquido zerado ou negativo"</text></outputEntry>
        <outputEntry id="Output_6_3"><text>"CRITICO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
