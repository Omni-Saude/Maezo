<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_parse_payment_file_routing"
             name="Parse Payment File Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: parse_payment_file_worker.py -->
  <decision id="Decision_parse_payment_file_routing" name="Parse Payment File Routing">
    <decisionTable id="DecisionTable_parse_payment_file_routing" hitPolicy="FIRST">
      <input id="Input_cnab_format" label="Formato CNAB">
        <inputExpression id="InputExpression_cnab_format" typeRef="string">
          <text>cnab_format</text>
        </inputExpression>
        <inputValues><text>"240","400","unknown"</text></inputValues>
      </input>
      <input id="Input_error_count" label="Quantidade Erros">
        <inputExpression id="InputExpression_error_count" typeRef="integer">
          <text>error_count</text>
        </inputExpression>
      </input>
      <input id="Input_record_count" label="Quantidade Registros">
        <inputExpression id="InputExpression_record_count" typeRef="integer">
          <text>record_count</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="Input_1_1"><text>"240"</text></inputEntry>
        <inputEntry id="Input_1_2"><text>0</text></inputEntry>
        <inputEntry id="Input_1_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2"><text>"CNAB 240 parseado sem erros"</text></outputEntry>
        <outputEntry id="Output_1_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="Input_2_1"><text>"400"</text></inputEntry>
        <inputEntry id="Input_2_2"><text>0</text></inputEntry>
        <inputEntry id="Input_2_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_2_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_2_2"><text>"CNAB 400 parseado sem erros"</text></outputEntry>
        <outputEntry id="Output_2_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="Input_3_1"><text>"240","400"</text></inputEntry>
        <inputEntry id="Input_3_2"><text>[1..5]</text></inputEntry>
        <inputEntry id="Input_3_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_3_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_3_2"><text>"Arquivo parseado com erros parciais - revisar registros"</text></outputEntry>
        <outputEntry id="Output_3_3"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="Input_4_1"><text>"240","400"</text></inputEntry>
        <inputEntry id="Input_4_2"><text>&gt; 5</text></inputEntry>
        <inputEntry id="Input_4_3"><text></text></inputEntry>
        <outputEntry id="Output_4_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_4_2"><text>"Muitos erros de parsing - arquivo corrompido"</text></outputEntry>
        <outputEntry id="Output_4_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="Input_5_1"><text>"unknown"</text></inputEntry>
        <inputEntry id="Input_5_2"><text></text></inputEntry>
        <inputEntry id="Input_5_3"><text></text></inputEntry>
        <outputEntry id="Output_5_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_5_2"><text>"Formato CNAB nao reconhecido"</text></outputEntry>
        <outputEntry id="Output_5_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_6">
        <inputEntry id="Input_6_1"><text></text></inputEntry>
        <inputEntry id="Input_6_2"><text></text></inputEntry>
        <inputEntry id="Input_6_3"><text>0</text></inputEntry>
        <outputEntry id="Output_6_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_6_2"><text>"Arquivo vazio - nenhum registro encontrado"</text></outputEntry>
        <outputEntry id="Output_6_3"><text>"ALTO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
