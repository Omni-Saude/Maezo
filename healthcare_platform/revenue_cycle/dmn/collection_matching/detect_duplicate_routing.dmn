<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_detect_duplicate_routing"
             name="Detect Duplicate Payment Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: detect_duplicate_payment_worker.py -->
  <decision id="Decision_detect_duplicate_routing" name="Detect Duplicate Payment Routing">
    <decisionTable id="DecisionTable_detect_duplicate_routing" hitPolicy="FIRST">
      <input id="Input_dup_by_transaction" label="Duplicado por Transaction ID">
        <inputExpression id="InputExpression_dup_by_transaction" typeRef="boolean">
          <text>dup_by_transaction</text>
        </inputExpression>
      </input>
      <input id="Input_dup_by_nosso_numero" label="Duplicado por Nosso Numero">
        <inputExpression id="InputExpression_dup_by_nosso_numero" typeRef="boolean">
          <text>dup_by_nosso_numero</text>
        </inputExpression>
      </input>
      <input id="Input_dup_by_composite" label="Duplicado por Chave Composta">
        <inputExpression id="InputExpression_dup_by_composite" typeRef="boolean">
          <text>dup_by_composite</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="Input_1_1"><text>true</text></inputEntry>
        <inputEntry id="Input_1_2"><text></text></inputEntry>
        <inputEntry id="Input_1_3"><text></text></inputEntry>
        <outputEntry id="Output_1_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_1_2"><text>"Duplicata exata por transaction_id - rejeitar pagamento"</text></outputEntry>
        <outputEntry id="Output_1_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="Input_2_1"><text>false</text></inputEntry>
        <inputEntry id="Input_2_2"><text>true</text></inputEntry>
        <inputEntry id="Input_2_3"><text></text></inputEntry>
        <outputEntry id="Output_2_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_2_2"><text>"Duplicata por nosso_numero bancario - rejeitar"</text></outputEntry>
        <outputEntry id="Output_2_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="Input_3_1"><text>false</text></inputEntry>
        <inputEntry id="Input_3_2"><text>false</text></inputEntry>
        <inputEntry id="Input_3_3"><text>true</text></inputEntry>
        <outputEntry id="Output_3_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_3_2"><text>"Possivel duplicata por valor+data+pagador - revisao manual"</text></outputEntry>
        <outputEntry id="Output_3_3"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="Input_4_1"><text>false</text></inputEntry>
        <inputEntry id="Input_4_2"><text>false</text></inputEntry>
        <inputEntry id="Input_4_3"><text>false</text></inputEntry>
        <outputEntry id="Output_4_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_4_2"><text>"Nenhuma duplicata detectada - prosseguir"</text></outputEntry>
        <outputEntry id="Output_4_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="Input_5_1"><text>true</text></inputEntry>
        <inputEntry id="Input_5_2"><text>true</text></inputEntry>
        <inputEntry id="Input_5_3"><text></text></inputEntry>
        <outputEntry id="Output_5_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_5_2"><text>"Multiplas deteccoes de duplicata - fraude potencial"</text></outputEntry>
        <outputEntry id="Output_5_3"><text>"CRITICO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
