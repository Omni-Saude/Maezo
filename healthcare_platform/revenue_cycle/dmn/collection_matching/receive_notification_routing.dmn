<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_receive_notification_routing"
             name="Receive Payment Notification Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: receive_payment_notification_worker.py -->
  <decision id="Decision_receive_notification_routing" name="Receive Payment Notification Routing">
    <decisionTable id="DecisionTable_receive_notification_routing" hitPolicy="FIRST">
      <input id="Input_signature_valid" label="Assinatura Valida">
        <inputExpression id="InputExpression_signature_valid" typeRef="boolean">
          <text>signature_valid</text>
        </inputExpression>
      </input>
      <input id="Input_payment_method" label="Metodo Pagamento">
        <inputExpression id="InputExpression_payment_method" typeRef="string">
          <text>payment_method</text>
        </inputExpression>
        <inputValues><text>"pix","boleto","bank_transfer"</text></inputValues>
      </input>
      <input id="Input_amount" label="Valor">
        <inputExpression id="InputExpression_amount" typeRef="double">
          <text>amount</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="Input_1_1"><text>true</text></inputEntry>
        <inputEntry id="Input_1_2"><text>"pix"</text></inputEntry>
        <inputEntry id="Input_1_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2"><text>"Notificacao PIX valida - processar imediatamente"</text></outputEntry>
        <outputEntry id="Output_1_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="Input_2_1"><text>true</text></inputEntry>
        <inputEntry id="Input_2_2"><text>"boleto"</text></inputEntry>
        <inputEntry id="Input_2_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_2_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_2_2"><text>"Notificacao boleto valida - processar"</text></outputEntry>
        <outputEntry id="Output_2_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="Input_3_1"><text>true</text></inputEntry>
        <inputEntry id="Input_3_2"><text>"bank_transfer"</text></inputEntry>
        <inputEntry id="Input_3_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_3_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_3_2"><text>"Transferencia bancaria valida - processar"</text></outputEntry>
        <outputEntry id="Output_3_3"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="Input_4_1"><text>false</text></inputEntry>
        <inputEntry id="Input_4_2"><text></text></inputEntry>
        <inputEntry id="Input_4_3"><text></text></inputEntry>
        <outputEntry id="Output_4_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_4_2"><text>"Assinatura HMAC invalida - rejeitar webhook"</text></outputEntry>
        <outputEntry id="Output_4_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="Input_5_1"><text>true</text></inputEntry>
        <inputEntry id="Input_5_2"><text></text></inputEntry>
        <inputEntry id="Input_5_3"><text>&lt;= 0</text></inputEntry>
        <outputEntry id="Output_5_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_5_2"><text>"Valor do pagamento zerado ou negativo"</text></outputEntry>
        <outputEntry id="Output_5_3"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_6">
        <inputEntry id="Input_6_1"><text>true</text></inputEntry>
        <inputEntry id="Input_6_2"><text></text></inputEntry>
        <inputEntry id="Input_6_3"><text>&gt; 1000000</text></inputEntry>
        <outputEntry id="Output_6_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_6_2"><text>"Valor alto - revisao de seguranca obrigatoria"</text></outputEntry>
        <outputEntry id="Output_6_3"><text>"ALTO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
