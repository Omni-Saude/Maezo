<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_glosa_identify_adjudication"
             name="Glosa Identification Adjudication"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Glosa Identification Adjudication
       For: identify_glosa_worker
       Archetype: ADMIN_ADJUDICATION
       Purpose: Identify glosa type from payer response text
  -->

  <decision id="Decision_glosa_identify_adjudication" name="Glosa Identification Adjudication">
    <decisionTable id="DecisionTable_glosa_identify_adjudication" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_1" label="Reason Text">
        <inputExpression id="InputExpr_1" typeRef="string">
          <text>reasonText</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Adjudication Category">
        <inputExpression id="InputExpr_2" typeRef="string">
          <text>adjudicationCategory</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Autorização expirada -->
      <rule id="Rule_1">
        <description>EXPIRED_AUTH identificada</description>
        <inputEntry id="IE_1_1"><text>contains(lower(reasonText), "autorização") and contains(lower(reasonText), "expirada")</text></inputEntry>
        <inputEntry id="IE_1_2"><text>-</text></inputEntry>
        <outputEntry id="OE_1_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_acao"><text>"EXPIRED_AUTH identificada"</text></outputEntry>
        <outputEntry id="OE_1_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Autorização/guia ausente -->
      <rule id="Rule_2">
        <description>MISSING_AUTH identificada</description>
        <inputEntry id="IE_2_1"><text>contains(lower(reasonText), "autorização") or contains(lower(reasonText), "guia")</text></inputEntry>
        <inputEntry id="IE_2_2"><text>-</text></inputEntry>
        <outputEntry id="OE_2_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_2_acao"><text>"MISSING_AUTH identificada"</text></outputEntry>
        <outputEntry id="OE_2_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Duplicidade -->
      <rule id="Rule_3">
        <description>DUPLICATE_CHARGE identificada</description>
        <inputEntry id="IE_3_1"><text>contains(lower(reasonText), "duplicad")</text></inputEntry>
        <inputEntry id="IE_3_2"><text>-</text></inputEntry>
        <outputEntry id="OE_3_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_3_acao"><text>"DUPLICATE_CHARGE identificada"</text></outputEntry>
        <outputEntry id="OE_3_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Não coberto -->
      <rule id="Rule_4">
        <description>NOT_COVERED identificada</description>
        <inputEntry id="IE_4_1"><text>contains(lower(reasonText), "não coberto")</text></inputEntry>
        <inputEntry id="IE_4_2"><text>-</text></inputEntry>
        <outputEntry id="OE_4_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_4_acao"><text>"NOT_COVERED identificada"</text></outputEntry>
        <outputEntry id="OE_4_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Quantidade excedida -->
      <rule id="Rule_5">
        <description>EXCEEDS_QUANTITY identificada</description>
        <inputEntry id="IE_5_1"><text>contains(lower(reasonText), "quantidade") or contains(lower(reasonText), "excede")</text></inputEntry>
        <inputEntry id="IE_5_2"><text>-</text></inputEntry>
        <outputEntry id="OE_5_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_5_acao"><text>"EXCEEDS_QUANTITY identificada"</text></outputEntry>
        <outputEntry id="OE_5_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 6: Código incorreto -->
      <rule id="Rule_6">
        <description>WRONG_CODE identificada</description>
        <inputEntry id="IE_6_1"><text>contains(lower(reasonText), "código") and contains(lower(reasonText), "incorreto")</text></inputEntry>
        <inputEntry id="IE_6_2"><text>-</text></inputEntry>
        <outputEntry id="OE_6_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_6_acao"><text>"WRONG_CODE identificada"</text></outputEntry>
        <outputEntry id="OE_6_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 7: Documentação incompleta -->
      <rule id="Rule_7">
        <description>MISSING_DOCUMENTATION identificada</description>
        <inputEntry id="IE_7_1"><text>contains(lower(reasonText), "documentação")</text></inputEntry>
        <inputEntry id="IE_7_2"><text>-</text></inputEntry>
        <outputEntry id="OE_7_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_7_acao"><text>"MISSING_DOCUMENTATION identificada"</text></outputEntry>
        <outputEntry id="OE_7_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 8: Procedimento incompatível -->
      <rule id="Rule_8">
        <description>INCOMPATIBLE_PROCEDURE identificada</description>
        <inputEntry id="IE_8_1"><text>contains(lower(reasonText), "incompatível")</text></inputEntry>
        <inputEntry id="IE_8_2"><text>-</text></inputEntry>
        <outputEntry id="OE_8_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_8_acao"><text>"INCOMPATIBLE_PROCEDURE identificada"</text></outputEntry>
        <outputEntry id="OE_8_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 9: Divergência de preço -->
      <rule id="Rule_9">
        <description>PRICE_DIVERGENCE identificada</description>
        <inputEntry id="IE_9_1"><text>contains(lower(reasonText), "valor") or contains(lower(reasonText), "preço")</text></inputEntry>
        <inputEntry id="IE_9_2"><text>-</text></inputEntry>
        <outputEntry id="OE_9_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_9_acao"><text>"PRICE_DIVERGENCE identificada"</text></outputEntry>
        <outputEntry id="OE_9_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="Rule_fallback">
        <description>Caso não enquadrado — revisão obrigatória</description>
        <inputEntry id="IE_fb_1"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao"><text>"TISS_VALIDATION - avaliar manualmente"</text></outputEntry>
        <outputEntry id="OE_fb_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_glosa_identify_adjudication">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
