<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_glosa_reason_adjudication"
             name="Glosa Reason Adjudication"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Glosa Reason Analysis Adjudication
       For: analyze_glosa_reason_worker
       Archetype: ADMIN_ADJUDICATION
       Purpose: Map keyword patterns to reason codes
  -->

  <decision id="Decision_glosa_reason_adjudication" name="Glosa Reason Adjudication">
    <decisionTable id="DecisionTable_glosa_reason_adjudication" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_1" label="Description">
        <inputExpression id="InputExpr_1" typeRef="string">
          <text>description</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Glosa Type">
        <inputExpression id="InputExpr_2" typeRef="string">
          <text>glosaType</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Autorização ausente -->
      <rule id="Rule_1">
        <description>Autorização ausente - MISSING_AUTH</description>
        <inputEntry id="IE_1_1"><text>contains(lower(description), "autorização") and contains(lower(description), "ausente")</text></inputEntry>
        <inputEntry id="IE_1_2"><text>-</text></inputEntry>
        <outputEntry id="OE_1_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_acao"><text>"Glosa por autorização ausente - MISSING_AUTH"</text></outputEntry>
        <outputEntry id="OE_1_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Autorização vencida -->
      <rule id="Rule_2">
        <description>Autorização vencida - EXPIRED_AUTH</description>
        <inputEntry id="IE_2_1"><text>contains(lower(description), "autorização") and contains(lower(description), "vencida")</text></inputEntry>
        <inputEntry id="IE_2_2"><text>-</text></inputEntry>
        <outputEntry id="OE_2_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_2_acao"><text>"Glosa por autorização vencida - EXPIRED_AUTH"</text></outputEntry>
        <outputEntry id="OE_2_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Cobrança duplicada -->
      <rule id="Rule_3">
        <description>Cobrança duplicada - DUPLICATE_CHARGE</description>
        <inputEntry id="IE_3_1"><text>contains(lower(description), "duplicad")</text></inputEntry>
        <inputEntry id="IE_3_2"><text>-</text></inputEntry>
        <outputEntry id="OE_3_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_3_acao"><text>"Cobrança duplicada - DUPLICATE_CHARGE"</text></outputEntry>
        <outputEntry id="OE_3_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Não coberto -->
      <rule id="Rule_4">
        <description>Não coberto - NOT_COVERED</description>
        <inputEntry id="IE_4_1"><text>contains(lower(description), "cobertura")</text></inputEntry>
        <inputEntry id="IE_4_2"><text>-</text></inputEntry>
        <outputEntry id="OE_4_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_4_acao"><text>"Não coberto - NOT_COVERED"</text></outputEntry>
        <outputEntry id="OE_4_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Código incompatível -->
      <rule id="Rule_5">
        <description>Procedimento incompatível - INCOMPATIBLE_PROCEDURE</description>
        <inputEntry id="IE_5_1"><text>contains(lower(description), "código") and contains(lower(description), "incompatível")</text></inputEntry>
        <inputEntry id="IE_5_2"><text>-</text></inputEntry>
        <outputEntry id="OE_5_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_5_acao"><text>"Procedimento incompatível - INCOMPATIBLE_PROCEDURE"</text></outputEntry>
        <outputEntry id="OE_5_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 6: Documentação incompleta -->
      <rule id="Rule_6">
        <description>Documentação incompleta - MISSING_DOCUMENTATION</description>
        <inputEntry id="IE_6_1"><text>contains(lower(description), "documentação")</text></inputEntry>
        <inputEntry id="IE_6_2"><text>-</text></inputEntry>
        <outputEntry id="OE_6_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_6_acao"><text>"Documentação incompleta - MISSING_DOCUMENTATION"</text></outputEntry>
        <outputEntry id="OE_6_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 7: Código incorreto -->
      <rule id="Rule_7">
        <description>Código incorreto - WRONG_CODE</description>
        <inputEntry id="IE_7_1"><text>contains(lower(description), "código")</text></inputEntry>
        <inputEntry id="IE_7_2"><text>-</text></inputEntry>
        <outputEntry id="OE_7_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_7_acao"><text>"Código incorreto - WRONG_CODE"</text></outputEntry>
        <outputEntry id="OE_7_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 8: Quantidade excedida -->
      <rule id="Rule_8">
        <description>Quantidade excedida - EXCEEDS_QUANTITY</description>
        <inputEntry id="IE_8_1"><text>contains(lower(description), "quantidade")</text></inputEntry>
        <inputEntry id="IE_8_2"><text>-</text></inputEntry>
        <outputEntry id="OE_8_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_8_acao"><text>"Quantidade excedida - EXCEEDS_QUANTITY"</text></outputEntry>
        <outputEntry id="OE_8_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 9: Divergência de preço -->
      <rule id="Rule_9">
        <description>Divergência de preço - PRICE_DIVERGENCE</description>
        <inputEntry id="IE_9_1"><text>contains(lower(description), "preço") or contains(lower(description), "valor")</text></inputEntry>
        <inputEntry id="IE_9_2"><text>-</text></inputEntry>
        <outputEntry id="OE_9_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_9_acao"><text>"Divergência de preço - PRICE_DIVERGENCE"</text></outputEntry>
        <outputEntry id="OE_9_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 10: Validação TISS -->
      <rule id="Rule_10">
        <description>Validação TISS - TISS_VALIDATION</description>
        <inputEntry id="IE_10_1"><text>contains(lower(description), "tiss")</text></inputEntry>
        <inputEntry id="IE_10_2"><text>-</text></inputEntry>
        <outputEntry id="OE_10_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_10_acao"><text>"Validação TISS - TISS_VALIDATION"</text></outputEntry>
        <outputEntry id="OE_10_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="Rule_fallback">
        <description>Caso não enquadrado — revisão obrigatória</description>
        <inputEntry id="IE_fb_1"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao"><text>"Caso requer avaliação manual"</text></outputEntry>
        <outputEntry id="OE_fb_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_glosa_reason_adjudication">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
