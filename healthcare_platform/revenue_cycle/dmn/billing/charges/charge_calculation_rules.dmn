<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_CHARGE_CALCULATION"
             name="Charge Calculation Rules"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Charge Calculation Rules
       Archetype: ADMIN_ADJUDICATION
       Outputs: resultado, acao, risco
       Hit Policy: FIRST
       Worker: calculate_charges_worker.py
  -->

  <decision id="Decision_CHARGE_CALCULATION" name="Charge Calculation Rules">
    <decisionTable id="DecisionTable_CHARGE_CALCULATION" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_PROC_CODE" label="Procedure Code">
        <inputExpression id="InputExpr_PROC_CODE" typeRef="string">
          <text>procedureCode</text>
        </inputExpression>
      </input>

      <input id="Input_QUANTITY" label="Quantity">
        <inputExpression id="InputExpr_QUANTITY" typeRef="number">
          <text>quantity</text>
        </inputExpression>
      </input>

      <input id="Input_UNIT_PRICE" label="Unit Price">
        <inputExpression id="InputExpr_UNIT_PRICE" typeRef="number">
          <text>unitPrice</text>
        </inputExpression>
      </input>

      <input id="Input_MODIFIER_TYPE" label="Modifier Type">
        <inputExpression id="InputExpr_MODIFIER_TYPE" typeRef="string">
          <text>modifierType</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Missing procedure code -->
      <rule id="Rule_PROC_CODE_MISSING">
        <description>Rejeitar codigo de procedimento ausente</description>
        <inputEntry id="IE_PROC_CODE_MISSING_1"><text>null,"","-"</text></inputEntry>
        <inputEntry id="IE_PROC_CODE_MISSING_2"><text>-</text></inputEntry>
        <inputEntry id="IE_PROC_CODE_MISSING_3"><text>-</text></inputEntry>
        <inputEntry id="IE_PROC_CODE_MISSING_4"><text>-</text></inputEntry>
        <outputEntry id="OE_PROC_CODE_MISSING_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_PROC_CODE_MISSING_acao"><text>"Rejeitar codigo de procedimento ausente"</text></outputEntry>
        <outputEntry id="OE_PROC_CODE_MISSING_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Invalid quantity -->
      <rule id="Rule_QUANTITY_INVALID">
        <description>Rejeitar quantidade invalida</description>
        <inputEntry id="IE_QUANTITY_INVALID_1"><text>-</text></inputEntry>
        <inputEntry id="IE_QUANTITY_INVALID_2"><text>&lt;= 0</text></inputEntry>
        <inputEntry id="IE_QUANTITY_INVALID_3"><text>-</text></inputEntry>
        <inputEntry id="IE_QUANTITY_INVALID_4"><text>-</text></inputEntry>
        <outputEntry id="OE_QUANTITY_INVALID_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_QUANTITY_INVALID_acao"><text>"Rejeitar quantidade invalida"</text></outputEntry>
        <outputEntry id="OE_QUANTITY_INVALID_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Negative unit price -->
      <rule id="Rule_UNIT_PRICE_NEGATIVE">
        <description>Rejeitar preco unitario negativo</description>
        <inputEntry id="IE_UNIT_PRICE_NEGATIVE_1"><text>-</text></inputEntry>
        <inputEntry id="IE_UNIT_PRICE_NEGATIVE_2"><text>-</text></inputEntry>
        <inputEntry id="IE_UNIT_PRICE_NEGATIVE_3"><text>&lt; 0</text></inputEntry>
        <inputEntry id="IE_UNIT_PRICE_NEGATIVE_4"><text>-</text></inputEntry>
        <outputEntry id="OE_UNIT_PRICE_NEGATIVE_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_UNIT_PRICE_NEGATIVE_acao"><text>"Rejeitar preco unitario negativo"</text></outputEntry>
        <outputEntry id="OE_UNIT_PRICE_NEGATIVE_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Unknown modifier type -->
      <rule id="Rule_MODIFIER_UNKNOWN">
        <description>Rejeitar tipo de modificador desconhecido</description>
        <inputEntry id="IE_MODIFIER_UNKNOWN_1"><text>-</text></inputEntry>
        <inputEntry id="IE_MODIFIER_UNKNOWN_2"><text>-</text></inputEntry>
        <inputEntry id="IE_MODIFIER_UNKNOWN_3"><text>-</text></inputEntry>
        <inputEntry id="IE_MODIFIER_UNKNOWN_4"><text>not("percentage","fixed","",null)</text></inputEntry>
        <outputEntry id="OE_MODIFIER_UNKNOWN_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_MODIFIER_UNKNOWN_acao"><text>"Rejeitar tipo de modificador desconhecido"</text></outputEntry>
        <outputEntry id="OE_MODIFIER_UNKNOWN_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Apply percentage modifier -->
      <rule id="Rule_MODIFIER_PERCENTAGE">
        <description>Aplicar modificador percentual</description>
        <inputEntry id="IE_MODIFIER_PERCENTAGE_1"><text>-</text></inputEntry>
        <inputEntry id="IE_MODIFIER_PERCENTAGE_2"><text>-</text></inputEntry>
        <inputEntry id="IE_MODIFIER_PERCENTAGE_3"><text>-</text></inputEntry>
        <inputEntry id="IE_MODIFIER_PERCENTAGE_4"><text>"percentage"</text></inputEntry>
        <outputEntry id="OE_MODIFIER_PERCENTAGE_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_MODIFIER_PERCENTAGE_acao"><text>"Aplicar modificador percentual"</text></outputEntry>
        <outputEntry id="OE_MODIFIER_PERCENTAGE_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 6: Apply fixed modifier -->
      <rule id="Rule_MODIFIER_FIXED">
        <description>Aplicar modificador fixo</description>
        <inputEntry id="IE_MODIFIER_FIXED_1"><text>-</text></inputEntry>
        <inputEntry id="IE_MODIFIER_FIXED_2"><text>-</text></inputEntry>
        <inputEntry id="IE_MODIFIER_FIXED_3"><text>-</text></inputEntry>
        <inputEntry id="IE_MODIFIER_FIXED_4"><text>"fixed"</text></inputEntry>
        <outputEntry id="OE_MODIFIER_FIXED_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_MODIFIER_FIXED_acao"><text>"Aplicar modificador fixo"</text></outputEntry>
        <outputEntry id="OE_MODIFIER_FIXED_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 7: Fallback - no modifier -->
      <rule id="Rule_FALLBACK">
        <description>Calcular cobranca sem modificador</description>
        <inputEntry id="IE_FALLBACK_1"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_2"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_3"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_4"><text>-</text></inputEntry>
        <outputEntry id="OE_FALLBACK_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_FALLBACK_acao"><text>"Calcular cobranca sem modificador"</text></outputEntry>
        <outputEntry id="OE_FALLBACK_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_CHARGE_CALCULATION">
      <dmndi:DMNShape id="DMNShape_Decision_CHARGE_CALCULATION" dmnElementRef="Decision_CHARGE_CALCULATION">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
