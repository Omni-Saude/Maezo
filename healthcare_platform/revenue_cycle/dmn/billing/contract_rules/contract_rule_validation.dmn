<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_CONTRACT_RULE_VALIDATION"
             name="Contract Rule Validation"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Contract Rule Validation
       Archetype: ADMIN_ADJUDICATION
       Outputs: resultado, acao, risco
       Hit Policy: FIRST
       Worker: apply_contract_rules_worker.py
  -->

  <decision id="Decision_CONTRACT_RULE_VALIDATION" name="Contract Rule Validation">
    <decisionTable id="DecisionTable_CONTRACT_RULE_VALIDATION" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_COPAY_PCT" label="Copay Percentage">
        <inputExpression id="InputExpr_COPAY_PCT" typeRef="number">
          <text>copayPct</text>
        </inputExpression>
      </input>

      <input id="Input_DEDUCTIBLE" label="Deductible">
        <inputExpression id="InputExpr_DEDUCTIBLE" typeRef="number">
          <text>deductible</text>
        </inputExpression>
      </input>

      <input id="Input_COVERAGE_LIMIT" label="Coverage Limit">
        <inputExpression id="InputExpr_COVERAGE_LIMIT" typeRef="number">
          <text>coverageLimit</text>
        </inputExpression>
      </input>

      <input id="Input_PROC_LIMITS_VALID" label="Procedure Limits Valid">
        <inputExpression id="InputExpr_PROC_LIMITS_VALID" typeRef="boolean">
          <text>procedureLimitsValid</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Invalid copay percentage -->
      <rule id="Rule_COPAY_INVALID">
        <description>Rejeitar percentual de copagamento invalido</description>
        <inputEntry id="IE_COPAY_INVALID_1"><text>&lt; 0 or &gt; 100</text></inputEntry>
        <inputEntry id="IE_COPAY_INVALID_2"><text>-</text></inputEntry>
        <inputEntry id="IE_COPAY_INVALID_3"><text>-</text></inputEntry>
        <inputEntry id="IE_COPAY_INVALID_4"><text>-</text></inputEntry>
        <outputEntry id="OE_COPAY_INVALID_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_COPAY_INVALID_acao"><text>"Rejeitar percentual de copagamento invalido"</text></outputEntry>
        <outputEntry id="OE_COPAY_INVALID_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Negative deductible -->
      <rule id="Rule_DEDUCTIBLE_NEGATIVE">
        <description>Rejeitar franquia negativa</description>
        <inputEntry id="IE_DEDUCTIBLE_NEGATIVE_1"><text>-</text></inputEntry>
        <inputEntry id="IE_DEDUCTIBLE_NEGATIVE_2"><text>&lt; 0</text></inputEntry>
        <inputEntry id="IE_DEDUCTIBLE_NEGATIVE_3"><text>-</text></inputEntry>
        <inputEntry id="IE_DEDUCTIBLE_NEGATIVE_4"><text>-</text></inputEntry>
        <outputEntry id="OE_DEDUCTIBLE_NEGATIVE_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_DEDUCTIBLE_NEGATIVE_acao"><text>"Rejeitar franquia negativa"</text></outputEntry>
        <outputEntry id="OE_DEDUCTIBLE_NEGATIVE_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Negative coverage limit -->
      <rule id="Rule_COVERAGE_NEGATIVE">
        <description>Rejeitar limite de cobertura negativo</description>
        <inputEntry id="IE_COVERAGE_NEGATIVE_1"><text>-</text></inputEntry>
        <inputEntry id="IE_COVERAGE_NEGATIVE_2"><text>-</text></inputEntry>
        <inputEntry id="IE_COVERAGE_NEGATIVE_3"><text>&lt; 0</text></inputEntry>
        <inputEntry id="IE_COVERAGE_NEGATIVE_4"><text>-</text></inputEntry>
        <outputEntry id="OE_COVERAGE_NEGATIVE_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_COVERAGE_NEGATIVE_acao"><text>"Rejeitar limite de cobertura negativo"</text></outputEntry>
        <outputEntry id="OE_COVERAGE_NEGATIVE_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Invalid procedure limits format -->
      <rule id="Rule_PROC_LIMITS_INVALID">
        <description>Rejeitar formato invalido de limites de procedimento</description>
        <inputEntry id="IE_PROC_LIMITS_INVALID_1"><text>-</text></inputEntry>
        <inputEntry id="IE_PROC_LIMITS_INVALID_2"><text>-</text></inputEntry>
        <inputEntry id="IE_PROC_LIMITS_INVALID_3"><text>-</text></inputEntry>
        <inputEntry id="IE_PROC_LIMITS_INVALID_4"><text>false</text></inputEntry>
        <outputEntry id="OE_PROC_LIMITS_INVALID_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_PROC_LIMITS_INVALID_acao"><text>"Rejeitar formato invalido de limites de procedimento"</text></outputEntry>
        <outputEntry id="OE_PROC_LIMITS_INVALID_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Apply default copay -->
      <rule id="Rule_COPAY_DEFAULT">
        <description>Aplicar copagamento padrao 0%</description>
        <inputEntry id="IE_COPAY_DEFAULT_1"><text>null</text></inputEntry>
        <inputEntry id="IE_COPAY_DEFAULT_2"><text>-</text></inputEntry>
        <inputEntry id="IE_COPAY_DEFAULT_3"><text>-</text></inputEntry>
        <inputEntry id="IE_COPAY_DEFAULT_4"><text>-</text></inputEntry>
        <outputEntry id="OE_COPAY_DEFAULT_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_COPAY_DEFAULT_acao"><text>"Aplicar copagamento padrao 0%"</text></outputEntry>
        <outputEntry id="OE_COPAY_DEFAULT_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 6: Apply default deductible -->
      <rule id="Rule_DEDUCTIBLE_DEFAULT">
        <description>Aplicar franquia padrao zero</description>
        <inputEntry id="IE_DEDUCTIBLE_DEFAULT_1"><text>-</text></inputEntry>
        <inputEntry id="IE_DEDUCTIBLE_DEFAULT_2"><text>null</text></inputEntry>
        <inputEntry id="IE_DEDUCTIBLE_DEFAULT_3"><text>-</text></inputEntry>
        <inputEntry id="IE_DEDUCTIBLE_DEFAULT_4"><text>-</text></inputEntry>
        <outputEntry id="OE_DEDUCTIBLE_DEFAULT_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_DEDUCTIBLE_DEFAULT_acao"><text>"Aplicar franquia padrao zero"</text></outputEntry>
        <outputEntry id="OE_DEDUCTIBLE_DEFAULT_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 7: Apply unlimited coverage -->
      <rule id="Rule_COVERAGE_DEFAULT">
        <description>Aplicar cobertura ilimitada</description>
        <inputEntry id="IE_COVERAGE_DEFAULT_1"><text>-</text></inputEntry>
        <inputEntry id="IE_COVERAGE_DEFAULT_2"><text>-</text></inputEntry>
        <inputEntry id="IE_COVERAGE_DEFAULT_3"><text>null</text></inputEntry>
        <inputEntry id="IE_COVERAGE_DEFAULT_4"><text>-</text></inputEntry>
        <outputEntry id="OE_COVERAGE_DEFAULT_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_COVERAGE_DEFAULT_acao"><text>"Aplicar cobertura ilimitada"</text></outputEntry>
        <outputEntry id="OE_COVERAGE_DEFAULT_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 8: Fallback - apply contract rules -->
      <rule id="Rule_FALLBACK">
        <description>Aplicar regras contratuais</description>
        <inputEntry id="IE_FALLBACK_1"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_2"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_3"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_4"><text>-</text></inputEntry>
        <outputEntry id="OE_FALLBACK_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_FALLBACK_acao"><text>"Aplicar regras contratuais"</text></outputEntry>
        <outputEntry id="OE_FALLBACK_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_CONTRACT_RULE_VALIDATION">
      <dmndi:DMNShape id="DMNShape_Decision_CONTRACT_RULE_VALIDATION" dmnElementRef="Decision_CONTRACT_RULE_VALIDATION">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
