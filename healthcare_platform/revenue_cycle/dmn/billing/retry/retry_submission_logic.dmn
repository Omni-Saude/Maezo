<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_RetrySubmission"
             name="Retry Submission Logic"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: retry_submission_logic_worker.py -->

  <decision id="Decision_RetrySubmission" name="Retry Submission Logic">
    <decisionTable id="DecisionTable_RetrySubmission" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_claimId" label="Claim ID">
        <inputExpression id="InputExpr_claimId" typeRef="string">
          <text>claimId</text>
        </inputExpression>
      </input>

      <input id="Input_tissXmlPresent" label="TISS XML Present">
        <inputExpression id="InputExpr_tissXmlPresent" typeRef="boolean">
          <text>tissXmlPresent</text>
        </inputExpression>
      </input>

      <input id="Input_payerId" label="Payer ID">
        <inputExpression id="InputExpr_payerId" typeRef="string">
          <text>payerId</text>
        </inputExpression>
      </input>

      <input id="Input_attemptNumber" label="Attempt Number">
        <inputExpression id="InputExpr_attemptNumber" typeRef="number">
          <text>attemptNumber</text>
        </inputExpression>
      </input>

      <input id="Input_maxAttempts" label="Max Attempts">
        <inputExpression id="InputExpr_maxAttempts" typeRef="number">
          <text>maxAttempts</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Missing claim ID -->
      <rule id="Rule_NoClaimId">
        <description>Rejeitar conta ausente</description>
        <inputEntry id="IE_NoClaimId_1"><text>claimId = null or claimId = ""</text></inputEntry>
        <inputEntry id="IE_NoClaimId_2"><text>-</text></inputEntry>
        <inputEntry id="IE_NoClaimId_3"><text>-</text></inputEntry>
        <inputEntry id="IE_NoClaimId_4"><text>-</text></inputEntry>
        <inputEntry id="IE_NoClaimId_5"><text>-</text></inputEntry>
        <outputEntry id="OE_NoClaimId_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_NoClaimId_acao"><text>"Rejeitar conta ausente"</text></outputEntry>
        <outputEntry id="OE_NoClaimId_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Missing TISS XML -->
      <rule id="Rule_NoTissXml">
        <description>Rejeitar XML TISS ausente</description>
        <inputEntry id="IE_NoTissXml_1"><text>-</text></inputEntry>
        <inputEntry id="IE_NoTissXml_2"><text>tissXmlPresent = false</text></inputEntry>
        <inputEntry id="IE_NoTissXml_3"><text>-</text></inputEntry>
        <inputEntry id="IE_NoTissXml_4"><text>-</text></inputEntry>
        <inputEntry id="IE_NoTissXml_5"><text>-</text></inputEntry>
        <outputEntry id="OE_NoTissXml_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_NoTissXml_acao"><text>"Rejeitar XML TISS ausente"</text></outputEntry>
        <outputEntry id="OE_NoTissXml_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Missing payer ID -->
      <rule id="Rule_NoPayerId">
        <description>Rejeitar operadora ausente</description>
        <inputEntry id="IE_NoPayerId_1"><text>-</text></inputEntry>
        <inputEntry id="IE_NoPayerId_2"><text>-</text></inputEntry>
        <inputEntry id="IE_NoPayerId_3"><text>payerId = null or payerId = ""</text></inputEntry>
        <inputEntry id="IE_NoPayerId_4"><text>-</text></inputEntry>
        <inputEntry id="IE_NoPayerId_5"><text>-</text></inputEntry>
        <outputEntry id="OE_NoPayerId_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_NoPayerId_acao"><text>"Rejeitar operadora ausente"</text></outputEntry>
        <outputEntry id="OE_NoPayerId_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Max attempts reached -->
      <rule id="Rule_MaxAttempts">
        <description>Maximo de tentativas atingido - encerrar</description>
        <inputEntry id="IE_MaxAttempts_1"><text>-</text></inputEntry>
        <inputEntry id="IE_MaxAttempts_2"><text>-</text></inputEntry>
        <inputEntry id="IE_MaxAttempts_3"><text>-</text></inputEntry>
        <inputEntry id="IE_MaxAttempts_4"><text>attemptNumber &gt;= maxAttempts</text></inputEntry>
        <inputEntry id="IE_MaxAttempts_5"><text>-</text></inputEntry>
        <outputEntry id="OE_MaxAttempts_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_MaxAttempts_acao"><text>"Maximo de tentativas atingido - encerrar"</text></outputEntry>
        <outputEntry id="OE_MaxAttempts_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Retry allowed -->
      <rule id="Rule_RetryAllowed">
        <description>Executar tentativa de reenvio</description>
        <inputEntry id="IE_RetryAllowed_1"><text>-</text></inputEntry>
        <inputEntry id="IE_RetryAllowed_2"><text>-</text></inputEntry>
        <inputEntry id="IE_RetryAllowed_3"><text>-</text></inputEntry>
        <inputEntry id="IE_RetryAllowed_4"><text>attemptNumber &lt; maxAttempts</text></inputEntry>
        <inputEntry id="IE_RetryAllowed_5"><text>-</text></inputEntry>
        <outputEntry id="OE_RetryAllowed_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_RetryAllowed_acao"><text>"Executar tentativa de reenvio"</text></outputEntry>
        <outputEntry id="OE_RetryAllowed_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Fallback: Manual review required -->
      <rule id="Rule_Fallback">
        <description>Caso requer avaliacao manual de reenvio</description>
        <inputEntry id="IE_Fallback_1"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_2"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_3"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_4"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_5"><text>-</text></inputEntry>
        <outputEntry id="OE_Fallback_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_Fallback_acao"><text>"Caso requer avaliacao manual de reenvio"</text></outputEntry>
        <outputEntry id="OE_Fallback_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RetrySubmission">
      <dmndi:DMNShape id="DMNShape_RetrySubmission" dmnElementRef="Decision_RetrySubmission">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
