<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_DISCOUNT_APPLICABILITY"
             name="Discount Applicability Rules"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Discount Applicability Rules
       Archetype: ADMIN_ADJUDICATION
       Outputs: resultado, acao, risco
       Hit Policy: FIRST
       Worker: apply_discounts_worker.py
  -->

  <decision id="Decision_DISCOUNT_APPLICABILITY" name="Discount Applicability Rules">
    <decisionTable id="DecisionTable_DISCOUNT_APPLICABILITY" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_DISCOUNT_PCT" label="Discount Percentage">
        <inputExpression id="InputExpr_DISCOUNT_PCT" typeRef="number">
          <text>discountPercentage</text>
        </inputExpression>
      </input>

      <input id="Input_QUANTITY" label="Quantity">
        <inputExpression id="InputExpr_QUANTITY" typeRef="number">
          <text>quantity</text>
        </inputExpression>
      </input>

      <input id="Input_MIN_QUANTITY" label="Minimum Quantity">
        <inputExpression id="InputExpr_MIN_QUANTITY" typeRef="number">
          <text>minQuantity</text>
        </inputExpression>
      </input>

      <input id="Input_MIN_AMOUNT" label="Minimum Amount">
        <inputExpression id="InputExpr_MIN_AMOUNT" typeRef="number">
          <text>minAmount</text>
        </inputExpression>
      </input>

      <input id="Input_TOTAL_AMOUNT" label="Total Amount">
        <inputExpression id="InputExpr_TOTAL_AMOUNT" typeRef="number">
          <text>totalAmount</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Invalid discount percentage -->
      <rule id="Rule_DISCOUNT_INVALID">
        <description>Rejeitar percentual de desconto invalido</description>
        <inputEntry id="IE_DISCOUNT_INVALID_1"><text>&lt; 0 or &gt; 100</text></inputEntry>
        <inputEntry id="IE_DISCOUNT_INVALID_2"><text>-</text></inputEntry>
        <inputEntry id="IE_DISCOUNT_INVALID_3"><text>-</text></inputEntry>
        <inputEntry id="IE_DISCOUNT_INVALID_4"><text>-</text></inputEntry>
        <inputEntry id="IE_DISCOUNT_INVALID_5"><text>-</text></inputEntry>
        <outputEntry id="OE_DISCOUNT_INVALID_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_DISCOUNT_INVALID_acao"><text>"Rejeitar percentual de desconto invalido"</text></outputEntry>
        <outputEntry id="OE_DISCOUNT_INVALID_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Volume bonus >= 100 -->
      <rule id="Rule_VOLUME_BONUS_100">
        <description>Aplicar bonus de volume 50%</description>
        <inputEntry id="IE_VOLUME_BONUS_100_1"><text>-</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_100_2"><text>&gt;= 100</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_100_3"><text>-</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_100_4"><text>-</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_100_5"><text>-</text></inputEntry>
        <outputEntry id="OE_VOLUME_BONUS_100_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_VOLUME_BONUS_100_acao"><text>"Aplicar bonus de volume 50%"</text></outputEntry>
        <outputEntry id="OE_VOLUME_BONUS_100_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Volume bonus >= 50 -->
      <rule id="Rule_VOLUME_BONUS_50">
        <description>Aplicar bonus de volume 30%</description>
        <inputEntry id="IE_VOLUME_BONUS_50_1"><text>-</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_50_2"><text>&gt;= 50</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_50_3"><text>-</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_50_4"><text>-</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_50_5"><text>-</text></inputEntry>
        <outputEntry id="OE_VOLUME_BONUS_50_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_VOLUME_BONUS_50_acao"><text>"Aplicar bonus de volume 30%"</text></outputEntry>
        <outputEntry id="OE_VOLUME_BONUS_50_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Volume bonus >= 20 -->
      <rule id="Rule_VOLUME_BONUS_20">
        <description>Aplicar bonus de volume 15%</description>
        <inputEntry id="IE_VOLUME_BONUS_20_1"><text>-</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_20_2"><text>&gt;= 20</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_20_3"><text>-</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_20_4"><text>-</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_20_5"><text>-</text></inputEntry>
        <outputEntry id="OE_VOLUME_BONUS_20_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_VOLUME_BONUS_20_acao"><text>"Aplicar bonus de volume 15%"</text></outputEntry>
        <outputEntry id="OE_VOLUME_BONUS_20_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Below minimum quantity -->
      <rule id="Rule_MIN_QUANTITY_NOT_MET">
        <description>Quantidade minima nao atingida - pular desconto</description>
        <inputEntry id="IE_MIN_QUANTITY_NOT_MET_1"><text>-</text></inputEntry>
        <inputEntry id="IE_MIN_QUANTITY_NOT_MET_2"><text>&lt; minQuantity</text></inputEntry>
        <inputEntry id="IE_MIN_QUANTITY_NOT_MET_3"><text>-</text></inputEntry>
        <inputEntry id="IE_MIN_QUANTITY_NOT_MET_4"><text>-</text></inputEntry>
        <inputEntry id="IE_MIN_QUANTITY_NOT_MET_5"><text>-</text></inputEntry>
        <outputEntry id="OE_MIN_QUANTITY_NOT_MET_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_MIN_QUANTITY_NOT_MET_acao"><text>"Quantidade minima nao atingida - pular desconto"</text></outputEntry>
        <outputEntry id="OE_MIN_QUANTITY_NOT_MET_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 6: Below minimum amount -->
      <rule id="Rule_MIN_AMOUNT_NOT_MET">
        <description>Valor minimo nao atingido - pular desconto</description>
        <inputEntry id="IE_MIN_AMOUNT_NOT_MET_1"><text>-</text></inputEntry>
        <inputEntry id="IE_MIN_AMOUNT_NOT_MET_2"><text>-</text></inputEntry>
        <inputEntry id="IE_MIN_AMOUNT_NOT_MET_3"><text>-</text></inputEntry>
        <inputEntry id="IE_MIN_AMOUNT_NOT_MET_4"><text>-</text></inputEntry>
        <inputEntry id="IE_MIN_AMOUNT_NOT_MET_5"><text>&lt; minAmount</text></inputEntry>
        <outputEntry id="OE_MIN_AMOUNT_NOT_MET_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_MIN_AMOUNT_NOT_MET_acao"><text>"Valor minimo nao atingido - pular desconto"</text></outputEntry>
        <outputEntry id="OE_MIN_AMOUNT_NOT_MET_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 7: Discount >= 100% requires review -->
      <rule id="Rule_DISCOUNT_FULL">
        <description>Desconto >= 100% requer revisao manual</description>
        <inputEntry id="IE_DISCOUNT_FULL_1"><text>&gt;= 100</text></inputEntry>
        <inputEntry id="IE_DISCOUNT_FULL_2"><text>-</text></inputEntry>
        <inputEntry id="IE_DISCOUNT_FULL_3"><text>-</text></inputEntry>
        <inputEntry id="IE_DISCOUNT_FULL_4"><text>-</text></inputEntry>
        <inputEntry id="IE_DISCOUNT_FULL_5"><text>-</text></inputEntry>
        <outputEntry id="OE_DISCOUNT_FULL_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_DISCOUNT_FULL_acao"><text>"Desconto >= 100% requer revisao manual"</text></outputEntry>
        <outputEntry id="OE_DISCOUNT_FULL_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 8: Fallback - apply base discount -->
      <rule id="Rule_FALLBACK">
        <description>Aplicar desconto base</description>
        <inputEntry id="IE_FALLBACK_1"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_2"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_3"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_4"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_5"><text>-</text></inputEntry>
        <outputEntry id="OE_FALLBACK_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_FALLBACK_acao"><text>"Aplicar desconto base"</text></outputEntry>
        <outputEntry id="OE_FALLBACK_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DISCOUNT_APPLICABILITY">
      <dmndi:DMNShape id="DMNShape_Decision_DISCOUNT_APPLICABILITY" dmnElementRef="Decision_DISCOUNT_APPLICABILITY">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
