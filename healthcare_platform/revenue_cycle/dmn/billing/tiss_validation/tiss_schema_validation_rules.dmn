<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_TissSchemaValidation"
             name="TISS Schema Validation Rules"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: tiss_schema_validation_rules_worker.py -->

  <decision id="Decision_TissSchemaValidation" name="TISS Schema Validation Rules">
    <decisionTable id="DecisionTable_TissSchemaValidation" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_tissXmlPresent" label="TISS XML Present">
        <inputExpression id="InputExpr_tissXmlPresent" typeRef="boolean">
          <text>tissXmlPresent</text>
        </inputExpression>
      </input>

      <input id="Input_guideType" label="Guide Type">
        <inputExpression id="InputExpr_guideType" typeRef="string">
          <text>guideType</text>
        </inputExpression>
      </input>

      <input id="Input_validationErrorsCount" label="Validation Errors Count">
        <inputExpression id="InputExpr_validationErrorsCount" typeRef="number">
          <text>validationErrorsCount</text>
        </inputExpression>
      </input>

      <input id="Input_hasCriticalErrors" label="Has Critical Errors">
        <inputExpression id="InputExpr_hasCriticalErrors" typeRef="boolean">
          <text>hasCriticalErrors</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Missing TISS XML -->
      <rule id="Rule_NoTissXml">
        <description>Rejeitar XML TISS ausente</description>
        <inputEntry id="IE_NoTissXml_1"><text>tissXmlPresent = false</text></inputEntry>
        <inputEntry id="IE_NoTissXml_2"><text>-</text></inputEntry>
        <inputEntry id="IE_NoTissXml_3"><text>-</text></inputEntry>
        <inputEntry id="IE_NoTissXml_4"><text>-</text></inputEntry>
        <outputEntry id="OE_NoTissXml_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_NoTissXml_acao"><text>"Rejeitar XML TISS ausente"</text></outputEntry>
        <outputEntry id="OE_NoTissXml_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Missing guide type -->
      <rule id="Rule_NoGuideType">
        <description>Rejeitar tipo de guia ausente</description>
        <inputEntry id="IE_NoGuideType_1"><text>-</text></inputEntry>
        <inputEntry id="IE_NoGuideType_2"><text>guideType = null or guideType = ""</text></inputEntry>
        <inputEntry id="IE_NoGuideType_3"><text>-</text></inputEntry>
        <inputEntry id="IE_NoGuideType_4"><text>-</text></inputEntry>
        <outputEntry id="OE_NoGuideType_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_NoGuideType_acao"><text>"Rejeitar tipo de guia ausente"</text></outputEntry>
        <outputEntry id="OE_NoGuideType_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Invalid guide type -->
      <rule id="Rule_InvalidGuideType">
        <description>Rejeitar tipo de guia invalido</description>
        <inputEntry id="IE_InvalidGuideType_1"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidGuideType_2"><text>not(guideType in ("sp_sadt","consultation","admission","extension","honorarios","summary"))</text></inputEntry>
        <inputEntry id="IE_InvalidGuideType_3"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidGuideType_4"><text>-</text></inputEntry>
        <outputEntry id="OE_InvalidGuideType_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_InvalidGuideType_acao"><text>"Rejeitar tipo de guia invalido"</text></outputEntry>
        <outputEntry id="OE_InvalidGuideType_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Critical schema errors -->
      <rule id="Rule_CriticalErrors">
        <description>Erros criticos de schema encontrados</description>
        <inputEntry id="IE_CriticalErrors_1"><text>-</text></inputEntry>
        <inputEntry id="IE_CriticalErrors_2"><text>-</text></inputEntry>
        <inputEntry id="IE_CriticalErrors_3"><text>-</text></inputEntry>
        <inputEntry id="IE_CriticalErrors_4"><text>hasCriticalErrors = true</text></inputEntry>
        <outputEntry id="OE_CriticalErrors_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_CriticalErrors_acao"><text>"Erros criticos de schema encontrados"</text></outputEntry>
        <outputEntry id="OE_CriticalErrors_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Validation warnings -->
      <rule id="Rule_ValidationWarnings">
        <description>Avisos de validacao encontrados - verificar</description>
        <inputEntry id="IE_ValidationWarnings_1"><text>-</text></inputEntry>
        <inputEntry id="IE_ValidationWarnings_2"><text>-</text></inputEntry>
        <inputEntry id="IE_ValidationWarnings_3"><text>validationErrorsCount &gt; 0</text></inputEntry>
        <inputEntry id="IE_ValidationWarnings_4"><text>-</text></inputEntry>
        <outputEntry id="OE_ValidationWarnings_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_ValidationWarnings_acao"><text>"Avisos de validacao encontrados - verificar"</text></outputEntry>
        <outputEntry id="OE_ValidationWarnings_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Fallback: Validation passed -->
      <rule id="Rule_Fallback">
        <description>Schema TISS validado com sucesso</description>
        <inputEntry id="IE_Fallback_1"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_2"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_3"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_4"><text>-</text></inputEntry>
        <outputEntry id="OE_Fallback_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Fallback_acao"><text>"Schema TISS validado com sucesso"</text></outputEntry>
        <outputEntry id="OE_Fallback_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_TissSchemaValidation">
      <dmndi:DMNShape id="DMNShape_TissSchemaValidation" dmnElementRef="Decision_TissSchemaValidation">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
