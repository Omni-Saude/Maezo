<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_ClaimValidation"
             name="Claim Validation Rules"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: claim_validation_rules_worker.py -->

  <decision id="Decision_ClaimValidation" name="Claim Validation Rules">
    <decisionTable id="DecisionTable_ClaimValidation" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_claimId" label="Claim ID">
        <inputExpression id="InputExpr_claimId" typeRef="string">
          <text>claimId</text>
        </inputExpression>
      </input>

      <input id="Input_claimDataValid" label="Claim Data Valid">
        <inputExpression id="InputExpr_claimDataValid" typeRef="boolean">
          <text>claimDataValid</text>
        </inputExpression>
      </input>

      <input id="Input_requiredFieldsPresent" label="Required Fields Present">
        <inputExpression id="InputExpr_requiredFieldsPresent" typeRef="boolean">
          <text>requiredFieldsPresent</text>
        </inputExpression>
      </input>

      <input id="Input_itemsCount" label="Items Count">
        <inputExpression id="InputExpr_itemsCount" typeRef="number">
          <text>itemsCount</text>
        </inputExpression>
      </input>

      <input id="Input_itemsValid" label="Items Valid">
        <inputExpression id="InputExpr_itemsValid" typeRef="boolean">
          <text>itemsValid</text>
        </inputExpression>
      </input>

      <input id="Input_totalConsistent" label="Total Consistent">
        <inputExpression id="InputExpr_totalConsistent" typeRef="boolean">
          <text>totalConsistent</text>
        </inputExpression>
      </input>

      <input id="Input_hasDuplicates" label="Has Duplicates">
        <inputExpression id="InputExpr_hasDuplicates" typeRef="boolean">
          <text>hasDuplicates</text>
        </inputExpression>
      </input>

      <input id="Input_authorizationRequired" label="Authorization Required">
        <inputExpression id="InputExpr_authorizationRequired" typeRef="boolean">
          <text>authorizationRequired</text>
        </inputExpression>
      </input>

      <input id="Input_authorizationPresent" label="Authorization Present">
        <inputExpression id="InputExpr_authorizationPresent" typeRef="boolean">
          <text>authorizationPresent</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Missing claim ID -->
      <rule id="Rule_NoClaimId">
        <description>Rejeitar ID da conta ausente</description>
        <inputEntry id="IE_NoClaimId_1"><text>claimId = null or claimId = ""</text></inputEntry>
        <inputEntry id="IE_NoClaimId_2"><text>-</text></inputEntry>
        <inputEntry id="IE_NoClaimId_3"><text>-</text></inputEntry>
        <inputEntry id="IE_NoClaimId_4"><text>-</text></inputEntry>
        <inputEntry id="IE_NoClaimId_5"><text>-</text></inputEntry>
        <inputEntry id="IE_NoClaimId_6"><text>-</text></inputEntry>
        <inputEntry id="IE_NoClaimId_7"><text>-</text></inputEntry>
        <inputEntry id="IE_NoClaimId_8"><text>-</text></inputEntry>
        <inputEntry id="IE_NoClaimId_9"><text>-</text></inputEntry>
        <outputEntry id="OE_NoClaimId_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_NoClaimId_acao"><text>"Rejeitar ID da conta ausente"</text></outputEntry>
        <outputEntry id="OE_NoClaimId_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Invalid claim data format -->
      <rule id="Rule_InvalidData">
        <description>Rejeitar formato de dados invalido</description>
        <inputEntry id="IE_InvalidData_1"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidData_2"><text>claimDataValid = false</text></inputEntry>
        <inputEntry id="IE_InvalidData_3"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidData_4"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidData_5"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidData_6"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidData_7"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidData_8"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidData_9"><text>-</text></inputEntry>
        <outputEntry id="OE_InvalidData_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_InvalidData_acao"><text>"Rejeitar formato de dados invalido"</text></outputEntry>
        <outputEntry id="OE_InvalidData_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Missing required fields -->
      <rule id="Rule_MissingFields">
        <description>Campos obrigatorios ausentes</description>
        <inputEntry id="IE_MissingFields_1"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingFields_2"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingFields_3"><text>requiredFieldsPresent = false</text></inputEntry>
        <inputEntry id="IE_MissingFields_4"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingFields_5"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingFields_6"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingFields_7"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingFields_8"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingFields_9"><text>-</text></inputEntry>
        <outputEntry id="OE_MissingFields_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_MissingFields_acao"><text>"Campos obrigatorios ausentes"</text></outputEntry>
        <outputEntry id="OE_MissingFields_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Empty items list -->
      <rule id="Rule_EmptyItems">
        <description>Rejeitar lista de itens vazia</description>
        <inputEntry id="IE_EmptyItems_1"><text>-</text></inputEntry>
        <inputEntry id="IE_EmptyItems_2"><text>-</text></inputEntry>
        <inputEntry id="IE_EmptyItems_3"><text>-</text></inputEntry>
        <inputEntry id="IE_EmptyItems_4"><text>itemsCount &lt;= 0</text></inputEntry>
        <inputEntry id="IE_EmptyItems_5"><text>-</text></inputEntry>
        <inputEntry id="IE_EmptyItems_6"><text>-</text></inputEntry>
        <inputEntry id="IE_EmptyItems_7"><text>-</text></inputEntry>
        <inputEntry id="IE_EmptyItems_8"><text>-</text></inputEntry>
        <inputEntry id="IE_EmptyItems_9"><text>-</text></inputEntry>
        <outputEntry id="OE_EmptyItems_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_EmptyItems_acao"><text>"Rejeitar lista de itens vazia"</text></outputEntry>
        <outputEntry id="OE_EmptyItems_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Invalid items -->
      <rule id="Rule_InvalidItems">
        <description>Itens com dados invalidos (quantidade, preco, codigo)</description>
        <inputEntry id="IE_InvalidItems_1"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidItems_2"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidItems_3"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidItems_4"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidItems_5"><text>itemsValid = false</text></inputEntry>
        <inputEntry id="IE_InvalidItems_6"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidItems_7"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidItems_8"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidItems_9"><text>-</text></inputEntry>
        <outputEntry id="OE_InvalidItems_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_InvalidItems_acao"><text>"Itens com dados invalidos (quantidade, preco, codigo)"</text></outputEntry>
        <outputEntry id="OE_InvalidItems_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 6: Missing required authorization -->
      <rule id="Rule_MissingAuth">
        <description>Autorizacao obrigatoria ausente para guia de internacao/prorrogacao</description>
        <inputEntry id="IE_MissingAuth_1"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingAuth_2"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingAuth_3"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingAuth_4"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingAuth_5"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingAuth_6"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingAuth_7"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingAuth_8"><text>authorizationRequired = true</text></inputEntry>
        <inputEntry id="IE_MissingAuth_9"><text>authorizationPresent = false</text></inputEntry>
        <outputEntry id="OE_MissingAuth_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_MissingAuth_acao"><text>"Autorizacao obrigatoria ausente para guia de internacao/prorrogacao"</text></outputEntry>
        <outputEntry id="OE_MissingAuth_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 7: Inconsistent total -->
      <rule id="Rule_InconsistentTotal">
        <description>Total da conta inconsistente com soma dos itens</description>
        <inputEntry id="IE_InconsistentTotal_1"><text>-</text></inputEntry>
        <inputEntry id="IE_InconsistentTotal_2"><text>-</text></inputEntry>
        <inputEntry id="IE_InconsistentTotal_3"><text>-</text></inputEntry>
        <inputEntry id="IE_InconsistentTotal_4"><text>-</text></inputEntry>
        <inputEntry id="IE_InconsistentTotal_5"><text>-</text></inputEntry>
        <inputEntry id="IE_InconsistentTotal_6"><text>totalConsistent = false</text></inputEntry>
        <inputEntry id="IE_InconsistentTotal_7"><text>-</text></inputEntry>
        <inputEntry id="IE_InconsistentTotal_8"><text>-</text></inputEntry>
        <inputEntry id="IE_InconsistentTotal_9"><text>-</text></inputEntry>
        <outputEntry id="OE_InconsistentTotal_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_InconsistentTotal_acao"><text>"Total da conta inconsistente com soma dos itens"</text></outputEntry>
        <outputEntry id="OE_InconsistentTotal_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 8: Duplicate items detected -->
      <rule id="Rule_Duplicates">
        <description>Itens duplicados detectados - requer revisao</description>
        <inputEntry id="IE_Duplicates_1"><text>-</text></inputEntry>
        <inputEntry id="IE_Duplicates_2"><text>-</text></inputEntry>
        <inputEntry id="IE_Duplicates_3"><text>-</text></inputEntry>
        <inputEntry id="IE_Duplicates_4"><text>-</text></inputEntry>
        <inputEntry id="IE_Duplicates_5"><text>-</text></inputEntry>
        <inputEntry id="IE_Duplicates_6"><text>-</text></inputEntry>
        <inputEntry id="IE_Duplicates_7"><text>hasDuplicates = true</text></inputEntry>
        <inputEntry id="IE_Duplicates_8"><text>-</text></inputEntry>
        <inputEntry id="IE_Duplicates_9"><text>-</text></inputEntry>
        <outputEntry id="OE_Duplicates_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_Duplicates_acao"><text>"Itens duplicados detectados - requer revisao"</text></outputEntry>
        <outputEntry id="OE_Duplicates_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Fallback: Validation passed -->
      <rule id="Rule_Fallback">
        <description>Conta validada - pronta para submissao</description>
        <inputEntry id="IE_Fallback_1"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_2"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_3"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_4"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_5"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_6"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_7"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_8"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_9"><text>-</text></inputEntry>
        <outputEntry id="OE_Fallback_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Fallback_acao"><text>"Conta validada - pronta para submissao"</text></outputEntry>
        <outputEntry id="OE_Fallback_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ClaimValidation">
      <dmndi:DMNShape id="DMNShape_ClaimValidation" dmnElementRef="Decision_ClaimValidation">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
