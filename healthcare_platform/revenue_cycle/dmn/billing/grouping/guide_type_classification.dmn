<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_GUIDE_TYPE_CLASSIFICATION"
             name="Guide Type Classification"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Guide Type Classification
       Archetype: ADMIN_ADJUDICATION
       Outputs: resultado, acao, risco
       Hit Policy: FIRST
       Worker: group_by_guide_worker.py
  -->

  <decision id="Decision_GUIDE_TYPE_CLASSIFICATION" name="Guide Type Classification">
    <decisionTable id="DecisionTable_GUIDE_TYPE_CLASSIFICATION" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_PROC_TYPE" label="Procedure Type">
        <inputExpression id="InputExpr_PROC_TYPE" typeRef="string">
          <text>procType</text>
        </inputExpression>
      </input>

      <input id="Input_PROC_CODE" label="Procedure Code">
        <inputExpression id="InputExpr_PROC_CODE" typeRef="string">
          <text>procCode</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Missing procedure type -->
      <rule id="Rule_PROC_TYPE_MISSING">
        <description>Rejeitar tipo de procedimento ausente</description>
        <inputEntry id="IE_PROC_TYPE_MISSING_1"><text>null,"","-"</text></inputEntry>
        <inputEntry id="IE_PROC_TYPE_MISSING_2"><text>-</text></inputEntry>
        <outputEntry id="OE_PROC_TYPE_MISSING_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_PROC_TYPE_MISSING_acao"><text>"Rejeitar tipo de procedimento ausente"</text></outputEntry>
        <outputEntry id="OE_PROC_TYPE_MISSING_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Missing procedure code -->
      <rule id="Rule_PROC_CODE_MISSING">
        <description>Rejeitar codigo de procedimento ausente</description>
        <inputEntry id="IE_PROC_CODE_MISSING_1"><text>-</text></inputEntry>
        <inputEntry id="IE_PROC_CODE_MISSING_2"><text>null,"","-"</text></inputEntry>
        <outputEntry id="OE_PROC_CODE_MISSING_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_PROC_CODE_MISSING_acao"><text>"Rejeitar codigo de procedimento ausente"</text></outputEntry>
        <outputEntry id="OE_PROC_CODE_MISSING_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Consultation type -->
      <rule id="Rule_TYPE_CONSULTATION">
        <description>Agrupar como CONSULTATION</description>
        <inputEntry id="IE_TYPE_CONSULTATION_1"><text>"consultation"</text></inputEntry>
        <inputEntry id="IE_TYPE_CONSULTATION_2"><text>-</text></inputEntry>
        <outputEntry id="OE_TYPE_CONSULTATION_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_TYPE_CONSULTATION_acao"><text>"Agrupar como CONSULTATION"</text></outputEntry>
        <outputEntry id="OE_TYPE_CONSULTATION_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Exam type -->
      <rule id="Rule_TYPE_EXAM">
        <description>Agrupar como SP_SADT</description>
        <inputEntry id="IE_TYPE_EXAM_1"><text>"exam"</text></inputEntry>
        <inputEntry id="IE_TYPE_EXAM_2"><text>-</text></inputEntry>
        <outputEntry id="OE_TYPE_EXAM_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_TYPE_EXAM_acao"><text>"Agrupar como SP_SADT"</text></outputEntry>
        <outputEntry id="OE_TYPE_EXAM_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Surgery type -->
      <rule id="Rule_TYPE_SURGERY">
        <description>Agrupar como SP_SADT</description>
        <inputEntry id="IE_TYPE_SURGERY_1"><text>"surgery"</text></inputEntry>
        <inputEntry id="IE_TYPE_SURGERY_2"><text>-</text></inputEntry>
        <outputEntry id="OE_TYPE_SURGERY_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_TYPE_SURGERY_acao"><text>"Agrupar como SP_SADT"</text></outputEntry>
        <outputEntry id="OE_TYPE_SURGERY_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 6: Admission type -->
      <rule id="Rule_TYPE_ADMISSION">
        <description>Agrupar como ADMISSION</description>
        <inputEntry id="IE_TYPE_ADMISSION_1"><text>"admission"</text></inputEntry>
        <inputEntry id="IE_TYPE_ADMISSION_2"><text>-</text></inputEntry>
        <outputEntry id="OE_TYPE_ADMISSION_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_TYPE_ADMISSION_acao"><text>"Agrupar como ADMISSION"</text></outputEntry>
        <outputEntry id="OE_TYPE_ADMISSION_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 7: Extension type -->
      <rule id="Rule_TYPE_EXTENSION">
        <description>Agrupar como EXTENSION</description>
        <inputEntry id="IE_TYPE_EXTENSION_1"><text>"extension"</text></inputEntry>
        <inputEntry id="IE_TYPE_EXTENSION_2"><text>-</text></inputEntry>
        <outputEntry id="OE_TYPE_EXTENSION_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_TYPE_EXTENSION_acao"><text>"Agrupar como EXTENSION"</text></outputEntry>
        <outputEntry id="OE_TYPE_EXTENSION_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 8: Honorarios type -->
      <rule id="Rule_TYPE_HONORARIOS">
        <description>Agrupar como HONORARIOS</description>
        <inputEntry id="IE_TYPE_HONORARIOS_1"><text>"honorarios"</text></inputEntry>
        <inputEntry id="IE_TYPE_HONORARIOS_2"><text>-</text></inputEntry>
        <outputEntry id="OE_TYPE_HONORARIOS_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_TYPE_HONORARIOS_acao"><text>"Agrupar como HONORARIOS"</text></outputEntry>
        <outputEntry id="OE_TYPE_HONORARIOS_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 9: Code starts with 1 (consultation) -->
      <rule id="Rule_CODE_PREFIX_1">
        <description>Agrupar como CONSULTATION (baseado no codigo)</description>
        <inputEntry id="IE_CODE_PREFIX_1_1"><text>-</text></inputEntry>
        <inputEntry id="IE_CODE_PREFIX_1_2"><text>starts with(.,"1")</text></inputEntry>
        <outputEntry id="OE_CODE_PREFIX_1_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_CODE_PREFIX_1_acao"><text>"Agrupar como CONSULTATION (baseado no codigo)"</text></outputEntry>
        <outputEntry id="OE_CODE_PREFIX_1_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 10: Code starts with 2 (SP_SADT) -->
      <rule id="Rule_CODE_PREFIX_2">
        <description>Agrupar como SP_SADT (baseado no codigo)</description>
        <inputEntry id="IE_CODE_PREFIX_2_1"><text>-</text></inputEntry>
        <inputEntry id="IE_CODE_PREFIX_2_2"><text>starts with(.,"2")</text></inputEntry>
        <outputEntry id="OE_CODE_PREFIX_2_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_CODE_PREFIX_2_acao"><text>"Agrupar como SP_SADT (baseado no codigo)"</text></outputEntry>
        <outputEntry id="OE_CODE_PREFIX_2_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 11: Code starts with 3 (SP_SADT) -->
      <rule id="Rule_CODE_PREFIX_3">
        <description>Agrupar como SP_SADT (baseado no codigo)</description>
        <inputEntry id="IE_CODE_PREFIX_3_1"><text>-</text></inputEntry>
        <inputEntry id="IE_CODE_PREFIX_3_2"><text>starts with(.,"3")</text></inputEntry>
        <outputEntry id="OE_CODE_PREFIX_3_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_CODE_PREFIX_3_acao"><text>"Agrupar como SP_SADT (baseado no codigo)"</text></outputEntry>
        <outputEntry id="OE_CODE_PREFIX_3_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 12: Code starts with 4 (SP_SADT) -->
      <rule id="Rule_CODE_PREFIX_4">
        <description>Agrupar como SP_SADT (baseado no codigo)</description>
        <inputEntry id="IE_CODE_PREFIX_4_1"><text>-</text></inputEntry>
        <inputEntry id="IE_CODE_PREFIX_4_2"><text>starts with(.,"4")</text></inputEntry>
        <outputEntry id="OE_CODE_PREFIX_4_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_CODE_PREFIX_4_acao"><text>"Agrupar como SP_SADT (baseado no codigo)"</text></outputEntry>
        <outputEntry id="OE_CODE_PREFIX_4_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 13: Fallback - unknown type, default to SP_SADT with review -->
      <rule id="Rule_FALLBACK">
        <description>Tipo desconhecido - padrao SP_SADT com revisao</description>
        <inputEntry id="IE_FALLBACK_1"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_2"><text>-</text></inputEntry>
        <outputEntry id="OE_FALLBACK_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_FALLBACK_acao"><text>"Tipo desconhecido - padrao SP_SADT com revisao"</text></outputEntry>
        <outputEntry id="OE_FALLBACK_risco"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_GUIDE_TYPE_CLASSIFICATION">
      <dmndi:DMNShape id="DMNShape_Decision_GUIDE_TYPE_CLASSIFICATION" dmnElementRef="Decision_GUIDE_TYPE_CLASSIFICATION">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
