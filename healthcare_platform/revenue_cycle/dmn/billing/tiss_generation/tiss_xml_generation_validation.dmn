<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_TISS_XML_GENERATION"
             name="TISS XML Generation Validation"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: TISS XML Generation Validation
       Archetype: ADMIN_ADJUDICATION
       Outputs: resultado, acao, risco
       Hit Policy: FIRST
       Worker: generate_tiss_xml_worker.py
  -->

  <decision id="Decision_TISS_XML_GENERATION" name="TISS XML Generation Validation">
    <decisionTable id="DecisionTable_TISS_XML_GENERATION" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_CLAIM_DATA_PRESENT" label="Claim Data Present">
        <inputExpression id="InputExpr_CLAIM_DATA_PRESENT" typeRef="boolean">
          <text>claimDataPresent</text>
        </inputExpression>
      </input>

      <input id="Input_PAYER_ID" label="Payer ID">
        <inputExpression id="InputExpr_PAYER_ID" typeRef="string">
          <text>payerId</text>
        </inputExpression>
      </input>

      <input id="Input_PROVIDER_ID" label="Provider ID">
        <inputExpression id="InputExpr_PROVIDER_ID" typeRef="string">
          <text>providerId</text>
        </inputExpression>
      </input>

      <input id="Input_PATIENT_ID" label="Patient ID">
        <inputExpression id="InputExpr_PATIENT_ID" typeRef="string">
          <text>patientId</text>
        </inputExpression>
      </input>

      <input id="Input_GUIDE_TYPE" label="Guide Type">
        <inputExpression id="InputExpr_GUIDE_TYPE" typeRef="string">
          <text>guideType</text>
        </inputExpression>
      </input>

      <input id="Input_XML_LENGTH" label="XML Length">
        <inputExpression id="InputExpr_XML_LENGTH" typeRef="number">
          <text>xmlLength</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Missing claim data -->
      <rule id="Rule_CLAIM_DATA_MISSING">
        <description>Rejeitar dados da conta ausentes</description>
        <inputEntry id="IE_CLAIM_DATA_MISSING_1"><text>false</text></inputEntry>
        <inputEntry id="IE_CLAIM_DATA_MISSING_2"><text>-</text></inputEntry>
        <inputEntry id="IE_CLAIM_DATA_MISSING_3"><text>-</text></inputEntry>
        <inputEntry id="IE_CLAIM_DATA_MISSING_4"><text>-</text></inputEntry>
        <inputEntry id="IE_CLAIM_DATA_MISSING_5"><text>-</text></inputEntry>
        <inputEntry id="IE_CLAIM_DATA_MISSING_6"><text>-</text></inputEntry>
        <outputEntry id="OE_CLAIM_DATA_MISSING_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_CLAIM_DATA_MISSING_acao"><text>"Rejeitar dados da conta ausentes"</text></outputEntry>
        <outputEntry id="OE_CLAIM_DATA_MISSING_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Missing payer ID -->
      <rule id="Rule_PAYER_MISSING">
        <description>Rejeitar operadora ausente</description>
        <inputEntry id="IE_PAYER_MISSING_1"><text>-</text></inputEntry>
        <inputEntry id="IE_PAYER_MISSING_2"><text>null,"","-"</text></inputEntry>
        <inputEntry id="IE_PAYER_MISSING_3"><text>-</text></inputEntry>
        <inputEntry id="IE_PAYER_MISSING_4"><text>-</text></inputEntry>
        <inputEntry id="IE_PAYER_MISSING_5"><text>-</text></inputEntry>
        <inputEntry id="IE_PAYER_MISSING_6"><text>-</text></inputEntry>
        <outputEntry id="OE_PAYER_MISSING_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_PAYER_MISSING_acao"><text>"Rejeitar operadora ausente"</text></outputEntry>
        <outputEntry id="OE_PAYER_MISSING_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Missing provider ID -->
      <rule id="Rule_PROVIDER_MISSING">
        <description>Rejeitar prestador ausente</description>
        <inputEntry id="IE_PROVIDER_MISSING_1"><text>-</text></inputEntry>
        <inputEntry id="IE_PROVIDER_MISSING_2"><text>-</text></inputEntry>
        <inputEntry id="IE_PROVIDER_MISSING_3"><text>null,"","-"</text></inputEntry>
        <inputEntry id="IE_PROVIDER_MISSING_4"><text>-</text></inputEntry>
        <inputEntry id="IE_PROVIDER_MISSING_5"><text>-</text></inputEntry>
        <inputEntry id="IE_PROVIDER_MISSING_6"><text>-</text></inputEntry>
        <outputEntry id="OE_PROVIDER_MISSING_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_PROVIDER_MISSING_acao"><text>"Rejeitar prestador ausente"</text></outputEntry>
        <outputEntry id="OE_PROVIDER_MISSING_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Missing patient ID -->
      <rule id="Rule_PATIENT_MISSING">
        <description>Rejeitar paciente ausente</description>
        <inputEntry id="IE_PATIENT_MISSING_1"><text>-</text></inputEntry>
        <inputEntry id="IE_PATIENT_MISSING_2"><text>-</text></inputEntry>
        <inputEntry id="IE_PATIENT_MISSING_3"><text>-</text></inputEntry>
        <inputEntry id="IE_PATIENT_MISSING_4"><text>null,"","-"</text></inputEntry>
        <inputEntry id="IE_PATIENT_MISSING_5"><text>-</text></inputEntry>
        <inputEntry id="IE_PATIENT_MISSING_6"><text>-</text></inputEntry>
        <outputEntry id="OE_PATIENT_MISSING_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_PATIENT_MISSING_acao"><text>"Rejeitar paciente ausente"</text></outputEntry>
        <outputEntry id="OE_PATIENT_MISSING_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Invalid guide type -->
      <rule id="Rule_GUIDE_TYPE_INVALID">
        <description>Rejeitar tipo de guia invalido</description>
        <inputEntry id="IE_GUIDE_TYPE_INVALID_1"><text>-</text></inputEntry>
        <inputEntry id="IE_GUIDE_TYPE_INVALID_2"><text>-</text></inputEntry>
        <inputEntry id="IE_GUIDE_TYPE_INVALID_3"><text>-</text></inputEntry>
        <inputEntry id="IE_GUIDE_TYPE_INVALID_4"><text>-</text></inputEntry>
        <inputEntry id="IE_GUIDE_TYPE_INVALID_5"><text>not("sp_sadt","consultation","admission","extension","honorarios","summary")</text></inputEntry>
        <inputEntry id="IE_GUIDE_TYPE_INVALID_6"><text>-</text></inputEntry>
        <outputEntry id="OE_GUIDE_TYPE_INVALID_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_GUIDE_TYPE_INVALID_acao"><text>"Rejeitar tipo de guia invalido"</text></outputEntry>
        <outputEntry id="OE_GUIDE_TYPE_INVALID_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 6: Empty XML -->
      <rule id="Rule_XML_EMPTY">
        <description>Rejeitar XML vazio apos geracao</description>
        <inputEntry id="IE_XML_EMPTY_1"><text>-</text></inputEntry>
        <inputEntry id="IE_XML_EMPTY_2"><text>-</text></inputEntry>
        <inputEntry id="IE_XML_EMPTY_3"><text>-</text></inputEntry>
        <inputEntry id="IE_XML_EMPTY_4"><text>-</text></inputEntry>
        <inputEntry id="IE_XML_EMPTY_5"><text>-</text></inputEntry>
        <inputEntry id="IE_XML_EMPTY_6"><text>&lt;= 0</text></inputEntry>
        <outputEntry id="OE_XML_EMPTY_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_XML_EMPTY_acao"><text>"Rejeitar XML vazio apos geracao"</text></outputEntry>
        <outputEntry id="OE_XML_EMPTY_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 7: Fallback - XML generated successfully -->
      <rule id="Rule_FALLBACK">
        <description>XML TISS gerado com sucesso - prosseguir para submissao</description>
        <inputEntry id="IE_FALLBACK_1"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_2"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_3"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_4"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_5"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_6"><text>-</text></inputEntry>
        <outputEntry id="OE_FALLBACK_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_FALLBACK_acao"><text>"XML TISS gerado com sucesso - prosseguir para submissao"</text></outputEntry>
        <outputEntry id="OE_FALLBACK_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_TISS_XML_GENERATION">
      <dmndi:DMNShape id="DMNShape_Decision_TISS_XML_GENERATION" dmnElementRef="Decision_TISS_XML_GENERATION">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
