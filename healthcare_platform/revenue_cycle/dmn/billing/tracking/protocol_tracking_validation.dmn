<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_ProtocolTracking"
             name="Protocol Tracking Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: protocol_tracking_validation_worker.py -->

  <decision id="Decision_ProtocolTracking" name="Protocol Tracking Validation">
    <decisionTable id="DecisionTable_ProtocolTracking" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_claimId" label="Claim ID">
        <inputExpression id="InputExpr_claimId" typeRef="string">
          <text>claimId</text>
        </inputExpression>
      </input>

      <input id="Input_protocolNumber" label="Protocol Number">
        <inputExpression id="InputExpr_protocolNumber" typeRef="string">
          <text>protocolNumber</text>
        </inputExpression>
      </input>

      <input id="Input_payerId" label="Payer ID">
        <inputExpression id="InputExpr_payerId" typeRef="string">
          <text>payerId</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Missing claim ID -->
      <rule id="Rule_NoClaimId">
        <description>Rejeitar conta ausente</description>
        <inputEntry id="IE_NoClaimId_1"><text>claimId = null or claimId = ""</text></inputEntry>
        <inputEntry id="IE_NoClaimId_2"><text>-</text></inputEntry>
        <inputEntry id="IE_NoClaimId_3"><text>-</text></inputEntry>
        <outputEntry id="OE_NoClaimId_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_NoClaimId_acao"><text>"Rejeitar conta ausente"</text></outputEntry>
        <outputEntry id="OE_NoClaimId_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Missing protocol number -->
      <rule id="Rule_NoProtocol">
        <description>Rejeitar protocolo ausente</description>
        <inputEntry id="IE_NoProtocol_1"><text>-</text></inputEntry>
        <inputEntry id="IE_NoProtocol_2"><text>protocolNumber = null or protocolNumber = ""</text></inputEntry>
        <inputEntry id="IE_NoProtocol_3"><text>-</text></inputEntry>
        <outputEntry id="OE_NoProtocol_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_NoProtocol_acao"><text>"Rejeitar protocolo ausente"</text></outputEntry>
        <outputEntry id="OE_NoProtocol_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Missing payer ID -->
      <rule id="Rule_NoPayerId">
        <description>Rejeitar operadora ausente</description>
        <inputEntry id="IE_NoPayerId_1"><text>-</text></inputEntry>
        <inputEntry id="IE_NoPayerId_2"><text>-</text></inputEntry>
        <inputEntry id="IE_NoPayerId_3"><text>payerId = null or payerId = ""</text></inputEntry>
        <outputEntry id="OE_NoPayerId_res"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_NoPayerId_acao"><text>"Rejeitar operadora ausente"</text></outputEntry>
        <outputEntry id="OE_NoPayerId_risco"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Fallback: Tracking approved -->
      
      <rule id="Rule_HighRisk">
        <description>Risco alto detectado - revisao obrigatoria</description>
        <inputEntry id="IE_HighRisk_1"><text>-</text></inputEntry>
        <inputEntry id="IE_HighRisk_2"><text>-</text></inputEntry>
        <inputEntry id="IE_HighRisk_3"><text>-</text></inputEntry>
        <outputEntry id="OE_HighRisk_res"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_HighRisk_acao"><text>"Situacao de risco alto identificada - avaliacao detalhada necessaria"</text></outputEntry>
        <outputEntry id="OE_HighRisk_risco"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Rastreamento aprovado - armazenar protocolo</description>
        <inputEntry id="IE_Fallback_1"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_2"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_3"><text>-</text></inputEntry>
        <outputEntry id="OE_Fallback_res"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Fallback_acao"><text>"Rastreamento aprovado - armazenar protocolo"</text></outputEntry>
        <outputEntry id="OE_Fallback_risco"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ProtocolTracking">
      <dmndi:DMNShape id="DMNShape_ProtocolTracking" dmnElementRef="Decision_ProtocolTracking">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
