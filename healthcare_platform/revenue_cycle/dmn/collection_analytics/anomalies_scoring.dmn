<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_anomalies_scoring"
             name="Anomalies Scoring"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: alert_anomalies_worker.py -->
  <decision id="Decision_anomalies_scoring" name="Anomalies Scoring">
    <decisionTable id="DecisionTable_anomalies_scoring" hitPolicy="FIRST">
      <input id="Input_z_score_abs" label="Z-Score Absoluto">
        <inputExpression id="IE_z_score_abs" typeRef="double"><text>z_score_abs</text></inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="U1"><text>>= 4</text></inputEntry>
        <outputEntry id="L1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="L1a"><text>"Anomalia critica - investigacao imediata"</text></outputEntry>
        <outputEntry id="L1b"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="U2"><text>[3..4)</text></inputEntry>
        <outputEntry id="L2"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="L2a"><text>"Anomalia severa - alerta gerencial"</text></outputEntry>
        <outputEntry id="L2b"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="U3"><text>[2.5..3)</text></inputEntry>
        <outputEntry id="L3"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="L3a"><text>"Anomalia moderada - monitorar"</text></outputEntry>
        <outputEntry id="L3b"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="U4"><text>[2..2.5)</text></inputEntry>
        <outputEntry id="L4"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="L4a"><text>"Desvio leve - registrar observacao"</text></outputEntry>
        <outputEntry id="L4b"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="U5"><text>&lt; 2</text></inputEntry>
        <outputEntry id="L5"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="L5a"><text>"Dentro da faixa normal"</text></outputEntry>
        <outputEntry id="L5b"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
