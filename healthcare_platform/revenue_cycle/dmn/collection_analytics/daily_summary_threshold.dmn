<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" id="Definitions_daily_summary_threshold" name="Daily Summary Threshold" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: send_daily_summary_worker.py -->
  <decision id="Decision_daily_summary_threshold" name="Daily Summary Threshold">
    <decisionTable id="DecisionTable_daily_summary_threshold" hitPolicy="FIRST">
      <input id="Input_messages_sent" label="Mensagens Enviadas">
        <inputExpression id="IE_ms" typeRef="integer"><text>messages_sent</text></inputExpression>
      </input>
      <input id="Input_failed" label="Falhas Envio">
        <inputExpression id="IE_fail" typeRef="integer"><text>failed_count</text></inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1"><inputEntry id="U1a"><text>0</text></inputEntry><inputEntry id="U1b"><text>> 0</text></inputEntry><outputEntry id="L1"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L1a"><text>"Nenhum envio bem-sucedido - verificar integracao"</text></outputEntry><outputEntry id="L1b"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2"><inputEntry id="U2a"><text>> 0</text></inputEntry><inputEntry id="U2b"><text>> 5</text></inputEntry><outputEntry id="L2"><text>"REVISAR"</text></outputEntry><outputEntry id="L2a"><text>"Muitas falhas de envio - verificar contatos"</text></outputEntry><outputEntry id="L2b"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_3"><inputEntry id="U3a"><text>> 0</text></inputEntry><inputEntry id="U3b"><text>[1..5]</text></inputEntry><outputEntry id="L3"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L3a"><text>"Algumas falhas - atualizar cadastros"</text></outputEntry><outputEntry id="L3b"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_4"><inputEntry id="U4a"><text>> 0</text></inputEntry><inputEntry id="U4b"><text>0</text></inputEntry><outputEntry id="L4"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a"><text>"Todos enviados com sucesso"</text></outputEntry><outputEntry id="L4b"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_5"><inputEntry id="U5a"><text>0</text></inputEntry><inputEntry id="U5b"><text>0</text></inputEntry><outputEntry id="L5"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a"><text>"Sem destinatarios - verificar lista"</text></outputEntry><outputEntry id="L5b"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>
</definitions>
