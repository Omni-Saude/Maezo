<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  ANOMALY-PATTERN - Deteccao de Padroes Anomalos
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_ANALYTICS
  Archetype: CLINICAL_SCORE | Source: alert_anomalies_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_ANOMALY_PATTERN"
             name="Deteccao de Padroes Anomalos"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_ANOMALY_PATTERN" name="Deteccao de Padroes Anomalos">
    <decisionTable id="DecisionTable_ANOMALY_PATTERN" hitPolicy="FIRST">

      <input id="Input_1" label="Desvio Padrao Score">
        <inputExpression id="InputExpression_1" typeRef="number">
          <text>stdDevScore</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Frequencia Anomalia">
        <inputExpression id="InputExpression_2" typeRef="number">
          <text>anomalyFrequency</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Tipo Anomalia">
        <inputExpression id="InputExpression_3" typeRef="string">
          <text>anomalyType</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1">
        <description>Anomalia critica - desvio extremo com alta frequencia</description>
        <inputEntry id="IE_1_1"><text>&gt; 3.0</text></inputEntry>
        <inputEntry id="IE_1_2"><text>&gt; 5</text></inputEntry>
        <inputEntry id="IE_1_3"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"Anomalia sistematica detectada - suspender processamento e investigar"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <description>Pagamento duplicado detectado</description>
        <inputEntry id="IE_2_1"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2"><text>-</text></inputEntry>
        <inputEntry id="IE_2_3"><text>"DUPLICATE_PAYMENT"</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"Possivel pagamento duplicado - bloquear e verificar"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <description>Desvio alto mas isolado</description>
        <inputEntry id="IE_3_1"><text>[2.0..3.0]</text></inputEntry>
        <inputEntry id="IE_3_2"><text>&lt;= 2</text></inputEntry>
        <inputEntry id="IE_3_3"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"Anomalia pontual - revisar caso individualmente"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_4">
        <description>Variacao de volume - padrao sazonal possivel</description>
        <inputEntry id="IE_4_1"><text>[1.0..2.0]</text></inputEntry>
        <inputEntry id="IE_4_2"><text>-</text></inputEntry>
        <inputEntry id="IE_4_3"><text>"VOLUME_SPIKE"</text></inputEntry>
        <outputEntry id="OE_4_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2"><text>"Pico de volume dentro do esperado sazonal - monitorar"</text></outputEntry>
        <outputEntry id="OE_4_3"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_5">
        <description>Desvio baixo - operacao normal</description>
        <inputEntry id="IE_5_1"><text>&lt; 1.0</text></inputEntry>
        <inputEntry id="IE_5_2"><text>-</text></inputEntry>
        <inputEntry id="IE_5_3"><text>-</text></inputEntry>
        <outputEntry id="OE_5_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_2"><text>"Valores dentro da faixa normal"</text></outputEntry>
        <outputEntry id="OE_5_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Fallback</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"Avaliar padrao anomalo manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ANOMALY_PATTERN">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_ANOMALY_PATTERN">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
