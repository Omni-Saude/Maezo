<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" id="Definitions_aging_report_scoring" name="Aging Report Scoring" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: generate_aging_report_worker.py -->
  <decision id="Decision_aging_report_scoring" name="Aging Report Scoring">
    <decisionTable id="DecisionTable_aging_report_scoring" hitPolicy="FIRST">
      <input id="Input_total_ar" label="Total AR R$">
        <inputExpression id="IE_ar" typeRef="double"><text>total_ar</text></inputExpression>
      </input>
      <input id="Input_over90_pct" label="Porcentagem >90 dias">
        <inputExpression id="IE_pct90" typeRef="double"><text>over_90_percentage</text></inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1"><inputEntry id="U1a"><text></text></inputEntry><inputEntry id="U1b"><text>> 40</text></inputEntry><outputEntry id="L1"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L1a"><text>"AR envelhecido critico - acoes emergenciais"</text></outputEntry><outputEntry id="L1b"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2"><inputEntry id="U2a"><text>>= 1000000</text></inputEntry><inputEntry id="U2b"><text>> 25</text></inputEntry><outputEntry id="L2"><text>"REVISAR"</text></outputEntry><outputEntry id="L2a"><text>"AR alto e envelhecido - plano de acao"</text></outputEntry><outputEntry id="L2b"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_3"><inputEntry id="U3a"><text></text></inputEntry><inputEntry id="U3b"><text>[15..25]</text></inputEntry><outputEntry id="L3"><text>"REVISAR"</text></outputEntry><outputEntry id="L3a"><text>"Aging moderado - intensificar cobranca"</text></outputEntry><outputEntry id="L3b"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_4"><inputEntry id="U4a"><text></text></inputEntry><inputEntry id="U4b"><text>[5..15)</text></inputEntry><outputEntry id="L4"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a"><text>"Aging aceitavel - manter ritmo"</text></outputEntry><outputEntry id="L4b"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_5"><inputEntry id="U5a"><text></text></inputEntry><inputEntry id="U5b"><text>&lt; 5</text></inputEntry><outputEntry id="L5"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a"><text>"AR saudavel"</text></outputEntry><outputEntry id="L5b"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>
</definitions>
