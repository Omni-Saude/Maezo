<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  LEAKAGE-PATTERN - Deteccao de Padroes de Vazamento de Receita
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_ANALYTICS
  Archetype: CLINICAL_SCORE | Source: detect_revenue_leakage_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_LEAKAGE_PATTERN"
             name="Deteccao de Padroes de Vazamento de Receita"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_LEAKAGE_PATTERN" name="Deteccao de Padroes de Vazamento de Receita">
    <decisionTable id="DecisionTable_LEAKAGE_PATTERN" hitPolicy="FIRST">

      <input id="Input_1" label="Taxa Vazamento Percentual">
        <inputExpression id="InputExpression_1" typeRef="number">
          <text>leakageRatePercent</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Origem Vazamento">
        <inputExpression id="InputExpression_2" typeRef="string">
          <text>leakageSource</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Valor Acumulado Perdido">
        <inputExpression id="InputExpression_3" typeRef="number">
          <text>accumulatedLoss</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1">
        <description>Vazamento alto por subcobranca</description>
        <inputEntry id="IE_1_1"><text>&gt; 10</text></inputEntry>
        <inputEntry id="IE_1_2"><text>"UNDERBILLING"</text></inputEntry>
        <inputEntry id="IE_1_3"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"Vazamento &gt;10% por subcobranca - auditoria urgente de codificacao"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <description>Perda acumulada elevada por glosas nao contestadas</description>
        <inputEntry id="IE_2_1"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2"><text>"UNCONTESTED_DENIAL"</text></inputEntry>
        <inputEntry id="IE_2_3"><text>&gt; 50000</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"Mais de R$50k em glosas nao contestadas - acionar equipe de recurso"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <description>Vazamento moderado por contratos desatualizados</description>
        <inputEntry id="IE_3_1"><text>[5..10]</text></inputEntry>
        <inputEntry id="IE_3_2"><text>"CONTRACT_GAP"</text></inputEntry>
        <inputEntry id="IE_3_3"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"Contratos com tabelas defasadas - agendar renegociacao"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_4">
        <description>Vazamento baixo - monitoramento padrao</description>
        <inputEntry id="IE_4_1"><text>[2..5]</text></inputEntry>
        <inputEntry id="IE_4_2"><text>-</text></inputEntry>
        <inputEntry id="IE_4_3"><text>&lt; 10000</text></inputEntry>
        <outputEntry id="OE_4_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2"><text>"Vazamento dentro da margem operacional - acompanhar mensalmente"</text></outputEntry>
        <outputEntry id="OE_4_3"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_5">
        <description>Vazamento residual - aceitavel</description>
        <inputEntry id="IE_5_1"><text>&lt; 2</text></inputEntry>
        <inputEntry id="IE_5_2"><text>-</text></inputEntry>
        <inputEntry id="IE_5_3"><text>-</text></inputEntry>
        <outputEntry id="OE_5_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_2"><text>"Taxa de vazamento residual dentro do benchmark"</text></outputEntry>
        <outputEntry id="OE_5_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Fallback</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"Avaliar padrao de vazamento manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_LEAKAGE_PATTERN">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_LEAKAGE_PATTERN">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
