<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" id="Definitions_executive_dashboard_scoring" name="Executive Dashboard Scoring" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: generate_executive_dashboard_worker.py -->
  <decision id="Decision_executive_dashboard_scoring" name="Executive Dashboard Scoring">
    <decisionTable id="DecisionTable_executive_dashboard_scoring" hitPolicy="FIRST">
      <input id="Input_collection_rate" label="Collection Rate %">
        <inputExpression id="IE_cr" typeRef="double"><text>collection_rate</text></inputExpression>
      </input>
      <input id="Input_dso" label="DSO Dias">
        <inputExpression id="IE_dso" typeRef="double"><text>dso</text></inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1"><inputEntry id="U1a"><text>&lt; 50</text></inputEntry><inputEntry id="U1b"><text>> 120</text></inputEntry><outputEntry id="L1"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L1a"><text>"KPIs criticos - reuniao executiva urgente"</text></outputEntry><outputEntry id="L1b"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2"><inputEntry id="U2a"><text>&lt; 70</text></inputEntry><inputEntry id="U2b"><text>> 90</text></inputEntry><outputEntry id="L2"><text>"REVISAR"</text></outputEntry><outputEntry id="L2a"><text>"KPIs abaixo meta - plano corretivo"</text></outputEntry><outputEntry id="L2b"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_3"><inputEntry id="U3a"><text>[70..85)</text></inputEntry><inputEntry id="U3b"><text>(60..90]</text></inputEntry><outputEntry id="L3"><text>"REVISAR"</text></outputEntry><outputEntry id="L3a"><text>"KPIs aceitaveis - buscar melhoria"</text></outputEntry><outputEntry id="L3b"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_4"><inputEntry id="U4a"><text>[85..95)</text></inputEntry><inputEntry id="U4b"><text>&lt;= 60</text></inputEntry><outputEntry id="L4"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a"><text>"KPIs bons - manter estrategia"</text></outputEntry><outputEntry id="L4b"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_5"><inputEntry id="U5a"><text>>= 95</text></inputEntry><inputEntry id="U5b"><text>&lt;= 45</text></inputEntry><outputEntry id="L5"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a"><text>"KPIs excelentes - benchmark"</text></outputEntry><outputEntry id="L5b"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>
</definitions>
