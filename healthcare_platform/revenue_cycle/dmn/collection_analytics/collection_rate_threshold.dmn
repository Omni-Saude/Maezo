<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_collection_rate_threshold"
             name="Collection Rate Threshold"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: calculate_collection_rate_worker.py -->
  <decision id="Decision_collection_rate_threshold" name="Collection Rate Threshold">
    <decisionTable id="DecisionTable_collection_rate_threshold" hitPolicy="FIRST">
      <input id="Input_collection_rate" label="Taxa Cobranca %">
        <inputExpression id="InputExpression_collection_rate" typeRef="double">
          <text>collection_rate</text>
        </inputExpression>
      </input>
      <input id="Input_uncollected" label="Valor Nao Cobrado">
        <inputExpression id="InputExpression_uncollected" typeRef="double">
          <text>uncollected</text>
        </inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="UnaryTests_1"><text>&lt; 50</text></inputEntry>
        <inputEntry id="UnaryTests_1b"><text>&gt;= 100000</text></inputEntry>
        <outputEntry id="LiteralExpression_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="LiteralExpression_1a"><text>"Alerta executivo - perda critica de receita"</text></outputEntry>
        <outputEntry id="LiteralExpression_1b"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="UnaryTests_2"><text>&lt; 70</text></inputEntry>
        <inputEntry id="UnaryTests_2b"><text>&gt;= 50000</text></inputEntry>
        <outputEntry id="LiteralExpression_2"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="LiteralExpression_2a"><text>"Escalar para gerencia de cobranca"</text></outputEntry>
        <outputEntry id="LiteralExpression_2b"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="UnaryTests_3"><text>&lt; 70</text></inputEntry>
        <inputEntry id="UnaryTests_3b"><text>&lt; 50000</text></inputEntry>
        <outputEntry id="LiteralExpression_3"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="LiteralExpression_3a"><text>"Analisar causas da baixa taxa"</text></outputEntry>
        <outputEntry id="LiteralExpression_3b"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="UnaryTests_4"><text>[70..85)</text></inputEntry>
        <inputEntry id="UnaryTests_4b"><text></text></inputEntry>
        <outputEntry id="LiteralExpression_4"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="LiteralExpression_4a"><text>"Monitorar tendencia de melhoria"</text></outputEntry>
        <outputEntry id="LiteralExpression_4b"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="UnaryTests_5"><text>&gt;= 85</text></inputEntry>
        <inputEntry id="UnaryTests_5b"><text></text></inputEntry>
        <outputEntry id="LiteralExpression_5"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="LiteralExpression_5a"><text>"Dentro da meta - continuar"</text></outputEntry>
        <outputEntry id="LiteralExpression_5b"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
