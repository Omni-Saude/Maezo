<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" id="Definitions_revenue_leakage_threshold" name="Revenue Leakage Threshold" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: detect_revenue_leakage_worker.py -->
  <decision id="Decision_revenue_leakage_threshold" name="Revenue Leakage Threshold">
    <decisionTable id="DecisionTable_revenue_leakage_threshold" hitPolicy="FIRST">
      <input id="Input_category" label="Categoria Vazamento">
        <inputExpression id="IE_cat" typeRef="string"><text>leakage_category</text></inputExpression>
      </input>
      <input id="Input_priority" label="Prioridade">
        <inputExpression id="IE_pri" typeRef="string"><text>priority</text></inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1"><inputEntry id="U1a"><text>"expired_authorizations"</text></inputEntry><inputEntry id="U1b"><text>"critical"</text></inputEntry><outputEntry id="L1"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L1a"><text>"Autorizacoes expirando - renovar urgente"</text></outputEntry><outputEntry id="L1b"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2"><inputEntry id="U2a"><text>"unbilled_encounters"</text></inputEntry><inputEntry id="U2b"><text>"high"</text></inputEntry><outputEntry id="L2"><text>"REVISAR"</text></outputEntry><outputEntry id="L2a"><text>"Faturar encounters pendentes"</text></outputEntry><outputEntry id="L2b"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_3"><inputEntry id="U3a"><text>"uncollected_approvals"</text></inputEntry><inputEntry id="U3b"><text>"high"</text></inputEntry><outputEntry id="L3"><text>"REVISAR"</text></outputEntry><outputEntry id="L3a"><text>"Cobrar aprovacoes pendentes"</text></outputEntry><outputEntry id="L3b"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_4"><inputEntry id="U4a"><text>"undercoded_procedures"</text></inputEntry><inputEntry id="U4b"><text>"medium"</text></inputEntry><outputEntry id="L4"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a"><text>"Revisar codificacao para otimizar"</text></outputEntry><outputEntry id="L4b"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_5"><inputEntry id="U5a"><text></text></inputEntry><inputEntry id="U5b"><text></text></inputEntry><outputEntry id="L5"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a"><text>"Monitorar vazamentos"</text></outputEntry><outputEntry id="L5b"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>
</definitions>
