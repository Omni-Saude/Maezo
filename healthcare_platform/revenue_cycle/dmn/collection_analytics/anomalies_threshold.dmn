<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_anomalies_threshold"
             name="Anomalies Threshold"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: alert_anomalies_worker.py -->
  <decision id="Decision_anomalies_threshold" name="Anomalies Threshold">
    <decisionTable id="DecisionTable_anomalies_threshold" hitPolicy="FIRST">
      <input id="Input_critical_count" label="Anomalias Criticas">
        <inputExpression id="IE_critical_count" typeRef="integer"><text>critical_anomalies</text></inputExpression>
      </input>
      <input id="Input_total_count" label="Total Anomalias">
        <inputExpression id="IE_total_count" typeRef="integer"><text>total_anomalies</text></inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1">
        <inputEntry id="U1a"><text>>= 3</text></inputEntry>
        <inputEntry id="U1b"><text></text></inputEntry>
        <outputEntry id="L1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="L1a"><text>"Multiplas anomalias criticas - parar e investigar"</text></outputEntry>
        <outputEntry id="L1b"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_2">
        <inputEntry id="U2a"><text>>= 1</text></inputEntry>
        <inputEntry id="U2b"><text>>= 5</text></inputEntry>
        <outputEntry id="L2"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="L2a"><text>"Anomalia critica com muitas anomalias"</text></outputEntry>
        <outputEntry id="L2b"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_3">
        <inputEntry id="U3a"><text>>= 1</text></inputEntry>
        <inputEntry id="U3b"><text></text></inputEntry>
        <outputEntry id="L3"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="L3a"><text>"Anomalia critica isolada - analisar"</text></outputEntry>
        <outputEntry id="L3b"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_4">
        <inputEntry id="U4a"><text>0</text></inputEntry>
        <inputEntry id="U4b"><text>>= 3</text></inputEntry>
        <outputEntry id="L4"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="L4a"><text>"Volume alto de anomalias nao-criticas"</text></outputEntry>
        <outputEntry id="L4b"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_5">
        <inputEntry id="U5a"><text>0</text></inputEntry>
        <inputEntry id="U5b"><text>[1..3)</text></inputEntry>
        <outputEntry id="L5"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="L5a"><text>"Poucas anomalias leves"</text></outputEntry>
        <outputEntry id="L5b"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_6">
        <inputEntry id="U6a"><text>0</text></inputEntry>
        <inputEntry id="U6b"><text>0</text></inputEntry>
        <outputEntry id="L6"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="L6a"><text>"Sem anomalias detectadas"</text></outputEntry>
        <outputEntry id="L6b"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
