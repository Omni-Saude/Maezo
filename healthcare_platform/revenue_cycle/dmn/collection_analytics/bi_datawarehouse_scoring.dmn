<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" id="Definitions_bi_datawarehouse_scoring" name="BI Datawarehouse Scoring" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: update_bi_datawarehouse_worker.py -->
  <decision id="Decision_bi_datawarehouse_scoring" name="BI Datawarehouse Scoring">
    <decisionTable id="DecisionTable_bi_datawarehouse_scoring" hitPolicy="FIRST">
      <input id="Input_total_records" label="Total Registros">
        <inputExpression id="IE_rec" typeRef="integer"><text>total_records</text></inputExpression>
      </input>
      <input id="Input_avg_collection_rate" label="Taxa Media Cobranca">
        <inputExpression id="IE_acr" typeRef="double"><text>avg_collection_rate</text></inputExpression>
      </input>
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1"><inputEntry id="U1a"><text>0</text></inputEntry><inputEntry id="U1b"><text></text></inputEntry><outputEntry id="L1"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L1a"><text>"Sem dados para exportar - verificar fonte"</text></outputEntry><outputEntry id="L1b"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2"><inputEntry id="U2a"><text>> 0</text></inputEntry><inputEntry id="U2b"><text>&lt; 50</text></inputEntry><outputEntry id="L2"><text>"REVISAR"</text></outputEntry><outputEntry id="L2a"><text>"Taxa cobranca baixa no lote exportado"</text></outputEntry><outputEntry id="L2b"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_3"><inputEntry id="U3a"><text>> 0</text></inputEntry><inputEntry id="U3b"><text>[50..80)</text></inputEntry><outputEntry id="L3"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L3a"><text>"Exportacao com metricas aceitaveis"</text></outputEntry><outputEntry id="L3b"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_4"><inputEntry id="U4a"><text>> 0</text></inputEntry><inputEntry id="U4b"><text>[80..95)</text></inputEntry><outputEntry id="L4"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a"><text>"Exportacao com boas metricas"</text></outputEntry><outputEntry id="L4b"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_5"><inputEntry id="U5a"><text>> 0</text></inputEntry><inputEntry id="U5b"><text>>= 95</text></inputEntry><outputEntry id="L5"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a"><text>"Exportacao com metricas excelentes"</text></outputEntry><outputEntry id="L5b"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>
</definitions>
