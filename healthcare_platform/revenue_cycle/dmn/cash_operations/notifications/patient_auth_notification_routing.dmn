<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_PatientAuthNotificationRouting"
             name="Patient Auth Notification Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: patient_auth_notification_routing_worker.py -->

  <!-- Source: patient_authorization_update_worker.py
       Rules extracted from STATUS_LABELS and DEFAULT_NEXT_STEPS mappings.
  -->

  <decision id="Decision_PatientAuthNotifRouting" name="Patient Auth Notification Routing">
    <decisionTable id="DecisionTable_PatientAuthNotifRouting" hitPolicy="FIRST">

      <input id="Input_authorizationStatus" label="Authorization Status">
        <inputExpression id="InputExpr_authorizationStatus" typeRef="string">
          <text>authorizationStatus</text>
        </inputExpression>
      </input>

      <output id="Output_destino" label="Destino" name="destino" typeRef="string"/>

      <output id="Output_prioridade" label="Prioridade" name="prioridade" typeRef="number"/>

      <output id="Output_restricao" label="Restricao" name="restricao" typeRef="string"/>

      <!-- R1: Approved — schedule appointment -->
      <rule id="Rule_approved">
        <description>Approved — notify patient to schedule</description>
        <inputEntry id="IE_a_1"><text>"approved"</text></inputEntry>
        <outputEntry id="OE_a_dest"><text>"whatsapp"</text></outputEntry>
        <outputEntry id="OE_a_prio"><text>3</text></outputEntry>
        <outputEntry id="OE_a_restr"><text>"Agende sua consulta"</text></outputEntry>
      </rule>

      <!-- R2: Denied — urgent, appeal instructions -->
      <rule id="Rule_denied">
        <description>Denied — urgent notification with appeal instructions</description>
        <inputEntry id="IE_d_1"><text>"denied"</text></inputEntry>
        <outputEntry id="OE_d_dest"><text>"whatsapp"</text></outputEntry>
        <outputEntry id="OE_d_prio"><text>1</text></outputEntry>
        <outputEntry id="OE_d_restr"><text>"Ligue 0800 para recurso"</text></outputEntry>
      </rule>

      <!-- R3: Pending — wait notification -->
      <rule id="Rule_pending">
        <description>Pending — notify patient to wait</description>
        <inputEntry id="IE_p_1"><text>"pending"</text></inputEntry>
        <outputEntry id="OE_p_dest"><text>"whatsapp"</text></outputEntry>
        <outputEntry id="OE_p_prio"><text>2</text></outputEntry>
        <outputEntry id="OE_p_restr"><text>"Aguarde 5 dias uteis"</text></outputEntry>
      </rule>

      <!-- R4: Cancelled — urgent notification -->
      <rule id="Rule_cancelled">
        <description>Cancelled — urgent notification</description>
        <inputEntry id="IE_c_1"><text>"cancelled"</text></inputEntry>
        <outputEntry id="OE_c_dest"><text>"whatsapp"</text></outputEntry>
        <outputEntry id="OE_c_prio"><text>1</text></outputEntry>
        <outputEntry id="OE_c_restr"><text>"Autorizacao cancelada"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="Rule_fallback">
        <description>Unknown status — default routing</description>
        <inputEntry id="IE_fb_1"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_dest"><text>"whatsapp"</text></outputEntry>
        <outputEntry id="OE_fb_prio"><text>5</text></outputEntry>
        <outputEntry id="OE_fb_restr"><text>"Entre em contato com a central"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_PatientAuthNotifRouting">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
