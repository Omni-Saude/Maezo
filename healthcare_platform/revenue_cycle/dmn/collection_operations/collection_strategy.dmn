<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COLLECTION-STRATEGY - Estrategia de Cobranca
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: prioritize_collection_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_COLLECTION_STRATEGY"
             name="Estrategia de Cobranca"
             targetNamespace="http://healthcare.platform/dmn/collection_operations">

  <decision id="Decision_COLLECTION_STRATEGY" name="Estrategia de Cobranca">
    <decisionTable id="DecisionTable_COLLECTION_STRATEGY" hitPolicy="FIRST">

      <input id="Input_1" label="Prioridade">
        <inputExpression id="InputExpression_1" typeRef="string">
          <text>priority</text>
        </inputExpression>
        <inputValues id="InputValues_1">
          <text>"critical","high","medium","low"</text>
        </inputValues>
      </input>

      <input id="Input_2" label="Dias em Atraso">
        <inputExpression id="InputExpression_2" typeRef="integer">
          <text>days_overdue</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Valor">
        <inputExpression id="InputExpression_3" typeRef="double">
          <text>amount</text>
        </inputExpression>
      </input>

      <input id="Input_4" label="Perfil Pagador">
        <inputExpression id="InputExpression_4" typeRef="string">
          <text>payer_profile</text>
        </inputExpression>
        <inputValues id="InputValues_4">
          <text>"reliable","standard","risky","defaulter"</text>
        </inputValues>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_strategy" label="Estrategia" name="strategy" typeRef="string">
        <outputValues><text>"LEGAL_ESCALATION","INTENSIVE_FOLLOW_UP","STANDARD_COLLECTION","REMINDER_ONLY"</text></outputValues>
      </output>
      <output id="Output_frequency" label="Frequencia Contato" name="contact_frequency" typeRef="string">
        <outputValues><text>"daily","weekly","biweekly","monthly"</text></outputValues>
      </output>
      <output id="Output_path" label="Caminho Escalacao" name="escalation_path" typeRef="string">
        <outputValues><text>"legal_team","senior_collector","collector","automated"</text></outputValues>
      </output>

      <rule id="Rule_Legal">
        <description>Estrategia juridica - casos criticos</description>
        <inputEntry id="IE_1_1"><text>"critical"</text></inputEntry>
        <inputEntry id="IE_1_2"><text>&gt; 90</text></inputEntry>
        <inputEntry id="IE_1_3"><text>-</text></inputEntry>
        <inputEntry id="IE_1_4"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"LEGAL_ESCALATION"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"daily"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"legal_team"</text></outputEntry>
      </rule>

      <rule id="Rule_Intensive">
        <description>Cobranca intensiva - prioridade alta</description>
        <inputEntry id="IE_2_1"><text>"high"</text></inputEntry>
        <inputEntry id="IE_2_2"><text>&gt; 60</text></inputEntry>
        <inputEntry id="IE_2_3"><text>-</text></inputEntry>
        <inputEntry id="IE_2_4"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"INTENSIVE_FOLLOW_UP"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"weekly"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"senior_collector"</text></outputEntry>
      </rule>

      <rule id="Rule_Standard">
        <description>Cobranca padrao - prioridade media</description>
        <inputEntry id="IE_3_1"><text>"medium"</text></inputEntry>
        <inputEntry id="IE_3_2"><text>&gt; 30</text></inputEntry>
        <inputEntry id="IE_3_3"><text>-</text></inputEntry>
        <inputEntry id="IE_3_4"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"STANDARD_COLLECTION"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"biweekly"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"collector"</text></outputEntry>
      </rule>

      <rule id="Rule_Reminder">
        <description>Apenas lembretes - prioridade baixa</description>
        <inputEntry id="IE_F_1"><text>"low"</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <inputEntry id="IE_F_4"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"REMINDER_ONLY"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"monthly"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"automated"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COLLECTION_STRATEGY">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_COLLECTION_STRATEGY">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
