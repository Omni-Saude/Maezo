<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AGING-BUCKETS - Classificacao por Faixa de Atraso
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: calculate_aging_bucket_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_AGING_BUCKETS"
             name="Classificacao por Faixa de Atraso"
             targetNamespace="http://healthcare.platform/dmn/collection_operations">

  <decision id="Decision_AGING_BUCKETS" name="Classificacao por Faixa de Atraso">
    <decisionTable id="DecisionTable_AGING_BUCKETS" hitPolicy="FIRST">

      <input id="Input_1" label="Dias em Atraso">
        <inputExpression id="InputExpression_1" typeRef="integer">
          <text>days_overdue</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_bucket" label="Faixa de Atraso" name="aging_bucket" typeRef="string"/>
      <output id="Output_urgency" label="Urgencia" name="urgency" typeRef="string">
        <outputValues><text>"low","medium","high","critical","escalate"</text></outputValues>
      </output>

      <rule id="Rule_Current">
        <description>Conta corrente (0-30 dias)</description>
        <inputEntry id="IE_1_1"><text>[0..30]</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"current"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"low"</text></outputEntry>
      </rule>

      <rule id="Rule_30Days">
        <description>Atraso 31-60 dias</description>
        <inputEntry id="IE_2_1"><text>[31..60]</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"30_days"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"medium"</text></outputEntry>
      </rule>

      <rule id="Rule_60Days">
        <description>Atraso 61-90 dias</description>
        <inputEntry id="IE_3_1"><text>[61..90]</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"60_days"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"high"</text></outputEntry>
      </rule>

      <rule id="Rule_90Days">
        <description>Atraso 91-120 dias</description>
        <inputEntry id="IE_4_1"><text>[91..120]</text></inputEntry>
        <outputEntry id="OE_4_1"><text>"90_days"</text></outputEntry>
        <outputEntry id="OE_4_2"><text>"critical"</text></outputEntry>
      </rule>

      <rule id="Rule_120Plus">
        <description>Atraso acima de 120 dias</description>
        <inputEntry id="IE_5_1"><text>&gt; 120</text></inputEntry>
        <outputEntry id="OE_5_1"><text>"120_plus"</text></outputEntry>
        <outputEntry id="OE_5_2"><text>"escalate"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Fallback</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"current"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"low"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AGING_BUCKETS">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_AGING_BUCKETS">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
