<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DISCREPANCY-TOLERANCE - Tolerancia para Diferencas de Pagamento
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: flag_discrepancies_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_DISCREPANCY_TOLERANCE"
             name="Tolerancia para Diferencas de Pagamento"
             targetNamespace="http://healthcare.platform/dmn/collection_operations">

  <decision id="Decision_DISCREPANCY_TOLERANCE" name="Tolerancia para Diferencas de Pagamento">
    <decisionTable id="DecisionTable_DISCREPANCY_TOLERANCE" hitPolicy="FIRST">

      <input id="Input_1" label="Valor Esperado">
        <inputExpression id="InputExpression_1" typeRef="double">
          <text>expected_amount</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Valor Recebido">
        <inputExpression id="InputExpression_2" typeRef="double">
          <text>received_amount</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Tipo Pagamento">
        <inputExpression id="InputExpression_3" typeRef="string">
          <text>payment_type</text>
        </inputExpression>
        <inputValues id="InputValues_3">
          <text>"transfer","check","cash","card"</text>
        </inputValues>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_within" label="Dentro Tolerancia" name="within_tolerance" typeRef="boolean"/>
      <output id="Output_percentage" label="Percentual Tolerancia" name="tolerance_percentage" typeRef="double"/>
      <output id="Output_action" label="Acao" name="action" typeRef="string">
        <outputValues><text>"AUTO_ACCEPT","FLAG_REVIEW","MANUAL_REVIEW"</text></outputValues>
      </output>
      <output id="Output_variance" label="Variancia" name="variance" typeRef="double"/>

      <rule id="Rule_MinimalVariance">
        <description>Variancia minima - aceitar automaticamente</description>
        <inputEntry id="IE_1_1"><text>-</text></inputEntry>
        <inputEntry id="IE_1_2"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1"><text>abs(received_amount - expected_amount) &lt; 0.01 * expected_amount</text></outputEntry>
        <outputEntry id="OE_1_2"><text>1.0</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"AUTO_ACCEPT"</text></outputEntry>
        <outputEntry id="OE_1_4"><text>received_amount - expected_amount</text></outputEntry>
      </rule>

      <rule id="Rule_SmallVariance">
        <description>Variancia pequena - sinalizar para revisao</description>
        <inputEntry id="IE_2_1"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2"><text>-</text></inputEntry>
        <inputEntry id="IE_2_3"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1"><text>abs(received_amount - expected_amount) &lt; 0.05 * expected_amount</text></outputEntry>
        <outputEntry id="OE_2_2"><text>5.0</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"FLAG_REVIEW"</text></outputEntry>
        <outputEntry id="OE_2_4"><text>received_amount - expected_amount</text></outputEntry>
      </rule>

      <rule id="Rule_LargeVariance">
        <description>Variancia grande - revisao manual necessaria</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>false</text></outputEntry>
        <outputEntry id="OE_F_2"><text>0</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"MANUAL_REVIEW"</text></outputEntry>
        <outputEntry id="OE_F_4"><text>received_amount - expected_amount</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DISCREPANCY_TOLERANCE">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_DISCREPANCY_TOLERANCE">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
