<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  PRIORITY-SCORING - Calculo de Prioridade de Cobranca
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_SCORING | Source: prioritize_collection_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_PRIORITY_SCORING"
             name="Calculo de Prioridade de Cobranca"
             targetNamespace="http://healthcare.platform/dmn/collection_operations">

  <decision id="Decision_PRIORITY_SCORING" name="Calculo de Prioridade de Cobranca">
    <decisionTable id="DecisionTable_PRIORITY_SCORING" hitPolicy="COLLECT" aggregation="SUM">

      <input id="Input_1" label="Valor">
        <inputExpression id="InputExpression_1" typeRef="double">
          <text>amount</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Dias em Atraso">
        <inputExpression id="InputExpression_2" typeRef="integer">
          <text>days_overdue</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Taxa Inadimplencia Pagador">
        <inputExpression id="InputExpression_3" typeRef="double">
          <text>payer_default_rate</text>
        </inputExpression>
      </input>

      <input id="Input_4" label="Tipo Conta">
        <inputExpression id="InputExpression_4" typeRef="string">
          <text>claim_type</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_score" label="Pontuacao" name="priority_score" typeRef="integer"/>
      <output id="Output_level" label="Nivel Prioridade" name="priority_level" typeRef="string">
        <outputValues><text>"critical","high","medium","low"</text></outputValues>
      </output>

      <rule id="Rule_Critical_1">
        <description>Critico: Alto valor e muito atrasado</description>
        <inputEntry id="IE_C1_1"><text>&gt; 50000</text></inputEntry>
        <inputEntry id="IE_C1_2"><text>&gt; 90</text></inputEntry>
        <inputEntry id="IE_C1_3"><text>-</text></inputEntry>
        <inputEntry id="IE_C1_4"><text>-</text></inputEntry>
        <outputEntry id="OE_C1_1"><text>100</text></outputEntry>
        <outputEntry id="OE_C1_2"><text>"critical"</text></outputEntry>
      </rule>

      <rule id="Rule_High_1">
        <description>Alto: Valor medio e atraso significativo</description>
        <inputEntry id="IE_H1_1"><text>&gt; 10000</text></inputEntry>
        <inputEntry id="IE_H1_2"><text>&gt; 60</text></inputEntry>
        <inputEntry id="IE_H1_3"><text>-</text></inputEntry>
        <inputEntry id="IE_H1_4"><text>-</text></inputEntry>
        <outputEntry id="OE_H1_1"><text>75</text></outputEntry>
        <outputEntry id="OE_H1_2"><text>"high"</text></outputEntry>
      </rule>

      <rule id="Rule_Medium_1">
        <description>Medio: Valor moderado com atraso</description>
        <inputEntry id="IE_M1_1"><text>&gt; 5000</text></inputEntry>
        <inputEntry id="IE_M1_2"><text>&gt; 30</text></inputEntry>
        <inputEntry id="IE_M1_3"><text>-</text></inputEntry>
        <inputEntry id="IE_M1_4"><text>-</text></inputEntry>
        <outputEntry id="OE_M1_1"><text>50</text></outputEntry>
        <outputEntry id="OE_M1_2"><text>"medium"</text></outputEntry>
      </rule>

      <rule id="Rule_Low_Fallback">
        <description>Baixo: Demais casos</description>
        <inputEntry id="IE_L1_1"><text>-</text></inputEntry>
        <inputEntry id="IE_L1_2"><text>-</text></inputEntry>
        <inputEntry id="IE_L1_3"><text>-</text></inputEntry>
        <inputEntry id="IE_L1_4"><text>-</text></inputEntry>
        <outputEntry id="OE_L1_1"><text>25</text></outputEntry>
        <outputEntry id="OE_L1_2"><text>"low"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PRIORITY_SCORING">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_PRIORITY_SCORING">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
