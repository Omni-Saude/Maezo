<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  PAYMENT-PLAN-ELIGIBILITY - Elegibilidade para Plano de Pagamento
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: negotiate_payment_plan_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_PAYMENT_PLAN_ELIGIBILITY"
             name="Elegibilidade para Plano de Pagamento"
             targetNamespace="http://healthcare.platform/dmn/collection_operations">

  <decision id="Decision_PAYMENT_PLAN_ELIGIBILITY" name="Elegibilidade para Plano de Pagamento">
    <decisionTable id="DecisionTable_PAYMENT_PLAN_ELIGIBILITY" hitPolicy="FIRST">

      <input id="Input_1" label="Valor Devido">
        <inputExpression id="InputExpression_1" typeRef="double">
          <text>amount_due</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Score Historico Pagador">
        <inputExpression id="InputExpression_2" typeRef="integer">
          <text>payer_history_score</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Dias em Atraso">
        <inputExpression id="InputExpression_3" typeRef="integer">
          <text>days_overdue</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_eligible" label="Elegivel" name="eligible" typeRef="boolean"/>
      <output id="Output_tier" label="Categoria Plano" name="plan_tier" typeRef="string">
        <outputValues><text>"premium","standard","basic","none"</text></outputValues>
      </output>
      <output id="Output_installments" label="Max Parcelas" name="max_installments" typeRef="integer"/>

      <rule id="Rule_Premium">
        <description>Plano premium: Score alto e valor significativo</description>
        <inputEntry id="IE_1_1"><text>&gt; 1000</text></inputEntry>
        <inputEntry id="IE_1_2"><text>&gt;= 80</text></inputEntry>
        <inputEntry id="IE_1_3"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1"><text>true</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"premium"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>12</text></outputEntry>
      </rule>

      <rule id="Rule_Standard">
        <description>Plano padrao: Score medio e valor moderado</description>
        <inputEntry id="IE_2_1"><text>&gt; 500</text></inputEntry>
        <inputEntry id="IE_2_2"><text>&gt;= 60</text></inputEntry>
        <inputEntry id="IE_2_3"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1"><text>true</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"standard"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>6</text></outputEntry>
      </rule>

      <rule id="Rule_Basic">
        <description>Plano basico: Score minimo aceitavel</description>
        <inputEntry id="IE_3_1"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2"><text>&gt;= 40</text></inputEntry>
        <inputEntry id="IE_3_3"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1"><text>true</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"basic"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>3</text></outputEntry>
      </rule>

      <rule id="Rule_NotEligible">
        <description>Nao elegivel: Score baixo</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>false</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"none"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>0</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PAYMENT_PLAN_ELIGIBILITY">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_PAYMENT_PLAN_ELIGIBILITY">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
