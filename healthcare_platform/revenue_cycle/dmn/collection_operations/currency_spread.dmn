<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  CURRENCY-SPREAD - Limites de Spread Cambial
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_OPERATIONS
  Archetype: THRESHOLD | Source: convert_currency_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_CURRENCY_SPREAD"
             name="Limites de Spread Cambial"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_CURRENCY_SPREAD" name="Limites de Spread Cambial">
    <decisionTable id="DecisionTable_CURRENCY_SPREAD" hitPolicy="FIRST">

      <input id="Input_1" label="Par Moeda">
        <inputExpression id="InputExpression_1" typeRef="string">
          <text>currencyPair</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Spread Percentual">
        <inputExpression id="InputExpression_2" typeRef="number">
          <text>spreadPercent</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Valor Operacao">
        <inputExpression id="InputExpression_3" typeRef="number">
          <text>operationAmount</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1">
        <description>Spread excessivo em operacao grande</description>
        <inputEntry id="IE_1_1"><text>-</text></inputEntry>
        <inputEntry id="IE_1_2"><text>&gt; 5.0</text></inputEntry>
        <inputEntry id="IE_1_3"><text>&gt; 100000</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"Spread acima de 5% em operacao &gt;R$100k - renegociar taxa"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <description>USD/BRL com spread alto</description>
        <inputEntry id="IE_2_1"><text>"USD_BRL"</text></inputEntry>
        <inputEntry id="IE_2_2"><text>&gt; 3.0</text></inputEntry>
        <inputEntry id="IE_2_3"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"Spread USD/BRL acima do mercado - verificar cotacao atualizada"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <description>EUR/BRL com spread alto</description>
        <inputEntry id="IE_3_1"><text>"EUR_BRL"</text></inputEntry>
        <inputEntry id="IE_3_2"><text>&gt; 3.5</text></inputEntry>
        <inputEntry id="IE_3_3"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"Spread EUR/BRL acima do mercado - verificar cotacao"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_4">
        <description>Spread dentro do aceitavel</description>
        <inputEntry id="IE_4_1"><text>-</text></inputEntry>
        <inputEntry id="IE_4_2"><text>&lt;= 2.0</text></inputEntry>
        <inputEntry id="IE_4_3"><text>-</text></inputEntry>
        <outputEntry id="OE_4_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2"><text>"Spread dentro dos limites aceitaveis"</text></outputEntry>
        <outputEntry id="OE_4_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_5">
        <description>Operacao pequena - spread toleravel</description>
        <inputEntry id="IE_5_1"><text>-</text></inputEntry>
        <inputEntry id="IE_5_2"><text>[2.0..5.0]</text></inputEntry>
        <inputEntry id="IE_5_3"><text>&lt; 10000</text></inputEntry>
        <outputEntry id="OE_5_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_2"><text>"Spread moderado em valor baixo - impacto aceitavel"</text></outputEntry>
        <outputEntry id="OE_5_3"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Fallback</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"Avaliar spread cambial manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_CURRENCY_SPREAD">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_CURRENCY_SPREAD">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
