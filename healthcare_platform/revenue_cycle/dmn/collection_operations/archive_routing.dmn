<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  ARCHIVE-ROUTING - Roteamento de Arquivamento de Reconciliacao
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: archive_reconciliation_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_ARCHIVE_ROUTING"
             name="Roteamento de Arquivamento de Reconciliacao"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_ARCHIVE_ROUTING" name="Roteamento de Arquivamento de Reconciliacao">
    <decisionTable id="DecisionTable_ARCHIVE_ROUTING" hitPolicy="FIRST">

      <input id="Input_1" label="Dias Retencao">
        <inputExpression id="InputExpression_1" typeRef="number">
          <text>retentionDays</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Quantidade Elegivel">
        <inputExpression id="InputExpression_2" typeRef="number">
          <text>eligibleCount</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Dry Run">
        <inputExpression id="InputExpression_3" typeRef="boolean">
          <text>dryRun</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1">
        <description>Retencao muito curta - risco de perda de dados</description>
        <inputEntry id="IE_1_1"><text>&lt; 90</text></inputEntry>
        <inputEntry id="IE_1_2"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3"><text>false</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"Periodo de retencao inferior a 90 dias - risco de perda de dados fiscais"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <description>Arquivamento massivo sem dry run</description>
        <inputEntry id="IE_2_1"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2"><text>&gt; 500</text></inputEntry>
        <inputEntry id="IE_2_3"><text>false</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"Mais de 500 registros para arquivar - executar dry run primeiro"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <description>Dry run - sempre prosseguir</description>
        <inputEntry id="IE_3_1"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2"><text>-</text></inputEntry>
        <inputEntry id="IE_3_3"><text>true</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"Modo simulacao - listar sem arquivar"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_4">
        <description>Arquivamento normal</description>
        <inputEntry id="IE_4_1"><text>&gt;= 365</text></inputEntry>
        <inputEntry id="IE_4_2"><text>&lt;= 500</text></inputEntry>
        <inputEntry id="IE_4_3"><text>false</text></inputEntry>
        <outputEntry id="OE_4_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2"><text>"Arquivamento padrao - retencao de 1+ ano atende requisitos legais"</text></outputEntry>
        <outputEntry id="OE_4_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_5">
        <description>Retencao entre 90-365 dias</description>
        <inputEntry id="IE_5_1"><text>[90..365]</text></inputEntry>
        <inputEntry id="IE_5_2"><text>-</text></inputEntry>
        <inputEntry id="IE_5_3"><text>false</text></inputEntry>
        <outputEntry id="OE_5_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_5_2"><text>"Retencao entre 90-365 dias - verificar requisitos regulatorios"</text></outputEntry>
        <outputEntry id="OE_5_3"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Fallback</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"Avaliar politica de arquivamento manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ARCHIVE_ROUTING">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_ARCHIVE_ROUTING">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
