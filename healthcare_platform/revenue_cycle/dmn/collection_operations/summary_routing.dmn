<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  SUMMARY-ROUTING - Roteamento de Envio de Resumo Diario
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: send_daily_summary_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_SUMMARY_ROUTING"
             name="Roteamento de Envio de Resumo Diario"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_SUMMARY_ROUTING" name="Roteamento de Envio de Resumo Diario">
    <decisionTable id="DecisionTable_SUMMARY_ROUTING" hitPolicy="FIRST">

      <input id="Input_1" label="Taxa Cobranca (%)">
        <inputExpression id="InputExpression_1" typeRef="number">
          <text>collectionRate</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="DSO (dias)">
        <inputExpression id="InputExpression_2" typeRef="number">
          <text>dso</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Quantidade Vencidos">
        <inputExpression id="InputExpression_3" typeRef="number">
          <text>overdueCount</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1">
        <description>Metricas criticas - alerta urgente</description>
        <inputEntry id="IE_1_1"><text>&lt; 60</text></inputEntry>
        <inputEntry id="IE_1_2"><text>&gt; 90</text></inputEntry>
        <inputEntry id="IE_1_3"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"Metricas criticas - enviar alerta urgente para diretoria alem do resumo"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <description>Muitos vencidos - destaque no resumo</description>
        <inputEntry id="IE_2_1"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2"><text>-</text></inputEntry>
        <inputEntry id="IE_2_3"><text>&gt; 50</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"Alto volume de vencidos - destacar no resumo e notificar gestores"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <description>Taxa baixa de cobranca</description>
        <inputEntry id="IE_3_1"><text>[60..80]</text></inputEntry>
        <inputEntry id="IE_3_2"><text>-</text></inputEntry>
        <inputEntry id="IE_3_3"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"Taxa de cobranca abaixo do ideal - incluir recomendacoes no resumo"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_4">
        <description>Metricas saudaveis</description>
        <inputEntry id="IE_4_1"><text>&gt;= 80</text></inputEntry>
        <inputEntry id="IE_4_2"><text>&lt;= 60</text></inputEntry>
        <inputEntry id="IE_4_3"><text>&lt;= 20</text></inputEntry>
        <outputEntry id="OE_4_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2"><text>"Metricas saudaveis - enviar resumo padrao"</text></outputEntry>
        <outputEntry id="OE_4_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_5">
        <description>DSO elevado</description>
        <inputEntry id="IE_5_1"><text>-</text></inputEntry>
        <inputEntry id="IE_5_2"><text>[60..90]</text></inputEntry>
        <inputEntry id="IE_5_3"><text>-</text></inputEntry>
        <outputEntry id="OE_5_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_2"><text>"DSO elevado - incluir analise de tendencia no resumo"</text></outputEntry>
        <outputEntry id="OE_5_3"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Fallback</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"Enviar resumo padrao"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_SUMMARY_ROUTING">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_SUMMARY_ROUTING">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
