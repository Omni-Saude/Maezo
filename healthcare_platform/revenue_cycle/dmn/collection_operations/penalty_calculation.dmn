<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  PENALTY-CALCULATION - Calculo de Multas e Penalidades
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: apply_penalties_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_PENALTY_CALCULATION"
             name="Calculo de Multas e Penalidades"
             targetNamespace="http://healthcare.platform/dmn/collection_operations">

  <decision id="Decision_PENALTY_CALCULATION" name="Calculo de Multas e Penalidades">
    <decisionTable id="DecisionTable_PENALTY_CALCULATION" hitPolicy="FIRST">

      <input id="Input_1" label="Dias em Atraso">
        <inputExpression id="InputExpression_1" typeRef="integer">
          <text>days_overdue</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Valor Devido">
        <inputExpression id="InputExpression_2" typeRef="double">
          <text>amount_due</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Tipo Pagador">
        <inputExpression id="InputExpression_3" typeRef="string">
          <text>payer_type</text>
        </inputExpression>
        <inputValues id="InputValues_3">
          <text>"individual","institutional","government"</text>
        </inputValues>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_amount" label="Valor Multa" name="penalty_amount" typeRef="double"/>
      <output id="Output_rate" label="Taxa Multa" name="penalty_rate" typeRef="double"/>
      <output id="Output_type" label="Tipo Multa" name="penalty_type" typeRef="string">
        <outputValues><text>"MORA","MULTA","JUROS","NONE"</text></outputValues>
      </output>

      <rule id="Rule_Mora">
        <description>Mora - acima 90 dias institucional</description>
        <inputEntry id="IE_1_1"><text>&gt; 90</text></inputEntry>
        <inputEntry id="IE_1_2"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3"><text>"institutional"</text></inputEntry>
        <outputEntry id="OE_1_1"><text>amount_due * 0.02</text></outputEntry>
        <outputEntry id="OE_1_2"><text>0.02</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"MORA"</text></outputEntry>
      </rule>

      <rule id="Rule_Multa">
        <description>Multa - acima 60 dias</description>
        <inputEntry id="IE_2_1"><text>&gt; 60</text></inputEntry>
        <inputEntry id="IE_2_2"><text>-</text></inputEntry>
        <inputEntry id="IE_2_3"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1"><text>amount_due * 0.01</text></outputEntry>
        <outputEntry id="OE_2_2"><text>0.01</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"MULTA"</text></outputEntry>
      </rule>

      <rule id="Rule_Juros">
        <description>Juros - acima 30 dias</description>
        <inputEntry id="IE_3_1"><text>&gt; 30</text></inputEntry>
        <inputEntry id="IE_3_2"><text>-</text></inputEntry>
        <inputEntry id="IE_3_3"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1"><text>amount_due * 0.005</text></outputEntry>
        <outputEntry id="OE_3_2"><text>0.005</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"JUROS"</text></outputEntry>
      </rule>

      <rule id="Rule_NoPenalty">
        <description>Sem penalidade</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>0</text></outputEntry>
        <outputEntry id="OE_F_2"><text>0</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"NONE"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PENALTY_CALCULATION">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_PENALTY_CALCULATION">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
