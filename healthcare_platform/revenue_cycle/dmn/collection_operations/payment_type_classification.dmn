<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  PAYMENT-TYPE-CLASSIFICATION - Classificacao de Tipo de Pagamento
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: classify_payment_type_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_PAYMENT_TYPE_CLASSIFICATION"
             name="Classificacao de Tipo de Pagamento"
             targetNamespace="http://healthcare.platform/dmn/collection_operations">

  <decision id="Decision_PAYMENT_TYPE_CLASSIFICATION" name="Classificacao de Tipo de Pagamento">
    <decisionTable id="DecisionTable_PAYMENT_TYPE_CLASSIFICATION" hitPolicy="FIRST">

      <input id="Input_1" label="Metodo Pagamento">
        <inputExpression id="InputExpression_1" typeRef="string">
          <text>payment_method</text>
        </inputExpression>
        <inputValues id="InputValues_1">
          <text>"PIX","TED","BOLETO","CHEQUE","DEPOSITO","CARTAO"</text>
        </inputValues>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_category" label="Categoria" name="payment_category" typeRef="string">
        <outputValues><text>"electronic","slip","paper","manual","other"</text></outputValues>
      </output>
      <output id="Output_days" label="Dias Processamento" name="processing_days" typeRef="integer"/>
      <output id="Output_review" label="Requer Revisao Manual" name="requires_manual_review" typeRef="boolean"/>

      <rule id="Rule_PIX">
        <description>PIX - pagamento instantaneo</description>
        <inputEntry id="IE_1_1"><text>"PIX"</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"electronic"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>0</text></outputEntry>
        <outputEntry id="OE_1_3"><text>false</text></outputEntry>
      </rule>

      <rule id="Rule_TED">
        <description>TED - transferencia eletronica</description>
        <inputEntry id="IE_2_1"><text>"TED"</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"electronic"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>1</text></outputEntry>
        <outputEntry id="OE_2_3"><text>false</text></outputEntry>
      </rule>

      <rule id="Rule_Boleto">
        <description>Boleto bancario</description>
        <inputEntry id="IE_3_1"><text>"BOLETO"</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"slip"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>3</text></outputEntry>
        <outputEntry id="OE_3_3"><text>false</text></outputEntry>
      </rule>

      <rule id="Rule_Cheque">
        <description>Cheque - requer revisao</description>
        <inputEntry id="IE_4_1"><text>"CHEQUE"</text></inputEntry>
        <outputEntry id="OE_4_1"><text>"paper"</text></outputEntry>
        <outputEntry id="OE_4_2"><text>5</text></outputEntry>
        <outputEntry id="OE_4_3"><text>true</text></outputEntry>
      </rule>

      <rule id="Rule_Deposito">
        <description>Deposito bancario - revisao manual</description>
        <inputEntry id="IE_5_1"><text>"DEPOSITO"</text></inputEntry>
        <outputEntry id="OE_5_1"><text>"manual"</text></outputEntry>
        <outputEntry id="OE_5_2"><text>2</text></outputEntry>
        <outputEntry id="OE_5_3"><text>true</text></outputEntry>
      </rule>

      <rule id="Rule_Cartao">
        <description>Cartao de credito/debito</description>
        <inputEntry id="IE_6_1"><text>"CARTAO"</text></inputEntry>
        <outputEntry id="OE_6_1"><text>"electronic"</text></outputEntry>
        <outputEntry id="OE_6_2"><text>2</text></outputEntry>
        <outputEntry id="OE_6_3"><text>false</text></outputEntry>
      </rule>

      <rule id="Rule_Other">
        <description>Outros metodos - revisar</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"other"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>5</text></outputEntry>
        <outputEntry id="OE_F_3"><text>true</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PAYMENT_TYPE_CLASSIFICATION">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_PAYMENT_TYPE_CLASSIFICATION">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
