<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  CONTRACTUAL-ADJUSTMENT-RULES - Regras de Ajuste Contratual
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: apply_contractual_adjustments_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_CONTRACTUAL_ADJUSTMENT_RULES"
             name="Regras de Ajuste Contratual"
             targetNamespace="http://healthcare.platform/dmn/collection_operations">

  <decision id="Decision_CONTRACTUAL_ADJUSTMENT_RULES" name="Regras de Ajuste Contratual">
    <decisionTable id="DecisionTable_CONTRACTUAL_ADJUSTMENT_RULES" hitPolicy="COLLECT">

      <input id="Input_1" label="ID Contrato Pagador">
        <inputExpression id="InputExpression_1" typeRef="string">
          <text>payer_contract_id</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Codigo Procedimento">
        <inputExpression id="InputExpression_2" typeRef="string">
          <text>procedure_code</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Valor Faturado">
        <inputExpression id="InputExpression_3" typeRef="double">
          <text>billed_amount</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_adjustment" label="Valor Ajuste" name="adjustment_amount" typeRef="double"/>
      <output id="Output_reason" label="Motivo Ajuste" name="adjustment_reason" typeRef="string"/>
      <output id="Output_final" label="Valor Final" name="final_amount" typeRef="double"/>

      <rule id="Rule_SUS_Contract">
        <description>Ajuste contrato SUS (30%)</description>
        <inputEntry id="IE_1_1"><text>starts with(payer_contract_id, "SUS")</text></inputEntry>
        <inputEntry id="IE_1_2"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1"><text>billed_amount * 0.3</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"SUS_TABLE"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>billed_amount * 0.7</text></outputEntry>
      </rule>

      <rule id="Rule_Unimed_Contract">
        <description>Ajuste contrato UNIMED procedimentos cirurgicos (15%)</description>
        <inputEntry id="IE_2_1"><text>starts with(payer_contract_id, "UNIMED")</text></inputEntry>
        <inputEntry id="IE_2_2"><text>starts with(procedure_code, "1")</text></inputEntry>
        <inputEntry id="IE_2_3"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1"><text>billed_amount * 0.15</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"CONTRACTED_RATE"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>billed_amount * 0.85</text></outputEntry>
      </rule>

      <rule id="Rule_Default">
        <description>Sem ajuste contratual</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>0</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"NO_ADJUSTMENT"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>billed_amount</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_CONTRACTUAL_ADJUSTMENT_RULES">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_CONTRACTUAL_ADJUSTMENT_RULES">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
