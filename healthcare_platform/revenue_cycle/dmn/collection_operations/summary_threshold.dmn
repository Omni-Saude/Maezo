<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  SUMMARY-THRESHOLD - Limiares para Alertas no Resumo Diario
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: send_daily_summary_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_SUMMARY_THRESHOLD"
             name="Limiares para Alertas no Resumo Diario"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_SUMMARY_THRESHOLD" name="Limiares para Alertas no Resumo Diario">
    <decisionTable id="DecisionTable_SUMMARY_THRESHOLD" hitPolicy="FIRST">

      <input id="Input_1" label="Valor Vencido (R$)">
        <inputExpression id="InputExpression_1" typeRef="number">
          <text>overdueAmount</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Valor Arrecadado Hoje (R$)">
        <inputExpression id="InputExpression_2" typeRef="number">
          <text>amountCollectedToday</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Destinatarios">
        <inputExpression id="InputExpression_3" typeRef="number">
          <text>recipientCount</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1">
        <description>Valor vencido critico</description>
        <inputEntry id="IE_1_1"><text>&gt; 1000000</text></inputEntry>
        <inputEntry id="IE_1_2"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"Valor vencido acima de R$1M - escalar para diretoria financeira"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <description>Sem destinatarios configurados</description>
        <inputEntry id="IE_2_1"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2"><text>-</text></inputEntry>
        <inputEntry id="IE_2_3"><text>0</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"Nenhum destinatario configurado para o resumo"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <description>Nenhuma arrecadacao no dia</description>
        <inputEntry id="IE_3_1"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2"><text>0</text></inputEntry>
        <inputEntry id="IE_3_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"Nenhuma arrecadacao registrada hoje - verificar integracao de pagamentos"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_4">
        <description>Vencidos moderados</description>
        <inputEntry id="IE_4_1"><text>[100000..1000000]</text></inputEntry>
        <inputEntry id="IE_4_2"><text>&gt; 0</text></inputEntry>
        <inputEntry id="IE_4_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="OE_4_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2"><text>"Incluir destaque de valores vencidos no resumo"</text></outputEntry>
        <outputEntry id="OE_4_3"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_5">
        <description>Operacao normal</description>
        <inputEntry id="IE_5_1"><text>&lt; 100000</text></inputEntry>
        <inputEntry id="IE_5_2"><text>&gt; 0</text></inputEntry>
        <inputEntry id="IE_5_3"><text>&gt; 0</text></inputEntry>
        <outputEntry id="OE_5_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_2"><text>"Enviar resumo padrao sem alertas especiais"</text></outputEntry>
        <outputEntry id="OE_5_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Fallback</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"Enviar resumo com configuracao padrao"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_SUMMARY_THRESHOLD">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_SUMMARY_THRESHOLD">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
