<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  ERP-MAPPING - Mapeamento de Campos para ERP
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_OPERATIONS
  Archetype: ROUTING | Source: export_to_erp_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_ERP_MAPPING"
             name="Mapeamento de Campos para ERP"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_ERP_MAPPING" name="Mapeamento de Campos para ERP">
    <decisionTable id="DecisionTable_ERP_MAPPING" hitPolicy="FIRST">

      <input id="Input_1" label="Sistema ERP">
        <inputExpression id="InputExpression_1" typeRef="string">
          <text>erpSystem</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Tipo Registro">
        <inputExpression id="InputExpression_2" typeRef="string">
          <text>recordType</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Versao API">
        <inputExpression id="InputExpression_3" typeRef="string">
          <text>apiVersion</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1">
        <description>Tasy - mapeamento padrao CDC</description>
        <inputEntry id="IE_1_1"><text>"TASY"</text></inputEntry>
        <inputEntry id="IE_1_2"><text>"PAYMENT"</text></inputEntry>
        <inputEntry id="IE_1_3"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"Usar mapeamento Tasy CDC padrao - campos nr_titulo, vl_pagamento"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <description>MV Soul - mapeamento legado</description>
        <inputEntry id="IE_2_1"><text>"MV_SOUL"</text></inputEntry>
        <inputEntry id="IE_2_2"><text>"PAYMENT"</text></inputEntry>
        <inputEntry id="IE_2_3"><text>"v1"</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"API v1 MV Soul depreciada - migrar para v2 quando possivel"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <description>Tipo registro desconhecido</description>
        <inputEntry id="IE_3_1"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2"><text>not("PAYMENT","ADJUSTMENT","GLOSA","CREDIT")</text></inputEntry>
        <inputEntry id="IE_3_3"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"Tipo de registro nao mapeado para exportacao ERP"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_4">
        <description>Ajuste contabil - requer campos extras</description>
        <inputEntry id="IE_4_1"><text>-</text></inputEntry>
        <inputEntry id="IE_4_2"><text>"ADJUSTMENT"</text></inputEntry>
        <inputEntry id="IE_4_3"><text>-</text></inputEntry>
        <outputEntry id="OE_4_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2"><text>"Incluir centro de custo e conta contabil no mapeamento"</text></outputEntry>
        <outputEntry id="OE_4_3"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_5">
        <description>Credito/estorno - validacao adicional</description>
        <inputEntry id="IE_5_1"><text>-</text></inputEntry>
        <inputEntry id="IE_5_2"><text>"CREDIT"</text></inputEntry>
        <inputEntry id="IE_5_3"><text>-</text></inputEntry>
        <outputEntry id="OE_5_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_5_2"><text>"Credito requer aprovacao antes de exportar ao ERP"</text></outputEntry>
        <outputEntry id="OE_5_3"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Fallback</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"Validar mapeamento ERP manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ERP_MAPPING">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_ERP_MAPPING">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
