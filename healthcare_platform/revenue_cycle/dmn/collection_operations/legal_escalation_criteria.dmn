<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  LEGAL-ESCALATION-CRITERIA - Criterios para Escalacao Juridica
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: escalate_to_legal_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_LEGAL_ESCALATION_CRITERIA"
             name="Criterios para Escalacao Juridica"
             targetNamespace="http://healthcare.platform/dmn/collection_operations">

  <decision id="Decision_LEGAL_ESCALATION_CRITERIA" name="Criterios para Escalacao Juridica">
    <decisionTable id="DecisionTable_LEGAL_ESCALATION_CRITERIA" hitPolicy="FIRST">

      <input id="Input_1" label="Valor Devido">
        <inputExpression id="InputExpression_1" typeRef="double">
          <text>amount_due</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Dias em Atraso">
        <inputExpression id="InputExpression_2" typeRef="integer">
          <text>days_overdue</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Tentativas Cobranca">
        <inputExpression id="InputExpression_3" typeRef="integer">
          <text>collection_attempts</text>
        </inputExpression>
      </input>

      <input id="Input_4" label="Tipo Pagador">
        <inputExpression id="InputExpression_4" typeRef="string">
          <text>payer_type</text>
        </inputExpression>
        <inputValues id="InputValues_4">
          <text>"individual","corporate","government"</text>
        </inputValues>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_escalate" label="Escalar para Juridico" name="escalate_to_legal" typeRef="boolean"/>
      <output id="Output_urgency" label="Nivel Urgencia" name="urgency_level" typeRef="string">
        <outputValues><text>"critical","high","medium","none"</text></outputValues>
      </output>
      <output id="Output_reason" label="Codigo Motivo" name="reason_code" typeRef="string">
        <outputValues><text>"CHRONIC_DEFAULT","EXHAUSTED_COLLECTION","INDIVIDUAL_DEFAULT","NOT_APPLICABLE"</text></outputValues>
      </output>

      <rule id="Rule_Critical_1">
        <description>Critico: Inadimplencia cronica com alto valor</description>
        <inputEntry id="IE_1_1"><text>&gt; 10000</text></inputEntry>
        <inputEntry id="IE_1_2"><text>&gt; 180</text></inputEntry>
        <inputEntry id="IE_1_3"><text>-</text></inputEntry>
        <inputEntry id="IE_1_4"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1"><text>true</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"critical"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"CHRONIC_DEFAULT"</text></outputEntry>
      </rule>

      <rule id="Rule_High_1">
        <description>Alto: Esgotadas tentativas de cobranca</description>
        <inputEntry id="IE_2_1"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2"><text>&gt; 120</text></inputEntry>
        <inputEntry id="IE_2_3"><text>&gt; 5</text></inputEntry>
        <inputEntry id="IE_2_4"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1"><text>true</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"high"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"EXHAUSTED_COLLECTION"</text></outputEntry>
      </rule>

      <rule id="Rule_Medium_1">
        <description>Medio: Pessoa fisica com valor significativo</description>
        <inputEntry id="IE_3_1"><text>&gt; 5000</text></inputEntry>
        <inputEntry id="IE_3_2"><text>&gt; 90</text></inputEntry>
        <inputEntry id="IE_3_3"><text>-</text></inputEntry>
        <inputEntry id="IE_3_4"><text>"individual"</text></inputEntry>
        <outputEntry id="OE_3_1"><text>true</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"medium"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"INDIVIDUAL_DEFAULT"</text></outputEntry>
      </rule>

      <rule id="Rule_NoEscalation">
        <description>Nao escalar: Criterios nao atingidos</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <inputEntry id="IE_F_4"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>false</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"none"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"NOT_APPLICABLE"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_LEGAL_ESCALATION_CRITERIA">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_LEGAL_ESCALATION_CRITERIA">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
