<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  CURRENCY-VALIDATION - Validacao de Conversao de Moeda
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: convert_currency_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_CURRENCY_VALIDATION"
             name="Validacao de Conversao de Moeda"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_CURRENCY_VALIDATION" name="Validacao de Conversao de Moeda">
    <decisionTable id="DecisionTable_CURRENCY_VALIDATION" hitPolicy="FIRST">

      <input id="Input_1" label="Taxa Cambio">
        <inputExpression id="InputExpression_1" typeRef="number">
          <text>exchangeRate</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Variacao vs PTAX (%)">
        <inputExpression id="InputExpression_2" typeRef="number">
          <text>ptaxVariationPct</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Valor Convertido (R$)">
        <inputExpression id="InputExpression_3" typeRef="number">
          <text>convertedAmountBRL</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1">
        <description>Taxa zero ou negativa</description>
        <inputEntry id="IE_1_1"><text>&lt;= 0</text></inputEntry>
        <inputEntry id="IE_1_2"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"Taxa de cambio invalida - nao pode ser zero ou negativa"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <description>Variacao excessiva vs PTAX</description>
        <inputEntry id="IE_2_1"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2"><text>&gt; 5</text></inputEntry>
        <inputEntry id="IE_2_3"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"Taxa com variacao superior a 5% do PTAX - validar com tesouraria"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <description>Conversao de alto valor</description>
        <inputEntry id="IE_3_1"><text>&gt; 0</text></inputEntry>
        <inputEntry id="IE_3_2"><text>[0..5]</text></inputEntry>
        <inputEntry id="IE_3_3"><text>&gt; 500000</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"Conversao de alto valor - requer dupla aprovacao"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_4">
        <description>Conversao padrao valida</description>
        <inputEntry id="IE_4_1"><text>&gt; 0</text></inputEntry>
        <inputEntry id="IE_4_2"><text>[0..5]</text></inputEntry>
        <inputEntry id="IE_4_3"><text>&lt;= 500000</text></inputEntry>
        <outputEntry id="OE_4_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2"><text>"Conversao validada - taxa dentro da faixa aceitavel"</text></outputEntry>
        <outputEntry id="OE_4_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Fallback</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"Validar conversao manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_CURRENCY_VALIDATION">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_CURRENCY_VALIDATION">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
