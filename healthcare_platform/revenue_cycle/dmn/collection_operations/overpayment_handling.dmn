<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  OVERPAYMENT-HANDLING - Tratamento de Pagamento Excedente
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: handle_overpayment_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_OVERPAYMENT_HANDLING"
             name="Tratamento de Pagamento Excedente"
             targetNamespace="http://healthcare.platform/dmn/collection_operations">

  <decision id="Decision_OVERPAYMENT_HANDLING" name="Tratamento de Pagamento Excedente">
    <decisionTable id="DecisionTable_OVERPAYMENT_HANDLING" hitPolicy="FIRST">

      <input id="Input_1" label="Valor Excedente">
        <inputExpression id="InputExpression_1" typeRef="double">
          <text>overpayment_amount</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Tipo Pagador">
        <inputExpression id="InputExpression_2" typeRef="string">
          <text>payer_type</text>
        </inputExpression>
        <inputValues id="InputValues_2">
          <text>"individual","corporate","government"</text>
        </inputValues>
      </input>

      <input id="Input_3" label="Status Relacionamento">
        <inputExpression id="InputExpression_3" typeRef="string">
          <text>relationship_status</text>
        </inputExpression>
        <inputValues id="InputValues_3">
          <text>"active","inactive"</text>
        </inputValues>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_action" label="Acao" name="action" typeRef="string">
        <outputValues><text>"CREDIT_NEXT_INVOICE","CREDIT_ACCOUNT","REFUND"</text></outputValues>
      </output>
      <output id="Output_priority" label="Prioridade Processamento" name="processing_priority" typeRef="string">
        <outputValues><text>"low","medium","high"</text></outputValues>
      </output>
      <output id="Output_approval" label="Aprovacao Necessaria" name="approval_required" typeRef="boolean"/>

      <rule id="Rule_SmallActive">
        <description>Valor pequeno com relacionamento ativo - creditar proxima fatura</description>
        <inputEntry id="IE_1_1"><text>&lt; 100</text></inputEntry>
        <inputEntry id="IE_1_2"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3"><text>"active"</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"CREDIT_NEXT_INVOICE"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"low"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>false</text></outputEntry>
      </rule>

      <rule id="Rule_MediumActive">
        <description>Valor medio com relacionamento ativo - creditar conta</description>
        <inputEntry id="IE_2_1"><text>&lt; 1000</text></inputEntry>
        <inputEntry id="IE_2_2"><text>-</text></inputEntry>
        <inputEntry id="IE_2_3"><text>"active"</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"CREDIT_ACCOUNT"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"medium"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>false</text></outputEntry>
      </rule>

      <rule id="Rule_LargeAmount">
        <description>Valor alto - reembolso com aprovacao</description>
        <inputEntry id="IE_3_1"><text>&gt;= 1000</text></inputEntry>
        <inputEntry id="IE_3_2"><text>-</text></inputEntry>
        <inputEntry id="IE_3_3"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"REFUND"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"high"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>true</text></outputEntry>
      </rule>

      <rule id="Rule_Inactive">
        <description>Relacionamento inativo - reembolso</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>"inactive"</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"REFUND"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"medium"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>true</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_OVERPAYMENT_HANDLING">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_OVERPAYMENT_HANDLING">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
