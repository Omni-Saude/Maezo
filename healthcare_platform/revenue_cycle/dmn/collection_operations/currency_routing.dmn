<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  CURRENCY-ROUTING - Roteamento de Conversao de Moeda
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: convert_currency_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_CURRENCY_ROUTING"
             name="Roteamento de Conversao de Moeda"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_CURRENCY_ROUTING" name="Roteamento de Conversao de Moeda">
    <decisionTable id="DecisionTable_CURRENCY_ROUTING" hitPolicy="FIRST">

      <input id="Input_1" label="Moeda Origem">
        <inputExpression id="InputExpression_1" typeRef="string">
          <text>currency</text>
        </inputExpression>
        <inputValues id="InputValues_1">
          <text>"BRL","USD","EUR","GBP"</text>
        </inputValues>
      </input>

      <input id="Input_2" label="Valor Bruto">
        <inputExpression id="InputExpression_2" typeRef="number">
          <text>grossAmount</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Taxa Cambio Disponivel">
        <inputExpression id="InputExpression_3" typeRef="boolean">
          <text>exchangeRateAvailable</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1">
        <description>Ja em BRL - sem conversao necessaria</description>
        <inputEntry id="IE_1_1"><text>"BRL"</text></inputEntry>
        <inputEntry id="IE_1_2"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"Pagamento ja em BRL - nenhuma conversao necessaria"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <description>Moeda estrangeira sem taxa disponivel</description>
        <inputEntry id="IE_2_1"><text>not("BRL")</text></inputEntry>
        <inputEntry id="IE_2_2"><text>-</text></inputEntry>
        <inputEntry id="IE_2_3"><text>false</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"Taxa de cambio nao disponivel - buscar cotacao antes de converter"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <description>Conversao de alto valor</description>
        <inputEntry id="IE_3_1"><text>not("BRL")</text></inputEntry>
        <inputEntry id="IE_3_2"><text>&gt; 100000</text></inputEntry>
        <inputEntry id="IE_3_3"><text>true</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"Conversao de alto valor - validar taxa de cambio com tesouraria"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_4">
        <description>Conversao USD padrao</description>
        <inputEntry id="IE_4_1"><text>"USD"</text></inputEntry>
        <inputEntry id="IE_4_2"><text>&lt;= 100000</text></inputEntry>
        <inputEntry id="IE_4_3"><text>true</text></inputEntry>
        <outputEntry id="OE_4_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2"><text>"Converter USD para BRL usando taxa vigente"</text></outputEntry>
        <outputEntry id="OE_4_3"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_5">
        <description>Conversao EUR/GBP padrao</description>
        <inputEntry id="IE_5_1"><text>"EUR","GBP"</text></inputEntry>
        <inputEntry id="IE_5_2"><text>&lt;= 100000</text></inputEntry>
        <inputEntry id="IE_5_3"><text>true</text></inputEntry>
        <outputEntry id="OE_5_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_2"><text>"Converter para BRL usando taxa vigente"</text></outputEntry>
        <outputEntry id="OE_5_3"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Fallback - moeda desconhecida</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"Moeda nao suportada - encaminhar para tratamento manual"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"ALTO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_CURRENCY_ROUTING">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_CURRENCY_ROUTING">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
