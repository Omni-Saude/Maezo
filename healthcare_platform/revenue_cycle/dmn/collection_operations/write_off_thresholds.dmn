<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  WRITE-OFF-THRESHOLDS - Limiares para Write-off de Contas
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: write_off_bad_debt_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_WRITE_OFF_THRESHOLDS"
             name="Limiares para Write-off de Contas"
             targetNamespace="http://healthcare.platform/dmn/collection_operations">

  <decision id="Decision_WRITE_OFF_THRESHOLDS" name="Limiares para Write-off de Contas">
    <decisionTable id="DecisionTable_WRITE_OFF_THRESHOLDS" hitPolicy="FIRST">

      <input id="Input_1" label="Valor">
        <inputExpression id="InputExpression_1" typeRef="double">
          <text>amount</text>
        </inputExpression>
      </input>

      <input id="Input_2" label="Dias em Atraso">
        <inputExpression id="InputExpression_2" typeRef="integer">
          <text>days_overdue</text>
        </inputExpression>
      </input>

      <input id="Input_3" label="Custo Cobranca">
        <inputExpression id="InputExpression_3" typeRef="double">
          <text>collection_cost</text>
        </inputExpression>
      </input>

      <input id="Input_4" label="Probabilidade Recuperacao">
        <inputExpression id="InputExpression_4" typeRef="double">
          <text>recovery_probability</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_approved" label="Aprovar Write-off" name="write_off_approved" typeRef="boolean"/>
      <output id="Output_reason" label="Codigo Motivo" name="reason_code" typeRef="string">
        <outputValues><text>"SMALL_BALANCE","LOW_RECOVERY","COST_EXCEEDS","NONE"</text></outputValues>
      </output>
      <output id="Output_manager" label="Requer Aprovacao Gerente" name="requires_manager_approval" typeRef="boolean"/>

      <rule id="Rule_SmallBalance">
        <description>Saldo pequeno com atraso longo</description>
        <inputEntry id="IE_1_1"><text>&lt; 100</text></inputEntry>
        <inputEntry id="IE_1_2"><text>&gt; 365</text></inputEntry>
        <inputEntry id="IE_1_3"><text>-</text></inputEntry>
        <inputEntry id="IE_1_4"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1"><text>true</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"SMALL_BALANCE"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>false</text></outputEntry>
      </rule>

      <rule id="Rule_LowRecovery">
        <description>Baixa probabilidade de recuperacao</description>
        <inputEntry id="IE_2_1"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2"><text>&gt; 180</text></inputEntry>
        <inputEntry id="IE_2_3"><text>-</text></inputEntry>
        <inputEntry id="IE_2_4"><text>&lt; 0.1</text></inputEntry>
        <outputEntry id="OE_2_1"><text>true</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"LOW_RECOVERY"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>true</text></outputEntry>
      </rule>

      <rule id="Rule_CostExceeds">
        <description>Custo cobranca excede valor recuperavel</description>
        <inputEntry id="IE_3_1"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2"><text>-</text></inputEntry>
        <inputEntry id="IE_3_3"><text>&gt; amount * 0.5</text></inputEntry>
        <inputEntry id="IE_3_4"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1"><text>true</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"COST_EXCEEDS"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>true</text></outputEntry>
      </rule>

      <rule id="Rule_NoWriteOff">
        <description>Nao aprovar write-off</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <inputEntry id="IE_F_4"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>false</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"NONE"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>false</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_WRITE_OFF_THRESHOLDS">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_WRITE_OFF_THRESHOLDS">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
