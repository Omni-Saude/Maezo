<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  ERP-EXPORT-ROUTING - Roteamento de Exportacao ERP
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: export_to_erp_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_ERP_EXPORT_ROUTING"
             name="Roteamento de Exportacao ERP"
             targetNamespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_ERP_EXPORT_ROUTING" name="Roteamento de Exportacao ERP">
    <decisionTable id="DecisionTable_ERP_EXPORT_ROUTING" hitPolicy="FIRST">

      <input id="Input_1" label="Sistema ERP">
        <inputExpression id="InputExpression_1" typeRef="string">
          <text>erpSystem</text>
        </inputExpression>
        <inputValues id="InputValues_1">
          <text>"tasy","mv_soul"</text>
        </inputValues>
      </input>

      <input id="Input_2" label="Tipo Entidade">
        <inputExpression id="InputExpression_2" typeRef="string">
          <text>entityType</text>
        </inputExpression>
        <inputValues id="InputValues_2">
          <text>"payment","reconciliation","adjustment","refund"</text>
        </inputValues>
      </input>

      <input id="Input_3" label="Operacao">
        <inputExpression id="InputExpression_3" typeRef="string">
          <text>operation</text>
        </inputExpression>
        <inputValues id="InputValues_3">
          <text>"insert","update","delete"</text>
        </inputValues>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1">
        <description>Delecao em ERP requer aprovacao</description>
        <inputEntry id="IE_1_1"><text>-</text></inputEntry>
        <inputEntry id="IE_1_2"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3"><text>"delete"</text></inputEntry>
        <outputEntry id="OE_1_1"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2"><text>"Operacao de delecao requer aprovacao de supervisor antes da sincronizacao"</text></outputEntry>
        <outputEntry id="OE_1_3"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2">
        <description>Reembolso em qualquer ERP requer revisao</description>
        <inputEntry id="IE_2_1"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2"><text>"refund"</text></inputEntry>
        <inputEntry id="IE_2_3"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_2"><text>"Exportacao de reembolso requer validacao antes da sincronizacao"</text></outputEntry>
        <outputEntry id="OE_2_3"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_3">
        <description>Pagamento via Tasy - rota padrao</description>
        <inputEntry id="IE_3_1"><text>"tasy"</text></inputEntry>
        <inputEntry id="IE_3_2"><text>"payment"</text></inputEntry>
        <inputEntry id="IE_3_3"><text>"insert"</text></inputEntry>
        <outputEntry id="OE_3_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_3_2"><text>"Sincronizar pagamento via Tasy API REST"</text></outputEntry>
        <outputEntry id="OE_3_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_4">
        <description>MV Soul - rota padrao</description>
        <inputEntry id="IE_4_1"><text>"mv_soul"</text></inputEntry>
        <inputEntry id="IE_4_2"><text>"payment"</text></inputEntry>
        <inputEntry id="IE_4_3"><text>"insert"</text></inputEntry>
        <outputEntry id="OE_4_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2"><text>"Sincronizar pagamento via MV Soul API"</text></outputEntry>
        <outputEntry id="OE_4_3"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_5">
        <description>Atualizacao de reconciliacao</description>
        <inputEntry id="IE_5_1"><text>-</text></inputEntry>
        <inputEntry id="IE_5_2"><text>"reconciliation"</text></inputEntry>
        <inputEntry id="IE_5_3"><text>"update"</text></inputEntry>
        <outputEntry id="OE_5_1"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_2"><text>"Atualizar reconciliacao no ERP"</text></outputEntry>
        <outputEntry id="OE_5_3"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback">
        <description>Fallback</description>
        <inputEntry id="IE_F_1"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2"><text>"Operacao ERP nao mapeada - avaliar manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ERP_EXPORT_ROUTING">
      <dmndi:DMNShape id="DMNShape_Decision" dmnElementRef="Decision_ERP_EXPORT_ROUTING">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
