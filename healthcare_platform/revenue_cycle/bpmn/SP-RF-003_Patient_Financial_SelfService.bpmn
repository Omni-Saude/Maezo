<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_SP_RF_003"
                  targetNamespace="http://cib7.healthcare/revenue-cycle/financial-selfservice"
                  exporter="CIB Seven Modeler"
                  exporterVersion="2.1.3">

  <!-- ========================================
       COLLABORATION
       ======================================== -->
  <bpmn:collaboration id="Collaboration_PatientFinancialSelfService">
    <bpmn:participant id="Participant_PatientSelfService" name="Patient Financial Self-Service" processRef="SP_RF_003_Patient_Financial_SelfService" />
  </bpmn:collaboration>

  <!-- ========================================
       PROCESS DEFINITION
       ======================================== -->
  <bpmn:process id="SP_RF_003_Patient_Financial_SelfService"
                name="Patient Financial Self-Service"
                isExecutable="true"
                camunda:versionTag="1.0.0">

    <!-- ========================================
         START EVENT
         ======================================== -->
    <bpmn:startEvent id="StartEvent_FinancialServiceTriggered" name="Financial Service Triggered">
      <bpmn:outgoing>Flow_ToServiceTypeGateway</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- ========================================
         SERVICE TYPE GATEWAY
         ======================================== -->
    <bpmn:exclusiveGateway id="Gateway_ServiceType" name="Service Type?">
      <bpmn:incoming>Flow_ToServiceTypeGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_PreVisitEstimate</bpmn:outgoing>
      <bpmn:outgoing>Flow_BillReady</bpmn:outgoing>
      <bpmn:outgoing>Flow_InsuranceUpdate</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sequenceFlow id="Flow_ToServiceTypeGateway" sourceRef="StartEvent_FinancialServiceTriggered" targetRef="Gateway_ServiceType" />
    <bpmn:sequenceFlow id="Flow_PreVisitEstimate" name="Pre-Visit Estimate" sourceRef="Gateway_ServiceType" targetRef="Task_CalculateCopayEstimate">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${serviceType == 'PRE_VISIT_ESTIMATE'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_BillReady" name="Bill Ready" sourceRef="Gateway_ServiceType" targetRef="Task_GenerateBillDetails">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${serviceType == 'BILL_READY'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_InsuranceUpdate" name="Insurance Update" sourceRef="Gateway_ServiceType" targetRef="Task_RequestInsuranceInfo">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${serviceType == 'INSURANCE_UPDATE'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <!-- ========================================
         PATH A: PRE-VISIT ESTIMATE
         ======================================== -->
    <bpmn:serviceTask id="Task_CalculateCopayEstimate"
                      name="Calculate Copay Estimate"
                      camunda:type="external"
                      camunda:topic="financial.copay_estimate">
      <bpmn:incoming>Flow_PreVisitEstimate</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSendEstimate</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:boundaryEvent id="BoundaryEvent_EstimateError" name="Estimate Error" attachedToRef="Task_CalculateCopayEstimate">
      <bpmn:outgoing>Flow_EstimateErrorToMerge</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_EstimateError" errorRef="Error_FinancialEstimate" />
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="Task_SendEstimate"
                      name="Send Estimate to Patient"
                      camunda:type="external"
                      camunda:topic="financial.send_estimate">
      <bpmn:incoming>Flow_ToSendEstimate</bpmn:incoming>
      <bpmn:outgoing>Flow_ToPatientAck</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:intermediateCatchEvent id="Event_PatientAcknowledgment" name="Patient Acknowledgment">
      <bpmn:incoming>Flow_ToPatientAck</bpmn:incoming>
      <bpmn:outgoing>Flow_PatientAckToMerge</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_PatientAck" messageRef="Message_PatientAck" />
    </bpmn:intermediateCatchEvent>

    <bpmn:boundaryEvent id="BoundaryEvent_AckTimeout" name="3 Days" cancelActivity="true" attachedToRef="Event_PatientAcknowledgment">
      <bpmn:outgoing>Flow_AckTimeoutToMerge</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_AckTimeout">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P3D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:sequenceFlow id="Flow_ToSendEstimate" sourceRef="Task_CalculateCopayEstimate" targetRef="Task_SendEstimate" />
    <bpmn:sequenceFlow id="Flow_ToPatientAck" sourceRef="Task_SendEstimate" targetRef="Event_PatientAcknowledgment" />
    <bpmn:sequenceFlow id="Flow_PatientAckToMerge" sourceRef="Event_PatientAcknowledgment" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_AckTimeoutToMerge" sourceRef="BoundaryEvent_AckTimeout" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_EstimateErrorToMerge" sourceRef="BoundaryEvent_EstimateError" targetRef="Gateway_Merge" />

    <!-- ========================================
         PATH B: BILL READY
         ======================================== -->
    <bpmn:serviceTask id="Task_GenerateBillDetails"
                      name="Generate Bill Details"
                      camunda:type="external"
                      camunda:topic="financial.bill_ready">
      <bpmn:incoming>Flow_BillReady</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSendBillNotification</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_SendBillNotification"
                      name="Send Bill Notification"
                      camunda:type="external"
                      camunda:topic="financial.bill_notification">
      <bpmn:incoming>Flow_ToSendBillNotification</bpmn:incoming>
      <bpmn:outgoing>Flow_ToPatientAction</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_PatientAction" name="Patient Action?">
      <bpmn:incoming>Flow_ToPatientAction</bpmn:incoming>
      <bpmn:outgoing>Flow_ViewBill</bpmn:outgoing>
      <bpmn:outgoing>Flow_PayBill</bpmn:outgoing>
      <bpmn:outgoing>Flow_QuestionBill</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sequenceFlow id="Flow_ToSendBillNotification" sourceRef="Task_GenerateBillDetails" targetRef="Task_SendBillNotification" />
    <bpmn:sequenceFlow id="Flow_ToPatientAction" sourceRef="Task_SendBillNotification" targetRef="Gateway_PatientAction" />
    <bpmn:sequenceFlow id="Flow_ViewBill" name="View" sourceRef="Gateway_PatientAction" targetRef="Task_SendDetailedBill">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${patientAction == 'VIEW'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_PayBill" name="Pay" sourceRef="Gateway_PatientAction" targetRef="SubProcess_PaymentFlow">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${patientAction == 'PAY'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_QuestionBill" name="Question" sourceRef="Gateway_PatientAction" targetRef="Task_RouteBillingSupport">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${patientAction == 'QUESTION'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <!-- View Bill Path -->
    <bpmn:serviceTask id="Task_SendDetailedBill"
                      name="Send Detailed Bill"
                      camunda:type="external"
                      camunda:topic="financial.bill_detail">
      <bpmn:incoming>Flow_ViewBill</bpmn:incoming>
      <bpmn:outgoing>Flow_ViewToMerge</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sequenceFlow id="Flow_ViewToMerge" sourceRef="Task_SendDetailedBill" targetRef="Gateway_Merge" />

    <!-- Question Bill Path -->
    <bpmn:serviceTask id="Task_RouteBillingSupport"
                      name="Route to Billing Support"
                      camunda:type="external"
                      camunda:topic="financial.billing_support">
      <bpmn:incoming>Flow_QuestionBill</bpmn:incoming>
      <bpmn:outgoing>Flow_QuestionToMerge</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sequenceFlow id="Flow_QuestionToMerge" sourceRef="Task_RouteBillingSupport" targetRef="Gateway_Merge" />

    <!-- ========================================
         SUBPROCESS: PAYMENT FLOW
         ======================================== -->
    <bpmn:subProcess id="SubProcess_PaymentFlow" name="Payment Flow">
      <bpmn:incoming>Flow_PayBill</bpmn:incoming>
      <bpmn:outgoing>Flow_PaymentToMerge</bpmn:outgoing>

      <bpmn:startEvent id="StartEvent_Payment" name="Payment Started">
        <bpmn:outgoing>Flow_ToPaymentMethod</bpmn:outgoing>
      </bpmn:startEvent>

      <bpmn:exclusiveGateway id="Gateway_PaymentMethod" name="Payment Method?">
        <bpmn:incoming>Flow_ToPaymentMethod</bpmn:incoming>
        <bpmn:outgoing>Flow_PayNow</bpmn:outgoing>
        <bpmn:outgoing>Flow_PayLater</bpmn:outgoing>
      </bpmn:exclusiveGateway>

      <bpmn:sequenceFlow id="Flow_ToPaymentMethod" sourceRef="StartEvent_Payment" targetRef="Gateway_PaymentMethod" />
      <bpmn:sequenceFlow id="Flow_PayNow" name="Pay Now" sourceRef="Gateway_PaymentMethod" targetRef="Task_ProcessPayment">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${paymentMethod == 'PAY_NOW'}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="Flow_PayLater" name="Pay Later" sourceRef="Gateway_PaymentMethod" targetRef="Task_SetupPaymentPlan">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${paymentMethod == 'PAY_LATER'}</bpmn:conditionExpression>
      </bpmn:sequenceFlow>

      <!-- Pay Now Path -->
      <bpmn:serviceTask id="Task_ProcessPayment"
                        name="Process Payment"
                        camunda:type="external"
                        camunda:topic="financial.payment_process">
        <bpmn:incoming>Flow_PayNow</bpmn:incoming>
        <bpmn:outgoing>Flow_ProcessPaymentToConfirmed</bpmn:outgoing>
      </bpmn:serviceTask>

      <bpmn:boundaryEvent id="BoundaryEvent_PaymentFailure" name="Payment Failure" attachedToRef="Task_ProcessPayment">
        <bpmn:outgoing>Flow_PaymentFailureToEnd</bpmn:outgoing>
        <bpmn:errorEventDefinition id="ErrorEventDefinition_PaymentFailure" errorRef="Error_FinancialPayment" />
      </bpmn:boundaryEvent>

      <!-- Pay Later Path -->
      <bpmn:serviceTask id="Task_SetupPaymentPlan"
                        name="Setup Payment Plan"
                        camunda:type="external"
                        camunda:topic="financial.payment_plan">
        <bpmn:incoming>Flow_PayLater</bpmn:incoming>
        <bpmn:outgoing>Flow_PaymentPlanToConfirmed</bpmn:outgoing>
      </bpmn:serviceTask>

      <bpmn:sequenceFlow id="Flow_ProcessPaymentToConfirmed" sourceRef="Task_ProcessPayment" targetRef="Task_PaymentConfirmed" />
      <bpmn:sequenceFlow id="Flow_PaymentPlanToConfirmed" sourceRef="Task_SetupPaymentPlan" targetRef="Task_PaymentConfirmed" />

      <!-- Payment Confirmed -->
      <bpmn:serviceTask id="Task_PaymentConfirmed"
                        name="Payment Confirmed"
                        camunda:type="external"
                        camunda:topic="financial.payment_confirmed">
        <bpmn:incoming>Flow_ProcessPaymentToConfirmed</bpmn:incoming>
        <bpmn:incoming>Flow_PaymentPlanToConfirmed</bpmn:incoming>
        <bpmn:outgoing>Flow_ToSendReceipt</bpmn:outgoing>
      </bpmn:serviceTask>

      <bpmn:serviceTask id="Task_SendReceipt"
                        name="Send Receipt"
                        camunda:type="external"
                        camunda:topic="financial.send_receipt">
        <bpmn:incoming>Flow_ToSendReceipt</bpmn:incoming>
        <bpmn:outgoing>Flow_ReceiptToEnd</bpmn:outgoing>
      </bpmn:serviceTask>

      <bpmn:sequenceFlow id="Flow_ToSendReceipt" sourceRef="Task_PaymentConfirmed" targetRef="Task_SendReceipt" />
      <bpmn:sequenceFlow id="Flow_ReceiptToEnd" sourceRef="Task_SendReceipt" targetRef="EndEvent_PaymentComplete" />
      <bpmn:sequenceFlow id="Flow_PaymentFailureToEnd" sourceRef="BoundaryEvent_PaymentFailure" targetRef="EndEvent_PaymentComplete" />

      <bpmn:endEvent id="EndEvent_PaymentComplete" name="Payment Complete">
        <bpmn:incoming>Flow_ReceiptToEnd</bpmn:incoming>
        <bpmn:incoming>Flow_PaymentFailureToEnd</bpmn:incoming>
      </bpmn:endEvent>
    </bpmn:subProcess>

    <bpmn:sequenceFlow id="Flow_PaymentToMerge" sourceRef="SubProcess_PaymentFlow" targetRef="Gateway_Merge" />

    <!-- ========================================
         PATH C: INSURANCE UPDATE
         ======================================== -->
    <bpmn:serviceTask id="Task_RequestInsuranceInfo"
                      name="Request Insurance Info"
                      camunda:type="external"
                      camunda:topic="financial.insurance_request">
      <bpmn:incoming>Flow_InsuranceUpdate</bpmn:incoming>
      <bpmn:outgoing>Flow_ToInsuranceResponse</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:intermediateCatchEvent id="Event_InsuranceResponse" name="Insurance Response">
      <bpmn:incoming>Flow_ToInsuranceResponse</bpmn:incoming>
      <bpmn:outgoing>Flow_ToVerifyCoverage</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_InsuranceResponse" messageRef="Message_InsuranceResponse" />
    </bpmn:intermediateCatchEvent>

    <bpmn:boundaryEvent id="BoundaryEvent_InsuranceTimeout" name="7 Days" cancelActivity="true" attachedToRef="Event_InsuranceResponse">
      <bpmn:outgoing>Flow_InsuranceTimeoutToMerge</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_InsuranceTimeout">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P7D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <bpmn:serviceTask id="Task_VerifyCoverage"
                      name="Verify Coverage"
                      camunda:type="external"
                      camunda:topic="financial.verify_coverage">
      <bpmn:incoming>Flow_ToVerifyCoverage</bpmn:incoming>
      <bpmn:outgoing>Flow_VerifyCoverageToMerge</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sequenceFlow id="Flow_ToInsuranceResponse" sourceRef="Task_RequestInsuranceInfo" targetRef="Event_InsuranceResponse" />
    <bpmn:sequenceFlow id="Flow_ToVerifyCoverage" sourceRef="Event_InsuranceResponse" targetRef="Task_VerifyCoverage" />
    <bpmn:sequenceFlow id="Flow_VerifyCoverageToMerge" sourceRef="Task_VerifyCoverage" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_InsuranceTimeoutToMerge" sourceRef="BoundaryEvent_InsuranceTimeout" targetRef="Gateway_Merge" />

    <!-- ========================================
         MERGE GATEWAY AND COMPLETION
         ======================================== -->
    <bpmn:exclusiveGateway id="Gateway_Merge" name="Merge">
      <bpmn:incoming>Flow_PatientAckToMerge</bpmn:incoming>
      <bpmn:incoming>Flow_AckTimeoutToMerge</bpmn:incoming>
      <bpmn:incoming>Flow_EstimateErrorToMerge</bpmn:incoming>
      <bpmn:incoming>Flow_ViewToMerge</bpmn:incoming>
      <bpmn:incoming>Flow_QuestionToMerge</bpmn:incoming>
      <bpmn:incoming>Flow_PaymentToMerge</bpmn:incoming>
      <bpmn:incoming>Flow_VerifyCoverageToMerge</bpmn:incoming>
      <bpmn:incoming>Flow_InsuranceTimeoutToMerge</bpmn:incoming>
      <bpmn:outgoing>Flow_ToUpdateFinancialRecord</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Task_UpdateFinancialRecord"
                      name="Update Financial Record"
                      camunda:type="external"
                      camunda:topic="financial.update_record">
      <bpmn:incoming>Flow_ToUpdateFinancialRecord</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEnd</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:sequenceFlow id="Flow_ToUpdateFinancialRecord" sourceRef="Gateway_Merge" targetRef="Task_UpdateFinancialRecord" />
    <bpmn:sequenceFlow id="Flow_ToEnd" sourceRef="Task_UpdateFinancialRecord" targetRef="EndEvent_FinancialServiceComplete" />

    <bpmn:endEvent id="EndEvent_FinancialServiceComplete" name="Financial Service Complete">
      <bpmn:incoming>Flow_ToEnd</bpmn:incoming>
    </bpmn:endEvent>

  </bpmn:process>

  <!-- ========================================
       MESSAGE DEFINITIONS
       ======================================== -->
  <bpmn:message id="Message_PatientAck" name="msg_patient_ack" />
  <bpmn:message id="Message_PaymentResponse" name="msg_payment_response" />
  <bpmn:message id="Message_InsuranceResponse" name="msg_insurance_response" />

  <!-- ========================================
       ERROR DEFINITIONS
       ======================================== -->
  <bpmn:error id="Error_FinancialPayment" name="FINANCIAL_PAYMENT_ERROR" errorCode="FIN_PAYMENT" />
  <bpmn:error id="Error_FinancialEstimate" name="FINANCIAL_ESTIMATE_ERROR" errorCode="FIN_ESTIMATE" />

  <!-- ========================================
       BPMN DIAGRAM INTERCHANGE
       ======================================== -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_SP_RF_003">
    <bpmndi:BPMNPlane id="BPMNPlane_SP_RF_003" bpmnElement="Collaboration_PatientFinancialSelfService">
      <bpmndi:BPMNShape id="Participant_PatientSelfService_di" bpmnElement="Participant_PatientSelfService" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1920" height="800" />
      </bpmndi:BPMNShape>

      <!-- Start Event -->
      <bpmndi:BPMNShape id="StartEvent_FinancialServiceTriggered_di" bpmnElement="StartEvent_FinancialServiceTriggered">
        <dc:Bounds x="232" y="422" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="210" y="465" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Service Type Gateway -->
      <bpmndi:BPMNShape id="Gateway_ServiceType_di" bpmnElement="Gateway_ServiceType" isMarkerVisible="true">
        <dc:Bounds x="325" y="415" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="313" y="385" width="74" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Path A: Pre-Visit Estimate -->
      <bpmndi:BPMNShape id="Task_CalculateCopayEstimate_di" bpmnElement="Task_CalculateCopayEstimate">
        <dc:Bounds x="440" y="140" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendEstimate_di" bpmnElement="Task_SendEstimate">
        <dc:Bounds x="600" y="140" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_PatientAcknowledgment_di" bpmnElement="Event_PatientAcknowledgment">
        <dc:Bounds x="762" y="162" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="753" y="205" width="54" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BoundaryEvent_AckTimeout_di" bpmnElement="BoundaryEvent_AckTimeout">
        <dc:Bounds x="772" y="180" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="806" y="203" width="37" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BoundaryEvent_EstimateError_di" bpmnElement="BoundaryEvent_EstimateError">
        <dc:Bounds x="502" y="202" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="534" y="233" width="64" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Path B: Bill Ready -->
      <bpmndi:BPMNShape id="Task_GenerateBillDetails_di" bpmnElement="Task_GenerateBillDetails">
        <dc:Bounds x="440" y="400" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendBillNotification_di" bpmnElement="Task_SendBillNotification">
        <dc:Bounds x="600" y="400" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_PatientAction_di" bpmnElement="Gateway_PatientAction" isMarkerVisible="true">
        <dc:Bounds x="755" y="415" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="738" y="385" width="84" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendDetailedBill_di" bpmnElement="Task_SendDetailedBill">
        <dc:Bounds x="870" y="300" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RouteBillingSupport_di" bpmnElement="Task_RouteBillingSupport">
        <dc:Bounds x="870" y="520" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Subprocess: Payment Flow -->
      <bpmndi:BPMNShape id="SubProcess_PaymentFlow_di" bpmnElement="SubProcess_PaymentFlow" isExpanded="true">
        <dc:Bounds x="870" y="360" width="580" height="260" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_Payment_di" bpmnElement="StartEvent_Payment">
        <dc:Bounds x="902" y="462" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="881" y="505" width="78" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_PaymentMethod_di" bpmnElement="Gateway_PaymentMethod" isMarkerVisible="true">
        <dc:Bounds x="985" y="455" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="968" y="425" width="84" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ProcessPayment_di" bpmnElement="Task_ProcessPayment">
        <dc:Bounds x="1090" y="390" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SetupPaymentPlan_di" bpmnElement="Task_SetupPaymentPlan">
        <dc:Bounds x="1090" y="520" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PaymentConfirmed_di" bpmnElement="Task_PaymentConfirmed">
        <dc:Bounds x="1240" y="440" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendReceipt_di" bpmnElement="Task_SendReceipt">
        <dc:Bounds x="1360" y="440" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_PaymentComplete_di" bpmnElement="EndEvent_PaymentComplete">
        <dc:Bounds x="1492" y="462" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1470" y="505" width="81" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="BoundaryEvent_PaymentFailure_di" bpmnElement="BoundaryEvent_PaymentFailure">
        <dc:Bounds x="1152" y="452" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1182" y="423" width="76" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Path C: Insurance Update -->
      <bpmndi:BPMNShape id="Task_RequestInsuranceInfo_di" bpmnElement="Task_RequestInsuranceInfo">
        <dc:Bounds x="440" y="700" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_InsuranceResponse_di" bpmnElement="Event_InsuranceResponse">
        <dc:Bounds x="602" y="722" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="595" y="765" width="50" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
