<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/zeebe/1.0"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_RC010"
                  targetNamespace="http://cib7.healthcare/revenue-cycle">

  <bpmn:process id="SP_RC_010_Maximization" name="Maximização de Receita" isExecutable="true">

    <bpmn:startEvent id="start_maximization" name="Início Maximização">
      <bpmn:outgoing>flow_to_predict_collection</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Predict Collection Date -->
    <bpmn:serviceTask id="task_predict_collection_date" name="Prever Data de Cobrança">
      <bpmn:extensionElements>
        <camunda:topic>predict-collection-date</camunda:topic>
        <camunda:inputOutput>
          <camunda:inputParameter name="accounts">${accountIds}</camunda:inputParameter>
          <camunda:inputParameter name="history">${historicalData}</camunda:inputParameter>
          <camunda:outputParameter name="collectionDatePredictions">${predictedDates}</camunda:outputParameter>
          <camunda:outputParameter name="predictionConfidence">${confidenceScores}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_predict_collection</bpmn:incoming>
      <bpmn:outgoing>flow_to_identify_slow_payers</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Identify Slow Payers -->
    <bpmn:serviceTask id="task_identify_slow_payers" name="Identificar Pagadores Lentos">
      <bpmn:extensionElements>
        <camunda:topic>identify-slow-payers</camunda:topic>
        <camunda:inputOutput>
          <camunda:inputParameter name="predictions">${collectionDatePredictions}</camunda:inputParameter>
          <camunda:inputParameter name="payerHistory">${payerPerformanceData}</camunda:inputParameter>
          <camunda:outputParameter name="identifiedSlowPayers">${slowPayers}</camunda:outputParameter>
          <camunda:outputParameter name="payerRiskScores">${riskScores}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_identify_slow_payers</bpmn:incoming>
      <bpmn:outgoing>flow_to_risk_gateway</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Risk Assessment Gateway -->
    <bpmn:exclusiveGateway id="gateway_risk_assessment" name="Alto Risco?">
      <bpmn:incoming>flow_to_risk_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_low_risk</bpmn:outgoing>
      <bpmn:outgoing>flow_high_risk</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- DMN: Revenue Optimization Strategy -->
    <bpmn:businessRuleTask id="dmn_optimization_strategy" name="Estratégia de Otimização">
      <bpmn:extensionElements>
        <camunda:decisionRef>revenue_optimization_strategy</camunda:decisionRef>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_low_risk</bpmn:incoming>
      <bpmn:outgoing>flow_to_update_forecasts</bpmn:outgoing>
    </bpmn:businessRuleTask>

    <!-- Update Revenue Forecasts -->
    <bpmn:serviceTask id="task_update_forecasts" name="Atualizar Projeções">
      <bpmn:extensionElements>
        <camunda:topic>update-forecasts</camunda:topic>
        <camunda:inputOutput>
          <camunda:inputParameter name="predictions">${collectionDatePredictions}</camunda:inputParameter>
          <camunda:inputParameter name="strategy">${optimizationPlan}</camunda:inputParameter>
          <camunda:outputParameter name="revenueForecasts">${updatedForecasts}</camunda:outputParameter>
          <camunda:outputParameter name="accuracyMetrics">${forecastAccuracy}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_update_forecasts</bpmn:incoming>
      <bpmn:outgoing>flow_to_analyze_opportunities</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Analyze Revenue Opportunities -->
    <bpmn:serviceTask id="task_analyze_opportunities" name="Analisar Oportunidades">
      <bpmn:extensionElements>
        <camunda:topic>analyze-revenue-opportunities</camunda:topic>
        <camunda:inputOutput>
          <camunda:inputParameter name="forecasts">${revenueForecasts}</camunda:inputParameter>
          <camunda:inputParameter name="slowPayers">${identifiedSlowPayers}</camunda:inputParameter>
          <camunda:outputParameter name="revenueOpportunities">${opportunities}</camunda:outputParameter>
          <camunda:outputParameter name="opportunityValue">${potentialValue}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_analyze_opportunities</bpmn:incoming>
      <bpmn:outgoing>flow_to_opportunity_gateway</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Opportunity Gateway -->
    <bpmn:exclusiveGateway id="gateway_opportunities" name="Oportunidades Identificadas?">
      <bpmn:incoming>flow_to_opportunity_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_has_opportunities</bpmn:outgoing>
      <bpmn:outgoing>flow_no_opportunities</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Parallel Gateway for Optimization Actions -->
    <bpmn:parallelGateway id="parallel_optimization_start" name="Executar Otimizações">
      <bpmn:incoming>flow_has_opportunities</bpmn:incoming>
      <bpmn:outgoing>flow_to_optimize_pricing</bpmn:outgoing>
      <bpmn:outgoing>flow_to_optimize_contracts</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- Optimize Pricing Strategy -->
    <bpmn:serviceTask id="task_optimize_pricing" name="Otimizar Precificação">
      <bpmn:extensionElements>
        <camunda:topic>optimize-pricing-strategy</camunda:topic>
        <camunda:inputOutput>
          <camunda:inputParameter name="opportunities">${revenueOpportunities}</camunda:inputParameter>
          <camunda:outputParameter name="optimizedPricing">${pricingRecommendations}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_optimize_pricing</bpmn:incoming>
      <bpmn:outgoing>flow_to_parallel_join</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Optimize Contract Terms -->
    <bpmn:serviceTask id="task_optimize_contracts" name="Otimizar Contratos">
      <bpmn:extensionElements>
        <camunda:topic>optimize-contract-terms</camunda:topic>
        <camunda:inputOutput>
          <camunda:inputParameter name="slowPayers">${identifiedSlowPayers}</camunda:inputParameter>
          <camunda:inputParameter name="opportunities">${revenueOpportunities}</camunda:inputParameter>
          <camunda:outputParameter name="optimizedContracts">${contractRecommendations}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_optimize_contracts</bpmn:incoming>
      <bpmn:outgoing>flow_to_parallel_join</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Parallel Gateway Join -->
    <bpmn:parallelGateway id="parallel_optimization_join" name="Combinar Otimizações">
      <bpmn:incoming>flow_to_parallel_join</bpmn:incoming>
      <bpmn:incoming>flow_to_parallel_join</bpmn:incoming>
      <bpmn:outgoing>flow_to_generate_action_plan</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- Generate Action Plan -->
    <bpmn:serviceTask id="task_generate_action_plan" name="Gerar Plano de Ação">
      <bpmn:extensionElements>
        <camunda:topic>generate-maximization-action-plan</camunda:topic>
        <camunda:inputOutput>
          <camunda:inputParameter name="pricingPlan">${optimizedPricing}</camunda:inputParameter>
          <camunda:inputParameter name="contractPlan">${optimizedContracts}</camunda:inputParameter>
          <camunda:inputParameter name="expectedValue">${opportunityValue}</camunda:inputParameter>
          <camunda:outputParameter name="implementationPlan">${actionPlan}</camunda:outputParameter>
          <camunda:outputParameter name="projectedImpact">${estimatedImpact}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_generate_action_plan</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_success</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Negotiate Payment Plan -->
    <bpmn:serviceTask id="task_negotiate_payment_plan" name="Negociar Plano de Pagamento">
      <bpmn:extensionElements>
        <camunda:topic>negotiate-payment-plan</camunda:topic>
        <camunda:inputOutput>
          <camunda:inputParameter name="slowPayers">${identifiedSlowPayers}</camunda:inputParameter>
          <camunda:inputParameter name="riskScores">${payerRiskScores}</camunda:inputParameter>
          <camunda:outputParameter name="paymentPlans">${negotiationOutcomes}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_high_risk</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_negotiated</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Timer boundary for forecast update cycle (weekly) -->
    <bpmn:boundaryEvent id="timer_forecast_cycle" name="Atualização Semanal" attachedToRef="task_update_forecasts">
      <bpmn:timerEventDefinition>
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/P7D</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- Review Opportunities -->
    <bpmn:userTask id="task_review_opportunities" name="Revisar Oportunidades">
      <bpmn:incoming>flow_no_opportunities</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_review</bpmn:outgoing>
    </bpmn:userTask>

    <!-- End Events -->
    <bpmn:endEvent id="end_success" name="Plano de Maximização Gerado">
      <bpmn:incoming>flow_to_end_success</bpmn:incoming>
      <bpmn:messageEventDefinition messageRef="Message_MaximizationComplete"/>
    </bpmn:endEvent>

    <bpmn:endEvent id="end_negotiated" name="Planos Negociados">
      <bpmn:incoming>flow_to_end_negotiated</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="end_review" name="Revisão Manual">
      <bpmn:incoming>flow_to_end_review</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="flow_to_predict_collection" sourceRef="start_maximization" targetRef="task_predict_collection_date"/>
    <bpmn:sequenceFlow id="flow_to_identify_slow_payers" sourceRef="task_predict_collection_date" targetRef="task_identify_slow_payers"/>
    <bpmn:sequenceFlow id="flow_to_risk_gateway" sourceRef="task_identify_slow_payers" targetRef="gateway_risk_assessment"/>
    <bpmn:sequenceFlow id="flow_low_risk" name="Não" sourceRef="gateway_risk_assessment" targetRef="dmn_optimization_strategy">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=avg(payerRiskScores) &lt; 0.7</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_high_risk" name="Sim" sourceRef="gateway_risk_assessment" targetRef="task_negotiate_payment_plan">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=avg(payerRiskScores) &gt;= 0.7</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_to_update_forecasts" sourceRef="dmn_optimization_strategy" targetRef="task_update_forecasts"/>
    <bpmn:sequenceFlow id="flow_to_analyze_opportunities" sourceRef="task_update_forecasts" targetRef="task_analyze_opportunities"/>
    <bpmn:sequenceFlow id="flow_to_opportunity_gateway" sourceRef="task_analyze_opportunities" targetRef="gateway_opportunities"/>
    <bpmn:sequenceFlow id="flow_has_opportunities" name="Sim" sourceRef="gateway_opportunities" targetRef="parallel_optimization_start">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=size(revenueOpportunities) > 0</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_no_opportunities" name="Não" sourceRef="gateway_opportunities" targetRef="task_review_opportunities">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=size(revenueOpportunities) = 0</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_to_optimize_pricing" sourceRef="parallel_optimization_start" targetRef="task_optimize_pricing"/>
    <bpmn:sequenceFlow id="flow_to_optimize_contracts" sourceRef="parallel_optimization_start" targetRef="task_optimize_contracts"/>
    <bpmn:sequenceFlow id="flow_to_parallel_join" sourceRef="task_optimize_pricing" targetRef="parallel_optimization_join"/>
    <bpmn:sequenceFlow id="flow_to_parallel_join" sourceRef="task_optimize_contracts" targetRef="parallel_optimization_join"/>
    <bpmn:sequenceFlow id="flow_to_generate_action_plan" sourceRef="parallel_optimization_join" targetRef="task_generate_action_plan"/>
    <bpmn:sequenceFlow id="flow_to_end_success" sourceRef="task_generate_action_plan" targetRef="end_success"/>
    <bpmn:sequenceFlow id="flow_to_end_negotiated" sourceRef="task_negotiate_payment_plan" targetRef="end_negotiated"/>
    <bpmn:sequenceFlow id="flow_to_end_review" sourceRef="task_review_opportunities" targetRef="end_review"/>

  </bpmn:process>

  <bpmn:message id="Message_MaximizationComplete" name="MaximizationCompleteMessage"/>

</bpmn:definitions>
