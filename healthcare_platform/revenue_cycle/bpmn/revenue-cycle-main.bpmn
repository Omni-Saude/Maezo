<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                   xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                   xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                   xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                   xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   id="Definitions_Revenue_Cycle_Main"
                   targetNamespace="http://cib7.healthcare/revenue-cycle"
                   exporter="CIB Seven"
                   exporterVersion="2.1.3">

  <!-- Error Definitions -->
  <bpmn:error id="Error_RevenueCycle" name="REVENUE_CYCLE_ERROR" errorCode="RC_ERROR"/>
  <bpmn:error id="Error_BillingRejected" name="BILLING_REJECTED" errorCode="RC_BILLING_REJECTED"/>

  <!-- Message Definitions -->
  <bpmn:message id="msg_encounter_created" name="msg_encounter_created"/>
  <bpmn:message id="msg_clinical_documentation_ready" name="msg_clinical_documentation_ready"/>
  <bpmn:message id="msg_discharge_completed" name="msg_discharge_completed"/>
  <bpmn:message id="msg_payment_reconciled" name="msg_payment_reconciled"/>
  <bpmn:message id="msg_patient_admitted" name="msg_patient_admitted"/>
  <bpmn:message id="msg_authorization_denied" name="msg_authorization_denied"/>
  <bpmn:message id="msg_procedures_completed" name="msg_procedures_completed"/>
  <bpmn:message id="msg_glosa_detected" name="msg_glosa_detected"/>

  <!-- Main Revenue Cycle Process -->
  <bpmn:process id="revenue_cycle_main" name="Revenue Cycle Orchestrator" isExecutable="true">

    <!-- Start Event: Message Start triggered by CDC bridge -->
    <bpmn:startEvent id="start_encounter_created" name="Encounter Created">
      <bpmn:outgoing>flow_start_to_scheduling</bpmn:outgoing>
      <bpmn:messageEventDefinition id="msgEvtDef_encounter_created" messageRef="msg_encounter_created"/>
    </bpmn:startEvent>

    <!-- SP-RC-001: Scheduling and Registration -->
    <bpmn:callActivity id="call_SP_RC_001" name="SP-RC-001: Agendamento e Registro" calledElement="SP_RC_001_Scheduling_Registration">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="encounterFhirId" target="encounterFhirId"/>
        <camunda:in source="patientFhirId" target="patientFhirId"/>
        <camunda:in source="payerId" target="payerId"/>
        <camunda:out source="registrationStatus" target="registrationStatus"/>
        <camunda:out source="coverageFhirId" target="coverageFhirId"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_start_to_scheduling</bpmn:incoming>
      <bpmn:outgoing>flow_scheduling_to_preservice</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Error Boundary Event for SP-RC-001 -->
    <bpmn:boundaryEvent id="error_SP_RC_001" name="Registration Error" attachedToRef="call_SP_RC_001">
      <bpmn:outgoing>flow_error_001_to_end_error</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_RC_001" errorRef="Error_RevenueCycle"/>
    </bpmn:boundaryEvent>

    <!-- SP-RC-002: Pre-Service (Eligibility + Authorization) -->
    <bpmn:callActivity id="call_SP_RC_002" name="SP-RC-002: Pré-Atendimento" calledElement="SP_RC_002_Pre_Service">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="encounterFhirId" target="encounterFhirId"/>
        <camunda:in source="patientFhirId" target="patientFhirId"/>
        <camunda:in source="payerId" target="payerId"/>
        <camunda:in source="coverageFhirId" target="coverageFhirId"/>
        <camunda:out source="authorizationStatus" target="authorizationStatus"/>
        <camunda:out source="eligibilityVerified" target="eligibilityVerified"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_scheduling_to_preservice</bpmn:incoming>
      <bpmn:outgoing>flow_preservice_to_catch_documentation</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Error Boundary Event for SP-RC-002 -->
    <bpmn:boundaryEvent id="error_SP_RC_002" name="Pre-Service Error" attachedToRef="call_SP_RC_002">
      <bpmn:outgoing>flow_error_002_to_end_error</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_RC_002" errorRef="Error_RevenueCycle"/>
    </bpmn:boundaryEvent>

    <!-- Timer Boundary Event for SP-RC-002: 48h Authorization SLA (interrupting) -->
    <bpmn:boundaryEvent id="timer_SP_RC_002_auth_sla" name="48h Authorization SLA" attachedToRef="call_SP_RC_002" cancelActivity="true">
      <bpmn:outgoing>flow_timer_002_to_escalation</bpmn:outgoing>
      <bpmn:timerEventDefinition id="timerDef_RC_002">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT48H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- Service Task: Authorization SLA Escalation -->
    <bpmn:serviceTask id="task_auth_sla_escalation" name="Escalate Authorization SLA Breach" camunda:delegateExpression="${authSlaEscalationDelegate}">
      <bpmn:incoming>flow_timer_002_to_escalation</bpmn:incoming>
      <bpmn:outgoing>flow_escalation_002_to_end_error</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Message Intermediate Catch: Wait for Clinical Documentation Ready -->
    <bpmn:intermediateCatchEvent id="catch_clinical_doc_ready" name="Clinical Documentation Ready">
      <bpmn:incoming>flow_preservice_to_catch_documentation</bpmn:incoming>
      <bpmn:outgoing>flow_catch_doc_to_clinical_service</bpmn:outgoing>
      <bpmn:messageEventDefinition id="msgEvtDef_doc_ready" messageRef="msg_clinical_documentation_ready"/>
    </bpmn:intermediateCatchEvent>

    <!-- SP-RC-003: Clinical Service -->
    <bpmn:callActivity id="call_SP_RC_003" name="SP-RC-003: Serviço Clínico" calledElement="SP_RC_003_Clinical_Service">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="encounterFhirId" target="encounterFhirId"/>
        <camunda:in source="patientFhirId" target="patientFhirId"/>
        <camunda:out source="clinicalServiceStatus" target="clinicalServiceStatus"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_catch_doc_to_clinical_service</bpmn:incoming>
      <bpmn:outgoing>flow_clinical_service_to_catch_discharge</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Error Boundary Event for SP-RC-003 -->
    <bpmn:boundaryEvent id="error_SP_RC_003" name="Clinical Service Error" attachedToRef="call_SP_RC_003">
      <bpmn:outgoing>flow_error_003_to_end_error</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_RC_003" errorRef="Error_RevenueCycle"/>
    </bpmn:boundaryEvent>

    <!-- Message Intermediate Catch: Wait for Discharge Completed -->
    <bpmn:intermediateCatchEvent id="catch_discharge_completed" name="Discharge Completed">
      <bpmn:incoming>flow_clinical_service_to_catch_discharge</bpmn:incoming>
      <bpmn:outgoing>flow_catch_discharge_to_production</bpmn:outgoing>
      <bpmn:messageEventDefinition id="msgEvtDef_discharge" messageRef="msg_discharge_completed"/>
    </bpmn:intermediateCatchEvent>

    <!-- SP-RC-004: Clinical Production (Consumption Capture) -->
    <bpmn:callActivity id="call_SP_RC_004" name="SP-RC-004: Produção Clínica" calledElement="SP_RC_004_Clinical_Production">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="encounterFhirId" target="encounterFhirId"/>
        <camunda:in source="patientFhirId" target="patientFhirId"/>
        <camunda:out source="billingItems" target="billingItems"/>
        <camunda:out source="accountClosed" target="accountClosed"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_catch_discharge_to_production</bpmn:incoming>
      <bpmn:outgoing>flow_production_to_coding</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Error Boundary Event for SP-RC-004 -->
    <bpmn:boundaryEvent id="error_SP_RC_004" name="Production Error" attachedToRef="call_SP_RC_004">
      <bpmn:outgoing>flow_error_004_to_end_error</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_RC_004" errorRef="Error_RevenueCycle"/>
    </bpmn:boundaryEvent>

    <!-- Timer Boundary Event for SP-RC-004: 24h Account Closure SLA (non-interrupting) -->
    <bpmn:boundaryEvent id="timer_SP_RC_004_closure_sla" name="24h Account Closure SLA" attachedToRef="call_SP_RC_004" cancelActivity="false">
      <bpmn:outgoing>flow_timer_004_to_alert</bpmn:outgoing>
      <bpmn:timerEventDefinition id="timerDef_RC_004">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT24H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- Message Boundary Event for SP-RC-004: Procedures Completed (non-interrupting) -->
    <bpmn:boundaryEvent id="catch_procedures_completed" name="Catch Procedures Completed" attachedToRef="call_SP_RC_004" cancelActivity="false">
      <bpmn:outgoing>flow_from_catch_procedures</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="msg_procedures_completed"/>
    </bpmn:boundaryEvent>

    <!-- Service Task: Account Closure SLA Alert -->
    <bpmn:serviceTask id="task_closure_sla_alert" name="Alert Account Closure SLA Risk" camunda:delegateExpression="${closureSlaAlertDelegate}">
      <bpmn:incoming>flow_timer_004_to_alert</bpmn:incoming>
      <bpmn:outgoing>flow_alert_004_to_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Task: Update Production Capture with Procedure Data -->
    <bpmn:task id="task_update_production_capture" name="Update Production Capture with Procedure Data">
      <bpmn:incoming>flow_from_catch_procedures</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_procedures_handled</bpmn:outgoing>
    </bpmn:task>

    <!-- End Event: Procedures Notification Handled -->
    <bpmn:endEvent id="end_procedures_handled" name="Procedures Notification Handled">
      <bpmn:incoming>flow_to_end_procedures_handled</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flow: Procedures Completed Handler -->
    <bpmn:sequenceFlow id="flow_from_catch_procedures" sourceRef="catch_procedures_completed" targetRef="task_update_production_capture"/>
    <bpmn:sequenceFlow id="flow_to_end_procedures_handled" sourceRef="task_update_production_capture" targetRef="end_procedures_handled"/>

    <!-- SP-RC-005: Coding and Audit -->
    <bpmn:callActivity id="call_SP_RC_005" name="SP-RC-005: Codificação e Auditoria" calledElement="SP_RC_005_Coding_Audit">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="encounterFhirId" target="encounterFhirId"/>
        <camunda:in source="patientFhirId" target="patientFhirId"/>
        <camunda:in source="billingItems" target="billingItems"/>
        <camunda:out source="codingStatus" target="codingStatus"/>
        <camunda:out source="auditStatus" target="auditStatus"/>
        <camunda:out source="drgCode" target="drgCode"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_production_to_coding</bpmn:incoming>
      <bpmn:outgoing>flow_coding_to_billing</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Error Boundary Event for SP-RC-005 -->
    <bpmn:boundaryEvent id="error_SP_RC_005" name="Coding Error" attachedToRef="call_SP_RC_005">
      <bpmn:outgoing>flow_error_005_to_end_error</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_RC_005" errorRef="Error_RevenueCycle"/>
    </bpmn:boundaryEvent>

    <!-- SP-RC-006: Billing and TISS Submission -->
    <bpmn:callActivity id="call_SP_RC_006" name="SP-RC-006: Faturamento e Envio TISS" calledElement="SP_RC_006_Billing_Submission">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="encounterFhirId" target="encounterFhirId"/>
        <camunda:in source="patientFhirId" target="patientFhirId"/>
        <camunda:in source="payerId" target="payerId"/>
        <camunda:in source="billingItems" target="billingItems"/>
        <camunda:in source="drgCode" target="drgCode"/>
        <camunda:out source="claimFhirId" target="claimFhirId"/>
        <camunda:out source="billingStatus" target="billingStatus"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_coding_to_billing</bpmn:incoming>
      <bpmn:incoming>flow_denial_to_resubmission</bpmn:incoming>
      <bpmn:outgoing>flow_billing_to_gateway</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Error Boundary Event for SP-RC-006 -->
    <bpmn:boundaryEvent id="error_SP_RC_006" name="Billing Error" attachedToRef="call_SP_RC_006">
      <bpmn:outgoing>flow_error_006_to_end_error</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_RC_006" errorRef="Error_RevenueCycle"/>
    </bpmn:boundaryEvent>

    <!-- Timer Boundary Event for SP-RC-006: 24h TISS Generation (non-interrupting) -->
    <bpmn:boundaryEvent id="timer_SP_RC_006_tiss_sla" name="24h TISS Generation SLA" attachedToRef="call_SP_RC_006" cancelActivity="false">
      <bpmn:outgoing>flow_timer_006_to_alert</bpmn:outgoing>
      <bpmn:timerEventDefinition id="timerDef_RC_006">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT24H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- Service Task: TISS Generation SLA Alert -->
    <bpmn:serviceTask id="task_tiss_sla_alert" name="Alert TISS Generation SLA Risk" camunda:delegateExpression="${tissSlaAlertDelegate}">
      <bpmn:incoming>flow_timer_006_to_alert</bpmn:incoming>
      <bpmn:outgoing>flow_alert_006_to_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Exclusive Gateway: Billing Approved? -->
    <bpmn:exclusiveGateway id="gateway_billing_approved" name="Billing Approved?" default="flow_gateway_to_collection">
      <bpmn:incoming>flow_billing_to_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_gateway_to_collection</bpmn:outgoing>
      <bpmn:outgoing>flow_gateway_to_denial</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Sequence Flow: Billing Rejected -->
    <bpmn:sequenceFlow id="flow_gateway_to_denial" name="Rejected" sourceRef="gateway_billing_approved" targetRef="throw_authorization_denied">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${billingStatus == 'REJECTED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <!-- Intermediate Throw Event: Authorization Denied -->
    <bpmn:intermediateThrowEvent id="throw_authorization_denied" name="Throw Authorization Denied">
      <bpmn:incoming>flow_gateway_to_denial</bpmn:incoming>
      <bpmn:outgoing>flow_throw_auth_denied_to_denial_mgmt</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="msg_authorization_denied"/>
    </bpmn:intermediateThrowEvent>

    <!-- Sequence Flow: From Authorization Denied to Denial Management -->
    <bpmn:sequenceFlow id="flow_throw_auth_denied_to_denial_mgmt" sourceRef="throw_authorization_denied" targetRef="call_SP_RC_007"/>

    <!-- Sequence Flow: Billing Approved (default) -->
    <bpmn:sequenceFlow id="flow_gateway_to_collection" name="Approved" sourceRef="gateway_billing_approved" targetRef="call_SP_RC_008"/>

    <!-- SP-RC-007: Denial Management -->
    <bpmn:callActivity id="call_SP_RC_007" name="SP-RC-007: Gestão de Glosas" calledElement="SP_RC_007_Denial_Management">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="encounterFhirId" target="encounterFhirId"/>
        <camunda:in source="claimFhirId" target="claimFhirId"/>
        <camunda:in source="payerId" target="payerId"/>
        <camunda:out source="denialCode" target="denialCode"/>
        <camunda:out source="contestationStatus" target="contestationStatus"/>
        <camunda:out source="resubmitClaim" target="resubmitClaim"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_gateway_to_denial</bpmn:incoming>
      <bpmn:outgoing>flow_denial_to_gateway_resolution</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Error Boundary Event for SP-RC-007 -->
    <bpmn:boundaryEvent id="error_SP_RC_007" name="Denial Management Error" attachedToRef="call_SP_RC_007">
      <bpmn:outgoing>flow_error_007_to_end_error</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_RC_007" errorRef="Error_RevenueCycle"/>
    </bpmn:boundaryEvent>

    <!-- Timer Boundary Event for SP-RC-007: 5 days Denial Contestation (interrupting) -->
    <bpmn:boundaryEvent id="timer_SP_RC_007_contestation_sla" name="5 Day Contestation SLA" attachedToRef="call_SP_RC_007" cancelActivity="true">
      <bpmn:outgoing>flow_timer_007_to_escalation</bpmn:outgoing>
      <bpmn:timerEventDefinition id="timerDef_RC_007">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P5D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- Service Task: Contestation SLA Escalation -->
    <bpmn:serviceTask id="task_contestation_sla_escalation" name="Escalate Contestation SLA Breach" camunda:delegateExpression="${contestationSlaEscalationDelegate}">
      <bpmn:incoming>flow_timer_007_to_escalation</bpmn:incoming>
      <bpmn:outgoing>flow_escalation_007_to_collection</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Exclusive Gateway: Resubmit or Proceed to Collection? -->
    <bpmn:exclusiveGateway id="gateway_denial_resolution" name="Resubmit Claim?" default="flow_denial_resolution_to_collection">
      <bpmn:incoming>flow_denial_to_gateway_resolution</bpmn:incoming>
      <bpmn:outgoing>flow_denial_to_resubmission</bpmn:outgoing>
      <bpmn:outgoing>flow_denial_resolution_to_collection</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Sequence Flow: Resubmit Claim -->
    <bpmn:sequenceFlow id="flow_denial_to_resubmission" name="Resubmit" sourceRef="gateway_denial_resolution" targetRef="call_SP_RC_006">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${resubmitClaim == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <!-- Sequence Flow: Proceed to Collection (default) -->
    <bpmn:sequenceFlow id="flow_denial_resolution_to_collection" name="Proceed to Collection" sourceRef="gateway_denial_resolution" targetRef="call_SP_RC_008"/>

    <!-- SP-RC-008: Revenue Collection and Reconciliation -->
    <bpmn:callActivity id="call_SP_RC_008" name="SP-RC-008: Arrecadação e Reconciliação" calledElement="SP_RC_008_Revenue_Collection">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="encounterFhirId" target="encounterFhirId"/>
        <camunda:in source="claimFhirId" target="claimFhirId"/>
        <camunda:in source="payerId" target="payerId"/>
        <camunda:out source="paymentReconciled" target="paymentReconciled"/>
        <camunda:out source="revenueAmount" target="revenueAmount"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_gateway_to_collection</bpmn:incoming>
      <bpmn:incoming>flow_denial_resolution_to_collection</bpmn:incoming>
      <bpmn:incoming>flow_escalation_007_to_collection</bpmn:incoming>
      <bpmn:outgoing>flow_collection_to_gateway_variance</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Exclusive Gateway: Payment Variance Detected? -->
    <bpmn:exclusiveGateway id="gateway_payment_variance" name="Payment Variance?" default="flow_variance_to_throw_reconciled">
      <bpmn:incoming>flow_collection_to_gateway_variance</bpmn:incoming>
      <bpmn:outgoing>flow_variance_to_throw_glosa</bpmn:outgoing>
      <bpmn:outgoing>flow_variance_to_throw_reconciled</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Intermediate Throw Event: Glosa Detected -->
    <bpmn:intermediateThrowEvent id="throw_glosa_detected" name="Throw Glosa Detected">
      <bpmn:incoming>flow_variance_to_throw_glosa</bpmn:incoming>
      <bpmn:outgoing>flow_throw_glosa_to_reconciled</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="msg_glosa_detected"/>
    </bpmn:intermediateThrowEvent>

    <!-- Sequence Flow: Variance Detected -->
    <bpmn:sequenceFlow id="flow_collection_to_gateway_variance" sourceRef="call_SP_RC_008" targetRef="gateway_payment_variance"/>
    <bpmn:sequenceFlow id="flow_variance_to_throw_glosa" name="Variance Detected" sourceRef="gateway_payment_variance" targetRef="throw_glosa_detected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${paymentVariance == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_variance_to_throw_reconciled" name="No Variance" sourceRef="gateway_payment_variance" targetRef="throw_payment_reconciled"/>
    <bpmn:sequenceFlow id="flow_throw_glosa_to_reconciled" sourceRef="throw_glosa_detected" targetRef="throw_payment_reconciled"/>

    <!-- Error Boundary Event for SP-RC-008 -->
    <bpmn:boundaryEvent id="error_SP_RC_008" name="Collection Error" attachedToRef="call_SP_RC_008">
      <bpmn:outgoing>flow_error_008_to_end_error</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_RC_008" errorRef="Error_RevenueCycle"/>
    </bpmn:boundaryEvent>

    <!-- Message Intermediate Throw: Notify Payment Reconciled -->
    <bpmn:intermediateThrowEvent id="throw_payment_reconciled" name="Payment Reconciled">
      <bpmn:incoming>flow_variance_to_throw_reconciled</bpmn:incoming>
      <bpmn:incoming>flow_throw_glosa_to_reconciled</bpmn:incoming>
      <bpmn:outgoing>flow_throw_reconciled_to_parallel_fork</bpmn:outgoing>
      <bpmn:messageEventDefinition id="msgEvtDef_payment_reconciled" messageRef="msg_payment_reconciled"/>
    </bpmn:intermediateThrowEvent>

    <!-- Parallel Gateway: Fork for Analytics and Maximization -->
    <bpmn:parallelGateway id="gateway_parallel_fork" name="Fork Analytics">
      <bpmn:incoming>flow_throw_reconciled_to_parallel_fork</bpmn:incoming>
      <bpmn:outgoing>flow_fork_to_analytics</bpmn:outgoing>
      <bpmn:outgoing>flow_fork_to_maximization</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- SP-RC-009: Analytics and Intelligence -->
    <bpmn:callActivity id="call_SP_RC_009" name="SP-RC-009: Analytics e Inteligência" calledElement="SP_RC_009_Analytics_Intelligence">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="encounterFhirId" target="encounterFhirId"/>
        <camunda:in source="revenueAmount" target="revenueAmount"/>
        <camunda:out source="analyticsCompleted" target="analyticsCompleted"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_fork_to_analytics</bpmn:incoming>
      <bpmn:outgoing>flow_analytics_to_parallel_join</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Error Boundary Event for SP-RC-009 -->
    <bpmn:boundaryEvent id="error_SP_RC_009" name="Analytics Error" attachedToRef="call_SP_RC_009">
      <bpmn:outgoing>flow_error_009_to_end_error</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_RC_009" errorRef="Error_RevenueCycle"/>
    </bpmn:boundaryEvent>

    <!-- SP-RC-010: Maximization and VBHC -->
    <bpmn:callActivity id="call_SP_RC_010" name="SP-RC-010: Maximização e VBHC" calledElement="SP_RC_010_Maximization">
      <bpmn:extensionElements>
        <camunda:in source="tenantId" target="tenantId"/>
        <camunda:in source="encounterFhirId" target="encounterFhirId"/>
        <camunda:in source="revenueAmount" target="revenueAmount"/>
        <camunda:out source="maximizationCompleted" target="maximizationCompleted"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_fork_to_maximization</bpmn:incoming>
      <bpmn:outgoing>flow_maximization_to_parallel_join</bpmn:outgoing>
    </bpmn:callActivity>

    <!-- Error Boundary Event for SP-RC-010 -->
    <bpmn:boundaryEvent id="error_SP_RC_010" name="Maximization Error" attachedToRef="call_SP_RC_010">
      <bpmn:outgoing>flow_error_010_to_end_error</bpmn:outgoing>
      <bpmn:errorEventDefinition id="errDef_RC_010" errorRef="Error_RevenueCycle"/>
    </bpmn:boundaryEvent>

    <!-- Parallel Gateway: Join Analytics and Maximization -->
    <bpmn:parallelGateway id="gateway_parallel_join" name="Join Analytics">
      <bpmn:incoming>flow_analytics_to_parallel_join</bpmn:incoming>
      <bpmn:incoming>flow_maximization_to_parallel_join</bpmn:incoming>
      <bpmn:outgoing>flow_join_to_end</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- End Event: Success -->
    <bpmn:endEvent id="end_revenue_cycle_success" name="Revenue Cycle Completed">
      <bpmn:incoming>flow_join_to_end</bpmn:incoming>
      <bpmn:incoming>flow_alert_004_to_end</bpmn:incoming>
      <bpmn:incoming>flow_alert_006_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- End Event: Error -->
    <bpmn:endEvent id="end_revenue_cycle_error" name="Revenue Cycle Error">
      <bpmn:incoming>flow_error_001_to_end_error</bpmn:incoming>
      <bpmn:incoming>flow_error_002_to_end_error</bpmn:incoming>
      <bpmn:incoming>flow_error_003_to_end_error</bpmn:incoming>
      <bpmn:incoming>flow_error_004_to_end_error</bpmn:incoming>
      <bpmn:incoming>flow_error_005_to_end_error</bpmn:incoming>
      <bpmn:incoming>flow_error_006_to_end_error</bpmn:incoming>
      <bpmn:incoming>flow_error_007_to_end_error</bpmn:incoming>
      <bpmn:incoming>flow_error_008_to_end_error</bpmn:incoming>
      <bpmn:incoming>flow_error_009_to_end_error</bpmn:incoming>
      <bpmn:incoming>flow_error_010_to_end_error</bpmn:incoming>
      <bpmn:incoming>flow_escalation_002_to_end_error</bpmn:incoming>
      <bpmn:errorEventDefinition id="errEvtDef_end_error" errorRef="Error_RevenueCycle"/>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="flow_start_to_scheduling" sourceRef="start_encounter_created" targetRef="call_SP_RC_001"/>
    <bpmn:sequenceFlow id="flow_scheduling_to_preservice" sourceRef="call_SP_RC_001" targetRef="call_SP_RC_002"/>
    <bpmn:sequenceFlow id="flow_preservice_to_catch_documentation" sourceRef="call_SP_RC_002" targetRef="catch_clinical_doc_ready"/>
    <bpmn:sequenceFlow id="flow_catch_doc_to_clinical_service" sourceRef="catch_clinical_doc_ready" targetRef="call_SP_RC_003"/>
    <bpmn:sequenceFlow id="flow_clinical_service_to_catch_discharge" sourceRef="call_SP_RC_003" targetRef="catch_discharge_completed"/>
    <bpmn:sequenceFlow id="flow_catch_discharge_to_production" sourceRef="catch_discharge_completed" targetRef="call_SP_RC_004"/>
    <bpmn:sequenceFlow id="flow_production_to_coding" sourceRef="call_SP_RC_004" targetRef="call_SP_RC_005"/>
    <bpmn:sequenceFlow id="flow_coding_to_billing" sourceRef="call_SP_RC_005" targetRef="call_SP_RC_006"/>
    <bpmn:sequenceFlow id="flow_billing_to_gateway" sourceRef="call_SP_RC_006" targetRef="gateway_billing_approved"/>
    <bpmn:sequenceFlow id="flow_denial_to_gateway_resolution" sourceRef="call_SP_RC_007" targetRef="gateway_denial_resolution"/>
    <bpmn:sequenceFlow id="flow_throw_reconciled_to_parallel_fork" sourceRef="throw_payment_reconciled" targetRef="gateway_parallel_fork"/>
    <bpmn:sequenceFlow id="flow_fork_to_analytics" sourceRef="gateway_parallel_fork" targetRef="call_SP_RC_009"/>
    <bpmn:sequenceFlow id="flow_fork_to_maximization" sourceRef="gateway_parallel_fork" targetRef="call_SP_RC_010"/>
    <bpmn:sequenceFlow id="flow_analytics_to_parallel_join" sourceRef="call_SP_RC_009" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="flow_maximization_to_parallel_join" sourceRef="call_SP_RC_010" targetRef="gateway_parallel_join"/>
    <bpmn:sequenceFlow id="flow_join_to_end" sourceRef="gateway_parallel_join" targetRef="end_revenue_cycle_success"/>

    <!-- Error Flows -->
    <bpmn:sequenceFlow id="flow_error_001_to_end_error" sourceRef="error_SP_RC_001" targetRef="end_revenue_cycle_error"/>
    <bpmn:sequenceFlow id="flow_error_002_to_end_error" sourceRef="error_SP_RC_002" targetRef="end_revenue_cycle_error"/>
    <bpmn:sequenceFlow id="flow_error_003_to_end_error" sourceRef="error_SP_RC_003" targetRef="end_revenue_cycle_error"/>
