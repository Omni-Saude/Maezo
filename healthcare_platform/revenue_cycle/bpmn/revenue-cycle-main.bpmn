    <bpmn:sequenceFlow id="flow_error_005_to_end_error" sourceRef="error_SP_RC_005" targetRef="end_revenue_cycle_error"/>
    <bpmn:sequenceFlow id="flow_error_006_to_end_error" sourceRef="error_SP_RC_006" targetRef="end_revenue_cycle_error"/>
    <bpmn:sequenceFlow id="flow_error_007_to_end_error" sourceRef="error_SP_RC_007" targetRef="end_revenue_cycle_error"/>
    <bpmn:sequenceFlow id="flow_error_008_to_end_error" sourceRef="error_SP_RC_008" targetRef="end_revenue_cycle_error"/>
    <bpmn:sequenceFlow id="flow_error_009_to_end_error" sourceRef="error_SP_RC_009" targetRef="end_revenue_cycle_error"/>
    <bpmn:sequenceFlow id="flow_error_010_to_end_error" sourceRef="error_SP_RC_010" targetRef="end_revenue_cycle_error"/>

    <!-- Timer Flows -->
    <bpmn:sequenceFlow id="flow_timer_002_to_escalation" sourceRef="timer_SP_RC_002_auth_sla" targetRef="task_auth_sla_escalation"/>
    <bpmn:sequenceFlow id="flow_escalation_002_to_end_error" sourceRef="task_auth_sla_escalation" targetRef="end_revenue_cycle_error"/>
    <bpmn:sequenceFlow id="flow_timer_004_to_alert" sourceRef="timer_SP_RC_004_closure_sla" targetRef="task_closure_sla_alert"/>
    <bpmn:sequenceFlow id="flow_alert_004_to_end" sourceRef="task_closure_sla_alert" targetRef="end_revenue_cycle_success"/>
    <bpmn:sequenceFlow id="flow_timer_006_to_alert" sourceRef="timer_SP_RC_006_tiss_sla" targetRef="task_tiss_sla_alert"/>
    <bpmn:sequenceFlow id="flow_alert_006_to_end" sourceRef="task_tiss_sla_alert" targetRef="end_revenue_cycle_success"/>
    <bpmn:sequenceFlow id="flow_timer_007_to_escalation" sourceRef="timer_SP_RC_007_contestation_sla" targetRef="task_contestation_sla_escalation"/>
    <bpmn:sequenceFlow id="flow_escalation_007_to_collection" sourceRef="task_contestation_sla_escalation" targetRef="call_SP_RC_008"/>

    <!-- Event Sub-Process: Glosa Detection Handler -->
    <bpmn:subProcess id="subprocess_glosa_handler" name="Glosa Detection Handler" triggeredByEvent="true">
      <bpmn:startEvent id="start_glosa_catch" name="Glosa Detected" isInterrupting="false">
        <bpmn:outgoing>flow_glosa_to_denial</bpmn:outgoing>
        <bpmn:messageEventDefinition messageRef="msg_glosa_detected"/>
      </bpmn:startEvent>
      <bpmn:callActivity id="call_SP_RC_007_from_glosa" name="SP-RC-007 Denial Management" calledElement="SP_RC_007_Denial_Management">
        <bpmn:extensionElements>
          <camunda:in source="tenantId" target="tenantId"/>
          <camunda:in source="encounterFhirId" target="encounterFhirId"/>
          <camunda:in source="claimFhirId" target="claimFhirId"/>
          <camunda:in source="payerId" target="payerId"/>
        </bpmn:extensionElements>
        <bpmn:incoming>flow_glosa_to_denial</bpmn:incoming>
        <bpmn:outgoing>flow_denial_to_end_glosa</bpmn:outgoing>
      </bpmn:callActivity>
      <bpmn:endEvent id="end_glosa_handled" name="Glosa Handled">
        <bpmn:incoming>flow_denial_to_end_glosa</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="flow_glosa_to_denial" sourceRef="start_glosa_catch" targetRef="call_SP_RC_007_from_glosa"/>
      <bpmn:sequenceFlow id="flow_denial_to_end_glosa" sourceRef="call_SP_RC_007_from_glosa" targetRef="end_glosa_handled"/>
    </bpmn:subProcess>

  </bpmn:process>

