<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_glosa_management"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  exporter="Camunda Modeler"
                  exporterVersion="5.0.0">

  <bpmn:process id="SUB_07_Glosa_Management" name="Gestão de Glosas (Denials Management)" isExecutable="true">

    <!-- Start Event -->
    <bpmn:startEvent id="StartEvent_ReceivePayerResponse" name="Receber Resposta com Glosas">
      <bpmn:outgoing>Flow_to_identify_glosa</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Identify Glosas -->
    <bpmn:serviceTask id="Task_IdentifyGlosa" name="Identificar Glosas">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="identify-glosa" />
        <zeebe:ioMapping>
          <zeebe:input source="=payerResponse" target="payerResponse" />
          <zeebe:output source="=glosas" target="glosas" />
          <zeebe:output source="=hasGlosas" target="hasGlosas" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_to_identify_glosa</bpmn:incoming>
      <bpmn:outgoing>Flow_to_gateway_has_glosas</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Gateway: Has Glosas? -->
    <bpmn:exclusiveGateway id="Gateway_HasGlosas" name="Tem Glosas?">
      <bpmn:incoming>Flow_to_gateway_has_glosas</bpmn:incoming>
      <bpmn:outgoing>Flow_no_glosas</bpmn:outgoing>
      <bpmn:outgoing>Flow_has_glosas</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- End Event: No Glosas -->
    <bpmn:endEvent id="EndEvent_NoGlosas" name="Sem Glosas">
      <bpmn:incoming>Flow_no_glosas</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Classify Glosa Type -->
    <bpmn:serviceTask id="Task_ClassifyGlosaType" name="Classificar Tipo de Glosa">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="classify-glosa-type" />
        <zeebe:ioMapping>
          <zeebe:input source="=glosas" target="glosas" />
          <zeebe:output source="=classifiedGlosas" target="classifiedGlosas" />
          <zeebe:output source="=glosaTypes" target="glosaTypes" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_has_glosas</bpmn:incoming>
      <bpmn:outgoing>Flow_to_parallel_split</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Parallel Gateway: Split Analysis -->
    <bpmn:parallelGateway id="Gateway_ParallelSplit" name="Iniciar Análises">
      <bpmn:incoming>Flow_to_parallel_split</bpmn:incoming>
      <bpmn:outgoing>Flow_to_calculate_impact</bpmn:outgoing>
      <bpmn:outgoing>Flow_to_analyze_reason</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- Calculate Financial Impact -->
    <bpmn:serviceTask id="Task_CalculateImpact" name="Calcular Impacto Financeiro">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="calculate-glosa-impact" />
        <zeebe:ioMapping>
          <zeebe:input source="=classifiedGlosas" target="glosas" />
          <zeebe:output source="=financialImpact" target="financialImpact" />
          <zeebe:output source="=totalGlosaValue" target="totalGlosaValue" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_to_calculate_impact</bpmn:incoming>
      <bpmn:outgoing>Flow_impact_to_join</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Analyze Glosa Reason -->
    <bpmn:serviceTask id="Task_AnalyzeReason" name="Analisar Motivo da Glosa">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="analyze-glosa-reason" />
        <zeebe:ioMapping>
          <zeebe:input source="=classifiedGlosas" target="glosas" />
          <zeebe:output source="=glosaReasons" target="glosaReasons" />
          <zeebe:output source="=rootCauses" target="rootCauses" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_to_analyze_reason</bpmn:incoming>
      <bpmn:outgoing>Flow_reason_to_join</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Parallel Gateway: Join Analysis -->
    <bpmn:parallelGateway id="Gateway_ParallelJoin" name="Consolidar Análises">
      <bpmn:incoming>Flow_impact_to_join</bpmn:incoming>
      <bpmn:incoming>Flow_reason_to_join</bpmn:incoming>
      <bpmn:outgoing>Flow_to_check_eligibility</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- Check Appeal Eligibility -->
    <bpmn:serviceTask id="Task_CheckEligibility" name="Verificar Elegibilidade de Recurso">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="check-appeal-eligibility" />
        <zeebe:ioMapping>
          <zeebe:input source="=classifiedGlosas" target="glosas" />
          <zeebe:input source="=glosaReasons" target="reasons" />
          <zeebe:input source="=financialImpact" target="impact" />
          <zeebe:output source="=isEligible" target="isEligible" />
          <zeebe:output source="=appealStrategy" target="appealStrategy" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_to_check_eligibility</bpmn:incoming>
      <bpmn:outgoing>Flow_to_gateway_eligible</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Gateway: Eligible for Appeal? -->
    <bpmn:exclusiveGateway id="Gateway_EligibleForAppeal" name="Elegível para Recurso?">
      <bpmn:incoming>Flow_to_gateway_eligible</bpmn:incoming>
      <bpmn:outgoing>Flow_not_eligible</bpmn:outgoing>
      <bpmn:outgoing>Flow_eligible</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Update Payment (Not Eligible) -->
    <bpmn:serviceTask id="Task_UpdatePaymentNotEligible" name="Atualizar Pagamento (Glosa Aceita)">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="update-payment-after-glosa" />
        <zeebe:ioMapping>
          <zeebe:input source="=classifiedGlosas" target="glosas" />
          <zeebe:input source="=totalGlosaValue" target="glosaValue" />
          <zeebe:input source="=false" target="appealSuccessful" />
          <zeebe:output source="=updatedPayment" target="updatedPayment" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_not_eligible</bpmn:incoming>
      <bpmn:outgoing>Flow_to_end_accepted</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- End Event: Glosa Accepted -->
    <bpmn:endEvent id="EndEvent_GlosaAccepted" name="Glosa Aceita">
      <bpmn:incoming>Flow_to_end_accepted</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Generate Appeal Documentation -->
    <bpmn:serviceTask id="Task_GenerateAppealDoc" name="Gerar Documentação de Recurso">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="generate-appeal-documentation" />
        <zeebe:ioMapping>
          <zeebe:input source="=classifiedGlosas" target="glosas" />
          <zeebe:input source="=appealStrategy" target="strategy" />
          <zeebe:input source="=glosaReasons" target="reasons" />
          <zeebe:output source="=appealDocumentation" target="appealDocumentation" />
          <zeebe:output source="=needsSupervisorReview" target="needsSupervisorReview" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_eligible</bpmn:incoming>
      <bpmn:outgoing>Flow_to_gateway_supervisor</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Gateway: Needs Supervisor Review? -->
    <bpmn:exclusiveGateway id="Gateway_NeedsSupervisor" name="Requer Revisão&#10;do Supervisor?">
      <bpmn:incoming>Flow_to_gateway_supervisor</bpmn:incoming>
      <bpmn:incoming>Flow_supervisor_reviewed</bpmn:incoming>
      <bpmn:outgoing>Flow_needs_supervisor</bpmn:outgoing>
      <bpmn:outgoing>Flow_no_supervisor_needed</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- User Task: Supervisor Review -->
    <bpmn:userTask id="UserTask_SupervisorReview" name="Revisão do Supervisor">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="escalate-to-supervisor" />
        <zeebe:ioMapping>
          <zeebe:input source="=appealDocumentation" target="documentation" />
          <zeebe:input source="=totalGlosaValue" target="glosaValue" />
          <zeebe:output source="=supervisorApproval" target="supervisorApproval" />
          <zeebe:output source="=supervisorNotes" target="supervisorNotes" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_needs_supervisor</bpmn:incoming>
      <bpmn:outgoing>Flow_supervisor_reviewed</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Timer Boundary Event on Supervisor Review (48h) -->
    <bpmn:boundaryEvent id="BoundaryEvent_SupervisorTimer" name="48h" attachedToRef="UserTask_SupervisorReview">
      <bpmn:outgoing>Flow_supervisor_timeout</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT48H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- Auto-approve on timeout -->
    <bpmn:serviceTask id="Task_AutoApprove" name="Auto-aprovar (Timeout)">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="auto-approve-appeal" />
        <zeebe:ioMapping>
          <zeebe:output source="=true" target="supervisorApproval" />
          <zeebe:output source="='Auto-approved after 48h'" target="supervisorNotes" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_supervisor_timeout</bpmn:incoming>
      <bpmn:outgoing>Flow_auto_approved</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Submit Appeal -->
    <bpmn:serviceTask id="Task_SubmitAppeal" name="Submeter Recurso">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="submit-glosa-appeal" />
        <zeebe:ioMapping>
          <zeebe:input source="=appealDocumentation" target="documentation" />
          <zeebe:input source="=classifiedGlosas" target="glosas" />
          <zeebe:input source="=supervisorNotes" target="notes" />
          <zeebe:output source="=appealSubmissionId" target="appealSubmissionId" />
          <zeebe:output source="=submissionDate" target="submissionDate" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_no_supervisor_needed</bpmn:incoming>
      <bpmn:incoming>Flow_auto_approved</bpmn:incoming>
      <bpmn:outgoing>Flow_to_timer_wait</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Error Boundary Event on Submit Appeal -->
    <bpmn:boundaryEvent id="BoundaryEvent_SubmitError" name="TISS Error" attachedToRef="Task_SubmitAppeal">
      <bpmn:outgoing>Flow_submit_error</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_TISS_ERROR" />
    </bpmn:boundaryEvent>

    <!-- Handle Submit Error -->
    <bpmn:serviceTask id="Task_HandleSubmitError" name="Tratar Erro de Submissão">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="handle-tiss-error" />
        <zeebe:ioMapping>
          <zeebe:input source="=error" target="error" />
          <zeebe:output source="=errorHandled" target="errorHandled" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_submit_error</bpmn:incoming>
      <bpmn:outgoing>Flow_error_handled</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- End Event: Submit Error -->
    <bpmn:endEvent id="EndEvent_SubmitError" name="Erro na Submissão">
      <bpmn:incoming>Flow_error_handled</bpmn:incoming>
      <bpmn:errorEventDefinition errorRef="Error_TISS_ERROR" />
    </bpmn:endEvent>

    <!-- Timer Event: Wait 5 Business Days -->
    <bpmn:intermediateCatchEvent id="IntermediateEvent_Wait5Days" name="Aguardar 5 Dias Úteis">
      <bpmn:incoming>Flow_to_timer_wait</bpmn:incoming>
      <bpmn:incoming>Flow_appeal_not_resolved</bpmn:incoming>
      <bpmn:outgoing>Flow_to_track_status</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P5D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>

    <!-- Track Appeal Status -->
    <bpmn:serviceTask id="Task_TrackStatus" name="Acompanhar Status do Recurso">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="track-appeal-status" />
        <zeebe:ioMapping>
          <zeebe:input source="=appealSubmissionId" target="submissionId" />
          <zeebe:input source="=loopCounter" target="attemptNumber" />
          <zeebe:output source="=appealStatus" target="appealStatus" />
          <zeebe:output source="=isResolved" target="isResolved" />
          <zeebe:output source="=appealSuccessful" target="appealSuccessful" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_to_track_status</bpmn:incoming>
      <bpmn:outgoing>Flow_to_gateway_resolved</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Timer Boundary Event on Process (30 days per ANS RN 424/2017) -->
    <bpmn:boundaryEvent id="BoundaryEvent_AppealMaxDuration" name="30 dias (ANS RN 424/2017)"
                        attachedToRef="Task_TrackStatus" cancelActivity="true">
      <bpmn:outgoing>Flow_max_duration_exceeded</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P30D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- Escalate Due to Timeout -->
    <bpmn:serviceTask id="Task_EscalateTimeout" name="Escalar por Timeout ANS">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="escalate-ans-timeout" />
        <zeebe:ioMapping>
          <zeebe:input source="=appealSubmissionId" target="submissionId" />
          <zeebe:output source="=escalated" target="escalated" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_max_duration_exceeded</bpmn:incoming>
      <bpmn:outgoing>Flow_escalated</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- End Event: Escalated -->
    <bpmn:endEvent id="EndEvent_Escalated" name="Escalado para ANS">
      <bpmn:incoming>Flow_escalated</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Gateway: Appeal Resolved? -->
    <bpmn:exclusiveGateway id="Gateway_AppealResolved" name="Recurso&#10;Resolvido?">
      <bpmn:incoming>Flow_to_gateway_resolved</bpmn:incoming>
      <bpmn:outgoing>Flow_appeal_resolved</bpmn:outgoing>
      <bpmn:outgoing>Flow_appeal_not_resolved</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Update Payment After Resolution -->
    <bpmn:serviceTask id="Task_UpdatePayment" name="Atualizar Pagamento">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="update-payment-after-glosa" />
        <zeebe:ioMapping>
          <zeebe:input source="=classifiedGlosas" target="glosas" />
          <zeebe:input source="=appealSuccessful" target="appealSuccessful" />
          <zeebe:input source="=appealStatus" target="appealStatus" />
          <zeebe:output source="=finalPayment" target="finalPayment" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_appeal_resolved</bpmn:incoming>
      <bpmn:outgoing>Flow_to_end_complete</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- End Event: Process Complete -->
    <bpmn:endEvent id="EndEvent_Complete" name="Processo Completo">
      <bpmn:incoming>Flow_to_end_complete</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="Flow_to_identify_glosa" sourceRef="StartEvent_ReceivePayerResponse" targetRef="Task_IdentifyGlosa" />
    <bpmn:sequenceFlow id="Flow_to_gateway_has_glosas" sourceRef="Task_IdentifyGlosa" targetRef="Gateway_HasGlosas" />
    <bpmn:sequenceFlow id="Flow_no_glosas" name="Não" sourceRef="Gateway_HasGlosas" targetRef="EndEvent_NoGlosas">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=hasGlosas = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_has_glosas" name="Sim" sourceRef="Gateway_HasGlosas" targetRef="Task_ClassifyGlosaType">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=hasGlosas = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_to_parallel_split" sourceRef="Task_ClassifyGlosaType" targetRef="Gateway_ParallelSplit" />
    <bpmn:sequenceFlow id="Flow_to_calculate_impact" sourceRef="Gateway_ParallelSplit" targetRef="Task_CalculateImpact" />
    <bpmn:sequenceFlow id="Flow_to_analyze_reason" sourceRef="Gateway_ParallelSplit" targetRef="Task_AnalyzeReason" />
    <bpmn:sequenceFlow id="Flow_impact_to_join" sourceRef="Task_CalculateImpact" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_reason_to_join" sourceRef="Task_AnalyzeReason" targetRef="Gateway_ParallelJoin" />
    <bpmn:sequenceFlow id="Flow_to_check_eligibility" sourceRef="Gateway_ParallelJoin" targetRef="Task_CheckEligibility" />
    <bpmn:sequenceFlow id="Flow_to_gateway_eligible" sourceRef="Task_CheckEligibility" targetRef="Gateway_EligibleForAppeal" />
    <bpmn:sequenceFlow id="Flow_not_eligible" name="Não" sourceRef="Gateway_EligibleForAppeal" targetRef="Task_UpdatePaymentNotEligible">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=isEligible = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_eligible" name="Sim" sourceRef="Gateway_EligibleForAppeal" targetRef="Task_GenerateAppealDoc">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=isEligible = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_to_end_accepted" sourceRef="Task_UpdatePaymentNotEligible" targetRef="EndEvent_GlosaAccepted" />
    <bpmn:sequenceFlow id="Flow_to_gateway_supervisor" sourceRef="Task_GenerateAppealDoc" targetRef="Gateway_NeedsSupervisor" />
    <bpmn:sequenceFlow id="Flow_needs_supervisor" name="Sim" sourceRef="Gateway_NeedsSupervisor" targetRef="UserTask_SupervisorReview">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=needsSupervisorReview = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_no_supervisor_needed" name="Não" sourceRef="Gateway_NeedsSupervisor" targetRef="Task_SubmitAppeal">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=needsSupervisorReview = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_supervisor_reviewed" sourceRef="UserTask_SupervisorReview" targetRef="Gateway_NeedsSupervisor" />
    <bpmn:sequenceFlow id="Flow_supervisor_timeout" sourceRef="BoundaryEvent_SupervisorTimer" targetRef="Task_AutoApprove" />
    <bpmn:sequenceFlow id="Flow_auto_approved" sourceRef="Task_AutoApprove" targetRef="Task_SubmitAppeal" />
    <bpmn:sequenceFlow id="Flow_submit_error" sourceRef="BoundaryEvent_SubmitError" targetRef="Task_HandleSubmitError" />
    <bpmn:sequenceFlow id="Flow_error_handled" sourceRef="Task_HandleSubmitError" targetRef="EndEvent_SubmitError" />
    <bpmn:sequenceFlow id="Flow_to_timer_wait" sourceRef="Task_SubmitAppeal" targetRef="IntermediateEvent_Wait5Days" />
    <bpmn:sequenceFlow id="Flow_to_track_status" sourceRef="IntermediateEvent_Wait5Days" targetRef="Task_TrackStatus" />
    <bpmn:sequenceFlow id="Flow_to_gateway_resolved" sourceRef="Task_TrackStatus" targetRef="Gateway_AppealResolved" />
    <bpmn:sequenceFlow id="Flow_appeal_resolved" name="Sim" sourceRef="Gateway_AppealResolved" targetRef="Task_UpdatePayment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=isResolved = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_appeal_not_resolved" name="Não (loop)" sourceRef="Gateway_AppealResolved" targetRef="IntermediateEvent_Wait5Days">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=isResolved = false and loopCounter &lt; 6</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_max_duration_exceeded" sourceRef="BoundaryEvent_AppealMaxDuration" targetRef="Task_EscalateTimeout" />
    <bpmn:sequenceFlow id="Flow_escalated" sourceRef="Task_EscalateTimeout" targetRef="EndEvent_Escalated" />
    <bpmn:sequenceFlow id="Flow_to_end_complete" sourceRef="Task_UpdatePayment" targetRef="EndEvent_Complete" />

  </bpmn:process>

  <!-- Error Definitions -->
  <bpmn:error id="Error_TISS_ERROR" name="TISS_ERROR" errorCode="TISS_ERROR" />

  <!-- BPMN Diagram -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="SUB_07_Glosa_Management">
      <!-- Diagram elements would be added here by a visual modeler -->
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
