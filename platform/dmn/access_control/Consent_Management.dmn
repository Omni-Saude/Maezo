<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_Consent_Management"
             name="Consent Management"
             namespace="http://cib7.healthcare/dmn/access_control">

  <decision id="Decision_Consent_Management" name="Gestão de Consentimento do Paciente">
    <informationRequirement>
      <requiredInput href="#InputData_consentType"/>
    </informationRequirement>
    <informationRequirement>
      <requiredInput href="#InputData_consentStatus"/>
    </informationRequirement>
    <informationRequirement>
      <requiredInput href="#InputData_dataUse"/>
    </informationRequirement>
    <informationRequirement>
      <requiredInput href="#InputData_tenantId"/>
    </informationRequirement>

    <decisionTable id="DecisionTable_Consent_Management" hitPolicy="FIRST">
      <input id="Input_consentType" label="Tipo de Consentimento" camunda:inputVariable="consentType">
        <inputExpression id="InputExpression_consentType" typeRef="string">
          <text>consentType</text>
        </inputExpression>
      </input>

      <input id="Input_consentStatus" label="Status do Consentimento" camunda:inputVariable="consentStatus">
        <inputExpression id="InputExpression_consentStatus" typeRef="string">
          <text>consentStatus</text>
        </inputExpression>
      </input>

      <input id="Input_dataUse" label="Uso dos Dados" camunda:inputVariable="dataUse">
        <inputExpression id="InputExpression_dataUse" typeRef="string">
          <text>dataUse</text>
        </inputExpression>
      </input>

      <input id="Input_tenantId" label="ID do Tenant" camunda:inputVariable="tenantId">
        <inputExpression id="InputExpression_tenantId" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="Output_consentValid" label="Consentimento Válido" name="consentValid" typeRef="boolean"/>
      <output id="Output_actionRequired" label="Ação Necessária" name="actionRequired" typeRef="string"/>
      <output id="Output_blockProcessing" label="Bloquear Processamento" name="blockProcessing" typeRef="boolean"/>
      <output id="Output_notifyPatient" label="Notificar Paciente" name="notifyPatient" typeRef="boolean"/>

      <!-- Rule 1: Treatment Consent - Implied by Service Use -->
      <rule id="Rule_Treatment_Implied">
        <inputEntry id="InputEntry_Treatment_Type">
          <text>"TREATMENT"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Treatment_Status">
          <text>"GRANTED","NOT_REQUESTED"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Treatment_Use">
          <text>"CLINICAL_CARE"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Treatment_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Treatment_Valid">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Treatment_Action">
          <text>"NONE"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Treatment_Block">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Treatment_Notify">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: Data Sharing - Requires Explicit Consent -->
      <rule id="Rule_Sharing_Granted">
        <inputEntry id="InputEntry_Sharing_Type">
          <text>"DATA_SHARING"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Sharing_Status">
          <text>"GRANTED"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Sharing_Use">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Sharing_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Sharing_Valid">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Sharing_Action">
          <text>"PROCEED"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Sharing_Block">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Sharing_Notify">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 3: Data Sharing - Not Granted -->
      <rule id="Rule_Sharing_NotGranted">
        <inputEntry id="InputEntry_SharingNot_Type">
          <text>"DATA_SHARING"</text>
        </inputEntry>
        <inputEntry id="InputEntry_SharingNot_Status">
          <text>"NOT_REQUESTED","REVOKED"</text>
        </inputEntry>
        <inputEntry id="InputEntry_SharingNot_Use">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_SharingNot_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_SharingNot_Valid">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_SharingNot_Action">
          <text>"REQUEST_CONSENT"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_SharingNot_Block">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_SharingNot_Notify">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Rule 4: Research Consent - Requires Active Consent -->
      <rule id="Rule_Research_Granted">
        <inputEntry id="InputEntry_Research_Type">
          <text>"RESEARCH"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Research_Status">
          <text>"GRANTED"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Research_Use">
          <text>"RESEARCH","CLINICAL_TRIAL"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Research_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Research_Valid">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Research_Action">
          <text>"ANONYMIZE_AND_PROCEED"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Research_Block">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Research_Notify">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 5: Research Consent - Not Granted -->
      <rule id="Rule_Research_NotGranted">
        <inputEntry id="InputEntry_ResearchNot_Type">
          <text>"RESEARCH"</text>
        </inputEntry>
        <inputEntry id="InputEntry_ResearchNot_Status">
          <text>"NOT_REQUESTED","REVOKED","EXPIRED"</text>
        </inputEntry>
        <inputEntry id="InputEntry_ResearchNot_Use">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_ResearchNot_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_ResearchNot_Valid">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_ResearchNot_Action">
          <text>"REQUEST_CONSENT"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_ResearchNot_Block">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_ResearchNot_Notify">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Rule 6: Marketing Consent - Opt-in Required -->
      <rule id="Rule_Marketing_Granted">
        <inputEntry id="InputEntry_Marketing_Type">
          <text>"MARKETING"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Marketing_Status">
          <text>"GRANTED"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Marketing_Use">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Marketing_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Marketing_Valid">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Marketing_Action">
          <text>"PROCEED"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Marketing_Block">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Marketing_Notify">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 7: Marketing Consent - Not Granted -->
      <rule id="Rule_Marketing_NotGranted">
        <inputEntry id="InputEntry_MarketingNot_Type">
          <text>"MARKETING"</text>
        </inputEntry>
        <inputEntry id="InputEntry_MarketingNot_Status">
          <text>"NOT_REQUESTED","REVOKED","EXPIRED"</text>
        </inputEntry>
        <inputEntry id="InputEntry_MarketingNot_Use">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_MarketingNot_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_MarketingNot_Valid">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_MarketingNot_Action">
          <text>"BLOCK"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_MarketingNot_Block">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_MarketingNot_Notify">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 8: Revoked Consent - Block All -->
      <rule id="Rule_Revoked_All">
        <inputEntry id="InputEntry_Revoked_Type">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Revoked_Status">
          <text>"REVOKED"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Revoked_Use">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Revoked_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Revoked_Valid">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Revoked_Action">
          <text>"DELETE_DATA"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Revoked_Block">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Revoked_Notify">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Rule 9: Expired Consent - Request Renewal -->
      <rule id="Rule_Expired">
        <inputEntry id="InputEntry_Expired_Type">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Expired_Status">
          <text>"EXPIRED"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Expired_Use">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Expired_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Expired_Valid">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Expired_Action">
          <text>"REQUEST_RENEWAL"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Expired_Block">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Expired_Notify">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Rule 10: Default - Request Consent -->
      <rule id="Rule_Default_Request">
        <inputEntry id="InputEntry_Default_Type">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_Status">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_Use">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Default_Valid">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_Action">
          <text>"REQUEST_CONSENT"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_Block">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_Notify">
          <text>true</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <inputData id="InputData_consentType" name="Tipo de Consentimento"/>
  <inputData id="InputData_consentStatus" name="Status do Consentimento"/>
  <inputData id="InputData_dataUse" name="Uso dos Dados"/>
  <inputData id="InputData_tenantId" name="ID do Tenant"/>
</definitions>
