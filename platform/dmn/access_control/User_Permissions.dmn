<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_User_Permissions"
             name="User Permissions"
             namespace="http://cib7.healthcare/dmn/access_control">

  <decision id="Decision_User_Permissions" name="Controle de Permissões de Usuário">
    <informationRequirement>
      <requiredInput href="#InputData_userRole"/>
    </informationRequirement>
    <informationRequirement>
      <requiredInput href="#InputData_department"/>
    </informationRequirement>
    <informationRequirement>
      <requiredInput href="#InputData_resourceType"/>
    </informationRequirement>
    <informationRequirement>
      <requiredInput href="#InputData_tenantId"/>
    </informationRequirement>

    <decisionTable id="DecisionTable_User_Permissions" hitPolicy="FIRST">
      <input id="Input_userRole" label="Papel do Usuário" camunda:inputVariable="userRole">
        <inputExpression id="InputExpression_userRole" typeRef="string">
          <text>userRole</text>
        </inputExpression>
      </input>

      <input id="Input_department" label="Departamento" camunda:inputVariable="department">
        <inputExpression id="InputExpression_department" typeRef="string">
          <text>department</text>
        </inputExpression>
      </input>

      <input id="Input_resourceType" label="Tipo de Recurso" camunda:inputVariable="resourceType">
        <inputExpression id="InputExpression_resourceType" typeRef="string">
          <text>resourceType</text>
        </inputExpression>
      </input>

      <input id="Input_tenantId" label="ID do Tenant" camunda:inputVariable="tenantId">
        <inputExpression id="InputExpression_tenantId" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="Output_accessLevel" label="Nível de Acesso" name="accessLevel" typeRef="string"/>
      <output id="Output_requiresMFA" label="Requer MFA" name="requiresMFA" typeRef="boolean"/>
      <output id="Output_auditRequired" label="Auditoria Obrigatória" name="auditRequired" typeRef="boolean"/>
      <output id="Output_dataScope" label="Escopo de Dados" name="dataScope" typeRef="string"/>

      <!-- Rule 1: Admin Full Access -->
      <rule id="Rule_Admin_Full">
        <inputEntry id="InputEntry_Admin_Role">
          <text>"ADMIN"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Admin_Dept">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Admin_Resource">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Admin_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Admin_Access">
          <text>"FULL"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Admin_MFA">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Admin_Audit">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Admin_Scope">
          <text>"ALL_DEPARTMENTS"</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: Physician Clinical Data -->
      <rule id="Rule_Physician_Clinical">
        <inputEntry id="InputEntry_Physician_Role">
          <text>"PHYSICIAN"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Physician_Dept">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Physician_Resource">
          <text>"PATIENT_DATA","CLINICAL"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Physician_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Physician_Access">
          <text>"READ_WRITE"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Physician_MFA">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Physician_Audit">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Physician_Scope">
          <text>"ASSIGNED_PATIENTS"</text>
        </outputEntry>
      </rule>

      <!-- Rule 3: Physician Billing Read-Only -->
      <rule id="Rule_Physician_Billing">
        <inputEntry id="InputEntry_Physician_Bill_Role">
          <text>"PHYSICIAN"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Physician_Bill_Dept">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Physician_Bill_Resource">
          <text>"BILLING"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Physician_Bill_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Physician_Bill_Access">
          <text>"READ_ONLY"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Physician_Bill_MFA">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Physician_Bill_Audit">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Physician_Bill_Scope">
          <text>"ASSIGNED_PATIENTS"</text>
        </outputEntry>
      </rule>

      <!-- Rule 4: Nurse Clinical Limited Access -->
      <rule id="Rule_Nurse_Clinical">
        <inputEntry id="InputEntry_Nurse_Role">
          <text>"NURSE"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Nurse_Dept">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Nurse_Resource">
          <text>"PATIENT_DATA","CLINICAL"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Nurse_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Nurse_Access">
          <text>"READ_WRITE"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Nurse_MFA">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Nurse_Audit">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Nurse_Scope">
          <text>"DEPARTMENT_PATIENTS"</text>
        </outputEntry>
      </rule>

      <!-- Rule 5: Billing Analyst Financial Access -->
      <rule id="Rule_Billing_Financial">
        <inputEntry id="InputEntry_Billing_Role">
          <text>"BILLING_ANALYST"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Billing_Dept">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Billing_Resource">
          <text>"BILLING"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Billing_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Billing_Access">
          <text>"READ_WRITE"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Billing_MFA">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Billing_Audit">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Billing_Scope">
          <text>"ALL_BILLING"</text>
        </outputEntry>
      </rule>

      <!-- Rule 6: Billing Analyst Patient Data Read-Only -->
      <rule id="Rule_Billing_Patient">
        <inputEntry id="InputEntry_Billing_Pat_Role">
          <text>"BILLING_ANALYST"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Billing_Pat_Dept">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Billing_Pat_Resource">
          <text>"PATIENT_DATA"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Billing_Pat_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Billing_Pat_Access">
          <text>"READ_ONLY"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Billing_Pat_MFA">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Billing_Pat_Audit">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Billing_Pat_Scope">
          <text>"BILLING_RELATED"</text>
        </outputEntry>
      </rule>

      <!-- Rule 7: Auditor Full Read Access -->
      <rule id="Rule_Auditor_All">
        <inputEntry id="InputEntry_Auditor_Role">
          <text>"AUDITOR"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Auditor_Dept">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Auditor_Resource">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Auditor_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Auditor_Access">
          <text>"READ_ONLY"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Auditor_MFA">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Auditor_Audit">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Auditor_Scope">
          <text>"ALL_DEPARTMENTS"</text>
        </outputEntry>
      </rule>

      <!-- Rule 8: Manager Reports Access -->
      <rule id="Rule_Manager_Reports">
        <inputEntry id="InputEntry_Manager_Role">
          <text>"MANAGER"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Manager_Dept">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Manager_Resource">
          <text>"REPORTS"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Manager_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Manager_Access">
          <text>"READ_WRITE"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Manager_MFA">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Manager_Audit">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Manager_Scope">
          <text>"DEPARTMENT"</text>
        </outputEntry>
      </rule>

      <!-- Rule 9: Reception Patient Registration -->
      <rule id="Rule_Reception_Registration">
        <inputEntry id="InputEntry_Reception_Role">
          <text>"RECEPTION"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Reception_Dept">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Reception_Resource">
          <text>"PATIENT_DATA"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Reception_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Reception_Access">
          <text>"READ_WRITE"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Reception_MFA">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Reception_Audit">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Reception_Scope">
          <text>"REGISTRATION_ONLY"</text>
        </outputEntry>
      </rule>

      <!-- Rule 10: Default Deny All -->
      <rule id="Rule_Default_Deny">
        <inputEntry id="InputEntry_Default_Role">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_Dept">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_Resource">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Default_Access">
          <text>"NONE"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_MFA">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_Audit">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_Scope">
          <text>"NONE"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <inputData id="InputData_userRole" name="Papel do Usuário"/>
  <inputData id="InputData_department" name="Departamento"/>
  <inputData id="InputData_resourceType" name="Tipo de Recurso"/>
  <inputData id="InputData_tenantId" name="ID do Tenant"/>
</definitions>
