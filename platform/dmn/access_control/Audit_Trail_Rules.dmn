<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_Audit_Trail"
             name="Audit Trail Rules"
             namespace="http://cib7.healthcare/dmn/access_control">

  <decision id="Decision_Audit_Trail" name="Regras de Trilha de Auditoria">
    <informationRequirement>
      <requiredInput href="#InputData_actionType"/>
    </informationRequirement>
    <informationRequirement>
      <requiredInput href="#InputData_resourceSensitivity"/>
    </informationRequirement>
    <informationRequirement>
      <requiredInput href="#InputData_userRole"/>
    </informationRequirement>
    <informationRequirement>
      <requiredInput href="#InputData_isAfterHours"/>
    </informationRequirement>
    <informationRequirement>
      <requiredInput href="#InputData_tenantId"/>
    </informationRequirement>

    <decisionTable id="DecisionTable_Audit_Trail" hitPolicy="FIRST">
      <input id="Input_actionType" label="Tipo de Ação" camunda:inputVariable="actionType">
        <inputExpression id="InputExpression_actionType" typeRef="string">
          <text>actionType</text>
        </inputExpression>
      </input>

      <input id="Input_resourceSensitivity" label="Sensibilidade do Recurso" camunda:inputVariable="resourceSensitivity">
        <inputExpression id="InputExpression_resourceSensitivity" typeRef="string">
          <text>resourceSensitivity</text>
        </inputExpression>
      </input>

      <input id="Input_userRole" label="Papel do Usuário" camunda:inputVariable="userRole">
        <inputExpression id="InputExpression_userRole" typeRef="string">
          <text>userRole</text>
        </inputExpression>
      </input>

      <input id="Input_isAfterHours" label="Fora do Horário" camunda:inputVariable="isAfterHours">
        <inputExpression id="InputExpression_isAfterHours" typeRef="boolean">
          <text>isAfterHours</text>
        </inputExpression>
      </input>

      <input id="Input_tenantId" label="ID do Tenant" camunda:inputVariable="tenantId">
        <inputExpression id="InputExpression_tenantId" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="Output_logLevel" label="Nível de Log" name="logLevel" typeRef="string"/>
      <output id="Output_alertRequired" label="Alerta Necessário" name="alertRequired" typeRef="boolean"/>
      <output id="Output_retentionYears" label="Anos de Retenção" name="retentionYears" typeRef="integer"/>
      <output id="Output_reviewRequired" label="Revisão Necessária" name="reviewRequired" typeRef="boolean"/>

      <!-- Rule 1: DELETE High Sensitivity - Maximum Audit -->
      <rule id="Rule_Delete_High">
        <inputEntry id="InputEntry_Delete_Action">
          <text>"DELETE"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Delete_Sensitivity">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Delete_Role">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Delete_Hours">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Delete_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Delete_Log">
          <text>"DETAILED"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Delete_Alert">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Delete_Retention">
          <text>10</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Delete_Review">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: EXPORT High Sensitivity - Detailed Audit -->
      <rule id="Rule_Export_High">
        <inputEntry id="InputEntry_Export_Action">
          <text>"EXPORT"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Export_Sensitivity">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Export_Role">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Export_Hours">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Export_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Export_Log">
          <text>"DETAILED"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Export_Alert">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Export_Retention">
          <text>7</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Export_Review">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Rule 3: PRINT High Sensitivity -->
      <rule id="Rule_Print_High">
        <inputEntry id="InputEntry_Print_Action">
          <text>"PRINT"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Print_Sensitivity">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Print_Role">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Print_Hours">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Print_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Print_Log">
          <text>"DETAILED"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Print_Alert">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Print_Retention">
          <text>5</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Print_Review">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 4: EDIT High Sensitivity - Standard Audit -->
      <rule id="Rule_Edit_High">
        <inputEntry id="InputEntry_Edit_Action">
          <text>"EDIT"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Edit_Sensitivity">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Edit_Role">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Edit_Hours">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Edit_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Edit_Log">
          <text>"STANDARD"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Edit_Alert">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Edit_Retention">
          <text>7</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Edit_Review">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 5: After Hours High Sensitivity - Always Alert -->
      <rule id="Rule_AfterHours_High">
        <inputEntry id="InputEntry_AfterHours_Action">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_AfterHours_Sensitivity">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="InputEntry_AfterHours_Role">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_AfterHours_Hours">
          <text>true</text>
        </inputEntry>
        <inputEntry id="InputEntry_AfterHours_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_AfterHours_Log">
          <text>"DETAILED"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_AfterHours_Alert">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_AfterHours_Retention">
          <text>7</text>
        </outputEntry>
        <outputEntry id="OutputEntry_AfterHours_Review">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Rule 6: VIEW High Sensitivity - Minimal Logging -->
      <rule id="Rule_View_High">
        <inputEntry id="InputEntry_View_Action">
          <text>"VIEW"</text>
        </inputEntry>
        <inputEntry id="InputEntry_View_Sensitivity">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="InputEntry_View_Role">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_View_Hours">
          <text>false</text>
        </inputEntry>
        <inputEntry id="InputEntry_View_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_View_Log">
          <text>"STANDARD"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_View_Alert">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_View_Retention">
          <text>3</text>
        </outputEntry>
        <outputEntry id="OutputEntry_View_Review">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 7: DELETE/EXPORT Medium Sensitivity -->
      <rule id="Rule_Critical_Medium">
        <inputEntry id="InputEntry_Critical_Action">
          <text>"DELETE","EXPORT"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_Sensitivity">
          <text>"MEDIUM"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_Role">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_Hours">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Critical_Log">
          <text>"STANDARD"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Critical_Alert">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Critical_Retention">
          <text>5</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Critical_Review">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 8: Edit/View Medium Sensitivity -->
      <rule id="Rule_Standard_Medium">
        <inputEntry id="InputEntry_Standard_Action">
          <text>"EDIT","VIEW"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Standard_Sensitivity">
          <text>"MEDIUM"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Standard_Role">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Standard_Hours">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Standard_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Standard_Log">
          <text>"STANDARD"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Standard_Alert">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Standard_Retention">
          <text>3</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Standard_Review">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 9: Low Sensitivity - Minimal Audit -->
      <rule id="Rule_Low_Sensitivity">
        <inputEntry id="InputEntry_Low_Action">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_Sensitivity">
          <text>"LOW"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_Role">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_Hours">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Low_Log">
          <text>"MINIMAL"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_Alert">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_Retention">
          <text>1</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_Review">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 10: Default - Standard Audit -->
      <rule id="Rule_Default">
        <inputEntry id="InputEntry_Default_Action">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_Sensitivity">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_Role">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_Hours">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_Tenant">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Default_Log">
          <text>"STANDARD"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_Alert">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_Retention">
          <text>2</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_Review">
          <text>false</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <inputData id="InputData_actionType" name="Tipo de Ação"/>
  <inputData id="InputData_resourceSensitivity" name="Sensibilidade do Recurso"/>
  <inputData id="InputData_userRole" name="Papel do Usuário"/>
  <inputData id="InputData_isAfterHours" name="Fora do Horário"/>
  <inputData id="InputData_tenantId" name="ID do Tenant"/>
</definitions>
