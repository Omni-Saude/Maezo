<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Upcoding_Detection_DMN"
             name="Upcoding Detection Decision"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="upcoding_detection_decision" name="Detecção de Upcoding/Fraude">
    <decisionTable id="upcoding_detection_table" hitPolicy="FIRST">
      <input id="input_claimedComplexity" label="Complexidade Alegada" camunda:inputVariable="claimedComplexity">
        <inputExpression id="inputExpr_claimedComplexity" typeRef="string">
          <text>claimedComplexity</text>
        </inputExpression>
      </input>
      <input id="input_documentedComplexity" label="Complexidade Documentada" camunda:inputVariable="documentedComplexity">
        <inputExpression id="inputExpr_documentedComplexity" typeRef="string">
          <text>documentedComplexity</text>
        </inputExpression>
      </input>
      <input id="input_averageLOS" label="Tempo Médio de Internação (dias)" camunda:inputVariable="averageLOS">
        <inputExpression id="inputExpr_averageLOS" typeRef="double">
          <text>averageLOS</text>
        </inputExpression>
      </input>
      <input id="input_actualLOS" label="Tempo Real de Internação (dias)" camunda:inputVariable="actualLOS">
        <inputExpression id="inputExpr_actualLOS" typeRef="integer">
          <text>actualLOS</text>
        </inputExpression>
      </input>
      <input id="input_outlierRatio" label="Razão de Outlier" camunda:inputVariable="outlierRatio">
        <inputExpression id="inputExpr_outlierRatio" typeRef="double">
          <text>outlierRatio</text>
        </inputExpression>
      </input>
      <input id="input_tenantId" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="inputExpr_tenantId" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="output_upcodingRisk" label="Risco de Upcoding" name="upcodingRisk" typeRef="string">
        <outputValues id="outputValues_upcodingRisk">
          <text>"HIGH","MEDIUM","LOW"</text>
        </outputValues>
      </output>
      <output id="output_riskScore" label="Score de Risco (0-100)" name="riskScore" typeRef="integer" />
      <output id="output_auditFlag" label="Flag de Auditoria" name="auditFlag" typeRef="boolean" />
      <output id="output_recommendation" label="Recomendação" name="recommendation" typeRef="string" />

      <!-- Regra 1: Complexidade alegada muito superior à documentada + LOS alto -->
      <rule id="rule_upcode_001">
        <inputEntry id="inputEntry_upcode_001_1">
          <text>"HIGH","EXTRA"</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_001_2">
          <text>"LOW","MEDIUM"</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_001_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_001_4">
          <text>&gt; 14</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_001_5">
          <text>&gt; 2.0</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_001_6">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_upcode_001_1">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_001_2">
          <text>95</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_001_3">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_001_4">
          <text>"CRÍTICO: Complexidade alegada inconsistente com documentação e LOS elevado - auditoria médica imediata"</text>
        </outputEntry>
      </rule>

      <!-- Regra 2: Complexidade moderadamente inflada com outlier significativo -->
      <rule id="rule_upcode_002">
        <inputEntry id="inputEntry_upcode_002_1">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_002_2">
          <text>"MEDIUM"</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_002_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_002_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_002_5">
          <text>&gt; 1.8</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_002_6">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_upcode_002_1">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_002_2">
          <text>85</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_002_3">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_002_4">
          <text>"Alto risco de upcoding - discrepância entre complexidade alegada e documentada com outlier significativo"</text>
        </outputEntry>
      </rule>

      <!-- Regra 3: LOS muito inferior à média (downcoding suspeito) -->
      <rule id="rule_upcode_003">
        <inputEntry id="inputEntry_upcode_003_1">
          <text>"LOW"</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_003_2">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_003_3">
          <text>&gt; 8.0</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_003_4">
          <text>&lt; 3</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_003_5">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_003_6">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_upcode_003_1">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_003_2">
          <text>80</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_003_3">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_003_4">
          <text>"Possível downcoding ou alta prematura - LOS muito inferior ao esperado para complexidade documentada"</text>
        </outputEntry>
      </rule>

      <!-- Regra 4: Outlier extremo com complexidade inflada -->
      <rule id="rule_upcode_004">
        <inputEntry id="inputEntry_upcode_004_1">
          <text>"EXTRA"</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_004_2">
          <text>"MEDIUM","LOW"</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_004_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_004_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_004_5">
          <text>&gt; 2.5</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_004_6">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_upcode_004_1">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_004_2">
          <text>90</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_004_3">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_004_4">
          <text>"Outlier extremo com complexidade máxima não justificada - investigação de fraude recomendada"</text>
        </outputEntry>
      </rule>

      <!-- Regra 5: Discrepância média com outlier moderado -->
      <rule id="rule_upcode_005">
        <inputEntry id="inputEntry_upcode_005_1">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_005_2">
          <text>"LOW"</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_005_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_005_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_005_5">
          <text>&gt; 1.5 and &lt;= 1.8</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_005_6">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_upcode_005_1">
          <text>"MEDIUM"</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_005_2">
          <text>65</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_005_3">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_005_4">
          <text>"Risco médio - revisar documentação para justificar complexidade alegada"</text>
        </outputEntry>
      </rule>

      <!-- Regra 6: LOS acima da média mas complexidade coerente -->
      <rule id="rule_upcode_006">
        <inputEntry id="inputEntry_upcode_006_1">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_006_2">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_006_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_006_4">
          <text>&gt; 12</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_006_5">
          <text>&gt; 1.3 and &lt;= 1.5</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_006_6">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_upcode_006_1">
          <text>"MEDIUM"</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_006_2">
          <text>45</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_006_3">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_006_4">
          <text>"Outlier justificado - complexidade documentada coerente com LOS"</text>
        </outputEntry>
      </rule>

      <!-- Regra 7: Pequena discrepância com baixo outlier -->
      <rule id="rule_upcode_007">
        <inputEntry id="inputEntry_upcode_007_1">
          <text>"MEDIUM"</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_007_2">
          <text>"LOW"</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_007_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_007_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_007_5">
          <text>&gt; 1.2 and &lt;= 1.5</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_007_6">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_upcode_007_1">
          <text>"MEDIUM"</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_007_2">
          <text>50</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_007_3">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_007_4">
          <text>"Monitorar - pequena discrepância requer acompanhamento"</text>
        </outputEntry>
      </rule>

      <!-- Regra 8: Complexidades alinhadas, LOS dentro da média -->
      <rule id="rule_upcode_008">
        <inputEntry id="inputEntry_upcode_008_1">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_008_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_008_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_008_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_008_5">
          <text>&lt;= 1.2</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_008_6">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_upcode_008_1">
          <text>"LOW"</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_008_2">
          <text>15</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_008_3">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_008_4">
          <text>"Baixo risco - codificação dentro dos parâmetros esperados"</text>
        </outputEntry>
      </rule>

      <!-- Regra 9: Complexidades idênticas mas com outlier alto -->
      <rule id="rule_upcode_009">
        <inputEntry id="inputEntry_upcode_009_1">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_009_2">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_009_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_009_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_009_5">
          <text>&gt; 1.8</text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_009_6">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_upcode_009_1">
          <text>"MEDIUM"</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_009_2">
          <text>55</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_009_3">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_009_4">
          <text>"Verificar complicações que justifiquem outlier mesmo com complexidade coerente"</text>
        </outputEntry>
      </rule>

      <!-- Regra 10: Fallback - análise padrão -->
      <rule id="rule_upcode_010">
        <inputEntry id="inputEntry_upcode_010_1">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_010_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_010_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_010_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_010_5">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_upcode_010_6">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_upcode_010_1">
          <text>"LOW"</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_010_2">
          <text>25</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_010_3">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_upcode_010_4">
          <text>"Análise de rotina - sem indicadores significativos de upcoding"</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Upcoding_Detection">
      <dmndi:DMNShape id="DMNShape_upcoding_detection_decision" dmnElementRef="upcoding_detection_decision">
        <dc:Bounds height="80" width="180" x="100" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
