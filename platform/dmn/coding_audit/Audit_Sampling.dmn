<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Audit_Sampling_DMN"
             name="Audit Sampling Decision"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="audit_sampling_decision" name="Seleção de Amostra para Auditoria">
    <decisionTable id="audit_sampling_table" hitPolicy="FIRST">
      <input id="input_claimAmount" label="Valor da Conta (R$)" camunda:inputVariable="claimAmount">
        <inputExpression id="inputExpr_claimAmount" typeRef="double">
          <text>claimAmount</text>
        </inputExpression>
      </input>
      <input id="input_payerRiskLevel" label="Nível de Risco do Pagador" camunda:inputVariable="payerRiskLevel">
        <inputExpression id="inputExpr_payerRiskLevel" typeRef="string">
          <text>payerRiskLevel</text>
        </inputExpression>
        <inputValues id="inputValues_payerRiskLevel">
          <text>"HIGH","MEDIUM","LOW"</text>
        </inputValues>
      </input>
      <input id="input_procedureComplexity" label="Complexidade do Procedimento" camunda:inputVariable="procedureComplexity">
        <inputExpression id="inputExpr_procedureComplexity" typeRef="string">
          <text>procedureComplexity</text>
        </inputExpression>
        <inputValues id="inputValues_procedureComplexity">
          <text>"EXTRA","LARGE","MEDIUM","SMALL"</text>
        </inputValues>
      </input>
      <input id="input_providerAuditHistory" label="Histórico de Auditoria do Prestador" camunda:inputVariable="providerAuditHistory">
        <inputExpression id="inputExpr_providerAuditHistory" typeRef="string">
          <text>providerAuditHistory</text>
        </inputExpression>
        <inputValues id="inputValues_providerAuditHistory">
          <text>"PROBLEMATIC","ATTENTION","GOOD","EXCELLENT"</text>
        </inputValues>
      </input>
      <input id="input_tenantId" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="inputExpr_tenantId" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="output_sampleForAudit" label="Selecionar para Auditoria" name="sampleForAudit" typeRef="boolean" />
      <output id="output_auditType" label="Tipo de Auditoria" name="auditType" typeRef="string">
        <outputValues id="outputValues_auditType">
          <text>"FULL","TARGETED","DESK"</text>
        </outputValues>
      </output>
      <output id="output_priority" label="Prioridade (1-5)" name="priority" typeRef="integer" />
      <output id="output_reviewerLevel" label="Nível do Revisor" name="reviewerLevel" typeRef="string" />

      <!-- Regra 1: Conta de alto valor + prestador problemático + risco alto -->
      <rule id="rule_sample_001">
        <inputEntry id="inputEntry_sample_001_1">
          <text>&gt; 100000</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_001_2">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_001_3">
          <text>"EXTRA","LARGE"</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_001_4">
          <text>"PROBLEMATIC"</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_001_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_sample_001_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_001_2">
          <text>"FULL"</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_001_3">
          <text>5</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_001_4">
          <text>"SENIOR_AUDITOR"</text>
        </outputEntry>
      </rule>

      <!-- Regra 2: Valor muito alto (>R$ 200k) - sempre auditar -->
      <rule id="rule_sample_002">
        <inputEntry id="inputEntry_sample_002_1">
          <text>&gt; 200000</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_002_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_002_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_002_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_002_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_sample_002_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_002_2">
          <text>"FULL"</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_002_3">
          <text>5</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_002_4">
          <text>"SENIOR_AUDITOR"</text>
        </outputEntry>
      </rule>

      <!-- Regra 3: Procedimento de porte especial + prestador em observação -->
      <rule id="rule_sample_003">
        <inputEntry id="inputEntry_sample_003_1">
          <text>&gt; 50000</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_003_2">
          <text>"MEDIUM","HIGH"</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_003_3">
          <text>"EXTRA"</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_003_4">
          <text>"ATTENTION","PROBLEMATIC"</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_003_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_sample_003_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_003_2">
          <text>"TARGETED"</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_003_3">
          <text>4</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_003_4">
          <text>"AUDITOR"</text>
        </outputEntry>
      </rule>

      <!-- Regra 4: Pagador de alto risco - auditoria direcionada -->
      <rule id="rule_sample_004">
        <inputEntry id="inputEntry_sample_004_1">
          <text>&gt; 30000</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_004_2">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_004_3">
          <text>"LARGE","EXTRA"</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_004_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_004_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_sample_004_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_004_2">
          <text>"TARGETED"</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_004_3">
          <text>4</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_004_4">
          <text>"AUDITOR"</text>
        </outputEntry>
      </rule>

      <!-- Regra 5: Prestador problemático com qualquer valor médio-alto -->
      <rule id="rule_sample_005">
        <inputEntry id="inputEntry_sample_005_1">
          <text>&gt; 15000</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_005_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_005_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_005_4">
          <text>"PROBLEMATIC"</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_005_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_sample_005_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_005_2">
          <text>"TARGETED"</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_005_3">
          <text>3</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_005_4">
          <text>"AUDITOR"</text>
        </outputEntry>
      </rule>

      <!-- Regra 6: Procedimentos complexos - auditoria de mesa -->
      <rule id="rule_sample_006">
        <inputEntry id="inputEntry_sample_006_1">
          <text>&gt; 20000 and &lt;= 50000</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_006_2">
          <text>"MEDIUM"</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_006_3">
          <text>"LARGE"</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_006_4">
          <text>"GOOD","ATTENTION"</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_006_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_sample_006_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_006_2">
          <text>"DESK"</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_006_3">
          <text>2</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_006_4">
          <text>"JUNIOR_AUDITOR"</text>
        </outputEntry>
      </rule>

      <!-- Regra 7: Amostragem aleatória para controle de qualidade -->
      <rule id="rule_sample_007">
        <inputEntry id="inputEntry_sample_007_1">
          <text>&gt; 10000 and &lt;= 20000</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_007_2">
          <text>"LOW","MEDIUM"</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_007_3">
          <text>"MEDIUM"</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_007_4">
          <text>"EXCELLENT","GOOD"</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_007_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_sample_007_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_007_2">
          <text>"DESK"</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_007_3">
          <text>1</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_007_4">
          <text>"JUNIOR_AUDITOR"</text>
        </outputEntry>
      </rule>

      <!-- Regra 8: Prestador excelente + baixo valor - não auditar -->
      <rule id="rule_sample_008">
        <inputEntry id="inputEntry_sample_008_1">
          <text>&lt;= 10000</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_008_2">
          <text>"LOW"</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_008_3">
          <text>"SMALL","MEDIUM"</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_008_4">
          <text>"EXCELLENT"</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_008_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_sample_008_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_008_2">
          <text>"DESK"</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_008_3">
          <text>0</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_008_4">
          <text>"AUTO_APPROVED"</text>
        </outputEntry>
      </rule>

      <!-- Regra 9: Procedimentos simples de baixo valor - auditoria mínima -->
      <rule id="rule_sample_009">
        <inputEntry id="inputEntry_sample_009_1">
          <text>&lt;= 5000</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_009_2">
          <text>"LOW"</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_009_3">
          <text>"SMALL"</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_009_4">
          <text>"GOOD","EXCELLENT"</text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_009_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_sample_009_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_009_2">
          <text>"DESK"</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_009_3">
          <text>0</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_009_4">
          <text>"AUTO_APPROVED"</text>
        </outputEntry>
      </rule>

      <!-- Regra 10: Fallback - auditoria de mesa padrão -->
      <rule id="rule_sample_010">
        <inputEntry id="inputEntry_sample_010_1">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_010_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_010_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_010_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_sample_010_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_sample_010_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_010_2">
          <text>"DESK"</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_010_3">
          <text>2</text>
        </outputEntry>
        <outputEntry id="outputEntry_sample_010_4">
          <text>"AUDITOR"</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Audit_Sampling">
      <dmndi:DMNShape id="DMNShape_audit_sampling_decision" dmnElementRef="audit_sampling_decision">
        <dc:Bounds height="80" width="180" x="100" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
