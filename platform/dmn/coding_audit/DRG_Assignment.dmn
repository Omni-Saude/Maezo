<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="DRG_Assignment_DMN"
             name="DRG Assignment Decision"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="drg_assignment_decision" name="Atribuição de DRG">
    <decisionTable id="drg_assignment_table" hitPolicy="FIRST">
      <input id="input_primaryDiagnosis" label="Diagnóstico Principal" camunda:inputVariable="primaryDiagnosis">
        <inputExpression id="inputExpr_primaryDiagnosis" typeRef="string">
          <text>primaryDiagnosis</text>
        </inputExpression>
      </input>
      <input id="input_procedurePerformed" label="Procedimento Realizado" camunda:inputVariable="procedurePerformed">
        <inputExpression id="inputExpr_procedurePerformed" typeRef="string">
          <text>procedurePerformed</text>
        </inputExpression>
      </input>
      <input id="input_comorbidityLevel" label="Nível de Comorbidade" camunda:inputVariable="comorbidityLevel">
        <inputExpression id="inputExpr_comorbidityLevel" typeRef="string">
          <text>comorbidityLevel</text>
        </inputExpression>
        <inputValues id="inputValues_comorbidityLevel">
          <text>"NONE","MINOR","MAJOR","CATASTROPHIC"</text>
        </inputValues>
      </input>
      <input id="input_lengthOfStay" label="Tempo de Internação (dias)" camunda:inputVariable="lengthOfStay">
        <inputExpression id="inputExpr_lengthOfStay" typeRef="integer">
          <text>lengthOfStay</text>
        </inputExpression>
      </input>
      <input id="input_tenantId" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="inputExpr_tenantId" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="output_drgCode" label="Código DRG" name="drgCode" typeRef="string" />
      <output id="output_drgWeight" label="Peso DRG" name="drgWeight" typeRef="double" />
      <output id="output_expectedLOS" label="Tempo de Internação Esperado" name="expectedLOS" typeRef="integer" />
      <output id="output_outlierFlag" label="Marcador de Outlier" name="outlierFlag" typeRef="boolean" />

      <!-- Regra 1: Cirurgia cardíaca com complicações catastróficas -->
      <rule id="rule_drg_001">
        <inputEntry id="inputEntry_drg_001_1">
          <text>starts with(primaryDiagnosis, "I2")</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_001_2">
          <text>"CARDIAC_SURGERY"</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_001_3">
          <text>"CATASTROPHIC"</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_001_4">
          <text>&gt; 14</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_001_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_drg_001_1">
          <text>"DRG-001-CC"</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_001_2">
          <text>4.85</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_001_3">
          <text>12</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_001_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Regra 2: Cirurgia cardíaca com complicações maiores -->
      <rule id="rule_drg_002">
        <inputEntry id="inputEntry_drg_002_1">
          <text>starts with(primaryDiagnosis, "I2")</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_002_2">
          <text>"CARDIAC_SURGERY"</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_002_3">
          <text>"MAJOR"</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_002_4">
          <text>&gt; 7 and &lt;= 14</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_002_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_drg_002_1">
          <text>"DRG-001-MC"</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_002_2">
          <text>3.65</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_002_3">
          <text>10</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_002_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 3: Parto cesáreo com complicações -->
      <rule id="rule_drg_003">
        <inputEntry id="inputEntry_drg_003_1">
          <text>starts with(primaryDiagnosis, "O8")</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_003_2">
          <text>"CESAREAN_SECTION"</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_003_3">
          <text>"MAJOR"</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_003_4">
          <text>&gt; 4</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_003_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_drg_003_1">
          <text>"DRG-370-MC"</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_003_2">
          <text>1.85</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_003_3">
          <text>3</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_003_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Regra 4: Parto cesáreo sem complicações -->
      <rule id="rule_drg_004">
        <inputEntry id="inputEntry_drg_004_1">
          <text>starts with(primaryDiagnosis, "O8")</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_004_2">
          <text>"CESAREAN_SECTION"</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_004_3">
          <text>"NONE","MINOR"</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_004_4">
          <text>&lt;= 4</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_004_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_drg_004_1">
          <text>"DRG-371"</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_004_2">
          <text>1.25</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_004_3">
          <text>3</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_004_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 5: Pneumonia com complicações maiores -->
      <rule id="rule_drg_005">
        <inputEntry id="inputEntry_drg_005_1">
          <text>starts with(primaryDiagnosis, "J1")</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_005_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_005_3">
          <text>"MAJOR","CATASTROPHIC"</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_005_4">
          <text>&gt; 8</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_005_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_drg_005_1">
          <text>"DRG-089-MC"</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_005_2">
          <text>2.15</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_005_3">
          <text>6</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_005_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Regra 6: Pneumonia sem complicações -->
      <rule id="rule_drg_006">
        <inputEntry id="inputEntry_drg_006_1">
          <text>starts with(primaryDiagnosis, "J1")</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_006_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_006_3">
          <text>"NONE","MINOR"</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_006_4">
          <text>&lt;= 8</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_006_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_drg_006_1">
          <text>"DRG-090"</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_006_2">
          <text>1.45</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_006_3">
          <text>5</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_006_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 7: Artroplastia de quadril/joelho -->
      <rule id="rule_drg_007">
        <inputEntry id="inputEntry_drg_007_1">
          <text>starts with(primaryDiagnosis, "M")</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_007_2">
          <text>"HIP_REPLACEMENT","KNEE_REPLACEMENT"</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_007_3">
          <text>"NONE","MINOR"</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_007_4">
          <text>&gt; 5 and &lt;= 10</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_007_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_drg_007_1">
          <text>"DRG-470"</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_007_2">
          <text>3.25</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_007_3">
          <text>8</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_007_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 8: AVC com complicações -->
      <rule id="rule_drg_008">
        <inputEntry id="inputEntry_drg_008_1">
          <text>starts with(primaryDiagnosis, "I6")</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_008_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_008_3">
          <text>"MAJOR","CATASTROPHIC"</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_008_4">
          <text>&gt; 12</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_008_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_drg_008_1">
          <text>"DRG-064-MC"</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_008_2">
          <text>2.85</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_008_3">
          <text>10</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_008_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Regra 9: Diabetes com complicações -->
      <rule id="rule_drg_009">
        <inputEntry id="inputEntry_drg_009_1">
          <text>starts with(primaryDiagnosis, "E1")</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_009_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_009_3">
          <text>"MAJOR"</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_009_4">
          <text>&gt; 5</text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_009_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_drg_009_1">
          <text>"DRG-637-MC"</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_009_2">
          <text>1.65</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_009_3">
          <text>4</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_009_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Regra 10: Fallback - DRG genérico para casos não classificados -->
      <rule id="rule_drg_010">
        <inputEntry id="inputEntry_drg_010_1">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_010_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_010_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_010_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_drg_010_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_drg_010_1">
          <text>"DRG-999"</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_010_2">
          <text>1.00</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_010_3">
          <text>5</text>
        </outputEntry>
        <outputEntry id="outputEntry_drg_010_4">
          <text>false</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DRG_Assignment">
      <dmndi:DMNShape id="DMNShape_drg_assignment_decision" dmnElementRef="drg_assignment_decision">
        <dc:Bounds height="80" width="180" x="100" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
