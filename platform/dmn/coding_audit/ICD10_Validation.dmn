<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="ICD10_Validation_DMN"
             name="ICD10 Validation Decision"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="icd10_validation_decision" name="Validação de Código ICD-10">
    <decisionTable id="icd10_validation_table" hitPolicy="FIRST">
      <input id="input_icdCode" label="Código ICD-10" camunda:inputVariable="icdCode">
        <inputExpression id="inputExpr_icdCode" typeRef="string">
          <text>icdCode</text>
        </inputExpression>
      </input>
      <input id="input_encounterType" label="Tipo de Atendimento" camunda:inputVariable="encounterType">
        <inputExpression id="inputExpr_encounterType" typeRef="string">
          <text>encounterType</text>
        </inputExpression>
        <inputValues id="inputValues_encounterType">
          <text>"INPATIENT","OUTPATIENT","EMERGENCY"</text>
        </inputValues>
      </input>
      <input id="input_diagnosisPosition" label="Posição do Diagnóstico" camunda:inputVariable="diagnosisPosition">
        <inputExpression id="inputExpr_diagnosisPosition" typeRef="string">
          <text>diagnosisPosition</text>
        </inputExpression>
        <inputValues id="inputValues_diagnosisPosition">
          <text>"PRIMARY","SECONDARY","COMPLICATION"</text>
        </inputValues>
      </input>
      <input id="input_patientAgeGroup" label="Faixa Etária" camunda:inputVariable="patientAgeGroup">
        <inputExpression id="inputExpr_patientAgeGroup" typeRef="string">
          <text>patientAgeGroup</text>
        </inputExpression>
        <inputValues id="inputValues_patientAgeGroup">
          <text>"NEONATAL","PEDIATRIC","ADULT","GERIATRIC"</text>
        </inputValues>
      </input>
      <input id="input_tenantId" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="inputExpr_tenantId" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="output_isValid" label="Código Válido" name="isValid" typeRef="boolean" />
      <output id="output_validationMessage" label="Mensagem de Validação" name="validationMessage" typeRef="string" />
      <output id="output_suggestedCode" label="Código Sugerido" name="suggestedCode" typeRef="string" />
      <output id="output_requiresReview" label="Requer Revisão" name="requiresReview" typeRef="boolean" />

      <!-- Regra 1: Código vazio ou nulo -->
      <rule id="rule_icd10_001">
        <inputEntry id="inputEntry_icd10_001_1">
          <text>icdCode == null or icdCode == ""</text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_001_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_001_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_001_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_001_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_icd10_001_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_001_2">
          <text>"Código ICD-10 não informado"</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_001_3">
          <text>null</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_001_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Regra 2: Código neonatal fora da faixa etária -->
      <rule id="rule_icd10_002">
        <inputEntry id="inputEntry_icd10_002_1">
          <text>starts with(icdCode, "P")</text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_002_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_002_3">
          <text>"PRIMARY"</text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_002_4">
          <text>not("NEONATAL")</text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_002_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_icd10_002_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_002_2">
          <text>"Código neonatal (P) utilizado para faixa etária incompatível"</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_002_3">
          <text>null</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_002_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Regra 3: Diagnóstico primário em emergência com código Z -->
      <rule id="rule_icd10_003">
        <inputEntry id="inputEntry_icd10_003_1">
          <text>starts with(icdCode, "Z")</text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_003_2">
          <text>"EMERGENCY"</text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_003_3">
          <text>"PRIMARY"</text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_003_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_003_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_icd10_003_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_003_2">
          <text>"Código Z (fatores que influenciam saúde) não permitido como diagnóstico primário em emergência"</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_003_3">
          <text>null</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_003_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Regra 4: Código externo de causa (V, W, X, Y) como diagnóstico primário -->
      <rule id="rule_icd10_004">
        <inputEntry id="inputEntry_icd10_004_1">
          <text>starts with(icdCode, "V") or starts with(icdCode, "W") or starts with(icdCode, "X") or starts with(icdCode, "Y")</text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_004_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_004_3">
          <text>"PRIMARY"</text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_004_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_004_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_icd10_004_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_004_2">
          <text>"Código de causa externa não pode ser diagnóstico primário - use código de natureza da lesão (S ou T)"</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_004_3">
          <text>null</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_004_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Regra 5: Código de internação válido (A-N capítulos principais) -->
      <rule id="rule_icd10_005">
        <inputEntry id="inputEntry_icd10_005_1">
          <text>matches(icdCode, "^[A-N][0-9]{2}(\\.[0-9]{1,2})?$")</text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_005_2">
          <text>"INPATIENT"</text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_005_3">
          <text>"PRIMARY"</text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_005_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_005_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_icd10_005_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_005_2">
          <text>"Código ICD-10 válido para internação"</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_005_3">
          <text>null</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_005_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 6: Código de trauma/lesão válido como diagnóstico primário -->
      <rule id="rule_icd10_006">
        <inputEntry id="inputEntry_icd10_006_1">
          <text>matches(icdCode, "^[ST][0-9]{2}(\\.[0-9]{1,2})?$")</text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_006_2">
          <text>"EMERGENCY"</text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_006_3">
          <text>"PRIMARY"</text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_006_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_006_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_icd10_006_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_006_2">
          <text>"Código de trauma/lesão válido para atendimento de emergência"</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_006_3">
          <text>null</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_006_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 7: Diagnóstico secundário ou complicação - qualquer código válido -->
      <rule id="rule_icd10_007">
        <inputEntry id="inputEntry_icd10_007_1">
          <text>matches(icdCode, "^[A-Z][0-9]{2}(\\.[0-9]{1,2})?$")</text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_007_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_007_3">
          <text>"SECONDARY","COMPLICATION"</text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_007_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_007_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_icd10_007_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_007_2">
          <text>"Código ICD-10 válido como diagnóstico secundário/complicação"</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_007_3">
          <text>null</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_007_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 8: Código ambulatorial válido (todos os capítulos) -->
      <rule id="rule_icd10_008">
        <inputEntry id="inputEntry_icd10_008_1">
          <text>matches(icdCode, "^[A-Z][0-9]{2}(\\.[0-9]{1,2})?$")</text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_008_2">
          <text>"OUTPATIENT"</text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_008_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_008_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_008_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_icd10_008_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_008_2">
          <text>"Código ICD-10 válido para atendimento ambulatorial"</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_008_3">
          <text>null</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_008_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 9: Código com formato incorreto -->
      <rule id="rule_icd10_009">
        <inputEntry id="inputEntry_icd10_009_1">
          <text>not(matches(icdCode, "^[A-Z][0-9]{2}(\\.[0-9]{1,2})?$"))</text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_009_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_009_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_009_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_009_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_icd10_009_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_009_2">
          <text>"Formato de código ICD-10 inválido - esperado: letra + 2 dígitos + ponto + até 2 dígitos"</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_009_3">
          <text>null</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_009_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Regra 10: Fallback - código não classificado requer revisão -->
      <rule id="rule_icd10_010">
        <inputEntry id="inputEntry_icd10_010_1">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_010_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_010_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_010_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_icd10_010_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_icd10_010_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_010_2">
          <text>"Código requer validação adicional por auditor médico"</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_010_3">
          <text>null</text>
        </outputEntry>
        <outputEntry id="outputEntry_icd10_010_4">
          <text>true</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ICD10_Validation">
      <dmndi:DMNShape id="DMNShape_icd10_validation_decision" dmnElementRef="icd10_validation_decision">
        <dc:Bounds height="80" width="180" x="100" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
