<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Procedure_Compatibility_DMN"
             name="Procedure Compatibility Decision"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="procedure_compatibility_decision" name="Verificação de Compatibilidade de Procedimentos">
    <decisionTable id="procedure_compatibility_table" hitPolicy="FIRST">
      <input id="input_procedureCodeA" label="Código Procedimento A" camunda:inputVariable="procedureCodeA">
        <inputExpression id="inputExpr_procedureCodeA" typeRef="string">
          <text>procedureCodeA</text>
        </inputExpression>
      </input>
      <input id="input_procedureCodeB" label="Código Procedimento B" camunda:inputVariable="procedureCodeB">
        <inputExpression id="inputExpr_procedureCodeB" typeRef="string">
          <text>procedureCodeB</text>
        </inputExpression>
      </input>
      <input id="input_sameSession" label="Mesma Sessão" camunda:inputVariable="sameSession">
        <inputExpression id="inputExpr_sameSession" typeRef="boolean">
          <text>sameSession</text>
        </inputExpression>
      </input>
      <input id="input_sameAnatomicalSite" label="Mesmo Sítio Anatômico" camunda:inputVariable="sameAnatomicalSite">
        <inputExpression id="inputExpr_sameAnatomicalSite" typeRef="boolean">
          <text>sameAnatomicalSite</text>
        </inputExpression>
      </input>
      <input id="input_tenantId" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="inputExpr_tenantId" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="output_compatible" label="Procedimentos Compatíveis" name="compatible" typeRef="boolean" />
      <output id="output_incompatibilityReason" label="Razão da Incompatibilidade" name="incompatibilityReason" typeRef="string" />
      <output id="output_requiresJustification" label="Requer Justificativa" name="requiresJustification" typeRef="boolean" />
      <output id="output_bundleApplicable" label="Bundle Aplicável" name="bundleApplicable" typeRef="boolean" />

      <!-- Regra 1: Procedimentos idênticos na mesma sessão - possível duplicação -->
      <rule id="rule_compat_001">
        <inputEntry id="inputEntry_compat_001_1">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_001_2">
          <text>procedureCodeA</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_001_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_001_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_001_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_compat_001_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_001_2">
          <text>"Procedimentos idênticos na mesma sessão - possível duplicação"</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_001_3">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_001_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 2: Cirurgias bilaterais na mesma sessão - aplicar bundle -->
      <rule id="rule_compat_002">
        <inputEntry id="inputEntry_compat_002_1">
          <text>starts with(procedureCodeA, "313")</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_002_2">
          <text>procedureCodeA</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_002_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_002_4">
          <text>false</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_002_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_compat_002_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_002_2">
          <text>"Procedimentos bilaterais - aplicar fator de redução"</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_002_3">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_002_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Regra 3: Procedimento principal + auxiliar no mesmo sítio - bundle -->
      <rule id="rule_compat_003">
        <inputEntry id="inputEntry_compat_003_1">
          <text>starts with(procedureCodeA, "31")</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_003_2">
          <text>starts with(procedureCodeB, "31")</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_003_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_003_4">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_003_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_compat_003_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_003_2">
          <text>"Procedimentos no mesmo sítio - aplicar regra de múltiplos procedimentos"</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_003_3">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_003_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Regra 4: Cesariana + parto vaginal - mutuamente exclusivos -->
      <rule id="rule_compat_004">
        <inputEntry id="inputEntry_compat_004_1">
          <text>"31309166"</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_004_2">
          <text>"31309158"</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_004_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_004_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_004_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_compat_004_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_004_2">
          <text>"Cesariana e parto vaginal são mutuamente exclusivos"</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_004_3">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_004_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 5: Procedimentos diagnósticos + cirúrgicos - compatíveis -->
      <rule id="rule_compat_005">
        <inputEntry id="inputEntry_compat_005_1">
          <text>starts with(procedureCodeA, "2")</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_005_2">
          <text>starts with(procedureCodeB, "3")</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_005_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_005_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_005_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_compat_005_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_005_2">
          <text>"Exame diagnóstico + procedimento cirúrgico - combinação válida"</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_005_3">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_005_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 6: Anestesia incompatível com sedação - mutuamente exclusivos -->
      <rule id="rule_compat_006">
        <inputEntry id="inputEntry_compat_006_1">
          <text>starts with(procedureCodeA, "32")</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_006_2">
          <text>starts with(procedureCodeB, "32")</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_006_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_006_4">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_006_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_compat_006_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_006_2">
          <text>"Dois procedimentos de anestesia/sedação no mesmo sítio são incompatíveis"</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_006_3">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_006_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 7: Procedimentos em sessões diferentes - sempre compatíveis -->
      <rule id="rule_compat_007">
        <inputEntry id="inputEntry_compat_007_1">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_007_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_007_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_007_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_007_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_compat_007_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_007_2">
          <text>"Procedimentos em sessões diferentes - sem restrições"</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_007_3">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_007_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 8: Múltiplos exames na mesma sessão - compatíveis se sítios diferentes -->
      <rule id="rule_compat_008">
        <inputEntry id="inputEntry_compat_008_1">
          <text>starts with(procedureCodeA, "2")</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_008_2">
          <text>starts with(procedureCodeB, "2")</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_008_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_008_4">
          <text>false</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_008_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_compat_008_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_008_2">
          <text>"Múltiplos exames diagnósticos em sítios diferentes - compatível"</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_008_3">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_008_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 9: Procedimentos em sítios anatômicos diferentes - compatíveis -->
      <rule id="rule_compat_009">
        <inputEntry id="inputEntry_compat_009_1">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_009_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_009_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_009_4">
          <text>false</text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_009_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_compat_009_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_009_2">
          <text>"Procedimentos em sítios anatômicos diferentes - compatível"</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_009_3">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_009_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 10: Fallback - compatível com justificativa -->
      <rule id="rule_compat_010">
        <inputEntry id="inputEntry_compat_010_1">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_010_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_010_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_010_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_compat_010_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_compat_010_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_010_2">
          <text>"Combinação requer validação por auditor médico"</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_010_3">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_compat_010_4">
          <text>false</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Procedure_Compatibility">
      <dmndi:DMNShape id="DMNShape_procedure_compatibility_decision" dmnElementRef="procedure_compatibility_decision">
        <dc:Bounds height="80" width="180" x="100" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
