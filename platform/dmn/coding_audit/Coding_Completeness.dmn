<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Coding_Completeness_DMN"
             name="Coding Completeness Decision"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="coding_completeness_decision" name="Verificação de Completude de Codificação">
    <decisionTable id="coding_completeness_table" hitPolicy="FIRST">
      <input id="input_hasPrimaryDiagnosis" label="Possui Diagnóstico Principal" camunda:inputVariable="hasPrimaryDiagnosis">
        <inputExpression id="inputExpr_hasPrimaryDiagnosis" typeRef="boolean">
          <text>hasPrimaryDiagnosis</text>
        </inputExpression>
      </input>
      <input id="input_hasProcedureCode" label="Possui Código de Procedimento" camunda:inputVariable="hasProcedureCode">
        <inputExpression id="inputExpr_hasProcedureCode" typeRef="boolean">
          <text>hasProcedureCode</text>
        </inputExpression>
      </input>
      <input id="input_hasPhysicianSignature" label="Possui Assinatura Médica" camunda:inputVariable="hasPhysicianSignature">
        <inputExpression id="inputExpr_hasPhysicianSignature" typeRef="boolean">
          <text>hasPhysicianSignature</text>
        </inputExpression>
      </input>
      <input id="input_documentationScore" label="Score de Documentação (0-100)" camunda:inputVariable="documentationScore">
        <inputExpression id="inputExpr_documentationScore" typeRef="integer">
          <text>documentationScore</text>
        </inputExpression>
      </input>
      <input id="input_encounterType" label="Tipo de Atendimento" camunda:inputVariable="encounterType">
        <inputExpression id="inputExpr_encounterType" typeRef="string">
          <text>encounterType</text>
        </inputExpression>
      </input>
      <input id="input_tenantId" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="inputExpr_tenantId" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="output_isComplete" label="Codificação Completa" name="isComplete" typeRef="boolean" />
      <output id="output_missingElements" label="Elementos Faltantes" name="missingElements" typeRef="string" />
      <output id="output_completenessScore" label="Score de Completude" name="completenessScore" typeRef="integer" />
      <output id="output_canSubmit" label="Pode Submeter" name="canSubmit" typeRef="boolean" />

      <!-- Regra 1: Sem diagnóstico principal - bloqueio crítico -->
      <rule id="rule_complete_001">
        <inputEntry id="inputEntry_complete_001_1">
          <text>false</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_001_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_001_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_001_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_001_5">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_001_6">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_complete_001_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_001_2">
          <text>"Diagnóstico principal ausente"</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_001_3">
          <text>0</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_001_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 2: Sem assinatura médica - bloqueio crítico -->
      <rule id="rule_complete_002">
        <inputEntry id="inputEntry_complete_002_1">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_002_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_002_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_002_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_002_5">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_002_6">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_complete_002_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_002_2">
          <text>"Assinatura médica ausente"</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_002_3">
          <text>15</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_002_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 3: Internação sem código de procedimento -->
      <rule id="rule_complete_003">
        <inputEntry id="inputEntry_complete_003_1">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_003_2">
          <text>false</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_003_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_003_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_003_5">
          <text>"INPATIENT"</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_003_6">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_complete_003_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_003_2">
          <text>"Código de procedimento ausente (obrigatório para internação)"</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_003_3">
          <text>40</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_003_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 4: Documentação muito baixa (score < 30) -->
      <rule id="rule_complete_004">
        <inputEntry id="inputEntry_complete_004_1">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_004_2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_004_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_004_4">
          <text>&lt; 30</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_004_5">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_004_6">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_complete_004_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_004_2">
          <text>"Documentação insuficiente (score muito baixo)"</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_004_3">
          <text>25</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_004_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 5: Documentação baixa (score 30-50) - permite submissão com alerta -->
      <rule id="rule_complete_005">
        <inputEntry id="inputEntry_complete_005_1">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_005_2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_005_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_005_4">
          <text>&gt;= 30 and &lt; 50</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_005_5">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_005_6">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_complete_005_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_005_2">
          <text>"Documentação pode ser melhorada"</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_005_3">
          <text>50</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_005_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Regra 6: Documentação regular (score 50-70) -->
      <rule id="rule_complete_006">
        <inputEntry id="inputEntry_complete_006_1">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_006_2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_006_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_006_4">
          <text>&gt;= 50 and &lt; 70</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_006_5">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_006_6">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_complete_006_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_006_2">
          <text>"Codificação regular - elementos principais presentes"</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_006_3">
          <text>70</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_006_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Regra 7: Documentação boa (score 70-85) -->
      <rule id="rule_complete_007">
        <inputEntry id="inputEntry_complete_007_1">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_007_2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_007_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_007_4">
          <text>&gt;= 70 and &lt; 85</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_007_5">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_007_6">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_complete_007_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_007_2">
          <text>"Codificação completa e bem documentada"</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_007_3">
          <text>85</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_007_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Regra 8: Documentação excelente (score >= 85) -->
      <rule id="rule_complete_008">
        <inputEntry id="inputEntry_complete_008_1">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_008_2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_008_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_008_4">
          <text>&gt;= 85</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_008_5">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_008_6">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_complete_008_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_008_2">
          <text>"Codificação excelente - documentação completa"</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_008_3">
          <text>100</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_008_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Regra 9: Ambulatório sem procedimento - permite se documentação boa -->
      <rule id="rule_complete_009">
        <inputEntry id="inputEntry_complete_009_1">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_009_2">
          <text>false</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_009_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_009_4">
          <text>&gt;= 60</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_009_5">
          <text>"OUTPATIENT"</text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_009_6">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_complete_009_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_009_2">
          <text>"Codificação ambulatorial completa (procedimento opcional)"</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_009_3">
          <text>75</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_009_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Regra 10: Fallback - bloqueio por segurança -->
      <rule id="rule_complete_010">
        <inputEntry id="inputEntry_complete_010_1">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_010_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_010_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_010_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_010_5">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_complete_010_6">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_complete_010_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_010_2">
          <text>"Codificação requer revisão adicional"</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_010_3">
          <text>20</text>
        </outputEntry>
        <outputEntry id="outputEntry_complete_010_4">
          <text>false</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Coding_Completeness">
      <dmndi:DMNShape id="DMNShape_coding_completeness_decision" dmnElementRef="coding_completeness_decision">
        <dc:Bounds height="80" width="180" x="100" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
