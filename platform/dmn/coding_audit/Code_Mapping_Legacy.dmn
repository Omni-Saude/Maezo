<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Code_Mapping_Legacy_DMN"
             name="Code Mapping Legacy Decision"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="code_mapping_legacy_decision" name="Mapeamento de Código Legado">
    <decisionTable id="code_mapping_legacy_table" hitPolicy="FIRST">
      <input id="input_legacyCode" label="Código Legado" camunda:inputVariable="legacyCode">
        <inputExpression id="inputExpr_legacyCode" typeRef="string">
          <text>legacyCode</text>
        </inputExpression>
      </input>
      <input id="input_sourceSystem" label="Sistema de Origem" camunda:inputVariable="sourceSystem">
        <inputExpression id="inputExpr_sourceSystem" typeRef="string">
          <text>sourceSystem</text>
        </inputExpression>
        <inputValues id="inputValues_sourceSystem">
          <text>"TASY","MV","SOUL","CUSTOM"</text>
        </inputValues>
      </input>
      <input id="input_codeType" label="Tipo de Código" camunda:inputVariable="codeType">
        <inputExpression id="inputExpr_codeType" typeRef="string">
          <text>codeType</text>
        </inputExpression>
        <inputValues id="inputValues_codeType">
          <text>"PROCEDURE","DIAGNOSIS","MATERIAL"</text>
        </inputValues>
      </input>
      <input id="input_tenantId" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="inputExpr_tenantId" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="output_standardCode" label="Código Padrão" name="standardCode" typeRef="string" />
      <output id="output_codeSystem" label="Sistema de Código" name="codeSystem" typeRef="string">
        <outputValues id="outputValues_codeSystem">
          <text>"ICD10","CBHPM","TUSS","SIMPRO"</text>
        </outputValues>
      </output>
      <output id="output_confidenceScore" label="Score de Confiança (0-100)" name="confidenceScore" typeRef="integer" />
      <output id="output_manualReviewRequired" label="Requer Revisão Manual" name="manualReviewRequired" typeRef="boolean" />

      <!-- Regra 1: TASY - Procedimento cirúrgico cardíaco -->
      <rule id="rule_legacy_001">
        <inputEntry id="inputEntry_legacy_001_1">
          <text>"TASY_CARD_001","TASY_CARD_002"</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_001_2">
          <text>"TASY"</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_001_3">
          <text>"PROCEDURE"</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_001_4">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_legacy_001_1">
          <text>"31101014"</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_001_2">
          <text>"CBHPM"</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_001_3">
          <text>95</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_001_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 2: MV - Diagnóstico de pneumonia -->
      <rule id="rule_legacy_002">
        <inputEntry id="inputEntry_legacy_002_1">
          <text>"MV_DIAG_485","MV_DIAG_486"</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_002_2">
          <text>"MV"</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_002_3">
          <text>"DIAGNOSIS"</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_002_4">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_legacy_002_1">
          <text>"J18.9"</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_002_2">
          <text>"ICD10"</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_002_3">
          <text>90</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_002_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 3: SOUL - Material OPME -->
      <rule id="rule_legacy_003">
        <inputEntry id="inputEntry_legacy_003_1">
          <text>starts with(legacyCode, "SOUL_MAT")</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_003_2">
          <text>"SOUL"</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_003_3">
          <text>"MATERIAL"</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_003_4">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_legacy_003_1">
          <text>"80000000"</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_003_2">
          <text>"TUSS"</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_003_3">
          <text>85</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_003_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 4: CUSTOM - Procedimento customizado requer mapeamento manual -->
      <rule id="rule_legacy_004">
        <inputEntry id="inputEntry_legacy_004_1">
          <text>starts with(legacyCode, "CUSTOM")</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_004_2">
          <text>"CUSTOM"</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_004_3">
          <text>"PROCEDURE"</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_004_4">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_legacy_004_1">
          <text>"99999999"</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_004_2">
          <text>"TUSS"</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_004_3">
          <text>50</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_004_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Regra 5: TASY - Cesariana -->
      <rule id="rule_legacy_005">
        <inputEntry id="inputEntry_legacy_005_1">
          <text>"TASY_OBS_CESAR"</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_005_2">
          <text>"TASY"</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_005_3">
          <text>"PROCEDURE"</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_005_4">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_legacy_005_1">
          <text>"31309166"</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_005_2">
          <text>"CBHPM"</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_005_3">
          <text>98</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_005_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 6: MV - Diagnóstico cardíaco -->
      <rule id="rule_legacy_006">
        <inputEntry id="inputEntry_legacy_006_1">
          <text>starts with(legacyCode, "MV_CARD")</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_006_2">
          <text>"MV"</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_006_3">
          <text>"DIAGNOSIS"</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_006_4">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_legacy_006_1">
          <text>"I21.9"</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_006_2">
          <text>"ICD10"</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_006_3">
          <text>88</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_006_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 7: SOUL - Procedimento ortopédico -->
      <rule id="rule_legacy_007">
        <inputEntry id="inputEntry_legacy_007_1">
          <text>starts with(legacyCode, "SOUL_ORTHO")</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_007_2">
          <text>"SOUL"</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_007_3">
          <text>"PROCEDURE"</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_007_4">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_legacy_007_1">
          <text>"31312110"</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_007_2">
          <text>"CBHPM"</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_007_3">
          <text>92</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_007_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 8: TASY - Material genérico -->
      <rule id="rule_legacy_008">
        <inputEntry id="inputEntry_legacy_008_1">
          <text>starts with(legacyCode, "TASY_MAT")</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_008_2">
          <text>"TASY"</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_008_3">
          <text>"MATERIAL"</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_008_4">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_legacy_008_1">
          <text>legacyCode</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_008_2">
          <text>"SIMPRO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_008_3">
          <text>70</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_008_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Regra 9: MV - Procedimento ambulatorial -->
      <rule id="rule_legacy_009">
        <inputEntry id="inputEntry_legacy_009_1">
          <text>starts with(legacyCode, "MV_AMB")</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_009_2">
          <text>"MV"</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_009_3">
          <text>"PROCEDURE"</text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_009_4">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_legacy_009_1">
          <text>"10101012"</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_009_2">
          <text>"TUSS"</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_009_3">
          <text>80</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_009_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra 10: Fallback - código legado não mapeado -->
      <rule id="rule_legacy_010">
        <inputEntry id="inputEntry_legacy_010_1">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_010_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_010_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_legacy_010_4">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_legacy_010_1">
          <text>legacyCode</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_010_2">
          <text>"TUSS"</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_010_3">
          <text>30</text>
        </outputEntry>
        <outputEntry id="outputEntry_legacy_010_4">
          <text>true</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Code_Mapping_Legacy">
      <dmndi:DMNShape id="DMNShape_code_mapping_legacy_decision" dmnElementRef="code_mapping_legacy_decision">
        <dc:Bounds height="80" width="180" x="100" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
