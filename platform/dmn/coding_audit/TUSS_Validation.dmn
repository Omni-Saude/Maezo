<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="TUSS_Validation_DMN"
             name="TUSS Validation Decision"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="tuss_validation_decision" name="Validação de Código TUSS">
    <decisionTable id="tuss_validation_table" hitPolicy="FIRST">
      <input id="input_tussCode" label="Código TUSS" camunda:inputVariable="tussCode">
        <inputExpression id="inputExpr_tussCode" typeRef="string">
          <text>tussCode</text>
        </inputExpression>
      </input>
      <input id="input_procedureCategory" label="Categoria do Procedimento" camunda:inputVariable="procedureCategory">
        <inputExpression id="inputExpr_procedureCategory" typeRef="string">
          <text>procedureCategory</text>
        </inputExpression>
      </input>
      <input id="input_isActive" label="Código Ativo" camunda:inputVariable="isActive">
        <inputExpression id="inputExpr_isActive" typeRef="boolean">
          <text>isActive</text>
        </inputExpression>
      </input>
      <input id="input_tenantId" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="inputExpr_tenantId" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="output_isValid" label="Código Válido" name="isValid" typeRef="boolean" />
      <output id="output_description" label="Descrição" name="description" typeRef="string" />
      <output id="output_requiresAuth" label="Requer Autorização" name="requiresAuth" typeRef="boolean" />
      <output id="output_category" label="Categoria" name="category" typeRef="string" />

      <!-- Regra 1: Código vazio ou nulo -->
      <rule id="rule_tuss_001">
        <inputEntry id="inputEntry_tuss_001_1">
          <text>tussCode == null or tussCode == ""</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_001_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_001_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_001_4">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_tuss_001_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_001_2">
          <text>"Código TUSS não informado"</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_001_3">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_001_4">
          <text>"ERRO"</text>
        </outputEntry>
      </rule>

      <!-- Regra 2: Código inativo -->
      <rule id="rule_tuss_002">
        <inputEntry id="inputEntry_tuss_002_1">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_002_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_002_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_002_4">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_tuss_002_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_002_2">
          <text>"Código TUSS inativo ou descontinuado"</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_002_3">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_002_4">
          <text>"INATIVO"</text>
        </outputEntry>
      </rule>

      <!-- Regra 3: Procedimentos cirúrgicos (categoria 3) -->
      <rule id="rule_tuss_003">
        <inputEntry id="inputEntry_tuss_003_1">
          <text>starts with(tussCode, "3")</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_003_2">
          <text>"CIRURGIA"</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_003_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_003_4">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_tuss_003_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_003_2">
          <text>"Procedimento cirúrgico válido - TUSS categoria 3"</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_003_3">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_003_4">
          <text>"CIRURGIA"</text>
        </outputEntry>
      </rule>

      <!-- Regra 4: Consultas médicas (categoria 1) -->
      <rule id="rule_tuss_004">
        <inputEntry id="inputEntry_tuss_004_1">
          <text>starts with(tussCode, "10101") or starts with(tussCode, "10102")</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_004_2">
          <text>"CONSULTA"</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_004_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_004_4">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_tuss_004_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_004_2">
          <text>"Consulta médica válida - TUSS categoria 1"</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_004_3">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_004_4">
          <text>"CONSULTA"</text>
        </outputEntry>
      </rule>

      <!-- Regra 5: Exames diagnósticos (categoria 2) -->
      <rule id="rule_tuss_005">
        <inputEntry id="inputEntry_tuss_005_1">
          <text>starts with(tussCode, "2")</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_005_2">
          <text>"EXAME"</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_005_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_005_4">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_tuss_005_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_005_2">
          <text>"Exame diagnóstico válido - TUSS categoria 2"</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_005_3">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_005_4">
          <text>"EXAME"</text>
        </outputEntry>
      </rule>

      <!-- Regra 6: OPME (categoria 8) - sempre requer autorização -->
      <rule id="rule_tuss_006">
        <inputEntry id="inputEntry_tuss_006_1">
          <text>starts with(tussCode, "8")</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_006_2">
          <text>"OPME"</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_006_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_006_4">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_tuss_006_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_006_2">
          <text>"OPME válido - TUSS categoria 8 (Materiais e Medicamentos)"</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_006_3">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_006_4">
          <text>"OPME"</text>
        </outputEntry>
      </rule>

      <!-- Regra 7: Diárias hospitalares (categoria 5) -->
      <rule id="rule_tuss_007">
        <inputEntry id="inputEntry_tuss_007_1">
          <text>starts with(tussCode, "5")</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_007_2">
          <text>"DIARIA"</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_007_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_007_4">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_tuss_007_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_007_2">
          <text>"Diária hospitalar válida - TUSS categoria 5"</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_007_3">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_007_4">
          <text>"DIARIA"</text>
        </outputEntry>
      </rule>

      <!-- Regra 8: Taxas hospitalares (categoria 6) -->
      <rule id="rule_tuss_008">
        <inputEntry id="inputEntry_tuss_008_1">
          <text>starts with(tussCode, "6")</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_008_2">
          <text>"TAXA"</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_008_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_008_4">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_tuss_008_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_008_2">
          <text>"Taxa hospitalar válida - TUSS categoria 6"</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_008_3">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_008_4">
          <text>"TAXA"</text>
        </outputEntry>
      </rule>

      <!-- Regra 9: Medicamentos (categoria 7) - requer autorização se alto custo -->
      <rule id="rule_tuss_009">
        <inputEntry id="inputEntry_tuss_009_1">
          <text>starts with(tussCode, "7")</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_009_2">
          <text>"MEDICAMENTO"</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_009_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_009_4">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_tuss_009_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_009_2">
          <text>"Medicamento válido - TUSS categoria 7"</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_009_3">
          <text>true</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_009_4">
          <text>"MEDICAMENTO"</text>
        </outputEntry>
      </rule>

      <!-- Regra 10: Fallback - código inválido ou não reconhecido -->
      <rule id="rule_tuss_010">
        <inputEntry id="inputEntry_tuss_010_1">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_010_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_010_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_tuss_010_4">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_tuss_010_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_010_2">
          <text>"Código TUSS não reconhecido ou inválido"</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_010_3">
          <text>false</text>
        </outputEntry>
        <outputEntry id="outputEntry_tuss_010_4">
          <text>"DESCONHECIDO"</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_TUSS_Validation">
      <dmndi:DMNShape id="DMNShape_tuss_validation_decision" dmnElementRef="tuss_validation_decision">
        <dc:Bounds height="80" width="180" x="100" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
