<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="CBHPM_Mapping_DMN"
             name="CBHPM Mapping Decision"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="cbhpm_mapping_decision" name="Mapeamento de Código CBHPM">
    <decisionTable id="cbhpm_mapping_table" hitPolicy="FIRST">
      <input id="input_procedureDescription" label="Descrição do Procedimento" camunda:inputVariable="procedureDescription">
        <inputExpression id="inputExpr_procedureDescription" typeRef="string">
          <text>procedureDescription</text>
        </inputExpression>
      </input>
      <input id="input_specialtyCode" label="Código da Especialidade" camunda:inputVariable="specialtyCode">
        <inputExpression id="inputExpr_specialtyCode" typeRef="string">
          <text>specialtyCode</text>
        </inputExpression>
      </input>
      <input id="input_portSize" label="Porte do Procedimento" camunda:inputVariable="portSize">
        <inputExpression id="inputExpr_portSize" typeRef="string">
          <text>portSize</text>
        </inputExpression>
        <inputValues id="inputValues_portSize">
          <text>"SMALL","MEDIUM","LARGE","EXTRA"</text>
        </inputValues>
      </input>
      <input id="input_anesthesiaRequired" label="Anestesia Requerida" camunda:inputVariable="anesthesiaRequired">
        <inputExpression id="inputExpr_anesthesiaRequired" typeRef="boolean">
          <text>anesthesiaRequired</text>
        </inputExpression>
      </input>
      <input id="input_tenantId" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="inputExpr_tenantId" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="output_cbhpmCode" label="Código CBHPM" name="cbhpmCode" typeRef="string" />
      <output id="output_portValue" label="Valor do Porte" name="portValue" typeRef="double" />
      <output id="output_auxiliaryFactor" label="Fator Auxiliar" name="auxiliaryFactor" typeRef="double" />
      <output id="output_anesthesiaFactor" label="Fator Anestesia" name="anesthesiaFactor" typeRef="double" />

      <!-- Regra 1: Cirurgia cardíaca de grande porte -->
      <rule id="rule_cbhpm_001">
        <inputEntry id="inputEntry_cbhpm_001_1">
          <text>contains(lower(procedureDescription), "revascularização") or contains(lower(procedureDescription), "coronária")</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_001_2">
          <text>"CARDIO"</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_001_3">
          <text>"EXTRA"</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_001_4">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_001_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_cbhpm_001_1">
          <text>"31101014"</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_001_2">
          <text>8.0</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_001_3">
          <text>0.30</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_001_4">
          <text>0.80</text>
        </outputEntry>
      </rule>

      <!-- Regra 2: Cesariana - porte médio -->
      <rule id="rule_cbhpm_002">
        <inputEntry id="inputEntry_cbhpm_002_1">
          <text>contains(lower(procedureDescription), "cesariana") or contains(lower(procedureDescription), "cesárea")</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_002_2">
          <text>"OBSTETRICIA"</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_002_3">
          <text>"MEDIUM"</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_002_4">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_002_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_cbhpm_002_1">
          <text>"31309166"</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_002_2">
          <text>4.5</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_002_3">
          <text>0.25</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_002_4">
          <text>0.40</text>
        </outputEntry>
      </rule>

      <!-- Regra 3: Artroscopia - porte médio sem anestesia geral -->
      <rule id="rule_cbhpm_003">
        <inputEntry id="inputEntry_cbhpm_003_1">
          <text>contains(lower(procedureDescription), "artroscopia")</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_003_2">
          <text>"ORTOPEDIA"</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_003_3">
          <text>"MEDIUM"</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_003_4">
          <text>false</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_003_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_cbhpm_003_1">
          <text>"31312187"</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_003_2">
          <text>3.5</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_003_3">
          <text>0.20</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_003_4">
          <text>0.0</text>
        </outputEntry>
      </rule>

      <!-- Regra 4: Colecistectomia laparoscópica - porte grande -->
      <rule id="rule_cbhpm_004">
        <inputEntry id="inputEntry_cbhpm_004_1">
          <text>contains(lower(procedureDescription), "colecistectomia") and contains(lower(procedureDescription), "laparoscópica")</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_004_2">
          <text>"CIRURGIA_GERAL"</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_004_3">
          <text>"LARGE"</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_004_4">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_004_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_cbhpm_004_1">
          <text>"31302912"</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_004_2">
          <text>6.0</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_004_3">
          <text>0.28</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_004_4">
          <text>0.60</text>
        </outputEntry>
      </rule>

      <!-- Regra 5: Colonoscopia - porte pequeno -->
      <rule id="rule_cbhpm_005">
        <inputEntry id="inputEntry_cbhpm_005_1">
          <text>contains(lower(procedureDescription), "colonoscopia")</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_005_2">
          <text>"GASTRO"</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_005_3">
          <text>"SMALL"</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_005_4">
          <text>false</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_005_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_cbhpm_005_1">
          <text>"31301102"</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_005_2">
          <text>1.8</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_005_3">
          <text>0.15</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_005_4">
          <text>0.0</text>
        </outputEntry>
      </rule>

      <!-- Regra 6: Cateterismo cardíaco - porte médio -->
      <rule id="rule_cbhpm_006">
        <inputEntry id="inputEntry_cbhpm_006_1">
          <text>contains(lower(procedureDescription), "cateterismo")</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_006_2">
          <text>"CARDIO"</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_006_3">
          <text>"MEDIUM"</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_006_4">
          <text>false</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_006_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_cbhpm_006_1">
          <text>"31101030"</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_006_2">
          <text>3.8</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_006_3">
          <text>0.22</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_006_4">
          <text>0.0</text>
        </outputEntry>
      </rule>

      <!-- Regra 7: Procedimentos neurológicos de porte especial -->
      <rule id="rule_cbhpm_007">
        <inputEntry id="inputEntry_cbhpm_007_1">
          <text>contains(lower(procedureDescription), "craniotomia") or contains(lower(procedureDescription), "tumor cerebral")</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_007_2">
          <text>"NEURO"</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_007_3">
          <text>"EXTRA"</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_007_4">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_007_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_cbhpm_007_1">
          <text>"31311091"</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_007_2">
          <text>9.0</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_007_3">
          <text>0.32</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_007_4">
          <text>0.85</text>
        </outputEntry>
      </rule>

      <!-- Regra 8: Procedimentos ortopédicos de porte grande -->
      <rule id="rule_cbhpm_008">
        <inputEntry id="inputEntry_cbhpm_008_1">
          <text>contains(lower(procedureDescription), "artroplastia") or contains(lower(procedureDescription), "prótese de quadril")</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_008_2">
          <text>"ORTOPEDIA"</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_008_3">
          <text>"LARGE"</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_008_4">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_008_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_cbhpm_008_1">
          <text>"31312110"</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_008_2">
          <text>7.5</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_008_3">
          <text>0.30</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_008_4">
          <text>0.70</text>
        </outputEntry>
      </rule>

      <!-- Regra 9: Porte pequeno com anestesia local -->
      <rule id="rule_cbhpm_009">
        <inputEntry id="inputEntry_cbhpm_009_1">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_009_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_009_3">
          <text>"SMALL"</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_009_4">
          <text>true</text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_009_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_cbhpm_009_1">
          <text>"00000000"</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_009_2">
          <text>1.5</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_009_3">
          <text>0.15</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_009_4">
          <text>0.10</text>
        </outputEntry>
      </rule>

      <!-- Regra 10: Fallback - mapeamento genérico baseado em porte -->
      <rule id="rule_cbhpm_010">
        <inputEntry id="inputEntry_cbhpm_010_1">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_010_2">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_010_3">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_010_4">
          <text></text>
        </inputEntry>
        <inputEntry id="inputEntry_cbhpm_010_5">
          <text></text>
        </inputEntry>
        <outputEntry id="outputEntry_cbhpm_010_1">
          <text>"99999999"</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_010_2">
          <text>2.0</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_010_3">
          <text>0.18</text>
        </outputEntry>
        <outputEntry id="outputEntry_cbhpm_010_4">
          <text>0.20</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_CBHPM_Mapping">
      <dmndi:DMNShape id="DMNShape_cbhpm_mapping_decision" dmnElementRef="cbhpm_mapping_decision">
        <dc:Bounds height="80" width="180" x="100" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
