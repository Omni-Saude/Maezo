<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:biodi="http://bpmn.io/schema/dmn/biodi/2.0"
             id="Copay_Calculation_Definitions"
             name="CIB7 Copay Calculation"
             namespace="http://cib7.healthcare.br/dmn/billing/copay"
             exporter="CIB7 Healthcare Orchestrator"
             exporterVersion="1.0">
  <decision id="copay_calculation" name="Cálculo de Coparticipação">
    <description>Calcula valores de coparticipação e coinsurance do paciente conforme tipo de plano, categoria de procedimento e se é atendimento de emergência. Inclui franquias anuais e isenções aplicáveis.</description>
    <decisionTable id="copay_calculation_table" hitPolicy="FIRST">
      <input id="input_copay_plan_type" label="Tipo de Plano" camunda:inputVariable="planType">
        <inputExpression id="input_copay_plan_type_exp" typeRef="string">
          <text>planType</text>
        </inputExpression>
      </input>
      <input id="input_procedure_category" label="Categoria do Procedimento" camunda:inputVariable="procedureCategory">
        <inputExpression id="input_procedure_category_exp" typeRef="string">
          <text>procedureCategory</text>
        </inputExpression>
        <inputValues id="input_procedure_category_values">
          <text>"CONSULTA","EXAME","INTERNACAO","CIRURGIA","TERAPIA"</text>
        </inputValues>
      </input>
      <input id="input_is_emergency" label="É Emergência" camunda:inputVariable="isEmergency">
        <inputExpression id="input_is_emergency_exp" typeRef="boolean">
          <text>isEmergency</text>
        </inputExpression>
      </input>
      <input id="input_copay_tenant_id" label="ID do Tenant" camunda:inputVariable="tenantId">
        <inputExpression id="input_copay_tenant_id_exp" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="output_copay_amount" label="Valor Coparticipação" name="copayAmount" typeRef="double"/>
      <output id="output_coinsurance_percent" label="Percentual Coinsurance" name="coinsurancePercent" typeRef="integer"/>
      <output id="output_annual_deductible" label="Franquia Anual" name="annualDeductible" typeRef="double"/>
      <output id="output_applies_waiver" label="Aplica Isenção" name="appliesWaiver" typeRef="boolean"/>

      <!-- Rule 1: Emergency - no copay regardless of plan -->
      <rule id="copay_rule_1">
        <inputEntry id="copay_rule_1_input_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="copay_rule_1_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="copay_rule_1_input_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="copay_rule_1_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="copay_rule_1_output_1">
          <text>0</text>
        </outputEntry>
        <outputEntry id="copay_rule_1_output_2">
          <text>0</text>
        </outputEntry>
        <outputEntry id="copay_rule_1_output_3">
          <text>0</text>
        </outputEntry>
        <outputEntry id="copay_rule_1_output_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: Premium plan - consultations -->
      <rule id="copay_rule_2">
        <inputEntry id="copay_rule_2_input_1">
          <text>"PREMIUM","EXECUTIVO","TOP"</text>
        </inputEntry>
        <inputEntry id="copay_rule_2_input_2">
          <text>"CONSULTA"</text>
        </inputEntry>
        <inputEntry id="copay_rule_2_input_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="copay_rule_2_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="copay_rule_2_output_1">
          <text>50</text>
        </outputEntry>
        <outputEntry id="copay_rule_2_output_2">
          <text>0</text>
        </outputEntry>
        <outputEntry id="copay_rule_2_output_3">
          <text>0</text>
        </outputEntry>
        <outputEntry id="copay_rule_2_output_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 3: Standard plan - consultations -->
      <rule id="copay_rule_3">
        <inputEntry id="copay_rule_3_input_1">
          <text>"STANDARD","BASICO","CLASSICO"</text>
        </inputEntry>
        <inputEntry id="copay_rule_3_input_2">
          <text>"CONSULTA"</text>
        </inputEntry>
        <inputEntry id="copay_rule_3_input_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="copay_rule_3_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="copay_rule_3_output_1">
          <text>80</text>
        </outputEntry>
        <outputEntry id="copay_rule_3_output_2">
          <text>0</text>
        </outputEntry>
        <outputEntry id="copay_rule_3_output_3">
          <text>500</text>
        </outputEntry>
        <outputEntry id="copay_rule_3_output_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 4: Any plan - diagnostic exams -->
      <rule id="copay_rule_4">
        <inputEntry id="copay_rule_4_input_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="copay_rule_4_input_2">
          <text>"EXAME"</text>
        </inputEntry>
        <inputEntry id="copay_rule_4_input_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="copay_rule_4_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="copay_rule_4_output_1">
          <text>0</text>
        </outputEntry>
        <outputEntry id="copay_rule_4_output_2">
          <text>15</text>
        </outputEntry>
        <outputEntry id="copay_rule_4_output_3">
          <text>0</text>
        </outputEntry>
        <outputEntry id="copay_rule_4_output_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 5: Premium plan - surgeries (no copay) -->
      <rule id="copay_rule_5">
        <inputEntry id="copay_rule_5_input_1">
          <text>"PREMIUM","EXECUTIVO","TOP"</text>
        </inputEntry>
        <inputEntry id="copay_rule_5_input_2">
          <text>"CIRURGIA"</text>
        </inputEntry>
        <inputEntry id="copay_rule_5_input_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="copay_rule_5_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="copay_rule_5_output_1">
          <text>0</text>
        </outputEntry>
        <outputEntry id="copay_rule_5_output_2">
          <text>0</text>
        </outputEntry>
        <outputEntry id="copay_rule_5_output_3">
          <text>0</text>
        </outputEntry>
        <outputEntry id="copay_rule_5_output_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Rule 6: Standard plan - surgeries (coinsurance) -->
      <rule id="copay_rule_6">
        <inputEntry id="copay_rule_6_input_1">
          <text>"STANDARD","BASICO","CLASSICO"</text>
        </inputEntry>
        <inputEntry id="copay_rule_6_input_2">
          <text>"CIRURGIA"</text>
        </inputEntry>
        <inputEntry id="copay_rule_6_input_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="copay_rule_6_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="copay_rule_6_output_1">
          <text>0</text>
        </outputEntry>
        <outputEntry id="copay_rule_6_output_2">
          <text>20</text>
        </outputEntry>
        <outputEntry id="copay_rule_6_output_3">
          <text>2000</text>
        </outputEntry>
        <outputEntry id="copay_rule_6_output_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 7: Hospitalization - standard coinsurance -->
      <rule id="copay_rule_7">
        <inputEntry id="copay_rule_7_input_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="copay_rule_7_input_2">
          <text>"INTERNACAO"</text>
        </inputEntry>
        <inputEntry id="copay_rule_7_input_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="copay_rule_7_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="copay_rule_7_output_1">
          <text>150</text>
        </outputEntry>
        <outputEntry id="copay_rule_7_output_2">
          <text>10</text>
        </outputEntry>
        <outputEntry id="copay_rule_7_output_3">
          <text>1500</text>
        </outputEntry>
        <outputEntry id="copay_rule_7_output_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 8: Therapies - fixed copay -->
      <rule id="copay_rule_8">
        <inputEntry id="copay_rule_8_input_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="copay_rule_8_input_2">
          <text>"TERAPIA"</text>
        </inputEntry>
        <inputEntry id="copay_rule_8_input_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="copay_rule_8_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="copay_rule_8_output_1">
          <text>35</text>
        </outputEntry>
        <outputEntry id="copay_rule_8_output_2">
          <text>0</text>
        </outputEntry>
        <outputEntry id="copay_rule_8_output_3">
          <text>300</text>
        </outputEntry>
        <outputEntry id="copay_rule_8_output_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 9: Default fallback -->
      <rule id="copay_rule_9">
        <inputEntry id="copay_rule_9_input_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="copay_rule_9_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="copay_rule_9_input_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="copay_rule_9_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="copay_rule_9_output_1">
          <text>60</text>
        </outputEntry>
        <outputEntry id="copay_rule_9_output_2">
          <text>10</text>
        </outputEntry>
        <outputEntry id="copay_rule_9_output_3">
          <text>1000</text>
        </outputEntry>
        <outputEntry id="copay_rule_9_output_4">
          <text>false</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
