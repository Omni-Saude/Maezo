<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:biodi="http://bpmn.io/schema/dmn/biodi/2.0"
             id="Billing_Deadline_Definitions"
             name="CIB7 Billing Deadline"
             namespace="http://cib7.healthcare.br/dmn/billing/deadline"
             exporter="CIB7 Healthcare Orchestrator"
             exporterVersion="1.0">
  <decision id="billing_deadline" name="Prazo de Faturamento">
    <description>Define prazos para submissão de contas médicas conforme tipo de atendimento e operadora. Calcula se está atrasado, aplica penalidades e define urgência de submissão.</description>
    <decisionTable id="billing_deadline_table" hitPolicy="FIRST">
      <input id="input_encounter_type" label="Tipo de Atendimento" camunda:inputVariable="encounterType">
        <inputExpression id="input_encounter_type_exp" typeRef="string">
          <text>encounterType</text>
        </inputExpression>
        <inputValues id="input_encounter_type_values">
          <text>"INPATIENT","OUTPATIENT","EMERGENCY","DAY_SURGERY"</text>
        </inputValues>
      </input>
      <input id="input_insurer_type" label="Tipo de Operadora" camunda:inputVariable="insurerType">
        <inputExpression id="input_insurer_type_exp" typeRef="string">
          <text>insurerType</text>
        </inputExpression>
      </input>
      <input id="input_days_since_discharge" label="Dias desde Alta" camunda:inputVariable="daysSinceDischarge">
        <inputExpression id="input_days_since_discharge_exp" typeRef="integer">
          <text>daysSinceDischarge</text>
        </inputExpression>
      </input>
      <input id="input_deadline_tenant_id" label="ID do Tenant" camunda:inputVariable="tenantId">
        <inputExpression id="input_deadline_tenant_id_exp" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="output_deadline_days" label="Prazo em Dias" name="deadlineDays" typeRef="integer"/>
      <output id="output_is_late" label="Está Atrasado" name="isLate" typeRef="boolean"/>
      <output id="output_penalty_percent" label="Percentual de Penalidade" name="penaltyPercent" typeRef="double"/>
      <output id="output_urgency_level" label="Nível de Urgência" name="urgencyLevel" typeRef="string"/>

      <!-- Rule 1: Inpatient - within deadline -->
      <rule id="deadline_rule_1">
        <inputEntry id="deadline_rule_1_input_1">
          <text>"INPATIENT"</text>
        </inputEntry>
        <inputEntry id="deadline_rule_1_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="deadline_rule_1_input_3">
          <text>[0..15]</text>
        </inputEntry>
        <inputEntry id="deadline_rule_1_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="deadline_rule_1_output_1">
          <text>30</text>
        </outputEntry>
        <outputEntry id="deadline_rule_1_output_2">
          <text>false</text>
        </outputEntry>
        <outputEntry id="deadline_rule_1_output_3">
          <text>0</text>
        </outputEntry>
        <outputEntry id="deadline_rule_1_output_4">
          <text>"NORMAL"</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: Inpatient - approaching deadline -->
      <rule id="deadline_rule_2">
        <inputEntry id="deadline_rule_2_input_1">
          <text>"INPATIENT"</text>
        </inputEntry>
        <inputEntry id="deadline_rule_2_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="deadline_rule_2_input_3">
          <text>[16..25]</text>
        </inputEntry>
        <inputEntry id="deadline_rule_2_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="deadline_rule_2_output_1">
          <text>30</text>
        </outputEntry>
        <outputEntry id="deadline_rule_2_output_2">
          <text>false</text>
        </outputEntry>
        <outputEntry id="deadline_rule_2_output_3">
          <text>0</text>
        </outputEntry>
        <outputEntry id="deadline_rule_2_output_4">
          <text>"HIGH"</text>
        </outputEntry>
      </rule>

      <!-- Rule 3: Inpatient - late with penalty -->
      <rule id="deadline_rule_3">
        <inputEntry id="deadline_rule_3_input_1">
          <text>"INPATIENT"</text>
        </inputEntry>
        <inputEntry id="deadline_rule_3_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="deadline_rule_3_input_3">
          <text>&gt; 30</text>
        </inputEntry>
        <inputEntry id="deadline_rule_3_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="deadline_rule_3_output_1">
          <text>30</text>
        </outputEntry>
        <outputEntry id="deadline_rule_3_output_2">
          <text>true</text>
        </outputEntry>
        <outputEntry id="deadline_rule_3_output_3">
          <text>5</text>
        </outputEntry>
        <outputEntry id="deadline_rule_3_output_4">
          <text>"CRITICAL"</text>
        </outputEntry>
      </rule>

      <!-- Rule 4: Outpatient - within deadline -->
      <rule id="deadline_rule_4">
        <inputEntry id="deadline_rule_4_input_1">
          <text>"OUTPATIENT"</text>
        </inputEntry>
        <inputEntry id="deadline_rule_4_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="deadline_rule_4_input_3">
          <text>[0..10]</text>
        </inputEntry>
        <inputEntry id="deadline_rule_4_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="deadline_rule_4_output_1">
          <text>15</text>
        </outputEntry>
        <outputEntry id="deadline_rule_4_output_2">
          <text>false</text>
        </outputEntry>
        <outputEntry id="deadline_rule_4_output_3">
          <text>0</text>
        </outputEntry>
        <outputEntry id="deadline_rule_4_output_4">
          <text>"NORMAL"</text>
        </outputEntry>
      </rule>

      <!-- Rule 5: Outpatient - late -->
      <rule id="deadline_rule_5">
        <inputEntry id="deadline_rule_5_input_1">
          <text>"OUTPATIENT"</text>
        </inputEntry>
        <inputEntry id="deadline_rule_5_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="deadline_rule_5_input_3">
          <text>&gt; 15</text>
        </inputEntry>
        <inputEntry id="deadline_rule_5_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="deadline_rule_5_output_1">
          <text>15</text>
        </outputEntry>
        <outputEntry id="deadline_rule_5_output_2">
          <text>true</text>
        </outputEntry>
        <outputEntry id="deadline_rule_5_output_3">
          <text>3</text>
        </outputEntry>
        <outputEntry id="deadline_rule_5_output_4">
          <text>"CRITICAL"</text>
        </outputEntry>
      </rule>

      <!-- Rule 6: Emergency - strict deadline -->
      <rule id="deadline_rule_6">
        <inputEntry id="deadline_rule_6_input_1">
          <text>"EMERGENCY"</text>
        </inputEntry>
        <inputEntry id="deadline_rule_6_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="deadline_rule_6_input_3">
          <text>[0..5]</text>
        </inputEntry>
        <inputEntry id="deadline_rule_6_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="deadline_rule_6_output_1">
          <text>7</text>
        </outputEntry>
        <outputEntry id="deadline_rule_6_output_2">
          <text>false</text>
        </outputEntry>
        <outputEntry id="deadline_rule_6_output_3">
          <text>0</text>
        </outputEntry>
        <outputEntry id="deadline_rule_6_output_4">
          <text>"HIGH"</text>
        </outputEntry>
      </rule>

      <!-- Rule 7: Emergency - late with heavy penalty -->
      <rule id="deadline_rule_7">
        <inputEntry id="deadline_rule_7_input_1">
          <text>"EMERGENCY"</text>
        </inputEntry>
        <inputEntry id="deadline_rule_7_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="deadline_rule_7_input_3">
          <text>&gt; 7</text>
        </inputEntry>
        <inputEntry id="deadline_rule_7_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="deadline_rule_7_output_1">
          <text>7</text>
        </outputEntry>
        <outputEntry id="deadline_rule_7_output_2">
          <text>true</text>
        </outputEntry>
        <outputEntry id="deadline_rule_7_output_3">
          <text>10</text>
        </outputEntry>
        <outputEntry id="deadline_rule_7_output_4">
          <text>"CRITICAL"</text>
        </outputEntry>
      </rule>

      <!-- Rule 8: Day surgery - expedited -->
      <rule id="deadline_rule_8">
        <inputEntry id="deadline_rule_8_input_1">
          <text>"DAY_SURGERY"</text>
        </inputEntry>
        <inputEntry id="deadline_rule_8_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="deadline_rule_8_input_3">
          <text>[0..10]</text>
        </inputEntry>
        <inputEntry id="deadline_rule_8_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="deadline_rule_8_output_1">
          <text>10</text>
        </outputEntry>
        <outputEntry id="deadline_rule_8_output_2">
          <text>false</text>
        </outputEntry>
        <outputEntry id="deadline_rule_8_output_3">
          <text>0</text>
        </outputEntry>
        <outputEntry id="deadline_rule_8_output_4">
          <text>"NORMAL"</text>
        </outputEntry>
      </rule>

      <!-- Rule 9: SUS - extended deadline -->
      <rule id="deadline_rule_9">
        <inputEntry id="deadline_rule_9_input_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="deadline_rule_9_input_2">
          <text>"SUS"</text>
        </inputEntry>
        <inputEntry id="deadline_rule_9_input_3">
          <text>[0..60]</text>
        </inputEntry>
        <inputEntry id="deadline_rule_9_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="deadline_rule_9_output_1">
          <text>90</text>
        </outputEntry>
        <outputEntry id="deadline_rule_9_output_2">
          <text>false</text>
        </outputEntry>
        <outputEntry id="deadline_rule_9_output_3">
          <text>0</text>
        </outputEntry>
        <outputEntry id="deadline_rule_9_output_4">
          <text>"NORMAL"</text>
        </outputEntry>
      </rule>

      <!-- Rule 10: Default fallback -->
      <rule id="deadline_rule_10">
        <inputEntry id="deadline_rule_10_input_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="deadline_rule_10_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="deadline_rule_10_input_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="deadline_rule_10_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="deadline_rule_10_output_1">
          <text>30</text>
        </outputEntry>
        <outputEntry id="deadline_rule_10_output_2">
          <text>false</text>
        </outputEntry>
        <outputEntry id="deadline_rule_10_output_3">
          <text>0</text>
        </outputEntry>
        <outputEntry id="deadline_rule_10_output_4">
          <text>"NORMAL"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
