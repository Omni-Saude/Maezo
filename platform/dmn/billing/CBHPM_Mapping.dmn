<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:biodi="http://bpmn.io/schema/dmn/biodi/2.0"
             id="CBHPM_Mapping_Definitions"
             name="CIB7 CBHPM Mapping"
             namespace="http://cib7.healthcare.br/dmn/billing/cbhpm"
             exporter="CIB7 Healthcare Orchestrator"
             exporterVersion="1.0">
  <decision id="cbhpm_mapping" name="Mapeamento CBHPM">
    <description>Mapeamento de honorários médicos conforme Classificação Brasileira Hierarquizada de Procedimentos Médicos (CBHPM). Calcula honorários principais, auxiliares e anestésicos baseado em porte cirúrgico.</description>
    <decisionTable id="cbhpm_mapping_table" hitPolicy="FIRST">
      <input id="input_cbhpm_code" label="Código CBHPM" camunda:inputVariable="cbhpmCode">
        <inputExpression id="input_cbhpm_code_exp" typeRef="string">
          <text>cbhpmCode</text>
        </inputExpression>
      </input>
      <input id="input_auxiliary_count" label="Número de Auxiliares" camunda:inputVariable="auxiliaryCount">
        <inputExpression id="input_auxiliary_count_exp" typeRef="integer">
          <text>auxiliaryCount</text>
        </inputExpression>
      </input>
      <input id="input_anesthesia_type" label="Tipo de Anestesia" camunda:inputVariable="anesthesiaType">
        <inputExpression id="input_anesthesia_type_exp" typeRef="string">
          <text>anesthesiaType</text>
        </inputExpression>
        <inputValues id="input_anesthesia_type_values">
          <text>"LOCAL","REGIONAL","GERAL","SEDACAO"</text>
        </inputValues>
      </input>
      <input id="input_cbhpm_tenant_id" label="ID do Tenant" camunda:inputVariable="tenantId">
        <inputExpression id="input_cbhpm_tenant_id_exp" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="output_honorary_value" label="Honorário Principal" name="honoraryValue" typeRef="double"/>
      <output id="output_auxiliary_value" label="Honorário Auxiliar" name="auxiliaryValue" typeRef="double"/>
      <output id="output_anesthesia_value" label="Honorário Anestesista" name="anesthesiaValue" typeRef="double"/>
      <output id="output_total_professional" label="Total Profissional" name="totalProfessional" typeRef="double"/>

      <!-- Rule 1: Large surgery (porte 4) with general anesthesia -->
      <rule id="cbhpm_rule_1">
        <inputEntry id="cbhpm_rule_1_input_1">
          <text>starts with(cbhpmCode, "31")</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_1_input_2">
          <text>[1..3]</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_1_input_3">
          <text>"GERAL"</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_1_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="cbhpm_rule_1_output_1">
          <text>8500</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_1_output_2">
          <text>auxiliaryCount * 2550</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_1_output_3">
          <text>5950</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_1_output_4">
          <text>8500 + (auxiliaryCount * 2550) + 5950</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: Medium surgery (porte 3) with regional anesthesia -->
      <rule id="cbhpm_rule_2">
        <inputEntry id="cbhpm_rule_2_input_1">
          <text>starts with(cbhpmCode, "30")</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_2_input_2">
          <text>[1..2]</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_2_input_3">
          <text>"REGIONAL"</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_2_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="cbhpm_rule_2_output_1">
          <text>5200</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_2_output_2">
          <text>auxiliaryCount * 1560</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_2_output_3">
          <text>3640</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_2_output_4">
          <text>5200 + (auxiliaryCount * 1560) + 3640</text>
        </outputEntry>
      </rule>

      <!-- Rule 3: Small surgery (porte 2) with local anesthesia -->
      <rule id="cbhpm_rule_3">
        <inputEntry id="cbhpm_rule_3_input_1">
          <text>starts with(cbhpmCode, "20")</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_3_input_2">
          <text>[0..1]</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_3_input_3">
          <text>"LOCAL"</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_3_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="cbhpm_rule_3_output_1">
          <text>2800</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_3_output_2">
          <text>auxiliaryCount * 840</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_3_output_3">
          <text>1260</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_3_output_4">
          <text>2800 + (auxiliaryCount * 840) + 1260</text>
        </outputEntry>
      </rule>

      <!-- Rule 4: Consultation or small procedure (porte 1) -->
      <rule id="cbhpm_rule_4">
        <inputEntry id="cbhpm_rule_4_input_1">
          <text>starts with(cbhpmCode, "10")</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_4_input_2">
          <text>0</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_4_input_3">
          <text>"LOCAL","SEDACAO"</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_4_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="cbhpm_rule_4_output_1">
          <text>450</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_4_output_2">
          <text>0</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_4_output_3">
          <text>200</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_4_output_4">
          <text>650</text>
        </outputEntry>
      </rule>

      <!-- Rule 5: Diagnostic procedures with sedation -->
      <rule id="cbhpm_rule_5">
        <inputEntry id="cbhpm_rule_5_input_1">
          <text>starts with(cbhpmCode, "40")</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_5_input_2">
          <text>0</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_5_input_3">
          <text>"SEDACAO"</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_5_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="cbhpm_rule_5_output_1">
          <text>1200</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_5_output_2">
          <text>0</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_5_output_3">
          <text>800</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_5_output_4">
          <text>2000</text>
        </outputEntry>
      </rule>

      <!-- Rule 6: Complex surgery with multiple auxiliaries -->
      <rule id="cbhpm_rule_6">
        <inputEntry id="cbhpm_rule_6_input_1">
          <text>starts with(cbhpmCode, "31")</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_6_input_2">
          <text>&gt; 3</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_6_input_3">
          <text>"GERAL"</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_6_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="cbhpm_rule_6_output_1">
          <text>12000</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_6_output_2">
          <text>auxiliaryCount * 3000</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_6_output_3">
          <text>8400</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_6_output_4">
          <text>12000 + (auxiliaryCount * 3000) + 8400</text>
        </outputEntry>
      </rule>

      <!-- Rule 7: Emergency procedures - premium rates -->
      <rule id="cbhpm_rule_7">
        <inputEntry id="cbhpm_rule_7_input_1">
          <text>contains(cbhpmCode, "EMERG")</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_7_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_7_input_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_7_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="cbhpm_rule_7_output_1">
          <text>7500</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_7_output_2">
          <text>auxiliaryCount * 2250</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_7_output_3">
          <text>5250</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_7_output_4">
          <text>7500 + (auxiliaryCount * 2250) + 5250</text>
        </outputEntry>
      </rule>

      <!-- Rule 8: Videosurgery - special rates -->
      <rule id="cbhpm_rule_8">
        <inputEntry id="cbhpm_rule_8_input_1">
          <text>contains(cbhpmCode, "VIDEO")</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_8_input_2">
          <text>[1..2]</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_8_input_3">
          <text>"GERAL"</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_8_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="cbhpm_rule_8_output_1">
          <text>9800</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_8_output_2">
          <text>auxiliaryCount * 2940</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_8_output_3">
          <text>6860</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_8_output_4">
          <text>9800 + (auxiliaryCount * 2940) + 6860</text>
        </outputEntry>
      </rule>

      <!-- Rule 9: Default fallback with standard rates -->
      <rule id="cbhpm_rule_9">
        <inputEntry id="cbhpm_rule_9_input_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_9_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_9_input_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="cbhpm_rule_9_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="cbhpm_rule_9_output_1">
          <text>3500</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_9_output_2">
          <text>auxiliaryCount * 1050</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_9_output_3">
          <text>2450</text>
        </outputEntry>
        <outputEntry id="cbhpm_rule_9_output_4">
          <text>3500 + (auxiliaryCount * 1050) + 2450</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
