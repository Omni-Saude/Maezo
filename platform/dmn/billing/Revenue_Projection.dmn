<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:biodi="http://bpmn.io/schema/dmn/biodi/2.0"
             id="Revenue_Projection_Definitions"
             name="CIB7 Revenue Projection"
             namespace="http://cib7.healthcare.br/dmn/billing/revenue"
             exporter="CIB7 Healthcare Orchestrator"
             exporterVersion="1.0">
  <decision id="revenue_projection" name="Projeção de Receita">
    <description>Projeta receita futura baseado em histórico, sazonalidade e taxa de ocupação. Fornece intervalos de confiança e fatores de ajuste para planejamento financeiro.</description>
    <decisionTable id="revenue_projection_table" hitPolicy="FIRST">
      <input id="input_historical_avg" label="Média Histórica" camunda:inputVariable="historicalAvg">
        <inputExpression id="input_historical_avg_exp" typeRef="double">
          <text>historicalAvg</text>
        </inputExpression>
      </input>
      <input id="input_seasonality" label="Sazonalidade" camunda:inputVariable="seasonality">
        <inputExpression id="input_seasonality_exp" typeRef="string">
          <text>seasonality</text>
        </inputExpression>
        <inputValues id="input_seasonality_values">
          <text>"HIGH","MEDIUM","LOW","HOLIDAY"</text>
        </inputValues>
      </input>
      <input id="input_occupancy_rate" label="Taxa de Ocupação (%)" camunda:inputVariable="occupancyRate">
        <inputExpression id="input_occupancy_rate_exp" typeRef="double">
          <text>occupancyRate</text>
        </inputExpression>
      </input>
      <input id="input_revenue_tenant_id" label="ID do Tenant" camunda:inputVariable="tenantId">
        <inputExpression id="input_revenue_tenant_id_exp" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="output_projected_revenue" label="Receita Projetada" name="projectedRevenue" typeRef="double"/>
      <output id="output_confidence_level" label="Nível de Confiança" name="confidenceLevel" typeRef="string"/>
      <output id="output_adjustment_factor" label="Fator de Ajuste" name="adjustmentFactor" typeRef="double"/>

      <!-- Rule 1: High season + high occupancy - optimistic projection -->
      <rule id="revenue_rule_1">
        <inputEntry id="revenue_rule_1_input_1">
          <text>&gt; 0</text>
        </inputEntry>
        <inputEntry id="revenue_rule_1_input_2">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="revenue_rule_1_input_3">
          <text>&gt;= 85</text>
        </inputEntry>
        <inputEntry id="revenue_rule_1_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="revenue_rule_1_output_1">
          <text>historicalAvg * 1.25</text>
        </outputEntry>
        <outputEntry id="revenue_rule_1_output_2">
          <text>"HIGH_90PCT"</text>
        </outputEntry>
        <outputEntry id="revenue_rule_1_output_3">
          <text>1.25</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: High season + medium occupancy -->
      <rule id="revenue_rule_2">
        <inputEntry id="revenue_rule_2_input_1">
          <text>&gt; 0</text>
        </inputEntry>
        <inputEntry id="revenue_rule_2_input_2">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="revenue_rule_2_input_3">
          <text>[70..85)</text>
        </inputEntry>
        <inputEntry id="revenue_rule_2_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="revenue_rule_2_output_1">
          <text>historicalAvg * 1.15</text>
        </outputEntry>
        <outputEntry id="revenue_rule_2_output_2">
          <text>"MEDIUM_80PCT"</text>
        </outputEntry>
        <outputEntry id="revenue_rule_2_output_3">
          <text>1.15</text>
        </outputEntry>
      </rule>

      <!-- Rule 3: Medium season + high occupancy -->
      <rule id="revenue_rule_3">
        <inputEntry id="revenue_rule_3_input_1">
          <text>&gt; 0</text>
        </inputEntry>
        <inputEntry id="revenue_rule_3_input_2">
          <text>"MEDIUM"</text>
        </inputEntry>
        <inputEntry id="revenue_rule_3_input_3">
          <text>&gt;= 80</text>
        </inputEntry>
        <inputEntry id="revenue_rule_3_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="revenue_rule_3_output_1">
          <text>historicalAvg * 1.10</text>
        </outputEntry>
        <outputEntry id="revenue_rule_3_output_2">
          <text>"MEDIUM_85PCT"</text>
        </outputEntry>
        <outputEntry id="revenue_rule_3_output_3">
          <text>1.10</text>
        </outputEntry>
      </rule>

      <!-- Rule 4: Medium season + medium occupancy -->
      <rule id="revenue_rule_4">
        <inputEntry id="revenue_rule_4_input_1">
          <text>&gt; 0</text>
        </inputEntry>
        <inputEntry id="revenue_rule_4_input_2">
          <text>"MEDIUM"</text>
        </inputEntry>
        <inputEntry id="revenue_rule_4_input_3">
          <text>[60..80)</text>
        </inputEntry>
        <inputEntry id="revenue_rule_4_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="revenue_rule_4_output_1">
          <text>historicalAvg * 1.0</text>
        </outputEntry>
        <outputEntry id="revenue_rule_4_output_2">
          <text>"MEDIUM_75PCT"</text>
        </outputEntry>
        <outputEntry id="revenue_rule_4_output_3">
          <text>1.0</text>
        </outputEntry>
      </rule>

      <!-- Rule 5: Low season + high occupancy -->
      <rule id="revenue_rule_5">
        <inputEntry id="revenue_rule_5_input_1">
          <text>&gt; 0</text>
        </inputEntry>
        <inputEntry id="revenue_rule_5_input_2">
          <text>"LOW"</text>
        </inputEntry>
        <inputEntry id="revenue_rule_5_input_3">
          <text>&gt;= 75</text>
        </inputEntry>
        <inputEntry id="revenue_rule_5_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="revenue_rule_5_output_1">
          <text>historicalAvg * 0.95</text>
        </outputEntry>
        <outputEntry id="revenue_rule_5_output_2">
          <text>"MEDIUM_80PCT"</text>
        </outputEntry>
        <outputEntry id="revenue_rule_5_output_3">
          <text>0.95</text>
        </outputEntry>
      </rule>

      <!-- Rule 6: Low season + medium occupancy -->
      <rule id="revenue_rule_6">
        <inputEntry id="revenue_rule_6_input_1">
          <text>&gt; 0</text>
        </inputEntry>
        <inputEntry id="revenue_rule_6_input_2">
          <text>"LOW"</text>
        </inputEntry>
        <inputEntry id="revenue_rule_6_input_3">
          <text>[50..75)</text>
        </inputEntry>
        <inputEntry id="revenue_rule_6_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="revenue_rule_6_output_1">
          <text>historicalAvg * 0.85</text>
        </outputEntry>
        <outputEntry id="revenue_rule_6_output_2">
          <text>"LOW_70PCT"</text>
        </outputEntry>
        <outputEntry id="revenue_rule_6_output_3">
          <text>0.85</text>
        </outputEntry>
      </rule>

      <!-- Rule 7: Low season + low occupancy - conservative -->
      <rule id="revenue_rule_7">
        <inputEntry id="revenue_rule_7_input_1">
          <text>&gt; 0</text>
        </inputEntry>
        <inputEntry id="revenue_rule_7_input_2">
          <text>"LOW"</text>
        </inputEntry>
        <inputEntry id="revenue_rule_7_input_3">
          <text>&lt; 50</text>
        </inputEntry>
        <inputEntry id="revenue_rule_7_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="revenue_rule_7_output_1">
          <text>historicalAvg * 0.70</text>
        </outputEntry>
        <outputEntry id="revenue_rule_7_output_2">
          <text>"LOW_60PCT"</text>
        </outputEntry>
        <outputEntry id="revenue_rule_7_output_3">
          <text>0.70</text>
        </outputEntry>
      </rule>

      <!-- Rule 8: Holiday period - variable projection -->
      <rule id="revenue_rule_8">
        <inputEntry id="revenue_rule_8_input_1">
          <text>&gt; 0</text>
        </inputEntry>
        <inputEntry id="revenue_rule_8_input_2">
          <text>"HOLIDAY"</text>
        </inputEntry>
        <inputEntry id="revenue_rule_8_input_3">
          <text>&gt;= 65</text>
        </inputEntry>
        <inputEntry id="revenue_rule_8_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="revenue_rule_8_output_1">
          <text>historicalAvg * 0.80</text>
        </outputEntry>
        <outputEntry id="revenue_rule_8_output_2">
          <text>"MEDIUM_70PCT"</text>
        </outputEntry>
        <outputEntry id="revenue_rule_8_output_3">
          <text>0.80</text>
        </outputEntry>
      </rule>

      <!-- Rule 9: Very low occupancy - critical -->
      <rule id="revenue_rule_9">
        <inputEntry id="revenue_rule_9_input_1">
          <text>&gt; 0</text>
        </inputEntry>
        <inputEntry id="revenue_rule_9_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="revenue_rule_9_input_3">
          <text>&lt; 40</text>
        </inputEntry>
        <inputEntry id="revenue_rule_9_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="revenue_rule_9_output_1">
          <text>historicalAvg * 0.60</text>
        </outputEntry>
        <outputEntry id="revenue_rule_9_output_2">
          <text>"LOW_50PCT_CRITICAL"</text>
        </outputEntry>
        <outputEntry id="revenue_rule_9_output_3">
          <text>0.60</text>
        </outputEntry>
      </rule>

      <!-- Rule 10: Default fallback - baseline projection -->
      <rule id="revenue_rule_10">
        <inputEntry id="revenue_rule_10_input_1">
          <text>&gt; 0</text>
        </inputEntry>
        <inputEntry id="revenue_rule_10_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="revenue_rule_10_input_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="revenue_rule_10_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="revenue_rule_10_output_1">
          <text>historicalAvg * 1.0</text>
        </outputEntry>
        <outputEntry id="revenue_rule_10_output_2">
          <text>"MEDIUM_70PCT_BASELINE"</text>
        </outputEntry>
        <outputEntry id="revenue_rule_10_output_3">
          <text>1.0</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
