<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:biodi="http://bpmn.io/schema/dmn/biodi/2.0"
             id="Discount_Rules_Definitions"
             name="CIB7 Discount Rules"
             namespace="http://cib7.healthcare.br/dmn/billing/discount"
             exporter="CIB7 Healthcare Orchestrator"
             exporterVersion="1.0">
  <decision id="discount_rules" name="Regras de Desconto">
    <description>Define regras de desconto comercial e negociação conforme categoria de pagador, timing de pagamento e volume. Inclui limites de desconto e requisitos de aprovação.</description>
    <decisionTable id="discount_rules_table" hitPolicy="FIRST">
      <input id="input_payer_category" label="Categoria do Pagador" camunda:inputVariable="payerCategory">
        <inputExpression id="input_payer_category_exp" typeRef="string">
          <text>payerCategory</text>
        </inputExpression>
        <inputValues id="input_payer_category_values">
          <text>"VIP","PREMIUM","STANDARD","GOVERNMENT","CASH"</text>
        </inputValues>
      </input>
      <input id="input_payment_timing" label="Timing de Pagamento" camunda:inputVariable="paymentTiming">
        <inputExpression id="input_payment_timing_exp" typeRef="string">
          <text>paymentTiming</text>
        </inputExpression>
        <inputValues id="input_payment_timing_values">
          <text>"ADVANCE","ON_TIME","LATE"</text>
        </inputValues>
      </input>
      <input id="input_volume_discount" label="Desconto por Volume" camunda:inputVariable="volumeDiscount">
        <inputExpression id="input_volume_discount_exp" typeRef="boolean">
          <text>volumeDiscount</text>
        </inputExpression>
      </input>
      <input id="input_discount_tenant_id" label="ID do Tenant" camunda:inputVariable="tenantId">
        <inputExpression id="input_discount_tenant_id_exp" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="output_discount_percent" label="Percentual de Desconto" name="discountPercent" typeRef="double"/>
      <output id="output_max_discount" label="Desconto Máximo" name="maxDiscount" typeRef="double"/>
      <output id="output_approval_required" label="Requer Aprovação" name="approvalRequired" typeRef="boolean"/>

      <!-- Rule 1: VIP payer - advance payment - volume discount -->
      <rule id="discount_rule_1">
        <inputEntry id="discount_rule_1_input_1">
          <text>"VIP"</text>
        </inputEntry>
        <inputEntry id="discount_rule_1_input_2">
          <text>"ADVANCE"</text>
        </inputEntry>
        <inputEntry id="discount_rule_1_input_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="discount_rule_1_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="discount_rule_1_output_1">
          <text>15.0</text>
        </outputEntry>
        <outputEntry id="discount_rule_1_output_2">
          <text>25.0</text>
        </outputEntry>
        <outputEntry id="discount_rule_1_output_3">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: VIP payer - on time payment -->
      <rule id="discount_rule_2">
        <inputEntry id="discount_rule_2_input_1">
          <text>"VIP"</text>
        </inputEntry>
        <inputEntry id="discount_rule_2_input_2">
          <text>"ON_TIME"</text>
        </inputEntry>
        <inputEntry id="discount_rule_2_input_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="discount_rule_2_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="discount_rule_2_output_1">
          <text>10.0</text>
        </outputEntry>
        <outputEntry id="discount_rule_2_output_2">
          <text>15.0</text>
        </outputEntry>
        <outputEntry id="discount_rule_2_output_3">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 3: PREMIUM payer - advance payment - volume discount -->
      <rule id="discount_rule_3">
        <inputEntry id="discount_rule_3_input_1">
          <text>"PREMIUM"</text>
        </inputEntry>
        <inputEntry id="discount_rule_3_input_2">
          <text>"ADVANCE"</text>
        </inputEntry>
        <inputEntry id="discount_rule_3_input_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="discount_rule_3_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="discount_rule_3_output_1">
          <text>12.0</text>
        </outputEntry>
        <outputEntry id="discount_rule_3_output_2">
          <text>18.0</text>
        </outputEntry>
        <outputEntry id="discount_rule_3_output_3">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 4: PREMIUM payer - on time payment -->
      <rule id="discount_rule_4">
        <inputEntry id="discount_rule_4_input_1">
          <text>"PREMIUM"</text>
        </inputEntry>
        <inputEntry id="discount_rule_4_input_2">
          <text>"ON_TIME"</text>
        </inputEntry>
        <inputEntry id="discount_rule_4_input_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="discount_rule_4_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="discount_rule_4_output_1">
          <text>7.0</text>
        </outputEntry>
        <outputEntry id="discount_rule_4_output_2">
          <text>12.0</text>
        </outputEntry>
        <outputEntry id="discount_rule_4_output_3">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 5: STANDARD payer - advance payment - volume discount -->
      <rule id="discount_rule_5">
        <inputEntry id="discount_rule_5_input_1">
          <text>"STANDARD"</text>
        </inputEntry>
        <inputEntry id="discount_rule_5_input_2">
          <text>"ADVANCE"</text>
        </inputEntry>
        <inputEntry id="discount_rule_5_input_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="discount_rule_5_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="discount_rule_5_output_1">
          <text>8.0</text>
        </outputEntry>
        <outputEntry id="discount_rule_5_output_2">
          <text>12.0</text>
        </outputEntry>
        <outputEntry id="discount_rule_5_output_3">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Rule 6: STANDARD payer - on time payment -->
      <rule id="discount_rule_6">
        <inputEntry id="discount_rule_6_input_1">
          <text>"STANDARD"</text>
        </inputEntry>
        <inputEntry id="discount_rule_6_input_2">
          <text>"ON_TIME"</text>
        </inputEntry>
        <inputEntry id="discount_rule_6_input_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="discount_rule_6_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="discount_rule_6_output_1">
          <text>5.0</text>
        </outputEntry>
        <outputEntry id="discount_rule_6_output_2">
          <text>8.0</text>
        </outputEntry>
        <outputEntry id="discount_rule_6_output_3">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Rule 7: GOVERNMENT payer - no discount (fixed rates) -->
      <rule id="discount_rule_7">
        <inputEntry id="discount_rule_7_input_1">
          <text>"GOVERNMENT"</text>
        </inputEntry>
        <inputEntry id="discount_rule_7_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="discount_rule_7_input_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="discount_rule_7_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="discount_rule_7_output_1">
          <text>0</text>
        </outputEntry>
        <outputEntry id="discount_rule_7_output_2">
          <text>0</text>
        </outputEntry>
        <outputEntry id="discount_rule_7_output_3">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 8: CASH payer - advance payment -->
      <rule id="discount_rule_8">
        <inputEntry id="discount_rule_8_input_1">
          <text>"CASH"</text>
        </inputEntry>
        <inputEntry id="discount_rule_8_input_2">
          <text>"ADVANCE"</text>
        </inputEntry>
        <inputEntry id="discount_rule_8_input_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="discount_rule_8_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="discount_rule_8_output_1">
          <text>20.0</text>
        </outputEntry>
        <outputEntry id="discount_rule_8_output_2">
          <text>30.0</text>
        </outputEntry>
        <outputEntry id="discount_rule_8_output_3">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 9: Late payment - no discount (penalty applied elsewhere) -->
      <rule id="discount_rule_9">
        <inputEntry id="discount_rule_9_input_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="discount_rule_9_input_2">
          <text>"LATE"</text>
        </inputEntry>
        <inputEntry id="discount_rule_9_input_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="discount_rule_9_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="discount_rule_9_output_1">
          <text>0</text>
        </outputEntry>
        <outputEntry id="discount_rule_9_output_2">
          <text>0</text>
        </outputEntry>
        <outputEntry id="discount_rule_9_output_3">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Rule 10: Default fallback - minimal discount -->
      <rule id="discount_rule_10">
        <inputEntry id="discount_rule_10_input_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="discount_rule_10_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="discount_rule_10_input_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="discount_rule_10_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="discount_rule_10_output_1">
          <text>3.0</text>
        </outputEntry>
        <outputEntry id="discount_rule_10_output_2">
          <text>5.0</text>
        </outputEntry>
        <outputEntry id="discount_rule_10_output_3">
          <text>true</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
