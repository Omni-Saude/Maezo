<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:biodi="http://bpmn.io/schema/dmn/biodi/2.0"
             id="Contract_Rules_Unimed_Definitions"
             name="CIB7 Unimed Contract Rules"
             namespace="http://cib7.healthcare.br/dmn/billing/unimed"
             exporter="CIB7 Healthcare Orchestrator"
             exporterVersion="1.0">
  <decision id="contract_rules_unimed" name="Regras de Contrato Unimed">
    <description>Regras específicas de cobertura e autorização para cooperativa Unimed. Inclui diferentes modalidades de planos e particularidades da rede cooperada.</description>
    <decisionTable id="contract_unimed_table" hitPolicy="FIRST">
      <input id="input_unimed_procedure_code" label="Código do Procedimento" camunda:inputVariable="procedureCode">
        <inputExpression id="input_unimed_procedure_code_exp" typeRef="string">
          <text>procedureCode</text>
        </inputExpression>
      </input>
      <input id="input_unimed_plan_type" label="Tipo de Plano" camunda:inputVariable="planType">
        <inputExpression id="input_unimed_plan_type_exp" typeRef="string">
          <text>planType</text>
        </inputExpression>
        <inputValues id="input_unimed_plan_type_values">
          <text>"EXECUTIVO","ESPECIAL","COOPERADO","MASTER","STANDARD"</text>
        </inputValues>
      </input>
      <input id="input_unimed_tenant_id" label="ID do Tenant" camunda:inputVariable="tenantId">
        <inputExpression id="input_unimed_tenant_id_exp" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="output_unimed_coverage_percentage" label="Percentual de Cobertura" name="coveragePercentage" typeRef="integer"/>
      <output id="output_unimed_requires_pre_auth" label="Requer Autorização Prévia" name="requiresPreAuth" typeRef="boolean"/>
      <output id="output_unimed_max_reimbursement" label="Reembolso Máximo" name="maxReimbursement" typeRef="double"/>
      <output id="output_unimed_special_rules" label="Regras Especiais" name="specialRules" typeRef="string"/>

      <!-- Rule 1: EXECUTIVO plan - full coverage for surgeries -->
      <rule id="unimed_rule_1">
        <inputEntry id="unimed_rule_1_input_1">
          <text>starts with(procedureCode, "3")</text>
        </inputEntry>
        <inputEntry id="unimed_rule_1_input_2">
          <text>"EXECUTIVO"</text>
        </inputEntry>
        <inputEntry id="unimed_rule_1_input_3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="unimed_rule_1_output_1">
          <text>100</text>
        </outputEntry>
        <outputEntry id="unimed_rule_1_output_2">
          <text>true</text>
        </outputEntry>
        <outputEntry id="unimed_rule_1_output_3">
          <text>80000</text>
        </outputEntry>
        <outputEntry id="unimed_rule_1_output_4">
          <text>"Cobertura integral, rede referenciada ou reembolso, pré-autorização 48h"</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: COOPERADO plan - preferential coverage -->
      <rule id="unimed_rule_2">
        <inputEntry id="unimed_rule_2_input_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="unimed_rule_2_input_2">
          <text>"COOPERADO"</text>
        </inputEntry>
        <inputEntry id="unimed_rule_2_input_3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="unimed_rule_2_output_1">
          <text>95</text>
        </outputEntry>
        <outputEntry id="unimed_rule_2_output_2">
          <text>false</text>
        </outputEntry>
        <outputEntry id="unimed_rule_2_output_3">
          <text>60000</text>
        </outputEntry>
        <outputEntry id="unimed_rule_2_output_4">
          <text>"Cooperados têm 95% cobertura, liberação facilitada via sistema"</text>
        </outputEntry>
      </rule>

      <!-- Rule 3: ESPECIAL plan - high complexity -->
      <rule id="unimed_rule_3">
        <inputEntry id="unimed_rule_3_input_1">
          <text>starts with(procedureCode, "4")</text>
        </inputEntry>
        <inputEntry id="unimed_rule_3_input_2">
          <text>"ESPECIAL"</text>
        </inputEntry>
        <inputEntry id="unimed_rule_3_input_3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="unimed_rule_3_output_1">
          <text>85</text>
        </outputEntry>
        <outputEntry id="unimed_rule_3_output_2">
          <text>true</text>
        </outputEntry>
        <outputEntry id="unimed_rule_3_output_3">
          <text>40000</text>
        </outputEntry>
        <outputEntry id="unimed_rule_3_output_4">
          <text>"Alta complexidade requer junta médica, até 5 dias úteis"</text>
        </outputEntry>
      </rule>

      <!-- Rule 4: MASTER plan - diagnostic coverage -->
      <rule id="unimed_rule_4">
        <inputEntry id="unimed_rule_4_input_1">
          <text>starts with(procedureCode, "2")</text>
        </inputEntry>
        <inputEntry id="unimed_rule_4_input_2">
          <text>"MASTER"</text>
        </inputEntry>
        <inputEntry id="unimed_rule_4_input_3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="unimed_rule_4_output_1">
          <text>90</text>
        </outputEntry>
        <outputEntry id="unimed_rule_4_output_2">
          <text>false</text>
        </outputEntry>
        <outputEntry id="unimed_rule_4_output_3">
          <text>8000</text>
        </outputEntry>
        <outputEntry id="unimed_rule_4_output_4">
          <text>"Exames diagnósticos com liberação online, cobertura 90%"</text>
        </outputEntry>
      </rule>

      <!-- Rule 5: STANDARD plan - basic consultations -->
      <rule id="unimed_rule_5">
        <inputEntry id="unimed_rule_5_input_1">
          <text>starts with(procedureCode, "10101012")</text>
        </inputEntry>
        <inputEntry id="unimed_rule_5_input_2">
          <text>"STANDARD"</text>
        </inputEntry>
        <inputEntry id="unimed_rule_5_input_3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="unimed_rule_5_output_1">
          <text>70</text>
        </outputEntry>
        <outputEntry id="unimed_rule_5_output_2">
          <text>false</text>
        </outputEntry>
        <outputEntry id="unimed_rule_5_output_3">
          <text>600</text>
        </outputEntry>
        <outputEntry id="unimed_rule_5_output_4">
          <text>"Consultas básicas sem autorização, coparticipação 30%"</text>
        </outputEntry>
      </rule>

      <!-- Rule 6: OPME procedures - all plans -->
      <rule id="unimed_rule_6">
        <inputEntry id="unimed_rule_6_input_1">
          <text>contains(procedureCode, "OPME")</text>
        </inputEntry>
        <inputEntry id="unimed_rule_6_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="unimed_rule_6_input_3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="unimed_rule_6_output_1">
          <text>90</text>
        </outputEntry>
        <outputEntry id="unimed_rule_6_output_2">
          <text>true</text>
        </outputEntry>
        <outputEntry id="unimed_rule_6_output_3">
          <text>120000</text>
        </outputEntry>
        <outputEntry id="unimed_rule_6_output_4">
          <text>"OPME com autorização via portal, análise técnica em 72h"</text>
        </outputEntry>
      </rule>

      <!-- Rule 7: Oncology treatments - special coverage -->
      <rule id="unimed_rule_7">
        <inputEntry id="unimed_rule_7_input_1">
          <text>contains(procedureCode, "ONCO")</text>
        </inputEntry>
        <inputEntry id="unimed_rule_7_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="unimed_rule_7_input_3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="unimed_rule_7_output_1">
          <text>100</text>
        </outputEntry>
        <outputEntry id="unimed_rule_7_output_2">
          <text>true</text>
        </outputEntry>
        <outputEntry id="unimed_rule_7_output_3">
          <text>0</text>
        </outputEntry>
        <outputEntry id="unimed_rule_7_output_4">
          <text>"Tratamentos oncológicos cobertos integralmente por lei, pré-autorização necessária"</text>
        </outputEntry>
      </rule>

      <!-- Rule 8: Default fallback -->
      <rule id="unimed_rule_8">
        <inputEntry id="unimed_rule_8_input_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="unimed_rule_8_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="unimed_rule_8_input_3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="unimed_rule_8_output_1">
          <text>65</text>
        </outputEntry>
        <outputEntry id="unimed_rule_8_output_2">
          <text>true</text>
        </outputEntry>
        <outputEntry id="unimed_rule_8_output_3">
          <text>15000</text>
        </outputEntry>
        <outputEntry id="unimed_rule_8_output_4">
          <text>"Verificar rol ANS e contrato específico da singular Unimed"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
