<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:biodi="http://bpmn.io/schema/dmn/biodi/2.0"
             id="Tax_Calculation_Definitions"
             name="CIB7 Tax Calculation"
             namespace="http://cib7.healthcare.br/dmn/billing/tax"
             exporter="CIB7 Healthcare Orchestrator"
             exporterVersion="1.0">
  <decision id="tax_calculation" name="Cálculo de Impostos">
    <description>Calcula impostos aplicáveis a serviços de saúde incluindo ISS (municipal), PIS e COFINS (federais). Alíquotas variam por tipo de serviço, município e regime tributário da prestadora.</description>
    <decisionTable id="tax_calculation_table" hitPolicy="FIRST">
      <input id="input_service_type" label="Tipo de Serviço" camunda:inputVariable="serviceType">
        <inputExpression id="input_service_type_exp" typeRef="string">
          <text>serviceType</text>
        </inputExpression>
      </input>
      <input id="input_municipality" label="Município" camunda:inputVariable="municipality">
        <inputExpression id="input_municipality_exp" typeRef="string">
          <text>municipality</text>
        </inputExpression>
      </input>
      <input id="input_tax_regime" label="Regime Tributário" camunda:inputVariable="taxRegime">
        <inputExpression id="input_tax_regime_exp" typeRef="string">
          <text>taxRegime</text>
        </inputExpression>
        <inputValues id="input_tax_regime_values">
          <text>"SIMPLES","LUCRO_REAL","LUCRO_PRESUMIDO"</text>
        </inputValues>
      </input>
      <input id="input_tax_tenant_id" label="ID do Tenant" camunda:inputVariable="tenantId">
        <inputExpression id="input_tax_tenant_id_exp" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="output_iss_rate" label="Alíquota ISS" name="issRate" typeRef="double"/>
      <output id="output_pis_rate" label="Alíquota PIS" name="pisRate" typeRef="double"/>
      <output id="output_cofins_rate" label="Alíquota COFINS" name="cofinsRate" typeRef="double"/>
      <output id="output_total_tax_rate" label="Alíquota Total" name="totalTaxRate" typeRef="double"/>

      <!-- Rule 1: Hospital services - São Paulo - SIMPLES -->
      <rule id="tax_rule_1">
        <inputEntry id="tax_rule_1_input_1">
          <text>"HOSPITALAR"</text>
        </inputEntry>
        <inputEntry id="tax_rule_1_input_2">
          <text>"SAO_PAULO"</text>
        </inputEntry>
        <inputEntry id="tax_rule_1_input_3">
          <text>"SIMPLES"</text>
        </inputEntry>
        <inputEntry id="tax_rule_1_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="tax_rule_1_output_1">
          <text>2.0</text>
        </outputEntry>
        <outputEntry id="tax_rule_1_output_2">
          <text>0</text>
        </outputEntry>
        <outputEntry id="tax_rule_1_output_3">
          <text>0</text>
        </outputEntry>
        <outputEntry id="tax_rule_1_output_4">
          <text>2.0</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: Hospital services - Rio de Janeiro - LUCRO_REAL -->
      <rule id="tax_rule_2">
        <inputEntry id="tax_rule_2_input_1">
          <text>"HOSPITALAR"</text>
        </inputEntry>
        <inputEntry id="tax_rule_2_input_2">
          <text>"RIO_DE_JANEIRO"</text>
        </inputEntry>
        <inputEntry id="tax_rule_2_input_3">
          <text>"LUCRO_REAL"</text>
        </inputEntry>
        <inputEntry id="tax_rule_2_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="tax_rule_2_output_1">
          <text>2.5</text>
        </outputEntry>
        <outputEntry id="tax_rule_2_output_2">
          <text>0.65</text>
        </outputEntry>
        <outputEntry id="tax_rule_2_output_3">
          <text>3.0</text>
        </outputEntry>
        <outputEntry id="tax_rule_2_output_4">
          <text>6.15</text>
        </outputEntry>
      </rule>

      <!-- Rule 3: Medical consultations - São Paulo - LUCRO_PRESUMIDO -->
      <rule id="tax_rule_3">
        <inputEntry id="tax_rule_3_input_1">
          <text>"CONSULTA_MEDICA"</text>
        </inputEntry>
        <inputEntry id="tax_rule_3_input_2">
          <text>"SAO_PAULO"</text>
        </inputEntry>
        <inputEntry id="tax_rule_3_input_3">
          <text>"LUCRO_PRESUMIDO"</text>
        </inputEntry>
        <inputEntry id="tax_rule_3_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="tax_rule_3_output_1">
          <text>5.0</text>
        </outputEntry>
        <outputEntry id="tax_rule_3_output_2">
          <text>0.65</text>
        </outputEntry>
        <outputEntry id="tax_rule_3_output_3">
          <text>3.0</text>
        </outputEntry>
        <outputEntry id="tax_rule_3_output_4">
          <text>8.65</text>
        </outputEntry>
      </rule>

      <!-- Rule 4: Diagnostic services - Brasília - LUCRO_REAL -->
      <rule id="tax_rule_4">
        <inputEntry id="tax_rule_4_input_1">
          <text>"DIAGNOSTICO"</text>
        </inputEntry>
        <inputEntry id="tax_rule_4_input_2">
          <text>"BRASILIA"</text>
        </inputEntry>
        <inputEntry id="tax_rule_4_input_3">
          <text>"LUCRO_REAL"</text>
        </inputEntry>
        <inputEntry id="tax_rule_4_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="tax_rule_4_output_1">
          <text>3.0</text>
        </outputEntry>
        <outputEntry id="tax_rule_4_output_2">
          <text>0.65</text>
        </outputEntry>
        <outputEntry id="tax_rule_4_output_3">
          <text>3.0</text>
        </outputEntry>
        <outputEntry id="tax_rule_4_output_4">
          <text>6.65</text>
        </outputEntry>
      </rule>

      <!-- Rule 5: Laboratory services - Belo Horizonte - SIMPLES -->
      <rule id="tax_rule_5">
        <inputEntry id="tax_rule_5_input_1">
          <text>"LABORATORIO"</text>
        </inputEntry>
        <inputEntry id="tax_rule_5_input_2">
          <text>"BELO_HORIZONTE"</text>
        </inputEntry>
        <inputEntry id="tax_rule_5_input_3">
          <text>"SIMPLES"</text>
        </inputEntry>
        <inputEntry id="tax_rule_5_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="tax_rule_5_output_1">
          <text>2.79</text>
        </outputEntry>
        <outputEntry id="tax_rule_5_output_2">
          <text>0</text>
        </outputEntry>
        <outputEntry id="tax_rule_5_output_3">
          <text>0</text>
        </outputEntry>
        <outputEntry id="tax_rule_5_output_4">
          <text>2.79</text>
        </outputEntry>
      </rule>

      <!-- Rule 6: Physiotherapy - Porto Alegre - LUCRO_PRESUMIDO -->
      <rule id="tax_rule_6">
        <inputEntry id="tax_rule_6_input_1">
          <text>"FISIOTERAPIA"</text>
        </inputEntry>
        <inputEntry id="tax_rule_6_input_2">
          <text>"PORTO_ALEGRE"</text>
        </inputEntry>
        <inputEntry id="tax_rule_6_input_3">
          <text>"LUCRO_PRESUMIDO"</text>
        </inputEntry>
        <inputEntry id="tax_rule_6_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="tax_rule_6_output_1">
          <text>4.5</text>
        </outputEntry>
        <outputEntry id="tax_rule_6_output_2">
          <text>0.65</text>
        </outputEntry>
        <outputEntry id="tax_rule_6_output_3">
          <text>3.0</text>
        </outputEntry>
        <outputEntry id="tax_rule_6_output_4">
          <text>8.15</text>
        </outputEntry>
      </rule>

      <!-- Rule 7: Home care - Curitiba - LUCRO_REAL -->
      <rule id="tax_rule_7">
        <inputEntry id="tax_rule_7_input_1">
          <text>"HOME_CARE"</text>
        </inputEntry>
        <inputEntry id="tax_rule_7_input_2">
          <text>"CURITIBA"</text>
        </inputEntry>
        <inputEntry id="tax_rule_7_input_3">
          <text>"LUCRO_REAL"</text>
        </inputEntry>
        <inputEntry id="tax_rule_7_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="tax_rule_7_output_1">
          <text>3.5</text>
        </outputEntry>
        <outputEntry id="tax_rule_7_output_2">
          <text>0.65</text>
        </outputEntry>
        <outputEntry id="tax_rule_7_output_3">
          <text>3.0</text>
        </outputEntry>
        <outputEntry id="tax_rule_7_output_4">
          <text>7.15</text>
        </outputEntry>
      </rule>

      <!-- Rule 8: Dental services - Recife - SIMPLES -->
      <rule id="tax_rule_8">
        <inputEntry id="tax_rule_8_input_1">
          <text>"ODONTOLOGIA"</text>
        </inputEntry>
        <inputEntry id="tax_rule_8_input_2">
          <text>"RECIFE"</text>
        </inputEntry>
        <inputEntry id="tax_rule_8_input_3">
          <text>"SIMPLES"</text>
        </inputEntry>
        <inputEntry id="tax_rule_8_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="tax_rule_8_output_1">
          <text>3.0</text>
        </outputEntry>
        <outputEntry id="tax_rule_8_output_2">
          <text>0</text>
        </outputEntry>
        <outputEntry id="tax_rule_8_output_3">
          <text>0</text>
        </outputEntry>
        <outputEntry id="tax_rule_8_output_4">
          <text>3.0</text>
        </outputEntry>
      </rule>

      <!-- Rule 9: Generic hospital services - LUCRO_REAL (default federal rates) -->
      <rule id="tax_rule_9">
        <inputEntry id="tax_rule_9_input_1">
          <text>"HOSPITALAR"</text>
        </inputEntry>
        <inputEntry id="tax_rule_9_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="tax_rule_9_input_3">
          <text>"LUCRO_REAL"</text>
        </inputEntry>
        <inputEntry id="tax_rule_9_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="tax_rule_9_output_1">
          <text>3.0</text>
        </outputEntry>
        <outputEntry id="tax_rule_9_output_2">
          <text>0.65</text>
        </outputEntry>
        <outputEntry id="tax_rule_9_output_3">
          <text>3.0</text>
        </outputEntry>
        <outputEntry id="tax_rule_9_output_4">
          <text>6.65</text>
        </outputEntry>
      </rule>

      <!-- Rule 10: Default fallback -->
      <rule id="tax_rule_10">
        <inputEntry id="tax_rule_10_input_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="tax_rule_10_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="tax_rule_10_input_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="tax_rule_10_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="tax_rule_10_output_1">
          <text>5.0</text>
        </outputEntry>
        <outputEntry id="tax_rule_10_output_2">
          <text>0.65</text>
        </outputEntry>
        <outputEntry id="tax_rule_10_output_3">
          <text>3.0</text>
        </outputEntry>
        <outputEntry id="tax_rule_10_output_4">
          <text>8.65</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
