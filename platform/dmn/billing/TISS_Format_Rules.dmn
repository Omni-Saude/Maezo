<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:biodi="http://bpmn.io/schema/dmn/biodi/2.0"
             id="TISS_Format_Rules_Definitions"
             name="CIB7 TISS Format Rules"
             namespace="http://cib7.healthcare.br/dmn/billing/tiss"
             exporter="CIB7 Healthcare Orchestrator"
             exporterVersion="1.0">
  <decision id="tiss_format_rules" name="Regras de Formato TISS">
    <description>Define regras de formatação para padrão TISS (Troca de Informações na Saúde Suplementar). Especifica campos obrigatórios, nível de validação e templates XML por tipo de guia e versão TISS.</description>
    <decisionTable id="tiss_format_rules_table" hitPolicy="FIRST">
      <input id="input_tiss_version" label="Versão TISS" camunda:inputVariable="tissVersion">
        <inputExpression id="input_tiss_version_exp" typeRef="string">
          <text>tissVersion</text>
        </inputExpression>
      </input>
      <input id="input_guide_type" label="Tipo de Guia" camunda:inputVariable="guideType">
        <inputExpression id="input_guide_type_exp" typeRef="string">
          <text>guideType</text>
        </inputExpression>
        <inputValues id="input_guide_type_values">
          <text>"CONSULTA","SADT","INTERNACAO","HONORARIO","ODONTO"</text>
        </inputValues>
      </input>
      <input id="input_tiss_procedure_type" label="Tipo de Procedimento" camunda:inputVariable="procedureType">
        <inputExpression id="input_tiss_procedure_type_exp" typeRef="string">
          <text>procedureType</text>
        </inputExpression>
      </input>
      <input id="input_tiss_tenant_id" label="ID do Tenant" camunda:inputVariable="tenantId">
        <inputExpression id="input_tiss_tenant_id_exp" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="output_required_fields" label="Campos Obrigatórios" name="requiredFields" typeRef="string"/>
      <output id="output_validation_level" label="Nível de Validação" name="validationLevel" typeRef="string"/>
      <output id="output_xml_template" label="Template XML" name="xmlTemplate" typeRef="string"/>

      <!-- Rule 1: TISS 4.0 - Consultation guide -->
      <rule id="tiss_rule_1">
        <inputEntry id="tiss_rule_1_input_1">
          <text>"4.0","4.01","4.02"</text>
        </inputEntry>
        <inputEntry id="tiss_rule_1_input_2">
          <text>"CONSULTA"</text>
        </inputEntry>
        <inputEntry id="tiss_rule_1_input_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="tiss_rule_1_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="tiss_rule_1_output_1">
          <text>"numeroGuia,beneficiario,contratado,profissional,procedimento,valor"</text>
        </outputEntry>
        <outputEntry id="tiss_rule_1_output_2">
          <text>"STANDARD"</text>
        </outputEntry>
        <outputEntry id="tiss_rule_1_output_3">
          <text>"guiaConsulta_v4.xsd"</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: TISS 4.0 - SADT (diagnostic and therapy services) -->
      <rule id="tiss_rule_2">
        <inputEntry id="tiss_rule_2_input_1">
          <text>"4.0","4.01","4.02"</text>
        </inputEntry>
        <inputEntry id="tiss_rule_2_input_2">
          <text>"SADT"</text>
        </inputEntry>
        <inputEntry id="tiss_rule_2_input_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="tiss_rule_2_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="tiss_rule_2_output_1">
          <text>"numeroGuia,beneficiario,contratado,solicitante,procedimentos,dataExecucao,valor"</text>
        </outputEntry>
        <outputEntry id="tiss_rule_2_output_2">
          <text>"ENHANCED"</text>
        </outputEntry>
        <outputEntry id="tiss_rule_2_output_3">
          <text>"guiaSADT_v4.xsd"</text>
        </outputEntry>
      </rule>

      <!-- Rule 3: TISS 4.0 - Hospitalization -->
      <rule id="tiss_rule_3">
        <inputEntry id="tiss_rule_3_input_1">
          <text>"4.0","4.01","4.02"</text>
        </inputEntry>
        <inputEntry id="tiss_rule_3_input_2">
          <text>"INTERNACAO"</text>
        </inputEntry>
        <inputEntry id="tiss_rule_3_input_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="tiss_rule_3_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="tiss_rule_3_output_1">
          <text>"numeroGuia,beneficiario,hospital,dataInternacao,dataAlta,diagnostico,procedimentos,diarias,taxas,materiais,medicamentos,gases,honorarios"</text>
        </outputEntry>
        <outputEntry id="tiss_rule_3_output_2">
          <text>"STRICT"</text>
        </outputEntry>
        <outputEntry id="tiss_rule_3_output_3">
          <text>"guiaInternacao_v4.xsd"</text>
        </outputEntry>
      </rule>

      <!-- Rule 4: TISS 4.0 - Professional fees -->
      <rule id="tiss_rule_4">
        <inputEntry id="tiss_rule_4_input_1">
          <text>"4.0","4.01","4.02"</text>
        </inputEntry>
        <inputEntry id="tiss_rule_4_input_2">
          <text>"HONORARIO"</text>
        </inputEntry>
        <inputEntry id="tiss_rule_4_input_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="tiss_rule_4_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="tiss_rule_4_output_1">
          <text>"numeroGuia,profissional,procedimentos,grauParticipacao,valorHonorarios"</text>
        </outputEntry>
        <outputEntry id="tiss_rule_4_output_2">
          <text>"STANDARD"</text>
        </outputEntry>
        <outputEntry id="tiss_rule_4_output_3">
          <text>"guiaHonorarios_v4.xsd"</text>
        </outputEntry>
      </rule>

      <!-- Rule 5: TISS 4.0 - Dental services -->
      <rule id="tiss_rule_5">
        <inputEntry id="tiss_rule_5_input_1">
          <text>"4.0","4.01","4.02"</text>
        </inputEntry>
        <inputEntry id="tiss_rule_5_input_2">
          <text>"ODONTO"</text>
        </inputEntry>
        <inputEntry id="tiss_rule_5_input_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="tiss_rule_5_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="tiss_rule_5_output_1">
          <text>"numeroGuia,beneficiario,dentista,procedimentosOdonto,dentes,faces,valor"</text>
        </outputEntry>
        <outputEntry id="tiss_rule_5_output_2">
          <text>"STANDARD"</text>
        </outputEntry>
        <outputEntry id="tiss_rule_5_output_3">
          <text>"guiaOdonto_v4.xsd"</text>
        </outputEntry>
      </rule>

      <!-- Rule 6: TISS 3.x legacy - Consultation -->
      <rule id="tiss_rule_6">
        <inputEntry id="tiss_rule_6_input_1">
          <text>"3.0","3.01","3.02","3.03"</text>
        </inputEntry>
        <inputEntry id="tiss_rule_6_input_2">
          <text>"CONSULTA"</text>
        </inputEntry>
        <inputEntry id="tiss_rule_6_input_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="tiss_rule_6_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="tiss_rule_6_output_1">
          <text>"numeroGuia,beneficiario,prestador,procedimento"</text>
        </outputEntry>
        <outputEntry id="tiss_rule_6_output_2">
          <text>"LEGACY"</text>
        </outputEntry>
        <outputEntry id="tiss_rule_6_output_3">
          <text>"guiaConsulta_v3.xsd"</text>
        </outputEntry>
      </rule>

      <!-- Rule 7: TISS 3.x legacy - SADT -->
      <rule id="tiss_rule_7">
        <inputEntry id="tiss_rule_7_input_1">
          <text>"3.0","3.01","3.02","3.03"</text>
        </inputEntry>
        <inputEntry id="tiss_rule_7_input_2">
          <text>"SADT"</text>
        </inputEntry>
        <inputEntry id="tiss_rule_7_input_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="tiss_rule_7_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="tiss_rule_7_output_1">
          <text>"numeroGuia,beneficiario,prestador,procedimentos"</text>
        </outputEntry>
        <outputEntry id="tiss_rule_7_output_2">
          <text>"LEGACY"</text>
        </outputEntry>
        <outputEntry id="tiss_rule_7_output_3">
          <text>"guiaSADT_v3.xsd"</text>
        </outputEntry>
      </rule>

      <!-- Rule 8: High complexity procedures - enhanced validation -->
      <rule id="tiss_rule_8">
        <inputEntry id="tiss_rule_8_input_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="tiss_rule_8_input_2">
          <text>"INTERNACAO"</text>
        </inputEntry>
        <inputEntry id="tiss_rule_8_input_3">
          <text>contains(procedureType, "ALTA_COMPLEXIDADE")</text>
        </inputEntry>
        <inputEntry id="tiss_rule_8_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="tiss_rule_8_output_1">
          <text>"numeroGuia,beneficiario,hospital,dataInternacao,dataAlta,diagnostico,procedimentos,diarias,taxas,materiais,medicamentos,gases,honorarios,laudo,justificativa"</text>
        </outputEntry>
        <outputEntry id="tiss_rule_8_output_2">
          <text>"STRICT_WITH_AUDIT"</text>
        </outputEntry>
        <outputEntry id="tiss_rule_8_output_3">
          <text>"guiaInternacaoAltaComplexidade_v4.xsd"</text>
        </outputEntry>
      </rule>

      <!-- Rule 9: Oncology - special requirements -->
      <rule id="tiss_rule_9">
        <inputEntry id="tiss_rule_9_input_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="tiss_rule_9_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="tiss_rule_9_input_3">
          <text>contains(procedureType, "ONCOLOGIA")</text>
        </inputEntry>
        <inputEntry id="tiss_rule_9_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="tiss_rule_9_output_1">
          <text>"numeroGuia,beneficiario,prestador,diagnosticoOncologico,estadiamento,protocolo,quimioterapicos,sessoes,ciclos"</text>
        </outputEntry>
        <outputEntry id="tiss_rule_9_output_2">
          <text>"STRICT_ONCOLOGY"</text>
        </outputEntry>
        <outputEntry id="tiss_rule_9_output_3">
          <text>"guiaOncologia_v4.xsd"</text>
        </outputEntry>
      </rule>

      <!-- Rule 10: Default fallback -->
      <rule id="tiss_rule_10">
        <inputEntry id="tiss_rule_10_input_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="tiss_rule_10_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="tiss_rule_10_input_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="tiss_rule_10_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="tiss_rule_10_output_1">
          <text>"numeroGuia,beneficiario,prestador,procedimento,valor"</text>
        </outputEntry>
        <outputEntry id="tiss_rule_10_output_2">
          <text>"STANDARD"</text>
        </outputEntry>
        <outputEntry id="tiss_rule_10_output_3">
          <text>"guiaGenerica_v4.xsd"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
