<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:biodi="http://bpmn.io/schema/dmn/biodi/2.0"
             id="Package_Pricing_Definitions"
             name="CIB7 Package Pricing"
             namespace="http://cib7.healthcare.br/dmn/billing/package"
             exporter="CIB7 Healthcare Orchestrator"
             exporterVersion="1.0">
  <decision id="package_pricing" name="Precificação de Pacotes">
    <description>Determina preços para diferentes tipos de pacotes e bundles assistenciais incluindo DRG, pacotes cirúrgicos, diárias e fee-for-service.</description>
    <decisionTable id="package_pricing_table" hitPolicy="FIRST">
      <input id="input_package_type" label="Tipo de Pacote" camunda:inputVariable="packageType">
        <inputExpression id="input_package_type_exp" typeRef="string">
          <text>packageType</text>
        </inputExpression>
        <inputValues id="input_package_type_values">
          <text>"DRG","BUNDLE","PER_DIEM","FEE_FOR_SERVICE"</text>
        </inputValues>
      </input>
      <input id="input_procedure_count" label="Quantidade de Procedimentos" camunda:inputVariable="procedureCount">
        <inputExpression id="input_procedure_count_exp" typeRef="integer">
          <text>procedureCount</text>
        </inputExpression>
      </input>
      <input id="input_stay_duration" label="Duração da Internação (dias)" camunda:inputVariable="stayDuration">
        <inputExpression id="input_stay_duration_exp" typeRef="integer">
          <text>stayDuration</text>
        </inputExpression>
      </input>
      <input id="input_package_tenant_id" label="ID do Tenant" camunda:inputVariable="tenantId">
        <inputExpression id="input_package_tenant_id_exp" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="output_package_price" label="Preço do Pacote" name="packagePrice" typeRef="double"/>
      <output id="output_adjustment_factor" label="Fator de Ajuste" name="adjustmentFactor" typeRef="double"/>
      <output id="output_pricing_method" label="Método de Precificação" name="pricingMethod" typeRef="string"/>

      <!-- Rule 1: DRG with short stay -->
      <rule id="package_rule_1">
        <inputEntry id="package_rule_1_input_1">
          <text>"DRG"</text>
        </inputEntry>
        <inputEntry id="package_rule_1_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="package_rule_1_input_3">
          <text>[1..3]</text>
        </inputEntry>
        <inputEntry id="package_rule_1_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="package_rule_1_output_1">
          <text>8500</text>
        </outputEntry>
        <outputEntry id="package_rule_1_output_2">
          <text>1.0</text>
        </outputEntry>
        <outputEntry id="package_rule_1_output_3">
          <text>"DRG_SHORT_STAY_FIXED"</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: DRG with medium stay -->
      <rule id="package_rule_2">
        <inputEntry id="package_rule_2_input_1">
          <text>"DRG"</text>
        </inputEntry>
        <inputEntry id="package_rule_2_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="package_rule_2_input_3">
          <text>[4..7]</text>
        </inputEntry>
        <inputEntry id="package_rule_2_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="package_rule_2_output_1">
          <text>15000</text>
        </outputEntry>
        <outputEntry id="package_rule_2_output_2">
          <text>1.15</text>
        </outputEntry>
        <outputEntry id="package_rule_2_output_3">
          <text>"DRG_MEDIUM_STAY_ADJUSTED"</text>
        </outputEntry>
      </rule>

      <!-- Rule 3: DRG with extended stay -->
      <rule id="package_rule_3">
        <inputEntry id="package_rule_3_input_1">
          <text>"DRG"</text>
        </inputEntry>
        <inputEntry id="package_rule_3_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="package_rule_3_input_3">
          <text>&gt; 7</text>
        </inputEntry>
        <inputEntry id="package_rule_3_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="package_rule_3_output_1">
          <text>15000 + ((stayDuration - 7) * 2500)</text>
        </outputEntry>
        <outputEntry id="package_rule_3_output_2">
          <text>1.25</text>
        </outputEntry>
        <outputEntry id="package_rule_3_output_3">
          <text>"DRG_EXTENDED_STAY_PER_DIEM_ADDON"</text>
        </outputEntry>
      </rule>

      <!-- Rule 4: BUNDLE with few procedures -->
      <rule id="package_rule_4">
        <inputEntry id="package_rule_4_input_1">
          <text>"BUNDLE"</text>
        </inputEntry>
        <inputEntry id="package_rule_4_input_2">
          <text>[1..3]</text>
        </inputEntry>
        <inputEntry id="package_rule_4_input_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="package_rule_4_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="package_rule_4_output_1">
          <text>12000</text>
        </outputEntry>
        <outputEntry id="package_rule_4_output_2">
          <text>0.95</text>
        </outputEntry>
        <outputEntry id="package_rule_4_output_3">
          <text>"BUNDLE_SMALL_DISCOUNT_5PCT"</text>
        </outputEntry>
      </rule>

      <!-- Rule 5: BUNDLE with many procedures -->
      <rule id="package_rule_5">
        <inputEntry id="package_rule_5_input_1">
          <text>"BUNDLE"</text>
        </inputEntry>
        <inputEntry id="package_rule_5_input_2">
          <text>&gt; 3</text>
        </inputEntry>
        <inputEntry id="package_rule_5_input_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="package_rule_5_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="package_rule_5_output_1">
          <text>procedureCount * 3500</text>
        </outputEntry>
        <outputEntry id="package_rule_5_output_2">
          <text>0.85</text>
        </outputEntry>
        <outputEntry id="package_rule_5_output_3">
          <text>"BUNDLE_VOLUME_DISCOUNT_15PCT"</text>
        </outputEntry>
      </rule>

      <!-- Rule 6: PER_DIEM standard ICU -->
      <rule id="package_rule_6">
        <inputEntry id="package_rule_6_input_1">
          <text>"PER_DIEM"</text>
        </inputEntry>
        <inputEntry id="package_rule_6_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="package_rule_6_input_3">
          <text>&gt; 0</text>
        </inputEntry>
        <inputEntry id="package_rule_6_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="package_rule_6_output_1">
          <text>stayDuration * 1800</text>
        </outputEntry>
        <outputEntry id="package_rule_6_output_2">
          <text>1.0</text>
        </outputEntry>
        <outputEntry id="package_rule_6_output_3">
          <text>"PER_DIEM_ICU_DAILY_RATE"</text>
        </outputEntry>
      </rule>

      <!-- Rule 7: FEE_FOR_SERVICE individual procedures -->
      <rule id="package_rule_7">
        <inputEntry id="package_rule_7_input_1">
          <text>"FEE_FOR_SERVICE"</text>
        </inputEntry>
        <inputEntry id="package_rule_7_input_2">
          <text>&gt; 0</text>
        </inputEntry>
        <inputEntry id="package_rule_7_input_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="package_rule_7_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="package_rule_7_output_1">
          <text>procedureCount * 950</text>
        </outputEntry>
        <outputEntry id="package_rule_7_output_2">
          <text>1.0</text>
        </outputEntry>
        <outputEntry id="package_rule_7_output_3">
          <text>"FEE_FOR_SERVICE_ITEMIZED"</text>
        </outputEntry>
      </rule>

      <!-- Rule 8: Default fallback -->
      <rule id="package_rule_8">
        <inputEntry id="package_rule_8_input_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="package_rule_8_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="package_rule_8_input_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="package_rule_8_input_4">
          <text>-</text>
        </inputEntry>
        <outputEntry id="package_rule_8_output_1">
          <text>5000</text>
        </outputEntry>
        <outputEntry id="package_rule_8_output_2">
          <text>1.0</text>
        </outputEntry>
        <outputEntry id="package_rule_8_output_3">
          <text>"DEFAULT_MINIMUM_PACKAGE"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
