<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:biodi="http://bpmn.io/schema/dmn/biodi/2.0"
             id="Contract_Rules_Amil_Definitions"
             name="CIB7 Amil Contract Rules"
             namespace="http://cib7.healthcare.br/dmn/billing/amil"
             exporter="CIB7 Healthcare Orchestrator"
             exporterVersion="1.0">
  <decision id="contract_rules_amil" name="Regras de Contrato Amil">
    <description>Regras específicas de cobertura e autorização para Amil (UnitedHealth Group). Inclui produtos S750, S450, S200 e Blue com particularidades da rede referenciada.</description>
    <decisionTable id="contract_amil_table" hitPolicy="FIRST">
      <input id="input_amil_procedure_code" label="Código do Procedimento" camunda:inputVariable="procedureCode">
        <inputExpression id="input_amil_procedure_code_exp" typeRef="string">
          <text>procedureCode</text>
        </inputExpression>
      </input>
      <input id="input_amil_plan_type" label="Tipo de Plano" camunda:inputVariable="planType">
        <inputExpression id="input_amil_plan_type_exp" typeRef="string">
          <text>planType</text>
        </inputExpression>
        <inputValues id="input_amil_plan_type_values">
          <text>"S750","S450","S200","BLUE","FACIL"</text>
        </inputValues>
      </input>
      <input id="input_amil_tenant_id" label="ID do Tenant" camunda:inputVariable="tenantId">
        <inputExpression id="input_amil_tenant_id_exp" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>

      <output id="output_amil_coverage_percentage" label="Percentual de Cobertura" name="coveragePercentage" typeRef="integer"/>
      <output id="output_amil_requires_pre_auth" label="Requer Autorização Prévia" name="requiresPreAuth" typeRef="boolean"/>
      <output id="output_amil_max_reimbursement" label="Reembolso Máximo" name="maxReimbursement" typeRef="double"/>
      <output id="output_amil_special_rules" label="Regras Especiais" name="specialRules" typeRef="string"/>

      <!-- Rule 1: S750 plan - premium tier -->
      <rule id="amil_rule_1">
        <inputEntry id="amil_rule_1_input_1">
          <text>starts with(procedureCode, "3")</text>
        </inputEntry>
        <inputEntry id="amil_rule_1_input_2">
          <text>"S750"</text>
        </inputEntry>
        <inputEntry id="amil_rule_1_input_3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="amil_rule_1_output_1">
          <text>100</text>
        </outputEntry>
        <outputEntry id="amil_rule_1_output_2">
          <text>true</text>
        </outputEntry>
        <outputEntry id="amil_rule_1_output_3">
          <text>90000</text>
        </outputEntry>
        <outputEntry id="amil_rule_1_output_4">
          <text>"S750: cobertura integral cirurgias, reembolso nacional/internacional"</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: S450 plan - high-tier coverage -->
      <rule id="amil_rule_2">
        <inputEntry id="amil_rule_2_input_1">
          <text>starts with(procedureCode, "4")</text>
        </inputEntry>
        <inputEntry id="amil_rule_2_input_2">
          <text>"S450"</text>
        </inputEntry>
        <inputEntry id="amil_rule_2_input_3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="amil_rule_2_output_1">
          <text>90</text>
        </outputEntry>
        <outputEntry id="amil_rule_2_output_2">
          <text>true</text>
        </outputEntry>
        <outputEntry id="amil_rule_2_output_3">
          <text>55000</text>
        </outputEntry>
        <outputEntry id="amil_rule_2_output_4">
          <text>"S450: 90% alta complexidade, autorização via app em 24h"</text>
        </outputEntry>
      </rule>

      <!-- Rule 3: S200 plan - standard coverage -->
      <rule id="amil_rule_3">
        <inputEntry id="amil_rule_3_input_1">
          <text>starts with(procedureCode, "2")</text>
        </inputEntry>
        <inputEntry id="amil_rule_3_input_2">
          <text>"S200"</text>
        </inputEntry>
        <inputEntry id="amil_rule_3_input_3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="amil_rule_3_output_1">
          <text>80</text>
        </outputEntry>
        <outputEntry id="amil_rule_3_output_2">
          <text>false</text>
        </outputEntry>
        <outputEntry id="amil_rule_3_output_3">
          <text>7500</text>
        </outputEntry>
        <outputEntry id="amil_rule_3_output_4">
          <text>"S200: 80% exames, rede credenciada, liberação automática"</text>
        </outputEntry>
      </rule>

      <!-- Rule 4: BLUE plan - corporate managed -->
      <rule id="amil_rule_4">
        <inputEntry id="amil_rule_4_input_1">
          <text>starts with(procedureCode, "10101012")</text>
        </inputEntry>
        <inputEntry id="amil_rule_4_input_2">
          <text>"BLUE"</text>
        </inputEntry>
        <inputEntry id="amil_rule_4_input_3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="amil_rule_4_output_1">
          <text>85</text>
        </outputEntry>
        <outputEntry id="amil_rule_4_output_2">
          <text>false</text>
        </outputEntry>
        <outputEntry id="amil_rule_4_output_3">
          <text>800</text>
        </outputEntry>
        <outputEntry id="amil_rule_4_output_4">
          <text>"Blue: 85% consultas, programa wellness incluído, telemedicina"</text>
        </outputEntry>
      </rule>

      <!-- Rule 5: FACIL plan - simplified access -->
      <rule id="amil_rule_5">
        <inputEntry id="amil_rule_5_input_1">
          <text>starts with(procedureCode, "5")</text>
        </inputEntry>
        <inputEntry id="amil_rule_5_input_2">
          <text>"FACIL"</text>
        </inputEntry>
        <inputEntry id="amil_rule_5_input_3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="amil_rule_5_output_1">
          <text>70</text>
        </outputEntry>
        <outputEntry id="amil_rule_5_output_2">
          <text>true</text>
        </outputEntry>
        <outputEntry id="amil_rule_5_output_3">
          <text>28000</text>
        </outputEntry>
        <outputEntry id="amil_rule_5_output_4">
          <text>"Fácil: 70% terapias, rede básica, autorização simplificada"</text>
        </outputEntry>
      </rule>

      <!-- Rule 6: Transplants and special procedures -->
      <rule id="amil_rule_6">
        <inputEntry id="amil_rule_6_input_1">
          <text>contains(procedureCode, "TRANSPLANTE")</text>
        </inputEntry>
        <inputEntry id="amil_rule_6_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="amil_rule_6_input_3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="amil_rule_6_output_1">
          <text>100</text>
        </outputEntry>
        <outputEntry id="amil_rule_6_output_2">
          <text>true</text>
        </outputEntry>
        <outputEntry id="amil_rule_6_output_3">
          <text>0</text>
        </outputEntry>
        <outputEntry id="amil_rule_6_output_4">
          <text>"Transplantes: cobertura integral por lei, rede especializada obrigatória"</text>
        </outputEntry>
      </rule>

      <!-- Rule 7: Genetic and molecular tests -->
      <rule id="amil_rule_7">
        <inputEntry id="amil_rule_7_input_1">
          <text>contains(procedureCode, "GENETICO")</text>
        </inputEntry>
        <inputEntry id="amil_rule_7_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="amil_rule_7_input_3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="amil_rule_7_output_1">
          <text>75</text>
        </outputEntry>
        <outputEntry id="amil_rule_7_output_2">
          <text>true</text>
        </outputEntry>
        <outputEntry id="amil_rule_7_output_3">
          <text>18000</text>
        </outputEntry>
        <outputEntry id="amil_rule_7_output_4">
          <text>"Testes genéticos: análise de comitê médico, protocolo específico"</text>
        </outputEntry>
      </rule>

      <!-- Rule 8: Default fallback -->
      <rule id="amil_rule_8">
        <inputEntry id="amil_rule_8_input_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="amil_rule_8_input_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="amil_rule_8_input_3">
          <text>-</text>
        </inputEntry>
        <outputEntry id="amil_rule_8_output_1">
          <text>70</text>
        </outputEntry>
        <outputEntry id="amil_rule_8_output_2">
          <text>true</text>
        </outputEntry>
        <outputEntry id="amil_rule_8_output_3">
          <text>15000</text>
        </outputEntry>
        <outputEntry id="amil_rule_8_output_4">
          <text>"Cobertura padrão: verificar rol ANS e guia de utilização"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
