<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="ICU_Admission_Definitions"
             name="Admissão em UTI"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="ICU_Admission_Decision" name="Decisão de Admissão em UTI">
    <decisionTable id="ICU_Admission_Table" hitPolicy="FIRST">
      <input id="ICU_Admission_Input_1" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="ICU_Admission_InputExpression_1" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>
      <input id="ICU_Admission_Input_2" label="Escore APACHE" camunda:inputVariable="apacheScore">
        <inputExpression id="ICU_Admission_InputExpression_2" typeRef="integer">
          <text>apacheScore</text>
        </inputExpression>
      </input>
      <input id="ICU_Admission_Input_3" label="Ventilação Mecânica" camunda:inputVariable="mechanicalVentilation">
        <inputExpression id="ICU_Admission_InputExpression_3" typeRef="boolean">
          <text>mechanicalVentilation</text>
        </inputExpression>
      </input>
      <input id="ICU_Admission_Input_4" label="Drogas Vasoativas" camunda:inputVariable="vasoactiveDrugs">
        <inputExpression id="ICU_Admission_InputExpression_4" typeRef="boolean">
          <text>vasoactiveDrugs</text>
        </inputExpression>
      </input>
      <input id="ICU_Admission_Input_5" label="Complexidade Pós-Cirúrgica" camunda:inputVariable="postSurgicalComplexity">
        <inputExpression id="ICU_Admission_InputExpression_5" typeRef="string">
          <text>postSurgicalComplexity</text>
        </inputExpression>
        <inputValues id="ICU_Admission_InputValues_5">
          <text>"HIGH","MEDIUM","LOW"</text>
        </inputValues>
      </input>
      <input id="ICU_Admission_Input_6" label="Contagem de Falências Orgânicas" camunda:inputVariable="organFailureCount">
        <inputExpression id="ICU_Admission_InputExpression_6" typeRef="integer">
          <text>organFailureCount</text>
        </inputExpression>
      </input>

      <output id="ICU_Admission_Output_1" label="UTI Necessária" name="icuRequired" typeRef="boolean" />
      <output id="ICU_Admission_Output_2" label="Tipo de UTI" name="icuType" typeRef="string">
        <outputValues id="ICU_Admission_OutputValues_2">
          <text>"GENERAL","CARDIAC","NEURO","BURN","NONE"</text>
        </outputValues>
      </output>
      <output id="ICU_Admission_Output_3" label="Prioridade do Leito" name="bedPriority" typeRef="string">
        <outputValues id="ICU_Admission_OutputValues_3">
          <text>"IMMEDIATE","URGENT","ELECTIVE"</text>
        </outputValues>
      </output>
      <output id="ICU_Admission_Output_4" label="Permanência Estimada (dias)" name="estimatedStayDays" typeRef="integer" />

      <!-- UTI Imediata: Ventilação mecânica + drogas vasoativas -->
      <rule id="ICU_Admission_Rule_1">
        <description>Critério imediato - Suporte ventilatório e hemodinâmico simultâneo</description>
        <inputEntry id="ICU_Admission_InputEntry_1_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_1_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_1_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_1_4">
          <text>true</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_1_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_1_6">
          <text>-</text>
        </inputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_1_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_1_2">
          <text>"GENERAL"</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_1_3">
          <text>"IMMEDIATE"</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_1_4">
          <text>7</text>
        </outputEntry>
      </rule>

      <!-- UTI Imediata: APACHE alto -->
      <rule id="ICU_Admission_Rule_2">
        <description>Critério imediato - APACHE score alto indica gravidade extrema</description>
        <inputEntry id="ICU_Admission_InputEntry_2_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_2_2">
          <text>&gt;= 25</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_2_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_2_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_2_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_2_6">
          <text>-</text>
        </inputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_2_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_2_2">
          <text>"GENERAL"</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_2_3">
          <text>"IMMEDIATE"</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_2_4">
          <text>10</text>
        </outputEntry>
      </rule>

      <!-- UTI Imediata: Múltiplas falências orgânicas -->
      <rule id="ICU_Admission_Rule_3">
        <description>Critério imediato - Disfunção de múltiplos órgãos</description>
        <inputEntry id="ICU_Admission_InputEntry_3_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_3_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_3_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_3_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_3_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_3_6">
          <text>&gt;= 3</text>
        </inputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_3_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_3_2">
          <text>"GENERAL"</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_3_3">
          <text>"IMMEDIATE"</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_3_4">
          <text>14</text>
        </outputEntry>
      </rule>

      <!-- UTI Urgente: Pós-operatório complexo -->
      <rule id="ICU_Admission_Rule_4">
        <description>Critério urgente - Pós-operatório de alta complexidade</description>
        <inputEntry id="ICU_Admission_InputEntry_4_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_4_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_4_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_4_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_4_5">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_4_6">
          <text>-</text>
        </inputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_4_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_4_2">
          <text>"GENERAL"</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_4_3">
          <text>"URGENT"</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_4_4">
          <text>5</text>
        </outputEntry>
      </rule>

      <!-- UTI Urgente: Ventilação mecânica isolada -->
      <rule id="ICU_Admission_Rule_5">
        <description>Critério urgente - Necessidade de ventilação mecânica</description>
        <inputEntry id="ICU_Admission_InputEntry_5_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_5_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_5_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_5_4">
          <text>false</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_5_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_5_6">
          <text>-</text>
        </inputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_5_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_5_2">
          <text>"GENERAL"</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_5_3">
          <text>"URGENT"</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_5_4">
          <text>5</text>
        </outputEntry>
      </rule>

      <!-- UTI Urgente: Drogas vasoativas isoladas -->
      <rule id="ICU_Admission_Rule_6">
        <description>Critério urgente - Necessidade de drogas vasoativas</description>
        <inputEntry id="ICU_Admission_InputEntry_6_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_6_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_6_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_6_4">
          <text>true</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_6_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_6_6">
          <text>-</text>
        </inputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_6_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_6_2">
          <text>"GENERAL"</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_6_3">
          <text>"URGENT"</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_6_4">
          <text>4</text>
        </outputEntry>
      </rule>

      <!-- UTI Urgente: APACHE moderado com falência orgânica -->
      <rule id="ICU_Admission_Rule_7">
        <description>Critério urgente - APACHE moderado com disfunção orgânica</description>
        <inputEntry id="ICU_Admission_InputEntry_7_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_7_2">
          <text>&gt;= 15, &lt; 25</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_7_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_7_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_7_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_7_6">
          <text>&gt;= 2</text>
        </inputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_7_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_7_2">
          <text>"GENERAL"</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_7_3">
          <text>"URGENT"</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_7_4">
          <text>6</text>
        </outputEntry>
      </rule>

      <!-- UTI Eletiva: Pós-operatório médio -->
      <rule id="ICU_Admission_Rule_8">
        <description>Critério eletivo - Pós-operatório de complexidade média planejado</description>
        <inputEntry id="ICU_Admission_InputEntry_8_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_8_2">
          <text>&lt; 15</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_8_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_8_4">
          <text>false</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_8_5">
          <text>"MEDIUM"</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_8_6">
          <text>&lt; 2</text>
        </inputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_8_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_8_2">
          <text>"GENERAL"</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_8_3">
          <text>"ELECTIVE"</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_8_4">
          <text>2</text>
        </outputEntry>
      </rule>

      <!-- Sem necessidade de UTI -->
      <rule id="ICU_Admission_Rule_9">
        <description>Sem critério para UTI - Enfermaria ou unidade intermediária suficiente</description>
        <inputEntry id="ICU_Admission_InputEntry_9_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_9_2">
          <text>&lt; 15</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_9_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_9_4">
          <text>false</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_9_5">
          <text>"LOW"</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_9_6">
          <text>&lt; 2</text>
        </inputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_9_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_9_2">
          <text>"NONE"</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_9_3">
          <text>"ELECTIVE"</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_9_4">
          <text>0</text>
        </outputEntry>
      </rule>

      <!-- Regra padrão -->
      <rule id="ICU_Admission_Rule_10">
        <description>Regra padrão - Avaliar caso a caso com intensivista</description>
        <inputEntry id="ICU_Admission_InputEntry_10_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_10_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_10_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_10_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_10_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ICU_Admission_InputEntry_10_6">
          <text>-</text>
        </inputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_10_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_10_2">
          <text>"NONE"</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_10_3">
          <text>"ELECTIVE"</text>
        </outputEntry>
        <outputEntry id="ICU_Admission_OutputEntry_10_4">
          <text>0</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

</definitions>
