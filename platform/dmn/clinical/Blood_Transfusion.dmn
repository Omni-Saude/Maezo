<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Blood_Transfusion_Definitions"
             name="Transfusão Sanguínea"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Blood_Transfusion_Decision" name="Decisão de Transfusão Sanguínea">
    <decisionTable id="Blood_Transfusion_Table" hitPolicy="FIRST">
      <input id="Blood_Transfusion_Input_1" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="Blood_Transfusion_InputExpression_1" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>
      <input id="Blood_Transfusion_Input_2" label="Nível de Hemoglobina (g/dL)" camunda:inputVariable="hemoglobinLevel">
        <inputExpression id="Blood_Transfusion_InputExpression_2" typeRef="double">
          <text>hemoglobinLevel</text>
        </inputExpression>
      </input>
      <input id="Blood_Transfusion_Input_3" label="Sangramento Ativo" camunda:inputVariable="isActiveBleed">
        <inputExpression id="Blood_Transfusion_InputExpression_3" typeRef="boolean">
          <text>isActiveBleed</text>
        </inputExpression>
      </input>
      <input id="Blood_Transfusion_Input_4" label="Pré-Cirúrgico" camunda:inputVariable="isPreSurgery">
        <inputExpression id="Blood_Transfusion_InputExpression_4" typeRef="boolean">
          <text>isPreSurgery</text>
        </inputExpression>
      </input>
      <input id="Blood_Transfusion_Input_5" label="Anemia Sintomática" camunda:inputVariable="symptomaticAnemia">
        <inputExpression id="Blood_Transfusion_InputExpression_5" typeRef="boolean">
          <text>symptomaticAnemia</text>
        </inputExpression>
      </input>

      <output id="Blood_Transfusion_Output_1" label="Transfusão Indicada" name="transfusionIndicated" typeRef="boolean" />
      <output id="Blood_Transfusion_Output_2" label="Unidades Recomendadas" name="unitsRecommended" typeRef="integer" />
      <output id="Blood_Transfusion_Output_3" label="Nível de Urgência" name="urgencyLevel" typeRef="string">
        <outputValues id="Blood_Transfusion_OutputValues_3">
          <text>"IMMEDIATE","URGENT","ROUTINE"</text>
        </outputValues>
      </output>
      <output id="Blood_Transfusion_Output_4" label="Requisitos Especiais" name="specialRequirements" typeRef="string" />

      <!-- Imediata: Sangramento ativo com Hb crítica -->
      <rule id="Blood_Transfusion_Rule_1">
        <description>Transfusão imediata - Sangramento ativo com anemia grave</description>
        <inputEntry id="Blood_Transfusion_InputEntry_1_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_1_2">
          <text>&lt; 7.0</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_1_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_1_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_1_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_1_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_1_2">
          <text>4</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_1_3">
          <text>"IMMEDIATE"</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_1_4">
          <text>"Sangue O negativo disponível, protocolo de hemorragia maciça, avaliar plaquetas e plasma fresco"</text>
        </outputEntry>
      </rule>

      <!-- Imediata: Hb extremamente baixa -->
      <rule id="Blood_Transfusion_Rule_2">
        <description>Transfusão imediata - Hemoglobina crítica independente de sintomas</description>
        <inputEntry id="Blood_Transfusion_InputEntry_2_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_2_2">
          <text>&lt; 6.0</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_2_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_2_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_2_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_2_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_2_2">
          <text>3</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_2_3">
          <text>"IMMEDIATE"</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_2_4">
          <text>"Anemia grave, monitorar sinais vitais continuamente, avaliar fonte de perda"</text>
        </outputEntry>
      </rule>

      <!-- Urgente: Pré-cirúrgico com Hb baixa -->
      <rule id="Blood_Transfusion_Rule_3">
        <description>Transfusão urgente - Otimizar hemoglobina pré-operatória</description>
        <inputEntry id="Blood_Transfusion_InputEntry_3_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_3_2">
          <text>&lt; 8.0</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_3_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_3_4">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_3_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_3_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_3_2">
          <text>2</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_3_3">
          <text>"URGENT"</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_3_4">
          <text>"Otimizar antes de cirurgia, tipagem e prova cruzada, reservar unidades adicionais"</text>
        </outputEntry>
      </rule>

      <!-- Urgente: Sangramento ativo com Hb moderadamente baixa -->
      <rule id="Blood_Transfusion_Rule_4">
        <description>Transfusão urgente - Sangramento com anemia moderada</description>
        <inputEntry id="Blood_Transfusion_InputEntry_4_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_4_2">
          <text>&gt;= 7.0, &lt; 8.0</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_4_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_4_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_4_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_4_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_4_2">
          <text>2</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_4_3">
          <text>"URGENT"</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_4_4">
          <text>"Controlar fonte de sangramento, monitorar hemoglobina a cada 6h, considerar unidades adicionais"</text>
        </outputEntry>
      </rule>

      <!-- Urgente: Anemia sintomática -->
      <rule id="Blood_Transfusion_Rule_5">
        <description>Transfusão urgente - Anemia com sintomas cardiovasculares</description>
        <inputEntry id="Blood_Transfusion_InputEntry_5_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_5_2">
          <text>&lt; 8.0</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_5_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_5_4">
          <text>false</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_5_5">
          <text>true</text>
        </inputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_5_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_5_2">
          <text>2</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_5_3">
          <text>"URGENT"</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_5_4">
          <text>"Sintomas: dispneia, taquicardia, angina. Monitorar resposta clínica, avaliar cardiopatia subjacente"</text>
        </outputEntry>
      </rule>

      <!-- Rotina: Anemia moderada assintomática -->
      <rule id="Blood_Transfusion_Rule_6">
        <description>Transfusão de rotina - Anemia moderada sem instabilidade</description>
        <inputEntry id="Blood_Transfusion_InputEntry_6_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_6_2">
          <text>&gt;= 7.0, &lt; 8.0</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_6_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_6_4">
          <text>false</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_6_5">
          <text>false</text>
        </inputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_6_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_6_2">
          <text>1</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_6_3">
          <text>"ROUTINE"</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_6_4">
          <text>"Considerar alternativas: ferro IV, eritropoietina. Investigar causa da anemia"</text>
        </outputEntry>
      </rule>

      <!-- Rotina: Anemia crônica em preparo cirúrgico -->
      <rule id="Blood_Transfusion_Rule_7">
        <description>Transfusão de rotina planejada - Otimização pré-operatória eletiva</description>
        <inputEntry id="Blood_Transfusion_InputEntry_7_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_7_2">
          <text>&gt;= 8.0, &lt; 10.0</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_7_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_7_4">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_7_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_7_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_7_2">
          <text>1</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_7_3">
          <text>"ROUTINE"</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_7_4">
          <text>"Cirurgia eletiva de grande porte. Considerar estratégias de poupança: eritropoietina, ferro"</text>
        </outputEntry>
      </rule>

      <!-- Sem indicação: Hb aceitável -->
      <rule id="Blood_Transfusion_Rule_8">
        <description>Sem indicação - Hemoglobina acima do limiar transfusional</description>
        <inputEntry id="Blood_Transfusion_InputEntry_8_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_8_2">
          <text>&gt;= 10.0</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_8_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_8_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_8_5">
          <text>false</text>
        </inputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_8_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_8_2">
          <text>0</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_8_3">
          <text>"ROUTINE"</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_8_4">
          <text>"Sem indicação transfusional. Monitorar evolução, tratar causa base da anemia"</text>
        </outputEntry>
      </rule>

      <!-- Regra padrão -->
      <rule id="Blood_Transfusion_Rule_9">
        <description>Avaliação individualizada necessária</description>
        <inputEntry id="Blood_Transfusion_InputEntry_9_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_9_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_9_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_9_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Blood_Transfusion_InputEntry_9_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_9_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_9_2">
          <text>0</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_9_3">
          <text>"ROUTINE"</text>
        </outputEntry>
        <outputEntry id="Blood_Transfusion_OutputEntry_9_4">
          <text>"Avaliar caso individualmente com hematologista, considerar contexto clínico completo"</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

</definitions>
