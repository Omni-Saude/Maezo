<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Clinical_Protocol_Definitions"
             name="Protocolo Clínico"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Clinical_Protocol_Decision" name="Decisão de Protocolo Clínico">
    <decisionTable id="Clinical_Protocol_Table" hitPolicy="FIRST">
      <input id="Clinical_Protocol_Input_1" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="Clinical_Protocol_InputExpression_1" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>
      <input id="Clinical_Protocol_Input_2" label="Categoria Diagnóstica" camunda:inputVariable="diagnosisCategory">
        <inputExpression id="Clinical_Protocol_InputExpression_2" typeRef="string">
          <text>diagnosisCategory</text>
        </inputExpression>
      </input>
      <input id="Clinical_Protocol_Input_3" label="Gravidade" camunda:inputVariable="severity">
        <inputExpression id="Clinical_Protocol_InputExpression_3" typeRef="string">
          <text>severity</text>
        </inputExpression>
        <inputValues id="Clinical_Protocol_InputValues_3">
          <text>"MILD","MODERATE","SEVERE","CRITICAL"</text>
        </inputValues>
      </input>
      <input id="Clinical_Protocol_Input_4" label="Categoria do Paciente" camunda:inputVariable="patientCategory">
        <inputExpression id="Clinical_Protocol_InputExpression_4" typeRef="string">
          <text>patientCategory</text>
        </inputExpression>
        <inputValues id="Clinical_Protocol_InputValues_4">
          <text>"PEDIATRIC","ADULT","GERIATRIC","OBSTETRIC"</text>
        </inputValues>
      </input>
      <input id="Clinical_Protocol_Input_5" label="Contagem de Comorbidades" camunda:inputVariable="comorbidityCount">
        <inputExpression id="Clinical_Protocol_InputExpression_5" typeRef="integer">
          <text>comorbidityCount</text>
        </inputExpression>
      </input>

      <output id="Clinical_Protocol_Output_1" label="Código do Protocolo" name="protocolCode" typeRef="string" />
      <output id="Clinical_Protocol_Output_2" label="Nome do Protocolo" name="protocolName" typeRef="string" />
      <output id="Clinical_Protocol_Output_3" label="Tempo de Internação Esperado (dias)" name="expectedLOS" typeRef="integer" />
      <output id="Clinical_Protocol_Output_4" label="Requer Especialista" name="requiresSpecialist" typeRef="boolean" />

      <!-- Protocolo: IAM crítico -->
      <rule id="Clinical_Protocol_Rule_1">
        <description>Protocolo para infarto agudo do miocárdio com elevação do ST</description>
        <inputEntry id="Clinical_Protocol_InputEntry_1_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_1_2">
          <text>"AMI","STEMI","CARDIAC_ARREST"</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_1_3">
          <text>"CRITICAL","SEVERE"</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_1_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_1_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_1_1">
          <text>"PROT-CARD-001"</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_1_2">
          <text>"Protocolo de Síndrome Coronariana Aguda com Supradesnivelamento de ST"</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_1_3">
          <text>7</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_1_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Protocolo: AVC agudo -->
      <rule id="Clinical_Protocol_Rule_2">
        <description>Protocolo para acidente vascular cerebral isquêmico agudo</description>
        <inputEntry id="Clinical_Protocol_InputEntry_2_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_2_2">
          <text>"STROKE","ISCHEMIC_STROKE","TIA"</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_2_3">
          <text>"SEVERE","CRITICAL"</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_2_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_2_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_2_1">
          <text>"PROT-NEURO-001"</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_2_2">
          <text>"Protocolo de AVC Isquêmico - Janela Terapêutica Trombólise"</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_2_3">
          <text>10</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_2_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Protocolo: Sepse grave/Choque séptico -->
      <rule id="Clinical_Protocol_Rule_3">
        <description>Protocolo para sepse grave e choque séptico</description>
        <inputEntry id="Clinical_Protocol_InputEntry_3_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_3_2">
          <text>"SEPSIS","SEPTIC_SHOCK","SEVERE_INFECTION"</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_3_3">
          <text>"SEVERE","CRITICAL"</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_3_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_3_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_3_1">
          <text>"PROT-INFEC-001"</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_3_2">
          <text>"Protocolo de Sepse - Bundle 1 hora e 6 horas"</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_3_3">
          <text>14</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_3_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Protocolo: Trauma grave -->
      <rule id="Clinical_Protocol_Rule_4">
        <description>Protocolo ATLS para politraumatismo</description>
        <inputEntry id="Clinical_Protocol_InputEntry_4_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_4_2">
          <text>"POLYTRAUMA","SEVERE_TRAUMA","HEAD_INJURY"</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_4_3">
          <text>"SEVERE","CRITICAL"</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_4_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_4_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_4_1">
          <text>"PROT-TRAUMA-001"</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_4_2">
          <text>"Protocolo ATLS - Advanced Trauma Life Support"</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_4_3">
          <text>12</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_4_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Protocolo: Parto/Obstetrícia -->
      <rule id="Clinical_Protocol_Rule_5">
        <description>Protocolo obstétrico para trabalho de parto e complicações</description>
        <inputEntry id="Clinical_Protocol_InputEntry_5_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_5_2">
          <text>"LABOR","DELIVERY","PREECLAMPSIA","ECLAMPSIA"</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_5_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_5_4">
          <text>"OBSTETRIC"</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_5_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_5_1">
          <text>"PROT-OBST-001"</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_5_2">
          <text>"Protocolo Obstétrico - Trabalho de Parto e Emergências Obstétricas"</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_5_3">
          <text>3</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_5_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Protocolo: Pediatria emergência -->
      <rule id="Clinical_Protocol_Rule_6">
        <description>Protocolo de emergência pediátrica</description>
        <inputEntry id="Clinical_Protocol_InputEntry_6_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_6_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_6_3">
          <text>"SEVERE","CRITICAL"</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_6_4">
          <text>"PEDIATRIC"</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_6_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_6_1">
          <text>"PROT-PED-001"</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_6_2">
          <text>"Protocolo de Emergência Pediátrica - PALS"</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_6_3">
          <text>5</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_6_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Protocolo: Pneumonia comunitária complexa -->
      <rule id="Clinical_Protocol_Rule_7">
        <description>Protocolo para pneumonia comunitária com comorbidades</description>
        <inputEntry id="Clinical_Protocol_InputEntry_7_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_7_2">
          <text>"PNEUMONIA","CAP","RESPIRATORY_INFECTION"</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_7_3">
          <text>"MODERATE","SEVERE"</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_7_4">
          <text>"GERIATRIC","ADULT"</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_7_5">
          <text>&gt;= 2</text>
        </inputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_7_1">
          <text>"PROT-RESP-001"</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_7_2">
          <text>"Protocolo de Pneumonia Comunitária - Estratificação CURB-65"</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_7_3">
          <text>7</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_7_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Protocolo: ICC descompensada -->
      <rule id="Clinical_Protocol_Rule_8">
        <description>Protocolo para insuficiência cardíaca congestiva descompensada</description>
        <inputEntry id="Clinical_Protocol_InputEntry_8_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_8_2">
          <text>"CHF","HEART_FAILURE","PULMONARY_EDEMA"</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_8_3">
          <text>"MODERATE","SEVERE"</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_8_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_8_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_8_1">
          <text>"PROT-CARD-002"</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_8_2">
          <text>"Protocolo de Insuficiência Cardíaca Descompensada"</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_8_3">
          <text>6</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_8_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Protocolo: Condição leve geral -->
      <rule id="Clinical_Protocol_Rule_9">
        <description>Protocolo de observação para condições leves sem complicações</description>
        <inputEntry id="Clinical_Protocol_InputEntry_9_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_9_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_9_3">
          <text>"MILD"</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_9_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_9_5">
          <text>&lt; 2</text>
        </inputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_9_1">
          <text>"PROT-GEN-001"</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_9_2">
          <text>"Protocolo de Observação Clínica - Condições Leves"</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_9_3">
          <text>2</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_9_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Protocolo padrão -->
      <rule id="Clinical_Protocol_Rule_10">
        <description>Protocolo genérico para situações não especificadas</description>
        <inputEntry id="Clinical_Protocol_InputEntry_10_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_10_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_10_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_10_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Clinical_Protocol_InputEntry_10_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_10_1">
          <text>"PROT-GEN-999"</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_10_2">
          <text>"Protocolo Padrão - Avaliar individualmente"</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_10_3">
          <text>5</text>
        </outputEntry>
        <outputEntry id="Clinical_Protocol_OutputEntry_10_4">
          <text>false</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

</definitions>
