<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Medication_Interaction_Definitions"
             name="Interação Medicamentosa"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Medication_Interaction_Decision" name="Decisão de Interação Medicamentosa">
    <decisionTable id="Medication_Interaction_Table" hitPolicy="FIRST">
      <input id="Medication_Interaction_Input_1" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="Medication_Interaction_InputExpression_1" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>
      <input id="Medication_Interaction_Input_2" label="Classe do Medicamento A" camunda:inputVariable="drugClassA">
        <inputExpression id="Medication_Interaction_InputExpression_2" typeRef="string">
          <text>drugClassA</text>
        </inputExpression>
      </input>
      <input id="Medication_Interaction_Input_3" label="Classe do Medicamento B" camunda:inputVariable="drugClassB">
        <inputExpression id="Medication_Interaction_InputExpression_3" typeRef="string">
          <text>drugClassB</text>
        </inputExpression>
      </input>
      <input id="Medication_Interaction_Input_4" label="Faixa Etária do Paciente" camunda:inputVariable="patientAge">
        <inputExpression id="Medication_Interaction_InputExpression_4" typeRef="string">
          <text>patientAge</text>
        </inputExpression>
        <inputValues id="Medication_Interaction_InputValues_4">
          <text>"PEDIATRIC","ADULT","GERIATRIC"</text>
        </inputValues>
      </input>
      <input id="Medication_Interaction_Input_5" label="Função Renal" camunda:inputVariable="renalFunction">
        <inputExpression id="Medication_Interaction_InputExpression_5" typeRef="string">
          <text>renalFunction</text>
        </inputExpression>
        <inputValues id="Medication_Interaction_InputValues_5">
          <text>"NORMAL","MILD_IMPAIRMENT","MODERATE","SEVERE"</text>
        </inputValues>
      </input>

      <output id="Medication_Interaction_Output_1" label="Gravidade da Interação" name="interactionSeverity" typeRef="string">
        <outputValues id="Medication_Interaction_OutputValues_1">
          <text>"CONTRAINDICATED","MAJOR","MODERATE","MINOR","NONE"</text>
        </outputValues>
      </output>
      <output id="Medication_Interaction_Output_2" label="Recomendação" name="recommendation" typeRef="string" />
      <output id="Medication_Interaction_Output_3" label="Requer Revisão Farmacêutica" name="requiresPharmacistReview" typeRef="boolean" />

      <!-- Contraindicado: Varfarina + AINEs -->
      <rule id="Medication_Interaction_Rule_1">
        <description>Contraindicado - Risco hemorrágico grave com anticoagulantes e AINEs</description>
        <inputEntry id="Medication_Interaction_InputEntry_1_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_1_2">
          <text>"ANTICOAGULANT","WARFARIN"</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_1_3">
          <text>"NSAID","IBUPROFEN","DICLOFENAC","ASPIRIN"</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_1_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_1_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_1_1">
          <text>"CONTRAINDICATED"</text>
        </outputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_1_2">
          <text>"CONTRAINDICADO: Risco hemorrágico grave. Substituir AINE por analgésico alternativo (paracetamol). Se AINE essencial, monitorar INR rigorosamente."</text>
        </outputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_1_3">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Contraindicado: IECA + Espironolactona em insuficiência renal -->
      <rule id="Medication_Interaction_Rule_2">
        <description>Contraindicado - Risco de hipercalemia grave em paciente com função renal comprometida</description>
        <inputEntry id="Medication_Interaction_InputEntry_2_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_2_2">
          <text>"ACE_INHIBITOR","ENALAPRIL","CAPTOPRIL"</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_2_3">
          <text>"POTASSIUM_SPARING_DIURETIC","SPIRONOLACTONE"</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_2_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_2_5">
          <text>"MODERATE","SEVERE"</text>
        </inputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_2_1">
          <text>"CONTRAINDICATED"</text>
        </outputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_2_2">
          <text>"CONTRAINDICADO: Risco elevado de hipercalemia grave em insuficiência renal. Evitar combinação ou monitorar potássio sérico diariamente."</text>
        </outputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_2_3">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Maior: Benzodiazepínicos + Opioides -->
      <rule id="Medication_Interaction_Rule_3">
        <description>Interação maior - Depressão respiratória significativa, especialmente em idosos</description>
        <inputEntry id="Medication_Interaction_InputEntry_3_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_3_2">
          <text>"BENZODIAZEPINE","DIAZEPAM","MIDAZOLAM"</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_3_3">
          <text>"OPIOID","MORPHINE","FENTANYL","TRAMADOL"</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_3_4">
          <text>"GERIATRIC"</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_3_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_3_1">
          <text>"MAJOR"</text>
        </outputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_3_2">
          <text>"INTERAÇÃO MAIOR: Risco aumentado de depressão respiratória em idoso. Reduzir doses, monitorar saturação O2 e nível de consciência. Considerar alternativas."</text>
        </outputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_3_3">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Maior: Digoxina + Aminoglicosídeo em insuficiência renal -->
      <rule id="Medication_Interaction_Rule_4">
        <description>Interação maior - Risco de toxicidade digitalica por competição de eliminação renal</description>
        <inputEntry id="Medication_Interaction_InputEntry_4_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_4_2">
          <text>"CARDIAC_GLYCOSIDE","DIGOXIN"</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_4_3">
          <text>"AMINOGLYCOSIDE","GENTAMICIN","AMIKACIN"</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_4_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_4_5">
          <text>"MILD_IMPAIRMENT","MODERATE","SEVERE"</text>
        </inputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_4_1">
          <text>"MAJOR"</text>
        </outputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_4_2">
          <text>"INTERAÇÃO MAIOR: Risco de toxicidade digitalica. Monitorar digoxinemia, potássio sérico e função renal. Ajustar doses conforme clearance."</text>
        </outputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_4_3">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Moderada: Omeprazol + Clopidogrel -->
      <rule id="Medication_Interaction_Rule_5">
        <description>Interação moderada - Redução da eficácia antiagregante por inibição do CYP2C19</description>
        <inputEntry id="Medication_Interaction_InputEntry_5_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_5_2">
          <text>"PROTON_PUMP_INHIBITOR","OMEPRAZOLE","ESOMEPRAZOLE"</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_5_3">
          <text>"ANTIPLATELET","CLOPIDOGREL"</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_5_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_5_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_5_1">
          <text>"MODERATE"</text>
        </outputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_5_2">
          <text>"INTERAÇÃO MODERADA: Possível redução do efeito antiagregante. Considerar substituir por pantoprazol ou aumentar intervalo de administração (12h)."</text>
        </outputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_5_3">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Moderada: Fluoroquinolona + Corticoide em idoso -->
      <rule id="Medication_Interaction_Rule_6">
        <description>Interação moderada - Risco aumentado de ruptura tendinosa em idoso</description>
        <inputEntry id="Medication_Interaction_InputEntry_6_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_6_2">
          <text>"FLUOROQUINOLONE","CIPROFLOXACIN","LEVOFLOXACIN"</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_6_3">
          <text>"CORTICOSTEROID","PREDNISONE","DEXAMETHASONE"</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_6_4">
          <text>"GERIATRIC"</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_6_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_6_1">
          <text>"MODERATE"</text>
        </outputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_6_2">
          <text>"INTERAÇÃO MODERADA: Risco aumentado de tendinite/ruptura em idoso. Orientar repouso relativo, evitar exercício intenso, suspender se dor articular."</text>
        </outputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_6_3">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Menor: Metformina + IECA -->
      <rule id="Medication_Interaction_Rule_7">
        <description>Interação menor - Possível aumento do efeito hipoglicemiante, geralmente bem tolerado</description>
        <inputEntry id="Medication_Interaction_InputEntry_7_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_7_2">
          <text>"BIGUANIDE","METFORMIN"</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_7_3">
          <text>"ACE_INHIBITOR","ENALAPRIL","CAPTOPRIL"</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_7_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_7_5">
          <text>"NORMAL","MILD_IMPAIRMENT"</text>
        </inputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_7_1">
          <text>"MINOR"</text>
        </outputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_7_2">
          <text>"INTERAÇÃO MENOR: Possível potencialização do efeito hipoglicemiante. Monitorar glicemia nos primeiros dias. Ajuste de dose raramente necessário."</text>
        </outputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_7_3">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Menor: Levotiroxina + Carbonato de cálcio -->
      <rule id="Medication_Interaction_Rule_8">
        <description>Interação menor - Redução da absorção por quelação, facilmente gerenciável</description>
        <inputEntry id="Medication_Interaction_InputEntry_8_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_8_2">
          <text>"THYROID_HORMONE","LEVOTHYROXINE"</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_8_3">
          <text>"CALCIUM_SUPPLEMENT","CALCIUM_CARBONATE"</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_8_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_8_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_8_1">
          <text>"MINOR"</text>
        </outputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_8_2">
          <text>"INTERAÇÃO MENOR: Administrar levotiroxina em jejum e cálcio após refeições (intervalo mínimo 4h). Monitorar TSH em 6-8 semanas."</text>
        </outputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_8_3">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Sem interação significativa -->
      <rule id="Medication_Interaction_Rule_9">
        <description>Sem interação clinicamente significativa documentada</description>
        <inputEntry id="Medication_Interaction_InputEntry_9_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_9_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_9_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_9_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Medication_Interaction_InputEntry_9_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_9_1">
          <text>"NONE"</text>
        </outputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_9_2">
          <text>"SEM INTERAÇÃO: Não há interação clinicamente significativa documentada entre estas classes de medicamentos. Seguir prescrição padrão."</text>
        </outputEntry>
        <outputEntry id="Medication_Interaction_OutputEntry_9_3">
          <text>false</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

</definitions>
