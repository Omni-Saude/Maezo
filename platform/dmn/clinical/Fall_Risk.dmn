<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Fall_Risk_Definitions"
             name="Risco de Queda"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Fall_Risk_Decision" name="Decisão de Risco de Queda">
    <decisionTable id="Fall_Risk_Table" hitPolicy="COLLECT" aggregation="SUM">
      <input id="Fall_Risk_Input_1" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="Fall_Risk_InputExpression_1" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>
      <input id="Fall_Risk_Input_2" label="Histórico de Quedas" camunda:inputVariable="historyOfFalls">
        <inputExpression id="Fall_Risk_InputExpression_2" typeRef="boolean">
          <text>historyOfFalls</text>
        </inputExpression>
      </input>
      <input id="Fall_Risk_Input_3" label="Diagnóstico Secundário" camunda:inputVariable="secondaryDiagnosis">
        <inputExpression id="Fall_Risk_InputExpression_3" typeRef="boolean">
          <text>secondaryDiagnosis</text>
        </inputExpression>
      </input>
      <input id="Fall_Risk_Input_4" label="Auxílio para Deambulação" camunda:inputVariable="ambulatoryAid">
        <inputExpression id="Fall_Risk_InputExpression_4" typeRef="string">
          <text>ambulatoryAid</text>
        </inputExpression>
        <inputValues id="Fall_Risk_InputValues_4">
          <text>"NONE","CRUTCH","FURNITURE","WHEELCHAIR"</text>
        </inputValues>
      </input>
      <input id="Fall_Risk_Input_5" label="Acesso Venoso/Heparina" camunda:inputVariable="ivAccess">
        <inputExpression id="Fall_Risk_InputExpression_5" typeRef="boolean">
          <text>ivAccess</text>
        </inputExpression>
      </input>
      <input id="Fall_Risk_Input_6" label="Marcha" camunda:inputVariable="gaitImpairment">
        <inputExpression id="Fall_Risk_InputExpression_6" typeRef="string">
          <text>gaitImpairment</text>
        </inputExpression>
        <inputValues id="Fall_Risk_InputValues_6">
          <text>"NORMAL","WEAK","IMPAIRED"</text>
        </inputValues>
      </input>
      <input id="Fall_Risk_Input_7" label="Estado Mental" camunda:inputVariable="mentalStatus">
        <inputExpression id="Fall_Risk_InputExpression_7" typeRef="string">
          <text>mentalStatus</text>
        </inputExpression>
        <inputValues id="Fall_Risk_InputValues_7">
          <text>"ORIENTED","CONFUSED"</text>
        </inputValues>
      </input>

      <output id="Fall_Risk_Output_1" label="Pontuação Morse" name="morseScore" typeRef="integer" />

      <!-- Histórico de quedas: 25 pontos -->
      <rule id="Fall_Risk_Rule_1">
        <description>Histórico de quedas nos últimos 3 meses</description>
        <inputEntry id="Fall_Risk_InputEntry_1_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_1_2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_1_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_1_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_1_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_1_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_1_7">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Fall_Risk_OutputEntry_1_1">
          <text>25</text>
        </outputEntry>
      </rule>

      <!-- Diagnóstico secundário: 15 pontos -->
      <rule id="Fall_Risk_Rule_2">
        <description>Presença de diagnóstico secundário</description>
        <inputEntry id="Fall_Risk_InputEntry_2_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_2_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_2_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_2_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_2_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_2_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_2_7">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Fall_Risk_OutputEntry_2_1">
          <text>15</text>
        </outputEntry>
      </rule>

      <!-- Auxílio para deambulação - Muletas/bengala: 15 pontos -->
      <rule id="Fall_Risk_Rule_3">
        <description>Uso de muletas, bengala ou andador</description>
        <inputEntry id="Fall_Risk_InputEntry_3_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_3_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_3_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_3_4">
          <text>"CRUTCH"</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_3_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_3_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_3_7">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Fall_Risk_OutputEntry_3_1">
          <text>15</text>
        </outputEntry>
      </rule>

      <!-- Auxílio para deambulação - Mobília: 30 pontos -->
      <rule id="Fall_Risk_Rule_4">
        <description>Apoia-se em mobília para deambular</description>
        <inputEntry id="Fall_Risk_InputEntry_4_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_4_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_4_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_4_4">
          <text>"FURNITURE"</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_4_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_4_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_4_7">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Fall_Risk_OutputEntry_4_1">
          <text>30</text>
        </outputEntry>
      </rule>

      <!-- Acesso venoso/heparina: 20 pontos -->
      <rule id="Fall_Risk_Rule_5">
        <description>Terapia intravenosa ou dispositivo de heparina lock</description>
        <inputEntry id="Fall_Risk_InputEntry_5_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_5_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_5_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_5_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_5_5">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_5_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_5_7">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Fall_Risk_OutputEntry_5_1">
          <text>20</text>
        </outputEntry>
      </rule>

      <!-- Marcha fraca: 10 pontos -->
      <rule id="Fall_Risk_Rule_6">
        <description>Marcha fraca, passos curtos</description>
        <inputEntry id="Fall_Risk_InputEntry_6_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_6_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_6_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_6_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_6_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_6_6">
          <text>"WEAK"</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_6_7">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Fall_Risk_OutputEntry_6_1">
          <text>10</text>
        </outputEntry>
      </rule>

      <!-- Marcha comprometida: 20 pontos -->
      <rule id="Fall_Risk_Rule_7">
        <description>Marcha comprometida, desequilíbrio</description>
        <inputEntry id="Fall_Risk_InputEntry_7_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_7_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_7_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_7_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_7_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_7_6">
          <text>"IMPAIRED"</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_7_7">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Fall_Risk_OutputEntry_7_1">
          <text>20</text>
        </outputEntry>
      </rule>

      <!-- Estado mental confuso: 15 pontos -->
      <rule id="Fall_Risk_Rule_8">
        <description>Estado mental confuso, desorientado</description>
        <inputEntry id="Fall_Risk_InputEntry_8_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_8_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_8_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_8_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_8_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_8_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Fall_Risk_InputEntry_8_7">
          <text>"CONFUSED"</text>
        </inputEntry>
        <outputEntry id="Fall_Risk_OutputEntry_8_1">
          <text>15</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <!-- Decisão para interpretar o score -->
  <decision id="Fall_Risk_Interpretation_Decision" name="Interpretação do Risco de Queda">
    <informationRequirement>
      <requiredDecision href="#Fall_Risk_Decision"/>
    </informationRequirement>
    <decisionTable id="Fall_Risk_Interpretation_Table" hitPolicy="FIRST">
      <input id="Fall_Risk_Interpretation_Input_1" label="Escore Morse">
        <inputExpression id="Fall_Risk_Interpretation_InputExpression_1" typeRef="integer">
          <text>morseScore</text>
        </inputExpression>
      </input>

      <output id="Fall_Risk_Interpretation_Output_1" label="Nível de Risco" name="fallRiskLevel" typeRef="string">
        <outputValues id="Fall_Risk_Interpretation_OutputValues_1">
          <text>"HIGH","MODERATE","LOW"</text>
        </outputValues>
      </output>
      <output id="Fall_Risk_Interpretation_Output_2" label="Protocolo de Prevenção" name="preventionProtocol" typeRef="string" />
      <output id="Fall_Risk_Interpretation_Output_3" label="Alocação de Quarto" name="roomAssignment" typeRef="string" />

      <!-- Alto risco: >= 45 pontos -->
      <rule id="Fall_Risk_Interpretation_Rule_1">
        <description>Alto risco de queda</description>
        <inputEntry id="Fall_Risk_Interpretation_InputEntry_1_1">
          <text>&gt;= 45</text>
        </inputEntry>
        <outputEntry id="Fall_Risk_Interpretation_OutputEntry_1_1">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="Fall_Risk_Interpretation_OutputEntry_1_2">
          <text>"Protocolo alto risco: pulseira amarela, grades elevadas, alarme de cama, acompanhante 24h, fisioterapia diária, supervisão em transferências"</text>
        </outputEntry>
        <outputEntry id="Fall_Risk_Interpretation_OutputEntry_1_3">
          <text>"Quarto próximo ao posto de enfermagem, preferencialmente térreo, banheiro adaptado"</text>
        </outputEntry>
      </rule>

      <!-- Risco moderado: 25-44 pontos -->
      <rule id="Fall_Risk_Interpretation_Rule_2">
        <description>Risco moderado de queda</description>
        <inputEntry id="Fall_Risk_Interpretation_InputEntry_2_1">
          <text>&gt;= 25, &lt; 45</text>
        </inputEntry>
        <outputEntry id="Fall_Risk_Interpretation_OutputEntry_2_1">
          <text>"MODERATE"</text>
        </outputEntry>
        <outputEntry id="Fall_Risk_Interpretation_OutputEntry_2_2">
          <text>"Protocolo risco moderado: pulseira amarela, campainha acessível, calçado antiderrapante, orientação sobre riscos, assistência em deambulação"</text>
        </outputEntry>
        <outputEntry id="Fall_Risk_Interpretation_OutputEntry_2_3">
          <text>"Quarto com fácil acesso ao banheiro, iluminação adequada, corredores desobstruídos"</text>
        </outputEntry>
      </rule>

      <!-- Baixo risco: < 25 pontos -->
      <rule id="Fall_Risk_Interpretation_Rule_3">
        <description>Baixo risco de queda</description>
        <inputEntry id="Fall_Risk_Interpretation_InputEntry_3_1">
          <text>&lt; 25</text>
        </inputEntry>
        <outputEntry id="Fall_Risk_Interpretation_OutputEntry_3_1">
          <text>"LOW"</text>
        </outputEntry>
        <outputEntry id="Fall_Risk_Interpretation_OutputEntry_3_2">
          <text>"Protocolo padrão: orientações gerais de segurança, manter ambiente organizado, estimular deambulação segura"</text>
        </outputEntry>
        <outputEntry id="Fall_Risk_Interpretation_OutputEntry_3_3">
          <text>"Quarto padrão, sem restrições especiais"</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

</definitions>
