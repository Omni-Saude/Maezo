<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Pressure_Injury_Risk_Definitions"
             name="Risco de Lesão por Pressão"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Pressure_Injury_Risk_Decision" name="Decisão de Risco de Lesão por Pressão">
    <decisionTable id="Pressure_Injury_Risk_Table" hitPolicy="COLLECT" aggregation="SUM">
      <input id="Pressure_Injury_Risk_Input_1" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="Pressure_Injury_Risk_InputExpression_1" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>
      <input id="Pressure_Injury_Risk_Input_2" label="Percepção Sensorial (1-4)" camunda:inputVariable="sensoryPerception">
        <inputExpression id="Pressure_Injury_Risk_InputExpression_2" typeRef="integer">
          <text>sensoryPerception</text>
        </inputExpression>
      </input>
      <input id="Pressure_Injury_Risk_Input_3" label="Umidade (1-4)" camunda:inputVariable="moisture">
        <inputExpression id="Pressure_Injury_Risk_InputExpression_3" typeRef="integer">
          <text>moisture</text>
        </inputExpression>
      </input>
      <input id="Pressure_Injury_Risk_Input_4" label="Atividade (1-4)" camunda:inputVariable="activity">
        <inputExpression id="Pressure_Injury_Risk_InputExpression_4" typeRef="integer">
          <text>activity</text>
        </inputExpression>
      </input>
      <input id="Pressure_Injury_Risk_Input_5" label="Mobilidade (1-4)" camunda:inputVariable="mobility">
        <inputExpression id="Pressure_Injury_Risk_InputExpression_5" typeRef="integer">
          <text>mobility</text>
        </inputExpression>
      </input>
      <input id="Pressure_Injury_Risk_Input_6" label="Nutrição (1-4)" camunda:inputVariable="nutrition">
        <inputExpression id="Pressure_Injury_Risk_InputExpression_6" typeRef="integer">
          <text>nutrition</text>
        </inputExpression>
      </input>
      <input id="Pressure_Injury_Risk_Input_7" label="Fricção e Cisalhamento (1-3)" camunda:inputVariable="frictionShear">
        <inputExpression id="Pressure_Injury_Risk_InputExpression_7" typeRef="integer">
          <text>frictionShear</text>
        </inputExpression>
      </input>

      <output id="Pressure_Injury_Risk_Output_1" label="Pontuação Braden" name="bradenScore" typeRef="integer" />

      <!-- Percepção sensorial -->
      <rule id="Pressure_Injury_Risk_Rule_1">
        <description>Pontuação de percepção sensorial</description>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_1_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_1_2">
          <text>&gt;= 1, &lt;= 4</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_1_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_1_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_1_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_1_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_1_7">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Pressure_Injury_Risk_OutputEntry_1_1">
          <text>sensoryPerception</text>
        </outputEntry>
      </rule>

      <!-- Umidade -->
      <rule id="Pressure_Injury_Risk_Rule_2">
        <description>Pontuação de umidade</description>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_2_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_2_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_2_3">
          <text>&gt;= 1, &lt;= 4</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_2_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_2_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_2_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_2_7">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Pressure_Injury_Risk_OutputEntry_2_1">
          <text>moisture</text>
        </outputEntry>
      </rule>

      <!-- Atividade -->
      <rule id="Pressure_Injury_Risk_Rule_3">
        <description>Pontuação de atividade</description>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_3_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_3_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_3_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_3_4">
          <text>&gt;= 1, &lt;= 4</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_3_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_3_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_3_7">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Pressure_Injury_Risk_OutputEntry_3_1">
          <text>activity</text>
        </outputEntry>
      </rule>

      <!-- Mobilidade -->
      <rule id="Pressure_Injury_Risk_Rule_4">
        <description>Pontuação de mobilidade</description>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_4_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_4_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_4_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_4_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_4_5">
          <text>&gt;= 1, &lt;= 4</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_4_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_4_7">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Pressure_Injury_Risk_OutputEntry_4_1">
          <text>mobility</text>
        </outputEntry>
      </rule>

      <!-- Nutrição -->
      <rule id="Pressure_Injury_Risk_Rule_5">
        <description>Pontuação de nutrição</description>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_5_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_5_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_5_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_5_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_5_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_5_6">
          <text>&gt;= 1, &lt;= 4</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_5_7">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Pressure_Injury_Risk_OutputEntry_5_1">
          <text>nutrition</text>
        </outputEntry>
      </rule>

      <!-- Fricção e cisalhamento -->
      <rule id="Pressure_Injury_Risk_Rule_6">
        <description>Pontuação de fricção e cisalhamento</description>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_6_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_6_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_6_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_6_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_6_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_6_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Pressure_Injury_Risk_InputEntry_6_7">
          <text>&gt;= 1, &lt;= 3</text>
        </inputEntry>
        <outputEntry id="Pressure_Injury_Risk_OutputEntry_6_1">
          <text>frictionShear</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <!-- Decisão para interpretar o score Braden -->
  <decision id="Pressure_Injury_Risk_Interpretation_Decision" name="Interpretação do Risco de Lesão por Pressão">
    <informationRequirement>
      <requiredDecision href="#Pressure_Injury_Risk_Decision"/>
    </informationRequirement>
    <decisionTable id="Pressure_Injury_Risk_Interpretation_Table" hitPolicy="FIRST">
      <input id="Pressure_Injury_Risk_Interpretation_Input_1" label="Escore Braden">
        <inputExpression id="Pressure_Injury_Risk_Interpretation_InputExpression_1" typeRef="integer">
          <text>bradenScore</text>
        </inputExpression>
      </input>

      <output id="Pressure_Injury_Risk_Interpretation_Output_1" label="Nível de Risco" name="riskLevel" typeRef="string">
        <outputValues id="Pressure_Injury_Risk_Interpretation_OutputValues_1">
          <text>"VERY_HIGH","HIGH","MODERATE","LOW"</text>
        </outputValues>
      </output>
      <output id="Pressure_Injury_Risk_Interpretation_Output_2" label="Bundle de Prevenção" name="preventionBundle" typeRef="string" />
      <output id="Pressure_Injury_Risk_Interpretation_Output_3" label="Reavaliação (horas)" name="reassessmentHours" typeRef="integer" />

      <!-- Risco muito alto: <= 9 -->
      <rule id="Pressure_Injury_Risk_Interpretation_Rule_1">
        <description>Risco muito alto de lesão por pressão</description>
        <inputEntry id="Pressure_Injury_Risk_Interpretation_InputEntry_1_1">
          <text>&lt;= 9</text>
        </inputEntry>
        <outputEntry id="Pressure_Injury_Risk_Interpretation_OutputEntry_1_1">
          <text>"VERY_HIGH"</text>
        </outputEntry>
        <outputEntry id="Pressure_Injury_Risk_Interpretation_OutputEntry_1_2">
          <text>"Bundle completo: colchão de redistribuição de pressão avançado (low-air-loss ou air-fluidized), mudança de decúbito 2/2h com documentação rigorosa, coxins de posicionamento, película protetora de pele, AGE proteico, avaliação nutricional especializada, fisioterapia motora, vigilância de áreas de pressão em cada turno"</text>
        </outputEntry>
        <outputEntry id="Pressure_Injury_Risk_Interpretation_OutputEntry_1_3">
          <text>8</text>
        </outputEntry>
      </rule>

      <!-- Risco alto: 10-12 -->
      <rule id="Pressure_Injury_Risk_Interpretation_Rule_2">
        <description>Risco alto de lesão por pressão</description>
        <inputEntry id="Pressure_Injury_Risk_Interpretation_InputEntry_2_1">
          <text>&gt;= 10, &lt;= 12</text>
        </inputEntry>
        <outputEntry id="Pressure_Injury_Risk_Interpretation_OutputEntry_2_1">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="Pressure_Injury_Risk_Interpretation_OutputEntry_2_2">
          <text>"Bundle intensivo: colchão de redistribuição de pressão (espuma viscoelástica de alta densidade ou caixa de ovo), mudança de decúbito 2/2h documentada, elevação de calcâneos, hidratação de pele, AGE proteico se necessário, inspeção de pele em cada turno, minimizar fricção em transferências"</text>
        </outputEntry>
        <outputEntry id="Pressure_Injury_Risk_Interpretation_OutputEntry_2_3">
          <text>12</text>
        </outputEntry>
      </rule>

      <!-- Risco moderado: 13-14 -->
      <rule id="Pressure_Injury_Risk_Interpretation_Rule_3">
        <description>Risco moderado de lesão por pressão</description>
        <inputEntry id="Pressure_Injury_Risk_Interpretation_InputEntry_3_1">
          <text>&gt;= 13, &lt;= 14</text>
        </inputEntry>
        <outputEntry id="Pressure_Injury_Risk_Interpretation_OutputEntry_3_1">
          <text>"MODERATE"</text>
        </outputEntry>
        <outputEntry id="Pressure_Injury_Risk_Interpretation_OutputEntry_3_2">
          <text>"Bundle moderado: colchão de espuma de 10cm, mudança de decúbito 3/3h, hidratação de pele, inspeção de proeminências ósseas 2x/dia, estimular mobilização ativa, otimizar nutrição, orientar paciente/família"</text>
        </outputEntry>
        <outputEntry id="Pressure_Injury_Risk_Interpretation_OutputEntry_3_3">
          <text>24</text>
        </outputEntry>
      </rule>

      <!-- Risco baixo: 15-18 -->
      <rule id="Pressure_Injury_Risk_Interpretation_Rule_4">
        <description>Risco baixo de lesão por pressão</description>
        <inputEntry id="Pressure_Injury_Risk_Interpretation_InputEntry_4_1">
          <text>&gt;= 15, &lt;= 18</text>
        </inputEntry>
        <outputEntry id="Pressure_Injury_Risk_Interpretation_OutputEntry_4_1">
          <text>"LOW"</text>
        </outputEntry>
        <outputEntry id="Pressure_Injury_Risk_Interpretation_OutputEntry_4_2">
          <text>"Bundle básico: colchão hospitalar padrão adequado, estimular mudanças de posição frequentes, inspeção de pele diária, hidratação de pele, manter nutrição adequada, educar sobre mobilização"</text>
        </outputEntry>
        <outputEntry id="Pressure_Injury_Risk_Interpretation_OutputEntry_4_3">
          <text>48</text>
        </outputEntry>
      </rule>

      <!-- Sem risco: >= 19 -->
      <rule id="Pressure_Injury_Risk_Interpretation_Rule_5">
        <description>Sem risco significativo de lesão por pressão</description>
        <inputEntry id="Pressure_Injury_Risk_Interpretation_InputEntry_5_1">
          <text>&gt;= 19</text>
        </inputEntry>
        <outputEntry id="Pressure_Injury_Risk_Interpretation_OutputEntry_5_1">
          <text>"LOW"</text>
        </outputEntry>
        <outputEntry id="Pressure_Injury_Risk_Interpretation_OutputEntry_5_2">
          <text>"Cuidados padrão: manter mobilização ativa, inspeção de pele conforme rotina, educação sobre prevenção"</text>
        </outputEntry>
        <outputEntry id="Pressure_Injury_Risk_Interpretation_OutputEntry_5_3">
          <text>72</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

</definitions>
