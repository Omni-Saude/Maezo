<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Sepsis_Risk_Definitions"
             name="Risco de Sepse"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Sepsis_Risk_Decision" name="Decisão de Risco de Sepse">
    <decisionTable id="Sepsis_Risk_Table" hitPolicy="FIRST">
      <input id="Sepsis_Risk_Input_1" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="Sepsis_Risk_InputExpression_1" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>
      <input id="Sepsis_Risk_Input_2" label="Pressão Sistólica (mmHg)" camunda:inputVariable="systolicBP">
        <inputExpression id="Sepsis_Risk_InputExpression_2" typeRef="integer">
          <text>systolicBP</text>
        </inputExpression>
      </input>
      <input id="Sepsis_Risk_Input_3" label="Frequência Respiratória (rpm)" camunda:inputVariable="respiratoryRate">
        <inputExpression id="Sepsis_Risk_InputExpression_3" typeRef="integer">
          <text>respiratoryRate</text>
        </inputExpression>
      </input>
      <input id="Sepsis_Risk_Input_4" label="Alteração Mental" camunda:inputVariable="alteredMentation">
        <inputExpression id="Sepsis_Risk_InputExpression_4" typeRef="boolean">
          <text>alteredMentation</text>
        </inputExpression>
      </input>
      <input id="Sepsis_Risk_Input_5" label="Temperatura (°C)" camunda:inputVariable="temperature">
        <inputExpression id="Sepsis_Risk_InputExpression_5" typeRef="double">
          <text>temperature</text>
        </inputExpression>
      </input>
      <input id="Sepsis_Risk_Input_6" label="Frequência Cardíaca (bpm)" camunda:inputVariable="heartRate">
        <inputExpression id="Sepsis_Risk_InputExpression_6" typeRef="integer">
          <text>heartRate</text>
        </inputExpression>
      </input>
      <input id="Sepsis_Risk_Input_7" label="Leucócitos (mil/mm³)" camunda:inputVariable="whiteBloodCellCount">
        <inputExpression id="Sepsis_Risk_InputExpression_7" typeRef="double">
          <text>whiteBloodCellCount</text>
        </inputExpression>
      </input>
      <input id="Sepsis_Risk_Input_8" label="Lactato (mmol/L)" camunda:inputVariable="lactateLevel">
        <inputExpression id="Sepsis_Risk_InputExpression_8" typeRef="double">
          <text>lactateLevel</text>
        </inputExpression>
      </input>

      <output id="Sepsis_Risk_Output_1" label="Risco de Sepse" name="sepsisRisk" typeRef="string">
        <outputValues id="Sepsis_Risk_OutputValues_1">
          <text>"HIGH","MODERATE","LOW"</text>
        </outputValues>
      </output>
      <output id="Sepsis_Risk_Output_2" label="Escore qSOFA" name="qsofaScore" typeRef="integer" />
      <output id="Sepsis_Risk_Output_3" label="Ação Recomendada" name="recommendedAction" typeRef="string" />
      <output id="Sepsis_Risk_Output_4" label="Escalação Necessária" name="escalationRequired" typeRef="boolean" />

      <!-- Alto risco: qSOFA 3/3 + lactato elevado -->
      <rule id="Sepsis_Risk_Rule_1">
        <description>Risco alto - qSOFA 3/3 com lactato elevado, provável choque séptico</description>
        <inputEntry id="Sepsis_Risk_InputEntry_1_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_1_2">
          <text>&lt;= 100</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_1_3">
          <text>&gt;= 22</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_1_4">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_1_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_1_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_1_7">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_1_8">
          <text>&gt; 4.0</text>
        </inputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_1_1">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_1_2">
          <text>3</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_1_3">
          <text>"Choque séptico provável - Iniciar protocolo sepse imediatamente, ressuscitação volêmica, antibiótico empírico em 1h, avaliar vasopressor"</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_1_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Alto risco: qSOFA 2/3 + sinais SIRS -->
      <rule id="Sepsis_Risk_Rule_2">
        <description>Risco alto - qSOFA 2/3 com critérios SIRS positivos</description>
        <inputEntry id="Sepsis_Risk_InputEntry_2_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_2_2">
          <text>&lt;= 100</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_2_3">
          <text>&gt;= 22</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_2_4">
          <text>false</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_2_5">
          <text>&gt; 38.0, &lt; 36.0</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_2_6">
          <text>&gt; 90</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_2_7">
          <text>&gt; 12.0, &lt; 4.0</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_2_8">
          <text>&gt;= 2.0</text>
        </inputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_2_1">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_2_2">
          <text>2</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_2_3">
          <text>"Sepse provável - Iniciar bundle sepse: hemoculturas, antibiótico em 1h, lactato seriado, balanço hídrico rigoroso"</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_2_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Alto risco: Alteração mental + hipotensão -->
      <rule id="Sepsis_Risk_Rule_3">
        <description>Risco alto - Alteração mental com hipotensão significativa</description>
        <inputEntry id="Sepsis_Risk_InputEntry_3_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_3_2">
          <text>&lt;= 90</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_3_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_3_4">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_3_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_3_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_3_7">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_3_8">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_3_1">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_3_2">
          <text>2</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_3_3">
          <text>"Sepse com disfunção orgânica - Avaliar necessidade de UTI, iniciar antibiótico, suporte hemodinâmico"</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_3_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Risco moderado: qSOFA 2/3 sem outros sinais -->
      <rule id="Sepsis_Risk_Rule_4">
        <description>Risco moderado - qSOFA 2/3 mas sem critérios completos de SIRS</description>
        <inputEntry id="Sepsis_Risk_InputEntry_4_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_4_2">
          <text>&lt;= 100</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_4_3">
          <text>&gt;= 22</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_4_4">
          <text>false</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_4_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_4_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_4_7">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_4_8">
          <text>&lt; 2.0</text>
        </inputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_4_1">
          <text>"MODERATE"</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_4_2">
          <text>2</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_4_3">
          <text>"Monitorar sinais de sepse - Coletar hemoculturas, considerar antibiótico, reavaliar em 2-4h"</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_4_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Risco moderado: Febre + taquicardia + leucocitose -->
      <rule id="Sepsis_Risk_Rule_5">
        <description>Risco moderado - SIRS presente sem critérios qSOFA completos</description>
        <inputEntry id="Sepsis_Risk_InputEntry_5_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_5_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_5_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_5_4">
          <text>false</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_5_5">
          <text>&gt; 38.0, &lt; 36.0</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_5_6">
          <text>&gt; 90</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_5_7">
          <text>&gt; 12.0, &lt; 4.0</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_5_8">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_5_1">
          <text>"MODERATE"</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_5_2">
          <text>0</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_5_3">
          <text>"SIRS identificada - Investigar foco infeccioso, hemoculturas, avaliar necessidade de antibiótico"</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_5_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Risco moderado: Lactato elevado isolado -->
      <rule id="Sepsis_Risk_Rule_6">
        <description>Risco moderado - Lactato elevado sem outros critérios graves</description>
        <inputEntry id="Sepsis_Risk_InputEntry_6_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_6_2">
          <text>&gt; 100</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_6_3">
          <text>&lt; 22</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_6_4">
          <text>false</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_6_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_6_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_6_7">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_6_8">
          <text>&gt;= 2.0, &lt;= 4.0</text>
        </inputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_6_1">
          <text>"MODERATE"</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_6_2">
          <text>0</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_6_3">
          <text>"Hiperlactatemia - Investigar causa, repetir lactato em 2-6h, monitorar evolução"</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_6_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Baixo risco: qSOFA 1/3 -->
      <rule id="Sepsis_Risk_Rule_7">
        <description>Risco baixo - qSOFA 1/3, monitorar evolução</description>
        <inputEntry id="Sepsis_Risk_InputEntry_7_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_7_2">
          <text>&lt;= 100</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_7_3">
          <text>&lt; 22</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_7_4">
          <text>false</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_7_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_7_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_7_7">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_7_8">
          <text>&lt; 2.0</text>
        </inputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_7_1">
          <text>"LOW"</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_7_2">
          <text>1</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_7_3">
          <text>"Risco baixo - Monitorar sinais vitais, reavaliar se piora clínica"</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_7_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Baixo risco: Sem critérios -->
      <rule id="Sepsis_Risk_Rule_8">
        <description>Risco baixo - Nenhum critério de sepse identificado</description>
        <inputEntry id="Sepsis_Risk_InputEntry_8_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_8_2">
          <text>&gt; 100</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_8_3">
          <text>&lt; 22</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_8_4">
          <text>false</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_8_5">
          <text>&gt;= 36.0, &lt;= 38.0</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_8_6">
          <text>&lt;= 90</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_8_7">
          <text>&gt;= 4.0, &lt;= 12.0</text>
        </inputEntry>
        <inputEntry id="Sepsis_Risk_InputEntry_8_8">
          <text>&lt; 2.0</text>
        </inputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_8_1">
          <text>"LOW"</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_8_2">
          <text>0</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_8_3">
          <text>"Sem sinais de sepse - Conduta conforme diagnóstico primário"</text>
        </outputEntry>
        <outputEntry id="Sepsis_Risk_OutputEntry_8_4">
          <text>false</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

</definitions>
