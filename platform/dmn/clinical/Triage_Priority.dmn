<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Triage_Priority_Definitions"
             name="Triagem de Prioridade"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Triage_Priority_Decision" name="Decisão de Triagem de Prioridade">
    <decisionTable id="Triage_Priority_Table" hitPolicy="FIRST">
      <input id="Triage_Priority_Input_1" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="Triage_Priority_InputExpression_1" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>
      <input id="Triage_Priority_Input_2" label="Queixa Principal" camunda:inputVariable="chiefComplaint">
        <inputExpression id="Triage_Priority_InputExpression_2" typeRef="string">
          <text>chiefComplaint</text>
        </inputExpression>
      </input>
      <input id="Triage_Priority_Input_3" label="Alerta de Sinais Vitais" camunda:inputVariable="vitalSignsAlert">
        <inputExpression id="Triage_Priority_InputExpression_3" typeRef="boolean">
          <text>vitalSignsAlert</text>
        </inputExpression>
      </input>
      <input id="Triage_Priority_Input_4" label="Nível de Dor (0-10)" camunda:inputVariable="painLevel">
        <inputExpression id="Triage_Priority_InputExpression_4" typeRef="integer">
          <text>painLevel</text>
        </inputExpression>
      </input>
      <input id="Triage_Priority_Input_5" label="Nível de Consciência" camunda:inputVariable="consciousnessLevel">
        <inputExpression id="Triage_Priority_InputExpression_5" typeRef="string">
          <text>consciousnessLevel</text>
        </inputExpression>
        <inputValues id="Triage_Priority_InputValues_5">
          <text>"ALERT","VERBAL","PAIN","UNRESPONSIVE"</text>
        </inputValues>
      </input>
      <input id="Triage_Priority_Input_6" label="Modo de Chegada" camunda:inputVariable="arrivalMode">
        <inputExpression id="Triage_Priority_InputExpression_6" typeRef="string">
          <text>arrivalMode</text>
        </inputExpression>
        <inputValues id="Triage_Priority_InputValues_6">
          <text>"WALK_IN","AMBULANCE","HELICOPTER"</text>
        </inputValues>
      </input>

      <output id="Triage_Priority_Output_1" label="Cor da Triagem" name="triageColor" typeRef="string">
        <outputValues id="Triage_Priority_OutputValues_1">
          <text>"RED","ORANGE","YELLOW","GREEN","BLUE"</text>
        </outputValues>
      </output>
      <output id="Triage_Priority_Output_2" label="Tempo Máximo de Espera (min)" name="maxWaitMinutes" typeRef="integer" />
      <output id="Triage_Priority_Output_3" label="Alocação de Recursos" name="resourceAllocation" typeRef="string" />
      <output id="Triage_Priority_Output_4" label="Requer Monitoramento" name="requiresMonitoring" typeRef="boolean" />

      <!-- Vermelho: Emergência imediata -->
      <rule id="Triage_Priority_Rule_1">
        <description>Paciente inconsciente ou com sinais vitais críticos - Emergência imediata</description>
        <inputEntry id="Triage_Priority_InputEntry_1_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_1_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_1_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_1_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_1_5">
          <text>"UNRESPONSIVE"</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_1_6">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_1_1">
          <text>"RED"</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_1_2">
          <text>0</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_1_3">
          <text>"Sala de emergência, equipe completa, monitor cardíaco"</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_1_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Vermelho: Dor torácica grave -->
      <rule id="Triage_Priority_Rule_2">
        <description>Dor torácica grave com sinais de alerta - Emergência imediata</description>
        <inputEntry id="Triage_Priority_InputEntry_2_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_2_2">
          <text>contains(?, "dor torácica"), contains(?, "peito"), contains(?, "infarto")</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_2_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_2_4">
          <text>&gt;= 8</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_2_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_2_6">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_2_1">
          <text>"RED"</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_2_2">
          <text>0</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_2_3">
          <text>"Sala de emergência, ECG imediato, equipe cardiológica"</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_2_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Laranja: Muito urgente -->
      <rule id="Triage_Priority_Rule_3">
        <description>Paciente com alteração de consciência ou chegada por ambulância/helicóptero</description>
        <inputEntry id="Triage_Priority_InputEntry_3_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_3_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_3_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_3_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_3_5">
          <text>"PAIN","VERBAL"</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_3_6">
          <text>"AMBULANCE","HELICOPTER"</text>
        </inputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_3_1">
          <text>"ORANGE"</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_3_2">
          <text>10</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_3_3">
          <text>"Sala de emergência, avaliação médica prioritária"</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_3_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Laranja: Dor intensa -->
      <rule id="Triage_Priority_Rule_4">
        <description>Paciente com dor intensa que necessita avaliação urgente</description>
        <inputEntry id="Triage_Priority_InputEntry_4_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_4_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_4_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_4_4">
          <text>&gt;= 7, &lt; 8</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_4_5">
          <text>"ALERT"</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_4_6">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_4_1">
          <text>"ORANGE"</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_4_2">
          <text>10</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_4_3">
          <text>"Avaliação médica prioritária, analgesia"</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_4_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Amarelo: Urgente -->
      <rule id="Triage_Priority_Rule_5">
        <description>Paciente com sinais vitais alterados mas estável</description>
        <inputEntry id="Triage_Priority_InputEntry_5_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_5_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_5_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_5_4">
          <text>&gt;= 4, &lt; 7</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_5_5">
          <text>"ALERT"</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_5_6">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_5_1">
          <text>"YELLOW"</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_5_2">
          <text>60</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_5_3">
          <text>"Avaliação médica em até 1 hora, monitoramento periódico"</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_5_4">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- Amarelo: Queixas específicas urgentes -->
      <rule id="Triage_Priority_Rule_6">
        <description>Queixas que requerem avaliação urgente mas não emergencial</description>
        <inputEntry id="Triage_Priority_InputEntry_6_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_6_2">
          <text>contains(?, "febre alta"), contains(?, "vômito"), contains(?, "diarreia"), contains(?, "trauma")</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_6_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_6_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_6_5">
          <text>"ALERT"</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_6_6">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_6_1">
          <text>"YELLOW"</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_6_2">
          <text>60</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_6_3">
          <text>"Avaliação médica em até 1 hora"</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_6_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Verde: Pouco urgente -->
      <rule id="Triage_Priority_Rule_7">
        <description>Paciente estável com queixa leve a moderada</description>
        <inputEntry id="Triage_Priority_InputEntry_7_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_7_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_7_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_7_4">
          <text>&gt;= 1, &lt; 4</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_7_5">
          <text>"ALERT"</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_7_6">
          <text>"WALK_IN"</text>
        </inputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_7_1">
          <text>"GREEN"</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_7_2">
          <text>120</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_7_3">
          <text>"Atendimento ambulatorial, aguardar em sala de espera"</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_7_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Azul: Não urgente -->
      <rule id="Triage_Priority_Rule_8">
        <description>Paciente sem urgência, condições crônicas ou administrativas</description>
        <inputEntry id="Triage_Priority_InputEntry_8_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_8_2">
          <text>contains(?, "atestado"), contains(?, "receita"), contains(?, "resultado"), contains(?, "retorno")</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_8_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_8_4">
          <text>0</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_8_5">
          <text>"ALERT"</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_8_6">
          <text>"WALK_IN"</text>
        </inputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_8_1">
          <text>"BLUE"</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_8_2">
          <text>240</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_8_3">
          <text>"Atendimento administrativo ou orientação"</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_8_4">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- Regra padrão: Verde -->
      <rule id="Triage_Priority_Rule_9">
        <description>Caso padrão para situações não especificadas</description>
        <inputEntry id="Triage_Priority_InputEntry_9_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_9_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_9_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_9_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_9_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Triage_Priority_InputEntry_9_6">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_9_1">
          <text>"GREEN"</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_9_2">
          <text>120</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_9_3">
          <text>"Avaliação médica padrão"</text>
        </outputEntry>
        <outputEntry id="Triage_Priority_OutputEntry_9_4">
          <text>false</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

</definitions>
