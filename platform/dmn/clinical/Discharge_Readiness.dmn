<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Discharge_Readiness_Definitions"
             name="Prontidão para Alta"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Discharge_Readiness_Decision" name="Decisão de Prontidão para Alta">
    <decisionTable id="Discharge_Readiness_Table" hitPolicy="FIRST">
      <input id="Discharge_Readiness_Input_1" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="Discharge_Readiness_InputExpression_1" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>
      <input id="Discharge_Readiness_Input_2" label="Sinais Vitais Estáveis" camunda:inputVariable="vitalSignsStable">
        <inputExpression id="Discharge_Readiness_InputExpression_2" typeRef="boolean">
          <text>vitalSignsStable</text>
        </inputExpression>
      </input>
      <input id="Discharge_Readiness_Input_3" label="Ingestão Oral Adequada" camunda:inputVariable="oralIntakeAdequate">
        <inputExpression id="Discharge_Readiness_InputExpression_3" typeRef="boolean">
          <text>oralIntakeAdequate</text>
        </inputExpression>
      </input>
      <input id="Discharge_Readiness_Input_4" label="Dor Controlada" camunda:inputVariable="painControlled">
        <inputExpression id="Discharge_Readiness_InputExpression_4" typeRef="boolean">
          <text>painControlled</text>
        </inputExpression>
      </input>
      <input id="Discharge_Readiness_Input_5" label="Mobilidade Avaliada" camunda:inputVariable="mobilityAssessed">
        <inputExpression id="Discharge_Readiness_InputExpression_5" typeRef="boolean">
          <text>mobilityAssessed</text>
        </inputExpression>
      </input>
      <input id="Discharge_Readiness_Input_6" label="Acompanhamento Agendado" camunda:inputVariable="followUpScheduled">
        <inputExpression id="Discharge_Readiness_InputExpression_6" typeRef="boolean">
          <text>followUpScheduled</text>
        </inputExpression>
      </input>
      <input id="Discharge_Readiness_Input_7" label="Cuidador Instruído" camunda:inputVariable="caregiverInstructed">
        <inputExpression id="Discharge_Readiness_InputExpression_7" typeRef="boolean">
          <text>caregiverInstructed</text>
        </inputExpression>
      </input>

      <output id="Discharge_Readiness_Output_1" label="Pronto para Alta" name="readyForDischarge" typeRef="boolean" />
      <output id="Discharge_Readiness_Output_2" label="Critérios Pendentes" name="pendingCriteria" typeRef="string" />
      <output id="Discharge_Readiness_Output_3" label="Alta Estimada (horas)" name="estimatedDischargeHours" typeRef="integer" />

      <!-- Pronto para alta - Todos critérios atendidos -->
      <rule id="Discharge_Readiness_Rule_1">
        <description>Pronto para alta - Todos os critérios de segurança atendidos</description>
        <inputEntry id="Discharge_Readiness_InputEntry_1_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_1_2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_1_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_1_4">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_1_5">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_1_6">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_1_7">
          <text>true</text>
        </inputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_1_1">
          <text>true</text>
        </outputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_1_2">
          <text>"Nenhum critério pendente"</text>
        </outputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_1_3">
          <text>2</text>
        </outputEntry>
      </rule>

      <!-- Não pronto - Sinais vitais instáveis -->
      <rule id="Discharge_Readiness_Rule_2">
        <description>Não pronto - Instabilidade hemodinâmica crítica</description>
        <inputEntry id="Discharge_Readiness_InputEntry_2_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_2_2">
          <text>false</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_2_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_2_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_2_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_2_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_2_7">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_2_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_2_2">
          <text>"CRÍTICO: Sinais vitais instáveis. Reavaliar estabilidade hemodinâmica, suspensão de oxigênio, controle de febre."</text>
        </outputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_2_3">
          <text>24</text>
        </outputEntry>
      </rule>

      <!-- Não pronto - Ingestão oral inadequada -->
      <rule id="Discharge_Readiness_Rule_3">
        <description>Não pronto - Incapacidade de manter hidratação/nutrição oral</description>
        <inputEntry id="Discharge_Readiness_InputEntry_3_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_3_2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_3_3">
          <text>false</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_3_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_3_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_3_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_3_7">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_3_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_3_2">
          <text>"Ingestão oral inadequada. Avaliar tolerância alimentar, necessidade de antiemético, considerar suporte nutricional domiciliar."</text>
        </outputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_3_3">
          <text>12</text>
        </outputEntry>
      </rule>

      <!-- Não pronto - Dor não controlada -->
      <rule id="Discharge_Readiness_Rule_4">
        <description>Não pronto - Analgesia insuficiente impedindo alta segura</description>
        <inputEntry id="Discharge_Readiness_InputEntry_4_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_4_2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_4_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_4_4">
          <text>false</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_4_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_4_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_4_7">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_4_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_4_2">
          <text>"Dor não controlada. Otimizar esquema analgésico, considerar associação de medicamentos, avaliar analgesia multimodal."</text>
        </outputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_4_3">
          <text>8</text>
        </outputEntry>
      </rule>

      <!-- Não pronto - Mobilidade não avaliada -->
      <rule id="Discharge_Readiness_Rule_5">
        <description>Não pronto - Segurança para mobilização domiciliar não confirmada</description>
        <inputEntry id="Discharge_Readiness_InputEntry_5_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_5_2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_5_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_5_4">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_5_5">
          <text>false</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_5_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_5_7">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_5_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_5_2">
          <text>"Mobilidade não avaliada. Solicitar avaliação de fisioterapia, teste de marcha, orientações sobre quedas, equipamentos auxiliares."</text>
        </outputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_5_3">
          <text>6</text>
        </outputEntry>
      </rule>

      <!-- Não pronto - Acompanhamento não agendado -->
      <rule id="Discharge_Readiness_Rule_6">
        <description>Não pronto - Continuidade do cuidado não garantida</description>
        <inputEntry id="Discharge_Readiness_InputEntry_6_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_6_2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_6_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_6_4">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_6_5">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_6_6">
          <text>false</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_6_7">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_6_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_6_2">
          <text>"Acompanhamento não agendado. Agendar retorno médico em 7-14 dias, consultas com especialistas se necessário, exames de controle."</text>
        </outputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_6_3">
          <text>4</text>
        </outputEntry>
      </rule>

      <!-- Não pronto - Cuidador não instruído -->
      <rule id="Discharge_Readiness_Rule_7">
        <description>Não pronto - Orientações domiciliares incompletas, risco de readmissão</description>
        <inputEntry id="Discharge_Readiness_InputEntry_7_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_7_2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_7_3">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_7_4">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_7_5">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_7_6">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_7_7">
          <text>false</text>
        </inputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_7_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_7_2">
          <text>"Cuidador não instruído. Realizar orientações sobre medicações, sinais de alerta, cuidados gerais, contatos de emergência."</text>
        </outputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_7_3">
          <text>3</text>
        </outputEntry>
      </rule>

      <!-- Não pronto - Múltiplos critérios pendentes -->
      <rule id="Discharge_Readiness_Rule_8">
        <description>Não pronto - Diversos critérios ainda não atendidos</description>
        <inputEntry id="Discharge_Readiness_InputEntry_8_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_8_2">
          <text>true</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_8_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_8_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_8_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_8_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_8_7">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_8_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_8_2">
          <text>"Múltiplos critérios pendentes. Revisar checklist de alta, priorizar pendências críticas, coordenar equipe multiprofissional."</text>
        </outputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_8_3">
          <text>24</text>
        </outputEntry>
      </rule>

      <!-- Regra padrão -->
      <rule id="Discharge_Readiness_Rule_9">
        <description>Situação não definida - Reavaliar critérios individualmente</description>
        <inputEntry id="Discharge_Readiness_InputEntry_9_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_9_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_9_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_9_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_9_5">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_9_6">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Discharge_Readiness_InputEntry_9_7">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_9_1">
          <text>false</text>
        </outputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_9_2">
          <text>"Situação indeterminada. Reavaliar todos os critérios de alta com equipe assistencial."</text>
        </outputEntry>
        <outputEntry id="Discharge_Readiness_OutputEntry_9_3">
          <text>12</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

</definitions>
