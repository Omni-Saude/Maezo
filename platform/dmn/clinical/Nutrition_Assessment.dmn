<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Nutrition_Assessment_Definitions"
             name="Avaliação Nutricional"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Nutrition_Assessment_Decision" name="Decisão de Avaliação Nutricional">
    <decisionTable id="Nutrition_Assessment_Table" hitPolicy="FIRST">
      <input id="Nutrition_Assessment_Input_1" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="Nutrition_Assessment_InputExpression_1" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>
      <input id="Nutrition_Assessment_Input_2" label="Categoria IMC" camunda:inputVariable="bmiCategory">
        <inputExpression id="Nutrition_Assessment_InputExpression_2" typeRef="string">
          <text>bmiCategory</text>
        </inputExpression>
      </input>
      <input id="Nutrition_Assessment_Input_3" label="Perda de Peso (%)" camunda:inputVariable="weightLossPercent">
        <inputExpression id="Nutrition_Assessment_InputExpression_3" typeRef="double">
          <text>weightLossPercent</text>
        </inputExpression>
      </input>
      <input id="Nutrition_Assessment_Input_4" label="Redução Ingestão Alimentar" camunda:inputVariable="foodIntakeReduction">
        <inputExpression id="Nutrition_Assessment_InputExpression_4" typeRef="string">
          <text>foodIntakeReduction</text>
        </inputExpression>
        <inputValues id="Nutrition_Assessment_InputValues_4">
          <text>"NONE","MILD","MODERATE","SEVERE"</text>
        </inputValues>
      </input>
      <input id="Nutrition_Assessment_Input_5" label="Gravidade da Doença" camunda:inputVariable="diseaseSeverity">
        <inputExpression id="Nutrition_Assessment_InputExpression_5" typeRef="string">
          <text>diseaseSeverity</text>
        </inputExpression>
        <inputValues id="Nutrition_Assessment_InputValues_5">
          <text>"MILD","MODERATE","SEVERE"</text>
        </inputValues>
      </input>

      <output id="Nutrition_Assessment_Output_1" label="Risco Nutricional" name="nutritionRisk" typeRef="string">
        <outputValues id="Nutrition_Assessment_OutputValues_1">
          <text>"HIGH","MODERATE","LOW"</text>
        </outputValues>
      </output>
      <output id="Nutrition_Assessment_Output_2" label="Tipo de Intervenção" name="interventionType" typeRef="string" />
      <output id="Nutrition_Assessment_Output_3" label="Consulta Dietética Necessária" name="dietaryConsultRequired" typeRef="boolean" />
      <output id="Nutrition_Assessment_Output_4" label="Reavaliação (dias)" name="reassessmentDays" typeRef="integer" />

      <!-- Alto risco: Desnutrição grave + doença severa -->
      <rule id="Nutrition_Assessment_Rule_1">
        <description>Risco alto - Desnutrição grave com doença severa</description>
        <inputEntry id="Nutrition_Assessment_InputEntry_1_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_1_2">
          <text>"UNDERWEIGHT_SEVERE","UNDERWEIGHT"</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_1_3">
          <text>&gt; 10.0</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_1_4">
          <text>"SEVERE"</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_1_5">
          <text>"SEVERE"</text>
        </inputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_1_1">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_1_2">
          <text>"Terapia nutricional agressiva: NPT ou dieta enteral especializada, suplementação proteica, monitoramento de eletrólitos"</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_1_3">
          <text>true</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_1_4">
          <text>3</text>
        </outputEntry>
      </rule>

      <!-- Alto risco: Perda ponderal significativa -->
      <rule id="Nutrition_Assessment_Rule_2">
        <description>Risco alto - Perda de peso importante recente</description>
        <inputEntry id="Nutrition_Assessment_InputEntry_2_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_2_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_2_3">
          <text>&gt; 15.0</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_2_4">
          <text>"SEVERE","MODERATE"</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_2_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_2_1">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_2_2">
          <text>"Suporte nutricional intensivo: considerar via enteral, hipercalórico-hiperproteico, monitorar síndrome de realimentação"</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_2_3">
          <text>true</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_2_4">
          <text>3</text>
        </outputEntry>
      </rule>

      <!-- Alto risco: Ingestão severamente reduzida + doença grave -->
      <rule id="Nutrition_Assessment_Rule_3">
        <description>Risco alto - Jejum prolongado em paciente crítico</description>
        <inputEntry id="Nutrition_Assessment_InputEntry_3_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_3_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_3_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_3_4">
          <text>"SEVERE"</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_3_5">
          <text>"SEVERE"</text>
        </inputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_3_1">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_3_2">
          <text>"Nutrição enteral precoce: iniciar em 24-48h, protocolo de gastroparesia, monitorar tolerância"</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_3_3">
          <text>true</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_3_4">
          <text>2</text>
        </outputEntry>
      </rule>

      <!-- Risco moderado: Desnutrição moderada -->
      <rule id="Nutrition_Assessment_Rule_4">
        <description>Risco moderado - Desnutrição moderada ou risco estabelecido</description>
        <inputEntry id="Nutrition_Assessment_InputEntry_4_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_4_2">
          <text>"UNDERWEIGHT"</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_4_3">
          <text>&gt;= 5.0, &lt;= 10.0</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_4_4">
          <text>"MODERATE"</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_4_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_4_1">
          <text>"MODERATE"</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_4_2">
          <text>"Suplementação oral: módulos calórico-proteicos, dieta hospitalar enriquecida, orientação nutricional"</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_4_3">
          <text>true</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_4_4">
          <text>7</text>
        </outputEntry>
      </rule>

      <!-- Risco moderado: Doença grave com ingestão reduzida -->
      <rule id="Nutrition_Assessment_Rule_5">
        <description>Risco moderado - Paciente grave com risco de desnutrição</description>
        <inputEntry id="Nutrition_Assessment_InputEntry_5_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_5_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_5_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_5_4">
          <text>"MODERATE","SEVERE"</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_5_5">
          <text>"SEVERE","MODERATE"</text>
        </inputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_5_1">
          <text>"MODERATE"</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_5_2">
          <text>"Suporte nutricional precoce: dieta via oral enriquecida ou enteral se necessário, monitorar ingestão"</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_5_3">
          <text>true</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_5_4">
          <text>5</text>
        </outputEntry>
      </rule>

      <!-- Risco moderado: Perda de peso moderada -->
      <rule id="Nutrition_Assessment_Rule_6">
        <description>Risco moderado - Perda ponderal significativa recente</description>
        <inputEntry id="Nutrition_Assessment_InputEntry_6_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_6_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_6_3">
          <text>&gt;= 5.0, &lt;= 10.0</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_6_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_6_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_6_1">
          <text>"MODERATE"</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_6_2">
          <text>"Intervenção nutricional: aumentar densidade calórica, fracionamento de refeições, orientação dietética"</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_6_3">
          <text>true</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_6_4">
          <text>7</text>
        </outputEntry>
      </rule>

      <!-- Baixo risco: Estado nutricional adequado -->
      <rule id="Nutrition_Assessment_Rule_7">
        <description>Risco baixo - Estado nutricional preservado</description>
        <inputEntry id="Nutrition_Assessment_InputEntry_7_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_7_2">
          <text>"NORMAL","OVERWEIGHT"</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_7_3">
          <text>&lt; 5.0</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_7_4">
          <text>"NONE","MILD"</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_7_5">
          <text>"MILD"</text>
        </inputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_7_1">
          <text>"LOW"</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_7_2">
          <text>"Dieta hospitalar padrão: manter ingestão adequada, monitorar aceitação alimentar"</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_7_3">
          <text>false</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_7_4">
          <text>14</text>
        </outputEntry>
      </rule>

      <!-- Baixo risco: Obesidade sem complicações -->
      <rule id="Nutrition_Assessment_Rule_8">
        <description>Risco baixo - Obesidade sem desnutrição associada</description>
        <inputEntry id="Nutrition_Assessment_InputEntry_8_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_8_2">
          <text>"OBESE","OVERWEIGHT"</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_8_3">
          <text>&lt; 5.0</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_8_4">
          <text>"NONE","MILD"</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_8_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_8_1">
          <text>"LOW"</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_8_2">
          <text>"Dieta balanceada: controle calórico se apropriado, avaliar sarcopenia oculta, educação nutricional"</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_8_3">
          <text>false</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_8_4">
          <text>14</text>
        </outputEntry>
      </rule>

      <!-- Regra padrão -->
      <rule id="Nutrition_Assessment_Rule_9">
        <description>Avaliação nutricional individualizada necessária</description>
        <inputEntry id="Nutrition_Assessment_InputEntry_9_1">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_9_2">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_9_3">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_9_4">
          <text>-</text>
        </inputEntry>
        <inputEntry id="Nutrition_Assessment_InputEntry_9_5">
          <text>-</text>
        </inputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_9_1">
          <text>"MODERATE"</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_9_2">
          <text>"Avaliação nutricional completa: aplicar NRS-2002 completo, avaliar antropometria, exames laboratoriais"</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_9_3">
          <text>true</text>
        </outputEntry>
        <outputEntry id="Nutrition_Assessment_OutputEntry_9_4">
          <text>7</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

</definitions>
