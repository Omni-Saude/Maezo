<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_recovery_prediction"
             name="Recovery Prediction"
             namespace="http://camunda.org/schema/1.0/dmn"
             exporter="Camunda Modeler"
             exporterVersion="5.0.0">
  <decision id="Decision_RecoveryPrediction" name="Previsão de Recuperação Financeira">
    <description>Prediz probabilidade e valor de recuperação de glosas</description>
    <decisionTable id="DecisionTable_RecoveryPrediction" hitPolicy="FIRST">
      <input id="Input_tenantId" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="InputExpression_tenantId" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>
      <input id="Input_glosaCategory" label="Categoria da Glosa" camunda:inputVariable="glosaCategory">
        <inputExpression id="InputExpression_glosaCategory" typeRef="string">
          <text>glosaCategory</text>
        </inputExpression>
      </input>
      <input id="Input_appealRound" label="Rodada de Recurso" camunda:inputVariable="appealRound">
        <inputExpression id="InputExpression_appealRound" typeRef="integer">
          <text>appealRound</text>
        </inputExpression>
      </input>
      <input id="Input_documentationQuality" label="Qualidade Documentação (%)" camunda:inputVariable="documentationQuality">
        <inputExpression id="InputExpression_documentationQuality" typeRef="integer">
          <text>documentationQuality</text>
        </inputExpression>
      </input>
      <input id="Input_historicalRecoveryRate" label="Taxa Histórica Recuperação" camunda:inputVariable="historicalRecoveryRate">
        <inputExpression id="InputExpression_historicalRecoveryRate" typeRef="double">
          <text>historicalRecoveryRate</text>
        </inputExpression>
      </input>
      <output id="Output_predictedRecovery" label="Recuperação Prevista (%)" name="predictedRecovery" typeRef="double" />
      <output id="Output_confidenceLevel" label="Nível de Confiança" name="confidenceLevel" typeRef="string">
        <outputValues id="OutputValues_confidenceLevel">
          <text>"HIGH","MEDIUM","LOW"</text>
        </outputValues>
      </output>
      <output id="Output_expectedTimeline" label="Prazo Esperado (dias)" name="expectedTimeline" typeRef="integer" />
      <output id="Output_costBenefitPositive" label="Custo-Benefício Positivo" name="costBenefitPositive" typeRef="boolean" />

      <rule id="Rule_High_Recovery_1">
        <description>Alta recuperação: glosa administrativa, primeira rodada, boa documentação</description>
        <inputEntry id="InputEntry_High_Recovery_1_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_High_Recovery_1_category">
          <text>"ADMINISTRATIVE","DOCUMENTATION","TECHNICAL"</text>
        </inputEntry>
        <inputEntry id="InputEntry_High_Recovery_1_round">
          <text>1</text>
        </inputEntry>
        <inputEntry id="InputEntry_High_Recovery_1_quality">
          <text>&gt;= 80</text>
        </inputEntry>
        <inputEntry id="InputEntry_High_Recovery_1_historical">
          <text>&gt; 0.7</text>
        </inputEntry>
        <outputEntry id="OutputEntry_High_Recovery_1_predicted">
          <text>0.85</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_Recovery_1_confidence">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_Recovery_1_timeline">
          <text>30</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_Recovery_1_costbenefit">
          <text>true</text>
        </outputEntry>
      </rule>

      <rule id="Rule_High_Recovery_2">
        <description>Alta recuperação: histórico excelente mesmo com qualidade média</description>
        <inputEntry id="InputEntry_High_Recovery_2_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_High_Recovery_2_category">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_High_Recovery_2_round">
          <text>1,2</text>
        </inputEntry>
        <inputEntry id="InputEntry_High_Recovery_2_quality">
          <text>[60..80)</text>
        </inputEntry>
        <inputEntry id="InputEntry_High_Recovery_2_historical">
          <text>&gt; 0.8</text>
        </inputEntry>
        <outputEntry id="OutputEntry_High_Recovery_2_predicted">
          <text>0.75</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_Recovery_2_confidence">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_Recovery_2_timeline">
          <text>45</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_Recovery_2_costbenefit">
          <text>true</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Medium_Recovery_1">
        <description>Média recuperação: segunda rodada com boa documentação</description>
        <inputEntry id="InputEntry_Medium_Recovery_1_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_Recovery_1_category">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_Recovery_1_round">
          <text>2</text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_Recovery_1_quality">
          <text>&gt;= 75</text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_Recovery_1_historical">
          <text>[0.5..0.7]</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Medium_Recovery_1_predicted">
          <text>0.60</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_Recovery_1_confidence">
          <text>"MEDIUM"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_Recovery_1_timeline">
          <text>60</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_Recovery_1_costbenefit">
          <text>true</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Medium_Recovery_2">
        <description>Média recuperação: glosa clínica primeira rodada</description>
        <inputEntry id="InputEntry_Medium_Recovery_2_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_Recovery_2_category">
          <text>"CLINICAL","MEDICAL_NECESSITY"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_Recovery_2_round">
          <text>1</text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_Recovery_2_quality">
          <text>&gt;= 70</text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_Recovery_2_historical">
          <text>&gt; 0.4</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Medium_Recovery_2_predicted">
          <text>0.55</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_Recovery_2_confidence">
          <text>"MEDIUM"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_Recovery_2_timeline">
          <text>75</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_Recovery_2_costbenefit">
          <text>true</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Low_Recovery_1">
        <description>Baixa recuperação: terceira rodada ou mais</description>
        <inputEntry id="InputEntry_Low_Recovery_1_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_Recovery_1_category">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_Recovery_1_round">
          <text>&gt;= 3</text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_Recovery_1_quality">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_Recovery_1_historical">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Low_Recovery_1_predicted">
          <text>0.25</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_Recovery_1_confidence">
          <text>"LOW"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_Recovery_1_timeline">
          <text>120</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_Recovery_1_costbenefit">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Low_Recovery_2">
        <description>Baixa recuperação: documentação ruim com histórico negativo</description>
        <inputEntry id="InputEntry_Low_Recovery_2_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_Recovery_2_category">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_Recovery_2_round">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_Recovery_2_quality">
          <text>&lt; 50</text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_Recovery_2_historical">
          <text>&lt; 0.3</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Low_Recovery_2_predicted">
          <text>0.15</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_Recovery_2_confidence">
          <text>"LOW"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_Recovery_2_timeline">
          <text>90</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_Recovery_2_costbenefit">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Low_Recovery_3">
        <description>Baixa recuperação: glosa de cobertura</description>
        <inputEntry id="InputEntry_Low_Recovery_3_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_Recovery_3_category">
          <text>"COVERAGE","EXCLUSION","NOT_COVERED"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_Recovery_3_round">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_Recovery_3_quality">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_Recovery_3_historical">
          <text>&lt; 0.4</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Low_Recovery_3_predicted">
          <text>0.20</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_Recovery_3_confidence">
          <text>"LOW"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_Recovery_3_timeline">
          <text>90</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_Recovery_3_costbenefit">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Medium_Recovery_3">
        <description>Média recuperação: primeira rodada com qualidade moderada</description>
        <inputEntry id="InputEntry_Medium_Recovery_3_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_Recovery_3_category">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_Recovery_3_round">
          <text>1</text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_Recovery_3_quality">
          <text>[50..75)</text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_Recovery_3_historical">
          <text>[0.4..0.6]</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Medium_Recovery_3_predicted">
          <text>0.50</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_Recovery_3_confidence">
          <text>"MEDIUM"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_Recovery_3_timeline">
          <text>60</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_Recovery_3_costbenefit">
          <text>true</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Default">
        <description>Caso padrão: recuperação moderada</description>
        <inputEntry id="InputEntry_Default_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_category">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_round">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_quality">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_historical">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Default_predicted">
          <text>0.45</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_confidence">
          <text>"MEDIUM"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_timeline">
          <text>60</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_costbenefit">
          <text>true</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
