<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_root_cause_classification"
             name="Root Cause Classification"
             namespace="http://camunda.org/schema/1.0/dmn"
             exporter="Camunda Modeler"
             exporterVersion="5.0.0">
  <decision id="Decision_RootCauseClassification" name="Classificação de Causa Raiz">
    <description>Identifica causa raiz de glosas para ações corretivas sistêmicas</description>
    <decisionTable id="DecisionTable_RootCauseClassification" hitPolicy="FIRST">
      <input id="Input_tenantId" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="InputExpression_tenantId" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>
      <input id="Input_glosaCode" label="Código da Glosa" camunda:inputVariable="glosaCode">
        <inputExpression id="InputExpression_glosaCode" typeRef="string">
          <text>glosaCode</text>
        </inputExpression>
      </input>
      <input id="Input_processStage" label="Etapa do Processo" camunda:inputVariable="processStage">
        <inputExpression id="InputExpression_processStage" typeRef="string">
          <text>processStage</text>
        </inputExpression>
        <inputValues id="InputValues_processStage">
          <text>"REGISTRATION","AUTHORIZATION","BILLING","CODING","SUBMISSION"</text>
        </inputValues>
      </input>
      <input id="Input_frequency" label="Frequência (ocorrências/mês)" camunda:inputVariable="frequency">
        <inputExpression id="InputExpression_frequency" typeRef="integer">
          <text>frequency</text>
        </inputExpression>
      </input>
      <output id="Output_rootCause" label="Causa Raiz" name="rootCause" typeRef="string" />
      <output id="Output_correctiveAction" label="Ação Corretiva" name="correctiveAction" typeRef="string" />
      <output id="Output_preventionMeasure" label="Medida Preventiva" name="preventionMeasure" typeRef="string" />
      <output id="Output_systemImprovement" label="Melhoria Sistêmica" name="systemImprovement" typeRef="string" />

      <rule id="Rule_Registration_DataQuality">
        <description>Erro de cadastro: dados incompletos/incorretos</description>
        <inputEntry id="InputEntry_Registration_DataQuality_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Registration_DataQuality_code">
          <text>"01","02","PATIENT_DATA","ELIGIBILITY"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Registration_DataQuality_stage">
          <text>"REGISTRATION"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Registration_DataQuality_frequency">
          <text>&gt; 10</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Registration_DataQuality_rootCause">
          <text>"Falha no processo de cadastro: validação insuficiente de dados do paciente"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Registration_DataQuality_corrective">
          <text>"Revisar cadastros dos últimos 30 dias. Corrigir dados incorretos. Treinar equipe de recepção."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Registration_DataQuality_prevention">
          <text>"Implementar validação obrigatória de CPF, carteirinha e dados de contato no momento do cadastro. Validação online com operadora."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Registration_DataQuality_system">
          <text>"Desenvolver integração em tempo real com sistemas de elegibilidade das operadoras. Alertas visuais para campos incompletos."</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Authorization_Deadline">
        <description>Autorização: falha no controle de prazos</description>
        <inputEntry id="InputEntry_Authorization_Deadline_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Authorization_Deadline_code">
          <text>"08","09","EXPIRED_AUTH","NO_AUTH"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Authorization_Deadline_stage">
          <text>"AUTHORIZATION"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Authorization_Deadline_frequency">
          <text>&gt; 5</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Authorization_Deadline_rootCause">
          <text>"Gestão inadequada de prazos de autorização. Falta de acompanhamento de validade."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Authorization_Deadline_corrective">
          <text>"Mapear todas as autorizações vencidas. Renovar urgentemente. Criar workflow de acompanhamento."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Authorization_Deadline_prevention">
          <text>"Estabelecer rotina diária de verificação de validade. Alertas automáticos 72h antes do vencimento."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Authorization_Deadline_system">
          <text>"Dashboard de autorização com semáforo de validade. Renovação automática quando possível. Notificações push para responsáveis."</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Coding_Accuracy">
        <description>Codificação: baixa acurácia CID/TUSS</description>
        <inputEntry id="InputEntry_Coding_Accuracy_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Coding_Accuracy_code">
          <text>"25","26","CODE_MISMATCH","INVALID_CODE"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Coding_Accuracy_stage">
          <text>"CODING"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Coding_Accuracy_frequency">
          <text>&gt; 15</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Coding_Accuracy_rootCause">
          <text>"Equipe de codificação com treinamento insuficiente. Ausência de auditoria pré-submissão."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Coding_Accuracy_corrective">
          <text>"Auditoria retrospectiva de códigos dos últimos 60 dias. Capacitação intensiva da equipe. Contratar auditor sênior."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Coding_Accuracy_prevention">
          <text>"Implementar dupla checagem para procedimentos de alta complexidade. Tabela de compatibilidade CID x TUSS por operadora."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Coding_Accuracy_system">
          <text>"Sistema de sugestão de códigos com IA. Validação automática de compatibilidade. Biblioteca de casos com codificação aprovada."</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Billing_Documentation">
        <description>Faturamento: documentação incompleta recorrente</description>
        <inputEntry id="InputEntry_Billing_Documentation_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Billing_Documentation_code">
          <text>"40","41","42","MISSING_DOCS","INCOMPLETE"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Billing_Documentation_stage">
          <text>"BILLING"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Billing_Documentation_frequency">
          <text>&gt; 20</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Billing_Documentation_rootCause">
          <text>"Processo de coleta de documentação fragmentado. Falta de checklist padronizado por tipo de atendimento."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Billing_Documentation_corrective">
          <text>"Criar checklists obrigatórios por tipo de procedimento. Bloquear faturamento se documentação incompleta."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Billing_Documentation_prevention">
          <text>"Implementar coleta digital de documentos no ponto de atendimento. Assinatura eletrônica de termos. Digitalização imediata."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Billing_Documentation_system">
          <text>"Sistema de gestão documental com OCR. Validação automática de completude. Workflow de solicitação de documentos faltantes."</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Submission_Deadline">
        <description>Submissão: envio fora do prazo recorrente</description>
        <inputEntry id="InputEntry_Submission_Deadline_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Submission_Deadline_code">
          <text>"05","LATE_SUBMISSION","DEADLINE_EXCEEDED"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Submission_Deadline_stage">
          <text>"SUBMISSION"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Submission_Deadline_frequency">
          <text>&gt; 8</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Submission_Deadline_rootCause">
          <text>"Gargalo no processo de fechamento de contas. Acúmulo de contas pendentes. Falta de priorização."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Submission_Deadline_corrective">
          <text>"Mutirão de fechamento de contas atrasadas. Contratar temporários. Redistribuir carga de trabalho."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Submission_Deadline_prevention">
          <text>"Estabelecer SLA interno de 15 dias da alta. Dashboard de aging de contas. Reuniões diárias de follow-up."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Submission_Deadline_system">
          <text>"Automação de submissão para contas simples. Priorização automática por prazo. RPA para tarefas repetitivas. Dashboard executivo."</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Clinical_Justification">
        <description>Clínico: falta de justificativa médica adequada</description>
        <inputEntry id="InputEntry_Clinical_Justification_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Clinical_Justification_code">
          <text>"15","16","CLINICAL_NECESSITY","NO_JUSTIFICATION"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Clinical_Justification_stage">
          <text>"CODING","BILLING"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Clinical_Justification_frequency">
          <text>&gt; 12</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Clinical_Justification_rootCause">
          <text>"Corpo clínico não documenta adequadamente a justificativa de procedimentos. Evoluções superficiais."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Clinical_Justification_corrective">
          <text>"Reunião com corpo clínico. Apresentar casos de glosa. Treinamento sobre documentação clínica. Criar templates."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Clinical_Justification_prevention">
          <text>"Templates de evolução por especialidade. Campos obrigatórios de justificativa. Revisão médica de casos de alto valor."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Clinical_Justification_system">
          <text>"Prontuário eletrônico com campos estruturados. Alertas para justificativa insuficiente. IA para sugestão de texto clínico."</text>
        </outputEntry>
      </rule>

      <rule id="Rule_OPME_Process">
        <description>OPME: falhas no processo de cotação e autorização</description>
        <inputEntry id="InputEntry_OPME_Process_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_OPME_Process_code">
          <text>"31","32","OPME_QUOTE","OPME_AUTH"</text>
        </inputEntry>
        <inputEntry id="InputEntry_OPME_Process_stage">
          <text>"AUTHORIZATION","BILLING"</text>
        </inputEntry>
        <inputEntry id="InputEntry_OPME_Process_frequency">
          <text>&gt; 3</text>
        </inputEntry>
        <outputEntry id="OutputEntry_OPME_Process_rootCause">
          <text>"Processo de OPME não padronizado. Falta de integração entre setores. Cotações incompletas ou tardias."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_OPME_Process_corrective">
          <text>"Criar procedimento operacional padrão para OPME. Designar responsável exclusivo. Revisar casos pendentes."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_OPME_Process_prevention">
          <text>"Workflow obrigatório: cotação pré-cirúrgica → autorização → conferência pós-uso → faturamento. Checklist em cada etapa."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_OPME_Process_system">
          <text>"Módulo específico de gestão de OPME. Integração com fornecedores. Rastreabilidade completa. Alertas de prazos. Dashboard financeiro."</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Default">
        <description>Caso padrão: análise individual necessária</description>
        <inputEntry id="InputEntry_Default_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_code">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_stage">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_frequency">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Default_rootCause">
          <text>"Causa raiz requer análise detalhada. Glosa não mapeada em padrões conhecidos."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_corrective">
          <text>"Reunir equipe multidisciplinar para análise do caso. Investigar histórico completo. Documentar achados."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_prevention">
          <text>"Registrar novo padrão de glosa. Atualizar base de conhecimento. Comunicar equipes envolvidas."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_system">
          <text>"Adicionar novo código à tabela de decisão. Monitorar recorrência. Ajustar sistema conforme necessário."</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
