<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_compliance_check"
             name="Compliance Check"
             namespace="http://camunda.org/schema/1.0/dmn"
             exporter="Camunda Modeler"
             exporterVersion="5.0.0">
  <decision id="Decision_ComplianceCheck" name="Verificação de Conformidade Regulatória">
    <description>Valida conformidade com normas regulatórias brasileiras de saúde</description>
    <decisionTable id="DecisionTable_ComplianceCheck" hitPolicy="FIRST">
      <input id="Input_tenantId" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="InputExpression_tenantId" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>
      <input id="Input_regulatoryBody" label="Órgão Regulador" camunda:inputVariable="regulatoryBody">
        <inputExpression id="InputExpression_regulatoryBody" typeRef="string">
          <text>regulatoryBody</text>
        </inputExpression>
        <inputValues id="InputValues_regulatoryBody">
          <text>"ANS","ANVISA","CRM","CFM"</text>
        </inputValues>
      </input>
      <input id="Input_ruleCategory" label="Categoria da Regra" camunda:inputVariable="ruleCategory">
        <inputExpression id="InputExpression_ruleCategory" typeRef="string">
          <text>ruleCategory</text>
        </inputExpression>
      </input>
      <input id="Input_lastAuditDate" label="Data Última Auditoria" camunda:inputVariable="lastAuditDate">
        <inputExpression id="InputExpression_lastAuditDate" typeRef="string">
          <text>lastAuditDate</text>
        </inputExpression>
      </input>
      <input id="Input_complianceScore" label="Score de Conformidade (%)" camunda:inputVariable="complianceScore">
        <inputExpression id="InputExpression_complianceScore" typeRef="integer">
          <text>complianceScore</text>
        </inputExpression>
      </input>
      <output id="Output_isCompliant" label="Está em Conformidade" name="isCompliant" typeRef="boolean" />
      <output id="Output_gapDescription" label="Descrição das Lacunas" name="gapDescription" typeRef="string" />
      <output id="Output_remediationPriority" label="Prioridade de Remediação" name="remediationPriority" typeRef="string">
        <outputValues id="OutputValues_remediationPriority">
          <text>"HIGH","MEDIUM","LOW"</text>
        </outputValues>
      </output>
      <output id="Output_deadlineDays" label="Prazo para Adequação (dias)" name="deadlineDays" typeRef="integer" />

      <rule id="Rule_ANS_TISS_Critical">
        <description>ANS: Padrão TISS não conforme - crítico</description>
        <inputEntry id="InputEntry_ANS_TISS_Critical_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_ANS_TISS_Critical_body">
          <text>"ANS"</text>
        </inputEntry>
        <inputEntry id="InputEntry_ANS_TISS_Critical_category">
          <text>"TISS","PADRAO_TISS","GUIAS_TISS"</text>
        </inputEntry>
        <inputEntry id="InputEntry_ANS_TISS_Critical_audit">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_ANS_TISS_Critical_score">
          <text>&lt; 70</text>
        </inputEntry>
        <outputEntry id="OutputEntry_ANS_TISS_Critical_compliant">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_ANS_TISS_Critical_gap">
          <text>"Não conformidade com padrão TISS vigente. Guias eletrônicas não atendem estrutura XML definida pela ANS. Risco de rejeição de lotes."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_ANS_TISS_Critical_priority">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_ANS_TISS_Critical_deadline">
          <text>30</text>
        </outputEntry>
      </rule>

      <rule id="Rule_ANS_RN_Critical">
        <description>ANS: Resolução Normativa não cumprida</description>
        <inputEntry id="InputEntry_ANS_RN_Critical_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_ANS_RN_Critical_body">
          <text>"ANS"</text>
        </inputEntry>
        <inputEntry id="InputEntry_ANS_RN_Critical_category">
          <text>"RN_259","RN_338","RN_424","RESOLUCAO_NORMATIVA"</text>
        </inputEntry>
        <inputEntry id="InputEntry_ANS_RN_Critical_audit">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_ANS_RN_Critical_score">
          <text>&lt; 75</text>
        </inputEntry>
        <outputEntry id="OutputEntry_ANS_RN_Critical_compliant">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_ANS_RN_Critical_gap">
          <text>"Descumprimento de Resolução Normativa ANS. Processos assistenciais ou administrativos não atendem requisitos mínimos. Risco de penalidades."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_ANS_RN_Critical_priority">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_ANS_RN_Critical_deadline">
          <text>60</text>
        </outputEntry>
      </rule>

      <rule id="Rule_ANVISA_Sanitario">
        <description>ANVISA: Norma sanitária crítica</description>
        <inputEntry id="InputEntry_ANVISA_Sanitario_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_ANVISA_Sanitario_body">
          <text>"ANVISA"</text>
        </inputEntry>
        <inputEntry id="InputEntry_ANVISA_Sanitario_category">
          <text>"RDC_50","VIGILANCIA_SANITARIA","MEDICAMENTOS","EQUIPAMENTOS"</text>
        </inputEntry>
        <inputEntry id="InputEntry_ANVISA_Sanitario_audit">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_ANVISA_Sanitario_score">
          <text>&lt; 80</text>
        </inputEntry>
        <outputEntry id="OutputEntry_ANVISA_Sanitario_compliant">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_ANVISA_Sanitario_gap">
          <text>"Não conformidade com normas sanitárias ANVISA. Equipamentos sem registro, medicamentos sem rastreabilidade ou ambiente inadequado."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_ANVISA_Sanitario_priority">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_ANVISA_Sanitario_deadline">
          <text>45</text>
        </outputEntry>
      </rule>

      <rule id="Rule_CRM_Registro">
        <description>CRM: Irregularidade no registro de médicos</description>
        <inputEntry id="InputEntry_CRM_Registro_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_CRM_Registro_body">
          <text>"CRM"</text>
        </inputEntry>
        <inputEntry id="InputEntry_CRM_Registro_category">
          <text>"REGISTRO","ESPECIALIDADE","REGULARIDADE"</text>
        </inputEntry>
        <inputEntry id="InputEntry_CRM_Registro_audit">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_CRM_Registro_score">
          <text>&lt; 85</text>
        </inputEntry>
        <outputEntry id="OutputEntry_CRM_Registro_compliant">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_CRM_Registro_gap">
          <text>"Médicos com registro irregular, vencido ou especialidade não registrada no CRM. Glosas garantidas se identificado."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_CRM_Registro_priority">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_CRM_Registro_deadline">
          <text>15</text>
        </outputEntry>
      </rule>

      <rule id="Rule_CFM_Etica">
        <description>CFM: Processo ético pendente</description>
        <inputEntry id="InputEntry_CFM_Etica_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_CFM_Etica_body">
          <text>"CFM"</text>
        </inputEntry>
        <inputEntry id="InputEntry_CFM_Etica_category">
          <text>"PROCESSO_ETICO","CODIGO_ETICA","RESTRICAO"</text>
        </inputEntry>
        <inputEntry id="InputEntry_CFM_Etica_audit">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_CFM_Etica_score">
          <text>&lt; 90</text>
        </inputEntry>
        <outputEntry id="OutputEntry_CFM_Etica_compliant">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_CFM_Etica_gap">
          <text>"Médico(s) com processo ético em andamento ou restrição do CFM. Verificar situação antes de submeter contas."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_CFM_Etica_priority">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_CFM_Etica_deadline">
          <text>7</text>
        </outputEntry>
      </rule>

      <rule id="Rule_ANS_Medium">
        <description>ANS: Conformidade média, melhorias necessárias</description>
        <inputEntry id="InputEntry_ANS_Medium_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_ANS_Medium_body">
          <text>"ANS"</text>
        </inputEntry>
        <inputEntry id="InputEntry_ANS_Medium_category">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_ANS_Medium_audit">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_ANS_Medium_score">
          <text>[70..85)</text>
        </inputEntry>
        <outputEntry id="OutputEntry_ANS_Medium_compliant">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_ANS_Medium_gap">
          <text>"Conformidade parcial com normas ANS. Pontos de melhoria identificados. Risco moderado de glosa ou penalidade."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_ANS_Medium_priority">
          <text>"MEDIUM"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_ANS_Medium_deadline">
          <text>90</text>
        </outputEntry>
      </rule>

      <rule id="Rule_ANVISA_Medium">
        <description>ANVISA: Conformidade média, ajustes necessários</description>
        <inputEntry id="InputEntry_ANVISA_Medium_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_ANVISA_Medium_body">
          <text>"ANVISA"</text>
        </inputEntry>
        <inputEntry id="InputEntry_ANVISA_Medium_category">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_ANVISA_Medium_audit">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_ANVISA_Medium_score">
          <text>[80..90)</text>
        </inputEntry>
        <outputEntry id="OutputEntry_ANVISA_Medium_compliant">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_ANVISA_Medium_gap">
          <text>"Atende requisitos mínimos ANVISA. Oportunidades de melhoria em rastreabilidade e documentação. Baixo risco imediato."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_ANVISA_Medium_priority">
          <text>"MEDIUM"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_ANVISA_Medium_deadline">
          <text>120</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Compliant_High">
        <description>Alta conformidade: manutenção e monitoramento</description>
        <inputEntry id="InputEntry_Compliant_High_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Compliant_High_body">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Compliant_High_category">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Compliant_High_audit">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Compliant_High_score">
          <text>&gt;= 90</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Compliant_High_compliant">
          <text>true</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Compliant_High_gap">
          <text>"Excelente conformidade regulatória. Manter processos atuais. Continuar monitoramento e atualização conforme novas normas."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Compliant_High_priority">
          <text>"LOW"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Compliant_High_deadline">
          <text>180</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Default">
        <description>Caso padrão: verificação necessária</description>
        <inputEntry id="InputEntry_Default_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_body">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_category">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_audit">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_score">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Default_compliant">
          <text>false</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_gap">
          <text>"Conformidade não avaliada ou dados insuficientes. Realizar auditoria completa. Verificar requisitos específicos do órgão regulador."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_priority">
          <text>"MEDIUM"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_deadline">
          <text>60</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
