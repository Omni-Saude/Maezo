<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_appeal_viability"
             name="Appeal Viability"
             namespace="http://camunda.org/schema/1.0/dmn"
             exporter="Camunda Modeler"
             exporterVersion="5.0.0">
  <decision id="Decision_AppealViability" name="Viabilidade de Recurso de Glosa">
    <description>Avalia a viabilidade e estratégia para recurso de glosa</description>
    <decisionTable id="DecisionTable_AppealViability" hitPolicy="FIRST">
      <input id="Input_tenantId" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="InputExpression_tenantId" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>
      <input id="Input_glosaType" label="Tipo de Glosa" camunda:inputVariable="glosaType">
        <inputExpression id="InputExpression_glosaType" typeRef="string">
          <text>glosaType</text>
        </inputExpression>
        <inputValues id="InputValues_glosaType">
          <text>"ADMINISTRATIVE","CLINICAL","TECHNICAL","COVERAGE","DOCUMENTATION"</text>
        </inputValues>
      </input>
      <input id="Input_glosaAmount" label="Valor da Glosa (R$)" camunda:inputVariable="glosaAmount">
        <inputExpression id="InputExpression_glosaAmount" typeRef="double">
          <text>glosaAmount</text>
        </inputExpression>
      </input>
      <input id="Input_daysSinceNotification" label="Dias desde Notificação" camunda:inputVariable="daysSinceNotification">
        <inputExpression id="InputExpression_daysSinceNotification" typeRef="integer">
          <text>daysSinceNotification</text>
        </inputExpression>
      </input>
      <input id="Input_hasDocumentation" label="Tem Documentação" camunda:inputVariable="hasDocumentation">
        <inputExpression id="InputExpression_hasDocumentation" typeRef="boolean">
          <text>hasDocumentation</text>
        </inputExpression>
      </input>
      <input id="Input_previousAppealResult" label="Resultado Recurso Anterior" camunda:inputVariable="previousAppealResult">
        <inputExpression id="InputExpression_previousAppealResult" typeRef="string">
          <text>previousAppealResult</text>
        </inputExpression>
      </input>
      <output id="Output_appealViability" label="Viabilidade do Recurso" name="appealViability" typeRef="string">
        <outputValues id="OutputValues_appealViability">
          <text>"HIGH","MEDIUM","LOW","DO_NOT_APPEAL"</text>
        </outputValues>
      </output>
      <output id="Output_successProbability" label="Probabilidade Sucesso (%)" name="successProbability" typeRef="integer" />
      <output id="Output_recommendedStrategy" label="Estratégia Recomendada" name="recommendedStrategy" typeRef="string" />
      <output id="Output_deadlineDays" label="Prazo (dias)" name="deadlineDays" typeRef="integer" />
      <output id="Output_requiresLegal" label="Requer Jurídico" name="requiresLegal" typeRef="boolean" />

      <rule id="Rule_DoNotAppeal_1">
        <description>Não recorrer: prazo vencido</description>
        <inputEntry id="InputEntry_DoNotAppeal_1_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_DoNotAppeal_1_type">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_DoNotAppeal_1_amount">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_DoNotAppeal_1_days">
          <text>&gt; 30</text>
        </inputEntry>
        <inputEntry id="InputEntry_DoNotAppeal_1_doc">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_DoNotAppeal_1_previous">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_DoNotAppeal_1_viability">
          <text>"DO_NOT_APPEAL"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_DoNotAppeal_1_probability">
          <text>5</text>
        </outputEntry>
        <outputEntry id="OutputEntry_DoNotAppeal_1_strategy">
          <text>"Prazo esgotado. Provisionar perda."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_DoNotAppeal_1_deadline">
          <text>0</text>
        </outputEntry>
        <outputEntry id="OutputEntry_DoNotAppeal_1_legal">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_DoNotAppeal_2">
        <description>Não recorrer: baixo valor sem documentação</description>
        <inputEntry id="InputEntry_DoNotAppeal_2_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_DoNotAppeal_2_type">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_DoNotAppeal_2_amount">
          <text>&lt; 500</text>
        </inputEntry>
        <inputEntry id="InputEntry_DoNotAppeal_2_days">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_DoNotAppeal_2_doc">
          <text>false</text>
        </inputEntry>
        <inputEntry id="InputEntry_DoNotAppeal_2_previous">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_DoNotAppeal_2_viability">
          <text>"DO_NOT_APPEAL"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_DoNotAppeal_2_probability">
          <text>10</text>
        </outputEntry>
        <outputEntry id="OutputEntry_DoNotAppeal_2_strategy">
          <text>"Custo-benefício negativo. Aceitar glosa."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_DoNotAppeal_2_deadline">
          <text>0</text>
        </outputEntry>
        <outputEntry id="OutputEntry_DoNotAppeal_2_legal">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_High_1">
        <description>Alta viabilidade: glosa administrativa com documentação</description>
        <inputEntry id="InputEntry_High_1_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_High_1_type">
          <text>"ADMINISTRATIVE"</text>
        </inputEntry>
        <inputEntry id="InputEntry_High_1_amount">
          <text>&gt; 1000</text>
        </inputEntry>
        <inputEntry id="InputEntry_High_1_days">
          <text>&lt;= 10</text>
        </inputEntry>
        <inputEntry id="InputEntry_High_1_doc">
          <text>true</text>
        </inputEntry>
        <inputEntry id="InputEntry_High_1_previous">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_High_1_viability">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_1_probability">
          <text>85</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_1_strategy">
          <text>"Recurso administrativo: corrigir inconsistências e resubmeter com documentação completa."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_1_deadline">
          <text>20</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_1_legal">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_High_2">
        <description>Alta viabilidade: glosa técnica/documentação com histórico positivo</description>
        <inputEntry id="InputEntry_High_2_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_High_2_type">
          <text>"TECHNICAL","DOCUMENTATION"</text>
        </inputEntry>
        <inputEntry id="InputEntry_High_2_amount">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_High_2_days">
          <text>&lt;= 15</text>
        </inputEntry>
        <inputEntry id="InputEntry_High_2_doc">
          <text>true</text>
        </inputEntry>
        <inputEntry id="InputEntry_High_2_previous">
          <text>"SUCCESS","PARTIAL_SUCCESS"</text>
        </inputEntry>
        <outputEntry id="OutputEntry_High_2_viability">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_2_probability">
          <text>80</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_2_strategy">
          <text>"Complementar documentação técnica. Enviar relatório médico detalhado."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_2_deadline">
          <text>18</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_2_legal">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Medium_1">
        <description>Média viabilidade: glosa clínica com documentação</description>
        <inputEntry id="InputEntry_Medium_1_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_1_type">
          <text>"CLINICAL"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_1_amount">
          <text>&gt; 5000</text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_1_days">
          <text>&lt;= 20</text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_1_doc">
          <text>true</text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_1_previous">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Medium_1_viability">
          <text>"MEDIUM"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_1_probability">
          <text>55</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_1_strategy">
          <text>"Recurso com junta médica: solicitar parecer técnico de especialista."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_1_deadline">
          <text>25</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_1_legal">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Medium_2">
        <description>Média viabilidade: glosa de cobertura com valor alto</description>
        <inputEntry id="InputEntry_Medium_2_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_2_type">
          <text>"COVERAGE"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_2_amount">
          <text>&gt; 10000</text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_2_days">
          <text>&lt;= 15</text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_2_doc">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_2_previous">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Medium_2_viability">
          <text>"MEDIUM"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_2_probability">
          <text>50</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_2_strategy">
          <text>"Analisar contrato e legislação ANS. Considerar recurso administrativo ANS."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_2_deadline">
          <text>30</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_2_legal">
          <text>true</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Low_1">
        <description>Baixa viabilidade: glosa clínica sem documentação</description>
        <inputEntry id="InputEntry_Low_1_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_1_type">
          <text>"CLINICAL"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_1_amount">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_1_days">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_1_doc">
          <text>false</text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_1_previous">
          <text>"REJECTED"</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Low_1_viability">
          <text>"LOW"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_1_probability">
          <text>25</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_1_strategy">
          <text>"Tentar obter documentação retroativa. Chance reduzida."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_1_deadline">
          <text>15</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_1_legal">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Default">
        <description>Caso padrão: viabilidade média</description>
        <inputEntry id="InputEntry_Default_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_type">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_amount">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_days">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_doc">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_previous">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Default_viability">
          <text>"MEDIUM"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_probability">
          <text>50</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_strategy">
          <text>"Avaliar documentação disponível e histórico antes de decidir."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_deadline">
          <text>20</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_legal">
          <text>false</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
