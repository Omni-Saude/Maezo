<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_batch_validation"
             name="Batch Validation"
             namespace="http://camunda.org/schema/1.0/dmn"
             exporter="Camunda Modeler"
             exporterVersion="5.0.0">
  <decision id="Decision_BatchValidation" name="Validação de Lote de Contas">
    <description>Define nível de validação necessário para lotes de contas antes da submissão</description>
    <decisionTable id="DecisionTable_BatchValidation" hitPolicy="FIRST">
      <input id="Input_tenantId" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="InputExpression_tenantId" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>
      <input id="Input_batchSize" label="Tamanho do Lote" camunda:inputVariable="batchSize">
        <inputExpression id="InputExpression_batchSize" typeRef="integer">
          <text>batchSize</text>
        </inputExpression>
      </input>
      <input id="Input_averageClaimValue" label="Valor Médio da Conta (R$)" camunda:inputVariable="averageClaimValue">
        <inputExpression id="InputExpression_averageClaimValue" typeRef="double">
          <text>averageClaimValue</text>
        </inputExpression>
      </input>
      <input id="Input_mixedPayers" label="Múltiplas Operadoras" camunda:inputVariable="mixedPayers">
        <inputExpression id="InputExpression_mixedPayers" typeRef="boolean">
          <text>mixedPayers</text>
        </inputExpression>
      </input>
      <input id="Input_hasHighRiskProcedures" label="Tem Procedimentos de Alto Risco" camunda:inputVariable="hasHighRiskProcedures">
        <inputExpression id="InputExpression_hasHighRiskProcedures" typeRef="boolean">
          <text>hasHighRiskProcedures</text>
        </inputExpression>
      </input>
      <output id="Output_validationLevel" label="Nível de Validação" name="validationLevel" typeRef="string">
        <outputValues id="OutputValues_validationLevel">
          <text>"FULL","SAMPLING","AUTOMATED"</text>
        </outputValues>
      </output>
      <output id="Output_sampleSize" label="Tamanho da Amostra" name="sampleSize" typeRef="integer" />
      <output id="Output_estimatedProcessTime" label="Tempo Estimado (minutos)" name="estimatedProcessTime" typeRef="integer" />
      <output id="Output_holdForReview" label="Reter para Revisão" name="holdForReview" typeRef="boolean" />

      <rule id="Rule_Full_HighRisk">
        <description>Validação completa: procedimentos de alto risco</description>
        <inputEntry id="InputEntry_Full_HighRisk_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Full_HighRisk_batchSize">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Full_HighRisk_avgValue">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Full_HighRisk_mixedPayers">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Full_HighRisk_highRisk">
          <text>true</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Full_HighRisk_validation">
          <text>"FULL"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Full_HighRisk_sample">
          <text>batchSize</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Full_HighRisk_time">
          <text>batchSize * 15</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Full_HighRisk_hold">
          <text>true</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Full_HighValue">
        <description>Validação completa: valor médio muito alto</description>
        <inputEntry id="InputEntry_Full_HighValue_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Full_HighValue_batchSize">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Full_HighValue_avgValue">
          <text>&gt; 30000</text>
        </inputEntry>
        <inputEntry id="InputEntry_Full_HighValue_mixedPayers">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Full_HighValue_highRisk">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Full_HighValue_validation">
          <text>"FULL"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Full_HighValue_sample">
          <text>batchSize</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Full_HighValue_time">
          <text>batchSize * 12</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Full_HighValue_hold">
          <text>true</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Full_LargeBatch_MixedPayers">
        <description>Validação completa: lote grande com múltiplas operadoras</description>
        <inputEntry id="InputEntry_Full_LargeBatch_MixedPayers_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Full_LargeBatch_MixedPayers_batchSize">
          <text>&gt; 100</text>
        </inputEntry>
        <inputEntry id="InputEntry_Full_LargeBatch_MixedPayers_avgValue">
          <text>&gt; 10000</text>
        </inputEntry>
        <inputEntry id="InputEntry_Full_LargeBatch_MixedPayers_mixedPayers">
          <text>true</text>
        </inputEntry>
        <inputEntry id="InputEntry_Full_LargeBatch_MixedPayers_highRisk">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Full_LargeBatch_MixedPayers_validation">
          <text>"FULL"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Full_LargeBatch_MixedPayers_sample">
          <text>batchSize</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Full_LargeBatch_MixedPayers_time">
          <text>batchSize * 10</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Full_LargeBatch_MixedPayers_hold">
          <text>true</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Sampling_Medium">
        <description>Validação por amostragem: lote médio com valor moderado</description>
        <inputEntry id="InputEntry_Sampling_Medium_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Sampling_Medium_batchSize">
          <text>[50..200]</text>
        </inputEntry>
        <inputEntry id="InputEntry_Sampling_Medium_avgValue">
          <text>[5000..15000]</text>
        </inputEntry>
        <inputEntry id="InputEntry_Sampling_Medium_mixedPayers">
          <text>true</text>
        </inputEntry>
        <inputEntry id="InputEntry_Sampling_Medium_highRisk">
          <text>false</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Sampling_Medium_validation">
          <text>"SAMPLING"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Sampling_Medium_sample">
          <text>30</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Sampling_Medium_time">
          <text>180</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Sampling_Medium_hold">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Sampling_SinglePayer">
        <description>Validação por amostragem: operadora única, lote grande</description>
        <inputEntry id="InputEntry_Sampling_SinglePayer_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Sampling_SinglePayer_batchSize">
          <text>&gt; 100</text>
        </inputEntry>
        <inputEntry id="InputEntry_Sampling_SinglePayer_avgValue">
          <text>[3000..10000]</text>
        </inputEntry>
        <inputEntry id="InputEntry_Sampling_SinglePayer_mixedPayers">
          <text>false</text>
        </inputEntry>
        <inputEntry id="InputEntry_Sampling_SinglePayer_highRisk">
          <text>false</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Sampling_SinglePayer_validation">
          <text>"SAMPLING"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Sampling_SinglePayer_sample">
          <text>25</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Sampling_SinglePayer_time">
          <text>150</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Sampling_SinglePayer_hold">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Automated_SmallLowValue">
        <description>Validação automatizada: lote pequeno, baixo valor</description>
        <inputEntry id="InputEntry_Automated_SmallLowValue_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Automated_SmallLowValue_batchSize">
          <text>&lt; 50</text>
        </inputEntry>
        <inputEntry id="InputEntry_Automated_SmallLowValue_avgValue">
          <text>&lt; 3000</text>
        </inputEntry>
        <inputEntry id="InputEntry_Automated_SmallLowValue_mixedPayers">
          <text>false</text>
        </inputEntry>
        <inputEntry id="InputEntry_Automated_SmallLowValue_highRisk">
          <text>false</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Automated_SmallLowValue_validation">
          <text>"AUTOMATED"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Automated_SmallLowValue_sample">
          <text>0</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Automated_SmallLowValue_time">
          <text>30</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Automated_SmallLowValue_hold">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Automated_Routine">
        <description>Validação automatizada: contas rotineiras, padrão conhecido</description>
        <inputEntry id="InputEntry_Automated_Routine_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Automated_Routine_batchSize">
          <text>&lt; 100</text>
        </inputEntry>
        <inputEntry id="InputEntry_Automated_Routine_avgValue">
          <text>&lt; 5000</text>
        </inputEntry>
        <inputEntry id="InputEntry_Automated_Routine_mixedPayers">
          <text>false</text>
        </inputEntry>
        <inputEntry id="InputEntry_Automated_Routine_highRisk">
          <text>false</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Automated_Routine_validation">
          <text>"AUTOMATED"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Automated_Routine_sample">
          <text>5</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Automated_Routine_time">
          <text>45</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Automated_Routine_hold">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Sampling_MediumValue">
        <description>Validação por amostragem: valor médio, risco moderado</description>
        <inputEntry id="InputEntry_Sampling_MediumValue_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Sampling_MediumValue_batchSize">
          <text>[30..100]</text>
        </inputEntry>
        <inputEntry id="InputEntry_Sampling_MediumValue_avgValue">
          <text>[3000..10000]</text>
        </inputEntry>
        <inputEntry id="InputEntry_Sampling_MediumValue_mixedPayers">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Sampling_MediumValue_highRisk">
          <text>false</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Sampling_MediumValue_validation">
          <text>"SAMPLING"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Sampling_MediumValue_sample">
          <text>20</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Sampling_MediumValue_time">
          <text>120</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Sampling_MediumValue_hold">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Default">
        <description>Caso padrão: validação por amostragem</description>
        <inputEntry id="InputEntry_Default_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_batchSize">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_avgValue">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_mixedPayers">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_highRisk">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Default_validation">
          <text>"SAMPLING"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_sample">
          <text>15</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_time">
          <text>90</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_hold">
          <text>false</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
