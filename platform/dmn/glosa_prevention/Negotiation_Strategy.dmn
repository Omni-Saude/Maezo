<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_negotiation_strategy"
             name="Negotiation Strategy"
             namespace="http://camunda.org/schema/1.0/dmn"
             exporter="Camunda Modeler"
             exporterVersion="5.0.0">
  <decision id="Decision_NegotiationStrategy" name="Estratégia de Negociação">
    <description>Define estratégia de negociação para glosas contestadas</description>
    <decisionTable id="DecisionTable_NegotiationStrategy" hitPolicy="FIRST">
      <input id="Input_tenantId" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="InputExpression_tenantId" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>
      <input id="Input_disputedAmount" label="Valor Contestado (R$)" camunda:inputVariable="disputedAmount">
        <inputExpression id="InputExpression_disputedAmount" typeRef="double">
          <text>disputedAmount</text>
        </inputExpression>
      </input>
      <input id="Input_payerRelationship" label="Relacionamento com Operadora" camunda:inputVariable="payerRelationship">
        <inputExpression id="InputExpression_payerRelationship" typeRef="string">
          <text>payerRelationship</text>
        </inputExpression>
        <inputValues id="InputValues_payerRelationship">
          <text>"STRATEGIC","REGULAR","NEW"</text>
        </inputValues>
      </input>
      <input id="Input_contractualBasis" label="Tem Base Contratual" camunda:inputVariable="contractualBasis">
        <inputExpression id="InputExpression_contractualBasis" typeRef="boolean">
          <text>contractualBasis</text>
        </inputExpression>
      </input>
      <input id="Input_volumeImpact" label="Impacto no Volume" camunda:inputVariable="volumeImpact">
        <inputExpression id="InputExpression_volumeImpact" typeRef="string">
          <text>volumeImpact</text>
        </inputExpression>
        <inputValues id="InputValues_volumeImpact">
          <text>"HIGH","MEDIUM","LOW"</text>
        </inputValues>
      </input>
      <output id="Output_negotiationStrategy" label="Estratégia de Negociação" name="negotiationStrategy" typeRef="string" />
      <output id="Output_targetRecovery" label="Meta de Recuperação (%)" name="targetRecovery" typeRef="double" />
      <output id="Output_maxConcession" label="Máxima Concessão (%)" name="maxConcession" typeRef="double" />
      <output id="Output_escalationPath" label="Caminho de Escalação" name="escalationPath" typeRef="string" />

      <rule id="Rule_Strategic_High">
        <description>Parceiro estratégico: negociação colaborativa, alto valor</description>
        <inputEntry id="InputEntry_Strategic_High_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Strategic_High_amount">
          <text>&gt; 50000</text>
        </inputEntry>
        <inputEntry id="InputEntry_Strategic_High_relationship">
          <text>"STRATEGIC"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Strategic_High_contractual">
          <text>true</text>
        </inputEntry>
        <inputEntry id="InputEntry_Strategic_High_volume">
          <text>"HIGH"</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Strategic_High_strategy">
          <text>"COLLABORATIVE: Reunião presencial com diretoria médica e comercial. Apresentar documentação completa. Buscar win-win."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Strategic_High_target">
          <text>0.90</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Strategic_High_concession">
          <text>0.10</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Strategic_High_escalation">
          <text>"Diretor Médico → Diretor Geral → Comitê Conjunto"</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Strategic_Contractual">
        <description>Parceiro estratégico: base contratual forte</description>
        <inputEntry id="InputEntry_Strategic_Contractual_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Strategic_Contractual_amount">
          <text>&gt; 20000</text>
        </inputEntry>
        <inputEntry id="InputEntry_Strategic_Contractual_relationship">
          <text>"STRATEGIC"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Strategic_Contractual_contractual">
          <text>true</text>
        </inputEntry>
        <inputEntry id="InputEntry_Strategic_Contractual_volume">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Strategic_Contractual_strategy">
          <text>"CONTRACTUAL: Fundamentar em cláusulas contratuais. Reunião técnica. Propor revisão de processo para evitar recorrência."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Strategic_Contractual_target">
          <text>0.85</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Strategic_Contractual_concession">
          <text>0.15</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Strategic_Contractual_escalation">
          <text>"Gerente Técnico → Diretor de Relacionamento → Jurídico"</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Regular_HighValue">
        <description>Operadora regular: alto valor, base contratual</description>
        <inputEntry id="InputEntry_Regular_HighValue_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Regular_HighValue_amount">
          <text>&gt; 30000</text>
        </inputEntry>
        <inputEntry id="InputEntry_Regular_HighValue_relationship">
          <text>"REGULAR"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Regular_HighValue_contractual">
          <text>true</text>
        </inputEntry>
        <inputEntry id="InputEntry_Regular_HighValue_volume">
          <text>"MEDIUM","HIGH"</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Regular_HighValue_strategy">
          <text>"ASSERTIVE: Apresentar caso completo com base contratual. Solicitar revisão por junta médica. Estabelecer prazo de resposta."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Regular_HighValue_target">
          <text>0.80</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Regular_HighValue_concession">
          <text>0.20</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Regular_HighValue_escalation">
          <text>"Analista → Supervisor → Gerente → ANS se necessário"</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Regular_Medium">
        <description>Operadora regular: valor médio, negociação pragmática</description>
        <inputEntry id="InputEntry_Regular_Medium_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Regular_Medium_amount">
          <text>[10000..30000]</text>
        </inputEntry>
        <inputEntry id="InputEntry_Regular_Medium_relationship">
          <text>"REGULAR"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Regular_Medium_contractual">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Regular_Medium_volume">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Regular_Medium_strategy">
          <text>"PRAGMATIC: Buscar acordo rápido. Propor pagamento parcial imediato. Documentar compromissos futuros. Evitar desgaste."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Regular_Medium_target">
          <text>0.70</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Regular_Medium_concession">
          <text>0.30</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Regular_Medium_escalation">
          <text>"Analista → Supervisor → Acordo administrativo"</text>
        </outputEntry>
      </rule>

      <rule id="Rule_New_HighValue">
        <description>Nova operadora: alto valor, estabelecer precedente</description>
        <inputEntry id="InputEntry_New_HighValue_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_New_HighValue_amount">
          <text>&gt; 20000</text>
        </inputEntry>
        <inputEntry id="InputEntry_New_HighValue_relationship">
          <text>"NEW"</text>
        </inputEntry>
        <inputEntry id="InputEntry_New_HighValue_contractual">
          <text>true</text>
        </inputEntry>
        <inputEntry id="InputEntry_New_HighValue_volume">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_New_HighValue_strategy">
          <text>"PRECEDENT: Estabelecer padrão de relacionamento. Documentação exemplar. Reunião formal. Criar canal de comunicação direto."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_New_HighValue_target">
          <text>0.85</text>
        </outputEntry>
        <outputEntry id="OutputEntry_New_HighValue_concession">
          <text>0.15</text>
        </outputEntry>
        <outputEntry id="OutputEntry_New_HighValue_escalation">
          <text>"Gerente de Contas → Diretor Comercial → Reunião de alinhamento"</text>
        </outputEntry>
      </rule>

      <rule id="Rule_NoContractual_Low">
        <description>Sem base contratual: baixo valor, custo-benefício</description>
        <inputEntry id="InputEntry_NoContractual_Low_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_NoContractual_Low_amount">
          <text>&lt; 10000</text>
        </inputEntry>
        <inputEntry id="InputEntry_NoContractual_Low_relationship">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_NoContractual_Low_contractual">
          <text>false</text>
        </inputEntry>
        <inputEntry id="InputEntry_NoContractual_Low_volume">
          <text>"LOW"</text>
        </inputEntry>
        <outputEntry id="OutputEntry_NoContractual_Low_strategy">
          <text>"COST-BENEFIT: Avaliar custo operacional vs valor. Aceitar acordo se oferta >= 50%. Evitar desgaste desnecessário."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_NoContractual_Low_target">
          <text>0.50</text>
        </outputEntry>
        <outputEntry id="OutputEntry_NoContractual_Low_concession">
          <text>0.50</text>
        </outputEntry>
        <outputEntry id="OutputEntry_NoContractual_Low_escalation">
          <text>"Analista → Decisão imediata"</text>
        </outputEntry>
      </rule>

      <rule id="Rule_NoContractual_High">
        <description>Sem base contratual: alto valor, buscar acordo</description>
        <inputEntry id="InputEntry_NoContractual_High_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_NoContractual_High_amount">
          <text>&gt; 15000</text>
        </inputEntry>
        <inputEntry id="InputEntry_NoContractual_High_relationship">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_NoContractual_High_contractual">
          <text>false</text>
        </inputEntry>
        <inputEntry id="InputEntry_NoContractual_High_volume">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_NoContractual_High_strategy">
          <text>"SETTLEMENT: Buscar acordo administrativo. Apresentar jurisprudência favorável. Propor desconto para acordo rápido."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_NoContractual_High_target">
          <text>0.65</text>
        </outputEntry>
        <outputEntry id="OutputEntry_NoContractual_High_concession">
          <text>0.35</text>
        </outputEntry>
        <outputEntry id="OutputEntry_NoContractual_High_escalation">
          <text>"Supervisor → Gerente → Mediação se necessário"</text>
        </outputEntry>
      </rule>

      <rule id="Rule_HighVolume_Impact">
        <description>Alto impacto no volume: preservar relacionamento</description>
        <inputEntry id="InputEntry_HighVolume_Impact_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_HighVolume_Impact_amount">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_HighVolume_Impact_relationship">
          <text>"STRATEGIC","REGULAR"</text>
        </inputEntry>
        <inputEntry id="InputEntry_HighVolume_Impact_contractual">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_HighVolume_Impact_volume">
          <text>"HIGH"</text>
        </inputEntry>
        <outputEntry id="OutputEntry_HighVolume_Impact_strategy">
          <text>"RELATIONSHIP: Priorizar manutenção do relacionamento. Flexibilidade em pontos negociáveis. Foco em acordos de longo prazo."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_HighVolume_Impact_target">
          <text>0.75</text>
        </outputEntry>
        <outputEntry id="OutputEntry_HighVolume_Impact_concession">
          <text>0.25</text>
        </outputEntry>
        <outputEntry id="OutputEntry_HighVolume_Impact_escalation">
          <text>"Gerente Comercial → Diretor de Relacionamento → Acordo estratégico"</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Default">
        <description>Caso padrão: negociação equilibrada</description>
        <inputEntry id="InputEntry_Default_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_amount">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_relationship">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_contractual">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_volume">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Default_strategy">
          <text>"BALANCED: Apresentar caso completo. Buscar entendimento mútuo. Propor solução equilibrada. Documentar acordo."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_target">
          <text>0.70</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_concession">
          <text>0.30</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_escalation">
          <text>"Analista → Supervisor → Gerente"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
