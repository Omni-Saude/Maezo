<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_documentation_checklist"
             name="Documentation Checklist"
             namespace="http://camunda.org/schema/1.0/dmn"
             exporter="Camunda Modeler"
             exporterVersion="5.0.0">
  <decision id="Decision_DocumentationChecklist" name="Validação de Documentação Pré-Submissão">
    <description>Define checklist de documentação obrigatória antes da submissão</description>
    <decisionTable id="DecisionTable_DocumentationChecklist" hitPolicy="FIRST">
      <input id="Input_tenantId" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="InputExpression_tenantId" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>
      <input id="Input_encounterType" label="Tipo de Atendimento" camunda:inputVariable="encounterType">
        <inputExpression id="InputExpression_encounterType" typeRef="string">
          <text>encounterType</text>
        </inputExpression>
      </input>
      <input id="Input_procedureComplexity" label="Complexidade Procedimento" camunda:inputVariable="procedureComplexity">
        <inputExpression id="InputExpression_procedureComplexity" typeRef="string">
          <text>procedureComplexity</text>
        </inputExpression>
        <inputValues id="InputValues_procedureComplexity">
          <text>"HIGH","MEDIUM","LOW"</text>
        </inputValues>
      </input>
      <input id="Input_isEmergency" label="É Emergência" camunda:inputVariable="isEmergency">
        <inputExpression id="InputExpression_isEmergency" typeRef="boolean">
          <text>isEmergency</text>
        </inputExpression>
      </input>
      <input id="Input_requiresPreAuth" label="Requer Autorização Prévia" camunda:inputVariable="requiresPreAuth">
        <inputExpression id="InputExpression_requiresPreAuth" typeRef="boolean">
          <text>requiresPreAuth</text>
        </inputExpression>
      </input>
      <output id="Output_requiredDocuments" label="Documentos Obrigatórios" name="requiredDocuments" typeRef="string" />
      <output id="Output_minimumScore" label="Score Mínimo (%)" name="minimumScore" typeRef="integer" />
      <output id="Output_criticalMissing" label="Itens Críticos Faltantes" name="criticalMissing" typeRef="string" />
      <output id="Output_submissionReady" label="Pronto para Submissão" name="submissionReady" typeRef="boolean" />

      <rule id="Rule_Surgery_High">
        <description>Cirurgia de alta complexidade</description>
        <inputEntry id="InputEntry_Surgery_High_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Surgery_High_type">
          <text>"CIRURGIA","SURGERY"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Surgery_High_complexity">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Surgery_High_emergency">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Surgery_High_preauth">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Surgery_High_docs">
          <text>"Guia TISS completa, Relatório cirúrgico detalhado, Termo de consentimento, Laudo anestésico, Protocolo operatório, Descrição OPME, Autorização prévia aprovada, Exames pré-operatórios, Laudos anatomopatológicos"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Surgery_High_score">
          <text>95</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Surgery_High_critical">
          <text>"Relatório cirúrgico, Autorização prévia"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Surgery_High_ready">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Emergency">
        <description>Atendimento de emergência</description>
        <inputEntry id="InputEntry_Emergency_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Emergency_type">
          <text>"EMERGENCIA","PRONTO_SOCORRO","EMERGENCY"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Emergency_complexity">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Emergency_emergency">
          <text>true</text>
        </inputEntry>
        <inputEntry id="InputEntry_Emergency_preauth">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Emergency_docs">
          <text>"Guia TISS, Boletim de atendimento, Relatório médico de urgência, Declaração de emergência, Evolução clínica, Exames realizados, Justificativa de internação se aplicável"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Emergency_score">
          <text>85</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Emergency_critical">
          <text>"Declaração de emergência, Relatório médico"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Emergency_ready">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_ICU">
        <description>Internação em UTI</description>
        <inputEntry id="InputEntry_ICU_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_ICU_type">
          <text>"UTI","ICU","CTI"</text>
        </inputEntry>
        <inputEntry id="InputEntry_ICU_complexity">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="InputEntry_ICU_emergency">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_ICU_preauth">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_ICU_docs">
          <text>"Guia TISS, Evolução médica diária, Escalas de gravidade (APACHE/SAPS), Justificativa de permanência, Relatório de transferência, Exames de monitoramento, Protocolos assistenciais, Autorização de diárias"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_ICU_score">
          <text>90</text>
        </outputEntry>
        <outputEntry id="OutputEntry_ICU_critical">
          <text>"Escalas de gravidade, Justificativa diária, Autorização"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_ICU_ready">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_OPME">
        <description>Procedimento com OPME</description>
        <inputEntry id="InputEntry_OPME_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_OPME_type">
          <text>"OPME","ORTESE","PROTESE"</text>
        </inputEntry>
        <inputEntry id="InputEntry_OPME_complexity">
          <text>"HIGH","MEDIUM"</text>
        </inputEntry>
        <inputEntry id="InputEntry_OPME_emergency">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_OPME_preauth">
          <text>true</text>
        </inputEntry>
        <outputEntry id="OutputEntry_OPME_docs">
          <text>"Guia TISS, Autorização prévia de OPME, Nota fiscal de materiais, Registro ANVISA dos materiais, Justificativa de uso, Relatório cirúrgico com descrição detalhada, Termo de consentimento específico"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_OPME_score">
          <text>100</text>
        </outputEntry>
        <outputEntry id="OutputEntry_OPME_critical">
          <text>"Autorização OPME, Nota fiscal, Registro ANVISA"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_OPME_ready">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Inpatient_Medium">
        <description>Internação de média complexidade</description>
        <inputEntry id="InputEntry_Inpatient_Medium_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Inpatient_Medium_type">
          <text>"INTERNACAO","INPATIENT"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Inpatient_Medium_complexity">
          <text>"MEDIUM"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Inpatient_Medium_emergency">
          <text>false</text>
        </inputEntry>
        <inputEntry id="InputEntry_Inpatient_Medium_preauth">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Inpatient_Medium_docs">
          <text>"Guia TISS, Relatório de internação, Evolução médica, Exames complementares, Prescrições médicas, Relatório de alta, Autorização de internação"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Inpatient_Medium_score">
          <text>85</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Inpatient_Medium_critical">
          <text>"Relatório de internação, Autorização"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Inpatient_Medium_ready">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Outpatient">
        <description>Consulta ambulatorial</description>
        <inputEntry id="InputEntry_Outpatient_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Outpatient_type">
          <text>"CONSULTA","AMBULATORIO","OUTPATIENT"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Outpatient_complexity">
          <text>"LOW"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Outpatient_emergency">
          <text>false</text>
        </inputEntry>
        <inputEntry id="InputEntry_Outpatient_preauth">
          <text>false</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Outpatient_docs">
          <text>"Guia TISS consulta, Relatório médico, Prescrições se aplicável, Solicitação de exames se aplicável"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Outpatient_score">
          <text>70</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Outpatient_critical">
          <text>"Guia TISS, Relatório médico"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Outpatient_ready">
          <text>true</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Exam_High">
        <description>Exames de alta complexidade</description>
        <inputEntry id="InputEntry_Exam_High_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Exam_High_type">
          <text>"EXAME","DIAGNOSTICO","EXAM"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Exam_High_complexity">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Exam_High_emergency">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Exam_High_preauth">
          <text>true</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Exam_High_docs">
          <text>"Guia TISS SADT, Solicitação médica detalhada, Autorização prévia, Laudo técnico completo, Imagens se aplicável, Justificativa clínica"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Exam_High_score">
          <text>90</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Exam_High_critical">
          <text>"Autorização prévia, Solicitação médica, Laudo"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Exam_High_ready">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Default">
        <description>Caso padrão: documentação básica</description>
        <inputEntry id="InputEntry_Default_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_type">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_complexity">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_emergency">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_preauth">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Default_docs">
          <text>"Guia TISS, Relatório médico, Exames pertinentes, Justificativa clínica"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_score">
          <text>75</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_critical">
          <text>"Guia TISS, Relatório médico"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_ready">
          <text>false</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
