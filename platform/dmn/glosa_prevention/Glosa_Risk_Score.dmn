<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_glosa_risk_score"
             name="Glosa Risk Score"
             namespace="http://camunda.org/schema/1.0/dmn"
             exporter="Camunda Modeler"
             exporterVersion="5.0.0">
  <decision id="Decision_GlosaRiskScore" name="Cálculo de Risco de Glosa">
    <description>Avalia o risco de glosa antes da submissão da conta hospitalar</description>
    <decisionTable id="DecisionTable_GlosaRiskScore" hitPolicy="FIRST">
      <input id="Input_tenantId" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="InputExpression_tenantId" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>
      <input id="Input_documentationCompleteness" label="Completude Documentação (%)" camunda:inputVariable="documentationCompleteness">
        <inputExpression id="InputExpression_documentationCompleteness" typeRef="integer">
          <text>documentationCompleteness</text>
        </inputExpression>
      </input>
      <input id="Input_codingAccuracy" label="Acurácia Codificação (%)" camunda:inputVariable="codingAccuracy">
        <inputExpression id="InputExpression_codingAccuracy" typeRef="integer">
          <text>codingAccuracy</text>
        </inputExpression>
      </input>
      <input id="Input_priorAuthStatus" label="Status Autorização Prévia" camunda:inputVariable="priorAuthStatus">
        <inputExpression id="InputExpression_priorAuthStatus" typeRef="string">
          <text>priorAuthStatus</text>
        </inputExpression>
        <inputValues id="InputValues_priorAuthStatus">
          <text>"APPROVED","PENDING","EXPIRED","NOT_REQUIRED"</text>
        </inputValues>
      </input>
      <input id="Input_payerHistory" label="Histórico Operadora" camunda:inputVariable="payerHistory">
        <inputExpression id="InputExpression_payerHistory" typeRef="string">
          <text>payerHistory</text>
        </inputExpression>
      </input>
      <input id="Input_claimAmount" label="Valor da Conta (R$)" camunda:inputVariable="claimAmount">
        <inputExpression id="InputExpression_claimAmount" typeRef="double">
          <text>claimAmount</text>
        </inputExpression>
      </input>
      <output id="Output_glosaRiskScore" label="Score de Risco" name="glosaRiskScore" typeRef="integer" />
      <output id="Output_riskLevel" label="Nível de Risco" name="riskLevel" typeRef="string">
        <outputValues id="OutputValues_riskLevel">
          <text>"CRITICAL","HIGH","MEDIUM","LOW"</text>
        </outputValues>
      </output>
      <output id="Output_recommendedAction" label="Ação Recomendada" name="recommendedAction" typeRef="string" />
      <output id="Output_holdForReview" label="Reter para Revisão" name="holdForReview" typeRef="boolean" />

      <rule id="Rule_Critical_1">
        <description>Risco crítico: documentação insuficiente e autorização expirada</description>
        <inputEntry id="InputEntry_Critical_1_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_1_doc">
          <text>&lt; 50</text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_1_coding">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_1_auth">
          <text>"EXPIRED"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_1_history">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_1_amount">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Critical_1_score">
          <text>95</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Critical_1_level">
          <text>"CRITICAL"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Critical_1_action">
          <text>"Bloquear submissão. Completar documentação e renovar autorização."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Critical_1_hold">
          <text>true</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Critical_2">
        <description>Risco crítico: baixa acurácia de codificação e alto valor</description>
        <inputEntry id="InputEntry_Critical_2_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_2_doc">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_2_coding">
          <text>&lt; 60</text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_2_auth">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_2_history">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_2_amount">
          <text>&gt; 50000</text>
        </inputEntry>
        <outputEntry id="OutputEntry_Critical_2_score">
          <text>90</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Critical_2_level">
          <text>"CRITICAL"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Critical_2_action">
          <text>"Revisar codificação antes de submeter. Auditoria obrigatória."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Critical_2_hold">
          <text>true</text>
        </outputEntry>
      </rule>

      <rule id="Rule_High_1">
        <description>Risco alto: documentação média com histórico negativo</description>
        <inputEntry id="InputEntry_High_1_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_High_1_doc">
          <text>[50..70)</text>
        </inputEntry>
        <inputEntry id="InputEntry_High_1_coding">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_High_1_auth">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_High_1_history">
          <text>"HIGH_REJECTION_RATE"</text>
        </inputEntry>
        <inputEntry id="InputEntry_High_1_amount">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_High_1_score">
          <text>75</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_1_level">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_1_action">
          <text>"Complementar documentação. Validar requisitos específicos da operadora."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_1_hold">
          <text>true</text>
        </outputEntry>
      </rule>

      <rule id="Rule_High_2">
        <description>Risco alto: autorização pendente com valor alto</description>
        <inputEntry id="InputEntry_High_2_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_High_2_doc">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_High_2_coding">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_High_2_auth">
          <text>"PENDING"</text>
        </inputEntry>
        <inputEntry id="InputEntry_High_2_history">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_High_2_amount">
          <text>&gt; 30000</text>
        </inputEntry>
        <outputEntry id="OutputEntry_High_2_score">
          <text>70</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_2_level">
          <text>"HIGH"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_2_action">
          <text>"Aguardar aprovação de autorização antes de submeter."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_2_hold">
          <text>true</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Medium_1">
        <description>Risco médio: documentação e codificação aceitáveis</description>
        <inputEntry id="InputEntry_Medium_1_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_1_doc">
          <text>[70..85)</text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_1_coding">
          <text>[70..85)</text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_1_auth">
          <text>"APPROVED","NOT_REQUIRED"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_1_history">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_1_amount">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Medium_1_score">
          <text>45</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_1_level">
          <text>"MEDIUM"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_1_action">
          <text>"Revisar pontos específicos. Submissão permitida com acompanhamento."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_1_hold">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Low_1">
        <description>Risco baixo: documentação e codificação excelentes</description>
        <inputEntry id="InputEntry_Low_1_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_1_doc">
          <text>&gt;= 85</text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_1_coding">
          <text>&gt;= 85</text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_1_auth">
          <text>"APPROVED","NOT_REQUIRED"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_1_history">
          <text>"LOW_REJECTION_RATE","AVERAGE"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_1_amount">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Low_1_score">
          <text>15</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_1_level">
          <text>"LOW"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_1_action">
          <text>"Submeter imediatamente. Processo normal."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_1_hold">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Default">
        <description>Caso padrão: risco médio</description>
        <inputEntry id="InputEntry_Default_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_doc">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_coding">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_auth">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_history">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_amount">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Default_score">
          <text>50</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_level">
          <text>"MEDIUM"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_action">
          <text>"Revisar documentação e codificação antes de submeter."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_hold">
          <text>false</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
