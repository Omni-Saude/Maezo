<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             id="Definitions_deadline_monitor"
             name="Deadline Monitor"
             namespace="http://camunda.org/schema/1.0/dmn"
             exporter="Camunda Modeler"
             exporterVersion="5.0.0">
  <decision id="Decision_DeadlineMonitor" name="Monitoramento de Prazos">
    <description>Monitora prazos de submissão e recursos para prevenir glosas por atraso</description>
    <decisionTable id="DecisionTable_DeadlineMonitor" hitPolicy="FIRST">
      <input id="Input_tenantId" label="Tenant ID" camunda:inputVariable="tenantId">
        <inputExpression id="InputExpression_tenantId" typeRef="string">
          <text>tenantId</text>
        </inputExpression>
      </input>
      <input id="Input_eventType" label="Tipo de Evento" camunda:inputVariable="eventType">
        <inputExpression id="InputExpression_eventType" typeRef="string">
          <text>eventType</text>
        </inputExpression>
        <inputValues id="InputValues_eventType">
          <text>"SUBMISSION","APPEAL","RESPONSE","RESUBMISSION"</text>
        </inputValues>
      </input>
      <input id="Input_payerType" label="Tipo de Operadora" camunda:inputVariable="payerType">
        <inputExpression id="InputExpression_payerType" typeRef="string">
          <text>payerType</text>
        </inputExpression>
      </input>
      <input id="Input_daysSinceEvent" label="Dias desde Evento" camunda:inputVariable="daysSinceEvent">
        <inputExpression id="InputExpression_daysSinceEvent" typeRef="integer">
          <text>daysSinceEvent</text>
        </inputExpression>
      </input>
      <input id="Input_regulatoryDeadline" label="Prazo Regulatório (dias)" camunda:inputVariable="regulatoryDeadline">
        <inputExpression id="InputExpression_regulatoryDeadline" typeRef="integer">
          <text>regulatoryDeadline</text>
        </inputExpression>
      </input>
      <output id="Output_daysRemaining" label="Dias Restantes" name="daysRemaining" typeRef="integer" />
      <output id="Output_urgencyLevel" label="Nível de Urgência" name="urgencyLevel" typeRef="string">
        <outputValues id="OutputValues_urgencyLevel">
          <text>"CRITICAL","HIGH","MEDIUM","LOW"</text>
        </outputValues>
      </output>
      <output id="Output_actionRequired" label="Ação Necessária" name="actionRequired" typeRef="string" />
      <output id="Output_autoEscalate" label="Escalar Automaticamente" name="autoEscalate" typeRef="boolean" />

      <rule id="Rule_Critical_Expired">
        <description>Crítico: prazo já vencido</description>
        <inputEntry id="InputEntry_Critical_Expired_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_Expired_eventType">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_Expired_payerType">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_Expired_days">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_Expired_regulatory">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Critical_Expired_remaining">
          <text>daysSinceEvent - regulatoryDeadline</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Critical_Expired_urgency">
          <text>if daysSinceEvent > regulatoryDeadline then "CRITICAL" else null</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Critical_Expired_action">
          <text>"PRAZO VENCIDO! Justificar atraso. Possível perda de direito ao recurso/pagamento."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Critical_Expired_escalate">
          <text>true</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Critical_Submission">
        <description>Crítico: submissão com menos de 3 dias para o prazo</description>
        <inputEntry id="InputEntry_Critical_Submission_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_Submission_eventType">
          <text>"SUBMISSION"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_Submission_payerType">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_Submission_days">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_Submission_regulatory">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Critical_Submission_remaining">
          <text>regulatoryDeadline - daysSinceEvent</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Critical_Submission_urgency">
          <text>if (regulatoryDeadline - daysSinceEvent) &lt;= 3 then "CRITICAL" else null</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Critical_Submission_action">
          <text>"URGENTE: Submeter conta imediatamente. Prioridade máxima. Evitar glosa por atraso."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Critical_Submission_escalate">
          <text>true</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Critical_Appeal">
        <description>Crítico: recurso com menos de 5 dias para o prazo</description>
        <inputEntry id="InputEntry_Critical_Appeal_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_Appeal_eventType">
          <text>"APPEAL"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_Appeal_payerType">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_Appeal_days">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Critical_Appeal_regulatory">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Critical_Appeal_remaining">
          <text>regulatoryDeadline - daysSinceEvent</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Critical_Appeal_urgency">
          <text>if (regulatoryDeadline - daysSinceEvent) &lt;= 5 then "CRITICAL" else null</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Critical_Appeal_action">
          <text>"URGENTE: Finalizar documentação de recurso. Submeter hoje. Risco de perder direito ao recurso."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Critical_Appeal_escalate">
          <text>true</text>
        </outputEntry>
      </rule>

      <rule id="Rule_High_Submission">
        <description>Alta urgência: submissão entre 4-7 dias do prazo</description>
        <inputEntry id="InputEntry_High_Submission_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_High_Submission_eventType">
          <text>"SUBMISSION"</text>
        </inputEntry>
        <inputEntry id="InputEntry_High_Submission_payerType">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_High_Submission_days">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_High_Submission_regulatory">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_High_Submission_remaining">
          <text>regulatoryDeadline - daysSinceEvent</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_Submission_urgency">
          <text>if (regulatoryDeadline - daysSinceEvent) &gt; 3 and (regulatoryDeadline - daysSinceEvent) &lt;= 7 then "HIGH" else null</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_Submission_action">
          <text>"ALTA PRIORIDADE: Acelerar faturamento. Revisar documentação. Submeter em 2-3 dias."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_Submission_escalate">
          <text>true</text>
        </outputEntry>
      </rule>

      <rule id="Rule_High_Appeal">
        <description>Alta urgência: recurso entre 6-10 dias do prazo</description>
        <inputEntry id="InputEntry_High_Appeal_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_High_Appeal_eventType">
          <text>"APPEAL"</text>
        </inputEntry>
        <inputEntry id="InputEntry_High_Appeal_payerType">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_High_Appeal_days">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_High_Appeal_regulatory">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_High_Appeal_remaining">
          <text>regulatoryDeadline - daysSinceEvent</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_Appeal_urgency">
          <text>if (regulatoryDeadline - daysSinceEvent) &gt; 5 and (regulatoryDeadline - daysSinceEvent) &lt;= 10 then "HIGH" else null</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_Appeal_action">
          <text>"PRIORIZAR: Reunir documentação complementar. Preparar argumentação. Enviar em 3-5 dias."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_High_Appeal_escalate">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Medium_Submission">
        <description>Média urgência: submissão entre 8-15 dias do prazo</description>
        <inputEntry id="InputEntry_Medium_Submission_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_Submission_eventType">
          <text>"SUBMISSION"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_Submission_payerType">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_Submission_days">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Medium_Submission_regulatory">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Medium_Submission_remaining">
          <text>regulatoryDeadline - daysSinceEvent</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_Submission_urgency">
          <text>if (regulatoryDeadline - daysSinceEvent) &gt; 7 and (regulatoryDeadline - daysSinceEvent) &lt;= 15 then "MEDIUM" else null</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_Submission_action">
          <text>"Acompanhar fechamento. Completar documentação. Agendar submissão em 5-7 dias."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Medium_Submission_escalate">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Low_Submission">
        <description>Baixa urgência: mais de 15 dias até o prazo</description>
        <inputEntry id="InputEntry_Low_Submission_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_Submission_eventType">
          <text>"SUBMISSION"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_Submission_payerType">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_Submission_days">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Low_Submission_regulatory">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Low_Submission_remaining">
          <text>regulatoryDeadline - daysSinceEvent</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_Submission_urgency">
          <text>if (regulatoryDeadline - daysSinceEvent) &gt; 15 then "LOW" else null</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_Submission_action">
          <text>"Processo normal. Continuar faturamento conforme fluxo padrão. Monitorar progresso."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Low_Submission_escalate">
          <text>false</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Response_Critical">
        <description>Resposta de operadora: prazo crítico</description>
        <inputEntry id="InputEntry_Response_Critical_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Response_Critical_eventType">
          <text>"RESPONSE"</text>
        </inputEntry>
        <inputEntry id="InputEntry_Response_Critical_payerType">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Response_Critical_days">
          <text>&gt; 45</text>
        </inputEntry>
        <inputEntry id="InputEntry_Response_Critical_regulatory">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Response_Critical_remaining">
          <text>60 - daysSinceEvent</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Response_Critical_urgency">
          <text>"CRITICAL"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Response_Critical_action">
          <text>"Operadora ultrapassou prazo de 45 dias. Notificar formalmente. Considerar recurso à ANS por descumprimento de prazo."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Response_Critical_escalate">
          <text>true</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Default">
        <description>Caso padrão</description>
        <inputEntry id="InputEntry_Default_tenantId">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_eventType">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_payerType">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_days">
          <text></text>
        </inputEntry>
        <inputEntry id="InputEntry_Default_regulatory">
          <text></text>
        </inputEntry>
        <outputEntry id="OutputEntry_Default_remaining">
          <text>regulatoryDeadline - daysSinceEvent</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_urgency">
          <text>"MEDIUM"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_action">
          <text>"Monitorar evolução. Seguir fluxo padrão de processamento."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_Default_escalate">
          <text>false</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
