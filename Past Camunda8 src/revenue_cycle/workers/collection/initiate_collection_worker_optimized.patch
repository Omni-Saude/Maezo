# =============================================================================
# PATCH 9: Memory monitoring in __init__
# =============================================================================
# Add memory tracking to __init__:

def __init__(
    self,
    settings=None,
    collection_service=None,
    patient_service=None,
    **kwargs
):
    """Initialize with memory monitoring."""
    with MemoryMonitor("init_collection_worker") as monitor:
        super().__init__(settings=settings)

        # Bounded cache instead of unlimited dict
        self._collection_cases = LRUCache(maxsize=1000)

        # Lazy-loaded services (not initialized until first use)
        self._agency_client = LazyLoader(lambda: self._initialize_agency_client())
        self._collection_service = LazyLoader(
            lambda: collection_service or self._initialize_collection_service()
        )
        self._patient_service = LazyLoader(
            lambda: patient_service or self._initialize_patient_service()
        )

    self._logger.info(
        "worker_initialized",
        memory_delta_mb=monitor.delta_mb,
        memory_peak_mb=monitor.peak_mb,
    )


