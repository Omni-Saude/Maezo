# =============================================================================
# PATCH 1: Add memory optimization imports
# =============================================================================
# After line 21 (after __future__ imports), add:

from revenue_cycle.utils.memory_optimization import (
    MemoryMonitor,
    QuantizedDecimalArray,
    memory_efficient,
    LazyLoader,
    chunked_iterator,
)
from functools import lru_cache


# =============================================================================
# PATCH 2: Replace unlimited dict cache with LRU
# =============================================================================
# Replace line 220:
# OLD:
#     self._collection_cases: dict[str, InitiateCollectionOutput] = {}
#
# NEW:
from cachetools import LRUCache
self._collection_cases = LRUCache(maxsize=1000)  # Bounded memory: max 1000 cases


# =============================================================================
# PATCH 3: Lazy load heavy services
# =============================================================================
# Replace lines 222-225:
# OLD:
#     self._agency_client = None
#     self._collection_service = collection_service
#     self._patient_service = patient_service
#
# NEW:
self._agency_client = LazyLoader(lambda: self._initialize_agency_client())
self._collection_service = LazyLoader(
    lambda: collection_service if collection_service else self._initialize_collection_service()
)
self._patient_service = LazyLoader(
    lambda: patient_service if patient_service else self._initialize_patient_service()
)


