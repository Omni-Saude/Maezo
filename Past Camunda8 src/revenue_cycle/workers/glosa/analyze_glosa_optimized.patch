# =============================================================================
# PATCH 4: INT8 quantization for recovery probabilities
# =============================================================================
# Add helper method for probability storage:

def _quantize_probabilities(
    self,
    probabilities: List[Decimal],
) -> CompactNumericArray:
    """
    Store recovery probabilities (0-100) as INT8.

    Memory savings:
    - List of 1000 Decimals: ~56KB
    - CompactNumericArray (int8): ~1KB
    - Reduction: 98.2%

    Args:
        probabilities: List of percentages (0-100)

    Returns:
        Compact array with INT8 storage
    """
    # Convert Decimal to int (0-100)
    int_probs = [int(p) for p in probabilities]
    return CompactNumericArray.from_list(int_probs, dtype="int8")


