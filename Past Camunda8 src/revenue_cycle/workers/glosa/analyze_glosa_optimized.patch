# PATCH 8: Optimize decision matrix storage
# =============================================================================
# Add compact decision matrix:

class CompactDecisionMatrix:
    """
    Memory-efficient storage for glosa decision matrix.

    Stores decision weights as INT8 instead of Decimal.

    Memory savings:
    - Full Decimal matrix (10x10): ~5.6KB
    - INT8 matrix (10x10): ~100 bytes
    - Reduction: 98.2%
    """

    def __init__(self, rows: int, cols: int):
        self._data = CompactNumericArray.from_list(
            [0] * (rows * cols),
            dtype="int8",
        )
        self._rows = rows
        self._cols = cols

    def set(self, row: int, col: int, value: int):
        """Set value at (row, col)."""
        idx = row * self._cols + col
        self._data._data[idx] = value

    def get(self, row: int, col: int) -> int:
        """Get value at (row, col)."""
        idx = row * self._cols + col
        return self._data[idx]


