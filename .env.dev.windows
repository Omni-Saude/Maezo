# =============================================================================
# MAEZO — Variaveis para rodar workers no Windows (apontando para servidor Linux)
#
# Instrucoes:
#   1. Copie este arquivo: cp .env.dev.windows .env.dev.windows.local
#   2. Substitua <SERVER_IP> pelo IP do servidor Linux (ex: 192.168.1.100)
#   3. Use com: bash scripts/dev/run_worker_local.sh --domain revenue_cycle
# =============================================================================

# IP do servidor Linux (ALTERAR AQUI)
DEV_SERVER_IP=<SERVER_IP>

# CIB Seven BPM Engine
CIBSEVEN_ENGINE_URL=http://${DEV_SERVER_IP}:8085/engine-rest
CIB7_BASE_URL=http://${DEV_SERVER_IP}:8085/engine-rest
CIB7_USER=admin
CIB7_PASSWORD=admin

# HAPI FHIR R4
FHIR_BASE_URL=http://${DEV_SERVER_IP}:8082/fhir

# PostgreSQL
DATABASE_URL=postgresql://maestro:maestro_dev@${DEV_SERVER_IP}:5435/maestro

# Kafka (correlacao de mensagens BPMN)
KAFKA_BOOTSTRAP_SERVERS=${DEV_SERVER_IP}:9092

# Worker config
LOG_LEVEL=DEBUG
PYTHONPATH=src
