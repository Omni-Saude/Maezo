<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_Orchestrator" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.0.0">
  <bpmn:collaboration id="Collaboration_Orchestrator">
    <bpmn:participant id="Participant_Hospital" name="Hospital do Futuro - Orquestrador do Ciclo da Receita" processRef="Process_ORCH_Ciclo_Receita" />
  </bpmn:collaboration>
  <bpmn:process id="Process_ORCH_Ciclo_Receita" name="Orquestrador do Ciclo da Receita" isExecutable="true" camunda:historyTimeToLive="P365D">
    <bpmn:extensionElements>
      <camunda:executionListener event="start" delegateExpression="${processMetricsListener}" />
      <camunda:executionListener event="end" delegateExpression="${processMetricsListener}" />
    </bpmn:extensionElements>
    <bpmn:laneSet id="LaneSet_Orchestrator">
      <bpmn:lane id="Lane_Orquestrador" name="Orquestrador">
        <bpmn:flowNodeRef>StartEvent_Inicio</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CheckIdempotency</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_CheckDuplicate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Duplicate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CallActivity_Agendamento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CallActivity_PreAtendimento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CallActivity_AtendimentoClinico</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CallActivity_Faturamento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CallActivity_AuditoriaMedica</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Prepare_Billing_Message</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_Send_Billing_Message</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_Wait_Billing_Complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Prepare_Denials_Message</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_Send_Denials_Message</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_Wait_Denials_Complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CallActivity_RecebimentoPagamento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CallActivity_AnaliseIndicadores</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CallActivity_MelhoriaContinua</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Fim</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Parallel_Inicio</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Parallel_Join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Error_Agendamento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Error_PreAtendimento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Error_AtendimentoClinico</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Error_Faturamento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Error_AuditoriaMedica</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Error_RecebimentoPagamento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Error_AnaliseIndicadores</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Error_MelhoriaContinua</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Timeout_Agendamento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Timeout_PreAtendimento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Timeout_AtendimentoClinico</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Timeout_Faturamento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Timeout_AuditoriaMedica</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Timeout_RecebimentoPagamento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Timeout_AnaliseIndicadores</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Timeout_MelhoriaContinua</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Inicio" name="Início do Ciclo da Receita">
      <bpmn:outgoing>Flow_Start_To_CheckIdempotency</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_CheckIdempotency" name="Verificar Idempotência" camunda:asyncBefore="true" camunda:delegateExpression="${checkIdempotencyDelegate}">
      <bpmn:incoming>Flow_Start_To_CheckIdempotency</bpmn:incoming>
      <bpmn:outgoing>Flow_CheckIdempotency_To_Gateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_CheckDuplicate" name="É duplicado?" default="Flow_Gateway_To_Agendamento">
      <bpmn:incoming>Flow_CheckIdempotency_To_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Gateway_To_Agendamento</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gateway_To_Duplicate</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_Duplicate" name="Processo Duplicado">
      <bpmn:incoming>Flow_Gateway_To_Duplicate</bpmn:incoming>
      <bpmn:messageEventDefinition messageRef="Message_Duplicate" />
    </bpmn:endEvent>
    <bpmn:callActivity id="CallActivity_Agendamento" name="SUB 01 - Agendamento e Registro" calledElement="Process_SUB01_Agendamento" camunda:asyncBefore="true">
      <bpmn:extensionElements>
        <camunda:in businessKey="${execution.processBusinessKey}" />
        <camunda:in variables="all" />
        <camunda:out variables="all" />
        <camunda:executionListener event="start" delegateExpression="${processMetricsListener}" />
        <camunda:executionListener event="end" delegateExpression="${processMetricsListener}" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Gateway_To_Agendamento</bpmn:incoming>
      <bpmn:outgoing>Flow_Agendamento_To_PreAtendimento</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:callActivity id="CallActivity_PreAtendimento" name="SUB 02 - Pré-Atendimento" calledElement="Process_SUB02_PreAtendimento" camunda:asyncBefore="true">
      <bpmn:extensionElements>
        <camunda:in businessKey="${execution.processBusinessKey}" />
        <camunda:in variables="all" />
        <camunda:out variables="all" />
        <camunda:executionListener event="start" delegateExpression="${processMetricsListener}" />
        <camunda:executionListener event="end" delegateExpression="${processMetricsListener}" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Agendamento_To_PreAtendimento</bpmn:incoming>
      <bpmn:outgoing>Flow_PreAtendimento_To_Atendimento</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:callActivity id="CallActivity_AtendimentoClinico" name="SUB 03 - Atendimento Clínico" calledElement="Process_SUB03_AtendimentoClinico" camunda:asyncBefore="true">
      <bpmn:extensionElements>
        <camunda:in businessKey="${execution.processBusinessKey}" />
        <camunda:in variables="all" />
        <camunda:out variables="all" />
        <camunda:executionListener event="start" delegateExpression="${processMetricsListener}" />
        <camunda:executionListener event="end" delegateExpression="${processMetricsListener}" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_PreAtendimento_To_Atendimento</bpmn:incoming>
      <bpmn:outgoing>Flow_Atendimento_To_Parallel</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:parallelGateway id="Gateway_Parallel_Inicio" name="Processos Paralelos">
      <bpmn:incoming>Flow_Atendimento_To_Parallel</bpmn:incoming>
      <bpmn:outgoing>Flow_Parallel_To_Faturamento</bpmn:outgoing>
      <bpmn:outgoing>Flow_Parallel_To_Auditoria</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:callActivity id="CallActivity_Faturamento" name="SUB 04 - Faturamento" calledElement="Process_SUB_04_Clinical_Production" camunda:asyncBefore="true">
      <bpmn:extensionElements>
        <camunda:in businessKey="${execution.processBusinessKey}" />
        <camunda:in variables="all" />
        <camunda:out variables="all" />
        <camunda:executionListener event="start" delegateExpression="${processMetricsListener}" />
        <camunda:executionListener event="end" delegateExpression="${processMetricsListener}" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Parallel_To_Faturamento</bpmn:incoming>
      <bpmn:outgoing>Flow_Faturamento_To_Join</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:callActivity id="CallActivity_AuditoriaMedica" name="SUB 05 - Auditoria Médica" calledElement="Process_SUB_05_Coding_Audit" camunda:asyncBefore="true">
      <bpmn:extensionElements>
        <camunda:in businessKey="${execution.processBusinessKey}" />
        <camunda:in variables="all" />
        <camunda:out variables="all" />
        <camunda:executionListener event="start" delegateExpression="${processMetricsListener}" />
        <camunda:executionListener event="end" delegateExpression="${processMetricsListener}" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Parallel_To_Auditoria</bpmn:incoming>
      <bpmn:outgoing>Flow_Auditoria_To_Join</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:parallelGateway id="Gateway_Parallel_Join" name="Sincronização">
      <bpmn:incoming>Flow_Faturamento_To_Join</bpmn:incoming>
      <bpmn:incoming>Flow_Auditoria_To_Join</bpmn:incoming>
      <bpmn:outgoing>Flow_Join_To_Glosas</bpmn:outgoing>
    </bpmn:parallelGateway>
    <!-- ASYNC MESSAGE PATTERN: SUB_06 Billing Submission -->
    <!-- Step 1: Prepare message payload -->
    <bpmn:serviceTask id="Task_Prepare_Billing_Message" name="Preparar Mensagem Faturamento" camunda:asyncBefore="true" camunda:delegateExpression="${prepareBillingMessageDelegate}">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="atendimentoId">${execution.processBusinessKey}</camunda:inputParameter>
          <camunda:inputParameter name="consolidatedCharges">${consolidatedCharges}</camunda:inputParameter>
          <camunda:inputParameter name="insuranceId">${insuranceId}</camunda:inputParameter>
          <camunda:outputParameter name="billingMessagePayload">${billingMessagePayload}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Join_To_Glosas</bpmn:incoming>
      <bpmn:outgoing>Flow_Prepare_Billing_To_Send</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Step 2: Send message asynchronously (Intermediate Throw Event) -->
    <bpmn:intermediateThrowEvent id="Event_Send_Billing_Message" name="Enviar para Faturamento">
      <bpmn:incoming>Flow_Prepare_Billing_To_Send</bpmn:incoming>
      <bpmn:outgoing>Flow_Send_Billing_To_Wait</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_StartBillingSubmission" camunda:delegateExpression="${sendMessageDelegate}" />
    </bpmn:intermediateThrowEvent>

    <!-- Step 3: Wait for completion message (Intermediate Catch Event) -->
    <bpmn:intermediateCatchEvent id="Event_Wait_Billing_Complete" name="Aguardar Faturamento">
      <bpmn:incoming>Flow_Send_Billing_To_Wait</bpmn:incoming>
      <bpmn:outgoing>Flow_Billing_Complete_To_Denials</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_BillingCompleted" />
    </bpmn:intermediateCatchEvent>

    <!-- LEGACY: Keep original Call Activity commented for reference -->
    <!--
    <bpmn:callActivity id="CallActivity_Glosas" name="SUB 06 - Gestão de Glosas" calledElement="Process_SUB_06_Billing_Submission" camunda:asyncBefore="true">
      <bpmn:extensionElements>
        <camunda:in businessKey="${execution.processBusinessKey}" />
        <camunda:in variables="all" />
        <camunda:out variables="all" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Join_To_Glosas</bpmn:incoming>
      <bpmn:outgoing>Flow_Glosas_To_Cobranca</bpmn:outgoing>
    </bpmn:callActivity>
    -->
    <!-- ASYNC MESSAGE PATTERN: SUB_07 Denials Management -->
    <!-- Step 1: Prepare message payload -->
    <bpmn:serviceTask id="Task_Prepare_Denials_Message" name="Preparar Mensagem Glosas" camunda:asyncBefore="true" camunda:delegateExpression="${prepareDenialsMessageDelegate}">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="atendimentoId">${execution.processBusinessKey}</camunda:inputParameter>
          <camunda:inputParameter name="billingResult">${billingResult}</camunda:inputParameter>
          <camunda:inputParameter name="protocolNumber">${protocolNumber}</camunda:inputParameter>
          <camunda:outputParameter name="denialsMessagePayload">${denialsMessagePayload}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Billing_Complete_To_Denials</bpmn:incoming>
      <bpmn:outgoing>Flow_Prepare_Denials_To_Send</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Step 2: Send message asynchronously (Intermediate Throw Event) -->
    <bpmn:intermediateThrowEvent id="Event_Send_Denials_Message" name="Enviar para Glosas">
      <bpmn:incoming>Flow_Prepare_Denials_To_Send</bpmn:incoming>
      <bpmn:outgoing>Flow_Send_Denials_To_Wait</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_StartDenialsManagement" camunda:delegateExpression="${sendMessageDelegate}" />
    </bpmn:intermediateThrowEvent>

    <!-- Step 3: Wait for completion message (Intermediate Catch Event) -->
    <bpmn:intermediateCatchEvent id="Event_Wait_Denials_Complete" name="Aguardar Glosas">
      <bpmn:incoming>Flow_Send_Denials_To_Wait</bpmn:incoming>
      <bpmn:outgoing>Flow_Denials_Complete_To_Recebimento</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_DenialResolved" />
    </bpmn:intermediateCatchEvent>

    <!-- LEGACY: Keep original Call Activity commented for reference -->
    <!--
    <bpmn:callActivity id="CallActivity_Cobranca" name="SUB 07 - Cobrança" calledElement="Process_SUB_07_Denials_Management" camunda:asyncBefore="true">
      <bpmn:extensionElements>
        <camunda:in businessKey="${execution.processBusinessKey}" />
        <camunda:in variables="all" />
        <camunda:out variables="all" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Glosas_To_Cobranca</bpmn:incoming>
      <bpmn:outgoing>Flow_Cobranca_To_Recebimento</bpmn:outgoing>
    </bpmn:callActivity>
    -->
    <bpmn:callActivity id="CallActivity_RecebimentoPagamento" name="SUB 08 - Recebimento e Pagamento" calledElement="Process_SUB_08_Revenue_Collection" camunda:asyncBefore="true">
      <bpmn:extensionElements>
        <camunda:in businessKey="${execution.processBusinessKey}" />
        <camunda:in variables="all" />
        <camunda:out variables="all" />
        <camunda:executionListener event="start" delegateExpression="${processMetricsListener}" />
        <camunda:executionListener event="end" delegateExpression="${processMetricsListener}" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Denials_Complete_To_Recebimento</bpmn:incoming>
      <bpmn:outgoing>Flow_Recebimento_To_Analise</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:callActivity id="CallActivity_AnaliseIndicadores" name="SUB 09 - Análise de Indicadores" calledElement="Process_SUB_09_Analytics" camunda:asyncBefore="true">
      <bpmn:extensionElements>
        <camunda:in businessKey="${execution.processBusinessKey}" />
        <camunda:in variables="all" />
        <camunda:out variables="all" />
        <camunda:executionListener event="start" delegateExpression="${processMetricsListener}" />
        <camunda:executionListener event="end" delegateExpression="${processMetricsListener}" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Recebimento_To_Analise</bpmn:incoming>
      <bpmn:outgoing>Flow_Analise_To_Melhoria</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:callActivity id="CallActivity_MelhoriaContinua" name="SUB 10 - Melhoria Contínua" calledElement="Process_SUB10_MelhoriaContinua" camunda:asyncBefore="true">
      <bpmn:extensionElements>
        <camunda:in businessKey="${execution.processBusinessKey}" />
        <camunda:in variables="all" />
        <camunda:out variables="all" />
        <camunda:executionListener event="start" delegateExpression="${processMetricsListener}" />
        <camunda:executionListener event="end" delegateExpression="${processMetricsListener}" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Analise_To_Melhoria</bpmn:incoming>
      <bpmn:outgoing>Flow_Melhoria_To_End</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:endEvent id="EndEvent_Fim" name="Ciclo Completo">
      <bpmn:incoming>Flow_Melhoria_To_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_CheckIdempotency" sourceRef="StartEvent_Inicio" targetRef="Task_CheckIdempotency" />
    <bpmn:sequenceFlow id="Flow_CheckIdempotency_To_Gateway" sourceRef="Task_CheckIdempotency" targetRef="Gateway_CheckDuplicate" />
    <bpmn:sequenceFlow id="Flow_Gateway_To_Agendamento" name="Novo processo" sourceRef="Gateway_CheckDuplicate" targetRef="CallActivity_Agendamento" />
    <bpmn:sequenceFlow id="Flow_Gateway_To_Duplicate" name="Duplicado" sourceRef="Gateway_CheckDuplicate" targetRef="EndEvent_Duplicate">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${is_duplicate == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Agendamento_To_PreAtendimento" sourceRef="CallActivity_Agendamento" targetRef="CallActivity_PreAtendimento" />
    <bpmn:sequenceFlow id="Flow_PreAtendimento_To_Atendimento" sourceRef="CallActivity_PreAtendimento" targetRef="CallActivity_AtendimentoClinico" />
    <bpmn:sequenceFlow id="Flow_Atendimento_To_Parallel" sourceRef="CallActivity_AtendimentoClinico" targetRef="Gateway_Parallel_Inicio" />
    <bpmn:sequenceFlow id="Flow_Parallel_To_Faturamento" sourceRef="Gateway_Parallel_Inicio" targetRef="CallActivity_Faturamento" />
    <bpmn:sequenceFlow id="Flow_Parallel_To_Auditoria" sourceRef="Gateway_Parallel_Inicio" targetRef="CallActivity_AuditoriaMedica" />
    <bpmn:sequenceFlow id="Flow_Faturamento_To_Join" sourceRef="CallActivity_Faturamento" targetRef="Gateway_Parallel_Join" />
    <bpmn:sequenceFlow id="Flow_Auditoria_To_Join" sourceRef="CallActivity_AuditoriaMedica" targetRef="Gateway_Parallel_Join" />
    <!-- Sequence Flows for Async Message Pattern SUB_06 -->
    <bpmn:sequenceFlow id="Flow_Join_To_Glosas" sourceRef="Gateway_Parallel_Join" targetRef="Task_Prepare_Billing_Message" />
    <bpmn:sequenceFlow id="Flow_Prepare_Billing_To_Send" sourceRef="Task_Prepare_Billing_Message" targetRef="Event_Send_Billing_Message" />
    <bpmn:sequenceFlow id="Flow_Send_Billing_To_Wait" sourceRef="Event_Send_Billing_Message" targetRef="Event_Wait_Billing_Complete" />
    <bpmn:sequenceFlow id="Flow_Billing_Complete_To_Denials" sourceRef="Event_Wait_Billing_Complete" targetRef="Task_Prepare_Denials_Message" />

    <!-- Sequence Flows for Async Message Pattern SUB_07 -->
    <bpmn:sequenceFlow id="Flow_Prepare_Denials_To_Send" sourceRef="Task_Prepare_Denials_Message" targetRef="Event_Send_Denials_Message" />
    <bpmn:sequenceFlow id="Flow_Send_Denials_To_Wait" sourceRef="Event_Send_Denials_Message" targetRef="Event_Wait_Denials_Complete" />
    <bpmn:sequenceFlow id="Flow_Denials_Complete_To_Recebimento" sourceRef="Event_Wait_Denials_Complete" targetRef="CallActivity_RecebimentoPagamento" />
    <bpmn:sequenceFlow id="Flow_Recebimento_To_Analise" sourceRef="CallActivity_RecebimentoPagamento" targetRef="CallActivity_AnaliseIndicadores" />
    <bpmn:sequenceFlow id="Flow_Analise_To_Melhoria" sourceRef="CallActivity_AnaliseIndicadores" targetRef="CallActivity_MelhoriaContinua" />
    <bpmn:sequenceFlow id="Flow_Melhoria_To_End" sourceRef="CallActivity_MelhoriaContinua" targetRef="EndEvent_Fim" />
    <!-- Error Boundary Events -->
    <bpmn:boundaryEvent id="BoundaryEvent_Error_Agendamento" name="Agendamento Error" attachedToRef="CallActivity_Agendamento">
      <bpmn:outgoing>Flow_Error_Agendamento</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_AgendamentoFailed" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Error_PreAtendimento" name="PreAtendimento Error" attachedToRef="CallActivity_PreAtendimento">
      <bpmn:outgoing>Flow_Error_PreAtendimento</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_PreAtendimentoFailed" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Error_AtendimentoClinico" name="Atendimento Error" attachedToRef="CallActivity_AtendimentoClinico">
      <bpmn:outgoing>Flow_Error_AtendimentoClinico</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_AtendimentoClinicoFailed" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Error_Faturamento" name="Faturamento Error" attachedToRef="CallActivity_Faturamento">
      <bpmn:outgoing>Flow_Error_Faturamento</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_FaturamentoFailed" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Error_AuditoriaMedica" name="Auditoria Error" attachedToRef="CallActivity_AuditoriaMedica">
      <bpmn:outgoing>Flow_Error_AuditoriaMedica</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_AuditoriaMedicaFailed" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Error_RecebimentoPagamento" name="Recebimento Error" attachedToRef="CallActivity_RecebimentoPagamento">
      <bpmn:outgoing>Flow_Error_RecebimentoPagamento</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_RecebimentoPagamentoFailed" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Error_AnaliseIndicadores" name="Analise Error" attachedToRef="CallActivity_AnaliseIndicadores">
      <bpmn:outgoing>Flow_Error_AnaliseIndicadores</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_AnaliseIndicadoresFailed" />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Error_MelhoriaContinua" name="Melhoria Error" attachedToRef="CallActivity_MelhoriaContinua">
      <bpmn:outgoing>Flow_Error_MelhoriaContinua</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_MelhoriaContinuaFailed" />
    </bpmn:boundaryEvent>
    <!-- Compensation Boundary Events -->
    <bpmn:boundaryEvent id="BoundaryEvent_Compensation_Agendamento" name="Compensate Agendamento" attachedToRef="CallActivity_Agendamento">
      <bpmn:compensateEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Compensation_PreAtendimento" name="Compensate PreAtendimento" attachedToRef="CallActivity_PreAtendimento">
      <bpmn:compensateEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Compensation_AtendimentoClinico" name="Compensate Atendimento" attachedToRef="CallActivity_AtendimentoClinico">
      <bpmn:compensateEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Compensation_Faturamento" name="Compensate Faturamento" attachedToRef="CallActivity_Faturamento">
      <bpmn:compensateEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Compensation_AuditoriaMedica" name="Compensate Auditoria" attachedToRef="CallActivity_AuditoriaMedica">
      <bpmn:compensateEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Compensation_RecebimentoPagamento" name="Compensate Recebimento" attachedToRef="CallActivity_RecebimentoPagamento">
      <bpmn:compensateEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Compensation_AnaliseIndicadores" name="Compensate Analise" attachedToRef="CallActivity_AnaliseIndicadores">
      <bpmn:compensateEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Compensation_MelhoriaContinua" name="Compensate Melhoria" attachedToRef="CallActivity_MelhoriaContinua">
      <bpmn:compensateEventDefinition />
    </bpmn:boundaryEvent>
    <!-- Timeout Boundary Events -->
    <bpmn:boundaryEvent id="BoundaryEvent_Timeout_Agendamento" name="Timeout 2h" attachedToRef="CallActivity_Agendamento" cancelActivity="false">
      <bpmn:outgoing>Flow_Timeout_Agendamento</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration>PT2H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Timeout_PreAtendimento" name="Timeout 4h" attachedToRef="CallActivity_PreAtendimento" cancelActivity="false">
      <bpmn:outgoing>Flow_Timeout_PreAtendimento</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration>PT4H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Timeout_AtendimentoClinico" name="Timeout 1d" attachedToRef="CallActivity_AtendimentoClinico" cancelActivity="false">
      <bpmn:outgoing>Flow_Timeout_AtendimentoClinico</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration>P1D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Timeout_Faturamento" name="Timeout 8h" attachedToRef="CallActivity_Faturamento" cancelActivity="false">
      <bpmn:outgoing>Flow_Timeout_Faturamento</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration>PT8H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Timeout_AuditoriaMedica" name="Timeout 3d" attachedToRef="CallActivity_AuditoriaMedica" cancelActivity="false">
      <bpmn:outgoing>Flow_Timeout_AuditoriaMedica</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration>P3D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Timeout_RecebimentoPagamento" name="Timeout 90d" attachedToRef="CallActivity_RecebimentoPagamento" cancelActivity="false">
      <bpmn:outgoing>Flow_Timeout_RecebimentoPagamento</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration>P90D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Timeout_AnaliseIndicadores" name="Timeout 8h" attachedToRef="CallActivity_AnaliseIndicadores" cancelActivity="false">
      <bpmn:outgoing>Flow_Timeout_AnaliseIndicadores</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration>PT8H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_Timeout_MelhoriaContinua" name="Timeout 7d" attachedToRef="CallActivity_MelhoriaContinua" cancelActivity="false">
      <bpmn:outgoing>Flow_Timeout_MelhoriaContinua</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration>P7D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <!-- Error Handling End Events -->
    <bpmn:endEvent id="EndEvent_Error_Agendamento" name="Agendamento Failed">
      <bpmn:incoming>Flow_Error_Agendamento</bpmn:incoming>
      <bpmn:errorEventDefinition errorRef="Error_AgendamentoFailed" />
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Error_PreAtendimento" name="PreAtendimento Failed">
      <bpmn:incoming>Flow_Error_PreAtendimento</bpmn:incoming>
      <bpmn:errorEventDefinition errorRef="Error_PreAtendimentoFailed" />
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Error_AtendimentoClinico" name="Atendimento Failed">
      <bpmn:incoming>Flow_Error_AtendimentoClinico</bpmn:incoming>
      <bpmn:errorEventDefinition errorRef="Error_AtendimentoClinicoFailed" />
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Error_Faturamento" name="Faturamento Failed">
      <bpmn:incoming>Flow_Error_Faturamento</bpmn:incoming>
      <bpmn:errorEventDefinition errorRef="Error_FaturamentoFailed" />
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Error_AuditoriaMedica" name="Auditoria Failed">
      <bpmn:incoming>Flow_Error_AuditoriaMedica</bpmn:incoming>
      <bpmn:errorEventDefinition errorRef="Error_AuditoriaMedicaFailed" />
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Error_RecebimentoPagamento" name="Recebimento Failed">
      <bpmn:incoming>Flow_Error_RecebimentoPagamento</bpmn:incoming>
      <bpmn:errorEventDefinition errorRef="Error_RecebimentoPagamentoFailed" />
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Error_AnaliseIndicadores" name="Analise Failed">
      <bpmn:incoming>Flow_Error_AnaliseIndicadores</bpmn:incoming>
      <bpmn:errorEventDefinition errorRef="Error_AnaliseIndicadoresFailed" />
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Error_MelhoriaContinua" name="Melhoria Failed">
      <bpmn:incoming>Flow_Error_MelhoriaContinua</bpmn:incoming>
      <bpmn:errorEventDefinition errorRef="Error_MelhoriaContinuaFailed" />
    </bpmn:endEvent>
    <!-- Timeout End Events -->
    <bpmn:endEvent id="EndEvent_Timeout_Agendamento" name="Agendamento Timeout">
      <bpmn:incoming>Flow_Timeout_Agendamento</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Timeout_PreAtendimento" name="PreAtendimento Timeout">
      <bpmn:incoming>Flow_Timeout_PreAtendimento</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Timeout_AtendimentoClinico" name="Atendimento Timeout">
      <bpmn:incoming>Flow_Timeout_AtendimentoClinico</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Timeout_Faturamento" name="Faturamento Timeout">
      <bpmn:incoming>Flow_Timeout_Faturamento</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Timeout_AuditoriaMedica" name="Auditoria Timeout">
      <bpmn:incoming>Flow_Timeout_AuditoriaMedica</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Timeout_RecebimentoPagamento" name="Recebimento Timeout">
      <bpmn:incoming>Flow_Timeout_RecebimentoPagamento</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Timeout_AnaliseIndicadores" name="Analise Timeout">
      <bpmn:incoming>Flow_Timeout_AnaliseIndicadores</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Timeout_MelhoriaContinua" name="Melhoria Timeout">
      <bpmn:incoming>Flow_Timeout_MelhoriaContinua</bpmn:incoming>
    </bpmn:endEvent>
    <!-- Error Flows -->
    <bpmn:sequenceFlow id="Flow_Error_Agendamento" sourceRef="BoundaryEvent_Error_Agendamento" targetRef="EndEvent_Error_Agendamento" />
    <bpmn:sequenceFlow id="Flow_Error_PreAtendimento" sourceRef="BoundaryEvent_Error_PreAtendimento" targetRef="EndEvent_Error_PreAtendimento" />
    <bpmn:sequenceFlow id="Flow_Error_AtendimentoClinico" sourceRef="BoundaryEvent_Error_AtendimentoClinico" targetRef="EndEvent_Error_AtendimentoClinico" />
    <bpmn:sequenceFlow id="Flow_Error_Faturamento" sourceRef="BoundaryEvent_Error_Faturamento" targetRef="EndEvent_Error_Faturamento" />
    <bpmn:sequenceFlow id="Flow_Error_AuditoriaMedica" sourceRef="BoundaryEvent_Error_AuditoriaMedica" targetRef="EndEvent_Error_AuditoriaMedica" />
    <bpmn:sequenceFlow id="Flow_Error_RecebimentoPagamento" sourceRef="BoundaryEvent_Error_RecebimentoPagamento" targetRef="EndEvent_Error_RecebimentoPagamento" />
    <bpmn:sequenceFlow id="Flow_Error_AnaliseIndicadores" sourceRef="BoundaryEvent_Error_AnaliseIndicadores" targetRef="EndEvent_Error_AnaliseIndicadores" />
    <bpmn:sequenceFlow id="Flow_Error_MelhoriaContinua" sourceRef="BoundaryEvent_Error_MelhoriaContinua" targetRef="EndEvent_Error_MelhoriaContinua" />
    <!-- Timeout Flows -->
    <bpmn:sequenceFlow id="Flow_Timeout_Agendamento" sourceRef="BoundaryEvent_Timeout_Agendamento" targetRef="EndEvent_Timeout_Agendamento" />
    <bpmn:sequenceFlow id="Flow_Timeout_PreAtendimento" sourceRef="BoundaryEvent_Timeout_PreAtendimento" targetRef="EndEvent_Timeout_PreAtendimento" />
    <bpmn:sequenceFlow id="Flow_Timeout_AtendimentoClinico" sourceRef="BoundaryEvent_Timeout_AtendimentoClinico" targetRef="EndEvent_Timeout_AtendimentoClinico" />
    <bpmn:sequenceFlow id="Flow_Timeout_Faturamento" sourceRef="BoundaryEvent_Timeout_Faturamento" targetRef="EndEvent_Timeout_Faturamento" />
    <bpmn:sequenceFlow id="Flow_Timeout_AuditoriaMedica" sourceRef="BoundaryEvent_Timeout_AuditoriaMedica" targetRef="EndEvent_Timeout_AuditoriaMedica" />
    <bpmn:sequenceFlow id="Flow_Timeout_RecebimentoPagamento" sourceRef="BoundaryEvent_Timeout_RecebimentoPagamento" targetRef="EndEvent_Timeout_RecebimentoPagamento" />
    <bpmn:sequenceFlow id="Flow_Timeout_AnaliseIndicadores" sourceRef="BoundaryEvent_Timeout_AnaliseIndicadores" targetRef="EndEvent_Timeout_AnaliseIndicadores" />
    <bpmn:sequenceFlow id="Flow_Timeout_MelhoriaContinua" sourceRef="BoundaryEvent_Timeout_MelhoriaContinua" targetRef="EndEvent_Timeout_MelhoriaContinua" />
  </bpmn:process>

  <!-- Error Definitions (at definitions level, not inside process) -->
  <bpmn:error id="Error_AgendamentoFailed" name="Error_AgendamentoFailed" errorCode="ERR_AGENDAMENTO" />
  <bpmn:error id="Error_PreAtendimentoFailed" name="Error_PreAtendimentoFailed" errorCode="ERR_PREATENDIMENTO" />
  <bpmn:error id="Error_AtendimentoClinicoFailed" name="Error_AtendimentoClinicoFailed" errorCode="ERR_ATENDIMENTO_CLINICO" />
  <bpmn:error id="Error_FaturamentoFailed" name="Error_FaturamentoFailed" errorCode="ERR_FATURAMENTO" />
  <bpmn:error id="Error_AuditoriaMedicaFailed" name="Error_AuditoriaMedicaFailed" errorCode="ERR_AUDITORIA_MEDICA" />
  <bpmn:error id="Error_RecebimentoPagamentoFailed" name="Error_RecebimentoPagamentoFailed" errorCode="ERR_RECEBIMENTO_PAGAMENTO" />
  <bpmn:error id="Error_AnaliseIndicadoresFailed" name="Error_AnaliseIndicadoresFailed" errorCode="ERR_ANALISE_INDICADORES" />
  <bpmn:error id="Error_MelhoriaContinuaFailed" name="Error_MelhoriaContinuaFailed" errorCode="ERR_MELHORIA_CONTINUA" />

  <!-- Global Message Definitions for Async Subprocess Communication -->
  <bpmn:message id="Message_Duplicate" name="Message_Duplicate" />

  <!-- SUB_06 Billing Submission Messages -->
  <bpmn:message id="Message_StartBillingSubmission" name="StartBillingSubmissionMessage" />
  <bpmn:message id="Message_BillingCompleted" name="BillingCompletedMessage" />

  <!-- SUB_07 Denials Management Messages -->
  <bpmn:message id="Message_StartDenialsManagement" name="StartDenialsManagementMessage" />
