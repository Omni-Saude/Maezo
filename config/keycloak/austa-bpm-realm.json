{
  "realm": "maezo-bpm",
  "enabled": true,
  "displayName": "MAEZO BPM Platform",
  "sslRequired": "external",
  "registrationAllowed": false,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      { "name": "admin", "description": "Full engine access" },
      { "name": "operator", "description": "Cockpit read + Tasklist full" },
      { "name": "analyst", "description": "Cockpit read + ins7ght" },
      { "name": "viewer", "description": "Read-only dashboards" }
    ]
  },
  "groups": [
    { "name": "hospital-a", "path": "/hospital-a" },
    { "name": "amh-sp-morumbi", "path": "/amh-sp-morumbi" },
    { "name": "amh-rj-barra", "path": "/amh-rj-barra" },
    { "name": "amh-mg-bh", "path": "/amh-mg-bh" }
  ],
  "clientScopes": [
    {
      "name": "external-task",
      "protocol": "openid-connect",
      "description": "Access to CIB Seven External Task API"
    },
    {
      "name": "fhir-read",
      "protocol": "openid-connect",
      "description": "Read access to HAPI FHIR resources"
    },
    {
      "name": "fhir-write",
      "protocol": "openid-connect",
      "description": "Write access to HAPI FHIR resources"
    },
    {
      "name": "process-start",
      "protocol": "openid-connect",
      "description": "Permission to start process instances"
    },
    {
      "name": "message-correlate",
      "protocol": "openid-connect",
      "description": "Permission to correlate messages to processes"
    },
    {
      "name": "history-read",
      "protocol": "openid-connect",
      "description": "Read access to process history"
    }
  ],
  "clients": [
    {
      "clientId": "worker-eligibility",
      "enabled": true,
      "serviceAccountsEnabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "changeme-eligibility",
      "defaultClientScopes": ["external-task", "fhir-read"],
      "protocol": "openid-connect",
      "publicClient": false,
      "directAccessGrantsEnabled": false
    },
    {
      "clientId": "worker-tiss",
      "enabled": true,
      "serviceAccountsEnabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "changeme-tiss",
      "defaultClientScopes": ["external-task", "fhir-read"],
      "protocol": "openid-connect",
      "publicClient": false,
      "directAccessGrantsEnabled": false
    },
    {
      "clientId": "worker-denial",
      "enabled": true,
      "serviceAccountsEnabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "changeme-denial",
      "defaultClientScopes": ["external-task", "fhir-read", "fhir-write"],
      "protocol": "openid-connect",
      "publicClient": false,
      "directAccessGrantsEnabled": false
    },
    {
      "clientId": "worker-whatsapp",
      "enabled": true,
      "serviceAccountsEnabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "changeme-whatsapp",
      "defaultClientScopes": ["external-task"],
      "protocol": "openid-connect",
      "publicClient": false,
