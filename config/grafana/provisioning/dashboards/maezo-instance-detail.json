                  { "options": { "ACTIVE": { "color": "blue", "index": 0, "text": "ATIVA" } }, "type": "value" },
                  { "options": { "COMPLETED": { "color": "green", "index": 1, "text": "CONCLUIDA" } }, "type": "value" },
                  { "options": { "EXTERNALLY_TERMINATED": { "color": "red", "index": 2, "text": "CANCELADA" } }, "type": "value" },
                  { "options": { "INTERNALLY_TERMINATED": { "color": "orange", "index": 3, "text": "TERMINADA" } }, "type": "value" }
