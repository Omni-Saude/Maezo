      "targets": [{
        "datasource": { "type": "postgres", "uid": "cibseven-pg" },
        "rawSql": "SELECT\n  i.incident_type_ AS \"Tipo\",\n  CASE WHEN i.end_time_ IS NULL THEN 'ATIVO' ELSE 'RESOLVIDO' END AS \"Status\",\n  COALESCE(i.activity_id_, '') AS \"Atividade\",\n  i.create_time_ AS \"Criado\",\n  i.end_time_ AS \"Resolvido\",\n  LEFT(COALESCE(i.incident_msg_, ''), 200) AS \"Mensagem\"\nFROM act_hi_incident i\nWHERE i.proc_inst_id_ = '$instance_id'\nORDER BY i.create_time_ DESC;",
