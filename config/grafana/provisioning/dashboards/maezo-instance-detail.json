      "id": 20,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "sortBy": [{ "desc": false, "displayName": "#" }]
      },
      "title": "Atividades da Instancia",
      "description": "Insira o instance_id na variavel $instance_id para ver o detalhe.",
      "type": "table",
      "targets": [{
        "datasource": { "type": "postgres", "uid": "cibseven-pg" },
        "rawSql": "SELECT\n  ROW_NUMBER() OVER (ORDER BY a.start_time_) AS \"#\",\n  a.act_type_ AS \"Tipo\",\n  COALESCE(a.act_name_, a.act_id_) AS \"Nome\",\n  a.start_time_ AS \"Inicio\",\n  CASE\n    WHEN a.end_time_ IS NOT NULL THEN\n      CASE\n        WHEN EXTRACT(EPOCH FROM (a.end_time_ - a.start_time_)) < 1\n          THEN ROUND(EXTRACT(EPOCH FROM (a.end_time_ - a.start_time_))::numeric * 1000) || 'ms'\n        WHEN EXTRACT(EPOCH FROM (a.end_time_ - a.start_time_)) < 60\n          THEN ROUND(EXTRACT(EPOCH FROM (a.end_time_ - a.start_time_))::numeric, 1) || 's'\n        ELSE ROUND(EXTRACT(EPOCH FROM (a.end_time_ - a.start_time_))::numeric / 60, 1) || 'm'\n      END\n    ELSE '-'\n  END AS \"Duracao\",\n  CASE\n    WHEN a.canceled_ = TRUE THEN 'CANCELADA'\n    WHEN a.end_time_ IS NOT NULL THEN 'OK'\n    ELSE 'EM ANDAMENTO'\n  END AS \"Status\"\nFROM act_hi_actinst a\nWHERE a.proc_inst_id_ = '$instance_id'\n  AND a.act_type_ NOT IN ('multiInstanceBody')\nORDER BY a.start_time_;",
        "format": "table",
        "refId": "A"
      }]
    },
