      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "countRows": true, "reducer": ["count"], "show": true },
        "sortBy": [{ "desc": true, "displayName": "Inicio" }]
      },
      "title": "Todas as Instancias RC",
      "type": "table",
      "targets": [{
        "datasource": { "type": "postgres", "uid": "cibseven-pg" },
        "rawSql": "SELECT\n  LEFT(p.id_, 12) AS \"ID\",\n  REPLACE(REPLACE(p.proc_def_key_, 'SP_RC_00', 'RC-00'), 'SP_RC_0', 'RC-0') AS \"Processo\",\n  p.state_ AS \"Estado\",\n  p.business_key_ AS \"Business Key\",\n  p.start_time_ AS \"Inicio\",\n  CASE\n    WHEN p.end_time_ IS NOT NULL THEN\n      ROUND(EXTRACT(EPOCH FROM (p.end_time_ - p.start_time_))::numeric, 1) || 's'\n    ELSE\n      ROUND(EXTRACT(EPOCH FROM (NOW() - p.start_time_))::numeric, 0) || 's (em curso)'\n  END AS \"Duracao\",\n  COALESCE(\n    (SELECT a.act_name_\n     FROM act_hi_actinst a\n     WHERE a.proc_inst_id_ = p.id_\n       AND a.end_time_ IS NULL\n       AND a.act_type_ NOT IN ('multiInstanceBody','noneStartEvent')\n     ORDER BY a.start_time_ DESC\n     LIMIT 1),\n    CASE WHEN p.state_ = 'COMPLETED' THEN '(concluido)' ELSE '?' END\n  ) AS \"Etapa Atual\",\n  (SELECT COUNT(*) FROM act_ru_incident i WHERE i.proc_inst_id_ = p.id_) AS \"Incidents\"\nFROM act_hi_procinst p\nWHERE p.proc_def_key_ LIKE 'SP_RC_%'\n  AND p.start_time_ >= NOW() - INTERVAL '7 days'\nORDER BY p.start_time_ DESC\nLIMIT 100;",
        "format": "table",
        "refId": "A"
      }]
    },
