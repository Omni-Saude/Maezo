      "targets": [{
        "datasource": { "type": "postgres", "uid": "cibseven-pg" },
        "rawSql": "SELECT\n  t.topic_name_ AS \"Topico\",\n  CASE t.state_\n    WHEN 0 THEN 'CRIADA'\n    WHEN 1 THEN 'FALHA'\n    WHEN 2 THEN 'OK'\n    WHEN 3 THEN 'DELETADA'\n    ELSE 'OUTRO'\n  END AS \"Status\",\n  t.worker_id_ AS \"Worker\",\n  t.timestamp_ AS \"Quando\",\n  COALESCE(t.error_msg_, '') AS \"Erro\"\nFROM act_hi_ext_task_log t\nWHERE t.proc_inst_id_ = '$instance_id'\nORDER BY t.timestamp_;",
        "format": "table",
        "refId": "A"
      }]
