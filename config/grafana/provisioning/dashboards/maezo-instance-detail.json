      "title": "Variaveis do Processo",
      "type": "table",
      "targets": [{
        "datasource": { "type": "postgres", "uid": "cibseven-pg" },
        "rawSql": "SELECT\n  v.name_ AS \"Variavel\",\n  v.var_type_ AS \"Tipo\",\n  CASE\n    WHEN v.var_type_ = 'string' THEN LEFT(COALESCE(v.text_, ''), 200)\n    WHEN v.var_type_ = 'boolean' THEN COALESCE(CAST(v.long_ AS TEXT), '')\n    WHEN v.var_type_ IN ('integer', 'long') THEN COALESCE(CAST(v.long_ AS TEXT), '')\n    WHEN v.var_type_ = 'double' THEN COALESCE(CAST(v.double_ AS TEXT), '')\n    WHEN v.var_type_ IN ('object', 'json') THEN LEFT(COALESCE(v.text_, v.text2_, ''), 200)\n    ELSE LEFT(COALESCE(v.text_, ''), 200)\n  END AS \"Valor\"\nFROM act_hi_varinst v\nWHERE v.proc_inst_id_ = '$instance_id'\nORDER BY v.name_;",
        "format": "table",
        "refId": "A"
      }]
