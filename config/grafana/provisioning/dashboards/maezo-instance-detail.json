        "cellHeight": "sm"
      },
      "title": "Jobs (Timers / Async)",
      "type": "table",
      "targets": [{
        "datasource": { "type": "postgres", "uid": "cibseven-pg" },
        "rawSql": "SELECT\n  j.type_ AS \"Tipo\",\n  COALESCE(j.handler_type_, '') AS \"Handler\",\n  j.duedate_ AS \"Due Date\",\n  j.retries_ AS \"Retries\",\n  j.suspension_state_ AS \"Suspenso\",\n  LEFT(COALESCE(j.exception_msg_, ''), 200) AS \"Excecao\"\nFROM act_ru_job j\nWHERE j.process_instance_id_ = '$instance_id'\nORDER BY j.duedate_;",
