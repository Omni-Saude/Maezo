          "rawQuery": true,
          "rawSql": "SELECT\n  l.timestamp_ AS \"Quando\",\n  l.proc_def_key_ AS \"Processo\",\n  l.topic_name_ AS \"Worker / Tópico\",\n  COALESCE(\n    (SELECT v.text_ FROM act_hi_varinst v\n     WHERE v.proc_inst_id_ = l.proc_inst_id_ AND v.name_ = 'patientId' LIMIT 1),\n    (SELECT v.text_ FROM act_hi_varinst v\n     WHERE v.proc_inst_id_ = l.proc_inst_id_ AND v.name_ = 'patient' LIMIT 1),\n    (SELECT v.text_ FROM act_hi_varinst v\n     WHERE v.proc_inst_id_ = l.proc_inst_id_ AND v.name_ = 'batchId' LIMIT 1),\n    '—'\n  ) AS \"Paciente\",\n  COALESCE(LEFT(l.error_msg_, 250), '(sem mensagem de erro)') AS \"Mensagem\",\n  l.retries_ AS \"Tentativas\",\n  LEFT(l.proc_inst_id_, 12) || '...' AS \"Instância\"\nFROM act_hi_ext_task_log l\nWHERE l.proc_def_key_ LIKE 'SP_RC_%'\n  AND l.state_ = 3\nORDER BY l.timestamp_ DESC\nLIMIT 200",
