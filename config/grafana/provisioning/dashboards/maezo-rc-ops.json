      "pluginVersion": "11.2.0",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "cibseven-pg"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  i.incident_timestamp_ AS \"Quando\",\n  REPLACE(p.proc_def_key_, 'SP_RC_', 'RC-') AS \"Processo\",\n  COALESCE(\n    MAX(CASE WHEN v.name_ = 'patientId'   THEN v.text_ END),\n    MAX(CASE WHEN v.name_ = 'patient'     THEN v.text_ END),\n    '—'\n  ) AS \"Paciente\",\n  COALESCE(\n    MAX(CASE WHEN v.name_ = 'encounterId' THEN v.text_ END),\n    MAX(CASE WHEN v.name_ = 'batchId'     THEN v.text_ END),\n    '—'\n  ) AS \"Atendimento / Lote\",\n  COALESCE(MAX(CASE WHEN v.name_ = 'payerId' THEN v.text_ END), '—') AS \"Convênio\",\n  i.activity_id_ AS \"Task que Falhou\",\n  LEFT(i.incident_msg_, 200) AS \"Mensagem de Erro\",\n  LEFT(p.id_, 12) || '...' AS \"Instância\"\nFROM act_ru_incident i\nJOIN act_hi_procinst p ON p.id_ = i.proc_inst_id_\nLEFT JOIN act_hi_varinst v\n  ON v.proc_inst_id_ = i.proc_inst_id_\n  AND v.name_ IN ('patientId','patient','encounterId','batchId','payerId')\nWHERE p.proc_def_key_ LIKE 'SP_RC_%'\nGROUP BY\n  i.id_, i.incident_timestamp_, p.proc_def_key_, p.id_,\n  i.activity_id_, i.incident_msg_\nORDER BY i.incident_timestamp_ DESC\nLIMIT 100",
          "refId": "A"
        }
      ],
      "title": "Incidentes Ativos",
      "type": "table"
