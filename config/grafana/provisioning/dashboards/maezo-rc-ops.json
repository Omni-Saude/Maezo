      "pluginVersion": "11.2.0",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "cibseven-pg"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  p.start_time_ AS \"Iniciado\",\n  ROUND(EXTRACT(EPOCH FROM (NOW() - p.start_time_)) / 60)::integer AS \"Min\",\n  REPLACE(p.proc_def_key_, 'SP_RC_', 'RC-') AS \"Processo\",\n  COALESCE(\n    MAX(CASE WHEN v.name_ = 'patientId'   THEN v.text_ END),\n    MAX(CASE WHEN v.name_ = 'patient'     THEN v.text_ END),\n    '—'\n  ) AS \"Paciente\",\n  COALESCE(\n    MAX(CASE WHEN v.name_ = 'encounterId' THEN v.text_ END),\n    MAX(CASE WHEN v.name_ = 'batchId'     THEN v.text_ END),\n    '—'\n  ) AS \"Atendimento / Lote\",\n  COALESCE(MAX(CASE WHEN v.name_ = 'payerId' THEN v.text_ END), '—') AS \"Convênio\",\n  COALESCE(MAX(et.topic_name_), '(user task / timer / gateway)') AS \"Aguardando\",\n  LEFT(p.id_, 12) || '...' AS \"Instância\"\nFROM act_hi_procinst p\nLEFT JOIN act_hi_varinst v\n  ON v.proc_inst_id_ = p.id_\n  AND v.name_ IN ('patientId','patient','encounterId','batchId','payerId')\nLEFT JOIN act_ru_ext_task et ON et.proc_inst_id_ = p.id_\nWHERE p.proc_def_key_ LIKE 'SP_RC_%'\n  AND p.state_ = 'ACTIVE'\n  AND NOT EXISTS (\n    SELECT 1 FROM act_ru_incident i WHERE i.proc_inst_id_ = p.id_\n  )\nGROUP BY p.id_, p.start_time_, p.proc_def_key_\nORDER BY p.start_time_ ASC\nLIMIT 100",
          "refId": "A"
        }
