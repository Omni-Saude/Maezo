# =============================================================================
# MAEZO Healthcare Platform — Variáveis de PRODUÇÃO
# =============================================================================
# ⚠️  NUNCA commite este arquivo com valores reais
# ⚠️  Copie para /opt/maezo/.env no servidor Swarm e preencha
# ⚠️  Senhas devem estar em Docker Swarm Secrets (não aqui)
#
# Uso:
#   scp .env.prod.example usuario@swarm-host:/opt/maezo/.env
#   ssh usuario@swarm-host "nano /opt/maezo/.env"
# =============================================================================

# ─── CIB Seven Community BPM Engine ──────────────────────────────────────────
# Auth: Basic Auth (sem Keycloak — ADR-020)
# Imagem: cibseven/cibseven:run-latest (Spring Boot — fork open-source do Camunda 7)
CIB7_USER=admin
CIB7_PASS=PREENCHER_senha_admin_cibseven

# ─── PostgreSQL externo ───────────────────────────────────────────────────────
# Banco EXTERNO — pode ser AWS RDS PostgreSQL 16 (Multi-AZ para produção) ou self-hosted.
# Por ora pode usar o postgres do docker-compose.local.yml (host: localhost, porta: 5432)
RDS_HOST=PREENCHER_host_do_postgres
RDS_USER=maestro
PG_PASS=PREENCHER_senha_postgres

# ─── Apache Kafka KRaft (self-hosted, sem AWS MSK) ───────────────────────────
# Gerar CLUSTER_ID válido:
#   docker run --rm confluentinc/cp-kafka:7.7.0 kafka-storage random-uuid
KAFKA_CLUSTER_ID=PREENCHER_uuid_gerado_acima

# ─── Domínio e TLS ────────────────────────────────────────────────────────────
DOMAIN=austa.com.br
ACME_EMAIL=devops@austa.com.br

# ─── Imagem Docker ────────────────────────────────────────────────────────────
# Atualizado automaticamente pelo CI/CD (github.sha)
# Para deploy manual: IMAGE_TAG=$(git rev-parse --short HEAD)
IMAGE_TAG=PREENCHER_sha_do_commit

# ─── Multi-tenancy ────────────────────────────────────────────────────────────
CIBSEVEN_DEFAULT_TENANT=hospital-a
# Tenants ativos: hospital-a | amh-sp-morumbi | amh-rj-barra | amh-mg-bh
# Extraído automaticamente do tópico Kafka (tasy.{TENANT}.{TABLE})

# ─── Integração TASY ERP ──────────────────────────────────────────────────────
TASY_API_URL=https://tasy.austa.com.br/api
TASY_API_KEY=PREENCHER_api_key_do_tasy
# Credenciais CDC Oracle LogMiner — negociar com DBA do Tasy
TASY_DB_HOST=PREENCHER_oracle_host
TASY_DB_USER=PREENCHER_oracle_user
# TASY_DB_PASSWORD via Swarm Secret (não colocar aqui)

# ─── WhatsApp Business API (Fase 2 — opcional) ───────────────────────────────
# WHATSAPP_API_URL=https://graph.facebook.com/v19.0
# WHATSAPP_PHONE_NUMBER_ID=PREENCHER
# WHATSAPP_ACCESS_TOKEN=PREENCHER_token_meta

# ─── Observabilidade ──────────────────────────────────────────────────────────
# Prometheus scrape configurado no docker-compose.swarm.yml
# Grafana: https://grafana.austa.com.br (credenciais via secret)
LOG_LEVEL=WARNING

# Alertas Grafana — n8n como ponte para Zoho Cliq (OAuth2)
# URL do webhook n8n que recebe alertas do Grafana e repassa ao Cliq
N8N_GRAFANA_WEBHOOK_URL=https://n8n.austaclinicas.com.br/webhook/grafana-alerts

# Alertas Grafana — destinatários de email (separar por vírgula)
GRAFANA_ALERT_EMAIL=ti@austa.com.br

# SMTP para envio de alertas por email
GF_SMTP_ENABLED=true
GF_SMTP_HOST=smtp.seuservidor.com.br:587
GF_SMTP_USER=grafana@austa.com.br
GF_SMTP_PASSWORD=PREENCHER_senha_smtp
GF_SMTP_FROM_ADDRESS=grafana@austa.com.br

# ─── Checklist antes do deploy ────────────────────────────────────────────────
# [ ] RDS_HOST preenchido e acessível na rede do Swarm (ou "postgres" se self-hosted)
# [ ] PG_PASS preenchido com a senha do PostgreSQL
# [ ] CIB7_PASS preenchido com a senha do admin Camunda
# [ ] KAFKA_CLUSTER_ID gerado (único por cluster)
# [ ] Docker Swarm Secrets criados:
#       docker secret create postgres_password -   # usado pelo HAPI FHIR
# [ ] IMAGE_TAG = SHA do commit a deploiar
# [ ] TASY_API_KEY válida
# [ ] DOMAIN apontando para o IP do Swarm Manager (DNS)
# [ ] Certificado TLS: Traefik vai buscar via ACME (ACME_EMAIL obrigatório)
