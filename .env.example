# =============================================================================
# MAEZO Healthcare Platform — Variáveis de Ambiente
# Copie para .env e preencha com os valores reais
# Arquitetura: Docker Swarm + AWS RDS PostgreSQL 16
# =============================================================================

# --- CIB Seven BPM Engine (Basic Auth — sem Keycloak) ---
CIB7_BASE_URL=http://cib7:8080/engine-rest
CIB7_USER=admin
CIB7_PASSWORD=changeme_in_production

# --- AWS RDS PostgreSQL 16 (banco externo — não container) ---
RDS_HOST=maezo.xxxxxxxx.us-east-1.rds.amazonaws.com
RDS_USER=maestro


# Senha via Docker Swarm Secret (não colocar aqui em produção)
# DATABASE_URL=postgresql://${RDS_USER}:$(cat /run/secrets/postgres_password)@${RDS_HOST}:5432/maestro
DATABASE_URL=postgresql://maestro:changeme@localhost:5432/maestro

# --- HAPI FHIR R4 ---
FHIR_BASE_URL=http://hapi_fhir:8080/fhir
# Externo: https://fhir.austa.com.br/fhir

# --- Apache Kafka (KRaft — sem ZooKeeper) ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# CLUSTER_ID gerado via: docker run --rm confluentinc/cp-kafka:7.7.0 kafka-storage random-uuid
KAFKA_CLUSTER_ID=

# --- Domínio e deploy ---
DOMAIN=austa.com.br
IMAGE_TAG=latest
ACME_EMAIL=devops@austa.com.br

# --- Multi-tenancy ---
CIBSEVEN_DEFAULT_TENANT=hospital-a
# Tenant é extraído automaticamente do tópico Kafka (tasy.{TENANT}.{TABLE})

# --- WhatsApp Business API (opcional, Fase 2) ---
# WHATSAPP_API_URL=https://graph.facebook.com/v18.0
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=

# --- TASY ERP (integração externa) ---
TASY_API_URL=https://tasy.austa.com.br/api
TASY_API_KEY=changeme

# --- Segurança webhooks ---
WEBHOOK_HMAC_SECRET=changeme_32_chars_minimum

# --- RPA de Autorização Unimed ---
# dev local : RPA_UNIMED_URL=http://localhost:8000
# Docker    : RPA_UNIMED_URL=http://rpa-unimed:8000   (DNS interno Swarm)
# Deixar vazio para desabilitar RPA (worker cai em RPA_NOT_CONFIGURED)
RPA_UNIMED_URL=http://rpa-unimed:8000
RPA_UNIMED_TIMEOUT=30
