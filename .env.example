# =============================================================================
# Maestro Healthcare Platform - Environment Variables
# Copy to .env and fill in real values
# =============================================================================

# --- CIB Seven Engine ---
CIBSEVEN_ENGINE_URL=http://localhost:8080/engine-rest
CIBSEVEN_DEFAULT_TENANT=hospital-a

# --- PostgreSQL (CIB Seven + HAPI FHIR) ---
POSTGRES_USER=maestro
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=cibseven
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- HAPI FHIR ---
FHIR_BASE_URL=http://localhost:8082/fhir
FHIR_DB_URL=jdbc:postgresql://postgres:5432/hapi_fhir

# --- Keycloak ---
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=maezo-bpm
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_in_production

# --- Worker Keycloak Clients (client_credentials) ---
WORKER_ELIGIBILITY_CLIENT_ID=worker-eligibility
WORKER_ELIGIBILITY_CLIENT_SECRET=changeme
WORKER_TISS_CLIENT_ID=worker-tiss
WORKER_TISS_CLIENT_SECRET=changeme
WORKER_DENIAL_CLIENT_ID=worker-denial
WORKER_DENIAL_CLIENT_SECRET=changeme
WORKER_WHATSAPP_CLIENT_ID=worker-whatsapp
WORKER_WHATSAPP_CLIENT_SECRET=changeme
WORKER_CLINICAL_CLIENT_ID=worker-clinical
WORKER_CLINICAL_CLIENT_SECRET=changeme
WORKER_PAYMENT_CLIENT_ID=worker-payment
WORKER_PAYMENT_CLIENT_SECRET=changeme

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://localhost:9200

# --- Observability ---
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin

# --- WhatsApp Business API (optional, Phase 2) ---
# WHATSAPP_API_URL=https://graph.facebook.com/v18.0
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
