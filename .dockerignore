# =============================================================================
# .dockerignore — Maestro Healthcare Platform
# Excludes non-runtime artifacts from Docker build context
# =============================================================================

# Tests (never ship to production)
**/tests/
tests/

# Decision artifacts (deploy separately to CIB Seven engine)
**/dmn/
**/bpmn/

# EXCEPTION: shared/dmn contains Python runtime code (federation_service.py)
# Após migração para src/ a exceção usa o novo caminho
!src/healthcare_platform/shared/dmn/
!healthcare_platform/shared/dmn/

# Legacy reference (kept for migration validation)
Dockerfile.legacy
docker-compose.legacy.yml

# Documentation
docs/
*.md

# Helm / K8s manifests (separate deploy pipeline)
helm/
k8s/

# Config files (not needed inside worker image)
config/
!config/debezium/plugins/

# Utility scripts
scripts/

# CI/CD
.github/

# Archives
**/.archive/
**/.archived-duplicates/

# Dev tools and caches
.venv/
__pycache__/
*.pyc
.pytest_cache/
.coverage
.ruff_cache/
.mypy_cache/
.git/
.gitignore

# Locale (load via volume mount if needed at runtime)
locale/

# IDE and AI tools
.vscode/
.claude/
.claude-flow/
.swarm/
agents/
CLAUDE.md
vectors.db
node_modules/

# Legacy folders (pre-restructuring reference)
.scripts/

# src/ tests and non-worker content (only workers ship to production)
src/**/tests/
src/**/__pycache__/
