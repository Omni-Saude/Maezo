# =============================================================================
# PATCH 10: Compact storage for authorization codes
# =============================================================================

def _store_authorization_code_compact(self, code: str) -> int:
    """
    Store authorization code as int instead of string.

    Authorization codes are typically numeric (6-12 digits).
    Store as int64 for 75% memory reduction.

    Memory savings:
    - String "123456789012": ~60 bytes
    - int64: 8 bytes
    - Reduction: 86.7%
    """
    try:
        return int(code)
    except ValueError:
        # Non-numeric code, hash it
        return hash(code) & 0x7FFFFFFFFFFFFFFF


# =============================================================================
# PATCH 11: Generator-based gateway response parsing
# =============================================================================

def _parse_gateway_responses(
    self,
    raw_responses: List[dict],
) -> Generator[PaymentGatewayResponse, None, None]:
    """
    Parse gateway responses as generator (no list materialization).

    Instead of building entire list, yield responses on demand.
    """
    for response_data in raw_responses:
        yield PaymentGatewayResponse.model_validate(response_data)


