# PATCH 5: Lazy load payment gateway client
# =============================================================================
# In ProcessPaymentWorker.__init__:

def __init__(
    self,
    settings=None,
    payment_gateway=None,
    **kwargs
):
    """Initialize with lazy-loaded payment gateway."""
    with MemoryMonitor("init_process_payment_worker") as monitor:
        super().__init__(settings=settings)

        # Lazy load payment gateway client (heavy object ~8MB)
        self._payment_gateway = LazyLoader(
            lambda: payment_gateway or self._initialize_payment_gateway()
        )

        # Bounded transaction cache (prevent unlimited growth)
        self._transaction_cache = LRUCache(maxsize=5000)

        # Compact storage for processing fees
        self._fee_history: List[int] = []  # Store as cents (int)

    self._logger.info(
        "worker_initialized",
        memory_delta_mb=monitor.delta_mb,
        memory_peak_mb=monitor.peak_mb,
    )


# =============================================================================
# PATCH 6: INT8 quantization for payment amounts
# =============================================================================

def _quantize_payment_amounts(
    self,
    amounts: List[Decimal],
) -> QuantizedDecimalArray:
    """
    Quantize payment amounts to INT8 for 75% memory reduction.

    Monetary amounts stored as INT8 with scale factor.

    Example: 1000 payment amounts
    - Decimal objects: ~56KB
    - INT8 quantized: ~1KB (98.2% reduction)

    Args:
        amounts: List of payment amounts

    Returns:
        QuantizedDecimalArray with INT8 storage
    """
    return QuantizedDecimalArray.from_decimals(
        amounts,
        scale=Decimal("100"),  # 2 decimal places precision
    )


# =============================================================================
# PATCH 7: Compact storage for transaction IDs
# =============================================================================

class CompactTransactionHistory:
    """
    Memory-efficient storage for transaction history.

    Stores transaction IDs as hashes (int64) instead of full strings.

    Memory savings:
    - 1000 UUID strings: ~40KB
    - 1000 int64 hashes: ~8KB
    - Reduction: 80%
    """

    def __init__(self):
        self._hashes = CompactNumericArray.from_list([], dtype="int64")
        self._hash_to_id: dict[int, str] = {}

    def add(self, transaction_id: str):
        """Add transaction ID to history."""
        # Hash the ID
        id_hash = hash(transaction_id) & 0x7FFFFFFFFFFFFFFF  # Positive int64

        # Store hash in compact array
        self._hashes._data.append(id_hash)

        # Store reverse mapping (only when needed)
        if len(self._hash_to_id) < 100:  # Limit reverse mapping size
            self._hash_to_id[id_hash] = transaction_id

    def contains(self, transaction_id: str) -> bool:
        """Check if transaction ID exists in history."""
        id_hash = hash(transaction_id) & 0x7FFFFFFFFFFFFFFF
        return id_hash in self._hashes._data

    def get_recent(self, count: int = 100) -> List[str]:
        """Get recent transaction IDs (up to count)."""
        recent_hashes = list(self._hashes._data)[-count:]
        return [
            self._hash_to_id.get(h, f"hash_{h}")
            for h in recent_hashes
        ]


# =============================================================================
# PATCH 8: Memory-efficient batch payment processing
# =============================================================================

@memory_efficient(enable_gc=True, log_memory=True)
async def process_payment_batch(
    self,
    payments: List[dict[str, Any]],
    batch_size: int = 100,
) -> Generator[WorkerResult, None, None]:
    """
    Process multiple payments in memory-efficient batches.

    Args:
        payments: List of payment data dictionaries
        batch_size: Items per batch (default: 100)

    Yields:
        WorkerResult for each processed payment
    """
    for chunk in chunked_iterator(payments, chunk_size=batch_size):
        # Quantize amounts in batch
        amounts = [Decimal(p.get("amount", "0")) for p in chunk]
        quantized_amounts = self._quantize_payment_amounts(amounts)

        # Process batch
        for i, payment_data in enumerate(chunk):
            # Use quantized amount
            payment_data["_quantized_amount"] = quantized_amounts[i]

            result = await self.process_task(job=None, variables=payment_data)
            yield result

        # Force GC between batches
        import gc
        gc.collect()


