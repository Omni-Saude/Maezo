<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="{{ rule_id }}_def"
             name="{{ rule_name }}"
             namespace="http://healthcare.platform/dmn/contract_extraction">
  <!--
    BUNDLING archetype template.
    Determines item inclusion/exclusion in procedure bundles.
    Payer: {{ rule.payer_id }}
    Category: {{ rule.category.value if rule.category else 'unknown' }}
    Archetype: {{ rule.archetype.value if rule.archetype else 'BUNDLING' }}
    Rule ID: {{ rule.id }}
    Hit Policy COLLECT returns ALL matching bundle items for a given set of inputs.
  -->
  <decision id="decision_{{ rule_id }}" name="{{ rule_name }}">
    <decisionTable id="dt_{{ rule_id }}" hitPolicy="{{ hit_policy }}">
{%- if inputs %}
{%- for inp in inputs %}
      <input id="in_{{ rule_id }}_{{ loop.index }}" label="{{ inp.name }}">
        <inputExpression id="inExpr_{{ rule_id }}_{{ loop.index }}" typeRef="{{ inp.type }}">
          <text>{{ inp.name }}</text>
        </inputExpression>
      </input>
{%- endfor %}
{%- else %}
      <input id="in_{{ rule_id }}_1" label="primary_code">
        <inputExpression id="inExpr_{{ rule_id }}_1" typeRef="string">
          <text>primary_code</text>
        </inputExpression>
      </input>
      <input id="in_{{ rule_id }}_2" label="secondary_code">
        <inputExpression id="inExpr_{{ rule_id }}_2" typeRef="string">
          <text>secondary_code</text>
        </inputExpression>
      </input>
      <input id="in_{{ rule_id }}_3" label="same_act">
        <inputExpression id="inExpr_{{ rule_id }}_3" typeRef="boolean">
          <text>same_act</text>
        </inputExpression>
      </input>
{%- endif %}
{%- if outputs %}
{%- for out in outputs %}
      <output id="out_{{ rule_id }}_{{ loop.index }}" label="{{ out.name }}" name="{{ out.name }}" typeRef="{{ out.type }}"/>
{%- endfor %}
{%- else %}
      <output id="out_{{ rule_id }}_1" label="is_bundled" name="is_bundled" typeRef="boolean"/>
      <output id="out_{{ rule_id }}_2" label="bundle_price" name="bundle_price" typeRef="number"/>
      <output id="out_{{ rule_id }}_3" label="bundle_code" name="bundle_code" typeRef="string"/>
{%- endif %}
{%- set effective_inputs = inputs if inputs else [{'name': 'primary_code', 'type': 'string'}, {'name': 'secondary_code', 'type': 'string'}, {'name': 'same_act', 'type': 'boolean'}] %}
{%- set effective_outputs = outputs if outputs else [{'name': 'is_bundled', 'type': 'boolean'}, {'name': 'bundle_price', 'type': 'number'}, {'name': 'bundle_code', 'type': 'string'}] %}
{%- for cond in conditions %}
      <rule id="r_{{ rule_id }}_{{ loop.index }}">
        <description>{{ cond.description | default('Bundle rule ' ~ loop.index) }}</description>
{%- set outer_loop = loop %}
{%- for inp in effective_inputs %}
        <inputEntry id="ie_{{ rule_id }}_{{ outer_loop.index }}_{{ loop.index }}"><text>{{ cond.input_entries[loop.index - 1] if cond.input_entries is defined and loop.index - 1 < cond.input_entries | length else '' }}</text></inputEntry>
{%- endfor %}
{%- for out in effective_outputs %}
        <outputEntry id="oe_{{ rule_id }}_{{ outer_loop.index }}_{{ loop.index }}"><text>{{ cond.output_entries[loop.index - 1] if cond.output_entries is defined and loop.index - 1 < cond.output_entries | length else '' }}</text></outputEntry>
{%- endfor %}
      </rule>
{%- endfor %}
    </decisionTable>
  </decision>
</definitions>
