<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="uti_daily_pricing_def"
             name="UTI Daily Pricing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!--
    Daily rates sourced from:
    - UTI Adulto: R$ 6,051.45/dia (Contrato Domed SESDF clausula 5.1, tabela_valor)
    - UTI Pediatrica: R$ 6,051.45/dia (same credenciamento framework, Item 2 Edital 5/2024)
    - UTI Neonatal: R$ 6,051.45/dia (same credenciamento framework, Item 1 Edital 5/2024)
    Note: The Edital 5/2024 uses same daily rate structure per leito/dia for all UTI types.
    Payment is per leito/dia EFETIVAMENTE utilizado (Contrato 3.3, 3.4; Edital 1.1 notas).
    SIGTAP diaria codes from Contrato 4.3.7.1 tabela_2:
      UTI Adulto:    08.02.01.008-3
      UTI Pediatrica: 08.02.01.015-6
      UTI Neonatal:  08.02.01.012-1
  -->
  <decision id="decision_uti_daily_pricing" name="UTI Daily Pricing" camunda:historyTimeToLive="180">
    <decisionTable id="dt_uti_daily_pricing" hitPolicy="FIRST">
      <input id="in_uti_type_p_uti_daily_pricing" label="UTI Type">
        <inputExpression id="inExpr_uti_type_p_uti_daily_pricing" typeRef="string">
          <text>uti_type</text>
        </inputExpression>
      </input>
      <input id="in_effective_days_uti_daily_pricing" label="Effective Days Occupied">
        <inputExpression id="inExpr_effective_days_uti_daily_pricing" typeRef="number">
          <text>effective_days</text>
        </inputExpression>
      </input>
      <output id="out_daily_rate_uti_daily_pricing" label="Daily Rate (BRL)" name="daily_rate" typeRef="number"/>
      <output id="out_currency_uti_daily_pricing" label="Currency" name="currency" typeRef="string"/>
      <output id="out_billing_basis_uti_daily_pricing" label="Billing Basis" name="billing_basis" typeRef="string"/>
      <output id="out_sigtap_diaria_uti_daily_pricing" label="SIGTAP Diaria Code" name="sigtap_code" typeRef="string"/>
      <!-- Rule 1: UTI Neonatal -->
      <rule id="r_price_neonatal_uti_daily_pricing">
        <description>Diaria UTI Neonatal - SIGTAP 08.02.01.012-1 (DIARIA DE UNIDADE DE TERAPIA INTENSIVA NEONATAL-UTIN II)</description>
        <inputEntry id="ie_pn_1_uti_daily_pricing"><text>"UTI_NEONATAL"</text></inputEntry>
        <inputEntry id="ie_pn_2_uti_daily_pricing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="oe_pn_1_uti_daily_pricing"><text>6051.45</text></outputEntry>
        <outputEntry id="oe_pn_2_uti_daily_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_pn_3_uti_daily_pricing"><text>"leito/dia efetivamente utilizado - UTI Neonatal UTIN II (Contrato 3.3, 3.4)"</text></outputEntry>
        <outputEntry id="oe_pn_4_uti_daily_pricing"><text>"08.02.01.012-1"</text></outputEntry>
      </rule>
      <!-- Rule 2: UTI Pediatrica -->
      <rule id="r_price_pediatrica_uti_daily_pricing">
        <description>Diaria UTI Pediatrica - SIGTAP 08.02.01.015-6 (DIARIA DE UNIDADE DE TERAPIA INTENSIVA PEDIATRICA-UTI II)</description>
        <inputEntry id="ie_pp_1_uti_daily_pricing"><text>"UTI_PEDIATRICA"</text></inputEntry>
        <inputEntry id="ie_pp_2_uti_daily_pricing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="oe_pp_1_uti_daily_pricing"><text>6051.45</text></outputEntry>
        <outputEntry id="oe_pp_2_uti_daily_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_pp_3_uti_daily_pricing"><text>"leito/dia efetivamente utilizado - UTI Pediatrica UTI II (Contrato 3.3, 3.4)"</text></outputEntry>
        <outputEntry id="oe_pp_4_uti_daily_pricing"><text>"08.02.01.015-6"</text></outputEntry>
      </rule>
      <!-- Rule 3: UTI Adulto -->
      <rule id="r_price_adulto_uti_daily_pricing">
        <description>Diaria UTI Adulto - SIGTAP 08.02.01.008-3 (DIARIA DE UNIDADE DE TERAPIA INTENSIVA ADULTO-UTI II) - R$ 6051.45/dia (Contrato clausula 5.1)</description>
        <inputEntry id="ie_pa_1_uti_daily_pricing"><text>"UTI_ADULTO"</text></inputEntry>
        <inputEntry id="ie_pa_2_uti_daily_pricing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="oe_pa_1_uti_daily_pricing"><text>6051.45</text></outputEntry>
        <outputEntry id="oe_pa_2_uti_daily_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_pa_3_uti_daily_pricing"><text>"leito/dia efetivamente utilizado - UTI Adulto UTI II (Contrato 5.1: R$ 6051.45/dia; 10220 dias/ano)"</text></outputEntry>
        <outputEntry id="oe_pa_4_uti_daily_pricing"><text>"08.02.01.008-3"</text></outputEntry>
      </rule>
      <!-- Rule 4: Zero days - no billing -->
      <rule id="r_price_zero_uti_daily_pricing">
        <description>Zero dias utilizados - sem faturamento</description>
        <inputEntry id="ie_pz_1_uti_daily_pricing"><text></text></inputEntry>
        <inputEntry id="ie_pz_2_uti_daily_pricing"><text>0</text></inputEntry>
        <outputEntry id="oe_pz_1_uti_daily_pricing"><text>0</text></outputEntry>
        <outputEntry id="oe_pz_2_uti_daily_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_pz_3_uti_daily_pricing"><text>"Sem dias efetivamente utilizados - sem faturamento"</text></outputEntry>
        <outputEntry id="oe_pz_4_uti_daily_pricing"><text>"N/A"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_uti_daily_pricing">
      <dmndi:DMNShape id="DMNShape_decision_uti_daily_pricing" dmnElementRef="decision_uti_daily_pricing">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
