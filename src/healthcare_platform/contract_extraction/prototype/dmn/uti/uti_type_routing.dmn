<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="uti_type_routing_def"
             name="UTI Type Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="decision_uti_type_routing" name="UTI Type Routing" camunda:historyTimeToLive="180">
    <decisionTable id="dt_uti_type_routing" hitPolicy="FIRST">
      <input id="in_age_days_uti_type_routing" label="Patient Age (Days)">
        <inputExpression id="inExpr_age_days_uti_type_routing" typeRef="number">
          <text>patient_age_days</text>
        </inputExpression>
      </input>
      <input id="in_weight_grams_uti_type_routing" label="Patient Weight (Grams)">
        <inputExpression id="inExpr_weight_grams_uti_type_routing" typeRef="number">
          <text>patient_weight_grams</text>
        </inputExpression>
      </input>
      <input id="in_gestational_age_uti_type_routing" label="Gestational Age (Weeks)">
        <inputExpression id="inExpr_gestational_age_uti_type_routing" typeRef="number">
          <text>gestational_age_weeks</text>
        </inputExpression>
      </input>
      <output id="out_uti_type_uti_type_routing" label="UTI Type" name="uti_type" typeRef="string"/>
      <output id="out_sigtap_uti_type_routing" label="SIGTAP Code" name="sigtap_code" typeRef="string"/>
      <output id="out_approved_uti_type_routing" label="Approved" name="approved" typeRef="boolean"/>
      <!-- Rule 1: Neonatal 0-28 days -->
      <rule id="r_neonatal_uti_type_routing">
        <description>UTI Neonatal: faixa etaria 0 a 28 dias (Edital 2.5, Contrato 4.3.4)</description>
        <inputEntry id="ie_n_1_uti_type_routing"><text>[0..28]</text></inputEntry>
        <inputEntry id="ie_n_2_uti_type_routing"><text></text></inputEntry>
        <inputEntry id="ie_n_3_uti_type_routing"><text></text></inputEntry>
        <outputEntry id="oe_n_1_uti_type_routing"><text>"UTI_NEONATAL"</text></outputEntry>
        <outputEntry id="oe_n_2_uti_type_routing"><text>"03.01.01.007-2"</text></outputEntry>
        <outputEntry id="oe_n_3_uti_type_routing"><text>true</text></outputEntry>
      </rule>
      <!-- Rule 2: Neonatal above 28 days if weight < 2500g OR gestational age < 40w -->
      <rule id="r_neonatal_extended_uti_type_routing">
        <description>UTI Neonatal: acima de 28 dias com peso inferior a 2500g OU idade gestacional corrigida inferior a 40 semanas (Contrato 4.3.4)</description>
        <inputEntry id="ie_ne_1_uti_type_routing"><text>&gt; 28</text></inputEntry>
        <inputEntry id="ie_ne_2_uti_type_routing"><text>&lt; 2500</text></inputEntry>
        <inputEntry id="ie_ne_3_uti_type_routing"><text></text></inputEntry>
        <outputEntry id="oe_ne_1_uti_type_routing"><text>"UTI_NEONATAL"</text></outputEntry>
        <outputEntry id="oe_ne_2_uti_type_routing"><text>"03.01.01.007-2"</text></outputEntry>
        <outputEntry id="oe_ne_3_uti_type_routing"><text>true</text></outputEntry>
      </rule>
      <!-- Rule 3: Neonatal above 28 days if gestational age < 40w (regardless of weight) -->
      <rule id="r_neonatal_low_gest_uti_type_routing">
        <description>UTI Neonatal: acima de 28 dias com idade gestacional corrigida inferior a 40 semanas (Contrato 4.3.4)</description>
        <inputEntry id="ie_nlg_1_uti_type_routing"><text>&gt; 28</text></inputEntry>
        <inputEntry id="ie_nlg_2_uti_type_routing"><text></text></inputEntry>
        <inputEntry id="ie_nlg_3_uti_type_routing"><text>&lt; 40</text></inputEntry>
        <outputEntry id="oe_nlg_1_uti_type_routing"><text>"UTI_NEONATAL"</text></outputEntry>
        <outputEntry id="oe_nlg_2_uti_type_routing"><text>"03.01.01.007-2"</text></outputEntry>
        <outputEntry id="oe_nlg_3_uti_type_routing"><text>true</text></outputEntry>
      </rule>
      <!-- Rule 4: Pediatric 29 days to 17y11m29d -->
      <rule id="r_pediatrica_uti_type_routing">
        <description>UTI Pediatrica: de 29 dias a 17 anos 11 meses 29 dias (Edital 2.5, Contrato 4.3.4)</description>
        <inputEntry id="ie_p_1_uti_type_routing"><text>[29..6569]</text></inputEntry>
        <inputEntry id="ie_p_2_uti_type_routing"><text></text></inputEntry>
        <inputEntry id="ie_p_3_uti_type_routing"><text></text></inputEntry>
        <outputEntry id="oe_p_1_uti_type_routing"><text>"UTI_PEDIATRICA"</text></outputEntry>
        <outputEntry id="oe_p_2_uti_type_routing"><text>"03.01.04.016-8"</text></outputEntry>
        <outputEntry id="oe_p_3_uti_type_routing"><text>true</text></outputEntry>
      </rule>
      <!-- Rule 5: Adult 18+ years -->
      <rule id="r_adulto_uti_type_routing">
        <description>UTI Adulto: acima de 18 anos (6570+ dias) (Edital 2.5, Contrato 4.3.4)</description>
        <inputEntry id="ie_a_1_uti_type_routing"><text>&gt;= 6570</text></inputEntry>
        <inputEntry id="ie_a_2_uti_type_routing"><text></text></inputEntry>
        <inputEntry id="ie_a_3_uti_type_routing"><text></text></inputEntry>
        <outputEntry id="oe_a_1_uti_type_routing"><text>"UTI_ADULTO"</text></outputEntry>
        <outputEntry id="oe_a_2_uti_type_routing"><text>"04.09.01.059-2"</text></outputEntry>
        <outputEntry id="oe_a_3_uti_type_routing"><text>true</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_uti_type_routing">
      <dmndi:DMNShape id="DMNShape_decision_uti_type_routing" dmnElementRef="decision_uti_type_routing">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
