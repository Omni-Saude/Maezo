<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="uti_admission_crossover_def"
             name="UTI Admission Crossover"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="decision_uti_admission_crossover" name="UTI Admission Crossover" camunda:historyTimeToLive="180">
    <decisionTable id="dt_uti_admission_crossover" hitPolicy="FIRST">
      <input id="in_requested_type_uti_admission_crossover" label="Requested UTI Type">
        <inputExpression id="inExpr_requested_type_uti_admission_crossover" typeRef="string">
          <text>requested_uti_type</text>
        </inputExpression>
      </input>
      <input id="in_preferred_available_uti_admission_crossover" label="Preferred UTI Available">
        <inputExpression id="inExpr_preferred_available_uti_admission_crossover" typeRef="boolean">
          <text>preferred_uti_available</text>
        </inputExpression>
      </input>
      <input id="in_age_days_co_uti_admission_crossover" label="Patient Age (Days)">
        <inputExpression id="inExpr_age_days_co_uti_admission_crossover" typeRef="number">
          <text>patient_age_days</text>
        </inputExpression>
      </input>
      <input id="in_weight_co_uti_admission_crossover" label="Weight (Grams)">
        <inputExpression id="inExpr_weight_co_uti_admission_crossover" typeRef="number">
          <text>weight_grams</text>
        </inputExpression>
      </input>
      <input id="in_gest_age_co_uti_admission_crossover" label="Gestational Age (Weeks)">
        <inputExpression id="inExpr_gest_age_co_uti_admission_crossover" typeRef="number">
          <text>gestational_age_weeks</text>
        </inputExpression>
      </input>
      <output id="out_admit_type_uti_admission_crossover" label="Admit to UTI Type" name="admit_to_uti_type" typeRef="string"/>
      <output id="out_justification_uti_admission_crossover" label="Justification" name="justification" typeRef="string"/>
      <output id="out_requires_doc_uti_admission_crossover" label="Requires Documentation" name="requires_documentation" typeRef="boolean"/>
      <!-- Rule 1: Preferred UTI type is available - standard admission -->
      <rule id="r_standard_neonatal_uti_admission_crossover">
        <description>UTI Neonatal disponivel - admissao padrao (Contrato 4.3.4)</description>
        <inputEntry id="ie_sn_1_uti_admission_crossover"><text>"UTI_NEONATAL"</text></inputEntry>
        <inputEntry id="ie_sn_2_uti_admission_crossover"><text>true</text></inputEntry>
        <inputEntry id="ie_sn_3_uti_admission_crossover"><text></text></inputEntry>
        <inputEntry id="ie_sn_4_uti_admission_crossover"><text></text></inputEntry>
        <inputEntry id="ie_sn_5_uti_admission_crossover"><text></text></inputEntry>
        <outputEntry id="oe_sn_1_uti_admission_crossover"><text>"UTI_NEONATAL"</text></outputEntry>
        <outputEntry id="oe_sn_2_uti_admission_crossover"><text>"Admissao padrao UTI Neonatal"</text></outputEntry>
        <outputEntry id="oe_sn_3_uti_admission_crossover"><text>false</text></outputEntry>
      </rule>
      <rule id="r_standard_pediatrica_uti_admission_crossover">
        <description>UTI Pediatrica disponivel - admissao padrao (Contrato 4.3.4)</description>
        <inputEntry id="ie_sp_1_uti_admission_crossover"><text>"UTI_PEDIATRICA"</text></inputEntry>
        <inputEntry id="ie_sp_2_uti_admission_crossover"><text>true</text></inputEntry>
        <inputEntry id="ie_sp_3_uti_admission_crossover"><text></text></inputEntry>
        <inputEntry id="ie_sp_4_uti_admission_crossover"><text></text></inputEntry>
        <inputEntry id="ie_sp_5_uti_admission_crossover"><text></text></inputEntry>
        <outputEntry id="oe_sp_1_uti_admission_crossover"><text>"UTI_PEDIATRICA"</text></outputEntry>
        <outputEntry id="oe_sp_2_uti_admission_crossover"><text>"Admissao padrao UTI Pediatrica"</text></outputEntry>
        <outputEntry id="oe_sp_3_uti_admission_crossover"><text>false</text></outputEntry>
      </rule>
      <rule id="r_standard_adulto_uti_admission_crossover">
        <description>UTI Adulto disponivel - admissao padrao (Contrato 4.3.4)</description>
        <inputEntry id="ie_sa_1_uti_admission_crossover"><text>"UTI_ADULTO"</text></inputEntry>
        <inputEntry id="ie_sa_2_uti_admission_crossover"><text>true</text></inputEntry>
        <inputEntry id="ie_sa_3_uti_admission_crossover"><text></text></inputEntry>
        <inputEntry id="ie_sa_4_uti_admission_crossover"><text></text></inputEntry>
        <inputEntry id="ie_sa_5_uti_admission_crossover"><text></text></inputEntry>
        <outputEntry id="oe_sa_1_uti_admission_crossover"><text>"UTI_ADULTO"</text></outputEntry>
        <outputEntry id="oe_sa_2_uti_admission_crossover"><text>"Admissao padrao UTI Adulto"</text></outputEntry>
        <outputEntry id="oe_sa_3_uti_admission_crossover"><text>false</text></outputEntry>
      </rule>
      <!-- Rule 2: Pediatric patient 13-17 years (4745-6569 days), no pediatric bed available -> Adult -->
      <rule id="r_crossover_ped_to_adult_uti_admission_crossover">
        <description>Sem leito pediatrico - paciente 13-17 anos admitido em UTI Adulto (Edital 2.5, Contrato 4.3.4)</description>
        <inputEntry id="ie_pa_1_uti_admission_crossover"><text>"UTI_PEDIATRICA"</text></inputEntry>
        <inputEntry id="ie_pa_2_uti_admission_crossover"><text>false</text></inputEntry>
        <inputEntry id="ie_pa_3_uti_admission_crossover"><text>[4745..6569]</text></inputEntry>
        <inputEntry id="ie_pa_4_uti_admission_crossover"><text></text></inputEntry>
        <inputEntry id="ie_pa_5_uti_admission_crossover"><text></text></inputEntry>
        <outputEntry id="oe_pa_1_uti_admission_crossover"><text>"UTI_ADULTO"</text></outputEntry>
        <outputEntry id="oe_pa_2_uti_admission_crossover"><text>"Sem leito pediatrico disponivel - internacao em UTI Adulto autorizada para pacientes de 13 a 17 anos 11 meses 29 dias"</text></outputEntry>
        <outputEntry id="oe_pa_3_uti_admission_crossover"><text>true</text></outputEntry>
      </rule>
      <!-- Rule 3: Neonatal patient (0-28 days), no neonatal bed available, weight>=2500g AND gest_age>=40w -> Pediatric -->
      <rule id="r_crossover_neo_to_ped_uti_admission_crossover">
        <description>Sem leito neonatal - recem-nascido a termo (peso>=2500g e IG corrigida>=40 sem) admitido em UTI Pediatrica (Edital 2.5, Contrato 4.3.4)</description>
        <inputEntry id="ie_np_1_uti_admission_crossover"><text>"UTI_NEONATAL"</text></inputEntry>
        <inputEntry id="ie_np_2_uti_admission_crossover"><text>false</text></inputEntry>
        <inputEntry id="ie_np_3_uti_admission_crossover"><text>[0..28]</text></inputEntry>
        <inputEntry id="ie_np_4_uti_admission_crossover"><text>&gt;= 2500</text></inputEntry>
        <inputEntry id="ie_np_5_uti_admission_crossover"><text>&gt;= 40</text></inputEntry>
        <outputEntry id="oe_np_1_uti_admission_crossover"><text>"UTI_PEDIATRICA"</text></outputEntry>
        <outputEntry id="oe_np_2_uti_admission_crossover"><text>"Sem leito neonatal disponivel - recem-nascido a termo com peso adequado (>=2500g e IG corrigida >=40 semanas) aceito em UTI Pediatrica, desde que ja tenha recebido alta hospitalar e retornado na emergencia pediatrica"</text></outputEntry>
        <outputEntry id="oe_np_3_uti_admission_crossover"><text>true</text></outputEntry>
      </rule>
      <!-- Rule 4: Fallback - crossover not applicable -->
      <rule id="r_crossover_denied_uti_admission_crossover">
        <description>Crossover nao aplicavel - sem leito disponivel e criterios nao atendidos</description>
        <inputEntry id="ie_cd_1_uti_admission_crossover"><text></text></inputEntry>
        <inputEntry id="ie_cd_2_uti_admission_crossover"><text>false</text></inputEntry>
        <inputEntry id="ie_cd_3_uti_admission_crossover"><text></text></inputEntry>
        <inputEntry id="ie_cd_4_uti_admission_crossover"><text></text></inputEntry>
        <inputEntry id="ie_cd_5_uti_admission_crossover"><text></text></inputEntry>
        <outputEntry id="oe_cd_1_uti_admission_crossover"><text>"AGUARDAR_LEITO"</text></outputEntry>
        <outputEntry id="oe_cd_2_uti_admission_crossover"><text>"Sem leito disponivel e sem criterio de crossover aplicavel - aguardar vaga ou buscar outra unidade pela CERIH/CRDF"</text></outputEntry>
        <outputEntry id="oe_cd_3_uti_admission_crossover"><text>true</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_uti_admission_crossover">
      <dmndi:DMNShape id="DMNShape_decision_uti_admission_crossover" dmnElementRef="decision_uti_admission_crossover">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
