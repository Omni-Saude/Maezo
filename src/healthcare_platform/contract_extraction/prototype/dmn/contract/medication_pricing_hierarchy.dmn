<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="medication_pricing_hierarchy_def"
             name="PRICING Rule medication_pricing_hierarchy"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!--
    PRICING archetype template.
    Determines the pricing source and markup for medications based on availability hierarchy.
    Payer: SES-DF
    Category: PRICING
    Archetype: PRICING
    Rule ID: medication_pricing_hierarchy
    Source: RN-018, Edital 05/2024 Anexo I, Section 9.9.1
    Hit Policy FIRST: returns the first matching rule in priority order.
  -->
  <decision id="decision_medication_pricing_hierarchy" name="PRICING Rule medication_pricing_hierarchy" camunda:historyTimeToLive="180">
    <decisionTable id="dt_medication_pricing_hierarchy" hitPolicy="FIRST">
      <input id="in_medication_pricing_hierarchy_1" label="medicamento_disponivel_brasindice">
        <inputExpression id="inExpr_medication_pricing_hierarchy_1" typeRef="boolean">
          <text>medicamento_disponivel_brasindice</text>
        </inputExpression>
      </input>
      <input id="in_medication_pricing_hierarchy_2" label="medicamento_disponivel_simpro">
        <inputExpression id="inExpr_medication_pricing_hierarchy_2" typeRef="boolean">
          <text>medicamento_disponivel_simpro</text>
        </inputExpression>
      </input>
      <input id="in_medication_pricing_hierarchy_3" label="num_orcamentos">
        <inputExpression id="inExpr_medication_pricing_hierarchy_3" typeRef="number">
          <text>num_orcamentos</text>
        </inputExpression>
      </input>
      <output id="out_medication_pricing_hierarchy_1" label="fonte_preco" name="fonte_preco" typeRef="string"/>
      <output id="out_medication_pricing_hierarchy_2" label="markup_pct" name="markup_pct" typeRef="number"/>
      <rule id="r_medication_pricing_hierarchy_1">
        <description>Hierarquia de preco medicamentos (9.9.1): Prioridade 1 - BRASINDICE Preco Fabrica (PF) + 15% (DF).</description>
        <inputEntry id="ie_medication_pricing_hierarchy_1_1"><text>true</text></inputEntry>
        <inputEntry id="ie_medication_pricing_hierarchy_1_2"><text>-</text></inputEntry>
        <inputEntry id="ie_medication_pricing_hierarchy_1_3"><text>-</text></inputEntry>
        <outputEntry id="oe_medication_pricing_hierarchy_1_1"><text>"BRASINDICE_PF_15"</text></outputEntry>
        <outputEntry id="oe_medication_pricing_hierarchy_1_2"><text>15</text></outputEntry>
      </rule>
      <rule id="r_medication_pricing_hierarchy_2">
        <description>Hierarquia de preco medicamentos (9.9.1): Prioridade 2 - tabela SIMPRO quando nao disponivel em BRASINDICE.</description>
        <inputEntry id="ie_medication_pricing_hierarchy_2_1"><text>false</text></inputEntry>
        <inputEntry id="ie_medication_pricing_hierarchy_2_2"><text>true</text></inputEntry>
        <inputEntry id="ie_medication_pricing_hierarchy_2_3"><text>-</text></inputEntry>
        <outputEntry id="oe_medication_pricing_hierarchy_2_1"><text>"SIMPRO"</text></outputEntry>
        <outputEntry id="oe_medication_pricing_hierarchy_2_2"><text>0</text></outputEntry>
      </rule>
      <rule id="r_medication_pricing_hierarchy_3">
        <description>Hierarquia de preco medicamentos (9.9.1): Prioridade 3 - menor valor dentre 3 orcamentos quando indisponivel em BRASINDICE e SIMPRO.</description>
        <inputEntry id="ie_medication_pricing_hierarchy_3_1"><text>false</text></inputEntry>
        <inputEntry id="ie_medication_pricing_hierarchy_3_2"><text>false</text></inputEntry>
        <inputEntry id="ie_medication_pricing_hierarchy_3_3"><text>&gt;= 3</text></inputEntry>
        <outputEntry id="oe_medication_pricing_hierarchy_3_1"><text>"ORCAMENTO_MINIMO"</text></outputEntry>
        <outputEntry id="oe_medication_pricing_hierarchy_3_2"><text>0</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_medication_pricing_hierarchy">
      <dmndi:DMNShape id="DMNShape_decision_medication_pricing_hierarchy" dmnElementRef="decision_medication_pricing_hierarchy">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
