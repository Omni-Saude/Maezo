<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="billing_cycle_def"
             name="AUTHORIZATION Rule billing_cycle"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!--
    ROUTING archetype template.
    Routes requests to the appropriate handler, formula, or service pathway.
    Payer: SES-DF
    Category: AUTHORIZATION
    Archetype: ROUTING
    Rule ID: billing_cycle
    Hit Policy FIRST: returns the first matching route.
  -->
  <decision id="decision_billing_cycle" name="AUTHORIZATION Rule billing_cycle" camunda:historyTimeToLive="180">
    <decisionTable id="dt_billing_cycle" hitPolicy="FIRST">
      <input id="Input_decision_billing_cycle" label="Trigger">
        <inputExpression id="InputExpr_decision_billing_cycle" typeRef="string">
          <text>trigger</text>
        </inputExpression>
      </input>
      <output id="Output_decision_billing_cycle" label="Resultado" name="resultado" typeRef="string"/>
      <rule id="Rule_decision_billing_cycle">
        <description>Ciclo de faturamento (clausula 4.3.8): competencia encerrada -> prestador envia conta em ate 5 dias uteis a CEAN (Portaria 460/2024). Conta nao conforme: notificacao + reapresentacao em 72h ou risco de atraso de pagamento. Documentacao obrigatoria: AIH, RAH, relatorio admissao UTI, evolucoes medicas, resumo de alta.</description>
        <inputEntry id="IE_decision_billing_cycle"><text>-</text></inputEntry>
        <outputEntry id="OE_decision_billing_cycle"><text>"REVISAR"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_billing_cycle">
      <dmndi:DMNShape id="DMNShape_decision_billing_cycle" dmnElementRef="decision_billing_cycle">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
