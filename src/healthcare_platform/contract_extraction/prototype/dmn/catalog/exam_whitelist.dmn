<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="exam_whitelist_def"
             name="Exam Whitelist"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!--
    Exames padronizados na SES/DF conforme Apendice VII do Edital/Contrato.
    Includes: bioquimica, hormonios, marcadores cardiacos, microbiologia,
              hematologia, parasitologia, urinalise, testes rapidos, radiologia,
              anatomia patologica.
    For SADT de alto custo (>R$450,00) autorizacao pelo medico supervisor requerida
    (Edital 2.8.6.5, Contrato 4.3.7.6.5).
  -->
  <decision id="decision_exam_whitelist" name="Exam Whitelist" camunda:historyTimeToLive="180">
    <decisionTable id="dt_exam_whitelist" hitPolicy="FIRST">
      <input id="in_codigo_sigtap_e_exam_whitelist" label="Codigo SIGTAP do Exame">
        <inputExpression id="inExpr_codigo_sigtap_e_exam_whitelist" typeRef="string">
          <text>codigo_sigtap</text>
        </inputExpression>
      </input>
      <output id="out_authorized_e_exam_whitelist" label="Authorized" name="authorized" typeRef="boolean"/>
      <output id="out_exam_name_exam_whitelist" label="Exam Name" name="exam_name" typeRef="string"/>
      <output id="out_tabela_ref_exam_whitelist" label="Reference Table" name="tabela_ref" typeRef="string"/>
      <!-- BIOQUIMICA -->
      <rule id="r_e_01_exam_whitelist">
        <description>Lactato (Apendice VII - Bioquimica)</description>
        <inputEntry id="ie_e_01_exam_whitelist"><text>"02.02.01.053-8"</text></inputEntry>
        <outputEntry id="oe_e_01_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_01_2_exam_whitelist"><text>"LACTATO"</text></outputEntry>
        <outputEntry id="oe_e_01_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_02_exam_whitelist">
        <description>Sodio em sangue total, soro e urina (Apendice VII)</description>
        <inputEntry id="ie_e_02_exam_whitelist"><text>"02.02.01.063-5"</text></inputEntry>
        <outputEntry id="oe_e_02_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_02_2_exam_whitelist"><text>"SODIO EM SANGUE TOTAL, SORO E URINA"</text></outputEntry>
        <outputEntry id="oe_e_02_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_03_exam_whitelist">
        <description>Potassio e Cloretos (Apendice VII)</description>
        <inputEntry id="ie_e_03_exam_whitelist"><text>"02.02.01.060-0"</text></inputEntry>
        <outputEntry id="oe_e_03_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_03_2_exam_whitelist"><text>"POTASSIO E CLORETOS EM SANGUE TOTAL, SORO E URINA"</text></outputEntry>
        <outputEntry id="oe_e_03_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_04_exam_whitelist">
        <description>Glicose Enzimatica (Apendice VII)</description>
        <inputEntry id="ie_e_04_exam_whitelist"><text>"02.02.01.047-3"</text></inputEntry>
        <outputEntry id="oe_e_04_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_04_2_exam_whitelist"><text>"GLICOSE ENZIMATICA"</text></outputEntry>
        <outputEntry id="oe_e_04_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_05_exam_whitelist">
        <description>Ureia Enzimatica (Apendice VII)</description>
        <inputEntry id="ie_e_05_exam_whitelist"><text>"02.02.01.069-4"</text></inputEntry>
        <outputEntry id="oe_e_05_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_05_2_exam_whitelist"><text>"UREIA ENZIMATICA"</text></outputEntry>
        <outputEntry id="oe_e_05_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_06_exam_whitelist">
        <description>Creatinina (Apendice VII)</description>
        <inputEntry id="ie_e_06_exam_whitelist"><text>"02.02.01.031-7"</text></inputEntry>
        <outputEntry id="oe_e_06_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_06_2_exam_whitelist"><text>"CREATININA"</text></outputEntry>
        <outputEntry id="oe_e_06_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_07_exam_whitelist">
        <description>TGO Cinetico - Transaminase Oxalacetica (Apendice VII)</description>
        <inputEntry id="ie_e_07_exam_whitelist"><text>"02.02.01.064-3"</text></inputEntry>
        <outputEntry id="oe_e_07_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_07_2_exam_whitelist"><text>"TGO CINETICO (AST)"</text></outputEntry>
        <outputEntry id="oe_e_07_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_08_exam_whitelist">
        <description>TGP Cinetico - Transaminase Piruvica (Apendice VII)</description>
        <inputEntry id="ie_e_08_exam_whitelist"><text>"02.02.01.065-1"</text></inputEntry>
        <outputEntry id="oe_e_08_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_08_2_exam_whitelist"><text>"TGP CINETICO (ALT)"</text></outputEntry>
        <outputEntry id="oe_e_08_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_09_exam_whitelist">
        <description>Bilirrubina Total e Fracoes (Apendice VII)</description>
        <inputEntry id="ie_e_09_exam_whitelist"><text>"02.02.01.020-1"</text></inputEntry>
        <outputEntry id="oe_e_09_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_09_2_exam_whitelist"><text>"BILIRRUBINA TOTAL E FRACOES"</text></outputEntry>
        <outputEntry id="oe_e_09_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_10_exam_whitelist">
        <description>Calcio (Apendice VII)</description>
        <inputEntry id="ie_e_10_exam_whitelist"><text>"02.02.01.021-0"</text></inputEntry>
        <outputEntry id="oe_e_10_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_10_2_exam_whitelist"><text>"CALCIO"</text></outputEntry>
        <outputEntry id="oe_e_10_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_11_exam_whitelist">
        <description>Gasometria Arterial (Apendice VII)</description>
        <inputEntry id="ie_e_11_exam_whitelist"><text>"02.02.01.073-2"</text></inputEntry>
        <outputEntry id="oe_e_11_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_11_2_exam_whitelist"><text>"GASOMETRIA ARTERIAL (pH, pCO2, PO2, HCO3, excesso base, satO2)"</text></outputEntry>
        <outputEntry id="oe_e_11_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_12_exam_whitelist">
        <description>Hemograma Completo (Apendice VII - Hematologia)</description>
        <inputEntry id="ie_e_12_exam_whitelist"><text>"02.02.02.038-0"</text></inputEntry>
        <outputEntry id="oe_e_12_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_12_2_exam_whitelist"><text>"HEMOGRAMA COMPLETO"</text></outputEntry>
        <outputEntry id="oe_e_12_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_13_exam_whitelist">
        <description>TAP - Tempo de Atividade de Protrombina (Apendice VII)</description>
        <inputEntry id="ie_e_13_exam_whitelist"><text>"02.02.02.014-2"</text></inputEntry>
        <outputEntry id="oe_e_13_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_13_2_exam_whitelist"><text>"TAP (TEMPO DE ATIVIDADE DE PROTROMBINA / RNI)"</text></outputEntry>
        <outputEntry id="oe_e_13_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_14_exam_whitelist">
        <description>TTPA - Tempo de Tromboplastina Parcial Ativada (Apendice VII)</description>
        <inputEntry id="ie_e_14_exam_whitelist"><text>"02.02.02.013-4"</text></inputEntry>
        <outputEntry id="oe_e_14_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_14_2_exam_whitelist"><text>"TTPA (TEMPO DE TROMBOPLASTINA PARCIAL ATIVADA)"</text></outputEntry>
        <outputEntry id="oe_e_14_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_15_exam_whitelist">
        <description>Hemocultura (Apendice VII - Microbiologia)</description>
        <inputEntry id="ie_e_15_exam_whitelist"><text>"02.02.08.015-3"</text></inputEntry>
        <outputEntry id="oe_e_15_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_15_2_exam_whitelist"><text>"HEMOCULTURA"</text></outputEntry>
        <outputEntry id="oe_e_15_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_16_exam_whitelist">
        <description>Antibiograma (Apendice VII)</description>
        <inputEntry id="ie_e_16_exam_whitelist"><text>"02.02.08.002-1"</text></inputEntry>
        <outputEntry id="oe_e_16_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_16_2_exam_whitelist"><text>"ANTIBIOGRAMA"</text></outputEntry>
        <outputEntry id="oe_e_16_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_17_exam_whitelist">
        <description>PCR - Proteina C Reativa (Apendice VII)</description>
        <inputEntry id="ie_e_17_exam_whitelist"><text>"02.02.03.008-3"</text></inputEntry>
        <outputEntry id="oe_e_17_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_17_2_exam_whitelist"><text>"PCR (PROTEINA C REATIVA)"</text></outputEntry>
        <outputEntry id="oe_e_17_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_18_exam_whitelist">
        <description>Troponina (Apendice VII - Marcadores Cardiacos)</description>
        <inputEntry id="ie_e_18_exam_whitelist"><text>"02.02.03.120-9"</text></inputEntry>
        <outputEntry id="oe_e_18_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_18_2_exam_whitelist"><text>"TROPONINA"</text></outputEntry>
        <outputEntry id="oe_e_18_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_19_exam_whitelist">
        <description>EAS - Exame de Urina Tipo 1 (Apendice VII - Urinalise)</description>
        <inputEntry id="ie_e_19_exam_whitelist"><text>"02.02.05.001-7"</text></inputEntry>
        <outputEntry id="oe_e_19_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_19_2_exam_whitelist"><text>"EAS (EXAME DE URINA TIPO 1)"</text></outputEntry>
        <outputEntry id="oe_e_19_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_20_exam_whitelist">
        <description>TSH (Apendice VII - Hormonios)</description>
        <inputEntry id="ie_e_20_exam_whitelist"><text>"02.02.06.025-0"</text></inputEntry>
        <outputEntry id="oe_e_20_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_20_2_exam_whitelist"><text>"TSH (TIROTROPINA)"</text></outputEntry>
        <outputEntry id="oe_e_20_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_21_exam_whitelist">
        <description>Fosfatase Alcalina (Apendice VII)</description>
        <inputEntry id="ie_e_21_exam_whitelist"><text>"02.02.01.042-2"</text></inputEntry>
        <outputEntry id="oe_e_21_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_21_2_exam_whitelist"><text>"FOSFATASE ALCALINA"</text></outputEntry>
        <outputEntry id="oe_e_21_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_22_exam_whitelist">
        <description>Magnesio (Apendice VII)</description>
        <inputEntry id="ie_e_22_exam_whitelist"><text>"02.02.01.056-2"</text></inputEntry>
        <outputEntry id="oe_e_22_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_22_2_exam_whitelist"><text>"MAGNESIO"</text></outputEntry>
        <outputEntry id="oe_e_22_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_23_exam_whitelist">
        <description>CK - Creatina Kinase (Apendice VII)</description>
        <inputEntry id="ie_e_23_exam_whitelist"><text>"02.02.01.032-5"</text></inputEntry>
        <outputEntry id="oe_e_23_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_23_2_exam_whitelist"><text>"CK (CREATINA KINASE TOTAL)"</text></outputEntry>
        <outputEntry id="oe_e_23_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_24_exam_whitelist">
        <description>Ultrassonografia Abdome Total (Apendice VII - Radiologia)</description>
        <inputEntry id="ie_e_24_exam_whitelist"><text>"02.05.02.004-6"</text></inputEntry>
        <outputEntry id="oe_e_24_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_24_2_exam_whitelist"><text>"ULTRASSONOGRAFIA DE ABDOME TOTAL"</text></outputEntry>
        <outputEntry id="oe_e_24_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <rule id="r_e_25_exam_whitelist">
        <description>Teste Rapido Dengue IGG/IGM (Apendice VII - Testes Rapidos)</description>
        <inputEntry id="ie_e_25_exam_whitelist"><text>"02.14.01.012-0"</text></inputEntry>
        <outputEntry id="oe_e_25_1_exam_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_e_25_2_exam_whitelist"><text>"TESTE RAPIDO DENGUE IGG/IGM / DENGUE NS1"</text></outputEntry>
        <outputEntry id="oe_e_25_3_exam_whitelist"><text>"SIGTAP"</text></outputEntry>
      </rule>
      <!-- Catch-all: exam not in whitelist -->
      <rule id="r_e_catchall_exam_whitelist">
        <description>Exame nao padronizado na SES/DF - nao autorizado automaticamente (Apendice VII)</description>
        <inputEntry id="ie_e_catchall_exam_whitelist"><text></text></inputEntry>
        <outputEntry id="oe_e_catchall_1_exam_whitelist"><text>false</text></outputEntry>
        <outputEntry id="oe_e_catchall_2_exam_whitelist"><text>"Exame nao padronizado na SES/DF - requer avaliacao pelo medico supervisor (Contrato 4.3.7.6)"</text></outputEntry>
        <outputEntry id="oe_e_catchall_3_exam_whitelist"><text>"N/A"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_exam_whitelist">
      <dmndi:DMNShape id="DMNShape_decision_exam_whitelist" dmnElementRef="decision_exam_whitelist">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
