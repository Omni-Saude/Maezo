        <outputEntry id="oe_m_02_2_material_whitelist"><text>"ABSORVENTE HIGIENICO TAMANHO HOSPITALAR"</text></outputEntry>
        <outputEntry id="oe_m_02_3_material_whitelist"><text>"279373"</text></outputEntry>
      </rule>
      <!-- Rule 3 -->
