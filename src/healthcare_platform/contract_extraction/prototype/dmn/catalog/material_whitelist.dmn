<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="material_whitelist_def"
             name="Material Whitelist"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!--
    Materiais padronizados na SES/DF conforme Apendice XI do contrato.
    Codigos SES (codigo_ses) e codigos BR (codigo_br) extraidos diretamente do arquivo.
    Materiais nao listados podem ser utilizados se tiverem descritivo similar a padronizado
    (Contrato 4.3.7.12). Materiais nao padronizados requerem autorizacao do medico supervisor.
  -->
  <decision id="decision_material_whitelist" name="Material Whitelist" camunda:historyTimeToLive="180">
    <decisionTable id="dt_material_whitelist" hitPolicy="FIRST">
      <input id="in_codigo_ses_material_whitelist" label="Codigo SES do Material">
        <inputExpression id="inExpr_codigo_ses_material_whitelist" typeRef="string">
          <text>codigo_ses</text>
        </inputExpression>
      </input>
      <output id="out_authorized_m_material_whitelist" label="Authorized" name="authorized" typeRef="boolean"/>
      <output id="out_material_name_material_whitelist" label="Material Name" name="material_name" typeRef="string"/>
      <output id="out_codigo_br_material_whitelist" label="Codigo BR" name="codigo_br" typeRef="string"/>
      <!-- Rule 1 -->
      <rule id="r_m_01_material_whitelist">
        <description>Abaixador de lingua convencional em madeira (Apendice XI)</description>
        <inputEntry id="ie_m_01_material_whitelist"><text>"91180"</text></inputEntry>
        <outputEntry id="oe_m_01_1_material_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_m_01_2_material_whitelist"><text>"ABAIXADOR DE LINGUA CONVENCIONAL EM MADEIRA, PACOTE COM 100 UND"</text></outputEntry>
        <outputEntry id="oe_m_01_3_material_whitelist"><text>"348807"</text></outputEntry>
      </rule>
      <!-- Rule 2 -->
      <rule id="r_m_02_material_whitelist">
