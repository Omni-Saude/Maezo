<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="hemotherapy_platelet_bundle_def"
             name="Hemotherapy Platelet Bundle Items"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!--
    Bundle inclusion/exclusion for Plaquetas based on Apendice IX (Hemoterapia).
    Hit Policy COLLECT: returns ALL matching rows.

    Plaquetas Randomico (SIGTAP 03.06.02.007-6):
      Included: Custo operacional, Selecao I (Tipagem ABO, Rh/PAI)
      Excluded: Selecao III (criancas <=4m), Aliquotagem, Deleucotizacao, Irradiacao

    Plaquetas por Aferese (SIGTAP 03.06.02.009-2):
      Included: Custo operacional, Selecao I (Tipagem/Retipagem ABO, Rh/PAI)
      Excluded: Selecao III (criancas <=4m), Irradiacao
  -->
  <decision id="decision_hemotherapy_platelet_bundle" name="Hemotherapy Platelet Bundle Items" camunda:historyTimeToLive="180">
    <decisionTable id="dt_hemotherapy_platelet_bundle" hitPolicy="COLLECT">
      <input id="in_platelet_type_hemotherapy_platelet_bundle" label="Platelet Type">
        <inputExpression id="inExpr_platelet_type_hemotherapy_platelet_bundle" typeRef="string">
          <text>platelet_type</text>
        </inputExpression>
      </input>
      <input id="in_service_category_plt_hemotherapy_platelet_bundle" label="Service Category">
        <inputExpression id="inExpr_service_category_plt_hemotherapy_platelet_bundle" typeRef="string">
          <text>service_category</text>
        </inputExpression>
      </input>
      <output id="out_item_included_plt_hemotherapy_platelet_bundle" label="Item Included" name="item_included" typeRef="boolean"/>
      <output id="out_item_name_plt_hemotherapy_platelet_bundle" label="Item Name" name="item_name" typeRef="string"/>
      <output id="out_is_complementary_plt_hemotherapy_platelet_bundle" label="Is Complementary" name="is_complementary" typeRef="boolean"/>
      <!-- RANDOMICO - Included -->
      <rule id="r_plt_rand_custo_op_hemotherapy_platelet_bundle">
        <description>Plaquetas Randomico: custo operacional incluido (Apendice IX)</description>
        <inputEntry id="ie_plt_rco_1_hemotherapy_platelet_bundle"><text>"RANDOMICO"</text></inputEntry>
        <inputEntry id="ie_plt_rco_2_hemotherapy_platelet_bundle"><text></text></inputEntry>
        <outputEntry id="oe_plt_rco_1_hemotherapy_platelet_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_plt_rco_2_hemotherapy_platelet_bundle"><text>"Custo operacional"</text></outputEntry>
        <outputEntry id="oe_plt_rco_3_hemotherapy_platelet_bundle"><text>false</text></outputEntry>
      </rule>
      <rule id="r_plt_rand_selecao_i_tipagem_hemotherapy_platelet_bundle">
        <description>Plaquetas Randomico: Selecao pre-transfusional I - Tipagem ABO incluida (Apendice IX)</description>
        <inputEntry id="ie_plt_rs1t_1_hemotherapy_platelet_bundle"><text>"RANDOMICO"</text></inputEntry>
        <inputEntry id="ie_plt_rs1t_2_hemotherapy_platelet_bundle"><text></text></inputEntry>
        <outputEntry id="oe_plt_rs1t_1_hemotherapy_platelet_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_plt_rs1t_2_hemotherapy_platelet_bundle"><text>"Selecao pre-transfusional I - Tipagem ABO"</text></outputEntry>
        <outputEntry id="oe_plt_rs1t_3_hemotherapy_platelet_bundle"><text>false</text></outputEntry>
      </rule>
      <rule id="r_plt_rand_selecao_i_rh_hemotherapy_platelet_bundle">
        <description>Plaquetas Randomico: Selecao pre-transfusional I - Rh/PAI incluida (Apendice IX)</description>
        <inputEntry id="ie_plt_rs1r_1_hemotherapy_platelet_bundle"><text>"RANDOMICO"</text></inputEntry>
        <inputEntry id="ie_plt_rs1r_2_hemotherapy_platelet_bundle"><text></text></inputEntry>
        <outputEntry id="oe_plt_rs1r_1_hemotherapy_platelet_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_plt_rs1r_2_hemotherapy_platelet_bundle"><text>"Selecao pre-transfusional I - Rh/PAI"</text></outputEntry>
        <outputEntry id="oe_plt_rs1r_3_hemotherapy_platelet_bundle"><text>false</text></outputEntry>
      </rule>
      <!-- RANDOMICO - Excluded (complementary) -->
      <rule id="r_plt_rand_excl_selecao_iii_hemotherapy_platelet_bundle">
        <description>Plaquetas Randomico: Selecao III (criancas &lt;=4m) EXCLUIDA - complementar (Apendice IX)</description>
        <inputEntry id="ie_plt_rs3_1_hemotherapy_platelet_bundle"><text>"RANDOMICO"</text></inputEntry>
        <inputEntry id="ie_plt_rs3_2_hemotherapy_platelet_bundle"><text>"selecao_iii"</text></inputEntry>
        <outputEntry id="oe_plt_rs3_1_hemotherapy_platelet_bundle"><text>false</text></outputEntry>
        <outputEntry id="oe_plt_rs3_2_hemotherapy_platelet_bundle"><text>"Selecao pre-transfusional III - criancas &lt;=4 meses (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_plt_rs3_3_hemotherapy_platelet_bundle"><text>true</text></outputEntry>
      </rule>
      <rule id="r_plt_rand_excl_aliquotagem_hemotherapy_platelet_bundle">
        <description>Plaquetas Randomico: Aliquotagem EXCLUIDA - complementar (Apendice IX)</description>
        <inputEntry id="ie_plt_raliq_1_hemotherapy_platelet_bundle"><text>"RANDOMICO"</text></inputEntry>
        <inputEntry id="ie_plt_raliq_2_hemotherapy_platelet_bundle"><text>"aliquotagem"</text></inputEntry>
        <outputEntry id="oe_plt_raliq_1_hemotherapy_platelet_bundle"><text>false</text></outputEntry>
        <outputEntry id="oe_plt_raliq_2_hemotherapy_platelet_bundle"><text>"Aliquotagem (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_plt_raliq_3_hemotherapy_platelet_bundle"><text>true</text></outputEntry>
      </rule>
      <rule id="r_plt_rand_excl_deleucotizacao_hemotherapy_platelet_bundle">
        <description>Plaquetas Randomico: Deleucotizacao EXCLUIDA - complementar (Apendice IX)</description>
        <inputEntry id="ie_plt_rdeleu_1_hemotherapy_platelet_bundle"><text>"RANDOMICO"</text></inputEntry>
        <inputEntry id="ie_plt_rdeleu_2_hemotherapy_platelet_bundle"><text>"deleucotizacao"</text></inputEntry>
        <outputEntry id="oe_plt_rdeleu_1_hemotherapy_platelet_bundle"><text>false</text></outputEntry>
        <outputEntry id="oe_plt_rdeleu_2_hemotherapy_platelet_bundle"><text>"Deleucotizacao (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_plt_rdeleu_3_hemotherapy_platelet_bundle"><text>true</text></outputEntry>
      </rule>
      <rule id="r_plt_rand_excl_irradiacao_hemotherapy_platelet_bundle">
        <description>Plaquetas Randomico: Irradiacao EXCLUIDA - complementar (Apendice IX)</description>
        <inputEntry id="ie_plt_rirr_1_hemotherapy_platelet_bundle"><text>"RANDOMICO"</text></inputEntry>
        <inputEntry id="ie_plt_rirr_2_hemotherapy_platelet_bundle"><text>"irradiacao"</text></inputEntry>
        <outputEntry id="oe_plt_rirr_1_hemotherapy_platelet_bundle"><text>false</text></outputEntry>
        <outputEntry id="oe_plt_rirr_2_hemotherapy_platelet_bundle"><text>"Irradiacao (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_plt_rirr_3_hemotherapy_platelet_bundle"><text>true</text></outputEntry>
      </rule>
      <!-- AFERESE - Included -->
      <rule id="r_plt_afer_custo_op_hemotherapy_platelet_bundle">
        <description>Plaquetas Aferese: custo operacional incluido (Apendice IX)</description>
        <inputEntry id="ie_plt_aco_1_hemotherapy_platelet_bundle"><text>"AFERESE"</text></inputEntry>
        <inputEntry id="ie_plt_aco_2_hemotherapy_platelet_bundle"><text></text></inputEntry>
        <outputEntry id="oe_plt_aco_1_hemotherapy_platelet_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_plt_aco_2_hemotherapy_platelet_bundle"><text>"Custo operacional"</text></outputEntry>
        <outputEntry id="oe_plt_aco_3_hemotherapy_platelet_bundle"><text>false</text></outputEntry>
      </rule>
      <rule id="r_plt_afer_selecao_i_tipagem_hemotherapy_platelet_bundle">
        <description>Plaquetas Aferese: Selecao pre-transfusional I - Tipagem/Retipagem ABO incluida (Apendice IX)</description>
        <inputEntry id="ie_plt_as1t_1_hemotherapy_platelet_bundle"><text>"AFERESE"</text></inputEntry>
        <inputEntry id="ie_plt_as1t_2_hemotherapy_platelet_bundle"><text></text></inputEntry>
        <outputEntry id="oe_plt_as1t_1_hemotherapy_platelet_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_plt_as1t_2_hemotherapy_platelet_bundle"><text>"Selecao pre-transfusional I - Tipagem/Retipagem ABO"</text></outputEntry>
        <outputEntry id="oe_plt_as1t_3_hemotherapy_platelet_bundle"><text>false</text></outputEntry>
      </rule>
      <rule id="r_plt_afer_selecao_i_rh_hemotherapy_platelet_bundle">
        <description>Plaquetas Aferese: Selecao pre-transfusional I - Rh/PAI incluida (Apendice IX)</description>
        <inputEntry id="ie_plt_as1r_1_hemotherapy_platelet_bundle"><text>"AFERESE"</text></inputEntry>
        <inputEntry id="ie_plt_as1r_2_hemotherapy_platelet_bundle"><text></text></inputEntry>
        <outputEntry id="oe_plt_as1r_1_hemotherapy_platelet_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_plt_as1r_2_hemotherapy_platelet_bundle"><text>"Selecao pre-transfusional I - Rh/PAI"</text></outputEntry>
        <outputEntry id="oe_plt_as1r_3_hemotherapy_platelet_bundle"><text>false</text></outputEntry>
      </rule>
      <!-- AFERESE - Excluded (complementary) -->
      <rule id="r_plt_afer_excl_selecao_iii_hemotherapy_platelet_bundle">
        <description>Plaquetas Aferese: Selecao III (criancas &lt;=4m) EXCLUIDA - complementar (Apendice IX)</description>
        <inputEntry id="ie_plt_as3_1_hemotherapy_platelet_bundle"><text>"AFERESE"</text></inputEntry>
        <inputEntry id="ie_plt_as3_2_hemotherapy_platelet_bundle"><text>"selecao_iii"</text></inputEntry>
        <outputEntry id="oe_plt_as3_1_hemotherapy_platelet_bundle"><text>false</text></outputEntry>
        <outputEntry id="oe_plt_as3_2_hemotherapy_platelet_bundle"><text>"Selecao pre-transfusional III - criancas &lt;=4 meses (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_plt_as3_3_hemotherapy_platelet_bundle"><text>true</text></outputEntry>
      </rule>
      <rule id="r_plt_afer_excl_irradiacao_hemotherapy_platelet_bundle">
        <description>Plaquetas Aferese: Irradiacao EXCLUIDA - complementar (Apendice IX)</description>
        <inputEntry id="ie_plt_airr_1_hemotherapy_platelet_bundle"><text>"AFERESE"</text></inputEntry>
        <inputEntry id="ie_plt_airr_2_hemotherapy_platelet_bundle"><text>"irradiacao"</text></inputEntry>
        <outputEntry id="oe_plt_airr_1_hemotherapy_platelet_bundle"><text>false</text></outputEntry>
        <outputEntry id="oe_plt_airr_2_hemotherapy_platelet_bundle"><text>"Irradiacao (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_plt_airr_3_hemotherapy_platelet_bundle"><text>true</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_hemotherapy_platelet_bundle">
      <dmndi:DMNShape id="DMNShape_decision_hemotherapy_platelet_bundle" dmnElementRef="decision_hemotherapy_platelet_bundle">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
