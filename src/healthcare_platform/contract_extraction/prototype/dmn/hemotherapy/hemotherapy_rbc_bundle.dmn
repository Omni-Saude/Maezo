<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="hemotherapy_rbc_bundle_def"
             name="Hemotherapy RBC Bundle Items"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!--
    Bundle inclusion/exclusion for Concentrado de Hemacias (SIGTAP 03.06.02.006-8)
    based on Apendice IX (Hemoterapia).
    Hit Policy COLLECT: returns ALL matching rows (included + complementary items).

    Included: Custo operacional, Selecao pre-transfusional I (Tipagem/Retipagem ABO, Rh/PAI),
              Selecao pre-transfusional II (prova de compatibilidade)
    Excluded (complementary at extra cost): Selecao III (criancas <=4m), Aliquotagem,
              Deleucotizacao, Irradiacao, Lavagem (aberto/fechado),
              Fenotipagem (2 sistemas / 3+ sistemas)
  -->
  <decision id="decision_hemotherapy_rbc_bundle" name="Hemotherapy RBC Bundle Items" camunda:historyTimeToLive="180">
    <decisionTable id="dt_hemotherapy_rbc_bundle" hitPolicy="COLLECT">
      <input id="in_product_type_rbc_hemotherapy_rbc_bundle" label="Product Type">
        <inputExpression id="inExpr_product_type_rbc_hemotherapy_rbc_bundle" typeRef="string">
          <text>product_type</text>
        </inputExpression>
      </input>
      <input id="in_service_category_rbc_hemotherapy_rbc_bundle" label="Service Category">
        <inputExpression id="inExpr_service_category_rbc_hemotherapy_rbc_bundle" typeRef="string">
          <text>service_category</text>
        </inputExpression>
      </input>
      <output id="out_item_included_rbc_hemotherapy_rbc_bundle" label="Item Included" name="item_included" typeRef="boolean"/>
      <output id="out_item_name_rbc_hemotherapy_rbc_bundle" label="Item Name" name="item_name" typeRef="string"/>
      <output id="out_is_complementary_rbc_hemotherapy_rbc_bundle" label="Is Complementary" name="is_complementary" typeRef="boolean"/>
      <!-- Included items -->
      <rule id="r_rbc_custo_operacional_hemotherapy_rbc_bundle">
        <description>Concentrado de Hemacias: custo operacional incluido no pacote (Apendice IX)</description>
        <inputEntry id="ie_rbc_co_1_hemotherapy_rbc_bundle"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_co_2_hemotherapy_rbc_bundle"><text></text></inputEntry>
        <outputEntry id="oe_rbc_co_1_hemotherapy_rbc_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_rbc_co_2_hemotherapy_rbc_bundle"><text>"Custo operacional"</text></outputEntry>
        <outputEntry id="oe_rbc_co_3_hemotherapy_rbc_bundle"><text>false</text></outputEntry>
      </rule>
      <rule id="r_rbc_selecao_i_tipagem_hemotherapy_rbc_bundle">
        <description>Concentrado de Hemacias: Selecao pre-transfusional I - Tipagem/Retipagem ABO incluida (Apendice IX)</description>
        <inputEntry id="ie_rbc_s1t_1_hemotherapy_rbc_bundle"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_s1t_2_hemotherapy_rbc_bundle"><text></text></inputEntry>
        <outputEntry id="oe_rbc_s1t_1_hemotherapy_rbc_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_rbc_s1t_2_hemotherapy_rbc_bundle"><text>"Selecao pre-transfusional I - Tipagem/Retipagem ABO"</text></outputEntry>
        <outputEntry id="oe_rbc_s1t_3_hemotherapy_rbc_bundle"><text>false</text></outputEntry>
      </rule>
      <rule id="r_rbc_selecao_i_rh_pai_hemotherapy_rbc_bundle">
        <description>Concentrado de Hemacias: Selecao pre-transfusional I - Rh/PAI incluida (Apendice IX)</description>
        <inputEntry id="ie_rbc_s1r_1_hemotherapy_rbc_bundle"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_s1r_2_hemotherapy_rbc_bundle"><text></text></inputEntry>
        <outputEntry id="oe_rbc_s1r_1_hemotherapy_rbc_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_rbc_s1r_2_hemotherapy_rbc_bundle"><text>"Selecao pre-transfusional I - Rh/PAI"</text></outputEntry>
        <outputEntry id="oe_rbc_s1r_3_hemotherapy_rbc_bundle"><text>false</text></outputEntry>
      </rule>
      <rule id="r_rbc_selecao_ii_hemotherapy_rbc_bundle">
        <description>Concentrado de Hemacias: Selecao pre-transfusional II - Prova de compatibilidade incluida (Apendice IX)</description>
        <inputEntry id="ie_rbc_s2_1_hemotherapy_rbc_bundle"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_s2_2_hemotherapy_rbc_bundle"><text></text></inputEntry>
        <outputEntry id="oe_rbc_s2_1_hemotherapy_rbc_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_rbc_s2_2_hemotherapy_rbc_bundle"><text>"Selecao pre-transfusional II - Prova de compatibilidade"</text></outputEntry>
        <outputEntry id="oe_rbc_s2_3_hemotherapy_rbc_bundle"><text>false</text></outputEntry>
      </rule>
      <!-- Excluded items (complementary services available at extra cost) -->
      <rule id="r_rbc_excl_selecao_iii_hemotherapy_rbc_bundle">
        <description>Concentrado de Hemacias: Selecao pre-transfusional III (criancas &lt;=4 meses) EXCLUIDA - servico complementar (Apendice IX)</description>
        <inputEntry id="ie_rbc_s3_1_hemotherapy_rbc_bundle"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_s3_2_hemotherapy_rbc_bundle"><text>"selecao_iii"</text></inputEntry>
        <outputEntry id="oe_rbc_s3_1_hemotherapy_rbc_bundle"><text>false</text></outputEntry>
        <outputEntry id="oe_rbc_s3_2_hemotherapy_rbc_bundle"><text>"Selecao pre-transfusional III - criancas &lt;=4 meses (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_rbc_s3_3_hemotherapy_rbc_bundle"><text>true</text></outputEntry>
      </rule>
      <rule id="r_rbc_excl_aliquotagem_hemotherapy_rbc_bundle">
        <description>Concentrado de Hemacias: Aliquotagem EXCLUIDA - servico complementar (Apendice IX)</description>
        <inputEntry id="ie_rbc_aliq_1_hemotherapy_rbc_bundle"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_aliq_2_hemotherapy_rbc_bundle"><text>"aliquotagem"</text></inputEntry>
        <outputEntry id="oe_rbc_aliq_1_hemotherapy_rbc_bundle"><text>false</text></outputEntry>
        <outputEntry id="oe_rbc_aliq_2_hemotherapy_rbc_bundle"><text>"Aliquotagem (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_rbc_aliq_3_hemotherapy_rbc_bundle"><text>true</text></outputEntry>
      </rule>
      <rule id="r_rbc_excl_deleucotizacao_hemotherapy_rbc_bundle">
        <description>Concentrado de Hemacias: Deleucotizacao EXCLUIDA - servico complementar (Apendice IX)</description>
        <inputEntry id="ie_rbc_deleu_1_hemotherapy_rbc_bundle"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_deleu_2_hemotherapy_rbc_bundle"><text>"deleucotizacao"</text></inputEntry>
        <outputEntry id="oe_rbc_deleu_1_hemotherapy_rbc_bundle"><text>false</text></outputEntry>
        <outputEntry id="oe_rbc_deleu_2_hemotherapy_rbc_bundle"><text>"Deleucotizacao (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_rbc_deleu_3_hemotherapy_rbc_bundle"><text>true</text></outputEntry>
      </rule>
      <rule id="r_rbc_excl_irradiacao_hemotherapy_rbc_bundle">
        <description>Concentrado de Hemacias: Irradiacao EXCLUIDA - servico complementar (Apendice IX)</description>
        <inputEntry id="ie_rbc_irr_1_hemotherapy_rbc_bundle"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_irr_2_hemotherapy_rbc_bundle"><text>"irradiacao"</text></inputEntry>
        <outputEntry id="oe_rbc_irr_1_hemotherapy_rbc_bundle"><text>false</text></outputEntry>
        <outputEntry id="oe_rbc_irr_2_hemotherapy_rbc_bundle"><text>"Irradiacao (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_rbc_irr_3_hemotherapy_rbc_bundle"><text>true</text></outputEntry>
      </rule>
      <rule id="r_rbc_excl_lavagem_aberto_hemotherapy_rbc_bundle">
        <description>Concentrado de Hemacias: Lavagem sistema aberto EXCLUIDA - servico complementar (Apendice IX)</description>
        <inputEntry id="ie_rbc_lava_1_hemotherapy_rbc_bundle"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_lava_2_hemotherapy_rbc_bundle"><text>"lavagem_aberto"</text></inputEntry>
        <outputEntry id="oe_rbc_lava_1_hemotherapy_rbc_bundle"><text>false</text></outputEntry>
        <outputEntry id="oe_rbc_lava_2_hemotherapy_rbc_bundle"><text>"Lavagem sistema aberto (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_rbc_lava_3_hemotherapy_rbc_bundle"><text>true</text></outputEntry>
      </rule>
      <rule id="r_rbc_excl_lavagem_fechado_hemotherapy_rbc_bundle">
        <description>Concentrado de Hemacias: Lavagem sistema fechado EXCLUIDA - servico complementar (Apendice IX)</description>
        <inputEntry id="ie_rbc_lavf_1_hemotherapy_rbc_bundle"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_lavf_2_hemotherapy_rbc_bundle"><text>"lavagem_fechado"</text></inputEntry>
        <outputEntry id="oe_rbc_lavf_1_hemotherapy_rbc_bundle"><text>false</text></outputEntry>
        <outputEntry id="oe_rbc_lavf_2_hemotherapy_rbc_bundle"><text>"Lavagem sistema fechado (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_rbc_lavf_3_hemotherapy_rbc_bundle"><text>true</text></outputEntry>
      </rule>
      <rule id="r_rbc_excl_fenotipagem_2_hemotherapy_rbc_bundle">
        <description>Concentrado de Hemacias: Fenotipagem 2 sistemas (Rh e Kell) EXCLUIDA - servico complementar (Apendice IX)</description>
        <inputEntry id="ie_rbc_fen2_1_hemotherapy_rbc_bundle"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_fen2_2_hemotherapy_rbc_bundle"><text>"fenotipagem_2_sistemas"</text></inputEntry>
        <outputEntry id="oe_rbc_fen2_1_hemotherapy_rbc_bundle"><text>false</text></outputEntry>
        <outputEntry id="oe_rbc_fen2_2_hemotherapy_rbc_bundle"><text>"Fenotipagem 2 sistemas - Rh e Kell (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_rbc_fen2_3_hemotherapy_rbc_bundle"><text>true</text></outputEntry>
      </rule>
      <rule id="r_rbc_excl_fenotipagem_3_hemotherapy_rbc_bundle">
        <description>Concentrado de Hemacias: Fenotipagem 3+ sistemas EXCLUIDA - servico complementar (Apendice IX)</description>
        <inputEntry id="ie_rbc_fen3_1_hemotherapy_rbc_bundle"><text>"CONCENTRADO_HEMACIAS"</text></inputEntry>
        <inputEntry id="ie_rbc_fen3_2_hemotherapy_rbc_bundle"><text>"fenotipagem_3_sistemas"</text></inputEntry>
        <outputEntry id="oe_rbc_fen3_1_hemotherapy_rbc_bundle"><text>false</text></outputEntry>
        <outputEntry id="oe_rbc_fen3_2_hemotherapy_rbc_bundle"><text>"Fenotipagem 3+ sistemas (EXCLUIDO)"</text></outputEntry>
        <outputEntry id="oe_rbc_fen3_3_hemotherapy_rbc_bundle"><text>true</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_hemotherapy_rbc_bundle">
      <dmndi:DMNShape id="DMNShape_decision_hemotherapy_rbc_bundle" dmnElementRef="decision_hemotherapy_rbc_bundle">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
