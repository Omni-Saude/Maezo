<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="hemodialysis_bundle_def"
             name="Hemodialysis Bundle Items"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!--
    Bundle inclusion/exclusion based on Apendice VIII (Terapia Renal Substitutiva).
    Hit Policy COLLECT: returns ALL matching rows (list of included/excluded items per session type).
  -->
  <decision id="decision_hemodialysis_bundle" name="Hemodialysis Bundle Items" camunda:historyTimeToLive="180">
    <decisionTable id="dt_hemodialysis_bundle" hitPolicy="COLLECT">
      <input id="in_session_type_b_hemodialysis_bundle" label="Session Type">
        <inputExpression id="inExpr_session_type_b_hemodialysis_bundle" typeRef="string">
          <text>session_type</text>
        </inputExpression>
      </input>
      <input id="in_item_category_hemodialysis_bundle" label="Item Category">
        <inputExpression id="inExpr_item_category_hemodialysis_bundle" typeRef="string">
          <text>item_category</text>
        </inputExpression>
      </input>
      <output id="out_item_included_b_hemodialysis_bundle" label="Item Included" name="item_included" typeRef="boolean"/>
      <output id="out_item_name_hemodialysis_bundle" label="Item Name" name="item_name" typeRef="string"/>
      <output id="out_qty_hemodialysis_bundle" label="Quantity per Session" name="quantity_per_session" typeRef="number"/>
      <!-- CONTINUA_PRIMEIRAS_24H - Included items (kit a cada 72h + materiais diarios) -->
      <rule id="r_b_c24_kit_maquina_hemodialysis_bundle">
        <description>Continua primeiras 24h: kit especifico maquina hemodiálise contínua incluido (a cada 72h) (Apendice VIII)</description>
        <inputEntry id="ie_b_c24k_1_hemodialysis_bundle"><text>"CONTINUA_PRIMEIRAS_24H"</text></inputEntry>
        <inputEntry id="ie_b_c24k_2_hemodialysis_bundle"><text></text></inputEntry>
        <outputEntry id="oe_b_c24k_1_hemodialysis_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_b_c24k_2_hemodialysis_bundle"><text>"Kit especifico para maquina de hemodialise continua (troca a cada 72h)"</text></outputEntry>
        <outputEntry id="oe_b_c24k_3_hemodialysis_bundle"><text>1</text></outputEntry>
      </rule>
      <rule id="r_b_c24_bolsa_drenagem_hemodialysis_bundle">
        <description>Continua primeiras 24h: bolsa de drenagem HP SP 354 incluida (a cada 72h)</description>
        <inputEntry id="ie_b_c24b_1_hemodialysis_bundle"><text>"CONTINUA_PRIMEIRAS_24H"</text></inputEntry>
        <inputEntry id="ie_b_c24b_2_hemodialysis_bundle"><text></text></inputEntry>
        <outputEntry id="oe_b_c24b_1_hemodialysis_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_b_c24b_2_hemodialysis_bundle"><text>"Bolsa de drenagem HP SP 354 (a cada 72h)"</text></outputEntry>
        <outputEntry id="oe_b_c24b_3_hemodialysis_bundle"><text>1</text></outputEntry>
      </rule>
      <rule id="r_b_c24_tubo_extensor_hemodialysis_bundle">
        <description>Continua primeiras 24h: tubo extensor incluido (a cada 72h)</description>
        <inputEntry id="ie_b_c24te_1_hemodialysis_bundle"><text>"CONTINUA_PRIMEIRAS_24H"</text></inputEntry>
        <inputEntry id="ie_b_c24te_2_hemodialysis_bundle"><text></text></inputEntry>
        <outputEntry id="oe_b_c24te_1_hemodialysis_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_b_c24te_2_hemodialysis_bundle"><text>"Tubo extensor (a cada 72h)"</text></outputEntry>
        <outputEntry id="oe_b_c24te_3_hemodialysis_bundle"><text>1</text></outputEntry>
      </rule>
      <rule id="r_b_c24_sol_eletro_hemodialysis_bundle">
        <description>Continua primeiras 24h: solucao eletrolitica 0,61% 5000ml - 10 bolsas/24h</description>
        <inputEntry id="ie_b_c24se_1_hemodialysis_bundle"><text>"CONTINUA_PRIMEIRAS_24H"</text></inputEntry>
        <inputEntry id="ie_b_c24se_2_hemodialysis_bundle"><text></text></inputEntry>
        <outputEntry id="oe_b_c24se_1_hemodialysis_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_b_c24se_2_hemodialysis_bundle"><text>"Solucao eletrolitica 0,61% 5000ml"</text></outputEntry>
        <outputEntry id="oe_b_c24se_3_hemodialysis_bundle"><text>10</text></outputEntry>
      </rule>
      <rule id="r_b_c24_citrato_hemodialysis_bundle">
        <description>Continua primeiras 24h: citrato de sodio 4% 3000ml - 2 bolsas/24h</description>
        <inputEntry id="ie_b_c24ci_1_hemodialysis_bundle"><text>"CONTINUA_PRIMEIRAS_24H"</text></inputEntry>
        <inputEntry id="ie_b_c24ci_2_hemodialysis_bundle"><text></text></inputEntry>
        <outputEntry id="oe_b_c24ci_1_hemodialysis_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_b_c24ci_2_hemodialysis_bundle"><text>"Citrato de sodio 4% 3000ml"</text></outputEntry>
        <outputEntry id="oe_b_c24ci_3_hemodialysis_bundle"><text>2</text></outputEntry>
      </rule>
      <rule id="r_b_c24_heparina_hemodialysis_bundle">
        <description>Continua primeiras 24h: frasco heparina sodica 5ml - 1/24h</description>
        <inputEntry id="ie_b_c24h_1_hemodialysis_bundle"><text>"CONTINUA_PRIMEIRAS_24H"</text></inputEntry>
        <inputEntry id="ie_b_c24h_2_hemodialysis_bundle"><text></text></inputEntry>
        <outputEntry id="oe_b_c24h_1_hemodialysis_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_b_c24h_2_hemodialysis_bundle"><text>"Heparina sodica 5ml (frasco)"</text></outputEntry>
        <outputEntry id="oe_b_c24h_3_hemodialysis_bundle"><text>1</text></outputEntry>
      </rule>
      <!-- CONTINUA_PRIMEIRAS_24H - Excluded items -->
      <rule id="r_b_c24_excl_cateter_medico_hemodialysis_bundle">
        <description>Continua primeiras 24h: honorarios medicos para acesso hemodialise EXCLUIDOS</description>
        <inputEntry id="ie_b_c24ex1_1_hemodialysis_bundle"><text>"CONTINUA_PRIMEIRAS_24H"</text></inputEntry>
        <inputEntry id="ie_b_c24ex1_2_hemodialysis_bundle"><text>"acesso_cateter"</text></inputEntry>
        <outputEntry id="oe_b_c24ex1_1_hemodialysis_bundle"><text>false</text></outputEntry>
        <outputEntry id="oe_b_c24ex1_2_hemodialysis_bundle"><text>"Honorarios medicos para acesso para hemodialise (EXCLUIDO do pacote)"</text></outputEntry>
        <outputEntry id="oe_b_c24ex1_3_hemodialysis_bundle"><text>0</text></outputEntry>
      </rule>
      <rule id="r_b_c24_excl_cateter_luminal_hemodialysis_bundle">
        <description>Continua primeiras 24h: cateter de duplo ou triplo lumen EXCLUIDO</description>
        <inputEntry id="ie_b_c24ex2_1_hemodialysis_bundle"><text>"CONTINUA_PRIMEIRAS_24H"</text></inputEntry>
        <inputEntry id="ie_b_c24ex2_2_hemodialysis_bundle"><text>"cateter_luminal"</text></inputEntry>
        <outputEntry id="oe_b_c24ex2_1_hemodialysis_bundle"><text>false</text></outputEntry>
        <outputEntry id="oe_b_c24ex2_2_hemodialysis_bundle"><text>"Cateter de duplo ou triplo lumen para hemodialise (EXCLUIDO do pacote)"</text></outputEntry>
        <outputEntry id="oe_b_c24ex2_3_hemodialysis_bundle"><text>0</text></outputEntry>
      </rule>
      <!-- CONTINUA_SUBSEQUENTE - Kit excluded (main difference vs first 24h) -->
      <rule id="r_b_cs_kit_excluido_hemodialysis_bundle">
        <description>Continua subsequente: kit especifico maquina EXCLUIDO do pacote (Apendice VIII)</description>
        <inputEntry id="ie_b_csk_1_hemodialysis_bundle"><text>"CONTINUA_SUBSEQUENTE"</text></inputEntry>
        <inputEntry id="ie_b_csk_2_hemodialysis_bundle"><text>"kit_maquina"</text></inputEntry>
        <outputEntry id="oe_b_csk_1_hemodialysis_bundle"><text>false</text></outputEntry>
        <outputEntry id="oe_b_csk_2_hemodialysis_bundle"><text>"Kit especifico para maquina de hemodialise continua (EXCLUIDO nas 24h subsequentes)"</text></outputEntry>
        <outputEntry id="oe_b_csk_3_hemodialysis_bundle"><text>0</text></outputEntry>
      </rule>
      <rule id="r_b_cs_sol_eletro_hemodialysis_bundle">
        <description>Continua subsequente: solucao eletrolitica incluida - 10 bolsas/24h</description>
        <inputEntry id="ie_b_csse_1_hemodialysis_bundle"><text>"CONTINUA_SUBSEQUENTE"</text></inputEntry>
        <inputEntry id="ie_b_csse_2_hemodialysis_bundle"><text></text></inputEntry>
        <outputEntry id="oe_b_csse_1_hemodialysis_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_b_csse_2_hemodialysis_bundle"><text>"Solucao eletrolitica 0,61% 5000ml"</text></outputEntry>
        <outputEntry id="oe_b_csse_3_hemodialysis_bundle"><text>10</text></outputEntry>
      </rule>
      <!-- INTERMITENTE - Included items (kit completo por sessao) -->
      <rule id="r_b_int_capilar_hemodialysis_bundle">
        <description>Intermitente: capilar (dialyzer) incluido por sessao - sem reuso</description>
        <inputEntry id="ie_b_ic_1_hemodialysis_bundle"><text>"INTERMITENTE"</text></inputEntry>
        <inputEntry id="ie_b_ic_2_hemodialysis_bundle"><text></text></inputEntry>
        <outputEntry id="oe_b_ic_1_hemodialysis_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_b_ic_2_hemodialysis_bundle"><text>"Capilar (dialyzer) - sem reuso"</text></outputEntry>
        <outputEntry id="oe_b_ic_3_hemodialysis_bundle"><text>1</text></outputEntry>
      </rule>
      <rule id="r_b_int_linha_arterial_hemodialysis_bundle">
        <description>Intermitente: linha arterial incluida por sessao - sem reuso</description>
        <inputEntry id="ie_b_ila_1_hemodialysis_bundle"><text>"INTERMITENTE"</text></inputEntry>
        <inputEntry id="ie_b_ila_2_hemodialysis_bundle"><text></text></inputEntry>
        <outputEntry id="oe_b_ila_1_hemodialysis_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_b_ila_2_hemodialysis_bundle"><text>"Linha arterial - sem reuso"</text></outputEntry>
        <outputEntry id="oe_b_ila_3_hemodialysis_bundle"><text>1</text></outputEntry>
      </rule>
      <rule id="r_b_int_linha_venosa_hemodialysis_bundle">
        <description>Intermitente: linha venosa incluida por sessao - sem reuso</description>
        <inputEntry id="ie_b_ilv_1_hemodialysis_bundle"><text>"INTERMITENTE"</text></inputEntry>
        <inputEntry id="ie_b_ilv_2_hemodialysis_bundle"><text></text></inputEntry>
        <outputEntry id="oe_b_ilv_1_hemodialysis_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_b_ilv_2_hemodialysis_bundle"><text>"Linha venosa - sem reuso"</text></outputEntry>
        <outputEntry id="oe_b_ilv_3_hemodialysis_bundle"><text>1</text></outputEntry>
      </rule>
      <rule id="r_b_int_sol_acida_hemodialysis_bundle">
        <description>Intermitente: frasco solucao acida (concentrado A) incluido</description>
        <inputEntry id="ie_b_isa_1_hemodialysis_bundle"><text>"INTERMITENTE"</text></inputEntry>
        <inputEntry id="ie_b_isa_2_hemodialysis_bundle"><text></text></inputEntry>
        <outputEntry id="oe_b_isa_1_hemodialysis_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_b_isa_2_hemodialysis_bundle"><text>"Frasco de solucao acida (concentrado A)"</text></outputEntry>
        <outputEntry id="oe_b_isa_3_hemodialysis_bundle"><text>1</text></outputEntry>
      </rule>
      <rule id="r_b_int_sol_basica_hemodialysis_bundle">
        <description>Intermitente: frascos solucao basica (concentrado B) incluidos</description>
        <inputEntry id="ie_b_isb_1_hemodialysis_bundle"><text>"INTERMITENTE"</text></inputEntry>
        <inputEntry id="ie_b_isb_2_hemodialysis_bundle"><text></text></inputEntry>
        <outputEntry id="oe_b_isb_1_hemodialysis_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_b_isb_2_hemodialysis_bundle"><text>"Frascos de solucao basica (concentrado B)"</text></outputEntry>
        <outputEntry id="oe_b_isb_3_hemodialysis_bundle"><text>2</text></outputEntry>
      </rule>
      <!-- INTERMITENTE - Excluded items -->
      <rule id="r_b_int_excl_acesso_hemodialysis_bundle">
        <description>Intermitente: honorarios medicos para acesso EXCLUIDOS</description>
        <inputEntry id="ie_b_iex1_1_hemodialysis_bundle"><text>"INTERMITENTE"</text></inputEntry>
        <inputEntry id="ie_b_iex1_2_hemodialysis_bundle"><text>"acesso_cateter"</text></inputEntry>
        <outputEntry id="oe_b_iex1_1_hemodialysis_bundle"><text>false</text></outputEntry>
        <outputEntry id="oe_b_iex1_2_hemodialysis_bundle"><text>"Honorarios medicos para acesso para hemodialise (EXCLUIDO do pacote)"</text></outputEntry>
        <outputEntry id="oe_b_iex1_3_hemodialysis_bundle"><text>0</text></outputEntry>
      </rule>
      <rule id="r_b_int_excl_cateter_hemodialysis_bundle">
        <description>Intermitente: cateter duplo ou triplo lumen EXCLUIDO</description>
        <inputEntry id="ie_b_iex2_1_hemodialysis_bundle"><text>"INTERMITENTE"</text></inputEntry>
        <inputEntry id="ie_b_iex2_2_hemodialysis_bundle"><text>"cateter_luminal"</text></inputEntry>
        <outputEntry id="oe_b_iex2_1_hemodialysis_bundle"><text>false</text></outputEntry>
        <outputEntry id="oe_b_iex2_2_hemodialysis_bundle"><text>"Cateter de duplo ou triplo lumen para hemodialise (EXCLUIDO do pacote)"</text></outputEntry>
        <outputEntry id="oe_b_iex2_3_hemodialysis_bundle"><text>0</text></outputEntry>
      </rule>
      <!-- INTERMITENTE_ESTENDIDA - sol acida e basica extras -->
      <rule id="r_b_ie_sol_acida_hemodialysis_bundle">
        <description>Intermitente Estendida: 2 frascos solucao acida incluidos (sessao 6-8h)</description>
        <inputEntry id="ie_b_iesa_1_hemodialysis_bundle"><text>"INTERMITENTE_ESTENDIDA"</text></inputEntry>
        <inputEntry id="ie_b_iesa_2_hemodialysis_bundle"><text></text></inputEntry>
        <outputEntry id="oe_b_iesa_1_hemodialysis_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_b_iesa_2_hemodialysis_bundle"><text>"Frascos de solucao acida (concentrado A) - sessao estendida"</text></outputEntry>
        <outputEntry id="oe_b_iesa_3_hemodialysis_bundle"><text>2</text></outputEntry>
      </rule>
      <rule id="r_b_ie_sol_basica_hemodialysis_bundle">
        <description>Intermitente Estendida: 3 frascos solucao basica incluidos (sessao 6-8h)</description>
        <inputEntry id="ie_b_iesb_1_hemodialysis_bundle"><text>"INTERMITENTE_ESTENDIDA"</text></inputEntry>
        <inputEntry id="ie_b_iesb_2_hemodialysis_bundle"><text></text></inputEntry>
        <outputEntry id="oe_b_iesb_1_hemodialysis_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_b_iesb_2_hemodialysis_bundle"><text>"Frascos de solucao basica (concentrado B) - sessao estendida"</text></outputEntry>
        <outputEntry id="oe_b_iesb_3_hemodialysis_bundle"><text>3</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_hemodialysis_bundle">
      <dmndi:DMNShape id="DMNShape_decision_hemodialysis_bundle" dmnElementRef="decision_hemodialysis_bundle">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
