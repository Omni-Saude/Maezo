<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="peritoneal_dialysis_pricing_def"
             name="Peritoneal Dialysis Pricing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!--
    Dialise Peritoneal pricing from Apendice VIII (Terapia Renal Substitutiva):
    SIGTAP 03.05.01.003-4
    Duas modalidades:
    - DPA (Dialise Peritoneal Automatizada)
    - CAPD (Dialise Peritoneal Ambulatorial Continua)
    Ambas incluem: enfermagem Nefrologia, honorarios medicos, aluguel maquina,
    equipamentos e materiais de consumo.
    Exclui: cateter Tenckhoff 2 cuff, visita medica.
  -->
  <decision id="decision_dp_pricing" name="Peritoneal Dialysis Pricing" camunda:historyTimeToLive="180">
    <decisionTable id="dt_dp_pricing" hitPolicy="FIRST">
      <input id="in_session_type_dpp_dp_pricing" label="Session Type">
        <inputExpression id="inExpr_session_type_dpp_dp_pricing" typeRef="string">
          <text>session_type</text>
        </inputExpression>
      </input>
      <input id="in_modality_dpp_dp_pricing" label="Modality">
        <inputExpression id="inExpr_modality_dpp_dp_pricing" typeRef="string">
          <text>modality</text>
        </inputExpression>
      </input>
      <output id="out_package_code_dpp_dp_pricing" label="Package SIGTAP Code" name="package_code" typeRef="string"/>
      <output id="out_billing_basis_dpp_dp_pricing" label="Billing Basis" name="billing_basis" typeRef="string"/>
      <output id="out_machine_rental_dpp_dp_pricing" label="Machine Rental Included" name="machine_rental_included" typeRef="boolean"/>
      <!-- Rule 1: DPA - Dialise Peritoneal Automatizada -->
      <rule id="r_dpp_dpa_dp_pricing">
        <description>Dialise Peritoneal Automatizada (DPA): inclui enfermagem Nefrologia, honorarios medicos, aluguel maquina, equipamentos e materiais. SIGTAP 03.05.01.003-4 (Apendice VIII)</description>
        <inputEntry id="ie_dpp_dpa_1_dp_pricing"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dpp_dpa_2_dp_pricing"><text>"DPA"</text></inputEntry>
        <outputEntry id="oe_dpp_dpa_1_dp_pricing"><text>"03.05.01.003-4"</text></outputEntry>
        <outputEntry id="oe_dpp_dpa_2_dp_pricing"><text>"Dialise Peritoneal Automatizada (DPA): inclui enfermagem Nefrologia, honorarios medicos, aluguel maquina, equipamentos, mascaras descartaveis (04), prep kit (01), wippers (02) e materiais de consumo. Exclui cateter Tenckhoff e visita medica (Apendice VIII)"</text></outputEntry>
        <outputEntry id="oe_dpp_dpa_3_dp_pricing"><text>true</text></outputEntry>
      </rule>
      <!-- Rule 2: CAPD - Dialise Peritoneal Ambulatorial Continua -->
      <rule id="r_dpp_capd_dp_pricing">
        <description>Dialise Peritoneal Ambulatorial Continua (CAPD): inclui enfermagem Nefrologia, honorarios medicos, aluguel maquina, equipamentos e materiais. SIGTAP 03.05.01.003-4 (Apendice VIII)</description>
        <inputEntry id="ie_dpp_capd_1_dp_pricing"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dpp_capd_2_dp_pricing"><text>"CAPD"</text></inputEntry>
        <outputEntry id="oe_dpp_capd_1_dp_pricing"><text>"03.05.01.003-4"</text></outputEntry>
        <outputEntry id="oe_dpp_capd_2_dp_pricing"><text>"Dialise Peritoneal Ambulatorial Continua (CAPD): inclui enfermagem Nefrologia, honorarios medicos, aluguel maquina, equipamentos, mascaras descartaveis (10), prep kit (05), wippers (05) e materiais de consumo. Exclui cateter Tenckhoff e visita medica (Apendice VIII)"</text></outputEntry>
        <outputEntry id="oe_dpp_capd_3_dp_pricing"><text>true</text></outputEntry>
      </rule>
      <!-- Rule 3: Fallback - unknown modality -->
      <rule id="r_dpp_fallback_dp_pricing">
        <description>Dialise Peritoneal modalidade nao especificada: requer classificacao DPA ou CAPD (Apendice VIII)</description>
        <inputEntry id="ie_dpp_fb_1_dp_pricing"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dpp_fb_2_dp_pricing"><text></text></inputEntry>
        <outputEntry id="oe_dpp_fb_1_dp_pricing"><text>"03.05.01.003-4"</text></outputEntry>
        <outputEntry id="oe_dpp_fb_2_dp_pricing"><text>"Dialise Peritoneal - modalidade nao especificada: classificar como DPA ou CAPD para definir quantidades de materiais"</text></outputEntry>
        <outputEntry id="oe_dpp_fb_3_dp_pricing"><text>true</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_dp_pricing">
      <dmndi:DMNShape id="DMNShape_decision_dp_pricing" dmnElementRef="decision_dp_pricing">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
