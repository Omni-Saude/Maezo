<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="peritoneal_dialysis_bundle_def"
             name="Peritoneal Dialysis Bundle Items"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!--
    Dialise Peritoneal bundle items from Apendice VIII (Terapia Renal Substitutiva):
    SIGTAP 03.05.01.003-4
    Modalidades: DPA (Dialise Peritoneal Automatizada) e CAPD (Dialise Peritoneal
    Ambulatorial Continua). Inclui enfermagem Nefrologia, equipamentos + aluguel maquina,
    materiais de consumo. Exclui cateter Tenckhoff 2 cuff e visita medica.
    Hit Policy COLLECT: retorna TODOS os itens correspondentes (incluidos e excluidos).
  -->
  <decision id="decision_dp_bundle" name="Peritoneal Dialysis Bundle Items" camunda:historyTimeToLive="180">
    <decisionTable id="dt_dp_bundle" hitPolicy="COLLECT">
      <input id="in_session_type_dpb_dp_bundle" label="Session Type">
        <inputExpression id="inExpr_session_type_dpb_dp_bundle" typeRef="string">
          <text>session_type</text>
        </inputExpression>
      </input>
      <input id="in_item_category_dpb_dp_bundle" label="Item Category">
        <inputExpression id="inExpr_item_category_dpb_dp_bundle" typeRef="string">
          <text>item_category</text>
        </inputExpression>
      </input>
      <output id="out_item_included_dpb_dp_bundle" label="Item Included" name="item_included" typeRef="boolean"/>
      <output id="out_item_name_dpb_dp_bundle" label="Item Name" name="item_name" typeRef="string"/>
      <output id="out_qty_dpb_dp_bundle" label="Quantity per Session" name="quantity_per_session" typeRef="number"/>
      <!-- Included items common to both DPA and CAPD -->
      <rule id="r_dp_enfermagem_dp_bundle">
        <description>Dialise Peritoneal: enfermagem Nefrologia incluida (Apendice VIII)</description>
        <inputEntry id="ie_dp_enf_1_dp_bundle"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_enf_2_dp_bundle"><text></text></inputEntry>
        <outputEntry id="oe_dp_enf_1_dp_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_enf_2_dp_bundle"><text>"Enfermagem Nefrologia"</text></outputEntry>
        <outputEntry id="oe_dp_enf_3_dp_bundle"><text>1</text></outputEntry>
      </rule>
      <rule id="r_dp_equipamentos_dp_bundle">
        <description>Dialise Peritoneal: equipamentos + aluguel maquina incluidos (Apendice VIII)</description>
        <inputEntry id="ie_dp_eq_1_dp_bundle"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_eq_2_dp_bundle"><text></text></inputEntry>
        <outputEntry id="oe_dp_eq_1_dp_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_eq_2_dp_bundle"><text>"Equipamentos + aluguel maquina"</text></outputEntry>
        <outputEntry id="oe_dp_eq_3_dp_bundle"><text>1</text></outputEntry>
      </rule>
      <rule id="r_dp_mascaras_dpa_dp_bundle">
        <description>Dialise Peritoneal DPA: 04 mascaras descartaveis (Apendice VIII)</description>
        <inputEntry id="ie_dp_md_1_dp_bundle"><text>"DIALISE_PERITONEAL_DPA"</text></inputEntry>
        <inputEntry id="ie_dp_md_2_dp_bundle"><text></text></inputEntry>
        <outputEntry id="oe_dp_md_1_dp_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_md_2_dp_bundle"><text>"Mascaras descartaveis (DPA)"</text></outputEntry>
        <outputEntry id="oe_dp_md_3_dp_bundle"><text>4</text></outputEntry>
      </rule>
      <rule id="r_dp_mascaras_capd_dp_bundle">
        <description>Dialise Peritoneal CAPD: 10 mascaras descartaveis (Apendice VIII)</description>
        <inputEntry id="ie_dp_mc_1_dp_bundle"><text>"DIALISE_PERITONEAL_CAPD"</text></inputEntry>
        <inputEntry id="ie_dp_mc_2_dp_bundle"><text></text></inputEntry>
        <outputEntry id="oe_dp_mc_1_dp_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_mc_2_dp_bundle"><text>"Mascaras descartaveis (CAPD)"</text></outputEntry>
        <outputEntry id="oe_dp_mc_3_dp_bundle"><text>10</text></outputEntry>
      </rule>
      <rule id="r_dp_clamps_dp_bundle">
        <description>Dialise Peritoneal: 02 clamps plasticos bolsa incluidos (Apendice VIII)</description>
        <inputEntry id="ie_dp_cl_1_dp_bundle"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_cl_2_dp_bundle"><text></text></inputEntry>
        <outputEntry id="oe_dp_cl_1_dp_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_cl_2_dp_bundle"><text>"Clamps plasticos bolsa"</text></outputEntry>
        <outputEntry id="oe_dp_cl_3_dp_bundle"><text>2</text></outputEntry>
      </rule>
      <rule id="r_dp_equipocassete_dp_bundle">
        <description>Dialise Peritoneal: 01 equipocassete Homechoice 3 entradas incluido (Apendice VIII)</description>
        <inputEntry id="ie_dp_ec_1_dp_bundle"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_ec_2_dp_bundle"><text></text></inputEntry>
        <outputEntry id="oe_dp_ec_1_dp_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_ec_2_dp_bundle"><text>"Equipocassete Homechoice 3 entradas"</text></outputEntry>
        <outputEntry id="oe_dp_ec_3_dp_bundle"><text>1</text></outputEntry>
      </rule>
      <rule id="r_dp_equipo_drenagem_dp_bundle">
        <description>Dialise Peritoneal: 01 equipo drenagem incluido (Apendice VIII)</description>
        <inputEntry id="ie_dp_ed_1_dp_bundle"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_ed_2_dp_bundle"><text></text></inputEntry>
        <outputEntry id="oe_dp_ed_1_dp_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_ed_2_dp_bundle"><text>"Equipo drenagem"</text></outputEntry>
        <outputEntry id="oe_dp_ed_3_dp_bundle"><text>1</text></outputEntry>
      </rule>
      <rule id="r_dp_prepkit_dpa_dp_bundle">
        <description>Dialise Peritoneal DPA: 01 prep kit incluido (Apendice VIII)</description>
        <inputEntry id="ie_dp_pk_1_dp_bundle"><text>"DIALISE_PERITONEAL_DPA"</text></inputEntry>
        <inputEntry id="ie_dp_pk_2_dp_bundle"><text></text></inputEntry>
        <outputEntry id="oe_dp_pk_1_dp_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_pk_2_dp_bundle"><text>"Prep Kit (DPA)"</text></outputEntry>
        <outputEntry id="oe_dp_pk_3_dp_bundle"><text>1</text></outputEntry>
      </rule>
      <rule id="r_dp_prepkit_capd_dp_bundle">
        <description>Dialise Peritoneal CAPD: 05 prep kits incluidos (Apendice VIII)</description>
        <inputEntry id="ie_dp_pkc_1_dp_bundle"><text>"DIALISE_PERITONEAL_CAPD"</text></inputEntry>
        <inputEntry id="ie_dp_pkc_2_dp_bundle"><text></text></inputEntry>
        <outputEntry id="oe_dp_pkc_1_dp_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_pkc_2_dp_bundle"><text>"Prep Kit (CAPD)"</text></outputEntry>
        <outputEntry id="oe_dp_pkc_3_dp_bundle"><text>5</text></outputEntry>
      </rule>
      <rule id="r_dp_bolsa_simples_dp_bundle">
        <description>Dialise Peritoneal: 01 bolsa simples 1,5/2,5/4,25% 2500ml incluida (Apendice VIII)</description>
        <inputEntry id="ie_dp_bs_1_dp_bundle"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_bs_2_dp_bundle"><text></text></inputEntry>
        <outputEntry id="oe_dp_bs_1_dp_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_bs_2_dp_bundle"><text>"Bolsa simples 1,5/2,5/4,25% 2500ml"</text></outputEntry>
        <outputEntry id="oe_dp_bs_3_dp_bundle"><text>1</text></outputEntry>
      </rule>
      <rule id="r_dp_bolsas_6000_dp_bundle">
        <description>Dialise Peritoneal: 02 bolsas simples 6000ml incluidas (Apendice VIII)</description>
        <inputEntry id="ie_dp_b6_1_dp_bundle"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_b6_2_dp_bundle"><text></text></inputEntry>
        <outputEntry id="oe_dp_b6_1_dp_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_b6_2_dp_bundle"><text>"Bolsas simples 6000ml"</text></outputEntry>
        <outputEntry id="oe_dp_b6_3_dp_bundle"><text>2</text></outputEntry>
      </rule>
      <rule id="r_dp_ultrabag_2000_dp_bundle">
        <description>Dialise Peritoneal: 05 bolsas Ultrabag 2000ml incluidas (Apendice VIII)</description>
        <inputEntry id="ie_dp_u2_1_dp_bundle"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_u2_2_dp_bundle"><text></text></inputEntry>
        <outputEntry id="oe_dp_u2_1_dp_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_u2_2_dp_bundle"><text>"Bolsas Ultrabag 2000ml"</text></outputEntry>
        <outputEntry id="oe_dp_u2_3_dp_bundle"><text>5</text></outputEntry>
      </rule>
      <rule id="r_dp_ultrabag_2500_dp_bundle">
        <description>Dialise Peritoneal: 05 bolsas Ultrabag 2500ml incluidas (Apendice VIII)</description>
        <inputEntry id="ie_dp_u25_1_dp_bundle"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_u25_2_dp_bundle"><text></text></inputEntry>
        <outputEntry id="oe_dp_u25_1_dp_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_u25_2_dp_bundle"><text>"Bolsas Ultrabag 2500ml"</text></outputEntry>
        <outputEntry id="oe_dp_u25_3_dp_bundle"><text>5</text></outputEntry>
      </rule>
      <rule id="r_dp_alcool_dp_bundle">
        <description>Dialise Peritoneal: alcool 70% 100ml incluido (Apendice VIII)</description>
        <inputEntry id="ie_dp_al_1_dp_bundle"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_al_2_dp_bundle"><text></text></inputEntry>
        <outputEntry id="oe_dp_al_1_dp_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_al_2_dp_bundle"><text>"Alcool 70% 100ml"</text></outputEntry>
        <outputEntry id="oe_dp_al_3_dp_bundle"><text>1</text></outputEntry>
      </rule>
      <rule id="r_dp_wipper_dpa_dp_bundle">
        <description>Dialise Peritoneal DPA: 02 wippers incluidos (Apendice VIII)</description>
        <inputEntry id="ie_dp_wd_1_dp_bundle"><text>"DIALISE_PERITONEAL_DPA"</text></inputEntry>
        <inputEntry id="ie_dp_wd_2_dp_bundle"><text></text></inputEntry>
        <outputEntry id="oe_dp_wd_1_dp_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_wd_2_dp_bundle"><text>"Wipper (DPA)"</text></outputEntry>
        <outputEntry id="oe_dp_wd_3_dp_bundle"><text>2</text></outputEntry>
      </rule>
      <rule id="r_dp_wipper_capd_dp_bundle">
        <description>Dialise Peritoneal CAPD: 05 wippers incluidos (Apendice VIII)</description>
        <inputEntry id="ie_dp_wc_1_dp_bundle"><text>"DIALISE_PERITONEAL_CAPD"</text></inputEntry>
        <inputEntry id="ie_dp_wc_2_dp_bundle"><text></text></inputEntry>
        <outputEntry id="oe_dp_wc_1_dp_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_wc_2_dp_bundle"><text>"Wipper (CAPD)"</text></outputEntry>
        <outputEntry id="oe_dp_wc_3_dp_bundle"><text>5</text></outputEntry>
      </rule>
      <rule id="r_dp_minicaps_dp_bundle">
        <description>Dialise Peritoneal: mini caps incluidos (Apendice VIII)</description>
        <inputEntry id="ie_dp_mi_1_dp_bundle"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_mi_2_dp_bundle"><text></text></inputEntry>
        <outputEntry id="oe_dp_mi_1_dp_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_mi_2_dp_bundle"><text>"Mini caps"</text></outputEntry>
        <outputEntry id="oe_dp_mi_3_dp_bundle"><text>1</text></outputEntry>
      </rule>
      <rule id="r_dp_luvas_estereis_dp_bundle">
        <description>Dialise Peritoneal: 02 pares luvas estereis incluidos (Apendice VIII)</description>
        <inputEntry id="ie_dp_le_1_dp_bundle"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_le_2_dp_bundle"><text></text></inputEntry>
        <outputEntry id="oe_dp_le_1_dp_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_le_2_dp_bundle"><text>"Luvas estereis (pares)"</text></outputEntry>
        <outputEntry id="oe_dp_le_3_dp_bundle"><text>2</text></outputEntry>
      </rule>
      <rule id="r_dp_mascara_cirurgica_dp_bundle">
        <description>Dialise Peritoneal: 01 mascara cirurgica incluida (Apendice VIII)</description>
        <inputEntry id="ie_dp_mci_1_dp_bundle"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_mci_2_dp_bundle"><text></text></inputEntry>
        <outputEntry id="oe_dp_mci_1_dp_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_mci_2_dp_bundle"><text>"Mascara cirurgica"</text></outputEntry>
        <outputEntry id="oe_dp_mci_3_dp_bundle"><text>1</text></outputEntry>
      </rule>
      <rule id="r_dp_compressa_dp_bundle">
        <description>Dialise Peritoneal: 02 pacotes compressa esteril incluidos (Apendice VIII)</description>
        <inputEntry id="ie_dp_co_1_dp_bundle"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_co_2_dp_bundle"><text></text></inputEntry>
        <outputEntry id="oe_dp_co_1_dp_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_co_2_dp_bundle"><text>"Compressa esteril (pacotes)"</text></outputEntry>
        <outputEntry id="oe_dp_co_3_dp_bundle"><text>2</text></outputEntry>
      </rule>
      <rule id="r_dp_luvas_procedimento_dp_bundle">
        <description>Dialise Peritoneal: 02 pares luvas procedimento incluidos (Apendice VIII)</description>
        <inputEntry id="ie_dp_lp_1_dp_bundle"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_lp_2_dp_bundle"><text></text></inputEntry>
        <outputEntry id="oe_dp_lp_1_dp_bundle"><text>true</text></outputEntry>
        <outputEntry id="oe_dp_lp_2_dp_bundle"><text>"Luvas procedimento (pares)"</text></outputEntry>
        <outputEntry id="oe_dp_lp_3_dp_bundle"><text>2</text></outputEntry>
      </rule>
      <!-- Excluded items -->
      <rule id="r_dp_excl_cateter_tenckhoff_dp_bundle">
        <description>Dialise Peritoneal: cateter Tenckhoff 2 cuff EXCLUIDO do pacote (Apendice VIII)</description>
        <inputEntry id="ie_dp_ext_1_dp_bundle"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_ext_2_dp_bundle"><text>"cateter_tenckhoff"</text></inputEntry>
        <outputEntry id="oe_dp_ext_1_dp_bundle"><text>false</text></outputEntry>
        <outputEntry id="oe_dp_ext_2_dp_bundle"><text>"Cateter Tenckhoff 2 cuff (EXCLUIDO do pacote)"</text></outputEntry>
        <outputEntry id="oe_dp_ext_3_dp_bundle"><text>0</text></outputEntry>
      </rule>
      <rule id="r_dp_excl_visita_medica_dp_bundle">
        <description>Dialise Peritoneal: visita medica EXCLUIDA do pacote (Apendice VIII)</description>
        <inputEntry id="ie_dp_exv_1_dp_bundle"><text>"DIALISE_PERITONEAL"</text></inputEntry>
        <inputEntry id="ie_dp_exv_2_dp_bundle"><text>"visita_medica"</text></inputEntry>
        <outputEntry id="oe_dp_exv_1_dp_bundle"><text>false</text></outputEntry>
        <outputEntry id="oe_dp_exv_2_dp_bundle"><text>"Visita medica (EXCLUIDA do pacote)"</text></outputEntry>
        <outputEntry id="oe_dp_exv_3_dp_bundle"><text>0</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_dp_bundle">
      <dmndi:DMNShape id="DMNShape_decision_dp_bundle" dmnElementRef="decision_dp_bundle">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
