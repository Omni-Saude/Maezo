<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="nutrition_enteral_adult_whitelist_def"
             name="Nutrition Enteral Adult Whitelist"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!--
    Whitelist de formulas enterais adulto conforme Apendice VI secoes 1 e 2.
    Secao 1: Formulas para terapia nutricional enteral adulto (9 itens)
    Secao 2: Formulas especializadas adulto (6 itens)
    Fonte: SES/SAIS/COASIS/DASIS/GESNUT 166054889
  -->
  <decision id="decision_nutrition_enteral_adult_whitelist" name="Nutrition Enteral Adult Whitelist" camunda:historyTimeToLive="180">
    <decisionTable id="dt_nutrition_enteral_adult_whitelist" hitPolicy="FIRST">
      <input id="in_code_neaw_nutrition_enteral_adult_whitelist" label="Code">
        <inputExpression id="inExpr_code_neaw_nutrition_enteral_adult_whitelist" typeRef="string">
          <text>code</text>
        </inputExpression>
      </input>
      <output id="out_authorized_neaw_nutrition_enteral_adult_whitelist" label="Authorized" name="authorized" typeRef="boolean"/>
      <output id="out_item_name_neaw_nutrition_enteral_adult_whitelist" label="Item Name" name="item_name" typeRef="string"/>
      <output id="out_ref_table_neaw_nutrition_enteral_adult_whitelist" label="Reference Table" name="reference_table" typeRef="string"/>
      <!-- Secao 1: Formulas padrao adulto -->
      <rule id="r_neaw_01_nutrition_enteral_adult_whitelist">
        <description>Padrao adulto polimerica sem fibras, normocalorica, po</description>
        <inputEntry id="ie_neaw_01_1_nutrition_enteral_adult_whitelist"><text>"NE_ADULTO_PADRAO_PO"</text></inputEntry>
        <outputEntry id="oe_neaw_01_1_nutrition_enteral_adult_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_01_2_nutrition_enteral_adult_whitelist"><text>"Formula padrao enteral adulto polimerica sem fibras, normocalorica 0,9-1,2 kcal/ml, normoproteica, sem sacarose, isenta gluten, po"</text></outputEntry>
        <outputEntry id="oe_neaw_01_3_nutrition_enteral_adult_whitelist"><text>"Apendice VI - Enteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_02_nutrition_enteral_adult_whitelist">
        <description>Padrao adulto com fibras, liquida</description>
        <inputEntry id="ie_neaw_02_1_nutrition_enteral_adult_whitelist"><text>"NE_ADULTO_PADRAO_FIBRAS_LIQ"</text></inputEntry>
        <outputEntry id="oe_neaw_02_1_nutrition_enteral_adult_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_02_2_nutrition_enteral_adult_whitelist"><text>"Formula padrao enteral adulto com fibras, normocalorica, normoproteica, sem sacarose, isenta gluten, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_02_3_nutrition_enteral_adult_whitelist"><text>"Apendice VI - Enteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_03_nutrition_enteral_adult_whitelist">
        <description>Padrao adulto com fibras, sistema fechado</description>
        <inputEntry id="ie_neaw_03_1_nutrition_enteral_adult_whitelist"><text>"NE_ADULTO_PADRAO_FIBRAS_SF"</text></inputEntry>
        <outputEntry id="oe_neaw_03_1_nutrition_enteral_adult_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_03_2_nutrition_enteral_adult_whitelist"><text>"Formula padrao enteral adulto com fibras, normocalorica, normoproteica, sistema fechado, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_03_3_nutrition_enteral_adult_whitelist"><text>"Apendice VI - Enteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_04_nutrition_enteral_adult_whitelist">
        <description>Hipercalorica adulto, liquida</description>
        <inputEntry id="ie_neaw_04_1_nutrition_enteral_adult_whitelist"><text>"NE_ADULTO_HIPERCALORICA_LIQ"</text></inputEntry>
        <outputEntry id="oe_neaw_04_1_nutrition_enteral_adult_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_04_2_nutrition_enteral_adult_whitelist"><text>"Formula hipercalorica adulto &gt;=1,5 kcal/ml, normoproteica, com ou sem fibras, sem sacarose, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_04_3_nutrition_enteral_adult_whitelist"><text>"Apendice VI - Enteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_05_nutrition_enteral_adult_whitelist">
        <description>Hipercalorica adulto, sistema fechado</description>
        <inputEntry id="ie_neaw_05_1_nutrition_enteral_adult_whitelist"><text>"NE_ADULTO_HIPERCALORICA_SF"</text></inputEntry>
        <outputEntry id="oe_neaw_05_1_nutrition_enteral_adult_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_05_2_nutrition_enteral_adult_whitelist"><text>"Formula hipercalorica adulto &gt;=1,5 kcal/ml, normoproteica, com ou sem fibras, sistema fechado, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_05_3_nutrition_enteral_adult_whitelist"><text>"Apendice VI - Enteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_06_nutrition_enteral_adult_whitelist">
        <description>Hiperproteica adulto, liquida</description>
        <inputEntry id="ie_neaw_06_1_nutrition_enteral_adult_whitelist"><text>"NE_ADULTO_HIPERPROTEICA_LIQ"</text></inputEntry>
        <outputEntry id="oe_neaw_06_1_nutrition_enteral_adult_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_06_2_nutrition_enteral_adult_whitelist"><text>"Formula hiperproteica adulto &gt;=20% VET, sem sacarose, sem fibras, isenta lactose/gluten, &gt;=0,9 kcal/ml, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_06_3_nutrition_enteral_adult_whitelist"><text>"Apendice VI - Enteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_07_nutrition_enteral_adult_whitelist">
        <description>Hiperproteica adulto, sistema fechado</description>
        <inputEntry id="ie_neaw_07_1_nutrition_enteral_adult_whitelist"><text>"NE_ADULTO_HIPERPROTEICA_SF"</text></inputEntry>
        <outputEntry id="oe_neaw_07_1_nutrition_enteral_adult_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_07_2_nutrition_enteral_adult_whitelist"><text>"Formula hiperproteica adulto &gt;=20% VET, hipercalorica &gt;=1,2 kcal/ml, com ou sem fibras, sistema fechado, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_07_3_nutrition_enteral_adult_whitelist"><text>"Apendice VI - Enteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_08_nutrition_enteral_adult_whitelist">
        <description>Semielementar adulto, liquida</description>
        <inputEntry id="ie_neaw_08_1_nutrition_enteral_adult_whitelist"><text>"NE_ADULTO_SEMIELEMENTAR_LIQ"</text></inputEntry>
        <outputEntry id="oe_neaw_08_1_nutrition_enteral_adult_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_08_2_nutrition_enteral_adult_whitelist"><text>"Formula oligomerica adulto para sindromes disabsortivas, isenta lactose/gluten, sem fibras, &gt;=0,9 kcal/ml, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_08_3_nutrition_enteral_adult_whitelist"><text>"Apendice VI - Enteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_09_nutrition_enteral_adult_whitelist">
        <description>Semielementar adulto, sistema fechado</description>
        <inputEntry id="ie_neaw_09_1_nutrition_enteral_adult_whitelist"><text>"NE_ADULTO_SEMIELEMENTAR_SF"</text></inputEntry>
        <outputEntry id="oe_neaw_09_1_nutrition_enteral_adult_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_09_2_nutrition_enteral_adult_whitelist"><text>"Formula oligomerica adulto para disturbios disabsortivos, isenta lactose/gluten, &gt;=20% proteina, sistema fechado, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_09_3_nutrition_enteral_adult_whitelist"><text>"Apendice VI - Enteral Adulto"</text></outputEntry>
      </rule>
      <!-- Secao 2: Formulas especializadas adulto -->
      <rule id="r_neaw_10_nutrition_enteral_adult_whitelist">
        <description>Imunomoduladora adulto, po</description>
        <inputEntry id="ie_neaw_10_1_nutrition_enteral_adult_whitelist"><text>"NE_ADULTO_IMUNOMODULADORA"</text></inputEntry>
        <outputEntry id="oe_neaw_10_1_nutrition_enteral_adult_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_10_2_nutrition_enteral_adult_whitelist"><text>"Formula imunomoduladora adulto com arginina e nucleotideos, hiperproteica &gt;=20% VET, &gt;=0,9 kcal/ml, po"</text></outputEntry>
        <outputEntry id="oe_neaw_10_3_nutrition_enteral_adult_whitelist"><text>"Apendice VI - Especializada Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_11_nutrition_enteral_adult_whitelist">
        <description>Doenca inflamatoria intestinal adulto, po</description>
        <inputEntry id="ie_neaw_11_1_nutrition_enteral_adult_whitelist"><text>"NE_ADULTO_DII"</text></inputEntry>
        <outputEntry id="oe_neaw_11_1_nutrition_enteral_adult_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_11_2_nutrition_enteral_adult_whitelist"><text>"Formula para DII fase ativa, polimerica, isenta lactose/gluten, com TCM, &gt;=0,9 kcal/ml, &gt;=10% proteina, po"</text></outputEntry>
        <outputEntry id="oe_neaw_11_3_nutrition_enteral_adult_whitelist"><text>"Apendice VI - Especializada Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_12_nutrition_enteral_adult_whitelist">
        <description>Nefropatia tratamento conservador adulto, liquida</description>
        <inputEntry id="ie_neaw_12_1_nutrition_enteral_adult_whitelist"><text>"NE_ADULTO_NEFROPATIA_CONSERVADOR"</text></inputEntry>
        <outputEntry id="oe_neaw_12_1_nutrition_enteral_adult_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_12_2_nutrition_enteral_adult_whitelist"><text>"Formula para DRC tratamento conservador, &gt;1,2 kcal/ml, proteina &lt;10% VET, baixo Na/K, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_12_3_nutrition_enteral_adult_whitelist"><text>"Apendice VI - Especializada Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_13_nutrition_enteral_adult_whitelist">
        <description>Nefropatia dialitico adulto, liquida</description>
        <inputEntry id="ie_neaw_13_1_nutrition_enteral_adult_whitelist"><text>"NE_ADULTO_NEFROPATIA_DIALITICO"</text></inputEntry>
        <outputEntry id="oe_neaw_13_1_nutrition_enteral_adult_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_13_2_nutrition_enteral_adult_whitelist"><text>"Formula para DRC em dialise, &gt;=1,5 kcal/ml, proteina &gt;=15% VET, baixo Na/K/P, isenta gluten, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_13_3_nutrition_enteral_adult_whitelist"><text>"Apendice VI - Especializada Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_14_nutrition_enteral_adult_whitelist">
        <description>Lesao por pressao adulto, liquida</description>
        <inputEntry id="ie_neaw_14_1_nutrition_enteral_adult_whitelist"><text>"NE_ADULTO_LESAO_PRESSAO"</text></inputEntry>
        <outputEntry id="oe_neaw_14_1_nutrition_enteral_adult_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_14_2_nutrition_enteral_adult_whitelist"><text>"Formula para lesao por pressao/cicatrizacao, com arginina, alto teor vit A/C/E/Zn/Cu/Se, &gt;=20% proteina, &gt;=0,9 kcal/ml, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_14_3_nutrition_enteral_adult_whitelist"><text>"Apendice VI - Especializada Adulto"</text></outputEntry>
      </rule>
      <rule id="r_neaw_15_nutrition_enteral_adult_whitelist">
        <description>Controle glicemico adulto, sistema fechado</description>
        <inputEntry id="ie_neaw_15_1_nutrition_enteral_adult_whitelist"><text>"NE_ADULTO_CONTROLE_GLICEMICO"</text></inputEntry>
        <outputEntry id="oe_neaw_15_1_nutrition_enteral_adult_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_neaw_15_2_nutrition_enteral_adult_whitelist"><text>"Formula para diabeticos/controle glicemico, com fibras, normocalorica, CHO &lt;50% VET, MUFAS &gt;=20% VET, sistema fechado, liquida"</text></outputEntry>
        <outputEntry id="oe_neaw_15_3_nutrition_enteral_adult_whitelist"><text>"Apendice VI - Especializada Adulto"</text></outputEntry>
      </rule>
      <!-- Catch-all -->
      <rule id="r_neaw_catchall_nutrition_enteral_adult_whitelist">
        <description>Formula enteral adulto nao autorizada - requer analise nutricional</description>
        <inputEntry id="ie_neaw_catchall_1_nutrition_enteral_adult_whitelist"><text></text></inputEntry>
        <outputEntry id="oe_neaw_catchall_1_nutrition_enteral_adult_whitelist"><text>false</text></outputEntry>
        <outputEntry id="oe_neaw_catchall_2_nutrition_enteral_adult_whitelist"><text>"Formula nao encontrada no Apendice VI adulto - requer analise do nutricionista"</text></outputEntry>
        <outputEntry id="oe_neaw_catchall_3_nutrition_enteral_adult_whitelist"><text>"N/A"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_nutrition_enteral_adult_whitelist">
      <dmndi:DMNShape id="DMNShape_decision_nutrition_enteral_adult_whitelist" dmnElementRef="decision_nutrition_enteral_adult_whitelist">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
