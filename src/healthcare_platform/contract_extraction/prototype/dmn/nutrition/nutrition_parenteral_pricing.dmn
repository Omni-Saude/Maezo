<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="nutrition_parenteral_pricing_def"
             name="Nutrition Parenteral Pricing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!--
    Precificacao de bolsas de nutricao parenteral por tipo de paciente.
    Valores de referencia (placeholder) por bolsa manipulada conforme Apendice V.
    Fonte: SES/SAIS/CATES/DIASF/GAFAE 119148749
  -->
  <decision id="decision_nutrition_parenteral_pricing" name="Nutrition Parenteral Pricing" camunda:historyTimeToLive="180">
    <decisionTable id="dt_nutrition_parenteral_pricing" hitPolicy="FIRST">
      <input id="in_item_code_npp_nutrition_parenteral_pricing" label="Item Code">
        <inputExpression id="inExpr_item_code_npp_nutrition_parenteral_pricing" typeRef="string">
          <text>item_code</text>
        </inputExpression>
      </input>
      <input id="in_patient_type_npp_nutrition_parenteral_pricing" label="Patient Type">
        <inputExpression id="inExpr_patient_type_npp_nutrition_parenteral_pricing" typeRef="string">
          <text>patient_type</text>
        </inputExpression>
      </input>
      <output id="out_unit_price_npp_nutrition_parenteral_pricing" label="Unit Price" name="unit_price" typeRef="number"/>
      <output id="out_currency_npp_nutrition_parenteral_pricing" label="Currency" name="currency" typeRef="string"/>
      <output id="out_pricing_table_npp_nutrition_parenteral_pricing" label="Pricing Table" name="pricing_table" typeRef="string"/>
      <!-- ADULTO -->
      <rule id="r_npp_01_nutrition_parenteral_pricing">
        <description>Adulto sem glutamina com lipideo 10-20% (BR 295269)</description>
        <inputEntry id="ie_npp_01_1_nutrition_parenteral_pricing"><text>"NP_ADULTO_SEM_GLUT_COM_LIP_10_20"</text></inputEntry>
        <inputEntry id="ie_npp_01_2_nutrition_parenteral_pricing"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_npp_01_1_nutrition_parenteral_pricing"><text>150.00</text></outputEntry>
        <outputEntry id="oe_npp_01_2_nutrition_parenteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_01_3_nutrition_parenteral_pricing"><text>"Apendice V - Parenteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_npp_02_nutrition_parenteral_pricing">
        <description>Adulto sem glutamina sem lipideo (BR 295270)</description>
        <inputEntry id="ie_npp_02_1_nutrition_parenteral_pricing"><text>"NP_ADULTO_SEM_GLUT_SEM_LIP"</text></inputEntry>
        <inputEntry id="ie_npp_02_2_nutrition_parenteral_pricing"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_npp_02_1_nutrition_parenteral_pricing"><text>120.00</text></outputEntry>
        <outputEntry id="oe_npp_02_2_nutrition_parenteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_02_3_nutrition_parenteral_pricing"><text>"Apendice V - Parenteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_npp_03_nutrition_parenteral_pricing">
        <description>Adulto sem glutamina com lipideo complexo omega (BR 295269)</description>
        <inputEntry id="ie_npp_03_1_nutrition_parenteral_pricing"><text>"NP_ADULTO_SEM_GLUT_COM_LIP_OMEGA"</text></inputEntry>
        <inputEntry id="ie_npp_03_2_nutrition_parenteral_pricing"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_npp_03_1_nutrition_parenteral_pricing"><text>180.00</text></outputEntry>
        <outputEntry id="oe_npp_03_2_nutrition_parenteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_03_3_nutrition_parenteral_pricing"><text>"Apendice V - Parenteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_npp_04_nutrition_parenteral_pricing">
        <description>Adulto com glutamina com lipideo 10-20% (BR 295267)</description>
        <inputEntry id="ie_npp_04_1_nutrition_parenteral_pricing"><text>"NP_ADULTO_COM_GLUT_COM_LIP_10_20"</text></inputEntry>
        <inputEntry id="ie_npp_04_2_nutrition_parenteral_pricing"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_npp_04_1_nutrition_parenteral_pricing"><text>170.00</text></outputEntry>
        <outputEntry id="oe_npp_04_2_nutrition_parenteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_04_3_nutrition_parenteral_pricing"><text>"Apendice V - Parenteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_npp_05_nutrition_parenteral_pricing">
        <description>Adulto com glutamina sem lipideo (BR 295268)</description>
        <inputEntry id="ie_npp_05_1_nutrition_parenteral_pricing"><text>"NP_ADULTO_COM_GLUT_SEM_LIP"</text></inputEntry>
        <inputEntry id="ie_npp_05_2_nutrition_parenteral_pricing"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_npp_05_1_nutrition_parenteral_pricing"><text>140.00</text></outputEntry>
        <outputEntry id="oe_npp_05_2_nutrition_parenteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_05_3_nutrition_parenteral_pricing"><text>"Apendice V - Parenteral Adulto"</text></outputEntry>
      </rule>
      <rule id="r_npp_06_nutrition_parenteral_pricing">
        <description>Adulto com glutamina com lipideo complexo omega (BR 295267)</description>
        <inputEntry id="ie_npp_06_1_nutrition_parenteral_pricing"><text>"NP_ADULTO_COM_GLUT_COM_LIP_OMEGA"</text></inputEntry>
        <inputEntry id="ie_npp_06_2_nutrition_parenteral_pricing"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_npp_06_1_nutrition_parenteral_pricing"><text>200.00</text></outputEntry>
        <outputEntry id="oe_npp_06_2_nutrition_parenteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_06_3_nutrition_parenteral_pricing"><text>"Apendice V - Parenteral Adulto"</text></outputEntry>
      </rule>
      <!-- PEDIATRICO -->
      <rule id="r_npp_07_nutrition_parenteral_pricing">
        <description>Pediatrico sem glutamina (BR 295269)</description>
        <inputEntry id="ie_npp_07_1_nutrition_parenteral_pricing"><text>"NP_PEDIATRICO_SEM_GLUT"</text></inputEntry>
        <inputEntry id="ie_npp_07_2_nutrition_parenteral_pricing"><text>"PEDIATRICO"</text></inputEntry>
        <outputEntry id="oe_npp_07_1_nutrition_parenteral_pricing"><text>160.00</text></outputEntry>
        <outputEntry id="oe_npp_07_2_nutrition_parenteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_07_3_nutrition_parenteral_pricing"><text>"Apendice V - Parenteral Pediatrico"</text></outputEntry>
      </rule>
      <rule id="r_npp_08_nutrition_parenteral_pricing">
        <description>Pediatrico com glutamina (BR 295267)</description>
        <inputEntry id="ie_npp_08_1_nutrition_parenteral_pricing"><text>"NP_PEDIATRICO_COM_GLUT"</text></inputEntry>
        <inputEntry id="ie_npp_08_2_nutrition_parenteral_pricing"><text>"PEDIATRICO"</text></inputEntry>
        <outputEntry id="oe_npp_08_1_nutrition_parenteral_pricing"><text>180.00</text></outputEntry>
        <outputEntry id="oe_npp_08_2_nutrition_parenteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_08_3_nutrition_parenteral_pricing"><text>"Apendice V - Parenteral Pediatrico"</text></outputEntry>
      </rule>
      <!-- NEONATAL -->
      <rule id="r_npp_09_nutrition_parenteral_pricing">
        <description>Neonatal sem glutamina (BR 295269)</description>
        <inputEntry id="ie_npp_09_1_nutrition_parenteral_pricing"><text>"NP_NEONATAL_SEM_GLUT"</text></inputEntry>
        <inputEntry id="ie_npp_09_2_nutrition_parenteral_pricing"><text>"NEONATAL"</text></inputEntry>
        <outputEntry id="oe_npp_09_1_nutrition_parenteral_pricing"><text>190.00</text></outputEntry>
        <outputEntry id="oe_npp_09_2_nutrition_parenteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_09_3_nutrition_parenteral_pricing"><text>"Apendice V - Parenteral Neonatal"</text></outputEntry>
      </rule>
      <rule id="r_npp_10_nutrition_parenteral_pricing">
        <description>Neonatal com glutamina (BR 295267)</description>
        <inputEntry id="ie_npp_10_1_nutrition_parenteral_pricing"><text>"NP_NEONATAL_COM_GLUT"</text></inputEntry>
        <inputEntry id="ie_npp_10_2_nutrition_parenteral_pricing"><text>"NEONATAL"</text></inputEntry>
        <outputEntry id="oe_npp_10_1_nutrition_parenteral_pricing"><text>210.00</text></outputEntry>
        <outputEntry id="oe_npp_10_2_nutrition_parenteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_10_3_nutrition_parenteral_pricing"><text>"Apendice V - Parenteral Neonatal"</text></outputEntry>
      </rule>
      <rule id="r_npp_11_nutrition_parenteral_pricing">
        <description>Neonatal sem glutamina com lipideo complexo omega (BR 295267)</description>
        <inputEntry id="ie_npp_11_1_nutrition_parenteral_pricing"><text>"NP_NEONATAL_SEM_GLUT_COM_LIP_OMEGA"</text></inputEntry>
        <inputEntry id="ie_npp_11_2_nutrition_parenteral_pricing"><text>"NEONATAL"</text></inputEntry>
        <outputEntry id="oe_npp_11_1_nutrition_parenteral_pricing"><text>220.00</text></outputEntry>
        <outputEntry id="oe_npp_11_2_nutrition_parenteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_11_3_nutrition_parenteral_pricing"><text>"Apendice V - Parenteral Neonatal"</text></outputEntry>
      </rule>
      <rule id="r_npp_12_nutrition_parenteral_pricing">
        <description>Neonatal com glutamina com lipideo complexo omega (BR 295267)</description>
        <inputEntry id="ie_npp_12_1_nutrition_parenteral_pricing"><text>"NP_NEONATAL_COM_GLUT_COM_LIP_OMEGA"</text></inputEntry>
        <inputEntry id="ie_npp_12_2_nutrition_parenteral_pricing"><text>"NEONATAL"</text></inputEntry>
        <outputEntry id="oe_npp_12_1_nutrition_parenteral_pricing"><text>240.00</text></outputEntry>
        <outputEntry id="oe_npp_12_2_nutrition_parenteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_12_3_nutrition_parenteral_pricing"><text>"Apendice V - Parenteral Neonatal"</text></outputEntry>
      </rule>
      <!-- Catch-all -->
      <rule id="r_npp_catchall_nutrition_parenteral_pricing">
        <description>Item nao encontrado - preco nao disponivel</description>
        <inputEntry id="ie_npp_catchall_1_nutrition_parenteral_pricing"><text></text></inputEntry>
        <inputEntry id="ie_npp_catchall_2_nutrition_parenteral_pricing"><text></text></inputEntry>
        <outputEntry id="oe_npp_catchall_1_nutrition_parenteral_pricing"><text>0</text></outputEntry>
        <outputEntry id="oe_npp_catchall_2_nutrition_parenteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_npp_catchall_3_nutrition_parenteral_pricing"><text>"N/A - Requer cotacao manual"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_nutrition_parenteral_pricing">
      <dmndi:DMNShape id="DMNShape_decision_nutrition_parenteral_pricing" dmnElementRef="decision_nutrition_parenteral_pricing">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
