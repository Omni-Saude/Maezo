<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="nutrition_parenteral_whitelist_def"
             name="Nutrition Parenteral Whitelist"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!--
    Whitelist de bolsas de nutricao parenteral autorizadas conforme Apendice V.
    Codigos BR referencia: 295267, 295268, 295269, 295270.
    Fonte: SES/SAIS/CATES/DIASF/GAFAE 119148749
  -->
  <decision id="decision_nutrition_parenteral_whitelist" name="Nutrition Parenteral Whitelist" camunda:historyTimeToLive="180">
    <decisionTable id="dt_nutrition_parenteral_whitelist" hitPolicy="FIRST">
      <input id="in_code_npw_nutrition_parenteral_whitelist" label="BR Code">
        <inputExpression id="inExpr_code_npw_nutrition_parenteral_whitelist" typeRef="string">
          <text>code</text>
        </inputExpression>
      </input>
      <output id="out_authorized_npw_nutrition_parenteral_whitelist" label="Authorized" name="authorized" typeRef="boolean"/>
      <output id="out_item_name_npw_nutrition_parenteral_whitelist" label="Item Name" name="item_name" typeRef="string"/>
      <output id="out_ref_table_npw_nutrition_parenteral_whitelist" label="Reference Table" name="reference_table" typeRef="string"/>
      <!-- Adulto sem glutamina, com emulsao lipidica 10-20% -->
      <rule id="r_npw_01_nutrition_parenteral_whitelist">
        <description>Adulto, aminoacidos sem glutamina, com emulsao lipidica 10-20% (BR 295269)</description>
        <inputEntry id="ie_npw_01_1_nutrition_parenteral_whitelist"><text>"NP_ADULTO_SEM_GLUT_COM_LIP_10_20"</text></inputEntry>
        <outputEntry id="oe_npw_01_1_nutrition_parenteral_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_01_2_nutrition_parenteral_whitelist"><text>"NP adulto sem glutamina com emulsao lipidica 10-20%, bolsa 1000-3000mL"</text></outputEntry>
        <outputEntry id="oe_npw_01_3_nutrition_parenteral_whitelist"><text>"Apendice V - BR 295269"</text></outputEntry>
      </rule>
      <!-- Adulto sem glutamina, sem emulsao lipidica -->
      <rule id="r_npw_02_nutrition_parenteral_whitelist">
        <description>Adulto, aminoacidos sem glutamina, sem emulsao lipidica (BR 295270)</description>
        <inputEntry id="ie_npw_02_1_nutrition_parenteral_whitelist"><text>"NP_ADULTO_SEM_GLUT_SEM_LIP"</text></inputEntry>
        <outputEntry id="oe_npw_02_1_nutrition_parenteral_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_02_2_nutrition_parenteral_whitelist"><text>"NP adulto sem glutamina sem emulsao lipidica, bolsa 1000-3000mL"</text></outputEntry>
        <outputEntry id="oe_npw_02_3_nutrition_parenteral_whitelist"><text>"Apendice V - BR 295270"</text></outputEntry>
      </rule>
      <!-- Adulto sem glutamina, com emulsao lipidica complexa omega 3,6,9 -->
      <rule id="r_npw_03_nutrition_parenteral_whitelist">
        <description>Adulto, aminoacidos sem glutamina, com emulsao lipidica complexa omega 3,6,9 (BR 295269)</description>
        <inputEntry id="ie_npw_03_1_nutrition_parenteral_whitelist"><text>"NP_ADULTO_SEM_GLUT_COM_LIP_OMEGA"</text></inputEntry>
        <outputEntry id="oe_npw_03_1_nutrition_parenteral_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_03_2_nutrition_parenteral_whitelist"><text>"NP adulto sem glutamina com emulsao lipidica complexa omega 3,6,9, bolsa 1000-3000mL"</text></outputEntry>
        <outputEntry id="oe_npw_03_3_nutrition_parenteral_whitelist"><text>"Apendice V - BR 295269"</text></outputEntry>
      </rule>
      <!-- Adulto com glutamina, com emulsao lipidica 10-20% -->
      <rule id="r_npw_04_nutrition_parenteral_whitelist">
        <description>Adulto, aminoacidos com glutamina, com emulsao lipidica 10-20% (BR 295267)</description>
        <inputEntry id="ie_npw_04_1_nutrition_parenteral_whitelist"><text>"NP_ADULTO_COM_GLUT_COM_LIP_10_20"</text></inputEntry>
        <outputEntry id="oe_npw_04_1_nutrition_parenteral_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_04_2_nutrition_parenteral_whitelist"><text>"NP adulto com glutamina com emulsao lipidica 10-20%, bolsa 1000-3000mL"</text></outputEntry>
        <outputEntry id="oe_npw_04_3_nutrition_parenteral_whitelist"><text>"Apendice V - BR 295267"</text></outputEntry>
      </rule>
      <!-- Adulto com glutamina, sem emulsao lipidica -->
      <rule id="r_npw_05_nutrition_parenteral_whitelist">
        <description>Adulto, aminoacidos com glutamina, sem emulsao lipidica (BR 295268)</description>
        <inputEntry id="ie_npw_05_1_nutrition_parenteral_whitelist"><text>"NP_ADULTO_COM_GLUT_SEM_LIP"</text></inputEntry>
        <outputEntry id="oe_npw_05_1_nutrition_parenteral_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_05_2_nutrition_parenteral_whitelist"><text>"NP adulto com glutamina sem emulsao lipidica, bolsa 1000-3000mL"</text></outputEntry>
        <outputEntry id="oe_npw_05_3_nutrition_parenteral_whitelist"><text>"Apendice V - BR 295268"</text></outputEntry>
      </rule>
      <!-- Adulto com glutamina, com emulsao lipidica complexa omega 3,6,9 -->
      <rule id="r_npw_06_nutrition_parenteral_whitelist">
        <description>Adulto, aminoacidos com glutamina, com emulsao lipidica complexa omega 3,6,9 (BR 295267)</description>
        <inputEntry id="ie_npw_06_1_nutrition_parenteral_whitelist"><text>"NP_ADULTO_COM_GLUT_COM_LIP_OMEGA"</text></inputEntry>
        <outputEntry id="oe_npw_06_1_nutrition_parenteral_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_06_2_nutrition_parenteral_whitelist"><text>"NP adulto com glutamina com emulsao lipidica complexa omega 3,6,9, bolsa 1000-3000mL"</text></outputEntry>
        <outputEntry id="oe_npw_06_3_nutrition_parenteral_whitelist"><text>"Apendice V - BR 295267"</text></outputEntry>
      </rule>
      <!-- Pediatrico sem glutamina -->
      <rule id="r_npw_07_nutrition_parenteral_whitelist">
        <description>Pediatrico, aminoacidos sem glutamina, com ou sem lipideo (BR 295269)</description>
        <inputEntry id="ie_npw_07_1_nutrition_parenteral_whitelist"><text>"NP_PEDIATRICO_SEM_GLUT"</text></inputEntry>
        <outputEntry id="oe_npw_07_1_nutrition_parenteral_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_07_2_nutrition_parenteral_whitelist"><text>"NP pediatrico sem glutamina com ou sem emulsao lipidica 10-20%, bolsa 500-2000mL"</text></outputEntry>
        <outputEntry id="oe_npw_07_3_nutrition_parenteral_whitelist"><text>"Apendice V - BR 295269"</text></outputEntry>
      </rule>
      <!-- Pediatrico com glutamina -->
      <rule id="r_npw_08_nutrition_parenteral_whitelist">
        <description>Pediatrico, aminoacidos com glutamina, com ou sem lipideo (BR 295267)</description>
        <inputEntry id="ie_npw_08_1_nutrition_parenteral_whitelist"><text>"NP_PEDIATRICO_COM_GLUT"</text></inputEntry>
        <outputEntry id="oe_npw_08_1_nutrition_parenteral_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_08_2_nutrition_parenteral_whitelist"><text>"NP pediatrico com glutamina com ou sem emulsao lipidica 10-20%, bolsa 500-2000mL"</text></outputEntry>
        <outputEntry id="oe_npw_08_3_nutrition_parenteral_whitelist"><text>"Apendice V - BR 295267"</text></outputEntry>
      </rule>
      <!-- Neonatal sem glutamina -->
      <rule id="r_npw_09_nutrition_parenteral_whitelist">
        <description>Neonatal, aminoacidos sem glutamina, com ou sem lipideo (BR 295269)</description>
        <inputEntry id="ie_npw_09_1_nutrition_parenteral_whitelist"><text>"NP_NEONATAL_SEM_GLUT"</text></inputEntry>
        <outputEntry id="oe_npw_09_1_nutrition_parenteral_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_09_2_nutrition_parenteral_whitelist"><text>"NP neonatal sem glutamina com ou sem emulsao lipidica 10-20%, bolsa ate 500mL"</text></outputEntry>
        <outputEntry id="oe_npw_09_3_nutrition_parenteral_whitelist"><text>"Apendice V - BR 295269"</text></outputEntry>
      </rule>
      <!-- Neonatal com glutamina -->
      <rule id="r_npw_10_nutrition_parenteral_whitelist">
        <description>Neonatal, aminoacidos com glutamina, com ou sem lipideo (BR 295267)</description>
        <inputEntry id="ie_npw_10_1_nutrition_parenteral_whitelist"><text>"NP_NEONATAL_COM_GLUT"</text></inputEntry>
        <outputEntry id="oe_npw_10_1_nutrition_parenteral_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_10_2_nutrition_parenteral_whitelist"><text>"NP neonatal com glutamina com ou sem emulsao lipidica 10-20%, bolsa ate 500mL"</text></outputEntry>
        <outputEntry id="oe_npw_10_3_nutrition_parenteral_whitelist"><text>"Apendice V - BR 295267"</text></outputEntry>
      </rule>
      <!-- Neonatal sem glutamina, com lipideo complexo omega -->
      <rule id="r_npw_11_nutrition_parenteral_whitelist">
        <description>Neonatal, aminoacidos sem glutamina, com emulsao lipidica complexa omega 3,6,9 (BR 295267)</description>
        <inputEntry id="ie_npw_11_1_nutrition_parenteral_whitelist"><text>"NP_NEONATAL_SEM_GLUT_COM_LIP_OMEGA"</text></inputEntry>
        <outputEntry id="oe_npw_11_1_nutrition_parenteral_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_11_2_nutrition_parenteral_whitelist"><text>"NP neonatal sem glutamina com emulsao lipidica complexa omega 3,6,9, bolsa ate 500mL"</text></outputEntry>
        <outputEntry id="oe_npw_11_3_nutrition_parenteral_whitelist"><text>"Apendice V - BR 295267"</text></outputEntry>
      </rule>
      <!-- Neonatal com glutamina, com lipideo complexo omega -->
      <rule id="r_npw_12_nutrition_parenteral_whitelist">
        <description>Neonatal, aminoacidos com glutamina, com emulsao lipidica complexa omega 3,6,9 (BR 295267)</description>
        <inputEntry id="ie_npw_12_1_nutrition_parenteral_whitelist"><text>"NP_NEONATAL_COM_GLUT_COM_LIP_OMEGA"</text></inputEntry>
        <outputEntry id="oe_npw_12_1_nutrition_parenteral_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_npw_12_2_nutrition_parenteral_whitelist"><text>"NP neonatal com glutamina com emulsao lipidica complexa omega 3,6,9, bolsa ate 500mL"</text></outputEntry>
        <outputEntry id="oe_npw_12_3_nutrition_parenteral_whitelist"><text>"Apendice V - BR 295267"</text></outputEntry>
      </rule>
      <!-- Catch-all -->
      <rule id="r_npw_catchall_nutrition_parenteral_whitelist">
        <description>Codigo nao autorizado - item parenteral fora do Apendice V</description>
        <inputEntry id="ie_npw_catchall_1_nutrition_parenteral_whitelist"><text></text></inputEntry>
        <outputEntry id="oe_npw_catchall_1_nutrition_parenteral_whitelist"><text>false</text></outputEntry>
        <outputEntry id="oe_npw_catchall_2_nutrition_parenteral_whitelist"><text>"Item nao encontrado no Apendice V - requer analise manual"</text></outputEntry>
        <outputEntry id="oe_npw_catchall_3_nutrition_parenteral_whitelist"><text>"N/A"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_nutrition_parenteral_whitelist">
      <dmndi:DMNShape id="DMNShape_decision_nutrition_parenteral_whitelist" dmnElementRef="decision_nutrition_parenteral_whitelist">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
