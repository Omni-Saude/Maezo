<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="nutrition_routing_def"
             name="Nutrition Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!--
    Formulacoes nutricionais padronizadas conforme Apendice V (Parenteral) e Apendice VI (Enteral).
    Nutricao enteral e parenteral requer autorizacao em ate 6h da prescricao
    (Contrato 4.3.7.5.11, Edital 2.8.5.10).
    Reavaliacao a cada 72h ou troca de tipo de terapia.
    Volume ranges based on Apendice V descriptions:
      - Adulto parenteral: 1000-3000 mL
      - Pediatrico parenteral: 500-2000 mL
      - Neonatal parenteral: 0-500 mL
    Enteral volumes per formula type per day (standard clinical ranges).
  -->
  <decision id="decision_nutrition_routing" name="Nutrition Routing" camunda:historyTimeToLive="180">
    <decisionTable id="dt_nutrition_routing" hitPolicy="FIRST">
      <input id="in_patient_type_n_nutrition_routing" label="Patient Type">
        <inputExpression id="inExpr_patient_type_n_nutrition_routing" typeRef="string">
          <text>patient_type</text>
        </inputExpression>
      </input>
      <input id="in_nutrition_route_nutrition_routing" label="Nutrition Route">
        <inputExpression id="inExpr_nutrition_route_nutrition_routing" typeRef="string">
          <text>nutrition_route</text>
        </inputExpression>
      </input>
      <input id="in_clinical_req_nutrition_routing" label="Clinical Requirement">
        <inputExpression id="inExpr_clinical_req_nutrition_routing" typeRef="string">
          <text>clinical_requirement</text>
        </inputExpression>
      </input>
      <output id="out_formula_type_nutrition_routing" label="Formula Type" name="formula_type" typeRef="string"/>
      <output id="out_volume_min_nutrition_routing" label="Volume Min (mL)" name="volume_range_min" typeRef="number"/>
      <output id="out_volume_max_nutrition_routing" label="Volume Max (mL)" name="volume_range_max" typeRef="number"/>
      <!-- ADULTO PARENTERAL - Regras baseadas no Apendice V -->
      <!-- Rule 1: Adulto parenteral padrao (sem glutamina, com lipideo) -->
      <rule id="r_n_01_nutrition_routing">
        <description>Adulto parenteral padrao sem glutamina, com emulsao lipidica 10-20% (Apendice V, BR 295269)</description>
        <inputEntry id="ie_n_01_1_nutrition_routing"><text>"ADULTO"</text></inputEntry>
        <inputEntry id="ie_n_01_2_nutrition_routing"><text>"PARENTERAL"</text></inputEntry>
        <inputEntry id="ie_n_01_3_nutrition_routing"><text>"PADRAO"</text></inputEntry>
        <outputEntry id="oe_n_01_1_nutrition_routing"><text>"NP_ADULTO_SEM_GLUTAMINA_COM_LIPIDEO - Nutricao parenteral adulto aminoacidos sem glutamina com emulsao lipidica 10-20%, bolsa manipulada (BR 295269)"</text></outputEntry>
        <outputEntry id="oe_n_01_2_nutrition_routing"><text>1000</text></outputEntry>
        <outputEntry id="oe_n_01_3_nutrition_routing"><text>3000</text></outputEntry>
      </rule>
      <!-- Rule 2: Adulto parenteral sem lipideo -->
      <rule id="r_n_02_nutrition_routing">
        <description>Adulto parenteral sem glutamina, sem emulsao lipidica (Apendice V, BR 295270)</description>
        <inputEntry id="ie_n_02_1_nutrition_routing"><text>"ADULTO"</text></inputEntry>
        <inputEntry id="ie_n_02_2_nutrition_routing"><text>"PARENTERAL"</text></inputEntry>
        <inputEntry id="ie_n_02_3_nutrition_routing"><text>"SEM_LIPIDEO"</text></inputEntry>
        <outputEntry id="oe_n_02_1_nutrition_routing"><text>"NP_ADULTO_SEM_GLUTAMINA_SEM_LIPIDEO - Nutricao parenteral adulto aminoacidos sem glutamina, sem emulsao lipidica, bolsa manipulada (BR 295270)"</text></outputEntry>
        <outputEntry id="oe_n_02_2_nutrition_routing"><text>1000</text></outputEntry>
        <outputEntry id="oe_n_02_3_nutrition_routing"><text>3000</text></outputEntry>
      </rule>
      <!-- Rule 3: Adulto parenteral com glutamina e lipideo -->
      <rule id="r_n_03_nutrition_routing">
        <description>Adulto parenteral com glutamina, com emulsao lipidica 10-20% (Apendice V, BR 295267)</description>
        <inputEntry id="ie_n_03_1_nutrition_routing"><text>"ADULTO"</text></inputEntry>
        <inputEntry id="ie_n_03_2_nutrition_routing"><text>"PARENTERAL"</text></inputEntry>
        <inputEntry id="ie_n_03_3_nutrition_routing"><text>"COM_GLUTAMINA"</text></inputEntry>
        <outputEntry id="oe_n_03_1_nutrition_routing"><text>"NP_ADULTO_COM_GLUTAMINA_COM_LIPIDEO - Nutricao parenteral adulto aminoacidos com glutamina com emulsao lipidica 10-20%, bolsa manipulada (BR 295267)"</text></outputEntry>
        <outputEntry id="oe_n_03_2_nutrition_routing"><text>1000</text></outputEntry>
        <outputEntry id="oe_n_03_3_nutrition_routing"><text>3000</text></outputEntry>
      </rule>
      <!-- Rule 4: Adulto parenteral com glutamina sem lipideo -->
      <rule id="r_n_04_nutrition_routing">
        <description>Adulto parenteral com glutamina, sem emulsao lipidica (Apendice V, BR 295268)</description>
        <inputEntry id="ie_n_04_1_nutrition_routing"><text>"ADULTO"</text></inputEntry>
        <inputEntry id="ie_n_04_2_nutrition_routing"><text>"PARENTERAL"</text></inputEntry>
        <inputEntry id="ie_n_04_3_nutrition_routing"><text>"COM_GLUTAMINA_SEM_LIPIDEO"</text></inputEntry>
        <outputEntry id="oe_n_04_1_nutrition_routing"><text>"NP_ADULTO_COM_GLUTAMINA_SEM_LIPIDEO - Nutricao parenteral adulto aminoacidos com glutamina sem emulsao lipidica, bolsa manipulada (BR 295268)"</text></outputEntry>
        <outputEntry id="oe_n_04_2_nutrition_routing"><text>1000</text></outputEntry>
        <outputEntry id="oe_n_04_3_nutrition_routing"><text>3000</text></outputEntry>
      </rule>
      <!-- PEDIATRICO PARENTERAL -->
      <!-- Rule 5: Pediatrico parenteral padrao sem glutamina -->
      <rule id="r_n_05_nutrition_routing">
        <description>Pediatrico parenteral sem glutamina, com ou sem lipideo (Apendice V, BR 295269)</description>
        <inputEntry id="ie_n_05_1_nutrition_routing"><text>"PEDIATRICO"</text></inputEntry>
        <inputEntry id="ie_n_05_2_nutrition_routing"><text>"PARENTERAL"</text></inputEntry>
        <inputEntry id="ie_n_05_3_nutrition_routing"><text>"PADRAO"</text></inputEntry>
        <outputEntry id="oe_n_05_1_nutrition_routing"><text>"NP_PEDIATRICO_SEM_GLUTAMINA - Nutricao parenteral pediatrica aminoacidos sem glutamina, com ou sem emulsao lipidica 10-20%, bolsa manipulada (BR 295269)"</text></outputEntry>
        <outputEntry id="oe_n_05_2_nutrition_routing"><text>500</text></outputEntry>
        <outputEntry id="oe_n_05_3_nutrition_routing"><text>2000</text></outputEntry>
      </rule>
      <!-- Rule 6: Pediatrico parenteral com glutamina -->
      <rule id="r_n_06_nutrition_routing">
        <description>Pediatrico parenteral com glutamina, com ou sem lipideo (Apendice V, BR 295267)</description>
        <inputEntry id="ie_n_06_1_nutrition_routing"><text>"PEDIATRICO"</text></inputEntry>
        <inputEntry id="ie_n_06_2_nutrition_routing"><text>"PARENTERAL"</text></inputEntry>
        <inputEntry id="ie_n_06_3_nutrition_routing"><text>"COM_GLUTAMINA"</text></inputEntry>
        <outputEntry id="oe_n_06_1_nutrition_routing"><text>"NP_PEDIATRICO_COM_GLUTAMINA - Nutricao parenteral pediatrica aminoacidos com glutamina, com ou sem emulsao lipidica 10-20%, bolsa manipulada (BR 295267)"</text></outputEntry>
        <outputEntry id="oe_n_06_2_nutrition_routing"><text>500</text></outputEntry>
        <outputEntry id="oe_n_06_3_nutrition_routing"><text>2000</text></outputEntry>
      </rule>
      <!-- NEONATAL PARENTERAL -->
      <!-- Rule 7: Neonatal parenteral padrao -->
      <rule id="r_n_07_nutrition_routing">
        <description>Neonatal parenteral sem glutamina (Apendice V, BR 295269)</description>
        <inputEntry id="ie_n_07_1_nutrition_routing"><text>"NEONATAL"</text></inputEntry>
        <inputEntry id="ie_n_07_2_nutrition_routing"><text>"PARENTERAL"</text></inputEntry>
        <inputEntry id="ie_n_07_3_nutrition_routing"><text>"PADRAO"</text></inputEntry>
        <outputEntry id="oe_n_07_1_nutrition_routing"><text>"NP_NEONATAL_SEM_GLUTAMINA - Nutricao parenteral neonatal aminoacidos sem glutamina, com ou sem emulsao lipidica 10-20%, bolsa manipulada (BR 295269)"</text></outputEntry>
        <outputEntry id="oe_n_07_2_nutrition_routing"><text>50</text></outputEntry>
        <outputEntry id="oe_n_07_3_nutrition_routing"><text>500</text></outputEntry>
      </rule>
      <!-- Rule 8: Neonatal parenteral com glutamina -->
      <rule id="r_n_08_nutrition_routing">
        <description>Neonatal parenteral com glutamina e lipideo complexo omega 3,6,9 (Apendice V, BR 295267)</description>
        <inputEntry id="ie_n_08_1_nutrition_routing"><text>"NEONATAL"</text></inputEntry>
        <inputEntry id="ie_n_08_2_nutrition_routing"><text>"PARENTERAL"</text></inputEntry>
        <inputEntry id="ie_n_08_3_nutrition_routing"><text>"COM_GLUTAMINA"</text></inputEntry>
        <outputEntry id="oe_n_08_1_nutrition_routing"><text>"NP_NEONATAL_COM_GLUTAMINA - Nutricao parenteral neonatal aminoacidos com glutamina, com ou sem emulsao lipidica 10-20%, bolsa manipulada (BR 295267)"</text></outputEntry>
        <outputEntry id="oe_n_08_2_nutrition_routing"><text>50</text></outputEntry>
        <outputEntry id="oe_n_08_3_nutrition_routing"><text>500</text></outputEntry>
      </rule>
      <!-- ADULTO ENTERAL - Regras baseadas no Apendice VI -->
      <!-- Rule 9: Adulto enteral padrao -->
      <rule id="r_n_09_nutrition_routing">
        <description>Adulto enteral padrao polimercia sem fibras (Apendice VI)</description>
        <inputEntry id="ie_n_09_1_nutrition_routing"><text>"ADULTO"</text></inputEntry>
        <inputEntry id="ie_n_09_2_nutrition_routing"><text>"ENTERAL"</text></inputEntry>
        <inputEntry id="ie_n_09_3_nutrition_routing"><text>"PADRAO"</text></inputEntry>
        <outputEntry id="oe_n_09_1_nutrition_routing"><text>"NE_ADULTO_PADRAO - Formula padrao adulto polimerica sem fibras, normocalorica (0,9-1,2 kcal/ml), normoproteica, sem sacarose, isenta gluten, apresentacao po"</text></outputEntry>
        <outputEntry id="oe_n_09_2_nutrition_routing"><text>500</text></outputEntry>
        <outputEntry id="oe_n_09_3_nutrition_routing"><text>2000</text></outputEntry>
      </rule>
      <!-- Rule 10: Adulto enteral hipercalorico -->
      <rule id="r_n_10_nutrition_routing">
        <description>Adulto enteral hipercalorico (Apendice VI)</description>
        <inputEntry id="ie_n_10_1_nutrition_routing"><text>"ADULTO"</text></inputEntry>
        <inputEntry id="ie_n_10_2_nutrition_routing"><text>"ENTERAL"</text></inputEntry>
        <inputEntry id="ie_n_10_3_nutrition_routing"><text>"HIPERCALORICO"</text></inputEntry>
        <outputEntry id="oe_n_10_1_nutrition_routing"><text>"NE_ADULTO_HIPERCALORICO - Formula hipercalorica adulto (&gt;=1,5kcal/ml), normoproteica, sem sacarose, isenta gluten, com ou sem fibras, apresentacao liquida"</text></outputEntry>
        <outputEntry id="oe_n_10_2_nutrition_routing"><text>500</text></outputEntry>
        <outputEntry id="oe_n_10_3_nutrition_routing"><text>1500</text></outputEntry>
      </rule>
      <!-- Rule 11: Adulto enteral hiperproteico -->
      <rule id="r_n_11_nutrition_routing">
        <description>Adulto enteral hiperproteico (Apendice VI)</description>
        <inputEntry id="ie_n_11_1_nutrition_routing"><text>"ADULTO"</text></inputEntry>
        <inputEntry id="ie_n_11_2_nutrition_routing"><text>"ENTERAL"</text></inputEntry>
        <inputEntry id="ie_n_11_3_nutrition_routing"><text>"HIPERPROTEICO"</text></inputEntry>
        <outputEntry id="oe_n_11_1_nutrition_routing"><text>"NE_ADULTO_HIPERPROTEICO - Formula hiperproteica adulto (&gt;=20% VET), sem sacarose, sem fibras, isenta lactose/gluten, densidade energetica &gt;=0,9 kcal/ml, apresentacao liquida"</text></outputEntry>
        <outputEntry id="oe_n_11_2_nutrition_routing"><text>500</text></outputEntry>
        <outputEntry id="oe_n_11_3_nutrition_routing"><text>2000</text></outputEntry>
      </rule>
      <!-- Rule 12: Adulto enteral semielementar -->
      <rule id="r_n_12_nutrition_routing">
        <description>Adulto enteral semielementar - sindromes disabsortivas (Apendice VI)</description>
        <inputEntry id="ie_n_12_1_nutrition_routing"><text>"ADULTO"</text></inputEntry>
        <inputEntry id="ie_n_12_2_nutrition_routing"><text>"ENTERAL"</text></inputEntry>
        <inputEntry id="ie_n_12_3_nutrition_routing"><text>"SEMIELEMENTAR"</text></inputEntry>
        <outputEntry id="oe_n_12_1_nutrition_routing"><text>"NE_ADULTO_SEMIELEMENTAR - Formula oligomerica adulto para sindromes disabsortivas, isenta lactose/gluten, sem fibras, sem sacarose, densidade &gt;=0,9 kcal/ml, apresentacao liquida"</text></outputEntry>
        <outputEntry id="oe_n_12_2_nutrition_routing"><text>500</text></outputEntry>
        <outputEntry id="oe_n_12_3_nutrition_routing"><text>2000</text></outputEntry>
      </rule>
      <!-- PEDIATRICO ENTERAL -->
      <!-- Rule 13: Pediatrico enteral padrao 0-1 ano -->
      <rule id="r_n_13_nutrition_routing">
        <description>Formula infantil padrao 0-1 ano para lactentes (Apendice VI)</description>
        <inputEntry id="ie_n_13_1_nutrition_routing"><text>"PEDIATRICO"</text></inputEntry>
        <inputEntry id="ie_n_13_2_nutrition_routing"><text>"ENTERAL"</text></inputEntry>
        <inputEntry id="ie_n_13_3_nutrition_routing"><text>"PADRAO_0_1ANO"</text></inputEntry>
        <outputEntry id="oe_n_13_1_nutrition_routing"><text>"NE_INFANTIL_0_1ANO - Formula infantil para lactentes, base leite de vaca, densidade &gt;=1 kcal/ml, sem sacarose, isenta gluten, apresentacao po"</text></outputEntry>
        <outputEntry id="oe_n_13_2_nutrition_routing"><text>100</text></outputEntry>
        <outputEntry id="oe_n_13_3_nutrition_routing"><text>500</text></outputEntry>
      </rule>
      <!-- Rule 14: Pediatrico enteral padrao acima 1 ano -->
      <rule id="r_n_14_nutrition_routing">
        <description>Formula pediatrica padrao para criancas acima de 1 ano (Apendice VI)</description>
        <inputEntry id="ie_n_14_1_nutrition_routing"><text>"PEDIATRICO"</text></inputEntry>
        <inputEntry id="ie_n_14_2_nutrition_routing"><text>"ENTERAL"</text></inputEntry>
        <inputEntry id="ie_n_14_3_nutrition_routing"><text>"PADRAO"</text></inputEntry>
        <outputEntry id="oe_n_14_1_nutrition_routing"><text>"NE_PEDIATRICO_PADRAO - Formula pediatrica polimerica para criancas &lt;10 anos, isenta gluten, densidade &gt;1 kcal/ml, proteina &gt;=10% VET, apresentacao po"</text></outputEntry>
        <outputEntry id="oe_n_14_2_nutrition_routing"><text>200</text></outputEntry>
        <outputEntry id="oe_n_14_3_nutrition_routing"><text>1200</text></outputEntry>
      </rule>
      <!-- Rule 15: Pediatrico enteral cetogenico para epilepsia refrataria -->
      <rule id="r_n_15_nutrition_routing">
        <description>Formula cetogenica para epilepsia refrataria (Apendice VI)</description>
        <inputEntry id="ie_n_15_1_nutrition_routing"><text>"PEDIATRICO"</text></inputEntry>
        <inputEntry id="ie_n_15_2_nutrition_routing"><text>"ENTERAL"</text></inputEntry>
        <inputEntry id="ie_n_15_3_nutrition_routing"><text>"CETOGENICO"</text></inputEntry>
        <outputEntry id="oe_n_15_1_nutrition_routing"><text>"NE_PEDIATRICO_CETOGENICO - Formula cetogenica pediatrica para epilepsia refrataria, proporcao 4g gordura:1g carb+proteina, isenta gluten, apresentacao po"</text></outputEntry>
        <outputEntry id="oe_n_15_2_nutrition_routing"><text>100</text></outputEntry>
        <outputEntry id="oe_n_15_3_nutrition_routing"><text>800</text></outputEntry>
      </rule>
      <!-- Rule 16: Adulto enteral para nefropatia dialitica -->
      <rule id="r_n_16_nutrition_routing">
        <description>Formula adulto enteral para nefropatia dialitica (Apendice VI especializada)</description>
        <inputEntry id="ie_n_16_1_nutrition_routing"><text>"ADULTO"</text></inputEntry>
        <inputEntry id="ie_n_16_2_nutrition_routing"><text>"ENTERAL"</text></inputEntry>
        <inputEntry id="ie_n_16_3_nutrition_routing"><text>"NEFROPATIA_DIALITICO"</text></inputEntry>
        <outputEntry id="oe_n_16_1_nutrition_routing"><text>"NE_ADULTO_NEFROPATIA_DIALITICO - Formula polimercia para doenca renal cronica em dialise, densidade &gt;=1,5 kcal/ml, proteina &gt;=15% VET, isenta gluten, baixo Na/K/P, apresentacao liquida"</text></outputEntry>
        <outputEntry id="oe_n_16_2_nutrition_routing"><text>500</text></outputEntry>
        <outputEntry id="oe_n_16_3_nutrition_routing"><text>1500</text></outputEntry>
      </rule>
      <!-- Rule 17: Neonatal enteral padrao -->
      <rule id="r_n_17_nutrition_routing">
        <description>Neonatal enteral formula infantil (Apendice VI)</description>
        <inputEntry id="ie_n_17_1_nutrition_routing"><text>"NEONATAL"</text></inputEntry>
        <inputEntry id="ie_n_17_2_nutrition_routing"><text>"ENTERAL"</text></inputEntry>
        <inputEntry id="ie_n_17_3_nutrition_routing"><text>"PADRAO"</text></inputEntry>
        <outputEntry id="oe_n_17_1_nutrition_routing"><text>"NE_NEONATAL_PADRAO - Formula infantil para neonatos, base leite de vaca, densidade calorica elevada &gt;=1 kcal/ml para prematuros, sem sacarose, isenta gluten, apresentacao po"</text></outputEntry>
        <outputEntry id="oe_n_17_2_nutrition_routing"><text>50</text></outputEntry>
        <outputEntry id="oe_n_17_3_nutrition_routing"><text>300</text></outputEntry>
      </rule>
      <!-- Catch-all -->
      <rule id="r_n_catchall_nutrition_routing">
        <description>Combinacao nao padronizada - requer avaliacao do nutricionista e autorizacao medico supervisor</description>
        <inputEntry id="ie_n_catchall_1_nutrition_routing"><text></text></inputEntry>
        <inputEntry id="ie_n_catchall_2_nutrition_routing"><text></text></inputEntry>
        <inputEntry id="ie_n_catchall_3_nutrition_routing"><text></text></inputEntry>
        <outputEntry id="oe_n_catchall_1_nutrition_routing"><text>"FORMULA_NAO_PADRONIZADA - Requer avaliacao nutricional e autorizacao medico supervisor SES/DF em ate 6h da prescricao (Contrato 4.3.7.5.11)"</text></outputEntry>
        <outputEntry id="oe_n_catchall_2_nutrition_routing"><text>0</text></outputEntry>
        <outputEntry id="oe_n_catchall_3_nutrition_routing"><text>0</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_nutrition_routing">
      <dmndi:DMNShape id="DMNShape_decision_nutrition_routing" dmnElementRef="decision_nutrition_routing">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
