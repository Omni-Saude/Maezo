<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="nutrition_enteral_pediatric_whitelist_def"
             name="Nutrition Enteral Pediatric Whitelist"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!--
    Whitelist de formulas enterais pediatricas conforme Apendice VI secoes 3 e 6.
    Secao 3: Formulas para terapia nutricional enteral infantil (5 itens)
    Secao 6: Formulas infantis (12 itens)
    Fonte: SES/SAIS/COASIS/DASIS/GESNUT 166054889
  -->
  <decision id="decision_nutrition_enteral_pediatric_whitelist" name="Nutrition Enteral Pediatric Whitelist" camunda:historyTimeToLive="180">
    <decisionTable id="dt_nutrition_enteral_pediatric_whitelist" hitPolicy="FIRST">
      <input id="in_code_nepw_nutrition_enteral_pediatric_whitelist" label="Code">
        <inputExpression id="inExpr_code_nepw_nutrition_enteral_pediatric_whitelist" typeRef="string">
          <text>code</text>
        </inputExpression>
      </input>
      <output id="out_authorized_nepw_nutrition_enteral_pediatric_whitelist" label="Authorized" name="authorized" typeRef="boolean"/>
      <output id="out_item_name_nepw_nutrition_enteral_pediatric_whitelist" label="Item Name" name="item_name" typeRef="string"/>
      <output id="out_ref_table_nepw_nutrition_enteral_pediatric_whitelist" label="Reference Table" name="reference_table" typeRef="string"/>
      <!-- Secao 3: Formulas enteral infantil -->
      <rule id="r_nepw_01_nutrition_enteral_pediatric_whitelist">
        <description>Padrao infantil 0 a 1 ano, base leite de vaca, po</description>
        <inputEntry id="ie_nepw_01_1_nutrition_enteral_pediatric_whitelist"><text>"NE_INFANTIL_0_1ANO"</text></inputEntry>
        <outputEntry id="oe_nepw_01_1_nutrition_enteral_pediatric_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_nepw_01_2_nutrition_enteral_pediatric_whitelist"><text>"Formula infantil para lactentes 0-1 ano, base leite de vaca, &gt;=1 kcal/ml, sem sacarose, isenta gluten, po"</text></outputEntry>
        <outputEntry id="oe_nepw_01_3_nutrition_enteral_pediatric_whitelist"><text>"Apendice VI - Enteral Infantil"</text></outputEntry>
      </rule>
      <rule id="r_nepw_02_nutrition_enteral_pediatric_whitelist">
        <description>Padrao infantil acima de 1 ano, polimerica, po</description>
        <inputEntry id="ie_nepw_02_1_nutrition_enteral_pediatric_whitelist"><text>"NE_PEDIATRICO_PADRAO_PO"</text></inputEntry>
        <outputEntry id="oe_nepw_02_1_nutrition_enteral_pediatric_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_nepw_02_2_nutrition_enteral_pediatric_whitelist"><text>"Formula pediatrica polimerica para criancas &lt;10 anos, isenta gluten, &gt;1 kcal/ml, &gt;=10% proteina, po"</text></outputEntry>
        <outputEntry id="oe_nepw_02_3_nutrition_enteral_pediatric_whitelist"><text>"Apendice VI - Enteral Infantil"</text></outputEntry>
      </rule>
      <rule id="r_nepw_03_nutrition_enteral_pediatric_whitelist">
        <description>Padrao infantil acima de 1 ano, sistema fechado</description>
        <inputEntry id="ie_nepw_03_1_nutrition_enteral_pediatric_whitelist"><text>"NE_PEDIATRICO_PADRAO_SF"</text></inputEntry>
        <outputEntry id="oe_nepw_03_1_nutrition_enteral_pediatric_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_nepw_03_2_nutrition_enteral_pediatric_whitelist"><text>"Formula pediatrica polimerica para criancas &lt;10 anos, isenta gluten, &gt;1 kcal/ml, sistema fechado, liquida"</text></outputEntry>
        <outputEntry id="oe_nepw_03_3_nutrition_enteral_pediatric_whitelist"><text>"Apendice VI - Enteral Infantil"</text></outputEntry>
      </rule>
      <rule id="r_nepw_04_nutrition_enteral_pediatric_whitelist">
        <description>Semielementar 1 a 10 anos, hidrolisada, po</description>
        <inputEntry id="ie_nepw_04_1_nutrition_enteral_pediatric_whitelist"><text>"NE_PEDIATRICO_SEMIELEMENTAR"</text></inputEntry>
        <outputEntry id="oe_nepw_04_1_nutrition_enteral_pediatric_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_nepw_04_2_nutrition_enteral_pediatric_whitelist"><text>"Formula hidrolisada pediatrica para sindromes disabsortivas 1-10 anos, isenta lactose/gluten, &gt;=1 kcal/ml, po"</text></outputEntry>
        <outputEntry id="oe_nepw_04_3_nutrition_enteral_pediatric_whitelist"><text>"Apendice VI - Enteral Infantil"</text></outputEntry>
      </rule>
      <rule id="r_nepw_05_nutrition_enteral_pediatric_whitelist">
        <description>Cetogenica para epilepsia refrataria, po</description>
        <inputEntry id="ie_nepw_05_1_nutrition_enteral_pediatric_whitelist"><text>"NE_PEDIATRICO_CETOGENICA"</text></inputEntry>
        <outputEntry id="oe_nepw_05_1_nutrition_enteral_pediatric_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_nepw_05_2_nutrition_enteral_pediatric_whitelist"><text>"Formula cetogenica pediatrica para epilepsia refrataria, proporcao 4g gordura:1g CHO+proteina, isenta gluten, po"</text></outputEntry>
        <outputEntry id="oe_nepw_05_3_nutrition_enteral_pediatric_whitelist"><text>"Apendice VI - Enteral Infantil"</text></outputEntry>
      </rule>
      <!-- Secao 6: Formulas infantis -->
      <rule id="r_nepw_06_nutrition_enteral_pediatric_whitelist">
        <description>Formula para prematuro, base leite de vaca, com LC-PUFAS, po</description>
        <inputEntry id="ie_nepw_06_1_nutrition_enteral_pediatric_whitelist"><text>"FI_PREMATURO"</text></inputEntry>
        <outputEntry id="oe_nepw_06_1_nutrition_enteral_pediatric_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_nepw_06_2_nutrition_enteral_pediatric_whitelist"><text>"Formula infantil para RN pre-termo e/ou alto risco, base leite de vaca, isenta sacarose/gluten, com LC-PUFAS, po"</text></outputEntry>
        <outputEntry id="oe_nepw_06_3_nutrition_enteral_pediatric_whitelist"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <rule id="r_nepw_07_nutrition_enteral_pediatric_whitelist">
        <description>Formula lactea ate 6 meses, base leite de vaca, po</description>
        <inputEntry id="ie_nepw_07_1_nutrition_enteral_pediatric_whitelist"><text>"FI_LACTEA_0_6M"</text></inputEntry>
        <outputEntry id="oe_nepw_07_1_nutrition_enteral_pediatric_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_nepw_07_2_nutrition_enteral_pediatric_whitelist"><text>"Formula infantil para lactentes 0-6 meses, base leite de vaca, com DHA/ARA, po"</text></outputEntry>
        <outputEntry id="oe_nepw_07_3_nutrition_enteral_pediatric_whitelist"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <rule id="r_nepw_08_nutrition_enteral_pediatric_whitelist">
        <description>Formula lactea apos 6 meses, base leite de vaca, po</description>
        <inputEntry id="ie_nepw_08_1_nutrition_enteral_pediatric_whitelist"><text>"FI_LACTEA_6M_PLUS"</text></inputEntry>
        <outputEntry id="oe_nepw_08_1_nutrition_enteral_pediatric_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_nepw_08_2_nutrition_enteral_pediatric_whitelist"><text>"Formula infantil de seguimento para lactentes &gt;6 meses, base leite de vaca, com DHA/ARA, po"</text></outputEntry>
        <outputEntry id="oe_nepw_08_3_nutrition_enteral_pediatric_whitelist"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <rule id="r_nepw_09_nutrition_enteral_pediatric_whitelist">
        <description>Formula de soja apos 6 meses, po</description>
        <inputEntry id="ie_nepw_09_1_nutrition_enteral_pediatric_whitelist"><text>"FI_SOJA_6M_PLUS"</text></inputEntry>
        <outputEntry id="oe_nepw_09_1_nutrition_enteral_pediatric_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_nepw_09_2_nutrition_enteral_pediatric_whitelist"><text>"Formula infantil de seguimento base soja para &gt;6 meses, sem sacarose, isenta gluten, po"</text></outputEntry>
        <outputEntry id="oe_nepw_09_3_nutrition_enteral_pediatric_whitelist"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <rule id="r_nepw_10_nutrition_enteral_pediatric_whitelist">
        <description>Formula para constipacao 0 a 6 meses, com prebioticos, po</description>
        <inputEntry id="ie_nepw_10_1_nutrition_enteral_pediatric_whitelist"><text>"FI_CONSTIPACAO_0_6M"</text></inputEntry>
        <outputEntry id="oe_nepw_10_1_nutrition_enteral_pediatric_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_nepw_10_2_nutrition_enteral_pediatric_whitelist"><text>"Formula infantil 0-6 meses com prebioticos FOS/GOS, isenta sacarose/gluten, po"</text></outputEntry>
        <outputEntry id="oe_nepw_10_3_nutrition_enteral_pediatric_whitelist"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <rule id="r_nepw_11_nutrition_enteral_pediatric_whitelist">
        <description>Formula para constipacao acima de 6 meses, com prebioticos, po</description>
        <inputEntry id="ie_nepw_11_1_nutrition_enteral_pediatric_whitelist"><text>"FI_CONSTIPACAO_6M_PLUS"</text></inputEntry>
        <outputEntry id="oe_nepw_11_1_nutrition_enteral_pediatric_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_nepw_11_2_nutrition_enteral_pediatric_whitelist"><text>"Formula infantil de seguimento &gt;6 meses com prebioticos FOS/GOS, isenta sacarose/gluten, po"</text></outputEntry>
        <outputEntry id="oe_nepw_11_3_nutrition_enteral_pediatric_whitelist"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <rule id="r_nepw_12_nutrition_enteral_pediatric_whitelist">
        <description>Formula anti-regurgitacao 0-12 meses, po</description>
        <inputEntry id="ie_nepw_12_1_nutrition_enteral_pediatric_whitelist"><text>"FI_ANTI_REGURGITACAO"</text></inputEntry>
        <outputEntry id="oe_nepw_12_1_nutrition_enteral_pediatric_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_nepw_12_2_nutrition_enteral_pediatric_whitelist"><text>"Formula infantil anti-regurgitacao 0-12 meses, com amido pre-gelatinizado ou gomas, isenta sacarose/gluten, po"</text></outputEntry>
        <outputEntry id="oe_nepw_12_3_nutrition_enteral_pediatric_whitelist"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <rule id="r_nepw_13_nutrition_enteral_pediatric_whitelist">
        <description>Formula semielementar com lactose, proteina extensamente hidrolisada, po</description>
        <inputEntry id="ie_nepw_13_1_nutrition_enteral_pediatric_whitelist"><text>"FI_SEMIELEMENTAR_COM_LACTOSE"</text></inputEntry>
        <outputEntry id="oe_nepw_13_1_nutrition_enteral_pediatric_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_nepw_13_2_nutrition_enteral_pediatric_whitelist"><text>"Formula infantil proteina extensamente hidrolisada de soro de leite, com lactose, sem sacarose/frutose, isenta gluten, po"</text></outputEntry>
        <outputEntry id="oe_nepw_13_3_nutrition_enteral_pediatric_whitelist"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <rule id="r_nepw_14_nutrition_enteral_pediatric_whitelist">
        <description>Formula semielementar sem lactose, proteina extensamente hidrolisada, po</description>
        <inputEntry id="ie_nepw_14_1_nutrition_enteral_pediatric_whitelist"><text>"FI_SEMIELEMENTAR_SEM_LACTOSE"</text></inputEntry>
        <outputEntry id="oe_nepw_14_1_nutrition_enteral_pediatric_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_nepw_14_2_nutrition_enteral_pediatric_whitelist"><text>"Formula infantil proteina extensamente hidrolisada de soro de leite, sem lactose/sacarose/frutose, isenta gluten, po"</text></outputEntry>
        <outputEntry id="oe_nepw_14_3_nutrition_enteral_pediatric_whitelist"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <rule id="r_nepw_15_nutrition_enteral_pediatric_whitelist">
        <description>Formula elementar base aminoacidos livres, po</description>
        <inputEntry id="ie_nepw_15_1_nutrition_enteral_pediatric_whitelist"><text>"FI_ELEMENTAR"</text></inputEntry>
        <outputEntry id="oe_nepw_15_1_nutrition_enteral_pediatric_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_nepw_15_2_nutrition_enteral_pediatric_whitelist"><text>"Formula infantil base aminoacidos livres para APLV, sem sacarose, isenta lactose/gluten, po"</text></outputEntry>
        <outputEntry id="oe_nepw_15_3_nutrition_enteral_pediatric_whitelist"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <rule id="r_nepw_16_nutrition_enteral_pediatric_whitelist">
        <description>Formula de nutrientes para neonatos alto risco, po</description>
        <inputEntry id="ie_nepw_16_1_nutrition_enteral_pediatric_whitelist"><text>"FI_NUTRIENTES_NEONATAL"</text></inputEntry>
        <outputEntry id="oe_nepw_16_1_nutrition_enteral_pediatric_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_nepw_16_2_nutrition_enteral_pediatric_whitelist"><text>"Formula de nutrientes para RN alto risco, maltodextrina, gorduras, proteina soro parcialmente hidrolisada, vitaminas/minerais, po"</text></outputEntry>
        <outputEntry id="oe_nepw_16_3_nutrition_enteral_pediatric_whitelist"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <rule id="r_nepw_17_nutrition_enteral_pediatric_whitelist">
        <description>Formula lactea sem lactose 0-12 meses, po</description>
        <inputEntry id="ie_nepw_17_1_nutrition_enteral_pediatric_whitelist"><text>"FI_SEM_LACTOSE"</text></inputEntry>
        <outputEntry id="oe_nepw_17_1_nutrition_enteral_pediatric_whitelist"><text>true</text></outputEntry>
        <outputEntry id="oe_nepw_17_2_nutrition_enteral_pediatric_whitelist"><text>"Formula infantil 0-12 meses sem lactose, base leite de vaca, isenta sacarose/lactose/gluten, po"</text></outputEntry>
        <outputEntry id="oe_nepw_17_3_nutrition_enteral_pediatric_whitelist"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <!-- Catch-all -->
      <rule id="r_nepw_catchall_nutrition_enteral_pediatric_whitelist">
        <description>Formula enteral pediatrica nao autorizada - requer analise do nutricionista</description>
        <inputEntry id="ie_nepw_catchall_1_nutrition_enteral_pediatric_whitelist"><text></text></inputEntry>
        <outputEntry id="oe_nepw_catchall_1_nutrition_enteral_pediatric_whitelist"><text>false</text></outputEntry>
        <outputEntry id="oe_nepw_catchall_2_nutrition_enteral_pediatric_whitelist"><text>"Formula nao encontrada no Apendice VI pediatrico/infantil - requer analise do nutricionista"</text></outputEntry>
        <outputEntry id="oe_nepw_catchall_3_nutrition_enteral_pediatric_whitelist"><text>"N/A"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_nutrition_enteral_pediatric_whitelist">
      <dmndi:DMNShape id="DMNShape_decision_nutrition_enteral_pediatric_whitelist" dmnElementRef="decision_nutrition_enteral_pediatric_whitelist">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
