<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="nutrition_enteral_pricing_def"
             name="Nutrition Enteral Pricing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!--
    Precificacao de formulas enterais por categoria e tipo de paciente.
    Valores de referencia (placeholder) conforme Apendice VI.
    Fonte: SES/SAIS/COASIS/DASIS/GESNUT 166054889
  -->
  <decision id="decision_nutrition_enteral_pricing" name="Nutrition Enteral Pricing" camunda:historyTimeToLive="180">
    <decisionTable id="dt_nutrition_enteral_pricing" hitPolicy="FIRST">
      <input id="in_item_code_nep_nutrition_enteral_pricing" label="Item Code">
        <inputExpression id="inExpr_item_code_nep_nutrition_enteral_pricing" typeRef="string">
          <text>item_code</text>
        </inputExpression>
      </input>
      <input id="in_patient_type_nep_nutrition_enteral_pricing" label="Patient Type">
        <inputExpression id="inExpr_patient_type_nep_nutrition_enteral_pricing" typeRef="string">
          <text>patient_type</text>
        </inputExpression>
      </input>
      <output id="out_unit_price_nep_nutrition_enteral_pricing" label="Unit Price" name="unit_price" typeRef="number"/>
      <output id="out_currency_nep_nutrition_enteral_pricing" label="Currency" name="currency" typeRef="string"/>
      <output id="out_pricing_table_nep_nutrition_enteral_pricing" label="Pricing Table" name="pricing_table" typeRef="string"/>
      <!-- ADULTO PADRAO -->
      <rule id="r_nep_01_nutrition_enteral_pricing">
        <description>Formula padrao adulto po</description>
        <inputEntry id="ie_nep_01_1_nutrition_enteral_pricing"><text>"NE_ADULTO_PADRAO_PO"</text></inputEntry>
        <inputEntry id="ie_nep_01_2_nutrition_enteral_pricing"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_nep_01_1_nutrition_enteral_pricing"><text>35.00</text></outputEntry>
        <outputEntry id="oe_nep_01_2_nutrition_enteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_01_3_nutrition_enteral_pricing"><text>"Apendice VI - Enteral Adulto Padrao"</text></outputEntry>
      </rule>
      <rule id="r_nep_02_nutrition_enteral_pricing">
        <description>Formula padrao adulto com fibras liquida</description>
        <inputEntry id="ie_nep_02_1_nutrition_enteral_pricing"><text>"NE_ADULTO_PADRAO_FIBRAS_LIQ"</text></inputEntry>
        <inputEntry id="ie_nep_02_2_nutrition_enteral_pricing"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_nep_02_1_nutrition_enteral_pricing"><text>42.00</text></outputEntry>
        <outputEntry id="oe_nep_02_2_nutrition_enteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_02_3_nutrition_enteral_pricing"><text>"Apendice VI - Enteral Adulto Padrao"</text></outputEntry>
      </rule>
      <rule id="r_nep_03_nutrition_enteral_pricing">
        <description>Formula hipercalorica adulto liquida</description>
        <inputEntry id="ie_nep_03_1_nutrition_enteral_pricing"><text>"NE_ADULTO_HIPERCALORICA_LIQ"</text></inputEntry>
        <inputEntry id="ie_nep_03_2_nutrition_enteral_pricing"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_nep_03_1_nutrition_enteral_pricing"><text>55.00</text></outputEntry>
        <outputEntry id="oe_nep_03_2_nutrition_enteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_03_3_nutrition_enteral_pricing"><text>"Apendice VI - Enteral Adulto Modificada"</text></outputEntry>
      </rule>
      <rule id="r_nep_04_nutrition_enteral_pricing">
        <description>Formula hiperproteica adulto liquida</description>
        <inputEntry id="ie_nep_04_1_nutrition_enteral_pricing"><text>"NE_ADULTO_HIPERPROTEICA_LIQ"</text></inputEntry>
        <inputEntry id="ie_nep_04_2_nutrition_enteral_pricing"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_nep_04_1_nutrition_enteral_pricing"><text>58.00</text></outputEntry>
        <outputEntry id="oe_nep_04_2_nutrition_enteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_04_3_nutrition_enteral_pricing"><text>"Apendice VI - Enteral Adulto Modificada"</text></outputEntry>
      </rule>
      <rule id="r_nep_05_nutrition_enteral_pricing">
        <description>Formula semielementar adulto liquida</description>
        <inputEntry id="ie_nep_05_1_nutrition_enteral_pricing"><text>"NE_ADULTO_SEMIELEMENTAR_LIQ"</text></inputEntry>
        <inputEntry id="ie_nep_05_2_nutrition_enteral_pricing"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_nep_05_1_nutrition_enteral_pricing"><text>75.00</text></outputEntry>
        <outputEntry id="oe_nep_05_2_nutrition_enteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_05_3_nutrition_enteral_pricing"><text>"Apendice VI - Enteral Adulto Modificada"</text></outputEntry>
      </rule>
      <!-- ADULTO ESPECIALIZADA -->
      <rule id="r_nep_06_nutrition_enteral_pricing">
        <description>Formula imunomoduladora adulto</description>
        <inputEntry id="ie_nep_06_1_nutrition_enteral_pricing"><text>"NE_ADULTO_IMUNOMODULADORA"</text></inputEntry>
        <inputEntry id="ie_nep_06_2_nutrition_enteral_pricing"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_nep_06_1_nutrition_enteral_pricing"><text>95.00</text></outputEntry>
        <outputEntry id="oe_nep_06_2_nutrition_enteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_06_3_nutrition_enteral_pricing"><text>"Apendice VI - Especializada Adulto"</text></outputEntry>
      </rule>
      <rule id="r_nep_07_nutrition_enteral_pricing">
        <description>Formula nefropatia dialitico adulto</description>
        <inputEntry id="ie_nep_07_1_nutrition_enteral_pricing"><text>"NE_ADULTO_NEFROPATIA_DIALITICO"</text></inputEntry>
        <inputEntry id="ie_nep_07_2_nutrition_enteral_pricing"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_nep_07_1_nutrition_enteral_pricing"><text>88.00</text></outputEntry>
        <outputEntry id="oe_nep_07_2_nutrition_enteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_07_3_nutrition_enteral_pricing"><text>"Apendice VI - Especializada Adulto"</text></outputEntry>
      </rule>
      <rule id="r_nep_08_nutrition_enteral_pricing">
        <description>Formula lesao por pressao adulto</description>
        <inputEntry id="ie_nep_08_1_nutrition_enteral_pricing"><text>"NE_ADULTO_LESAO_PRESSAO"</text></inputEntry>
        <inputEntry id="ie_nep_08_2_nutrition_enteral_pricing"><text>"ADULTO"</text></inputEntry>
        <outputEntry id="oe_nep_08_1_nutrition_enteral_pricing"><text>82.00</text></outputEntry>
        <outputEntry id="oe_nep_08_2_nutrition_enteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_08_3_nutrition_enteral_pricing"><text>"Apendice VI - Especializada Adulto"</text></outputEntry>
      </rule>
      <!-- PEDIATRICO -->
      <rule id="r_nep_09_nutrition_enteral_pricing">
        <description>Formula padrao infantil 0-1 ano</description>
        <inputEntry id="ie_nep_09_1_nutrition_enteral_pricing"><text>"NE_INFANTIL_0_1ANO"</text></inputEntry>
        <inputEntry id="ie_nep_09_2_nutrition_enteral_pricing"><text>"PEDIATRICO"</text></inputEntry>
        <outputEntry id="oe_nep_09_1_nutrition_enteral_pricing"><text>45.00</text></outputEntry>
        <outputEntry id="oe_nep_09_2_nutrition_enteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_09_3_nutrition_enteral_pricing"><text>"Apendice VI - Enteral Infantil"</text></outputEntry>
      </rule>
      <rule id="r_nep_10_nutrition_enteral_pricing">
        <description>Formula padrao pediatrica acima 1 ano</description>
        <inputEntry id="ie_nep_10_1_nutrition_enteral_pricing"><text>"NE_PEDIATRICO_PADRAO_PO"</text></inputEntry>
        <inputEntry id="ie_nep_10_2_nutrition_enteral_pricing"><text>"PEDIATRICO"</text></inputEntry>
        <outputEntry id="oe_nep_10_1_nutrition_enteral_pricing"><text>48.00</text></outputEntry>
        <outputEntry id="oe_nep_10_2_nutrition_enteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_10_3_nutrition_enteral_pricing"><text>"Apendice VI - Enteral Infantil"</text></outputEntry>
      </rule>
      <rule id="r_nep_11_nutrition_enteral_pricing">
        <description>Formula cetogenica pediatrica</description>
        <inputEntry id="ie_nep_11_1_nutrition_enteral_pricing"><text>"NE_PEDIATRICO_CETOGENICA"</text></inputEntry>
        <inputEntry id="ie_nep_11_2_nutrition_enteral_pricing"><text>"PEDIATRICO"</text></inputEntry>
        <outputEntry id="oe_nep_11_1_nutrition_enteral_pricing"><text>120.00</text></outputEntry>
        <outputEntry id="oe_nep_11_2_nutrition_enteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_11_3_nutrition_enteral_pricing"><text>"Apendice VI - Enteral Infantil Especializada"</text></outputEntry>
      </rule>
      <!-- NEONATAL -->
      <rule id="r_nep_12_nutrition_enteral_pricing">
        <description>Formula prematuro neonatal</description>
        <inputEntry id="ie_nep_12_1_nutrition_enteral_pricing"><text>"FI_PREMATURO"</text></inputEntry>
        <inputEntry id="ie_nep_12_2_nutrition_enteral_pricing"><text>"NEONATAL"</text></inputEntry>
        <outputEntry id="oe_nep_12_1_nutrition_enteral_pricing"><text>65.00</text></outputEntry>
        <outputEntry id="oe_nep_12_2_nutrition_enteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_12_3_nutrition_enteral_pricing"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <rule id="r_nep_13_nutrition_enteral_pricing">
        <description>Formula elementar base aminoacidos livres</description>
        <inputEntry id="ie_nep_13_1_nutrition_enteral_pricing"><text>"FI_ELEMENTAR"</text></inputEntry>
        <inputEntry id="ie_nep_13_2_nutrition_enteral_pricing"><text>"NEONATAL"</text></inputEntry>
        <outputEntry id="oe_nep_13_1_nutrition_enteral_pricing"><text>135.00</text></outputEntry>
        <outputEntry id="oe_nep_13_2_nutrition_enteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_13_3_nutrition_enteral_pricing"><text>"Apendice VI - Formulas Infantis Especializada"</text></outputEntry>
      </rule>
      <rule id="r_nep_14_nutrition_enteral_pricing">
        <description>Formula nutrientes para RN alto risco</description>
        <inputEntry id="ie_nep_14_1_nutrition_enteral_pricing"><text>"FI_NUTRIENTES_NEONATAL"</text></inputEntry>
        <inputEntry id="ie_nep_14_2_nutrition_enteral_pricing"><text>"NEONATAL"</text></inputEntry>
        <outputEntry id="oe_nep_14_1_nutrition_enteral_pricing"><text>55.00</text></outputEntry>
        <outputEntry id="oe_nep_14_2_nutrition_enteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_14_3_nutrition_enteral_pricing"><text>"Apendice VI - Formulas Infantis"</text></outputEntry>
      </rule>
      <!-- Catch-all -->
      <rule id="r_nep_catchall_nutrition_enteral_pricing">
        <description>Item nao encontrado - preco nao disponivel</description>
        <inputEntry id="ie_nep_catchall_1_nutrition_enteral_pricing"><text></text></inputEntry>
        <inputEntry id="ie_nep_catchall_2_nutrition_enteral_pricing"><text></text></inputEntry>
        <outputEntry id="oe_nep_catchall_1_nutrition_enteral_pricing"><text>0</text></outputEntry>
        <outputEntry id="oe_nep_catchall_2_nutrition_enteral_pricing"><text>"BRL"</text></outputEntry>
        <outputEntry id="oe_nep_catchall_3_nutrition_enteral_pricing"><text>"N/A - Requer cotacao manual"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_nutrition_enteral_pricing">
      <dmndi:DMNShape id="DMNShape_decision_nutrition_enteral_pricing" dmnElementRef="decision_nutrition_enteral_pricing">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
