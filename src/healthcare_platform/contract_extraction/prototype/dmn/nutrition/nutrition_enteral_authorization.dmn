<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="nutrition_enteral_authorization_def"
             name="Nutrition Enteral Authorization"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!--
    Regras de autorizacao para terapia nutricional enteral.
    Contrato 4.3.7.5.11: nutricao requer autorizacao em ate 6h da prescricao.
    Reavaliacao a cada 72h ou troca de tipo de terapia.
    Formulas especializadas requerem aprovacao supervisor.
    Fonte: SES/SAIS/COASIS/DASIS/GESNUT 166054889
  -->
  <decision id="decision_nutrition_enteral_authorization" name="Nutrition Enteral Authorization" camunda:historyTimeToLive="180">
    <decisionTable id="dt_nutrition_enteral_authorization" hitPolicy="FIRST">
      <input id="in_proc_code_nea_nutrition_enteral_authorization" label="Procedure Code">
        <inputExpression id="inExpr_proc_code_nea_nutrition_enteral_authorization" typeRef="string">
          <text>procedure_code</text>
        </inputExpression>
      </input>
      <input id="in_amount_nea_nutrition_enteral_authorization" label="Amount">
        <inputExpression id="inExpr_amount_nea_nutrition_enteral_authorization" typeRef="number">
          <text>amount</text>
        </inputExpression>
      </input>
      <input id="in_payer_id_nea_nutrition_enteral_authorization" label="Payer ID">
        <inputExpression id="inExpr_payer_id_nea_nutrition_enteral_authorization" typeRef="string">
          <text>payer_id</text>
        </inputExpression>
      </input>
      <output id="out_requires_auth_nea_nutrition_enteral_authorization" label="Requires Auth" name="requires_auth" typeRef="boolean"/>
      <output id="out_auth_type_nea_nutrition_enteral_authorization" label="Auth Type" name="auth_type" typeRef="string"/>
      <output id="out_urgency_nea_nutrition_enteral_authorization" label="Urgency Level" name="urgency_level" typeRef="string"/>
      <!-- Formulas especializadas alto custo - pre-autorizacao obrigatoria -->
      <rule id="r_nea_01_nutrition_enteral_authorization">
        <description>Formula imunomoduladora - requer pre-autorizacao supervisor</description>
        <inputEntry id="ie_nea_01_1_nutrition_enteral_authorization"><text>"NE_ADULTO_IMUNOMODULADORA"</text></inputEntry>
        <inputEntry id="ie_nea_01_2_nutrition_enteral_authorization"><text></text></inputEntry>
        <inputEntry id="ie_nea_01_3_nutrition_enteral_authorization"><text></text></inputEntry>
        <outputEntry id="oe_nea_01_1_nutrition_enteral_authorization"><text>true</text></outputEntry>
        <outputEntry id="oe_nea_01_2_nutrition_enteral_authorization"><text>"PRE_AUTORIZACAO_SUPERVISOR"</text></outputEntry>
        <outputEntry id="oe_nea_01_3_nutrition_enteral_authorization"><text>"URGENTE_6H"</text></outputEntry>
      </rule>
      <rule id="r_nea_02_nutrition_enteral_authorization">
        <description>Formula para DII - requer pre-autorizacao supervisor</description>
        <inputEntry id="ie_nea_02_1_nutrition_enteral_authorization"><text>"NE_ADULTO_DII"</text></inputEntry>
        <inputEntry id="ie_nea_02_2_nutrition_enteral_authorization"><text></text></inputEntry>
        <inputEntry id="ie_nea_02_3_nutrition_enteral_authorization"><text></text></inputEntry>
        <outputEntry id="oe_nea_02_1_nutrition_enteral_authorization"><text>true</text></outputEntry>
        <outputEntry id="oe_nea_02_2_nutrition_enteral_authorization"><text>"PRE_AUTORIZACAO_SUPERVISOR"</text></outputEntry>
        <outputEntry id="oe_nea_02_3_nutrition_enteral_authorization"><text>"URGENTE_6H"</text></outputEntry>
      </rule>
      <rule id="r_nea_03_nutrition_enteral_authorization">
        <description>Formula nefropatia dialitico - requer pre-autorizacao</description>
        <inputEntry id="ie_nea_03_1_nutrition_enteral_authorization"><text>"NE_ADULTO_NEFROPATIA_DIALITICO"</text></inputEntry>
        <inputEntry id="ie_nea_03_2_nutrition_enteral_authorization"><text></text></inputEntry>
        <inputEntry id="ie_nea_03_3_nutrition_enteral_authorization"><text></text></inputEntry>
        <outputEntry id="oe_nea_03_1_nutrition_enteral_authorization"><text>true</text></outputEntry>
        <outputEntry id="oe_nea_03_2_nutrition_enteral_authorization"><text>"PRE_AUTORIZACAO_SUPERVISOR"</text></outputEntry>
        <outputEntry id="oe_nea_03_3_nutrition_enteral_authorization"><text>"URGENTE_6H"</text></outputEntry>
      </rule>
      <rule id="r_nea_04_nutrition_enteral_authorization">
        <description>Formula nefropatia conservador - requer pre-autorizacao</description>
        <inputEntry id="ie_nea_04_1_nutrition_enteral_authorization"><text>"NE_ADULTO_NEFROPATIA_CONSERVADOR"</text></inputEntry>
        <inputEntry id="ie_nea_04_2_nutrition_enteral_authorization"><text></text></inputEntry>
        <inputEntry id="ie_nea_04_3_nutrition_enteral_authorization"><text></text></inputEntry>
        <outputEntry id="oe_nea_04_1_nutrition_enteral_authorization"><text>true</text></outputEntry>
        <outputEntry id="oe_nea_04_2_nutrition_enteral_authorization"><text>"PRE_AUTORIZACAO_SUPERVISOR"</text></outputEntry>
        <outputEntry id="oe_nea_04_3_nutrition_enteral_authorization"><text>"URGENTE_6H"</text></outputEntry>
      </rule>
      <rule id="r_nea_05_nutrition_enteral_authorization">
        <description>Formula cetogenica pediatrica - requer pre-autorizacao neuropediatria</description>
        <inputEntry id="ie_nea_05_1_nutrition_enteral_authorization"><text>"NE_PEDIATRICO_CETOGENICA"</text></inputEntry>
        <inputEntry id="ie_nea_05_2_nutrition_enteral_authorization"><text></text></inputEntry>
        <inputEntry id="ie_nea_05_3_nutrition_enteral_authorization"><text></text></inputEntry>
        <outputEntry id="oe_nea_05_1_nutrition_enteral_authorization"><text>true</text></outputEntry>
        <outputEntry id="oe_nea_05_2_nutrition_enteral_authorization"><text>"PRE_AUTORIZACAO_NEUROPEDIATRIA"</text></outputEntry>
        <outputEntry id="oe_nea_05_3_nutrition_enteral_authorization"><text>"URGENTE_6H"</text></outputEntry>
      </rule>
      <rule id="r_nea_06_nutrition_enteral_authorization">
        <description>Formula elementar (aminoacidos livres) - requer pre-autorizacao alergista</description>
        <inputEntry id="ie_nea_06_1_nutrition_enteral_authorization"><text>"FI_ELEMENTAR"</text></inputEntry>
        <inputEntry id="ie_nea_06_2_nutrition_enteral_authorization"><text></text></inputEntry>
        <inputEntry id="ie_nea_06_3_nutrition_enteral_authorization"><text></text></inputEntry>
        <outputEntry id="oe_nea_06_1_nutrition_enteral_authorization"><text>true</text></outputEntry>
        <outputEntry id="oe_nea_06_2_nutrition_enteral_authorization"><text>"PRE_AUTORIZACAO_ALERGISTA"</text></outputEntry>
        <outputEntry id="oe_nea_06_3_nutrition_enteral_authorization"><text>"URGENTE_6H"</text></outputEntry>
      </rule>
      <!-- Formulas padrao com valor alto - requer autorizacao por valor -->
      <rule id="r_nea_07_nutrition_enteral_authorization">
        <description>Qualquer formula enteral com valor acima de 5000 BRL - requer autorizacao financeira</description>
        <inputEntry id="ie_nea_07_1_nutrition_enteral_authorization"><text></text></inputEntry>
        <inputEntry id="ie_nea_07_2_nutrition_enteral_authorization"><text>&gt; 5000</text></inputEntry>
        <inputEntry id="ie_nea_07_3_nutrition_enteral_authorization"><text></text></inputEntry>
        <outputEntry id="oe_nea_07_1_nutrition_enteral_authorization"><text>true</text></outputEntry>
        <outputEntry id="oe_nea_07_2_nutrition_enteral_authorization"><text>"AUTORIZACAO_FINANCEIRA"</text></outputEntry>
        <outputEntry id="oe_nea_07_3_nutrition_enteral_authorization"><text>"NORMAL_24H"</text></outputEntry>
      </rule>
      <!-- Formulas padrao dentro do limite - autorizacao automatica -->
      <rule id="r_nea_08_nutrition_enteral_authorization">
        <description>Formula padrao adulto dentro do limite - autorizacao automatica em 6h</description>
        <inputEntry id="ie_nea_08_1_nutrition_enteral_authorization"><text></text></inputEntry>
        <inputEntry id="ie_nea_08_2_nutrition_enteral_authorization"><text>&lt;= 5000</text></inputEntry>
        <inputEntry id="ie_nea_08_3_nutrition_enteral_authorization"><text>"SES_DF"</text></inputEntry>
        <outputEntry id="oe_nea_08_1_nutrition_enteral_authorization"><text>true</text></outputEntry>
        <outputEntry id="oe_nea_08_2_nutrition_enteral_authorization"><text>"AUTORIZACAO_AUTOMATICA"</text></outputEntry>
        <outputEntry id="oe_nea_08_3_nutrition_enteral_authorization"><text>"URGENTE_6H"</text></outputEntry>
      </rule>
      <!-- Catch-all -->
      <rule id="r_nea_catchall_nutrition_enteral_authorization">
        <description>Caso nao coberto - requer avaliacao manual do gestor de contratos</description>
        <inputEntry id="ie_nea_catchall_1_nutrition_enteral_authorization"><text></text></inputEntry>
        <inputEntry id="ie_nea_catchall_2_nutrition_enteral_authorization"><text></text></inputEntry>
        <inputEntry id="ie_nea_catchall_3_nutrition_enteral_authorization"><text></text></inputEntry>
        <outputEntry id="oe_nea_catchall_1_nutrition_enteral_authorization"><text>true</text></outputEntry>
        <outputEntry id="oe_nea_catchall_2_nutrition_enteral_authorization"><text>"AVALIACAO_MANUAL"</text></outputEntry>
        <outputEntry id="oe_nea_catchall_3_nutrition_enteral_authorization"><text>"NORMAL_24H"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_nutrition_enteral_authorization">
      <dmndi:DMNShape id="DMNShape_decision_nutrition_enteral_authorization" dmnElementRef="decision_nutrition_enteral_authorization">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
