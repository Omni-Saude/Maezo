<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  PRIOR-TRACK-005 - Rastreamento Recurso em Andamento
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: PRIOR-TRACK
  Perspectiva: HOSPITAL (Faturamento/Auditoria)

  ============================================================================
  INDICACOES (Quando PROSSEGUIR):
  ============================================================================
  - Recurso em andamento com prazo adequado
  - Instancia de recurso apropriada
  - Documentacao completa

  ============================================================================
  CONTRAINDICACOES (Quando BLOQUEAR):
  ============================================================================
  - Recurso com prazo excedido
  - Falta documentacao complementar
  - Instancia inadequada

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - RN 424/2017 (Autorizacao Previa)
  - RN 389/2015 (Direito ao Recurso - Prazos)
  - RN 465/2021 (Procedimentos Regulados)
  - Lei 9.656/1998 Art. 12 (Cobertura Obrigatoria)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_PRIOR_TRACK_005"
             name="Rastreamento Recurso em Andamento"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_PRIOR_TRACK_005" name="[SP-PA-004 | authorization/track] Verificar Rastreamento Recurso em Andamento" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_PRIOR_TRACK_005" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_PRIOR_TRACK_005" label="Tem Recurso Aberto">
        <inputExpression id="InputExpression_1_PRIOR_TRACK_005" typeRef="boolean">
          <text>temRecursoAberto</text>
        </inputExpression>
      </input>

      <input id="Input_2_PRIOR_TRACK_005" label="Dias Recurso">
        <inputExpression id="InputExpression_2_PRIOR_TRACK_005" typeRef="integer">
          <text>diasRecurso</text>
        </inputExpression>
      </input>

      <input id="Input_3_PRIOR_TRACK_005" label="Instancia Recurso">
        <inputExpression id="InputExpression_3_PRIOR_TRACK_005" typeRef="string">
          <text>instanciaRecurso</text>
        </inputExpression>
        <inputValues id="InputValues_3_PRIOR_TRACK_005">
          <text>"1A", "2A", "ANS"</text>
        </inputValues>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_PRIOR_TRACK_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_PRIOR_TRACK_005" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_PRIOR_TRACK_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_PRIOR_TRACK_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_PRIOR_TRACK_005" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA B1: Bloqueio - Recurso ANS com prazo excedido -->
      <rule id="Rule_Bloqueio_1_PRIOR_TRACK_005">
        <description>Recurso na ANS ha mais de 60 dias sem resposta</description>
        <inputEntry id="InputEntry_B1_1_PRIOR_TRACK_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_PRIOR_TRACK_005"><text>&gt; 60</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_PRIOR_TRACK_005"><text>"ANS"</text></inputEntry>
        <outputEntry id="OutputEntry_B1_1_PRIOR_TRACK_005"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_2_PRIOR_TRACK_005"><text>"Recurso na ANS ha mais de 60 dias sem resposta. Prazo critico excedido."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_3_PRIOR_TRACK_005"><text>"Contatar ANS para obter posicionamento. Considerar acoes judiciais se necessario."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_4_PRIOR_TRACK_005"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_5_PRIOR_TRACK_005"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA B2: Bloqueio - Sem recurso aberto -->
      <rule id="Rule_Bloqueio_2_PRIOR_TRACK_005">
        <description>Nao ha recurso aberto para acompanhamento</description>
        <inputEntry id="InputEntry_B2_1_PRIOR_TRACK_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_PRIOR_TRACK_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_PRIOR_TRACK_005"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B2_1_PRIOR_TRACK_005"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_2_PRIOR_TRACK_005"><text>"Nao ha recurso aberto para rastreamento. Regra nao se aplica."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_3_PRIOR_TRACK_005"><text>"Verificar necessidade de interpor recurso ou aplicar regra correspondente."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_4_PRIOR_TRACK_005"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_5_PRIOR_TRACK_005"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA A1: Alerta - Recurso 2a instancia com prazo longo -->
      <rule id="Rule_Alerta_1_PRIOR_TRACK_005">
        <description>Recurso em 2a instancia ha mais de 30 dias</description>
        <inputEntry id="InputEntry_A1_1_PRIOR_TRACK_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_PRIOR_TRACK_005"><text>&gt; 30</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_PRIOR_TRACK_005"><text>"2A"</text></inputEntry>
        <outputEntry id="OutputEntry_A1_1_PRIOR_TRACK_005"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_2_PRIOR_TRACK_005"><text>"Recurso em 2a instancia ha mais de 30 dias. Acompanhamento necessario."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_3_PRIOR_TRACK_005"><text>"Contatar operadora para obter status do recurso. Preparar documentacao para ANS se negado."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_4_PRIOR_TRACK_005"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_5_PRIOR_TRACK_005"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA A2: Alerta - Recurso 1a instancia com prazo longo -->
      <rule id="Rule_Alerta_2_PRIOR_TRACK_005">
        <description>Recurso em 1a instancia ha mais de 15 dias</description>
        <inputEntry id="InputEntry_A2_1_PRIOR_TRACK_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_PRIOR_TRACK_005"><text>&gt; 15</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_PRIOR_TRACK_005"><text>"1A"</text></inputEntry>
        <outputEntry id="OutputEntry_A2_1_PRIOR_TRACK_005"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A2_2_PRIOR_TRACK_005"><text>"Recurso em 1a instancia ha mais de 15 dias. Monitoramento necessario."</text></outputEntry>
        <outputEntry id="OutputEntry_A2_3_PRIOR_TRACK_005"><text>"Contatar operadora para agilizar resposta. Verificar se ha documentacao complementar pendente."</text></outputEntry>
        <outputEntry id="OutputEntry_A2_4_PRIOR_TRACK_005"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_A2_5_PRIOR_TRACK_005"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA P1: Aprovado - Recurso recente -->
      <rule id="Rule_Aprovado_1_PRIOR_TRACK_005">
        <description>Recurso em andamento com prazo adequado</description>
        <inputEntry id="InputEntry_P1_1_PRIOR_TRACK_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_PRIOR_TRACK_005"><text>&lt;= 15</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_PRIOR_TRACK_005"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_PRIOR_TRACK_005"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_2_PRIOR_TRACK_005"><text>"Recurso em andamento com prazo adequado para resposta."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_3_PRIOR_TRACK_005"><text>"Aguardar resposta da instancia de recurso. Monitorar prazo."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_4_PRIOR_TRACK_005"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_5_PRIOR_TRACK_005"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisao manual -->
      <rule id="Rule_Fallback_PRIOR_TRACK_005">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_PRIOR_TRACK_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_PRIOR_TRACK_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_PRIOR_TRACK_005"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_PRIOR_TRACK_005"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_PRIOR_TRACK_005"><text>"Situacao de recurso em andamento requer analise manual."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_PRIOR_TRACK_005"><text>"Encaminhar para auditoria verificar status do recurso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_PRIOR_TRACK_005"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_PRIOR_TRACK_005"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PRIOR_TRACK_005">
      <dmndi:DMNShape id="DMNShape_Decision_PRIOR_TRACK_005" dmnElementRef="Decision_PRIOR_TRACK_005">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
