<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-EXTENSION-003 - Extensao Prazo Vencimento
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-EXTENSION
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_EXTENSION_003" name="Extensao Prazo Vencimento" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_EXTENSION_003" name="[SP-PA-004 | authorization/extension] Avaliar Extensao de Prazo de Vencimento" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_EXTENSION_003" hitPolicy="FIRST">

      <input id="Input_1_AUTH_EXTENSION_003" label="Dias Restantes">
        <inputExpression id="InputExpression_1_AUTH_EXTENSION_003" typeRef="number">
          <text>diasRestantes</text>
        </inputExpression>
      </input>

      <input id="Input_2_AUTH_EXTENSION_003" label="Motivo Extensao">
        <inputExpression id="InputExpression_2_AUTH_EXTENSION_003" typeRef="string">
          <text>motivoExtensao</text>
        </inputExpression>
        <inputValues id="InputValues_2_AUTH_EXTENSION_003">
          <text>"INTERCORRENCIA", "ATRASO_OPERADORA", "COMPLEMENTACAO", "REAGENDAMENTO", "OUTRO"</text>
        </inputValues>
      </input>

      <input id="Input_3_AUTH_EXTENSION_003" label="Aprovacao Gerencia">
        <inputExpression id="InputExpression_3_AUTH_EXTENSION_003" typeRef="boolean">
          <text>aprovacaoGerencia</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_AUTH_EXTENSION_003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_AUTH_EXTENSION_003" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_AUTH_EXTENSION_003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_AUTH_EXTENSION_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_AUTH_EXTENSION_003" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloqueio_1_AUTH_EXTENSION_003">
        <description>Extensao prematura sem justificativa gerencial</description>
        <inputEntry id="InputEntry_B1_1_AUTH_EXTENSION_003"><text>&gt; 30</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_EXTENSION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_EXTENSION_003"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_AUTH_EXTENSION_003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_AUTH_EXTENSION_003"><text>"Extensao solicitada com mais de 30 dias restantes sem aprovacao gerencial."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_AUTH_EXTENSION_003"><text>"Aguardar prazo se aproximar ou obter aprovacao gerencial para extensao antecipada."</text></outputEntry>
<outputEntry id="Rule_Bloqueio_1_outputEntry_alertasConformidade_AUTH_EXTENSION_003"><text>"PRAZO"</text></outputEntry>
<outputEntry id="Rule_Bloqueio_1_outputEntry_riscoDenial_AUTH_EXTENSION_003"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloqueio_2_AUTH_EXTENSION_003">
        <description>Extensao sem motivo justificado</description>
        <inputEntry id="InputEntry_B2_1_AUTH_EXTENSION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_AUTH_EXTENSION_003"><text>"OUTRO"</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_AUTH_EXTENSION_003"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_AUTH_EXTENSION_003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_AUTH_EXTENSION_003"><text>"Motivo de extensao nao especificado ou invalido."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_AUTH_EXTENSION_003"><text>"Especificar motivo valido ou obter aprovacao gerencial."</text></outputEntry>
<outputEntry id="Rule_Bloqueio_2_outputEntry_alertasConformidade_AUTH_EXTENSION_003"><text>"PRAZO"</text></outputEntry>
<outputEntry id="Rule_Bloqueio_2_outputEntry_riscoDenial_AUTH_EXTENSION_003"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alerta_1_AUTH_EXTENSION_003">
        <description>Prazo de vencimento critico</description>
        <inputEntry id="InputEntry_A1_1_AUTH_EXTENSION_003"><text>&lt; 15</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_EXTENSION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_EXTENSION_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_AUTH_EXTENSION_003"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_AUTH_EXTENSION_003"><text>"Autorizacao com menos de 15 dias para vencimento. Acao urgente necessaria."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_AUTH_EXTENSION_003"><text>"Priorizar solicitacao de extensao junto a operadora."</text></outputEntry>
<outputEntry id="Rule_Alerta_1_outputEntry_alertasConformidade_AUTH_EXTENSION_003"><text>"PRAZO"</text></outputEntry>
<outputEntry id="Rule_Alerta_1_outputEntry_riscoDenial_AUTH_EXTENSION_003"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_AUTH_EXTENSION_003">
        <description>Extensao por intercorrencia medica</description>
        <inputEntry id="InputEntry_P1_1_AUTH_EXTENSION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_AUTH_EXTENSION_003"><text>"INTERCORRENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_AUTH_EXTENSION_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_AUTH_EXTENSION_003"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_AUTH_EXTENSION_003"><text>"Extensao por intercorrencia medica aprovada automaticamente."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_AUTH_EXTENSION_003"><text>"Prosseguir com solicitacao de extensao junto a operadora."</text></outputEntry>
<outputEntry id="Rule_Prosseguir_1_outputEntry_alertasConformidade_AUTH_EXTENSION_003"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Prosseguir_1_outputEntry_riscoDenial_AUTH_EXTENSION_003"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_2_AUTH_EXTENSION_003">
        <description>Extensao por atraso da operadora</description>
        <inputEntry id="InputEntry_P2_1_AUTH_EXTENSION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_AUTH_EXTENSION_003"><text>"ATRASO_OPERADORA"</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_AUTH_EXTENSION_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_AUTH_EXTENSION_003"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_AUTH_EXTENSION_003"><text>"Extensao por atraso da operadora. Registrar protocolo de reclamacao."</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_AUTH_EXTENSION_003"><text>"Protocolar reclamacao e solicitar extensao automatica."</text></outputEntry>
<outputEntry id="Rule_Prosseguir_2_outputEntry_alertasConformidade_AUTH_EXTENSION_003"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Prosseguir_2_outputEntry_riscoDenial_AUTH_EXTENSION_003"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_3_AUTH_EXTENSION_003">
        <description>Extensao aprovada pela gerencia</description>
        <inputEntry id="InputEntry_P3_1_AUTH_EXTENSION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P3_2_AUTH_EXTENSION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P3_3_AUTH_EXTENSION_003"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P3_1_AUTH_EXTENSION_003"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P3_2_AUTH_EXTENSION_003"><text>"Extensao aprovada pela gerencia. Prosseguir com solicitacao."</text></outputEntry>
<outputEntry id="OutputEntry_P3_3_AUTH_EXTENSION_003"><text>"Registrar aprovacao gerencial e solicitar extensao."</text></outputEntry>
<outputEntry id="Rule_Prosseguir_3_outputEntry_alertasConformidade_AUTH_EXTENSION_003"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Prosseguir_3_outputEntry_riscoDenial_AUTH_EXTENSION_003"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_AUTH_EXTENSION_003">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_EXTENSION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_EXTENSION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_EXTENSION_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_AUTH_EXTENSION_003"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_AUTH_EXTENSION_003"><text>"Extensao de prazo requer analise manual."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_AUTH_EXTENSION_003"><text>"Encaminhar para gerencia avaliar necessidade de extensao."</text></outputEntry>
<outputEntry id="Rule_Fallback_AUTH_EXTENSION_003_outputEntry_alertasConformidade"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Fallback_AUTH_EXTENSION_003_outputEntry_riscoDenial"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_EXTENSION_003">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_EXTENSION_003" dmnElementRef="Decision_AUTH_EXTENSION_003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>