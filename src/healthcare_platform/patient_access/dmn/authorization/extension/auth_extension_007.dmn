<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-EXTENSION-007 - Extensao Transplante
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-EXTENSION
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_EXTENSION_007" name="Extensao Transplante" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_EXTENSION_007" name="[SP-PA-004 | authorization/extension] Avaliar Extensao de Acompanhamento de Transplante" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_EXTENSION_007" hitPolicy="FIRST">

      <input id="Input_1_AUTH_EXTENSION_007" label="Tipo Transplante">
        <inputExpression id="InputExpression_1_AUTH_EXTENSION_007" typeRef="string">
          <text>tipoTransplante</text>
        </inputExpression>
        <inputValues id="InputValues_1_AUTH_EXTENSION_007">
          <text>"RENAL", "HEPATICO", "CARDIACO", "MEDULA", "CORNEA", "OUTRO"</text>
        </inputValues>
      </input>

      <input id="Input_2_AUTH_EXTENSION_007" label="Fase Acompanhamento">
        <inputExpression id="InputExpression_2_AUTH_EXTENSION_007" typeRef="string">
          <text>faseAcompanhamento</text>
        </inputExpression>
        <inputValues id="InputValues_2_AUTH_EXTENSION_007">
          <text>"IMEDIATA", "PRECOCE", "TARDIA", "MANUTENCAO"</text>
        </inputValues>
      </input>

      <input id="Input_3_AUTH_EXTENSION_007" label="Complicacoes">
        <inputExpression id="InputExpression_3_AUTH_EXTENSION_007" typeRef="boolean">
          <text>complicacoes</text>
        </inputExpression>
      </input>

      <input id="Input_4_AUTH_EXTENSION_007" label="Justificativa Extensao">
        <inputExpression id="InputExpression_4_AUTH_EXTENSION_007" typeRef="boolean">
          <text>justificativaExtensao</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_AUTH_EXTENSION_007" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_AUTH_EXTENSION_007" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_AUTH_EXTENSION_007" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_AUTH_EXTENSION_007" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_AUTH_EXTENSION_007" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloqueio_1_AUTH_EXTENSION_007">
        <description>Fase imediata requer justificativa para extensao</description>
        <inputEntry id="InputEntry_B1_1_AUTH_EXTENSION_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_EXTENSION_007"><text>"IMEDIATA"</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_EXTENSION_007"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_AUTH_EXTENSION_007"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_AUTH_EXTENSION_007"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_AUTH_EXTENSION_007"><text>"Fase imediata de transplante sem justificativa para extensao."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_AUTH_EXTENSION_007"><text>"Documentar necessidade de extensao ou aguardar passagem para fase seguinte."</text></outputEntry>
<outputEntry id="Rule_Bloqueio_1_outputEntry_alertasConformidade_AUTH_EXTENSION_007"><text>"PRAZO"</text></outputEntry>
<outputEntry id="Rule_Bloqueio_1_outputEntry_riscoDenial_AUTH_EXTENSION_007"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloqueio_2_AUTH_EXTENSION_007">
        <description>Fase tardia sem complicacoes documentadas</description>
        <inputEntry id="InputEntry_B2_1_AUTH_EXTENSION_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_AUTH_EXTENSION_007"><text>"TARDIA"</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_AUTH_EXTENSION_007"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_AUTH_EXTENSION_007"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_AUTH_EXTENSION_007"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_AUTH_EXTENSION_007"><text>"Fase tardia sem complicacoes nao justifica extensao."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_AUTH_EXTENSION_007"><text>"Transferir para acompanhamento ambulatorial regular."</text></outputEntry>
<outputEntry id="Rule_Bloqueio_2_outputEntry_alertasConformidade_AUTH_EXTENSION_007"><text>"PRAZO"</text></outputEntry>
<outputEntry id="Rule_Bloqueio_2_outputEntry_riscoDenial_AUTH_EXTENSION_007"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alerta_1_AUTH_EXTENSION_007">
        <description>Complicacoes em fase tardia</description>
        <inputEntry id="InputEntry_A1_1_AUTH_EXTENSION_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_EXTENSION_007"><text>"TARDIA"</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_EXTENSION_007"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_AUTH_EXTENSION_007"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_AUTH_EXTENSION_007"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_AUTH_EXTENSION_007"><text>"Complicacoes em fase tardia de transplante. Avaliar extensao de cobertura."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_AUTH_EXTENSION_007"><text>"Documentar complicacoes e solicitar parecer da equipe de transplante."</text></outputEntry>
<outputEntry id="Rule_Alerta_1_outputEntry_alertasConformidade_AUTH_EXTENSION_007"><text>"PRAZO"</text></outputEntry>
<outputEntry id="Rule_Alerta_1_outputEntry_riscoDenial_AUTH_EXTENSION_007"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alerta_2_AUTH_EXTENSION_007">
        <description>Fase de manutencao requer revisao periodica</description>
        <inputEntry id="InputEntry_A2_1_AUTH_EXTENSION_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_AUTH_EXTENSION_007"><text>"MANUTENCAO"</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_AUTH_EXTENSION_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_AUTH_EXTENSION_007"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_AUTH_EXTENSION_007"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_AUTH_EXTENSION_007"><text>"Paciente em fase de manutencao. Verificar necessidade de extensao."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_AUTH_EXTENSION_007"><text>"Agendar revisao periodica com equipe de transplante."</text></outputEntry>
<outputEntry id="Rule_Alerta_2_outputEntry_alertasConformidade_AUTH_EXTENSION_007"><text>"PRAZO"</text></outputEntry>
<outputEntry id="Rule_Alerta_2_outputEntry_riscoDenial_AUTH_EXTENSION_007"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_AUTH_EXTENSION_007">
        <description>Complicacoes em fase imediata pos-transplante</description>
        <inputEntry id="InputEntry_P1_1_AUTH_EXTENSION_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_AUTH_EXTENSION_007"><text>"IMEDIATA"</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_AUTH_EXTENSION_007"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_AUTH_EXTENSION_007"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_AUTH_EXTENSION_007"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_AUTH_EXTENSION_007"><text>"Extensao aprovada por complicacoes em fase imediata de transplante."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_AUTH_EXTENSION_007"><text>"Prosseguir com autorizacao de tratamento das complicacoes."</text></outputEntry>
<outputEntry id="Rule_Prosseguir_1_outputEntry_alertasConformidade_AUTH_EXTENSION_007"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Prosseguir_1_outputEntry_riscoDenial_AUTH_EXTENSION_007"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_2_AUTH_EXTENSION_007">
        <description>Acompanhamento de fase precoce</description>
        <inputEntry id="InputEntry_P2_1_AUTH_EXTENSION_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_AUTH_EXTENSION_007"><text>"PRECOCE"</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_AUTH_EXTENSION_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_AUTH_EXTENSION_007"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_AUTH_EXTENSION_007"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_AUTH_EXTENSION_007"><text>"Extensao de fase precoce pos-transplante aprovada automaticamente."</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_AUTH_EXTENSION_007"><text>"Prosseguir com autorizacao de acompanhamento precoce."</text></outputEntry>
<outputEntry id="Rule_Prosseguir_2_outputEntry_alertasConformidade_AUTH_EXTENSION_007"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Prosseguir_2_outputEntry_riscoDenial_AUTH_EXTENSION_007"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_3_AUTH_EXTENSION_007">
        <description>Extensao com justificativa adequada</description>
        <inputEntry id="InputEntry_P3_1_AUTH_EXTENSION_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P3_2_AUTH_EXTENSION_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P3_3_AUTH_EXTENSION_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P3_4_AUTH_EXTENSION_007"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P3_1_AUTH_EXTENSION_007"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P3_2_AUTH_EXTENSION_007"><text>"Extensao de transplante aprovada com justificativa documentada."</text></outputEntry>
<outputEntry id="OutputEntry_P3_3_AUTH_EXTENSION_007"><text>"Prosseguir com autorizacao conforme justificativa."</text></outputEntry>
<outputEntry id="Rule_Prosseguir_3_outputEntry_alertasConformidade_AUTH_EXTENSION_007"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Prosseguir_3_outputEntry_riscoDenial_AUTH_EXTENSION_007"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_AUTH_EXTENSION_007">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_EXTENSION_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_EXTENSION_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_EXTENSION_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_AUTH_EXTENSION_007"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_AUTH_EXTENSION_007"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_AUTH_EXTENSION_007"><text>"Extensao de transplante requer analise da equipe especializada."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_AUTH_EXTENSION_007"><text>"Encaminhar para junta de transplantes avaliar extensao."</text></outputEntry>
<outputEntry id="Rule_Fallback_AUTH_EXTENSION_007_outputEntry_alertasConformidade"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Fallback_AUTH_EXTENSION_007_outputEntry_riscoDenial"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_EXTENSION_007">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_EXTENSION_007" dmnElementRef="Decision_AUTH_EXTENSION_007">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>