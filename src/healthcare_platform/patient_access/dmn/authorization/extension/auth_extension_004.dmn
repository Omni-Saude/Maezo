<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-EXTENSION-004 - Prorrogacao Pediatrica
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-EXTENSION
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_EXTENSION_004" name="Prorrogacao Pediatrica" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_EXTENSION_004" name="[SP-PA-004 | authorization/extension] Avaliar Prorrogacao de Tratamento Pediatrico" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_EXTENSION_004" hitPolicy="FIRST">

      <input id="Input_1_AUTH_EXTENSION_004" label="Idade Paciente">
        <inputExpression id="InputExpression_1_AUTH_EXTENSION_004" typeRef="number">
          <text>idadePaciente</text>
        </inputExpression>
      </input>

      <input id="Input_2_AUTH_EXTENSION_004" label="Tipo Tratamento">
        <inputExpression id="InputExpression_2_AUTH_EXTENSION_004" typeRef="string">
          <text>tipoTratamento</text>
        </inputExpression>
        <inputValues id="InputValues_2_AUTH_EXTENSION_004">
          <text>"PEDIATRICO", "ADOLESCENTE", "TRANSICAO", "ADULTO"</text>
        </inputValues>
      </input>

      <input id="Input_3_AUTH_EXTENSION_004" label="Acompanhamento Especializado">
        <inputExpression id="InputExpression_3_AUTH_EXTENSION_004" typeRef="boolean">
          <text>acompanhamentoEspecializado</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_AUTH_EXTENSION_004" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_AUTH_EXTENSION_004" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_AUTH_EXTENSION_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_AUTH_EXTENSION_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_AUTH_EXTENSION_004" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloqueio_1_AUTH_EXTENSION_004">
        <description>Paciente adulto em protocolo pediatrico</description>
        <inputEntry id="InputEntry_B1_1_AUTH_EXTENSION_004"><text>&gt; 18</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_EXTENSION_004"><text>"PEDIATRICO"</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_EXTENSION_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_AUTH_EXTENSION_004"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_AUTH_EXTENSION_004"><text>"Paciente acima de 18 anos nao elegivel para protocolo pediatrico."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_AUTH_EXTENSION_004"><text>"Transferir para protocolo de tratamento adulto ou solicitar justificativa especial."</text></outputEntry>
<outputEntry id="Rule_Bloqueio_1_outputEntry_alertasConformidade_AUTH_EXTENSION_004"><text>"PRAZO"</text></outputEntry>
<outputEntry id="Rule_Bloqueio_1_outputEntry_riscoDenial_AUTH_EXTENSION_004"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloqueio_2_AUTH_EXTENSION_004">
        <description>Tratamento pediatrico sem especialista</description>
        <inputEntry id="InputEntry_B2_1_AUTH_EXTENSION_004"><text>&lt;= 12</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_AUTH_EXTENSION_004"><text>"PEDIATRICO"</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_AUTH_EXTENSION_004"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_AUTH_EXTENSION_004"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_AUTH_EXTENSION_004"><text>"Crianca ate 12 anos requer acompanhamento de pediatra."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_AUTH_EXTENSION_004"><text>"Vincular especialista pediatrico ao tratamento."</text></outputEntry>
<outputEntry id="Rule_Bloqueio_2_outputEntry_alertasConformidade_AUTH_EXTENSION_004"><text>"PRAZO"</text></outputEntry>
<outputEntry id="Rule_Bloqueio_2_outputEntry_riscoDenial_AUTH_EXTENSION_004"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alerta_1_AUTH_EXTENSION_004">
        <description>Paciente em idade de transicao pediatrica</description>
        <inputEntry id="InputEntry_A1_1_AUTH_EXTENSION_004"><text>[16..18]</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_EXTENSION_004"><text>"PEDIATRICO"</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_EXTENSION_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_AUTH_EXTENSION_004"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_AUTH_EXTENSION_004"><text>"Paciente em idade de transicao (16-18 anos). Avaliar passagem para adulto."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_AUTH_EXTENSION_004"><text>"Planejar transicao gradual para protocolo adulto conforme ECA."</text></outputEntry>
<outputEntry id="Rule_Alerta_1_outputEntry_alertasConformidade_AUTH_EXTENSION_004"><text>"PRAZO"</text></outputEntry>
<outputEntry id="Rule_Alerta_1_outputEntry_riscoDenial_AUTH_EXTENSION_004"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alerta_2_AUTH_EXTENSION_004">
        <description>Adolescente em tratamento pediatrico</description>
        <inputEntry id="InputEntry_A2_1_AUTH_EXTENSION_004"><text>[13..16[</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_AUTH_EXTENSION_004"><text>"PEDIATRICO"</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_AUTH_EXTENSION_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_AUTH_EXTENSION_004"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_AUTH_EXTENSION_004"><text>"Adolescente em protocolo pediatrico. Verificar adequacao do tratamento."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_AUTH_EXTENSION_004"><text>"Avaliar se tratamento de adolescente seria mais adequado."</text></outputEntry>
<outputEntry id="Rule_Alerta_2_outputEntry_alertasConformidade_AUTH_EXTENSION_004"><text>"PRAZO"</text></outputEntry>
<outputEntry id="Rule_Alerta_2_outputEntry_riscoDenial_AUTH_EXTENSION_004"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_AUTH_EXTENSION_004">
        <description>Tratamento pediatrico adequado</description>
        <inputEntry id="InputEntry_P1_1_AUTH_EXTENSION_004"><text>&lt;= 12</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_AUTH_EXTENSION_004"><text>"PEDIATRICO"</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_AUTH_EXTENSION_004"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_AUTH_EXTENSION_004"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_AUTH_EXTENSION_004"><text>"Prorrogacao pediatrica aprovada. Acompanhamento especializado confirmado."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_AUTH_EXTENSION_004"><text>"Prosseguir com autorizacao de tratamento pediatrico."</text></outputEntry>
<outputEntry id="Rule_Prosseguir_1_outputEntry_alertasConformidade_AUTH_EXTENSION_004"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Prosseguir_1_outputEntry_riscoDenial_AUTH_EXTENSION_004"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_2_AUTH_EXTENSION_004">
        <description>Protocolo de transicao adequado</description>
        <inputEntry id="InputEntry_P2_1_AUTH_EXTENSION_004"><text>[13..18]</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_AUTH_EXTENSION_004"><text>"TRANSICAO"</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_AUTH_EXTENSION_004"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_AUTH_EXTENSION_004"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_AUTH_EXTENSION_004"><text>"Tratamento de transicao aprovado para adolescente."</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_AUTH_EXTENSION_004"><text>"Prosseguir com protocolo de transicao pediatrico-adulto."</text></outputEntry>
<outputEntry id="Rule_Prosseguir_2_outputEntry_alertasConformidade_AUTH_EXTENSION_004"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Prosseguir_2_outputEntry_riscoDenial_AUTH_EXTENSION_004"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_3_AUTH_EXTENSION_004">
        <description>Tratamento de adolescente</description>
        <inputEntry id="InputEntry_P3_1_AUTH_EXTENSION_004"><text>[13..18]</text></inputEntry>
        <inputEntry id="InputEntry_P3_2_AUTH_EXTENSION_004"><text>"ADOLESCENTE"</text></inputEntry>
        <inputEntry id="InputEntry_P3_3_AUTH_EXTENSION_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P3_1_AUTH_EXTENSION_004"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P3_2_AUTH_EXTENSION_004"><text>"Tratamento de adolescente aprovado."</text></outputEntry>
<outputEntry id="OutputEntry_P3_3_AUTH_EXTENSION_004"><text>"Prosseguir com autorizacao de tratamento."</text></outputEntry>
<outputEntry id="Rule_Prosseguir_3_outputEntry_alertasConformidade_AUTH_EXTENSION_004"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Prosseguir_3_outputEntry_riscoDenial_AUTH_EXTENSION_004"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_AUTH_EXTENSION_004">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_EXTENSION_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_EXTENSION_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_EXTENSION_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_AUTH_EXTENSION_004"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_AUTH_EXTENSION_004"><text>"Prorrogacao pediatrica requer analise manual."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_AUTH_EXTENSION_004"><text>"Encaminhar para auditoria pediatrica avaliar elegibilidade."</text></outputEntry>
<outputEntry id="Rule_Fallback_AUTH_EXTENSION_004_outputEntry_alertasConformidade"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Fallback_AUTH_EXTENSION_004_outputEntry_riscoDenial"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_EXTENSION_004">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_EXTENSION_004" dmnElementRef="Decision_AUTH_EXTENSION_004">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>