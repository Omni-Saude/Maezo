<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-PREAUTH-005 - Validacao Codigo Procedimento na Autorizacao
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-PREAUTH
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_PREAUTH_005" name="Validacao Codigo Procedimento na Autorizacao" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_PREAUTH_005" name="[SP-PA-004 | authorization/preauth] Validar Codigo do Procedimento na Autorizacao" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_PREAUTH_005" hitPolicy="FIRST">

      <input id="Input_1_AUTH_PREAUTH_005" label="Codigo TUSS">
        <inputExpression id="InputExpression_1_AUTH_PREAUTH_005" typeRef="string">
          <text>codigoTUSS</text>
        </inputExpression>
      </input>

      <input id="Input_2_AUTH_PREAUTH_005" label="Codigo Consta na Autorizacao">
        <inputExpression id="InputExpression_2_AUTH_PREAUTH_005" typeRef="boolean">
          <text>codigoConstaAutorizacao</text>
        </inputExpression>
      </input>

      <input id="Input_3_AUTH_PREAUTH_005" label="Requer Autorizacao Previa">
        <inputExpression id="InputExpression_3_AUTH_PREAUTH_005" typeRef="boolean">
          <text>requerAutorizacaoPrevia</text>
        </inputExpression>
      </input>

      <input id="Input_4_AUTH_PREAUTH_005" label="Tipo Guia">
        <inputExpression id="InputExpression_4_AUTH_PREAUTH_005" typeRef="string">
          <text>tipoGuia</text>
        </inputExpression>
        <inputValues id="InputValues_4_AUTH_PREAUTH_005">
          <text>"SADT", "INTERNACAO", "CONSULTA", "HONORARIOS"</text>
        </inputValues>
      </input>

      <output id="Output_1_AUTH_PREAUTH_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_AUTH_PREAUTH_005" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_AUTH_PREAUTH_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_AUTH_PREAUTH_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_AUTH_PREAUTH_005" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Bloqueio_1_AUTH_PREAUTH_005">
        <description>Codigo TUSS nao consta na autorizacao e requer autorizacao previa</description>
        <inputEntry id="InputEntry_B1_1_AUTH_PREAUTH_005"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_PREAUTH_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_PREAUTH_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_AUTH_PREAUTH_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_AUTH_PREAUTH_005"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_AUTH_PREAUTH_005"><text>"Codigo TUSS nao consta na autorizacao. Procedimento requer autorizacao previa."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_AUTH_PREAUTH_005"><text>"Solicitar autorizacao para o codigo TUSS especifico."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_1_4_AUTH_PREAUTH_005"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_1_5_AUTH_PREAUTH_005"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Bloqueio_2_AUTH_PREAUTH_005">
        <description>Codigo TUSS do procedimento nao informado</description>
        <inputEntry id="InputEntry_B2_1_AUTH_PREAUTH_005"><text>null</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_AUTH_PREAUTH_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_AUTH_PREAUTH_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_AUTH_PREAUTH_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B2_1_AUTH_PREAUTH_005"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_2_AUTH_PREAUTH_005"><text>"Codigo TUSS do procedimento nao informado."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_3_AUTH_PREAUTH_005"><text>"Inserir codigo TUSS do procedimento."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_2_4_AUTH_PREAUTH_005"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_2_5_AUTH_PREAUTH_005"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_1_AUTH_PREAUTH_005">
        <description>Codigo TUSS consta na autorizacao</description>
        <inputEntry id="InputEntry_A1_1_AUTH_PREAUTH_005"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_PREAUTH_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_PREAUTH_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_AUTH_PREAUTH_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_AUTH_PREAUTH_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_AUTH_PREAUTH_005"><text>"Codigo TUSS do procedimento consta na autorizacao."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_AUTH_PREAUTH_005"><text>"Prosseguir com faturamento."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_1_4_AUTH_PREAUTH_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_1_5_AUTH_PREAUTH_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_2_AUTH_PREAUTH_005">
        <description>Procedimento nao requer autorizacao previa</description>
        <inputEntry id="InputEntry_A2_1_AUTH_PREAUTH_005"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_AUTH_PREAUTH_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_AUTH_PREAUTH_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_AUTH_PREAUTH_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A2_1_AUTH_PREAUTH_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_2_AUTH_PREAUTH_005"><text>"Procedimento nao requer autorizacao previa conforme contrato."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_3_AUTH_PREAUTH_005"><text>"Prosseguir com faturamento direto."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_2_4_AUTH_PREAUTH_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_2_5_AUTH_PREAUTH_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_AUTH_PREAUTH_005">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_PREAUTH_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_PREAUTH_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_PREAUTH_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_AUTH_PREAUTH_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_AUTH_PREAUTH_005"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_AUTH_PREAUTH_005"><text>"Nao foi possivel validar codigo do procedimento."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_AUTH_PREAUTH_005"><text>"Verificar se codigo TUSS esta na autorizacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_AUTH_PREAUTH_005_4"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_AUTH_PREAUTH_005_5"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_PREAUTH_005">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_PREAUTH_005" dmnElementRef="Decision_AUTH_PREAUTH_005">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>