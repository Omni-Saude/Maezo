<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-PREAUTH-009 - Autorizacao Retroativa (Emergencia)
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-PREAUTH
  Perspectiva: HOSPITAL (Faturamento/Auditoria)

  ============================================================================
  INDICACOES (Quando PROSSEGUIR):
  ============================================================================
  - Atendimento de emergencia caracterizado
  - Autorizacao retroativa dentro do prazo regulatorio (24-72h)
  - Documentacao de urgencia/emergencia presente

  ============================================================================
  CONTRAINDICACOES (Quando BLOQUEAR):
  ============================================================================
  - Atendimento eletivo sem autorizacao previa
  - Autorizacao retroativa fora do prazo permitido
  - Falta caracterizacao de emergencia na documentacao

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - RN 424/2017 (Autorizacao Previa)
  - RN 465/2021 Art. 3 (Procedimentos de Urgencia/Emergencia)
  - Lei 9.656/1998 Art. 12-C (Cobertura Emergencial)
  - RN 259/2011 Art. 2 (Prazo Emergencia 12h, Urgencia 24h)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_AUTH_PREAUTH_009"
             name="Autorizacao Retroativa (Emergencia)"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_PREAUTH_009" name="[SP-PA-004 | authorization/preauth] Verificar Autorizacao Retroativa para Emergencia" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_PREAUTH_009" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_AUTH_PREAUTH_009" label="Tipo Atendimento">
        <inputExpression id="InputExpression_1_AUTH_PREAUTH_009" typeRef="string">
          <text>tipoAtendimento</text>
        </inputExpression>
        <inputValues id="InputValues_1_AUTH_PREAUTH_009">
          <text>"ELETIVO", "URGENCIA", "EMERGENCIA"</text>
        </inputValues>
      </input>

      <input id="Input_2_AUTH_PREAUTH_009" label="Horas Desde Atendimento">
        <inputExpression id="InputExpression_2_AUTH_PREAUTH_009" typeRef="integer">
          <text>horasDesdeAtendimento</text>
        </inputExpression>
      </input>

      <input id="Input_3_AUTH_PREAUTH_009" label="Tem Autorizacao">
        <inputExpression id="InputExpression_3_AUTH_PREAUTH_009" typeRef="boolean">
          <text>temAutorizacao</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_AUTH_PREAUTH_009" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_AUTH_PREAUTH_009" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_AUTH_PREAUTH_009" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_AUTH_PREAUTH_009" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_AUTH_PREAUTH_009" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA B1: Bloqueio - Atendimento eletivo sem autorizacao -->
      <rule id="Rule_Bloqueio_1_AUTH_PREAUTH_009">
        <description>Atendimento eletivo realizado sem autorizacao previa</description>
        <inputEntry id="InputEntry_B1_1_AUTH_PREAUTH_009"><text>"ELETIVO"</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_PREAUTH_009"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_PREAUTH_009"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_B1_1_AUTH_PREAUTH_009"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_2_AUTH_PREAUTH_009"><text>"Atendimento eletivo realizado sem autorizacao previa. Nao se aplica autorizacao retroativa."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_3_AUTH_PREAUTH_009"><text>"Procedimentos eletivos devem ter autorizacao previa obrigatoria. Solicitar autorizacao antes de executar."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_4_AUTH_PREAUTH_009"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_5_AUTH_PREAUTH_009"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA B2: Bloqueio - Emergencia sem autorizacao retroativa apos 72h -->
      <rule id="Rule_Bloqueio_2_AUTH_PREAUTH_009">
        <description>Emergencia sem autorizacao apos prazo regulatorio</description>
        <inputEntry id="InputEntry_B2_1_AUTH_PREAUTH_009"><text>"EMERGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_AUTH_PREAUTH_009"><text>&gt; 72</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_AUTH_PREAUTH_009"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_B2_1_AUTH_PREAUTH_009"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_2_AUTH_PREAUTH_009"><text>"Atendimento de emergencia sem autorizacao retroativa apos 72h. Prazo regulatorio expirado."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_3_AUTH_PREAUTH_009"><text>"Solicitar justificativa formal do atraso e negociar com operadora autorizacao excepcional."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_4_AUTH_PREAUTH_009"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_5_AUTH_PREAUTH_009"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA B3: Bloqueio - Urgencia sem autorizacao apos 48h -->
      <rule id="Rule_Bloqueio_3_AUTH_PREAUTH_009">
        <description>Urgencia sem autorizacao apos prazo regulatorio</description>
        <inputEntry id="InputEntry_B3_1_AUTH_PREAUTH_009"><text>"URGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_AUTH_PREAUTH_009"><text>&gt; 48</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_AUTH_PREAUTH_009"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_B3_1_AUTH_PREAUTH_009"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B3_2_AUTH_PREAUTH_009"><text>"Atendimento de urgencia sem autorizacao retroativa apos 48h. Prazo regulatorio expirado."</text></outputEntry>
        <outputEntry id="OutputEntry_B3_3_AUTH_PREAUTH_009"><text>"Solicitar justificativa formal do atraso e negociar com operadora autorizacao excepcional."</text></outputEntry>
        <outputEntry id="OutputEntry_B3_4_AUTH_PREAUTH_009"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_B3_5_AUTH_PREAUTH_009"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA A1: Alerta - Emergencia no limite do prazo (48-72h) -->
      <rule id="Rule_Alerta_1_AUTH_PREAUTH_009">
        <description>Emergencia proxima ao limite do prazo retroativo</description>
        <inputEntry id="InputEntry_A1_1_AUTH_PREAUTH_009"><text>"EMERGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_PREAUTH_009"><text>[48..72]</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_PREAUTH_009"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_A1_1_AUTH_PREAUTH_009"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_2_AUTH_PREAUTH_009"><text>"Emergencia sem autorizacao entre 48-72h. Prazo retroativo no limite regulatorio."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_3_AUTH_PREAUTH_009"><text>"Solicitar autorizacao retroativa URGENTE a operadora antes de vencer prazo de 72h."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_4_AUTH_PREAUTH_009"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_5_AUTH_PREAUTH_009"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA A2: Alerta - Urgencia no limite do prazo (24-48h) -->
      <rule id="Rule_Alerta_2_AUTH_PREAUTH_009">
        <description>Urgencia proxima ao limite do prazo retroativo</description>
        <inputEntry id="InputEntry_A2_1_AUTH_PREAUTH_009"><text>"URGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_AUTH_PREAUTH_009"><text>[24..48]</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_AUTH_PREAUTH_009"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_A2_1_AUTH_PREAUTH_009"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A2_2_AUTH_PREAUTH_009"><text>"Urgencia sem autorizacao entre 24-48h. Prazo retroativo no limite regulatorio."</text></outputEntry>
        <outputEntry id="OutputEntry_A2_3_AUTH_PREAUTH_009"><text>"Solicitar autorizacao retroativa URGENTE a operadora antes de vencer prazo de 48h."</text></outputEntry>
        <outputEntry id="OutputEntry_A2_4_AUTH_PREAUTH_009"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_A2_5_AUTH_PREAUTH_009"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA P1: Aprovado - Emergencia dentro do prazo retroativo -->
      <rule id="Rule_Aprovado_1_AUTH_PREAUTH_009">
        <description>Emergencia dentro do prazo para autorizacao retroativa</description>
        <inputEntry id="InputEntry_P1_1_AUTH_PREAUTH_009"><text>"EMERGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_AUTH_PREAUTH_009"><text>&lt;= 48</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_AUTH_PREAUTH_009"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_AUTH_PREAUTH_009"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_2_AUTH_PREAUTH_009"><text>"Atendimento de emergencia dentro do prazo para autorizacao retroativa (ate 72h)."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_3_AUTH_PREAUTH_009"><text>"Solicitar autorizacao retroativa a operadora justificando carater emergencial do atendimento."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_4_AUTH_PREAUTH_009"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_5_AUTH_PREAUTH_009"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA P2: Aprovado - Urgencia dentro do prazo retroativo -->
      <rule id="Rule_Aprovado_2_AUTH_PREAUTH_009">
        <description>Urgencia dentro do prazo para autorizacao retroativa</description>
        <inputEntry id="InputEntry_P2_1_AUTH_PREAUTH_009"><text>"URGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_AUTH_PREAUTH_009"><text>&lt;= 24</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_AUTH_PREAUTH_009"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_P2_1_AUTH_PREAUTH_009"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P2_2_AUTH_PREAUTH_009"><text>"Atendimento de urgencia dentro do prazo para autorizacao retroativa (ate 48h)."</text></outputEntry>
        <outputEntry id="OutputEntry_P2_3_AUTH_PREAUTH_009"><text>"Solicitar autorizacao retroativa a operadora justificando carater urgente do atendimento."</text></outputEntry>
        <outputEntry id="OutputEntry_P2_4_AUTH_PREAUTH_009"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P2_5_AUTH_PREAUTH_009"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA P3: Aprovado - Atendimento com autorizacao previa -->
      <rule id="Rule_Aprovado_3_AUTH_PREAUTH_009">
        <description>Atendimento ja possui autorizacao previa</description>
        <inputEntry id="InputEntry_P3_1_AUTH_PREAUTH_009"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P3_2_AUTH_PREAUTH_009"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P3_3_AUTH_PREAUTH_009"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_P3_1_AUTH_PREAUTH_009"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P3_2_AUTH_PREAUTH_009"><text>"Atendimento ja possui autorizacao previa registrada."</text></outputEntry>
        <outputEntry id="OutputEntry_P3_3_AUTH_PREAUTH_009"><text>"Prosseguir com faturamento conforme autorizacao existente."</text></outputEntry>
        <outputEntry id="OutputEntry_P3_4_AUTH_PREAUTH_009"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P3_5_AUTH_PREAUTH_009"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisao manual -->
      <rule id="Rule_Fallback_AUTH_PREAUTH_009">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_PREAUTH_009"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_PREAUTH_009"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_PREAUTH_009"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_AUTH_PREAUTH_009"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_AUTH_PREAUTH_009"><text>"Situacao de autorizacao retroativa requer analise manual especializada."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_AUTH_PREAUTH_009"><text>"Encaminhar para auditoria avaliar elegibilidade para autorizacao retroativa."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_AUTH_PREAUTH_009"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_AUTH_PREAUTH_009"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_PREAUTH_009">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_PREAUTH_009" dmnElementRef="Decision_AUTH_PREAUTH_009">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
