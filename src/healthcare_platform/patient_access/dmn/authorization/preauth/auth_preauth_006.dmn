<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-PREAUTH-006 - Autorizacao Parcial (Procedimento Autorizado Parcialmente)
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-PREAUTH
  Perspectiva: HOSPITAL (Faturamento/Auditoria)

  ============================================================================
  INDICACOES (Quando PROSSEGUIR):
  ============================================================================
  - Procedimento possui autorizacao parcial valida
  - Status "PARCIAL" confirmado pela operadora
  - Documentacao de divergencia presente

  ============================================================================
  CONTRAINDICACOES (Quando BLOQUEAR):
  ============================================================================
  - Status autorizacao incompativel com faturamento
  - Autorizacao negada ou expirada
  - Falta especificacao da parcela autorizada

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - RN 424/2017 (Autorizacao Previa)
  - RN 465/2021 (Procedimentos Regulados)
  - TISS 4.01.00 (Guia SADT)
  - Lei 9.656/1998 Art. 12 (Cobertura Obrigatoria)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_AUTH_PREAUTH_006"
             name="Autorizacao Parcial (Procedimento Autorizado Parcialmente)"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_PREAUTH_006" name="[SP-PA-004 | authorization/preauth] Verificar Autorizacao Parcial de Procedimento" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_PREAUTH_006" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_AUTH_PREAUTH_006" label="Tem Autorizacao">
        <inputExpression id="InputExpression_1_AUTH_PREAUTH_006" typeRef="boolean">
          <text>temAutorizacao</text>
        </inputExpression>
      </input>

      <input id="Input_2_AUTH_PREAUTH_006" label="Status Autorizacao">
        <inputExpression id="InputExpression_2_AUTH_PREAUTH_006" typeRef="string">
          <text>statusAutorizacao</text>
        </inputExpression>
        <inputValues id="InputValues_2_AUTH_PREAUTH_006">
          <text>"TOTAL", "PARCIAL", "NEGADA", "EXPIRADA"</text>
        </inputValues>
      </input>

      <input id="Input_3_AUTH_PREAUTH_006" label="Dias Desde Autorizacao">
        <inputExpression id="InputExpression_3_AUTH_PREAUTH_006" typeRef="integer">
          <text>diasDesdeAutorizacao</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_AUTH_PREAUTH_006" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_AUTH_PREAUTH_006" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_AUTH_PREAUTH_006" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_AUTH_PREAUTH_006" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_AUTH_PREAUTH_006" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA B1: Bloqueio - Sem autorizacao -->
      <rule id="Rule_Bloqueio_1_AUTH_PREAUTH_006">
        <description>Procedimento sem autorizacao registrada</description>
        <inputEntry id="InputEntry_B1_1_AUTH_PREAUTH_006"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_PREAUTH_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_PREAUTH_006"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B1_1_AUTH_PREAUTH_006"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_2_AUTH_PREAUTH_006"><text>"Procedimento sem autorizacao previa. Faturamento bloqueado."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_3_AUTH_PREAUTH_006"><text>"Solicitar autorizacao total ou parcial junto a operadora antes de prosseguir."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_4_AUTH_PREAUTH_006"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_5_AUTH_PREAUTH_006"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA B2: Bloqueio - Autorizacao negada -->
      <rule id="Rule_Bloqueio_2_AUTH_PREAUTH_006">
        <description>Autorizacao negada pela operadora</description>
        <inputEntry id="InputEntry_B2_1_AUTH_PREAUTH_006"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_AUTH_PREAUTH_006"><text>"NEGADA"</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_AUTH_PREAUTH_006"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B2_1_AUTH_PREAUTH_006"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_2_AUTH_PREAUTH_006"><text>"Autorizacao negada pela operadora. Faturamento bloqueado."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_3_AUTH_PREAUTH_006"><text>"Encaminhar para recurso administrativo ou solicitar nova autorizacao com justificativa clinica."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_4_AUTH_PREAUTH_006"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_5_AUTH_PREAUTH_006"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA B3: Bloqueio - Autorizacao expirada -->
      <rule id="Rule_Bloqueio_3_AUTH_PREAUTH_006">
        <description>Autorizacao expirada antes do atendimento</description>
        <inputEntry id="InputEntry_B3_1_AUTH_PREAUTH_006"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_AUTH_PREAUTH_006"><text>"EXPIRADA"</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_AUTH_PREAUTH_006"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B3_1_AUTH_PREAUTH_006"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B3_2_AUTH_PREAUTH_006"><text>"Autorizacao expirada. Validade vencida para faturamento."</text></outputEntry>
        <outputEntry id="OutputEntry_B3_3_AUTH_PREAUTH_006"><text>"Solicitar renovacao da autorizacao com nova validade."</text></outputEntry>
        <outputEntry id="OutputEntry_B3_4_AUTH_PREAUTH_006"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_B3_5_AUTH_PREAUTH_006"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA A1: Alerta - Autorizacao parcial -->
      <rule id="Rule_Alerta_1_AUTH_PREAUTH_006">
        <description>Procedimento com autorizacao parcial</description>
        <inputEntry id="InputEntry_A1_1_AUTH_PREAUTH_006"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_PREAUTH_006"><text>"PARCIAL"</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_PREAUTH_006"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_A1_1_AUTH_PREAUTH_006"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_2_AUTH_PREAUTH_006"><text>"Procedimento autorizado parcialmente pela operadora. Requer segregacao de itens."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_3_AUTH_PREAUTH_006"><text>"Faturar somente itens autorizados. Itens nao autorizados devem ser cobrados do paciente ou recurso administrativo."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_4_AUTH_PREAUTH_006"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_5_AUTH_PREAUTH_006"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA P1: Aprovado - Autorizacao total -->
      <rule id="Rule_Aprovado_1_AUTH_PREAUTH_006">
        <description>Procedimento com autorizacao total</description>
        <inputEntry id="InputEntry_P1_1_AUTH_PREAUTH_006"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_AUTH_PREAUTH_006"><text>"TOTAL"</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_AUTH_PREAUTH_006"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_AUTH_PREAUTH_006"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_2_AUTH_PREAUTH_006"><text>"Procedimento totalmente autorizado pela operadora."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_3_AUTH_PREAUTH_006"><text>"Prosseguir com faturamento integral conforme guia autorizada."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_4_AUTH_PREAUTH_006"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_5_AUTH_PREAUTH_006"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisao manual -->
      <rule id="Rule_Fallback_AUTH_PREAUTH_006">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_PREAUTH_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_PREAUTH_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_PREAUTH_006"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_AUTH_PREAUTH_006"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_AUTH_PREAUTH_006"><text>"Status de autorizacao parcial requer analise manual detalhada."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_AUTH_PREAUTH_006"><text>"Encaminhar para auditoria avaliar especificacoes da autorizacao parcial."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_AUTH_PREAUTH_006"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_AUTH_PREAUTH_006"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_PREAUTH_006">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_PREAUTH_006" dmnElementRef="Decision_AUTH_PREAUTH_006">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
