<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-PREAUTH-004 - Validacao Quantidade Autorizada
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-PREAUTH
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_PREAUTH_004" name="Validacao Quantidade Autorizada" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_PREAUTH_004" name="[SP-PA-004 | authorization/preauth] Validar Quantidade Autorizada" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_PREAUTH_004" hitPolicy="FIRST">

      <input id="Input_1_AUTH_PREAUTH_004" label="Quantidade Autorizada">
        <inputExpression id="InputExpression_1_AUTH_PREAUTH_004" typeRef="number">
          <text>quantidadeAutorizada</text>
        </inputExpression>
      </input>

      <input id="Input_2_AUTH_PREAUTH_004" label="Quantidade Realizada">
        <inputExpression id="InputExpression_2_AUTH_PREAUTH_004" typeRef="number">
          <text>quantidadeRealizada</text>
        </inputExpression>
      </input>

      <input id="Input_3_AUTH_PREAUTH_004" label="Quantidade Ja Faturada">
        <inputExpression id="InputExpression_3_AUTH_PREAUTH_004" typeRef="number">
          <text>quantidadeJaFaturada</text>
        </inputExpression>
      </input>

      <input id="Input_4_AUTH_PREAUTH_004" label="Saldo Disponivel">
        <inputExpression id="InputExpression_4_AUTH_PREAUTH_004" typeRef="number">
          <text>saldoDisponivel</text>
        </inputExpression>
      </input>

      <output id="Output_1_AUTH_PREAUTH_004" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_AUTH_PREAUTH_004" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_AUTH_PREAUTH_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_AUTH_PREAUTH_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_AUTH_PREAUTH_004" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Bloqueio_1_AUTH_PREAUTH_004">
        <description>Saldo de autorizacao zerado</description>
        <inputEntry id="InputEntry_B1_1_AUTH_PREAUTH_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_PREAUTH_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_PREAUTH_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_AUTH_PREAUTH_004"><text>&lt;= 0</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_AUTH_PREAUTH_004"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_AUTH_PREAUTH_004"><text>"Saldo de autorizacao esgotado. Quantidade autorizada ja utilizada."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_AUTH_PREAUTH_004"><text>"Solicitar nova autorizacao com quantidade adicional."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_1_4_AUTH_PREAUTH_004"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_1_5_AUTH_PREAUTH_004"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Bloqueio_2_AUTH_PREAUTH_004">
        <description>Quantidade realizada excede saldo disponivel</description>
        <inputEntry id="InputEntry_B2_1_AUTH_PREAUTH_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_AUTH_PREAUTH_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_AUTH_PREAUTH_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_AUTH_PREAUTH_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B2_1_AUTH_PREAUTH_004"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_2_AUTH_PREAUTH_004"><text>"Quantidade realizada excede o saldo disponivel na autorizacao."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_3_AUTH_PREAUTH_004"><text>"Ajustar quantidade ou solicitar autorizacao complementar."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_2_4_AUTH_PREAUTH_004"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_2_5_AUTH_PREAUTH_004"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alerta_1_AUTH_PREAUTH_004">
        <description>Saldo de autorizacao ficara baixo apos faturamento</description>
        <inputEntry id="InputEntry_AL1_1_AUTH_PREAUTH_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_AL1_2_AUTH_PREAUTH_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_AL1_3_AUTH_PREAUTH_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_AL1_4_AUTH_PREAUTH_004"><text>[1..2]</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL1_1_AUTH_PREAUTH_004"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_2_AUTH_PREAUTH_004"><text>"Saldo de autorizacao baixo. Considerar solicitar complemento."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_3_AUTH_PREAUTH_004"><text>"Verificar necessidade de autorizacao complementar."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_1_4_AUTH_PREAUTH_004"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_1_5_AUTH_PREAUTH_004"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_1_AUTH_PREAUTH_004">
        <description>Saldo de autorizacao suficiente</description>
        <inputEntry id="InputEntry_A1_1_AUTH_PREAUTH_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_PREAUTH_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_PREAUTH_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_AUTH_PREAUTH_004"><text>&gt; 2</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_AUTH_PREAUTH_004"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_AUTH_PREAUTH_004"><text>"Quantidade dentro do limite autorizado. Saldo disponivel."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_AUTH_PREAUTH_004"><text>"Prosseguir com faturamento."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_1_4_AUTH_PREAUTH_004"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_1_5_AUTH_PREAUTH_004"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_AUTH_PREAUTH_004">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_PREAUTH_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_PREAUTH_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_PREAUTH_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_AUTH_PREAUTH_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_AUTH_PREAUTH_004"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_AUTH_PREAUTH_004"><text>"Nao foi possivel validar quantidade autorizada."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_AUTH_PREAUTH_004"><text>"Verificar quantidades na guia e no lancamento."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_AUTH_PREAUTH_004_4"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_AUTH_PREAUTH_004_5"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_PREAUTH_004">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_PREAUTH_004" dmnElementRef="Decision_AUTH_PREAUTH_004">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>