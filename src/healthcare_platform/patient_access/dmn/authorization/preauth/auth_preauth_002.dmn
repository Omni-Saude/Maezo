<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-PREAUTH-002 - Validacao Vigencia da Autorizacao
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-PREAUTH
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_PREAUTH_002" name="Validacao Vigencia da Autorizacao" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_PREAUTH_002" name="[SP-PA-004 | authorization/preauth] Validar Vigencia da Autorizacao" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_PREAUTH_002" hitPolicy="FIRST">

      <input id="Input_1_AUTH_PREAUTH_002" label="Data Autorizacao">
        <inputExpression id="InputExpression_1_AUTH_PREAUTH_002" typeRef="date">
          <text>dataAutorizacao</text>
        </inputExpression>
      </input>

      <input id="Input_2_AUTH_PREAUTH_002" label="Data Validade">
        <inputExpression id="InputExpression_2_AUTH_PREAUTH_002" typeRef="date">
          <text>dataValidade</text>
        </inputExpression>
      </input>

      <input id="Input_3_AUTH_PREAUTH_002" label="Dias Ate Vencimento">
        <inputExpression id="InputExpression_3_AUTH_PREAUTH_002" typeRef="number">
          <text>diasAteVencimento</text>
        </inputExpression>
      </input>

      <output id="Output_1_AUTH_PREAUTH_002" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_AUTH_PREAUTH_002" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_AUTH_PREAUTH_002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_AUTH_PREAUTH_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_AUTH_PREAUTH_002" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Bloqueio_1_AUTH_PREAUTH_002">
        <description>Autorizacao com data de validade expirada</description>
        <inputEntry id="InputEntry_B1_1_AUTH_PREAUTH_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_PREAUTH_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_PREAUTH_002"><text>&lt; 0</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_AUTH_PREAUTH_002"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_AUTH_PREAUTH_002"><text>"Autorizacao expirada. Data de validade ultrapassada."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_AUTH_PREAUTH_002"><text>"Solicitar nova autorizacao junto a operadora."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_1_4_AUTH_PREAUTH_002"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_1_5_AUTH_PREAUTH_002"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alerta_1_AUTH_PREAUTH_002">
        <description>Autorizacao proxima do vencimento (7 dias)</description>
        <inputEntry id="InputEntry_AL1_1_AUTH_PREAUTH_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_AL1_2_AUTH_PREAUTH_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_AL1_3_AUTH_PREAUTH_002"><text>[0..7]</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL1_1_AUTH_PREAUTH_002"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_2_AUTH_PREAUTH_002"><text>"Autorizacao vencendo em breve. Priorizar realizacao do procedimento."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_3_AUTH_PREAUTH_002"><text>"Agendar procedimento com urgencia ou solicitar extensao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_1_4_AUTH_PREAUTH_002"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_1_5_AUTH_PREAUTH_002"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Alerta_2_AUTH_PREAUTH_002">
        <description>Autorizacao vencendo em 15 dias</description>
        <inputEntry id="InputEntry_AL2_1_AUTH_PREAUTH_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_AL2_2_AUTH_PREAUTH_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_AL2_3_AUTH_PREAUTH_002"><text>]7..15]</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL2_1_AUTH_PREAUTH_002"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL2_2_AUTH_PREAUTH_002"><text>"Autorizacao vence em 15 dias. Monitorar agendamento."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL2_3_AUTH_PREAUTH_002"><text>"Verificar agenda para realizacao do procedimento."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_2_4_AUTH_PREAUTH_002"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_2_5_AUTH_PREAUTH_002"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_1_AUTH_PREAUTH_002">
        <description>Autorizacao com mais de 15 dias de validade</description>
        <inputEntry id="InputEntry_A1_1_AUTH_PREAUTH_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_PREAUTH_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_PREAUTH_002"><text>&gt; 15</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_AUTH_PREAUTH_002"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_AUTH_PREAUTH_002"><text>"Autorizacao dentro do prazo de validade."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_AUTH_PREAUTH_002"><text>"Prosseguir com agendamento normal."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_1_4_AUTH_PREAUTH_002"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_1_5_AUTH_PREAUTH_002"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_AUTH_PREAUTH_002">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_PREAUTH_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_PREAUTH_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_PREAUTH_002"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_AUTH_PREAUTH_002"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_AUTH_PREAUTH_002"><text>"Nao foi possivel determinar vigencia da autorizacao."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_AUTH_PREAUTH_002"><text>"Verificar datas de autorizacao e validade manualmente."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_AUTH_PREAUTH_002_4"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_AUTH_PREAUTH_002_5"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_PREAUTH_002">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_PREAUTH_002" dmnElementRef="Decision_AUTH_PREAUTH_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>