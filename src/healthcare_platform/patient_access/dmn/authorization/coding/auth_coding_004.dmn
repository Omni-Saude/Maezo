<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-CODING-004 - Validacao Codigo na Lista Cobertura ANS
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-CODING
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_CODING_004" name="Validacao Codigo na Lista Cobertura ANS" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_CODING_004" name="[SP-PA-004 | authorization/coding] Validar Codigo na Lista de Cobertura ANS" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_CODING_004" hitPolicy="FIRST">

      <input id="Input_1_AUTH_CODING_004" label="Codigo TUSS">
        <inputExpression id="InputExpression_1_AUTH_CODING_004" typeRef="string">
          <text>codigoTUSS</text>
        </inputExpression>
      </input>

      <input id="Input_2_AUTH_CODING_004" label="Consta no Rol ANS">
        <inputExpression id="InputExpression_2_AUTH_CODING_004" typeRef="boolean">
          <text>constaRolANS</text>
        </inputExpression>
      </input>

      <input id="Input_3_AUTH_CODING_004" label="Coberto pelo Plano">
        <inputExpression id="InputExpression_3_AUTH_CODING_004" typeRef="boolean">
          <text>cobertoPeloPlano</text>
        </inputExpression>
      </input>

      <input id="Input_4_AUTH_CODING_004" label="Segmentacao Plano">
        <inputExpression id="InputExpression_4_AUTH_CODING_004" typeRef="string">
          <text>segmentacaoPlano</text>
        </inputExpression>
        <inputValues id="InputValues_4_AUTH_CODING_004">
          <text>"AMBULATORIAL", "HOSPITALAR", "OBSTETRICO", "ODONTOLOGICO", "REFERENCIA"</text>
        </inputValues>
      </input>

      <output id="Output_1_AUTH_CODING_004" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_AUTH_CODING_004" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_AUTH_CODING_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_AUTH_CODING_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_AUTH_CODING_004" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Bloqueio_1_AUTH_CODING_004">
        <description>Codigo TUSS nao consta no Rol ANS</description>
        <inputEntry id="InputEntry_B1_1_AUTH_CODING_004"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_CODING_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_CODING_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_AUTH_CODING_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_AUTH_CODING_004"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_AUTH_CODING_004"><text>"Codigo TUSS nao consta no Rol de Procedimentos ANS."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_AUTH_CODING_004"><text>"Verificar codigo ou solicitar autorizacao especial."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_1_4_AUTH_CODING_004"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_1_5_AUTH_CODING_004"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Bloqueio_2_AUTH_CODING_004">
        <description>Procedimento nao coberto pela segmentacao do plano</description>
        <inputEntry id="InputEntry_B2_1_AUTH_CODING_004"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_AUTH_CODING_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_AUTH_CODING_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_AUTH_CODING_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B2_1_AUTH_CODING_004"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_2_AUTH_CODING_004"><text>"Procedimento nao coberto pela segmentacao do plano do beneficiario."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_3_AUTH_CODING_004"><text>"Verificar cobertura do plano ou orientar upgrade."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_2_4_AUTH_CODING_004"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_2_5_AUTH_CODING_004"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alerta_1_AUTH_CODING_004">
        <description>Codigo TUSS nao informado</description>
        <inputEntry id="InputEntry_AL1_1_AUTH_CODING_004"><text>null</text></inputEntry>
        <inputEntry id="InputEntry_AL1_2_AUTH_CODING_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_AL1_3_AUTH_CODING_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_AL1_4_AUTH_CODING_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL1_1_AUTH_CODING_004"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_2_AUTH_CODING_004"><text>"Codigo TUSS do procedimento nao informado."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_3_AUTH_CODING_004"><text>"Inserir codigo TUSS do procedimento."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_1_4_AUTH_CODING_004"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_1_5_AUTH_CODING_004"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_1_AUTH_CODING_004">
        <description>Procedimento coberto pelo Rol e pelo plano</description>
        <inputEntry id="InputEntry_A1_1_AUTH_CODING_004"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_CODING_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_CODING_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_AUTH_CODING_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_AUTH_CODING_004"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_AUTH_CODING_004"><text>"Procedimento coberto pelo Rol ANS e pelo plano do beneficiario."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_AUTH_CODING_004"><text>"Prosseguir com solicitacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_1_4_AUTH_CODING_004"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_1_5_AUTH_CODING_004"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_AUTH_CODING_004">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_CODING_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_CODING_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_CODING_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_AUTH_CODING_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_AUTH_CODING_004"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_AUTH_CODING_004"><text>"Verificar cobertura do procedimento."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_AUTH_CODING_004"><text>"Consultar Rol ANS e contrato do plano."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_AUTH_CODING_004_4"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_AUTH_CODING_004_5"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_CODING_004">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_CODING_004" dmnElementRef="Decision_AUTH_CODING_004">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>