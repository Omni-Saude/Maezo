<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-CODING-005 - Validacao Logica de Combinacao de Codigos
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-CODING
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_CODING_005" name="Validacao Logica de Combinacao de Codigos" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_CODING_005" name="[SP-PA-004 | authorization/coding] Validar Logica de Combinacao de Codigos" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_CODING_005" hitPolicy="FIRST">

      <input id="Input_1_AUTH_CODING_005" label="Codigo TUSS Principal">
        <inputExpression id="InputExpression_1_AUTH_CODING_005" typeRef="string">
          <text>codigoTUSSPrincipal</text>
        </inputExpression>
      </input>

      <input id="Input_2_AUTH_CODING_005" label="Codigo TUSS Secundario">
        <inputExpression id="InputExpression_2_AUTH_CODING_005" typeRef="string">
          <text>codigoTUSSSecundario</text>
        </inputExpression>
      </input>

      <input id="Input_3_AUTH_CODING_005" label="Combinacao Permitida">
        <inputExpression id="InputExpression_3_AUTH_CODING_005" typeRef="boolean">
          <text>combinacaoPermitida</text>
        </inputExpression>
      </input>

      <input id="Input_4_AUTH_CODING_005" label="Procedimentos Excludentes">
        <inputExpression id="InputExpression_4_AUTH_CODING_005" typeRef="boolean">
          <text>procedimentosExcludentes</text>
        </inputExpression>
      </input>

      <input id="Input_5_AUTH_CODING_005" label="Requer Justificativa">
        <inputExpression id="InputExpression_5_AUTH_CODING_005" typeRef="boolean">
          <text>requerJustificativa</text>
        </inputExpression>
      </input>

      <output id="Output_1_AUTH_CODING_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_AUTH_CODING_005" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_AUTH_CODING_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_AUTH_CODING_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_AUTH_CODING_005" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Bloqueio_1_AUTH_CODING_005">
        <description>Procedimentos sao mutuamente excludentes</description>
        <inputEntry id="InputEntry_B1_1_AUTH_CODING_005"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_CODING_005"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_CODING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_AUTH_CODING_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_5_AUTH_CODING_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_AUTH_CODING_005"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_AUTH_CODING_005"><text>"Procedimentos sao mutuamente excludentes e nao podem ser cobrados juntos."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_AUTH_CODING_005"><text>"Remover um dos procedimentos da solicitacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_1_4_AUTH_CODING_005"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_1_5_AUTH_CODING_005"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Bloqueio_2_AUTH_CODING_005">
        <description>Combinacao de codigos nao permitida</description>
        <inputEntry id="InputEntry_B2_1_AUTH_CODING_005"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_AUTH_CODING_005"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_AUTH_CODING_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_AUTH_CODING_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_5_AUTH_CODING_005"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_B2_1_AUTH_CODING_005"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_2_AUTH_CODING_005"><text>"Combinacao de codigos TUSS nao permitida pelas regras de cobranca."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_3_AUTH_CODING_005"><text>"Revisar codificacao ou solicitar autorizacao especial."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_2_4_AUTH_CODING_005"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_2_5_AUTH_CODING_005"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alerta_1_AUTH_CODING_005">
        <description>Combinacao permitida mas requer justificativa</description>
        <inputEntry id="InputEntry_AL1_1_AUTH_CODING_005"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_AL1_2_AUTH_CODING_005"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_AL1_3_AUTH_CODING_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_AL1_4_AUTH_CODING_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_AL1_5_AUTH_CODING_005"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL1_1_AUTH_CODING_005"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_2_AUTH_CODING_005"><text>"Combinacao de procedimentos permitida mas requer justificativa."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_3_AUTH_CODING_005"><text>"Anexar justificativa para cobranca conjunta."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_1_4_AUTH_CODING_005"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_1_5_AUTH_CODING_005"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_1_AUTH_CODING_005">
        <description>Combinacao de codigos permitida</description>
        <inputEntry id="InputEntry_A1_1_AUTH_CODING_005"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_CODING_005"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_CODING_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_AUTH_CODING_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_AUTH_CODING_005"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_AUTH_CODING_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_AUTH_CODING_005"><text>"Combinacao de codigos TUSS permitida."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_AUTH_CODING_005"><text>"Prosseguir com solicitacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_1_4_AUTH_CODING_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_1_5_AUTH_CODING_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_2_AUTH_CODING_005">
        <description>Apenas um codigo informado</description>
        <inputEntry id="InputEntry_A2_1_AUTH_CODING_005"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_AUTH_CODING_005"><text>null</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_AUTH_CODING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_AUTH_CODING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_5_AUTH_CODING_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A2_1_AUTH_CODING_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_2_AUTH_CODING_005"><text>"Codigo unico informado. Validacao de combinacao nao aplicavel."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_3_AUTH_CODING_005"><text>"Prosseguir com solicitacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_2_4_AUTH_CODING_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_2_5_AUTH_CODING_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_AUTH_CODING_005">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_CODING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_CODING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_CODING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_AUTH_CODING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_AUTH_CODING_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_AUTH_CODING_005"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_AUTH_CODING_005"><text>"Verificar regras de combinacao de codigos."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_AUTH_CODING_005"><text>"Consultar CBHPM e regras de cobranca."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_AUTH_CODING_005_4"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_AUTH_CODING_005_5"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_CODING_005">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_CODING_005" dmnElementRef="Decision_AUTH_CODING_005">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>