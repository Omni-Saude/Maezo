<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-CODING-003 - Validacao Diagnostico Secundario de Suporte
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-CODING
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_CODING_003" name="Validacao Diagnostico Secundario de Suporte" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_CODING_003" name="[SP-PA-004 | authorization/coding] Validar Diagnostico Secundario de Suporte" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_CODING_003" hitPolicy="FIRST">

      <input id="Input_1_AUTH_CODING_003" label="CID Principal">
        <inputExpression id="InputExpression_1_AUTH_CODING_003" typeRef="string">
          <text>cidPrincipal</text>
        </inputExpression>
      </input>

      <input id="Input_2_AUTH_CODING_003" label="CID Secundario">
        <inputExpression id="InputExpression_2_AUTH_CODING_003" typeRef="string">
          <text>cidSecundario</text>
        </inputExpression>
      </input>

      <input id="Input_3_AUTH_CODING_003" label="CIDs Coerentes">
        <inputExpression id="InputExpression_3_AUTH_CODING_003" typeRef="boolean">
          <text>cidsCoerentes</text>
        </inputExpression>
      </input>

      <input id="Input_4_AUTH_CODING_003" label="Comorbidade Contraindicante">
        <inputExpression id="InputExpression_4_AUTH_CODING_003" typeRef="boolean">
          <text>comorbidadeContraindicante</text>
        </inputExpression>
      </input>

      <output id="Output_1_AUTH_CODING_003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_AUTH_CODING_003" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_AUTH_CODING_003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_AUTH_CODING_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_AUTH_CODING_003" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Bloqueio_1_AUTH_CODING_003">
        <description>Comorbidade contraindica o procedimento</description>
        <inputEntry id="InputEntry_B1_1_AUTH_CODING_003"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_CODING_003"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_CODING_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_AUTH_CODING_003"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_AUTH_CODING_003"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_AUTH_CODING_003"><text>"Diagnostico secundario indica comorbidade que contraindica o procedimento."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_AUTH_CODING_003"><text>"Revisar indicacao considerando comorbidades."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_1_4_AUTH_CODING_003"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_1_5_AUTH_CODING_003"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alerta_1_AUTH_CODING_003">
        <description>CIDs aparentemente incoerentes</description>
        <inputEntry id="InputEntry_AL1_1_AUTH_CODING_003"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_AL1_2_AUTH_CODING_003"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_AL1_3_AUTH_CODING_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_AL1_4_AUTH_CODING_003"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL1_1_AUTH_CODING_003"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_2_AUTH_CODING_003"><text>"Diagnosticos principal e secundario aparentam incoerencia."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_3_AUTH_CODING_003"><text>"Revisar codificacao ou adicionar justificativa."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_1_4_AUTH_CODING_003"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_1_5_AUTH_CODING_003"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_1_AUTH_CODING_003">
        <description>Diagnosticos coerentes e sem contraindicacao</description>
        <inputEntry id="InputEntry_A1_1_AUTH_CODING_003"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_CODING_003"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_CODING_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_AUTH_CODING_003"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_AUTH_CODING_003"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_AUTH_CODING_003"><text>"Diagnosticos principal e secundario coerentes."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_AUTH_CODING_003"><text>"Prosseguir com solicitacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_1_4_AUTH_CODING_003"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_1_5_AUTH_CODING_003"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_2_AUTH_CODING_003">
        <description>Sem diagnostico secundario informado</description>
        <inputEntry id="InputEntry_A2_1_AUTH_CODING_003"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_AUTH_CODING_003"><text>null</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_AUTH_CODING_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_AUTH_CODING_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A2_1_AUTH_CODING_003"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_2_AUTH_CODING_003"><text>"Diagnostico secundario nao informado. Nao obrigatorio."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_3_AUTH_CODING_003"><text>"Prosseguir com solicitacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_2_4_AUTH_CODING_003"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_2_5_AUTH_CODING_003"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_AUTH_CODING_003">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_CODING_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_CODING_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_CODING_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_AUTH_CODING_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_AUTH_CODING_003"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_AUTH_CODING_003"><text>"Verificar coerencia entre diagnosticos."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_AUTH_CODING_003"><text>"Validar CIDs com equipe medica."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_AUTH_CODING_003_4"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_AUTH_CODING_003_5"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_CODING_003">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_CODING_003" dmnElementRef="Decision_AUTH_CODING_003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>