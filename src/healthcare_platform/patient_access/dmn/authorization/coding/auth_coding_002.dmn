<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-CODING-002 - Validacao Especialidade Compativel com Procedimento
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-CODING
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_CODING_002" name="Validacao Especialidade Compativel com Procedimento" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_CODING_002" name="[SP-PA-004 | authorization/coding] Validar Especialidade Compativel com Procedimento" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_CODING_002" hitPolicy="FIRST">

      <input id="Input_1_AUTH_CODING_002" label="Especialidade">
        <inputExpression id="InputExpression_1_AUTH_CODING_002" typeRef="string">
          <text>especialidade</text>
        </inputExpression>
      </input>

      <input id="Input_2_AUTH_CODING_002" label="Codigo TUSS">
        <inputExpression id="InputExpression_2_AUTH_CODING_002" typeRef="string">
          <text>codigoTUSS</text>
        </inputExpression>
      </input>

      <input id="Input_3_AUTH_CODING_002" label="Especialidade Compativel">
        <inputExpression id="InputExpression_3_AUTH_CODING_002" typeRef="boolean">
          <text>especialidadeCompativel</text>
        </inputExpression>
      </input>

      <input id="Input_4_AUTH_CODING_002" label="Grupo Procedimento">
        <inputExpression id="InputExpression_4_AUTH_CODING_002" typeRef="string">
          <text>grupoProcedimento</text>
        </inputExpression>
        <inputValues id="InputValues_4_AUTH_CODING_002">
          <text>"CIRURGICO", "DIAGNOSTICO", "TERAPEUTICO", "CLINICO"</text>
        </inputValues>
      </input>

      <output id="Output_1_AUTH_CODING_002" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_AUTH_CODING_002" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_AUTH_CODING_002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_AUTH_CODING_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_AUTH_CODING_002" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Bloqueio_1_AUTH_CODING_002">
        <description>Especialidade do profissional nao informada</description>
        <inputEntry id="InputEntry_B1_1_AUTH_CODING_002"><text>null</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_CODING_002"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_CODING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_AUTH_CODING_002"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_AUTH_CODING_002"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_AUTH_CODING_002"><text>"Especialidade do profissional nao informada."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_AUTH_CODING_002"><text>"Inserir especialidade do profissional executante."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_1_4_AUTH_CODING_002"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_1_5_AUTH_CODING_002"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Bloqueio_2_AUTH_CODING_002">
        <description>Especialidade incompativel com procedimento cirurgico</description>
        <inputEntry id="InputEntry_B2_1_AUTH_CODING_002"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_AUTH_CODING_002"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_AUTH_CODING_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_AUTH_CODING_002"><text>"CIRURGICO"</text></inputEntry>
        
      <outputEntry id="OutputEntry_B2_1_AUTH_CODING_002"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_2_AUTH_CODING_002"><text>"Especialidade incompativel com procedimento cirurgico."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_3_AUTH_CODING_002"><text>"Verificar habilitacao do profissional para o procedimento."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_2_4_AUTH_CODING_002"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_2_5_AUTH_CODING_002"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alerta_1_AUTH_CODING_002">
        <description>Especialidade incompativel com procedimento nao-cirurgico</description>
        <inputEntry id="InputEntry_AL1_1_AUTH_CODING_002"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_AL1_2_AUTH_CODING_002"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_AL1_3_AUTH_CODING_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_AL1_4_AUTH_CODING_002"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL1_1_AUTH_CODING_002"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_2_AUTH_CODING_002"><text>"Especialidade pode nao ser compativel com o procedimento."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_3_AUTH_CODING_002"><text>"Verificar se profissional esta habilitado."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_1_4_AUTH_CODING_002"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_1_5_AUTH_CODING_002"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_1_AUTH_CODING_002">
        <description>Especialidade compativel com procedimento</description>
        <inputEntry id="InputEntry_A1_1_AUTH_CODING_002"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_CODING_002"><text>not(null)</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_CODING_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_AUTH_CODING_002"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_AUTH_CODING_002"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_AUTH_CODING_002"><text>"Especialidade compativel com o tipo de procedimento."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_AUTH_CODING_002"><text>"Prosseguir com solicitacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_1_4_AUTH_CODING_002"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_1_5_AUTH_CODING_002"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_AUTH_CODING_002">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_CODING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_CODING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_CODING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_AUTH_CODING_002"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_AUTH_CODING_002"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_AUTH_CODING_002"><text>"Verificar compatibilidade especialidade-procedimento."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_AUTH_CODING_002"><text>"Consultar tabela de especialidades por procedimento."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_AUTH_CODING_002_4"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_AUTH_CODING_002_5"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_CODING_002">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_CODING_002" dmnElementRef="Decision_AUTH_CODING_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>