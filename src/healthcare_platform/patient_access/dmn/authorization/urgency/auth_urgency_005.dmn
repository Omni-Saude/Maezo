<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-URGENCY-005 - Validacao Extensao de Emergencia
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-URGENCY
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_URGENCY_005" name="Validacao Extensao de Emergencia" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_URGENCY_005" name="[SP-PA-004 | authorization/urgency] Validar Extensao de Emergencia" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_URGENCY_005" hitPolicy="FIRST">

      <input id="Input_1_AUTH_URGENCY_005" label="Horas Permanencia">
        <inputExpression id="InputExpression_1_AUTH_URGENCY_005" typeRef="number">
          <text>horasPermanencia</text>
        </inputExpression>
      </input>

      <input id="Input_2_AUTH_URGENCY_005" label="Justificativa Extensao">
        <inputExpression id="InputExpression_2_AUTH_URGENCY_005" typeRef="boolean">
          <text>justificativaExtensao</text>
        </inputExpression>
      </input>

      <input id="Input_3_AUTH_URGENCY_005" label="Transicao para Internacao">
        <inputExpression id="InputExpression_3_AUTH_URGENCY_005" typeRef="boolean">
          <text>transicaoParaInternacao</text>
        </inputExpression>
      </input>

      <input id="Input_4_AUTH_URGENCY_005" label="Autorizacao Internacao">
        <inputExpression id="InputExpression_4_AUTH_URGENCY_005" typeRef="boolean">
          <text>autorizacaoInternacao</text>
        </inputExpression>
      </input>

      <output id="Output_1_AUTH_URGENCY_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_AUTH_URGENCY_005" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_AUTH_URGENCY_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_AUTH_URGENCY_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_AUTH_URGENCY_005" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Aprovado_1_AUTH_URGENCY_005">
        <description>Dentro das primeiras 12h de observacao</description>
        <inputEntry id="InputEntry_A1_1_AUTH_URGENCY_005"><text>&lt;= 12</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_URGENCY_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_URGENCY_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_AUTH_URGENCY_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_AUTH_URGENCY_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_AUTH_URGENCY_005"><text>"Dentro do periodo inicial de observacao de emergencia."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_AUTH_URGENCY_005"><text>"Prosseguir com atendimento de emergencia."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_1_4_AUTH_URGENCY_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_1_5_AUTH_URGENCY_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_2_AUTH_URGENCY_005">
        <description>Extensao de emergencia com justificativa</description>
        <inputEntry id="InputEntry_A2_1_AUTH_URGENCY_005"><text>&gt; 12</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_AUTH_URGENCY_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_AUTH_URGENCY_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_AUTH_URGENCY_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A2_1_AUTH_URGENCY_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_2_AUTH_URGENCY_005"><text>"Extensao de emergencia justificada clinicamente."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_3_AUTH_URGENCY_005"><text>"Prosseguir com cobranca de observacao prolongada."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_2_4_AUTH_URGENCY_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_2_5_AUTH_URGENCY_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_3_AUTH_URGENCY_005">
        <description>Transicao para internacao autorizada</description>
        <inputEntry id="InputEntry_A3_1_AUTH_URGENCY_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_2_AUTH_URGENCY_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_3_AUTH_URGENCY_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A3_4_AUTH_URGENCY_005"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_A3_1_AUTH_URGENCY_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A3_2_AUTH_URGENCY_005"><text>"Transicao de emergencia para internacao autorizada."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A3_3_AUTH_URGENCY_005"><text>"Prosseguir com faturamento de internacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_3_4_AUTH_URGENCY_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_3_5_AUTH_URGENCY_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Alerta_1_AUTH_URGENCY_005">
        <description>Extensao alem de 12h sem justificativa</description>
        <inputEntry id="InputEntry_AL1_1_AUTH_URGENCY_005"><text>&gt; 12</text></inputEntry>
        <inputEntry id="InputEntry_AL1_2_AUTH_URGENCY_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_AL1_3_AUTH_URGENCY_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_AL1_4_AUTH_URGENCY_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL1_1_AUTH_URGENCY_005"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_2_AUTH_URGENCY_005"><text>"Permanencia alem de 12h requer justificativa clinica."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_3_AUTH_URGENCY_005"><text>"Documentar justificativa para extensao de observacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_1_4_AUTH_URGENCY_005"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_1_5_AUTH_URGENCY_005"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Bloqueio_1_AUTH_URGENCY_005">
        <description>Transicao para internacao sem autorizacao</description>
        <inputEntry id="InputEntry_B1_1_AUTH_URGENCY_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_URGENCY_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_URGENCY_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_AUTH_URGENCY_005"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_AUTH_URGENCY_005"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_AUTH_URGENCY_005"><text>"Transicao para internacao requer autorizacao especifica."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_AUTH_URGENCY_005"><text>"Solicitar autorizacao de internacao antes de prosseguir."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_1_4_AUTH_URGENCY_005"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_1_5_AUTH_URGENCY_005"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_AUTH_URGENCY_005">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_URGENCY_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_URGENCY_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_URGENCY_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_AUTH_URGENCY_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_AUTH_URGENCY_005"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_AUTH_URGENCY_005"><text>"Verificar necessidade de extensao de emergencia."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_AUTH_URGENCY_005"><text>"Analisar permanencia e necessidade de autorizacao adicional."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_AUTH_URGENCY_005_4"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_AUTH_URGENCY_005_5"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_URGENCY_005">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_URGENCY_005" dmnElementRef="Decision_AUTH_URGENCY_005">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>