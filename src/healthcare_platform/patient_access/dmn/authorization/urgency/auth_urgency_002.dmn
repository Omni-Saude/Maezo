<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-URGENCY-002 - Autorizacao Urgencia 24h
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-URGENCY
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_URGENCY_002" name="Autorizacao Urgencia 24h" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_URGENCY_002" name="[SP-PA-004 | authorization/urgency] Processar Autorizacao Urgencia 24h" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_URGENCY_002" hitPolicy="FIRST">

      <input id="Input_1_AUTH_URGENCY_002" label="Carater Atendimento">
        <inputExpression id="InputExpression_1_AUTH_URGENCY_002" typeRef="string">
          <text>caraterAtendimento</text>
        </inputExpression>
        <inputValues id="InputValues_1_AUTH_URGENCY_002">
          <text>"ELETIVO", "URGENCIA", "EMERGENCIA"</text>
        </inputValues>
      </input>

      <input id="Input_2_AUTH_URGENCY_002" label="Horas Desde Solicitacao">
        <inputExpression id="InputExpression_2_AUTH_URGENCY_002" typeRef="number">
          <text>horasDesdesolicitacao</text>
        </inputExpression>
      </input>

      <input id="Input_3_AUTH_URGENCY_002" label="Resposta Operadora">
        <inputExpression id="InputExpression_3_AUTH_URGENCY_002" typeRef="string">
          <text>respostaOperadora</text>
        </inputExpression>
        <inputValues id="InputValues_3_AUTH_URGENCY_002">
          <text>"APROVADO", "NEGADO", "PENDENTE", "SEM_RESPOSTA"</text>
        </inputValues>
      </input>

      <output id="Output_1_AUTH_URGENCY_002" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_AUTH_URGENCY_002" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_AUTH_URGENCY_002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_AUTH_URGENCY_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_AUTH_URGENCY_002" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Aprovado_1_AUTH_URGENCY_002">
        <description>Urgencia autorizada pela operadora</description>
        <inputEntry id="InputEntry_A1_1_AUTH_URGENCY_002"><text>"URGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_URGENCY_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_URGENCY_002"><text>"APROVADO"</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_AUTH_URGENCY_002"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_AUTH_URGENCY_002"><text>"Urgencia autorizada pela operadora."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_AUTH_URGENCY_002"><text>"Prosseguir com atendimento e faturamento."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_1_4_AUTH_URGENCY_002"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_1_5_AUTH_URGENCY_002"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_2_AUTH_URGENCY_002">
        <description>Sem resposta apos 24h - autorizacao tacita</description>
        <inputEntry id="InputEntry_A2_1_AUTH_URGENCY_002"><text>"URGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_AUTH_URGENCY_002"><text>&gt; 24</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_AUTH_URGENCY_002"><text>"SEM_RESPOSTA"</text></inputEntry>
        
      <outputEntry id="OutputEntry_A2_1_AUTH_URGENCY_002"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_2_AUTH_URGENCY_002"><text>"Autorizacao tacita por ausencia de resposta em 24h (RN 259/2011)."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_3_AUTH_URGENCY_002"><text>"Documentar ausencia de resposta e prosseguir com atendimento."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_2_4_AUTH_URGENCY_002"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_2_5_AUTH_URGENCY_002"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Alerta_1_AUTH_URGENCY_002">
        <description>Aguardando resposta dentro do prazo</description>
        <inputEntry id="InputEntry_AL1_1_AUTH_URGENCY_002"><text>"URGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_AL1_2_AUTH_URGENCY_002"><text>&lt;= 24</text></inputEntry>
        <inputEntry id="InputEntry_AL1_3_AUTH_URGENCY_002"><text>"PENDENTE", "SEM_RESPOSTA"</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL1_1_AUTH_URGENCY_002"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_2_AUTH_URGENCY_002"><text>"Aguardando resposta da operadora. Prazo de 24h em andamento."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_3_AUTH_URGENCY_002"><text>"Monitorar resposta e cobrar operadora se necessario."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_1_4_AUTH_URGENCY_002"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_1_5_AUTH_URGENCY_002"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Bloqueio_1_AUTH_URGENCY_002">
        <description>Urgencia negada pela operadora</description>
        <inputEntry id="InputEntry_B1_1_AUTH_URGENCY_002"><text>"URGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_URGENCY_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_URGENCY_002"><text>"NEGADO"</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_AUTH_URGENCY_002"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_AUTH_URGENCY_002"><text>"Urgencia negada pela operadora."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_AUTH_URGENCY_002"><text>"Analisar motivo e avaliar recurso ou nova solicitacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_1_4_AUTH_URGENCY_002"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_1_5_AUTH_URGENCY_002"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_AUTH_URGENCY_002">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_URGENCY_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_URGENCY_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_URGENCY_002"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_AUTH_URGENCY_002"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_AUTH_URGENCY_002"><text>"Verificar status de autorizacao de urgencia."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_AUTH_URGENCY_002"><text>"Consultar sistema da operadora para status atualizado."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_AUTH_URGENCY_002_4"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_AUTH_URGENCY_002_5"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_URGENCY_002">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_URGENCY_002" dmnElementRef="Decision_AUTH_URGENCY_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>