<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-URGENCY-004 - Documentacao Pos-Emergencia
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-URGENCY
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_URGENCY_004" name="Documentacao Pos-Emergencia" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_URGENCY_004" name="[SP-PA-004 | authorization/urgency] Validar Documentacao Pos-Emergencia" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_URGENCY_004" hitPolicy="FIRST">

      <input id="Input_1_AUTH_URGENCY_004" label="Tipo Atendimento Origem">
        <inputExpression id="InputExpression_1_AUTH_URGENCY_004" typeRef="string">
          <text>tipoAtendimentoOrigem</text>
        </inputExpression>
        <inputValues id="InputValues_1_AUTH_URGENCY_004">
          <text>"EMERGENCIA", "URGENCIA"</text>
        </inputValues>
      </input>

      <input id="Input_2_AUTH_URGENCY_004" label="Horas Desde Atendimento">
        <inputExpression id="InputExpression_2_AUTH_URGENCY_004" typeRef="number">
          <text>horasDesdeAtendimento</text>
        </inputExpression>
      </input>

      <input id="Input_3_AUTH_URGENCY_004" label="Documentacao Completa">
        <inputExpression id="InputExpression_3_AUTH_URGENCY_004" typeRef="boolean">
          <text>documentacaoCompleta</text>
        </inputExpression>
      </input>

      <input id="Input_4_AUTH_URGENCY_004" label="Regularizacao Solicitada">
        <inputExpression id="InputExpression_4_AUTH_URGENCY_004" typeRef="boolean">
          <text>regularizacaoSolicitada</text>
        </inputExpression>
      </input>

      <output id="Output_1_AUTH_URGENCY_004" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_AUTH_URGENCY_004" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_AUTH_URGENCY_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_AUTH_URGENCY_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_AUTH_URGENCY_004" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Aprovado_1_AUTH_URGENCY_004">
        <description>Documentacao pos-emergencia completa e regularizada</description>
        <inputEntry id="InputEntry_A1_1_AUTH_URGENCY_004"><text>"EMERGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_URGENCY_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_URGENCY_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_AUTH_URGENCY_004"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_AUTH_URGENCY_004"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_AUTH_URGENCY_004"><text>"Documentacao pos-emergencia completa. Regularizacao solicitada."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_AUTH_URGENCY_004"><text>"Prosseguir com faturamento."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_1_4_AUTH_URGENCY_004"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_1_5_AUTH_URGENCY_004"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Alerta_1_AUTH_URGENCY_004">
        <description>Prazo de regularizacao proximo de expirar</description>
        <inputEntry id="InputEntry_AL1_1_AUTH_URGENCY_004"><text>"EMERGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_AL1_2_AUTH_URGENCY_004"><text>[20..24]</text></inputEntry>
        <inputEntry id="InputEntry_AL1_3_AUTH_URGENCY_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_AL1_4_AUTH_URGENCY_004"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL1_1_AUTH_URGENCY_004"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_2_AUTH_URGENCY_004"><text>"URGENTE: Prazo de 24h para regularizacao proximo de expirar."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_3_AUTH_URGENCY_004"><text>"Solicitar regularizacao imediatamente."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_1_4_AUTH_URGENCY_004"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_1_5_AUTH_URGENCY_004"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Alerta_2_AUTH_URGENCY_004">
        <description>Documentacao pos-emergencia incompleta</description>
        <inputEntry id="InputEntry_AL2_1_AUTH_URGENCY_004"><text>"EMERGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_AL2_2_AUTH_URGENCY_004"><text>&lt; 20</text></inputEntry>
        <inputEntry id="InputEntry_AL2_3_AUTH_URGENCY_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_AL2_4_AUTH_URGENCY_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL2_1_AUTH_URGENCY_004"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL2_2_AUTH_URGENCY_004"><text>"Documentacao pos-emergencia incompleta. Prazo em andamento."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL2_3_AUTH_URGENCY_004"><text>"Completar documentacao de emergencia."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_2_4_AUTH_URGENCY_004"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_2_5_AUTH_URGENCY_004"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Bloqueio_1_AUTH_URGENCY_004">
        <description>Prazo de regularizacao expirado</description>
        <inputEntry id="InputEntry_B1_1_AUTH_URGENCY_004"><text>"EMERGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_URGENCY_004"><text>&gt; 24</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_URGENCY_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_AUTH_URGENCY_004"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_AUTH_URGENCY_004"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_AUTH_URGENCY_004"><text>"Prazo de 24h para regularizacao expirado sem solicitacao."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_AUTH_URGENCY_004"><text>"Justificar atraso e solicitar regularizacao extraordinaria."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_1_4_AUTH_URGENCY_004"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_1_5_AUTH_URGENCY_004"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_AUTH_URGENCY_004">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_URGENCY_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_URGENCY_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_URGENCY_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_AUTH_URGENCY_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_AUTH_URGENCY_004"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_AUTH_URGENCY_004"><text>"Verificar documentacao pos-emergencia."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_AUTH_URGENCY_004"><text>"Consultar prontuario e documentacao do atendimento."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_AUTH_URGENCY_004_4"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_AUTH_URGENCY_004_5"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_URGENCY_004">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_URGENCY_004" dmnElementRef="Decision_AUTH_URGENCY_004">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>