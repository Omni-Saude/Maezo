<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-URGENCY-003 - Bypass por Condicao Risco de Vida
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-URGENCY
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_URGENCY_003" name="Bypass por Condicao Risco de Vida" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_URGENCY_003" name="[SP-PA-004 | authorization/urgency] Aplicar Bypass por Risco de Vida" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_URGENCY_003" hitPolicy="FIRST">

      <input id="Input_1_AUTH_URGENCY_003" label="Risco de Vida">
        <inputExpression id="InputExpression_1_AUTH_URGENCY_003" typeRef="boolean">
          <text>riscoVida</text>
        </inputExpression>
      </input>

      <input id="Input_2_AUTH_URGENCY_003" label="Classificacao Manchester">
        <inputExpression id="InputExpression_2_AUTH_URGENCY_003" typeRef="string">
          <text>classificacaoManchester</text>
        </inputExpression>
        <inputValues id="InputValues_2_AUTH_URGENCY_003">
          <text>"VERMELHO", "LARANJA", "AMARELO", "VERDE", "AZUL"</text>
        </inputValues>
      </input>

      <input id="Input_3_AUTH_URGENCY_003" label="Documentacao Clinica">
        <inputExpression id="InputExpression_3_AUTH_URGENCY_003" typeRef="boolean">
          <text>documentacaoClinica</text>
        </inputExpression>
      </input>

      <input id="Input_4_AUTH_URGENCY_003" label="CID Emergencial">
        <inputExpression id="InputExpression_4_AUTH_URGENCY_003" typeRef="boolean">
          <text>cidEmergencial</text>
        </inputExpression>
      </input>

      <output id="Output_1_AUTH_URGENCY_003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_AUTH_URGENCY_003" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_AUTH_URGENCY_003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_AUTH_URGENCY_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_AUTH_URGENCY_003" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Aprovado_1_AUTH_URGENCY_003">
        <description>Classificacao Manchester vermelho - bypass imediato</description>
        <inputEntry id="InputEntry_A1_1_AUTH_URGENCY_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_URGENCY_003"><text>"VERMELHO"</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_URGENCY_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_AUTH_URGENCY_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_AUTH_URGENCY_003"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_AUTH_URGENCY_003"><text>"Bypass por risco de vida. Classificacao Manchester vermelho."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_AUTH_URGENCY_003"><text>"Atender imediatamente. Documentar e regularizar posteriormente."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_1_4_AUTH_URGENCY_003"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_1_5_AUTH_URGENCY_003"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_2_AUTH_URGENCY_003">
        <description>Classificacao Manchester laranja com risco de vida</description>
        <inputEntry id="InputEntry_A2_1_AUTH_URGENCY_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_AUTH_URGENCY_003"><text>"LARANJA"</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_AUTH_URGENCY_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_AUTH_URGENCY_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A2_1_AUTH_URGENCY_003"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_2_AUTH_URGENCY_003"><text>"Bypass por risco de vida. Manchester laranja com documentacao."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_3_AUTH_URGENCY_003"><text>"Atender e documentar risco de vida para regularizacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_2_4_AUTH_URGENCY_003"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_2_5_AUTH_URGENCY_003"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_3_AUTH_URGENCY_003">
        <description>CID classifica como emergencia</description>
        <inputEntry id="InputEntry_A3_1_AUTH_URGENCY_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A3_2_AUTH_URGENCY_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_3_AUTH_URGENCY_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A3_4_AUTH_URGENCY_003"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_A3_1_AUTH_URGENCY_003"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A3_2_AUTH_URGENCY_003"><text>"Bypass por CID emergencial com risco de vida documentado."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A3_3_AUTH_URGENCY_003"><text>"Atender e anexar documentacao clinica para regularizacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_3_4_AUTH_URGENCY_003"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_3_5_AUTH_URGENCY_003"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Alerta_1_AUTH_URGENCY_003">
        <description>Alegacao de risco sem documentacao adequada</description>
        <inputEntry id="InputEntry_AL1_1_AUTH_URGENCY_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_AL1_2_AUTH_URGENCY_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_AL1_3_AUTH_URGENCY_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_AL1_4_AUTH_URGENCY_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL1_1_AUTH_URGENCY_003"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_2_AUTH_URGENCY_003"><text>"Risco de vida alegado mas documentacao incompleta."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_3_AUTH_URGENCY_003"><text>"Documentar condicao clinica detalhadamente."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_1_4_AUTH_URGENCY_003"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_1_5_AUTH_URGENCY_003"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Bloqueio_1_AUTH_URGENCY_003">
        <description>Sem risco de vida documentado</description>
        <inputEntry id="InputEntry_B1_1_AUTH_URGENCY_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_URGENCY_003"><text>"VERDE", "AZUL"</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_URGENCY_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_AUTH_URGENCY_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_AUTH_URGENCY_003"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_AUTH_URGENCY_003"><text>"Bypass por risco de vida nao aplicavel. Sem risco documentado."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_AUTH_URGENCY_003"><text>"Seguir fluxo normal de autorizacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_1_4_AUTH_URGENCY_003"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_1_5_AUTH_URGENCY_003"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_AUTH_URGENCY_003">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_URGENCY_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_URGENCY_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_URGENCY_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_AUTH_URGENCY_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_AUTH_URGENCY_003"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_AUTH_URGENCY_003"><text>"Avaliar condicao de risco de vida."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_AUTH_URGENCY_003"><text>"Solicitar avaliacao medica para classificacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_AUTH_URGENCY_003_4"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_AUTH_URGENCY_003_5"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_URGENCY_003">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_URGENCY_003" dmnElementRef="Decision_AUTH_URGENCY_003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>