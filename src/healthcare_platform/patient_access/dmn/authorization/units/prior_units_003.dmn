<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  PRIOR-UNITS-003 - Excedente Nao Autorizado
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: PRIOR-UNITS
  Perspectiva: HOSPITAL (Faturamento/Auditoria)

  ============================================================================
  INDICACOES (Quando PROSSEGUIR):
  ============================================================================
  - Excedente com justificativa clinica
  - Documentacao de emergencia presente
  - Anuencia tacita da operadora

  ============================================================================
  CONTRAINDICACOES (Quando BLOQUEAR):
  ============================================================================
  - Excedente sem justificativa
  - Falta documentacao clinica
  - Procedimento eletivo sem autorizacao

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - RN 424/2017 (Autorizacao Previa)
  - RN 465/2021 (Procedimentos Regulados)
  - RN 259/2011 (Autorizacao Tacita)
  - Lei 9.656/1998 Art. 12 (Cobertura Obrigatoria)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_PRIOR_UNITS_003"
             name="Excedente Nao Autorizado"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_PRIOR_UNITS_003" name="[SP-PA-004 | authorization/units] Verificar Excedente Nao Autorizado" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_PRIOR_UNITS_003" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_PRIOR_UNITS_003" label="Sessoes Excedentes">
        <inputExpression id="InputExpression_1_PRIOR_UNITS_003" typeRef="integer">
          <text>sessoesExcedentes</text>
        </inputExpression>
      </input>

      <input id="Input_2_PRIOR_UNITS_003" label="Tem Justificativa">
        <inputExpression id="InputExpression_2_PRIOR_UNITS_003" typeRef="boolean">
          <text>temJustificativa</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_PRIOR_UNITS_003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_PRIOR_UNITS_003" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_PRIOR_UNITS_003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_PRIOR_UNITS_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_PRIOR_UNITS_003" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA B1: Bloqueio - Excedente sem justificativa -->
      <rule id="Rule_Bloqueio_1_PRIOR_UNITS_003">
        <description>Sessoes excedentes sem justificativa clinica</description>
        <inputEntry id="InputEntry_B1_1_PRIOR_UNITS_003"><text>&gt; 0</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_PRIOR_UNITS_003"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_B1_1_PRIOR_UNITS_003"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_2_PRIOR_UNITS_003"><text>"Sessoes excedentes ao autorizado sem justificativa clinica. Faturamento bloqueado."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_3_PRIOR_UNITS_003"><text>"Providenciar justificativa clinica robusta ou solicitar autorizacao para sessoes excedentes."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_4_PRIOR_UNITS_003"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_5_PRIOR_UNITS_003"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA A1: Alerta - Excedente com justificativa -->
      <rule id="Rule_Alerta_1_PRIOR_UNITS_003">
        <description>Sessoes excedentes com justificativa presente</description>
        <inputEntry id="InputEntry_A1_1_PRIOR_UNITS_003"><text>&gt; 0</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_PRIOR_UNITS_003"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_A1_1_PRIOR_UNITS_003"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_2_PRIOR_UNITS_003"><text>"Sessoes excedentes ao autorizado. Justificativa clinica presente."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_3_PRIOR_UNITS_003"><text>"Faturar sessoes excedentes com justificativa anexa. Risco de glosa parcial. Considerar recurso se negado."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_4_PRIOR_UNITS_003"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_5_PRIOR_UNITS_003"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA P1: Aprovado - Sem excedentes -->
      <rule id="Rule_Aprovado_1_PRIOR_UNITS_003">
        <description>Nenhuma sessao excedente</description>
        <inputEntry id="InputEntry_P1_1_PRIOR_UNITS_003"><text>&lt;= 0</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_PRIOR_UNITS_003"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_PRIOR_UNITS_003"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_2_PRIOR_UNITS_003"><text>"Sem sessoes excedentes ao autorizado. Dentro do limite."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_3_PRIOR_UNITS_003"><text>"Prosseguir com faturamento das sessoes autorizadas."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_4_PRIOR_UNITS_003"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_5_PRIOR_UNITS_003"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisao manual -->
      <rule id="Rule_Fallback_PRIOR_UNITS_003">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_PRIOR_UNITS_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_PRIOR_UNITS_003"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_PRIOR_UNITS_003"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_PRIOR_UNITS_003"><text>"Situacao de sessoes excedentes requer analise manual."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_PRIOR_UNITS_003"><text>"Encaminhar para auditoria avaliar justificativa de sessoes excedentes."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_PRIOR_UNITS_003"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_PRIOR_UNITS_003"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PRIOR_UNITS_003">
      <dmndi:DMNShape id="DMNShape_Decision_PRIOR_UNITS_003" dmnElementRef="Decision_PRIOR_UNITS_003">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
