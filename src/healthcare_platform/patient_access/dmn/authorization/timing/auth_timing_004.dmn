<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-TIMING-004 - Bloqueio por Autorizacao Expirada
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-TIMING
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_TIMING_004" name="Bloqueio por Autorizacao Expirada" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_TIMING_004" name="[SP-PA-004 | authorization/timing] Bloquear Autorizacao Expirada" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_TIMING_004" hitPolicy="FIRST">

      <input id="Input_1_AUTH_TIMING_004" label="Dias Ate Vencimento">
        <inputExpression id="InputExpression_1_AUTH_TIMING_004" typeRef="number">
          <text>diasAteVencimento</text>
        </inputExpression>
      </input>

      <input id="Input_2_AUTH_TIMING_004" label="Extensao Aprovada">
        <inputExpression id="InputExpression_2_AUTH_TIMING_004" typeRef="boolean">
          <text>extensaoAprovada</text>
        </inputExpression>
      </input>

      <input id="Input_3_AUTH_TIMING_004" label="Carater Atendimento">
        <inputExpression id="InputExpression_3_AUTH_TIMING_004" typeRef="string">
          <text>caraterAtendimento</text>
        </inputExpression>
        <inputValues id="InputValues_3_AUTH_TIMING_004">
          <text>"ELETIVO", "URGENCIA", "EMERGENCIA"</text>
        </inputValues>
      </input>

      <input id="Input_4_AUTH_TIMING_004" label="Regularizacao Posterior">
        <inputExpression id="InputExpression_4_AUTH_TIMING_004" typeRef="boolean">
          <text>regularizacaoPosterior</text>
        </inputExpression>
      </input>

      <output id="Output_1_AUTH_TIMING_004" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_AUTH_TIMING_004" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_AUTH_TIMING_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_AUTH_TIMING_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_AUTH_TIMING_004" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Aprovado_1_AUTH_TIMING_004">
        <description>Autorizacao vencida mas extensao aprovada</description>
        <inputEntry id="InputEntry_A1_1_AUTH_TIMING_004"><text>&lt; 0</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_TIMING_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_TIMING_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_AUTH_TIMING_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_AUTH_TIMING_004"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_AUTH_TIMING_004"><text>"Autorizacao vencida mas extensao foi aprovada pela operadora."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_AUTH_TIMING_004"><text>"Utilizar numero da extensao no faturamento."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_1_4_AUTH_TIMING_004"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_1_5_AUTH_TIMING_004"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_2_AUTH_TIMING_004">
        <description>Atendimento de emergencia com regularizacao posterior</description>
        <inputEntry id="InputEntry_A2_1_AUTH_TIMING_004"><text>&lt; 0</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_AUTH_TIMING_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_AUTH_TIMING_004"><text>"EMERGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_AUTH_TIMING_004"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_A2_1_AUTH_TIMING_004"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_2_AUTH_TIMING_004"><text>"Atendimento de emergencia com autorizacao regularizada posteriormente."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_3_AUTH_TIMING_004"><text>"Anexar documentacao de regularizacao ao faturamento."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_2_4_AUTH_TIMING_004"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_2_5_AUTH_TIMING_004"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Bloqueio_1_AUTH_TIMING_004">
        <description>Autorizacao vencida sem extensao para procedimento eletivo</description>
        <inputEntry id="InputEntry_B1_1_AUTH_TIMING_004"><text>&lt; 0</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_TIMING_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_TIMING_004"><text>"ELETIVO"</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_AUTH_TIMING_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_AUTH_TIMING_004"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_AUTH_TIMING_004"><text>"Autorizacao expirada. Procedimento eletivo nao pode ser faturado."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_AUTH_TIMING_004"><text>"Solicitar nova autorizacao para o procedimento."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_1_4_AUTH_TIMING_004"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_1_5_AUTH_TIMING_004"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alerta_1_AUTH_TIMING_004">
        <description>Atendimento de urgencia aguardando regularizacao</description>
        <inputEntry id="InputEntry_AL1_1_AUTH_TIMING_004"><text>&lt; 0</text></inputEntry>
        <inputEntry id="InputEntry_AL1_2_AUTH_TIMING_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_AL1_3_AUTH_TIMING_004"><text>"URGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_AL1_4_AUTH_TIMING_004"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL1_1_AUTH_TIMING_004"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_2_AUTH_TIMING_004"><text>"Atendimento de urgencia com autorizacao vencida. Regularizacao necessaria."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_3_AUTH_TIMING_004"><text>"Solicitar regularizacao retroativa junto a operadora."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_1_4_AUTH_TIMING_004"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_1_5_AUTH_TIMING_004"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_3_AUTH_TIMING_004">
        <description>Autorizacao dentro da validade</description>
        <inputEntry id="InputEntry_A3_1_AUTH_TIMING_004"><text>&gt;= 0</text></inputEntry>
        <inputEntry id="InputEntry_A3_2_AUTH_TIMING_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_3_AUTH_TIMING_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_4_AUTH_TIMING_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A3_1_AUTH_TIMING_004"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A3_2_AUTH_TIMING_004"><text>"Autorizacao dentro do prazo de validade."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A3_3_AUTH_TIMING_004"><text>"Prosseguir com faturamento."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_3_4_AUTH_TIMING_004"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_3_5_AUTH_TIMING_004"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_AUTH_TIMING_004">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_TIMING_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_TIMING_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_TIMING_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_AUTH_TIMING_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_AUTH_TIMING_004"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_AUTH_TIMING_004"><text>"Situacao de autorizacao expirada requer analise manual."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_AUTH_TIMING_004"><text>"Verificar possibilidade de extensao ou regularizacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_AUTH_TIMING_004_4"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_AUTH_TIMING_004_5"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_TIMING_004">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_TIMING_004" dmnElementRef="Decision_AUTH_TIMING_004">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>