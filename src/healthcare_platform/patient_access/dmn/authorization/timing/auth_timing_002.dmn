<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-TIMING-002 - Data do Servico Dentro da Janela Autorizada
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-TIMING
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_TIMING_002" name="Data do Servico Dentro da Janela Autorizada" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_TIMING_002" name="[SP-PA-004 | authorization/timing] Verificar Data do Servico na Janela Autorizada" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_TIMING_002" hitPolicy="FIRST">

      <input id="Input_1_AUTH_TIMING_002" label="Data Atendimento">
        <inputExpression id="InputExpression_1_AUTH_TIMING_002" typeRef="date">
          <text>dataAtendimento</text>
        </inputExpression>
      </input>

      <input id="Input_2_AUTH_TIMING_002" label="Data Prevista Atendimento">
        <inputExpression id="InputExpression_2_AUTH_TIMING_002" typeRef="date">
          <text>dataPrevistaAtendimento</text>
        </inputExpression>
      </input>

      <input id="Input_3_AUTH_TIMING_002" label="Dias Diferenca">
        <inputExpression id="InputExpression_3_AUTH_TIMING_002" typeRef="number">
          <text>diasDiferenca</text>
        </inputExpression>
      </input>

      <input id="Input_4_AUTH_TIMING_002" label="Tolerancia Dias">
        <inputExpression id="InputExpression_4_AUTH_TIMING_002" typeRef="number">
          <text>toleranciaDias</text>
        </inputExpression>
      </input>

      <output id="Output_1_AUTH_TIMING_002" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_AUTH_TIMING_002" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_AUTH_TIMING_002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_AUTH_TIMING_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_AUTH_TIMING_002" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Bloqueio_1_AUTH_TIMING_002">
        <description>Data do atendimento fora da tolerancia autorizada</description>
        <inputEntry id="InputEntry_B1_1_AUTH_TIMING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_TIMING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_TIMING_002"><text>&gt; 30</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_AUTH_TIMING_002"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_AUTH_TIMING_002"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_AUTH_TIMING_002"><text>"Data do atendimento diverge mais de 30 dias da data autorizada."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_AUTH_TIMING_002"><text>"Solicitar nova autorizacao com data correta."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_1_4_AUTH_TIMING_002"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_1_5_AUTH_TIMING_002"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alerta_1_AUTH_TIMING_002">
        <description>Data do atendimento com diferenca significativa</description>
        <inputEntry id="InputEntry_AL1_1_AUTH_TIMING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_AL1_2_AUTH_TIMING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_AL1_3_AUTH_TIMING_002"><text>[8..30]</text></inputEntry>
        <inputEntry id="InputEntry_AL1_4_AUTH_TIMING_002"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL1_1_AUTH_TIMING_002"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_2_AUTH_TIMING_002"><text>"Data do atendimento diverge da data prevista. Verificar se aceitavel."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_3_AUTH_TIMING_002"><text>"Confirmar aceite da data pela operadora ou justificar."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_1_4_AUTH_TIMING_002"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_1_5_AUTH_TIMING_002"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_1_AUTH_TIMING_002">
        <description>Data do atendimento dentro da tolerancia</description>
        <inputEntry id="InputEntry_A1_1_AUTH_TIMING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_TIMING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_TIMING_002"><text>[-7..7]</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_AUTH_TIMING_002"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_AUTH_TIMING_002"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_AUTH_TIMING_002"><text>"Data do atendimento dentro da janela autorizada."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_AUTH_TIMING_002"><text>"Prosseguir com faturamento."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_1_4_AUTH_TIMING_002"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_1_5_AUTH_TIMING_002"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_AUTH_TIMING_002">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_TIMING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_TIMING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_TIMING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_AUTH_TIMING_002"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_AUTH_TIMING_002"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_AUTH_TIMING_002"><text>"Nao foi possivel validar janela de atendimento."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_AUTH_TIMING_002"><text>"Verificar datas de autorizacao e atendimento."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_AUTH_TIMING_002_4"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_AUTH_TIMING_002_5"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_TIMING_002">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_TIMING_002" dmnElementRef="Decision_AUTH_TIMING_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>