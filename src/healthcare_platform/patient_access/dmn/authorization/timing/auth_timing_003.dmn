<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-TIMING-003 - Alerta Vencimento Proximo
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-TIMING
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_TIMING_003" name="Alerta Vencimento Proximo" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_TIMING_003" name="[SP-PA-004 | authorization/timing] Alertar Vencimento Proximo" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_TIMING_003" hitPolicy="FIRST">

      <input id="Input_1_AUTH_TIMING_003" label="Dias Ate Vencimento">
        <inputExpression id="InputExpression_1_AUTH_TIMING_003" typeRef="number">
          <text>diasAteVencimento</text>
        </inputExpression>
      </input>

      <input id="Input_2_AUTH_TIMING_003" label="Procedimento Agendado">
        <inputExpression id="InputExpression_2_AUTH_TIMING_003" typeRef="boolean">
          <text>procedimentoAgendado</text>
        </inputExpression>
      </input>

      <input id="Input_3_AUTH_TIMING_003" label="Extensao Solicitada">
        <inputExpression id="InputExpression_3_AUTH_TIMING_003" typeRef="boolean">
          <text>extensaoSolicitada</text>
        </inputExpression>
      </input>

      <output id="Output_1_AUTH_TIMING_003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_AUTH_TIMING_003" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_AUTH_TIMING_003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_AUTH_TIMING_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_AUTH_TIMING_003" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Bloqueio_1_AUTH_TIMING_003">
        <description>Autorizacao ja vencida</description>
        <inputEntry id="InputEntry_B1_1_AUTH_TIMING_003"><text>&lt; 0</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_TIMING_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_TIMING_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_AUTH_TIMING_003"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_AUTH_TIMING_003"><text>"Autorizacao ja vencida."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_AUTH_TIMING_003"><text>"Solicitar nova autorizacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_1_4_AUTH_TIMING_003"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_1_5_AUTH_TIMING_003"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alerta_1_AUTH_TIMING_003">
        <description>Autorizacao vence em ate 2 dias</description>
        <inputEntry id="InputEntry_AL1_1_AUTH_TIMING_003"><text>[0..2]</text></inputEntry>
        <inputEntry id="InputEntry_AL1_2_AUTH_TIMING_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_AL1_3_AUTH_TIMING_003"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL1_1_AUTH_TIMING_003"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_2_AUTH_TIMING_003"><text>"URGENTE: Autorizacao vence em ate 2 dias. Acao imediata necessaria."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_3_AUTH_TIMING_003"><text>"Agendar procedimento imediatamente ou solicitar extensao urgente."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_1_4_AUTH_TIMING_003"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_1_5_AUTH_TIMING_003"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Alerta_2_AUTH_TIMING_003">
        <description>Autorizacao vence em ate 7 dias</description>
        <inputEntry id="InputEntry_AL2_1_AUTH_TIMING_003"><text>[3..7]</text></inputEntry>
        <inputEntry id="InputEntry_AL2_2_AUTH_TIMING_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_AL2_3_AUTH_TIMING_003"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL2_1_AUTH_TIMING_003"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL2_2_AUTH_TIMING_003"><text>"Autorizacao vence em ate 7 dias. Priorizar agendamento."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL2_3_AUTH_TIMING_003"><text>"Agendar procedimento ou iniciar solicitacao de extensao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_2_4_AUTH_TIMING_003"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_2_5_AUTH_TIMING_003"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_1_AUTH_TIMING_003">
        <description>Autorizacao proxima do vencimento mas ja agendado</description>
        <inputEntry id="InputEntry_A1_1_AUTH_TIMING_003"><text>[0..7]</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_TIMING_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_TIMING_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_AUTH_TIMING_003"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_AUTH_TIMING_003"><text>"Autorizacao proxima do vencimento porem procedimento ja agendado."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_AUTH_TIMING_003"><text>"Confirmar realizacao do procedimento na data agendada."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_1_4_AUTH_TIMING_003"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_1_5_AUTH_TIMING_003"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_2_AUTH_TIMING_003">
        <description>Autorizacao proxima do vencimento mas extensao ja solicitada</description>
        <inputEntry id="InputEntry_A2_1_AUTH_TIMING_003"><text>[0..7]</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_AUTH_TIMING_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_AUTH_TIMING_003"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_A2_1_AUTH_TIMING_003"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_2_AUTH_TIMING_003"><text>"Extensao de autorizacao ja solicitada."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_3_AUTH_TIMING_003"><text>"Acompanhar resposta da solicitacao de extensao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_2_4_AUTH_TIMING_003"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_2_5_AUTH_TIMING_003"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_3_AUTH_TIMING_003">
        <description>Autorizacao com prazo confortavel</description>
        <inputEntry id="InputEntry_A3_1_AUTH_TIMING_003"><text>&gt; 7</text></inputEntry>
        <inputEntry id="InputEntry_A3_2_AUTH_TIMING_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_3_AUTH_TIMING_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A3_1_AUTH_TIMING_003"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A3_2_AUTH_TIMING_003"><text>"Autorizacao dentro do prazo de validade."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A3_3_AUTH_TIMING_003"><text>"Prosseguir com agendamento normal."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_3_4_AUTH_TIMING_003"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_3_5_AUTH_TIMING_003"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_AUTH_TIMING_003">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_TIMING_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_TIMING_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_TIMING_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_AUTH_TIMING_003"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_AUTH_TIMING_003"><text>"Situacao de vencimento requer analise manual."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_AUTH_TIMING_003"><text>"Verificar prazo e status de agendamento."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_AUTH_TIMING_003_4"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_AUTH_TIMING_003_5"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_TIMING_003">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_TIMING_003" dmnElementRef="Decision_AUTH_TIMING_003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>