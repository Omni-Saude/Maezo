<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-TIMING-001 - Autorizacao Dentro do Periodo de Validade
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-TIMING
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_TIMING_001" name="Autorizacao Dentro do Periodo de Validade" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_TIMING_001" name="[SP-PA-004 | authorization/timing] Verificar Autorizacao no Periodo de Validade" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_TIMING_001" hitPolicy="FIRST">

      <input id="Input_1_AUTH_TIMING_001" label="Dias Desde Autorizacao">
        <inputExpression id="InputExpression_1_AUTH_TIMING_001" typeRef="number">
          <text>diasDesdeAutorizacao</text>
        </inputExpression>
      </input>

      <input id="Input_2_AUTH_TIMING_001" label="Dias Ate Vencimento">
        <inputExpression id="InputExpression_2_AUTH_TIMING_001" typeRef="number">
          <text>diasAteVencimento</text>
        </inputExpression>
      </input>

      <input id="Input_3_AUTH_TIMING_001" label="Prazo Validade Dias">
        <inputExpression id="InputExpression_3_AUTH_TIMING_001" typeRef="number">
          <text>prazoValidadeDias</text>
        </inputExpression>
      </input>

      <output id="Output_1_AUTH_TIMING_001" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_AUTH_TIMING_001" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_AUTH_TIMING_001" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_AUTH_TIMING_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_AUTH_TIMING_001" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Bloqueio_1_AUTH_TIMING_001">
        <description>Atendimento apos vencimento da autorizacao</description>
        <inputEntry id="InputEntry_B1_1_AUTH_TIMING_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_TIMING_001"><text>&lt; 0</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_TIMING_001"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_AUTH_TIMING_001"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_AUTH_TIMING_001"><text>"Atendimento realizado apos vencimento da autorizacao."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_AUTH_TIMING_001"><text>"Solicitar nova autorizacao ou justificar atraso junto a operadora."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_1_4_AUTH_TIMING_001"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_1_5_AUTH_TIMING_001"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Bloqueio_2_AUTH_TIMING_001">
        <description>Atendimento anterior a data de autorizacao</description>
        <inputEntry id="InputEntry_B2_1_AUTH_TIMING_001"><text>&lt; 0</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_AUTH_TIMING_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_AUTH_TIMING_001"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B2_1_AUTH_TIMING_001"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_2_AUTH_TIMING_001"><text>"Data do atendimento anterior a data de autorizacao."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_3_AUTH_TIMING_001"><text>"Verificar datas ou solicitar autorizacao retroativa."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_2_4_AUTH_TIMING_001"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_2_5_AUTH_TIMING_001"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_1_AUTH_TIMING_001">
        <description>Atendimento dentro do periodo de validade</description>
        <inputEntry id="InputEntry_A1_1_AUTH_TIMING_001"><text>&gt;= 0</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_TIMING_001"><text>&gt;= 0</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_TIMING_001"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_AUTH_TIMING_001"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_AUTH_TIMING_001"><text>"Atendimento dentro do periodo de validade da autorizacao."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_AUTH_TIMING_001"><text>"Prosseguir com faturamento."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_1_4_AUTH_TIMING_001"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_1_5_AUTH_TIMING_001"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_AUTH_TIMING_001">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_TIMING_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_TIMING_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_TIMING_001"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_AUTH_TIMING_001"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_AUTH_TIMING_001"><text>"Nao foi possivel determinar validade temporal."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_AUTH_TIMING_001"><text>"Verificar datas de autorizacao e atendimento."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_AUTH_TIMING_001_4"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_AUTH_TIMING_001_5"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_TIMING_001">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_TIMING_001" dmnElementRef="Decision_AUTH_TIMING_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>