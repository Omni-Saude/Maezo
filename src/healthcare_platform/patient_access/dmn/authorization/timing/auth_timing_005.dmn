<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-TIMING-005 - Validacao Timing de Solicitacao de Extensao
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-TIMING
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_TIMING_005" name="Validacao Timing de Solicitacao de Extensao" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_TIMING_005" name="[SP-PA-004 | authorization/timing] Validar Timing de Solicitacao de Extensao" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_TIMING_005" hitPolicy="FIRST">

      <input id="Input_1_AUTH_TIMING_005" label="Dias Ate Vencimento">
        <inputExpression id="InputExpression_1_AUTH_TIMING_005" typeRef="number">
          <text>diasAteVencimento</text>
        </inputExpression>
      </input>

      <input id="Input_2_AUTH_TIMING_005" label="Extensao Ja Solicitada">
        <inputExpression id="InputExpression_2_AUTH_TIMING_005" typeRef="boolean">
          <text>extensaoJaSolicitada</text>
        </inputExpression>
      </input>

      <input id="Input_3_AUTH_TIMING_005" label="Dias Desde Solicitacao">
        <inputExpression id="InputExpression_3_AUTH_TIMING_005" typeRef="number">
          <text>diasDesdeSolicitacao</text>
        </inputExpression>
      </input>

      <input id="Input_4_AUTH_TIMING_005" label="Prazo Resposta Operadora">
        <inputExpression id="InputExpression_4_AUTH_TIMING_005" typeRef="number">
          <text>prazoRespostaOperadora</text>
        </inputExpression>
      </input>

      <output id="Output_1_AUTH_TIMING_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_AUTH_TIMING_005" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_AUTH_TIMING_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_AUTH_TIMING_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_AUTH_TIMING_005" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Bloqueio_1_AUTH_TIMING_005">
        <description>Autorizacao vencida e extensao nao foi solicitada</description>
        <inputEntry id="InputEntry_B1_1_AUTH_TIMING_005"><text>&lt; 0</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_TIMING_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_TIMING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_AUTH_TIMING_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_AUTH_TIMING_005"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_AUTH_TIMING_005"><text>"Autorizacao vencida e extensao nao foi solicitada a tempo."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_AUTH_TIMING_005"><text>"Solicitar nova autorizacao. Extensao nao mais viavel."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_1_4_AUTH_TIMING_005"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_1_5_AUTH_TIMING_005"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alerta_1_AUTH_TIMING_005">
        <description>Extensao solicitada tardiamente ainda em analise</description>
        <inputEntry id="InputEntry_AL1_1_AUTH_TIMING_005"><text>&lt; 0</text></inputEntry>
        <inputEntry id="InputEntry_AL1_2_AUTH_TIMING_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_AL1_3_AUTH_TIMING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_AL1_4_AUTH_TIMING_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL1_1_AUTH_TIMING_005"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_2_AUTH_TIMING_005"><text>"Extensao solicitada apos vencimento. Aguardando resposta da operadora."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_3_AUTH_TIMING_005"><text>"Cobrar resposta urgente da operadora sobre extensao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_1_4_AUTH_TIMING_005"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_1_5_AUTH_TIMING_005"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Alerta_2_AUTH_TIMING_005">
        <description>Vencimento proximo e extensao nao solicitada</description>
        <inputEntry id="InputEntry_AL2_1_AUTH_TIMING_005"><text>[0..5]</text></inputEntry>
        <inputEntry id="InputEntry_AL2_2_AUTH_TIMING_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_AL2_3_AUTH_TIMING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_AL2_4_AUTH_TIMING_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL2_1_AUTH_TIMING_005"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL2_2_AUTH_TIMING_005"><text>"Autorizacao vence em breve. Solicitar extensao imediatamente."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL2_3_AUTH_TIMING_005"><text>"Iniciar processo de extensao com urgencia."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_2_4_AUTH_TIMING_005"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_2_5_AUTH_TIMING_005"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_1_AUTH_TIMING_005">
        <description>Extensao ja solicitada dentro do prazo</description>
        <inputEntry id="InputEntry_A1_1_AUTH_TIMING_005"><text>&gt;= 0</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_TIMING_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_TIMING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_AUTH_TIMING_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_AUTH_TIMING_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_AUTH_TIMING_005"><text>"Extensao de autorizacao ja solicitada dentro do prazo."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_AUTH_TIMING_005"><text>"Acompanhar resposta da operadora."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_1_4_AUTH_TIMING_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_1_5_AUTH_TIMING_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_2_AUTH_TIMING_005">
        <description>Prazo confortavel para solicitar extensao se necessario</description>
        <inputEntry id="InputEntry_A2_1_AUTH_TIMING_005"><text>&gt; 5</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_AUTH_TIMING_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_AUTH_TIMING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_AUTH_TIMING_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A2_1_AUTH_TIMING_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_2_AUTH_TIMING_005"><text>"Prazo adequado para solicitar extensao se necessario."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_3_AUTH_TIMING_005"><text>"Avaliar necessidade de extensao e solicitar com antecedencia."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_2_4_AUTH_TIMING_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_2_5_AUTH_TIMING_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_AUTH_TIMING_005">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_TIMING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_TIMING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_TIMING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_AUTH_TIMING_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_AUTH_TIMING_005"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_AUTH_TIMING_005"><text>"Situacao de extensao requer analise manual."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_AUTH_TIMING_005"><text>"Verificar status de extensao e prazos."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_AUTH_TIMING_005_4"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_AUTH_TIMING_005_5"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_TIMING_005">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_TIMING_005" dmnElementRef="Decision_AUTH_TIMING_005">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>