<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-DOCUMENTATION-004 - Verificacao Codigo Diagnostico Confirmado
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-DOCUMENTATION
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_DOCUMENTATION_004" name="Verificacao Codigo Diagnostico Confirmado" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_DOCUMENTATION_004" name="[SP-PA-004 | authorization/documentation] Verificar Codigo Diagnostico Confirmado" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_DOCUMENTATION_004" hitPolicy="FIRST">

      <input id="Input_1_AUTH_DOCUMENTATION_004" label="Tem CID Confirmado">
        <inputExpression id="InputExpression_1_AUTH_DOCUMENTATION_004" typeRef="boolean">
          <text>temCIDConfirmado</text>
        </inputExpression>
      </input>

      <input id="Input_2_AUTH_DOCUMENTATION_004" label="CID Valido">
        <inputExpression id="InputExpression_2_AUTH_DOCUMENTATION_004" typeRef="boolean">
          <text>cidValido</text>
        </inputExpression>
      </input>

      <input id="Input_3_AUTH_DOCUMENTATION_004" label="CID Compativel Procedimento">
        <inputExpression id="InputExpression_3_AUTH_DOCUMENTATION_004" typeRef="boolean">
          <text>cidCompativelProcedimento</text>
        </inputExpression>
      </input>

      <input id="Input_4_AUTH_DOCUMENTATION_004" label="Requer CID Especifico">
        <inputExpression id="InputExpression_4_AUTH_DOCUMENTATION_004" typeRef="boolean">
          <text>requerCIDEspecifico</text>
        </inputExpression>
      </input>

      <output id="Output_1_AUTH_DOCUMENTATION_004" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_AUTH_DOCUMENTATION_004" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_AUTH_DOCUMENTATION_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_AUTH_DOCUMENTATION_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_AUTH_DOCUMENTATION_004" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Bloqueio_1_AUTH_DOCUMENTATION_004">
        <description>CID obrigatorio nao informado</description>
        <inputEntry id="InputEntry_B1_1_AUTH_DOCUMENTATION_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_DOCUMENTATION_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_DOCUMENTATION_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_AUTH_DOCUMENTATION_004"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_AUTH_DOCUMENTATION_004"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_AUTH_DOCUMENTATION_004"><text>"Codigo CID-10 obrigatorio nao informado."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_AUTH_DOCUMENTATION_004"><text>"Inserir codigo CID-10 do diagnostico."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_1_4_AUTH_DOCUMENTATION_004"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_1_5_AUTH_DOCUMENTATION_004"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Bloqueio_2_AUTH_DOCUMENTATION_004">
        <description>Codigo CID-10 invalido</description>
        <inputEntry id="InputEntry_B2_1_AUTH_DOCUMENTATION_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_AUTH_DOCUMENTATION_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_AUTH_DOCUMENTATION_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_AUTH_DOCUMENTATION_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B2_1_AUTH_DOCUMENTATION_004"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_2_AUTH_DOCUMENTATION_004"><text>"Codigo CID-10 informado e invalido ou nao existe."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_3_AUTH_DOCUMENTATION_004"><text>"Corrigir codigo CID-10 do diagnostico."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_2_4_AUTH_DOCUMENTATION_004"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_2_5_AUTH_DOCUMENTATION_004"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Bloqueio_3_AUTH_DOCUMENTATION_004">
        <description>CID incompativel com procedimento solicitado</description>
        <inputEntry id="InputEntry_B3_1_AUTH_DOCUMENTATION_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_AUTH_DOCUMENTATION_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_AUTH_DOCUMENTATION_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B3_4_AUTH_DOCUMENTATION_004"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_B3_1_AUTH_DOCUMENTATION_004"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B3_2_AUTH_DOCUMENTATION_004"><text>"Codigo CID-10 nao e compativel com o procedimento solicitado."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B3_3_AUTH_DOCUMENTATION_004"><text>"Revisar CID ou justificar indicacao atipica."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_3_4_AUTH_DOCUMENTATION_004"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_3_5_AUTH_DOCUMENTATION_004"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_1_AUTH_DOCUMENTATION_004">
        <description>CID valido e compativel com procedimento</description>
        <inputEntry id="InputEntry_A1_1_AUTH_DOCUMENTATION_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_DOCUMENTATION_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_DOCUMENTATION_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_AUTH_DOCUMENTATION_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_AUTH_DOCUMENTATION_004"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_AUTH_DOCUMENTATION_004"><text>"Codigo CID-10 valido e compativel com procedimento."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_AUTH_DOCUMENTATION_004"><text>"Prosseguir com solicitacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_1_4_AUTH_DOCUMENTATION_004"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_1_5_AUTH_DOCUMENTATION_004"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_2_AUTH_DOCUMENTATION_004">
        <description>Procedimento nao requer CID especifico</description>
        <inputEntry id="InputEntry_A2_1_AUTH_DOCUMENTATION_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_AUTH_DOCUMENTATION_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_AUTH_DOCUMENTATION_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_AUTH_DOCUMENTATION_004"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_A2_1_AUTH_DOCUMENTATION_004"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_2_AUTH_DOCUMENTATION_004"><text>"Procedimento nao requer CID especifico."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_3_AUTH_DOCUMENTATION_004"><text>"Prosseguir com solicitacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_2_4_AUTH_DOCUMENTATION_004"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_2_5_AUTH_DOCUMENTATION_004"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_AUTH_DOCUMENTATION_004">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_DOCUMENTATION_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_DOCUMENTATION_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_DOCUMENTATION_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_AUTH_DOCUMENTATION_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_AUTH_DOCUMENTATION_004"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_AUTH_DOCUMENTATION_004"><text>"Verificar codigo CID-10 do diagnostico."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_AUTH_DOCUMENTATION_004"><text>"Validar CID junto a equipe medica."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_AUTH_DOCUMENTATION_004_4"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_AUTH_DOCUMENTATION_004_5"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_DOCUMENTATION_004">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_DOCUMENTATION_004" dmnElementRef="Decision_AUTH_DOCUMENTATION_004">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>