<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-DOCUMENTATION-005 - Verificacao Documentacao Suporte Completa
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-DOCUMENTATION
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_DOCUMENTATION_005" name="Verificacao Documentacao Suporte Completa" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_DOCUMENTATION_005" name="[SP-PA-004 | authorization/documentation] Verificar Documentacao Suporte Completa" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_DOCUMENTATION_005" hitPolicy="FIRST">

      <input id="Input_1_AUTH_DOCUMENTATION_005" label="Tem Laudo Medico">
        <inputExpression id="InputExpression_1_AUTH_DOCUMENTATION_005" typeRef="boolean">
          <text>temLaudoMedico</text>
        </inputExpression>
      </input>

      <input id="Input_2_AUTH_DOCUMENTATION_005" label="Tem Exame Pre-Requisito">
        <inputExpression id="InputExpression_2_AUTH_DOCUMENTATION_005" typeRef="boolean">
          <text>temExamePreRequisito</text>
        </inputExpression>
      </input>

      <input id="Input_3_AUTH_DOCUMENTATION_005" label="Tem Justificativa Medica">
        <inputExpression id="InputExpression_3_AUTH_DOCUMENTATION_005" typeRef="boolean">
          <text>temJustificativaMedica</text>
        </inputExpression>
      </input>

      <input id="Input_4_AUTH_DOCUMENTATION_005" label="Tem CID Confirmado">
        <inputExpression id="InputExpression_4_AUTH_DOCUMENTATION_005" typeRef="boolean">
          <text>temCIDConfirmado</text>
        </inputExpression>
      </input>

      <input id="Input_5_AUTH_DOCUMENTATION_005" label="Documentos Obrigatorios Faltantes">
        <inputExpression id="InputExpression_5_AUTH_DOCUMENTATION_005" typeRef="number">
          <text>documentosObrigatoriosFaltantes</text>
        </inputExpression>
      </input>

      <output id="Output_1_AUTH_DOCUMENTATION_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_AUTH_DOCUMENTATION_005" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_AUTH_DOCUMENTATION_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_AUTH_DOCUMENTATION_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_AUTH_DOCUMENTATION_005" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Bloqueio_1_AUTH_DOCUMENTATION_005">
        <description>Multiplos documentos obrigatorios faltantes</description>
        <inputEntry id="InputEntry_B1_1_AUTH_DOCUMENTATION_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_DOCUMENTATION_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_DOCUMENTATION_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_AUTH_DOCUMENTATION_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_5_AUTH_DOCUMENTATION_005"><text>&gt;= 3</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_AUTH_DOCUMENTATION_005"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_AUTH_DOCUMENTATION_005"><text>"Documentacao muito incompleta. Multiplos documentos obrigatorios faltantes."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_AUTH_DOCUMENTATION_005"><text>"Completar toda a documentacao antes de solicitar autorizacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_1_4_AUTH_DOCUMENTATION_005"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_1_5_AUTH_DOCUMENTATION_005"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Bloqueio_2_AUTH_DOCUMENTATION_005">
        <description>Sem laudo medico e sem justificativa</description>
        <inputEntry id="InputEntry_B2_1_AUTH_DOCUMENTATION_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_AUTH_DOCUMENTATION_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_AUTH_DOCUMENTATION_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_AUTH_DOCUMENTATION_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_5_AUTH_DOCUMENTATION_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B2_1_AUTH_DOCUMENTATION_005"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_2_AUTH_DOCUMENTATION_005"><text>"Laudo medico e justificativa ausentes."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_3_AUTH_DOCUMENTATION_005"><text>"Anexar laudo medico e/ou justificativa clinica."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_2_4_AUTH_DOCUMENTATION_005"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_2_5_AUTH_DOCUMENTATION_005"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alerta_1_AUTH_DOCUMENTATION_005">
        <description>Alguns documentos obrigatorios faltantes</description>
        <inputEntry id="InputEntry_AL1_1_AUTH_DOCUMENTATION_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_AL1_2_AUTH_DOCUMENTATION_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_AL1_3_AUTH_DOCUMENTATION_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_AL1_4_AUTH_DOCUMENTATION_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_AL1_5_AUTH_DOCUMENTATION_005"><text>[1..2]</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL1_1_AUTH_DOCUMENTATION_005"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_2_AUTH_DOCUMENTATION_005"><text>"Documentacao parcialmente incompleta. Verificar documentos faltantes."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_3_AUTH_DOCUMENTATION_005"><text>"Completar documentos faltantes antes de submeter."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_1_4_AUTH_DOCUMENTATION_005"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_1_5_AUTH_DOCUMENTATION_005"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_1_AUTH_DOCUMENTATION_005">
        <description>Toda documentacao de suporte completa</description>
        <inputEntry id="InputEntry_A1_1_AUTH_DOCUMENTATION_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_DOCUMENTATION_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_DOCUMENTATION_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_AUTH_DOCUMENTATION_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_AUTH_DOCUMENTATION_005"><text>0</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_AUTH_DOCUMENTATION_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_AUTH_DOCUMENTATION_005"><text>"Documentacao de suporte completa."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_AUTH_DOCUMENTATION_005"><text>"Prosseguir com solicitacao de autorizacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_1_4_AUTH_DOCUMENTATION_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_1_5_AUTH_DOCUMENTATION_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_2_AUTH_DOCUMENTATION_005">
        <description>Nenhum documento obrigatorio faltante</description>
        <inputEntry id="InputEntry_A2_1_AUTH_DOCUMENTATION_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_AUTH_DOCUMENTATION_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_AUTH_DOCUMENTATION_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_AUTH_DOCUMENTATION_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_5_AUTH_DOCUMENTATION_005"><text>0</text></inputEntry>
        
      <outputEntry id="OutputEntry_A2_1_AUTH_DOCUMENTATION_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_2_AUTH_DOCUMENTATION_005"><text>"Todos os documentos obrigatorios presentes."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_3_AUTH_DOCUMENTATION_005"><text>"Prosseguir com solicitacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_2_4_AUTH_DOCUMENTATION_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_2_5_AUTH_DOCUMENTATION_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_AUTH_DOCUMENTATION_005">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_DOCUMENTATION_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_DOCUMENTATION_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_DOCUMENTATION_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_AUTH_DOCUMENTATION_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_AUTH_DOCUMENTATION_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_AUTH_DOCUMENTATION_005"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_AUTH_DOCUMENTATION_005"><text>"Verificar checklist de documentacao."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_AUTH_DOCUMENTATION_005"><text>"Revisar todos os documentos de suporte necessarios."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_AUTH_DOCUMENTATION_005_4"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_AUTH_DOCUMENTATION_005_5"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_DOCUMENTATION_005">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_DOCUMENTATION_005" dmnElementRef="Decision_AUTH_DOCUMENTATION_005">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>