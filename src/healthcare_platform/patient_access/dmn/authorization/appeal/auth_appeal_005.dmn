<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-APPEAL-005 - Elegibilidade Segunda Instancia
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-APPEAL
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_APPEAL_005" name="Elegibilidade Segunda Instancia" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_APPEAL_005" name="[SP-PA-004 | authorization/appeal] Verificar Elegibilidade Segunda Instancia" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_APPEAL_005" hitPolicy="FIRST">

      <input id="Input_1_AUTH_APPEAL_005" label="Instancia Atual">
        <inputExpression id="InputExpression_1_AUTH_APPEAL_005" typeRef="number">
          <text>instanciaAtual</text>
        </inputExpression>
      </input>

      <input id="Input_2_AUTH_APPEAL_005" label="Recurso Primeira Instancia Negado">
        <inputExpression id="InputExpression_2_AUTH_APPEAL_005" typeRef="boolean">
          <text>recursoPrimeiraInstanciaNegado</text>
        </inputExpression>
      </input>

      <input id="Input_3_AUTH_APPEAL_005" label="Dias Desde Resposta">
        <inputExpression id="InputExpression_3_AUTH_APPEAL_005" typeRef="number">
          <text>diasDesdeResposta</text>
        </inputExpression>
      </input>

      <input id="Input_4_AUTH_APPEAL_005" label="Tem Novos Argumentos">
        <inputExpression id="InputExpression_4_AUTH_APPEAL_005" typeRef="boolean">
          <text>temNovosArgumentos</text>
        </inputExpression>
      </input>

      <output id="Output_1_AUTH_APPEAL_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_AUTH_APPEAL_005" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_AUTH_APPEAL_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_AUTH_APPEAL_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_AUTH_APPEAL_005" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Bloqueio_1_AUTH_APPEAL_005">
        <description>Ja atingiu ultima instancia administrativa</description>
        <inputEntry id="InputEntry_B1_1_AUTH_APPEAL_005"><text>&gt;= 3</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_APPEAL_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_APPEAL_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_AUTH_APPEAL_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_AUTH_APPEAL_005"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_AUTH_APPEAL_005"><text>"Ultima instancia administrativa atingida. Nao cabe mais recurso."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_AUTH_APPEAL_005"><text>"Considerar via judicial ou ANS."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_1_4_AUTH_APPEAL_005"><text>"PRAZO"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_1_5_AUTH_APPEAL_005"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Bloqueio_2_AUTH_APPEAL_005">
        <description>Prazo para segunda instancia expirado</description>
        <inputEntry id="InputEntry_B2_1_AUTH_APPEAL_005"><text>1</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_AUTH_APPEAL_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_AUTH_APPEAL_005"><text>&gt; 30</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_AUTH_APPEAL_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B2_1_AUTH_APPEAL_005"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_2_AUTH_APPEAL_005"><text>"Prazo para recurso de segunda instancia expirado."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_3_AUTH_APPEAL_005"><text>"Considerar nova solicitacao ou via alternativa."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_2_4_AUTH_APPEAL_005"><text>"PRAZO"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_2_5_AUTH_APPEAL_005"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alerta_1_AUTH_APPEAL_005">
        <description>Segunda instancia sem novos argumentos</description>
        <inputEntry id="InputEntry_AL1_1_AUTH_APPEAL_005"><text>1</text></inputEntry>
        <inputEntry id="InputEntry_AL1_2_AUTH_APPEAL_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_AL1_3_AUTH_APPEAL_005"><text>&lt;= 30</text></inputEntry>
        <inputEntry id="InputEntry_AL1_4_AUTH_APPEAL_005"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL1_1_AUTH_APPEAL_005"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_2_AUTH_APPEAL_005"><text>"Recurso de segunda instancia sem novos argumentos pode ser indeferido."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_3_AUTH_APPEAL_005"><text>"Buscar novos argumentos ou evidencias antes de prosseguir."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_1_4_AUTH_APPEAL_005"><text>"PRAZO"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_1_5_AUTH_APPEAL_005"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_1_AUTH_APPEAL_005">
        <description>Elegivel para recurso de segunda instancia</description>
        <inputEntry id="InputEntry_A1_1_AUTH_APPEAL_005"><text>1</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_APPEAL_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_APPEAL_005"><text>&lt;= 30</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_AUTH_APPEAL_005"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_AUTH_APPEAL_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_AUTH_APPEAL_005"><text>"Elegivel para recurso de segunda instancia com novos argumentos."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_AUTH_APPEAL_005"><text>"Preparar e protocolar recurso de segunda instancia."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_1_4_AUTH_APPEAL_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_1_5_AUTH_APPEAL_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_2_AUTH_APPEAL_005">
        <description>Ainda em primeira instancia</description>
        <inputEntry id="InputEntry_A2_1_AUTH_APPEAL_005"><text>0</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_AUTH_APPEAL_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_AUTH_APPEAL_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_AUTH_APPEAL_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A2_1_AUTH_APPEAL_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_2_AUTH_APPEAL_005"><text>"Ainda em fase de primeira instancia."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_3_AUTH_APPEAL_005"><text>"Aguardar resposta da primeira instancia."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_2_4_AUTH_APPEAL_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_2_5_AUTH_APPEAL_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_AUTH_APPEAL_005">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_APPEAL_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_APPEAL_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_APPEAL_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_AUTH_APPEAL_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_AUTH_APPEAL_005"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_AUTH_APPEAL_005"><text>"Verificar elegibilidade para proxima instancia."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_AUTH_APPEAL_005"><text>"Analisar historico de recursos e prazos."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_AUTH_APPEAL_005_4"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_AUTH_APPEAL_005_5"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_APPEAL_005">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_APPEAL_005" dmnElementRef="Decision_AUTH_APPEAL_005">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>