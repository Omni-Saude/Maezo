<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-APPEAL-002 - Verificacao Nova Documentacao Disponivel
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-APPEAL
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_APPEAL_002" name="Verificacao Nova Documentacao Disponivel" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_APPEAL_002" name="[SP-PA-004 | authorization/appeal] Verificar Nova Documentacao Disponivel" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_APPEAL_002" hitPolicy="FIRST">

      <input id="Input_1_AUTH_APPEAL_002" label="Tem Nova Documentacao">
        <inputExpression id="InputExpression_1_AUTH_APPEAL_002" typeRef="boolean">
          <text>temNovaDocumentacao</text>
        </inputExpression>
      </input>

      <input id="Input_2_AUTH_APPEAL_002" label="Documentacao Relevante">
        <inputExpression id="InputExpression_2_AUTH_APPEAL_002" typeRef="boolean">
          <text>documentacaoRelevante</text>
        </inputExpression>
      </input>

      <input id="Input_3_AUTH_APPEAL_002" label="Tipo Nova Documentacao">
        <inputExpression id="InputExpression_3_AUTH_APPEAL_002" typeRef="string">
          <text>tipoNovaDocumentacao</text>
        </inputExpression>
        <inputValues id="InputValues_3_AUTH_APPEAL_002">
          <text>"LAUDO", "EXAME", "PARECER", "ARTIGO", "OUTRO"</text>
        </inputValues>
      </input>

      <output id="Output_1_AUTH_APPEAL_002" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_AUTH_APPEAL_002" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_AUTH_APPEAL_002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_AUTH_APPEAL_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_AUTH_APPEAL_002" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Alerta_1_AUTH_APPEAL_002">
        <description>Recurso sem nova documentacao</description>
        <inputEntry id="InputEntry_AL1_1_AUTH_APPEAL_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_AL1_2_AUTH_APPEAL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_AL1_3_AUTH_APPEAL_002"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL1_1_AUTH_APPEAL_002"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_2_AUTH_APPEAL_002"><text>"Recurso sem nova documentacao pode ter baixa chance de sucesso."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL1_3_AUTH_APPEAL_002"><text>"Obter documentacao adicional antes de protocolar recurso."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_1_4_AUTH_APPEAL_002"><text>"PRAZO"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_1_5_AUTH_APPEAL_002"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Alerta_2_AUTH_APPEAL_002">
        <description>Nova documentacao pode nao ser relevante</description>
        <inputEntry id="InputEntry_AL2_1_AUTH_APPEAL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_AL2_2_AUTH_APPEAL_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_AL2_3_AUTH_APPEAL_002"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_AL2_1_AUTH_APPEAL_002"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL2_2_AUTH_APPEAL_002"><text>"Nova documentacao pode nao ser relevante para o motivo da negativa."</text></outputEntry>
        
      <outputEntry id="OutputEntry_AL2_3_AUTH_APPEAL_002"><text>"Revisar documentacao e alinhar com motivo da negativa."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alerta_2_4_AUTH_APPEAL_002"><text>"PRAZO"</text></outputEntry>
      <outputEntry id="OutputEntry_Alerta_2_5_AUTH_APPEAL_002"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_1_AUTH_APPEAL_002">
        <description>Nova documentacao com parecer medico relevante</description>
        <inputEntry id="InputEntry_A1_1_AUTH_APPEAL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_APPEAL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_APPEAL_002"><text>"PARECER"</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_AUTH_APPEAL_002"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_AUTH_APPEAL_002"><text>"Parecer medico adicional fortalece o recurso."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_AUTH_APPEAL_002"><text>"Prosseguir com protocolo do recurso."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_1_4_AUTH_APPEAL_002"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_1_5_AUTH_APPEAL_002"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_2_AUTH_APPEAL_002">
        <description>Nova documentacao com laudo ou exame relevante</description>
        <inputEntry id="InputEntry_A2_1_AUTH_APPEAL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_AUTH_APPEAL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_AUTH_APPEAL_002"><text>"LAUDO", "EXAME"</text></inputEntry>
        
      <outputEntry id="OutputEntry_A2_1_AUTH_APPEAL_002"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_2_AUTH_APPEAL_002"><text>"Nova documentacao clinica relevante disponivel."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_3_AUTH_APPEAL_002"><text>"Prosseguir com protocolo do recurso."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_2_4_AUTH_APPEAL_002"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_2_5_AUTH_APPEAL_002"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_3_AUTH_APPEAL_002">
        <description>Outra documentacao relevante disponivel</description>
        <inputEntry id="InputEntry_A3_1_AUTH_APPEAL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A3_2_AUTH_APPEAL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A3_3_AUTH_APPEAL_002"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A3_1_AUTH_APPEAL_002"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A3_2_AUTH_APPEAL_002"><text>"Nova documentacao relevante disponivel para recurso."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A3_3_AUTH_APPEAL_002"><text>"Prosseguir com protocolo do recurso."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_3_4_AUTH_APPEAL_002"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_3_5_AUTH_APPEAL_002"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_AUTH_APPEAL_002">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_APPEAL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_APPEAL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_APPEAL_002"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_AUTH_APPEAL_002"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_AUTH_APPEAL_002"><text>"Verificar documentacao para recurso."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_AUTH_APPEAL_002"><text>"Avaliar documentacao disponivel com equipe medica."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_AUTH_APPEAL_002_4"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_AUTH_APPEAL_002_5"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_APPEAL_002">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_APPEAL_002" dmnElementRef="Decision_AUTH_APPEAL_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>