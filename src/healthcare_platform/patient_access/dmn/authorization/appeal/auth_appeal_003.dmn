<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  AUTH-APPEAL-003 - Avaliacao Elegibilidade para Recurso
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: AUTH-APPEAL
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_AUTH_APPEAL_003" name="Avaliacao Elegibilidade para Recurso" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_AUTH_APPEAL_003" name="[SP-PA-004 | authorization/appeal] Avaliar Elegibilidade para Recurso" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_AUTH_APPEAL_003" hitPolicy="FIRST">

      <input id="Input_1_AUTH_APPEAL_003" label="Motivo Negativa">
        <inputExpression id="InputExpression_1_AUTH_APPEAL_003" typeRef="string">
          <text>motivoNegativa</text>
        </inputExpression>
        <inputValues id="InputValues_1_AUTH_APPEAL_003">
          <text>"NAO_COBERTO", "DOCUMENTACAO_INCOMPLETA", "CID_INCOMPATIVEL", "SEM_INDICACAO", "LIMITE_EXCEDIDO", "CARENCIA"</text>
        </inputValues>
      </input>

      <input id="Input_2_AUTH_APPEAL_003" label="Pode Contestar">
        <inputExpression id="InputExpression_2_AUTH_APPEAL_003" typeRef="boolean">
          <text>podeContestar</text>
        </inputExpression>
      </input>

      <input id="Input_3_AUTH_APPEAL_003" label="Recurso Anterior">
        <inputExpression id="InputExpression_3_AUTH_APPEAL_003" typeRef="boolean">
          <text>recursoAnterior</text>
        </inputExpression>
      </input>

      <input id="Input_4_AUTH_APPEAL_003" label="Recursos Disponiveis">
        <inputExpression id="InputExpression_4_AUTH_APPEAL_003" typeRef="number">
          <text>recursosDisponiveis</text>
        </inputExpression>
      </input>

      <output id="Output_1_AUTH_APPEAL_003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_AUTH_APPEAL_003" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_AUTH_APPEAL_003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_AUTH_APPEAL_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_AUTH_APPEAL_003" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Bloqueio_1_AUTH_APPEAL_003">
        <description>Nao ha mais recursos disponiveis</description>
        <inputEntry id="InputEntry_B1_1_AUTH_APPEAL_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_AUTH_APPEAL_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_AUTH_APPEAL_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_AUTH_APPEAL_003"><text>0</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_AUTH_APPEAL_003"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_AUTH_APPEAL_003"><text>"Todos os recursos foram esgotados. Nao ha mais instancias."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_AUTH_APPEAL_003"><text>"Considerar via judicial ou nova solicitacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_1_4_AUTH_APPEAL_003"><text>"PRAZO"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_1_5_AUTH_APPEAL_003"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Bloqueio_2_AUTH_APPEAL_003">
        <description>Negativa por carencia nao contestavel</description>
        <inputEntry id="InputEntry_B2_1_AUTH_APPEAL_003"><text>"CARENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_AUTH_APPEAL_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_AUTH_APPEAL_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_AUTH_APPEAL_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B2_1_AUTH_APPEAL_003"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_2_AUTH_APPEAL_003"><text>"Negativa por carencia nao e passivel de contestacao."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_3_AUTH_APPEAL_003"><text>"Aguardar cumprimento da carencia ou justificar urgencia."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Bloqueio_2_4_AUTH_APPEAL_003"><text>"PRAZO"</text></outputEntry>
      <outputEntry id="OutputEntry_Bloqueio_2_5_AUTH_APPEAL_003"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_1_AUTH_APPEAL_003">
        <description>Negativa por documentacao incompleta - contestavel</description>
        <inputEntry id="InputEntry_A1_1_AUTH_APPEAL_003"><text>"DOCUMENTACAO_INCOMPLETA"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_AUTH_APPEAL_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_AUTH_APPEAL_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_AUTH_APPEAL_003"><text>&gt; 0</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_AUTH_APPEAL_003"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_AUTH_APPEAL_003"><text>"Elegivel para recurso. Completar documentacao e protocolar."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_AUTH_APPEAL_003"><text>"Reunir documentacao faltante e protocolar recurso."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_1_4_AUTH_APPEAL_003"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_1_5_AUTH_APPEAL_003"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_2_AUTH_APPEAL_003">
        <description>Negativa por CID incompativel - contestavel</description>
        <inputEntry id="InputEntry_A2_1_AUTH_APPEAL_003"><text>"CID_INCOMPATIVEL"</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_AUTH_APPEAL_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_AUTH_APPEAL_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_AUTH_APPEAL_003"><text>&gt; 0</text></inputEntry>
        
      <outputEntry id="OutputEntry_A2_1_AUTH_APPEAL_003"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_2_AUTH_APPEAL_003"><text>"Elegivel para recurso. Justificar indicacao clinica."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_3_AUTH_APPEAL_003"><text>"Anexar justificativa medica detalhada e protocolar recurso."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_2_4_AUTH_APPEAL_003"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_2_5_AUTH_APPEAL_003"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Aprovado_3_AUTH_APPEAL_003">
        <description>Negativa passivel de contestacao</description>
        <inputEntry id="InputEntry_A3_1_AUTH_APPEAL_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_2_AUTH_APPEAL_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A3_3_AUTH_APPEAL_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_4_AUTH_APPEAL_003"><text>&gt; 0</text></inputEntry>
        
      <outputEntry id="OutputEntry_A3_1_AUTH_APPEAL_003"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A3_2_AUTH_APPEAL_003"><text>"Caso elegivel para recurso."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A3_3_AUTH_APPEAL_003"><text>"Preparar fundamentacao e protocolar recurso."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Aprovado_3_4_AUTH_APPEAL_003"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Aprovado_3_5_AUTH_APPEAL_003"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_AUTH_APPEAL_003">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_AUTH_APPEAL_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_AUTH_APPEAL_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_AUTH_APPEAL_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_AUTH_APPEAL_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_AUTH_APPEAL_003"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_AUTH_APPEAL_003"><text>"Avaliar elegibilidade para recurso."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_AUTH_APPEAL_003"><text>"Analisar motivo da negativa e opcoes de recurso."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_AUTH_APPEAL_003_4"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_AUTH_APPEAL_003_5"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_AUTH_APPEAL_003">
      <dmndi:DMNShape id="DMNShape_Decision_AUTH_APPEAL_003" dmnElementRef="Decision_AUTH_APPEAL_003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>