<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             id="eligibility-verification-definitions"
             name="Eligibility Verification Decision"
             namespace="http://camunda.org/schema/1.0/dmn"
             exporter="Camunda Modeler"
             exporterVersion="5.20.0">

  <decision id="eligibility-verification" name="[SP-PA-004 | authorization/federated] Verificação de Elegibilidade" camunda:historyTimeToLive="180">

    <decisionTable id="eligibility-table" hitPolicy="FIRST">

      <!-- ===== INPUT DEFINITIONS ===== -->
      <input id="input-insurance-type_eligibility-verification" label="Tipo de Convênio" camunda:inputVariable="insuranceType">
        <inputExpression id="input-expr-1_eligibility-verification" typeRef="string">
          <text>insuranceType</text>
        </inputExpression>
        <inputValues id="input-values-1_eligibility-verification">
          <text>"SUS","PARTICULAR","PLANO_SAUDE","CONVENIO_EMPRESA","INTERNACIONAL"</text>
        </inputValues>
      </input>

      <input id="input-coverage-status_eligibility-verification" label="Status da Cobertura" camunda:inputVariable="coverageStatus">
        <inputExpression id="input-expr-2_eligibility-verification" typeRef="string">
          <text>coverageStatus</text>
        </inputExpression>
        <inputValues id="input-values-2_eligibility-verification">
          <text>"ACTIVE","SUSPENDED","EXPIRED","PENDING","BLOCKED"</text>
        </inputValues>
      </input>

      <input id="input-emergency_eligibility-verification" label="Emergência Médica" camunda:inputVariable="isEmergency">
        <inputExpression id="input-expr-3_eligibility-verification" typeRef="boolean">
          <text>isEmergency</text>
        </inputExpression>
      </input>

      <input id="input-contract-active_eligibility-verification" label="Contrato Ativo" camunda:inputVariable="hasActiveContract">
        <inputExpression id="input-expr-4_eligibility-verification" typeRef="boolean">
          <text>hasActiveContract</text>
        </inputExpression>
      </input>

      <!-- ===== OUTPUT DEFINITIONS ===== -->
      <output id="output-eligible_eligibility-verification" label="Elegível" name="eligible" typeRef="boolean" />

      <output id="output-reason_eligibility-verification" label="Motivo" name="reason" typeRef="string">
        <outputValues id="output-values-1_eligibility-verification">
          <text>"EMERGENCY_OVERRIDE","COVERED","SUSPENDED_COVERAGE","EXPIRED_CONTRACT","NO_COVERAGE","BLOCKED_INSURANCE","PENDING_VERIFICATION"</text>
        </outputValues>
      </output>

      <output id="output-priority_eligibility-verification" label="Prioridade" name="priority" typeRef="integer">
        <outputValues id="output-values-2_eligibility-verification">
          <text>1,2,3,4,5</text>
        </outputValues>
      </output>

      <output id="output-requires-manual-review_eligibility-verification" label="Revisão Manual" name="requiresManualReview" typeRef="boolean" />

      <!-- ===== DECISION RULES ===== -->

      <!-- RULE 1: Emergência sempre aprova (prioridade máxima) -->
      <rule id="rule-emergency_eligibility-verification">
        <description>Emergências médicas são sempre elegíveis independente do status do convênio</description>
        <inputEntry id="rule1-input1_eligibility-verification">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule1-input2_eligibility-verification">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule1-input3_eligibility-verification">
          <text>true</text>
        </inputEntry>
        <inputEntry id="rule1-input4_eligibility-verification">
          <text>-</text>
        </inputEntry>
        <outputEntry id="rule1-output1_eligibility-verification">
          <text>true</text>
        </outputEntry>
        <outputEntry id="rule1-output2_eligibility-verification">
          <text>"EMERGENCY_OVERRIDE"</text>
        </outputEntry>
        <outputEntry id="rule1-output3_eligibility-verification">
          <text>1</text>
        </outputEntry>
        <outputEntry id="rule1-output4_eligibility-verification">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- RULE 2: SUS com contrato ativo -->
      <rule id="rule-sus-active_eligibility-verification">
        <description>SUS com cobertura ativa é elegível</description>
        <inputEntry id="rule2-input1_eligibility-verification">
          <text>"SUS"</text>
        </inputEntry>
        <inputEntry id="rule2-input2_eligibility-verification">
          <text>"ACTIVE"</text>
        </inputEntry>
        <inputEntry id="rule2-input3_eligibility-verification">
          <text>false</text>
        </inputEntry>
        <inputEntry id="rule2-input4_eligibility-verification">
          <text>true</text>
        </inputEntry>
        <outputEntry id="rule2-output1_eligibility-verification">
          <text>true</text>
        </outputEntry>
        <outputEntry id="rule2-output2_eligibility-verification">
          <text>"COVERED"</text>
        </outputEntry>
        <outputEntry id="rule2-output3_eligibility-verification">
          <text>2</text>
        </outputEntry>
        <outputEntry id="rule2-output4_eligibility-verification">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- RULE 3: Plano de saúde ativo -->
      <rule id="rule-plano-active_eligibility-verification">
        <description>Plano de saúde com cobertura ativa</description>
        <inputEntry id="rule3-input1_eligibility-verification">
          <text>"PLANO_SAUDE","CONVENIO_EMPRESA"</text>
        </inputEntry>
        <inputEntry id="rule3-input2_eligibility-verification">
          <text>"ACTIVE"</text>
        </inputEntry>
        <inputEntry id="rule3-input3_eligibility-verification">
          <text>false</text>
        </inputEntry>
        <inputEntry id="rule3-input4_eligibility-verification">
          <text>true</text>
        </inputEntry>
        <outputEntry id="rule3-output1_eligibility-verification">
          <text>true</text>
        </outputEntry>
        <outputEntry id="rule3-output2_eligibility-verification">
          <text>"COVERED"</text>
        </outputEntry>
        <outputEntry id="rule3-output3_eligibility-verification">
          <text>2</text>
        </outputEntry>
        <outputEntry id="rule3-output4_eligibility-verification">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- RULE 4: Convênio internacional requer revisão -->
      <rule id="rule-international-review_eligibility-verification">
        <description>Convênios internacionais requerem análise manual</description>
        <inputEntry id="rule4-input1_eligibility-verification">
          <text>"INTERNACIONAL"</text>
        </inputEntry>
        <inputEntry id="rule4-input2_eligibility-verification">
          <text>"ACTIVE","PENDING"</text>
        </inputEntry>
        <inputEntry id="rule4-input3_eligibility-verification">
          <text>false</text>
        </inputEntry>
        <inputEntry id="rule4-input4_eligibility-verification">
          <text>-</text>
        </inputEntry>
        <outputEntry id="rule4-output1_eligibility-verification">
          <text>false</text>
        </outputEntry>
        <outputEntry id="rule4-output2_eligibility-verification">
          <text>"PENDING_VERIFICATION"</text>
        </outputEntry>
        <outputEntry id="rule4-output3_eligibility-verification">
          <text>3</text>
        </outputEntry>
        <outputEntry id="rule4-output4_eligibility-verification">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- RULE 5: Cobertura suspensa -->
      <rule id="rule-suspended_eligibility-verification">
        <description>Cobertura suspensa não é elegível</description>
        <inputEntry id="rule5-input1_eligibility-verification">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule5-input2_eligibility-verification">
          <text>"SUSPENDED"</text>
        </inputEntry>
        <inputEntry id="rule5-input3_eligibility-verification">
          <text>false</text>
        </inputEntry>
        <inputEntry id="rule5-input4_eligibility-verification">
          <text>-</text>
        </inputEntry>
        <outputEntry id="rule5-output1_eligibility-verification">
          <text>false</text>
        </outputEntry>
        <outputEntry id="rule5-output2_eligibility-verification">
          <text>"SUSPENDED_COVERAGE"</text>
        </outputEntry>
        <outputEntry id="rule5-output3_eligibility-verification">
          <text>4</text>
        </outputEntry>
        <outputEntry id="rule5-output4_eligibility-verification">
          <text>true</text>
        </outputEntry>
      </rule>

      <!-- RULE 6: Cobertura expirada -->
      <rule id="rule-expired_eligibility-verification">
        <description>Cobertura expirada não é elegível</description>
        <inputEntry id="rule6-input1_eligibility-verification">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule6-input2_eligibility-verification">
          <text>"EXPIRED"</text>
        </inputEntry>
        <inputEntry id="rule6-input3_eligibility-verification">
          <text>false</text>
        </inputEntry>
        <inputEntry id="rule6-input4_eligibility-verification">
          <text>-</text>
        </inputEntry>
        <outputEntry id="rule6-output1_eligibility-verification">
          <text>false</text>
        </outputEntry>
        <outputEntry id="rule6-output2_eligibility-verification">
          <text>"EXPIRED_CONTRACT"</text>
        </outputEntry>
        <outputEntry id="rule6-output3_eligibility-verification">
          <text>5</text>
        </outputEntry>
        <outputEntry id="rule6-output4_eligibility-verification">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- RULE 7: Convênio bloqueado -->
      <rule id="rule-blocked_eligibility-verification">
        <description>Convênio bloqueado não é elegível</description>
        <inputEntry id="rule7-input1_eligibility-verification">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule7-input2_eligibility-verification">
          <text>"BLOCKED"</text>
        </inputEntry>
        <inputEntry id="rule7-input3_eligibility-verification">
          <text>false</text>
        </inputEntry>
        <inputEntry id="rule7-input4_eligibility-verification">
          <text>-</text>
        </inputEntry>
        <outputEntry id="rule7-output1_eligibility-verification">
          <text>false</text>
        </outputEntry>
        <outputEntry id="rule7-output2_eligibility-verification">
          <text>"BLOCKED_INSURANCE"</text>
        </outputEntry>
        <outputEntry id="rule7-output3_eligibility-verification">
          <text>5</text>
        </outputEntry>
        <outputEntry id="rule7-output4_eligibility-verification">
          <text>false</text>
        </outputEntry>
      </rule>

      <!-- RULE 8: Fallback - negar por segurança -->
      <rule id="rule-default-deny_eligibility-verification">
        <description>Casos não mapeados são negados por padrão</description>
        <inputEntry id="rule8-input1_eligibility-verification">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule8-input2_eligibility-verification">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule8-input3_eligibility-verification">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule8-input4_eligibility-verification">
          <text>-</text>
        </inputEntry>
        <outputEntry id="rule8-output1_eligibility-verification">
          <text>false</text>
        </outputEntry>
        <outputEntry id="rule8-output2_eligibility-verification">
          <text>"NO_COVERAGE"</text>
        </outputEntry>
        <outputEntry id="rule8-output3_eligibility-verification">
          <text>5</text>
        </outputEntry>
        <outputEntry id="rule8-output4_eligibility-verification">
          <text>true</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <!-- ===== DIAGRAM LAYOUT ===== -->
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_eligibility_eligibility-verification">
      <dmndi:DMNShape id="DMNShape_eligibility_eligibility-verification" dmnElementRef="eligibility-verification">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
