<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_SP_RC_015" targetNamespace="http://cib7.healthcare/revenue-cycle/financial-selfservice" exporter="Camunda Modeler" exporterVersion="5.35.0">
  <bpmn:collaboration id="Collaboration_PatientFinancialSelfService">
    <bpmn:participant id="Participant_PatientSelfService" name="FLUXO DE PAGAMENTO  PARA PACIENTES" processRef="SP_RC_015_Patient_Payment" />
    <bpmn:textAnnotation id="TextAnnotation_1fnzttb">
      <bpmn:text>coletar justificativa junto ao Pós-Venda</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_17dc8mt">
      <bpmn:text>enviar NF após realizar o serviço e fechar a conta</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0dc515b">
      <bpmn:text>adiantamento de cliente</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0ez7dfz">
      <bpmn:text>envio do link CIELO</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_03p6qrj">
      <bpmn:text>integração CIELO</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0xr8zbc" associationDirection="None" sourceRef="EndEvent_PaymentComplete" targetRef="TextAnnotation_17dc8mt" />
    <bpmn:association id="Association_0prda21" associationDirection="None" sourceRef="Activity_0q7ozmd" targetRef="TextAnnotation_0dc515b" />
    <bpmn:association id="Association_1x91470" associationDirection="None" sourceRef="Task_ProcessPayment" targetRef="TextAnnotation_0ez7dfz" />
    <bpmn:association id="Association_0eti0m4" associationDirection="None" sourceRef="Task_PaymentConfirmed" targetRef="TextAnnotation_03p6qrj" />
  </bpmn:collaboration>
  <bpmn:process id="SP_RC_015_Patient_Payment" name="Pagamento do Paciente" isExecutable="true" camunda:versionTag="1.0.0" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="StartEvent_Payment" name="pagamento&#10;iniciado">
      <bpmn:outgoing>Flow_ToPaymentMethod</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="Gateway_PaymentMethod" default="Flow_PayLater">
      <bpmn:incoming>Flow_ToPaymentMethod</bpmn:incoming>
      <bpmn:outgoing>Flow_PayNow</bpmn:outgoing>
      <bpmn:outgoing>Flow_PayLater</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_ProcessPayment" name="Gerar&#10;pagamento" camunda:type="external" camunda:topic="financial.payment_process">
      <bpmn:incoming>Flow_PayNow</bpmn:incoming>
      <bpmn:outgoing>Flow_0ywrgoo</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="BoundaryEvent_PaymentFailure" name="erro no&#10;pagamento" attachedToRef="Task_ProcessPayment">
      <bpmn:outgoing>Flow_PaymentFailureToEnd</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_PaymentFailure" errorRef="Error_FinancialPayment" />
    </bpmn:boundaryEvent>
    <bpmn:serviceTask id="Task_PaymentConfirmed" name="Confirmar&#10;pagamento" camunda:type="external" camunda:topic="financial.payment_confirmed">
      <bpmn:incoming>Flow_0h7j49g</bpmn:incoming>
      <bpmn:outgoing>Flow_0p9wb4d</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_0mv5ecp">
      <bpmn:incoming>Flow_0ywrgoo</bpmn:incoming>
      <bpmn:incoming>Flow_PaymentPlanToConfirmed</bpmn:incoming>
      <bpmn:outgoing>Flow_0h7j49g</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="Event_1vc0dcr" name="pagamento&#10;não concluído">
      <bpmn:incoming>Flow_PaymentFailureToEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:intermediateThrowEvent id="Event_1yjwwze" name="pagamento&#10;concluído">
      <bpmn:incoming>Flow_0p9wb4d</bpmn:incoming>
      <bpmn:outgoing>Flow_0btmht5</bpmn:outgoing>
    </bpmn:intermediateThrowEvent>
    <bpmn:serviceTask id="Activity_0izmecj" name="Enviar recibo&#10;via Tasy" camunda:type="external" camunda:topic="financial.send_receipt_tasy">
      <bpmn:incoming>Flow_0d83x4g</bpmn:incoming>
      <bpmn:outgoing>Flow_1fms7ah</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_0q7ozmd" name="Gerar&#10;recibo" camunda:type="external" camunda:topic="financial.generate_receipt">
      <bpmn:incoming>Flow_0btmht5</bpmn:incoming>
      <bpmn:outgoing>Flow_0d83x4g</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_PaymentComplete" name="pagamento&#10;realizado">
      <bpmn:incoming>Flow_1fms7ah</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_SetupPaymentPlan" name="Programar&#10;pagamento" camunda:type="external" camunda:topic="financial.payment_plan">
      <bpmn:incoming>Flow_PayLater</bpmn:incoming>
      <bpmn:outgoing>Flow_PaymentPlanToConfirmed</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_ToPaymentMethod" sourceRef="StartEvent_Payment" targetRef="Gateway_PaymentMethod" />
    <bpmn:sequenceFlow id="Flow_PayNow" name="Pagamento&#10;pré" sourceRef="Gateway_PaymentMethod" targetRef="Task_ProcessPayment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${paymentMethod == 'PAY_NOW'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_PayLater" name="Pagamento&#10;pós" sourceRef="Gateway_PaymentMethod" targetRef="Task_SetupPaymentPlan">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0ywrgoo" sourceRef="Task_ProcessPayment" targetRef="Gateway_0mv5ecp" />
    <bpmn:sequenceFlow id="Flow_PaymentFailureToEnd" sourceRef="BoundaryEvent_PaymentFailure" targetRef="Event_1vc0dcr" />
    <bpmn:sequenceFlow id="Flow_0h7j49g" sourceRef="Gateway_0mv5ecp" targetRef="Task_PaymentConfirmed" />
    <bpmn:sequenceFlow id="Flow_0p9wb4d" sourceRef="Task_PaymentConfirmed" targetRef="Event_1yjwwze" />
    <bpmn:sequenceFlow id="Flow_PaymentPlanToConfirmed" sourceRef="Task_SetupPaymentPlan" targetRef="Gateway_0mv5ecp" />
    <bpmn:sequenceFlow id="Flow_0btmht5" sourceRef="Event_1yjwwze" targetRef="Activity_0q7ozmd" />
    <bpmn:sequenceFlow id="Flow_0d83x4g" sourceRef="Activity_0q7ozmd" targetRef="Activity_0izmecj" />
    <bpmn:sequenceFlow id="Flow_1fms7ah" sourceRef="Activity_0izmecj" targetRef="EndEvent_PaymentComplete" />
  </bpmn:process>
  <bpmn:message id="Message_PatientAck" name="msg_patient_ack" />
  <bpmn:message id="Message_PaymentResponse" name="msg_payment_response" />
  <bpmn:message id="Message_InsuranceResponse" name="msg_insurance_response" />
  <bpmn:error id="Error_FinancialPayment" name="FINANCIAL_PAYMENT_ERROR" errorCode="FIN_PAYMENT" />
  <bpmn:error id="Error_FinancialEstimate" name="FINANCIAL_ESTIMATE_ERROR" errorCode="FIN_ESTIMATE" />
