    <bpmn:textAnnotation id="TextAnnotation_1j4c6hr">
      <bpmn:text>AVALIAÇÃO QT PRESCRITO ($) AVALIAÇÃO DE MARGENS AVALIAÇÃO COMORBIDADES/ RISCOS (IDADE, ETC)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1v3jur1">
      <bpmn:text>AVALIAÇÃO DO TIPO DE ATENDIMENTO (AMBULATORIAL / EXTERNO)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1lwar1p">
      <bpmn:text>AVALIAÇÃO Nº DE SESSÕES PRESCRITAS X CONDIÇÕES DO CLIENTE</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0lm0elf">
      <bpmn:text>AVALIAÇÃO PROCEDIMENTO INDICADO X CIRURGIÃO (TEMPO / PERMANÊNCIA</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0spscbi">
      <bpmn:text>AVALIAÇÃO CONDIÇÕES CLÍNICAS DO PACIENTE (IDADE, COMORBIDADES, ETC)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1ldxrys">
      <bpmn:text>AVALIAÇÃO TÉCNICA E OPME (ROBÔ; IMPORTADAS; NACIONAIS)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_11jigf8">
      <bpmn:text>AVALIAÇÃO DE CONDIÇÕES FINANCEIRAS (DESCONTOS E PARCELAMENTOS)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0wwu2qv">
      <bpmn:text>OFERTA PACOTE DIAMANTE OFERTA PACOTE OURO</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1fki9ex">
      <bpmn:text>FINALIZA VENDA HOSPITAL</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0x388pv">
      <bpmn:text>DIRECIONA PAGAMENTO ANESTESIA</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_04tn24t">
      <bpmn:text>DIRECIONA PAGAMENTO OPME DIRETO AO FORNECEDOR</bpmn:text>
