        <bpmndi:BPMNLabel>
          <dc:Bounds x="1104" y="967" width="71" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_1sriif5_di" bpmnElement="BoundaryEvent_AckTimeout">
