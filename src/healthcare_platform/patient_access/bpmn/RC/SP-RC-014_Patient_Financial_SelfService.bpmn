<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_SP_RC_014" targetNamespace="http://cib7.healthcare/revenue-cycle/financial-selfservice" exporter="Camunda Modeler" exporterVersion="5.35.0">
  <bpmn:collaboration id="Collaboration_PatientFinancialSelfService">
    <bpmn:participant id="Participant_PatientSelfService" name="AUTOATENDIMENTO FINANCEIRO PARA PACIENTES" processRef="SP_RC_014_Patient_Financial_SelfService" />
    <bpmn:textAnnotation id="TextAnnotation_1a917xf">
      <bpmn:text>qual o gatilho real para dar início a esse processo?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0loiqwi">
      <bpmn:text>Falta BPMN dedicado para cancelamento de cobrança, estorno de pagamento e chargeback. Para o portal, criar:
(1) Processo de cancelamento de cobrança (antes do pagamento),
(2) Processo de estorno/reembolso (após pagamento),
(3) Processo de chargeback de cartão de crédito,</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0koqwka">
      <bpmn:text>coletar justificativa junto ao Pós-Venda</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1cr6rkx" associationDirection="None" sourceRef="Activity_1vwhrk4" targetRef="TextAnnotation_0koqwka" />
    <bpmn:association id="Association_19n7dcr" associationDirection="None" sourceRef="StartEvent_FinancialServiceTriggered" targetRef="TextAnnotation_1a917xf" />
  </bpmn:collaboration>
  <bpmn:process id="SP_RC_014_Patient_Financial_SelfService" name="Autoatendimento Financeiro do Paciente" isExecutable="true" camunda:versionTag="1.0.0" camunda:historyTimeToLive="30">
    <bpmn:sequenceFlow id="Flow_PreVisitEstimate" name="Orçamento" sourceRef="Gateway_ServiceType" targetRef="Task_CalculateCopayEstimate">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${serviceType == 'PRE_VISIT_ESTIMATE'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1y8re44" sourceRef="Activity_1lkmtbn" targetRef="Gateway_1ukgpvb" />
    <bpmn:sequenceFlow id="Flow_1mrb90a" sourceRef="Activity_1vwhrk4" targetRef="Gateway_1lv6ayl" />
    <bpmn:sequenceFlow id="Flow_ToPatientAction" sourceRef="Task_SendBillNotification" targetRef="Gateway_PatientAction" />
    <bpmn:sequenceFlow id="Flow_QuestionBill" name="dúvida" sourceRef="Gateway_PatientAction" targetRef="Task_RouteBillingSupport" />
    <bpmn:sequenceFlow id="Flow_ViewBill" name="visualização" sourceRef="Gateway_PatientAction" targetRef="Task_SendDetailedBill">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${patientAction == 'VIEW'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_PayBill" name="pagamento" sourceRef="Gateway_PatientAction" targetRef="Gateway_1ukgpvb">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${patientAction == 'PAY'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ToSendBillNotification" sourceRef="Task_GenerateBillDetails" targetRef="Task_SendBillNotification" />
    <bpmn:sequenceFlow id="Flow_BillReady" name="conta pronta" sourceRef="Gateway_ServiceType" targetRef="Task_GenerateBillDetails">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${serviceType == 'BILL_READY'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ToServiceTypeGateway" sourceRef="StartEvent_FinancialServiceTriggered" targetRef="Gateway_ServiceType" />
    <bpmn:sequenceFlow id="Flow_InsuranceUpdate" name="Informações&#10;sobre o plano" sourceRef="Gateway_ServiceType" targetRef="Task_RequestInsuranceInfo" />
    <bpmn:sequenceFlow id="Flow_ViewToMerge" sourceRef="Task_SendDetailedBill" targetRef="Gateway_1fs6ggx" />
    <bpmn:sequenceFlow id="Flow_PaymentToMerge" sourceRef="Activity_1nfug9a" targetRef="Gateway_1lv6ayl" />
    <bpmn:sequenceFlow id="Flow_0rhe02j" sourceRef="Gateway_1lv6ayl" targetRef="Gateway_1c9m4ve" />
    <bpmn:sequenceFlow id="Flow_1ppyxnl" sourceRef="Gateway_03wtcaa" targetRef="Gateway_1fs6ggx" />
    <bpmn:sequenceFlow id="Flow_1u45hjv" sourceRef="Gateway_1fs6ggx" targetRef="Task_UpdateFinancialRecord" />
    <bpmn:sequenceFlow id="Flow_1lrxl3r" sourceRef="Task_RouteBillingSupport" targetRef="Gateway_03wtcaa" />
    <bpmn:sequenceFlow id="Flow_ToInsuranceResponse" sourceRef="Task_RequestInsuranceInfo" targetRef="Event_InsuranceResponse" />
    <bpmn:sequenceFlow id="Flow_ToVerifyCoverage" sourceRef="Event_InsuranceResponse" targetRef="Task_VerifyCoverage" />
    <bpmn:sequenceFlow id="Flow_ToEnd" sourceRef="Task_UpdateFinancialRecord" targetRef="EndEvent_FinancialServiceComplete" />
    <bpmn:serviceTask id="Task_SendEstimate" name="Enviar orçamento" camunda:type="external" camunda:topic="financial.send_estimate">
      <bpmn:incoming>Flow_ToSendEstimate</bpmn:incoming>
      <bpmn:outgoing>Flow_ToPatientAck</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_CalculateCopayEstimate" name="Realizar&#10;orçamento" camunda:type="external" camunda:topic="financial.copay_estimate">
      <bpmn:incoming>Flow_PreVisitEstimate</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSendEstimate</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_1lkmtbn" name="Obter ciência do paciente" camunda:type="external" camunda:topic="financial.patient_acknowledgment">
      <bpmn:incoming>Flow_ToPatientAck</bpmn:incoming>
      <bpmn:outgoing>Flow_1y8re44</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="BoundaryEvent_AckTimeout" name="após 24h&#10;sem retorno" attachedToRef="Activity_1lkmtbn">
      <bpmn:outgoing>Flow_AckTimeoutToMerge</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1f3sz9d">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P3D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_ToSendEstimate" sourceRef="Task_CalculateCopayEstimate" targetRef="Task_SendEstimate" />
    <bpmn:sequenceFlow id="Flow_ToPatientAck" sourceRef="Task_SendEstimate" targetRef="Activity_1lkmtbn" />
    <bpmn:sequenceFlow id="Flow_AckTimeoutToMerge" sourceRef="BoundaryEvent_AckTimeout" targetRef="Activity_1vwhrk4" />
    <bpmn:exclusiveGateway id="Gateway_PatientAction" name="Ação do&#10;paciente" default="Flow_QuestionBill">
      <bpmn:incoming>Flow_ToPatientAction</bpmn:incoming>
      <bpmn:outgoing>Flow_ViewBill</bpmn:outgoing>
      <bpmn:outgoing>Flow_PayBill</bpmn:outgoing>
      <bpmn:outgoing>Flow_QuestionBill</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_SendBillNotification" name="Enviar aviso de cobrança" camunda:type="external" camunda:topic="financial.bill_notification">
      <bpmn:incoming>Flow_ToSendBillNotification</bpmn:incoming>
      <bpmn:outgoing>Flow_ToPatientAction</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_GenerateBillDetails" name="Gerar detalhes da fatura" camunda:type="external" camunda:topic="financial.bill_ready">
      <bpmn:incoming>Flow_BillReady</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSendBillNotification</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_ServiceType" name="tipo de serviço" default="Flow_InsuranceUpdate">
      <bpmn:incoming>Flow_ToServiceTypeGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_PreVisitEstimate</bpmn:outgoing>
      <bpmn:outgoing>Flow_BillReady</bpmn:outgoing>
      <bpmn:outgoing>Flow_InsuranceUpdate</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_RequestInsuranceInfo" name="Solicitar informações" camunda:type="external" camunda:topic="financial.insurance_request">
      <bpmn:incoming>Flow_InsuranceUpdate</bpmn:incoming>
      <bpmn:outgoing>Flow_ToInsuranceResponse</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_1fs6ggx">
      <bpmn:incoming>Flow_ViewToMerge</bpmn:incoming>
      <bpmn:incoming>Flow_1ppyxnl</bpmn:incoming>
      <bpmn:incoming>Flow_0l5guoa</bpmn:incoming>
      <bpmn:outgoing>Flow_1u45hjv</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_SendDetailedBill" name="Enviar fatura detalhada" camunda:type="external" camunda:topic="financial.bill_detail">
      <bpmn:incoming>Flow_ViewBill</bpmn:incoming>
      <bpmn:outgoing>Flow_ViewToMerge</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_14ddlj2" sourceRef="Gateway_1ukgpvb" targetRef="Activity_1nfug9a" />
    <bpmn:manualTask id="Activity_1vwhrk4" name="Cancelar&#10;orçamento">
      <bpmn:incoming>Flow_AckTimeoutToMerge</bpmn:incoming>
      <bpmn:outgoing>Flow_1mrb90a</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:serviceTask id="Task_RouteBillingSupport" name="Enviar suporte&#10;de cobrança" camunda:type="external" camunda:topic="financial.billing_support">
      <bpmn:incoming>Flow_QuestionBill</bpmn:incoming>
      <bpmn:outgoing>Flow_1lrxl3r</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_VerifyCoverage" name="Validar cobertura" camunda:type="external" camunda:topic="financial.verify_coverage">
      <bpmn:incoming>Flow_ToVerifyCoverage</bpmn:incoming>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="BoundaryEvent_InsuranceTimeout" name="após 7 dias&#10;sem validação" attachedToRef="Task_VerifyCoverage">
      <bpmn:outgoing>Flow_07utwp4</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_InsuranceTimeout">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P7D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:exclusiveGateway id="Gateway_03wtcaa">
      <bpmn:incoming>Flow_1lrxl3r</bpmn:incoming>
      <bpmn:incoming>Flow_07utwp4</bpmn:incoming>
      <bpmn:outgoing>Flow_1ppyxnl</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:intermediateCatchEvent id="Event_InsuranceResponse" name="resposta do&#10;convênio">
      <bpmn:incoming>Flow_ToInsuranceResponse</bpmn:incoming>
      <bpmn:outgoing>Flow_ToVerifyCoverage</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDefinition_InsuranceResponse" messageRef="Message_InsuranceResponse" />
    </bpmn:intermediateCatchEvent>
    <bpmn:startEvent id="StartEvent_FinancialServiceTriggered" name="disparo de serviço financeiro">
      <bpmn:outgoing>Flow_ToServiceTypeGateway</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_07utwp4" sourceRef="BoundaryEvent_InsuranceTimeout" targetRef="Gateway_03wtcaa" />
    <bpmn:endEvent id="EndEvent_FinancialServiceComplete" name="Serviço financeiro concluído">
      <bpmn:incoming>Flow_ToEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_UpdateFinancialRecord" name="Atualizar registro no TASY" camunda:type="external" camunda:topic="financial.update_record">
      <bpmn:incoming>Flow_1u45hjv</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEnd</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_19ow8z6" name="desistência" sourceRef="Event_10hpvcr" targetRef="Activity_0nhfqoh" />
    <bpmn:sequenceFlow id="Flow_0l5guoa" sourceRef="Gateway_1c9m4ve" targetRef="Gateway_1fs6ggx" />
    <bpmn:sequenceFlow id="Flow_1bbahp8" sourceRef="Activity_0nhfqoh" targetRef="Gateway_1c9m4ve" />
    <bpmn:exclusiveGateway id="Gateway_1ukgpvb">
      <bpmn:incoming>Flow_PayBill</bpmn:incoming>
      <bpmn:incoming>Flow_1y8re44</bpmn:incoming>
      <bpmn:outgoing>Flow_14ddlj2</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:subProcess id="Activity_1nfug9a" name="SP-RC-015&#10;Pagamento">
      <bpmn:incoming>Flow_14ddlj2</bpmn:incoming>
      <bpmn:outgoing>Flow_PaymentToMerge</bpmn:outgoing>
      <bpmn:startEvent id="StartEvent_Activity_1nfug9a" name="Start">
        <bpmn:outgoing>Flow_internal_Activity_1nfug9a</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:endEvent id="EndEvent_Activity_1nfug9a" name="End">
        <bpmn:incoming>Flow_internal_Activity_1nfug9a</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_internal_Activity_1nfug9a" sourceRef="StartEvent_Activity_1nfug9a" targetRef="EndEvent_Activity_1nfug9a" />
    </bpmn:subProcess>
    <bpmn:exclusiveGateway id="Gateway_1lv6ayl">
      <bpmn:incoming>Flow_1mrb90a</bpmn:incoming>
      <bpmn:incoming>Flow_PaymentToMerge</bpmn:incoming>
      <bpmn:outgoing>Flow_0rhe02j</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gateway_1c9m4ve">
      <bpmn:incoming>Flow_0rhe02j</bpmn:incoming>
      <bpmn:incoming>Flow_1bbahp8</bpmn:incoming>
      <bpmn:outgoing>Flow_0l5guoa</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:boundaryEvent id="Event_10hpvcr" attachedToRef="Activity_1nfug9a">
      <bpmn:outgoing>Flow_19ow8z6</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_0h13s2x" />
    </bpmn:boundaryEvent>
    <bpmn:subProcess id="Activity_0nhfqoh" name="SP-RC_016&#10;Restituição">
      <bpmn:incoming>Flow_19ow8z6</bpmn:incoming>
      <bpmn:outgoing>Flow_1bbahp8</bpmn:outgoing>
      <bpmn:startEvent id="StartEvent_Activity_0nhfqoh" name="Start">
        <bpmn:outgoing>Flow_internal_Activity_0nhfqoh</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:endEvent id="EndEvent_Activity_0nhfqoh" name="End">
        <bpmn:incoming>Flow_internal_Activity_0nhfqoh</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_internal_Activity_0nhfqoh" sourceRef="StartEvent_Activity_0nhfqoh" targetRef="EndEvent_Activity_0nhfqoh" />
    </bpmn:subProcess>
  </bpmn:process>
  <bpmn:message id="Message_PatientAck" name="msg_patient_ack" />
  <bpmn:message id="Message_PaymentResponse" name="msg_payment_response" />
  <bpmn:message id="Message_InsuranceResponse" name="msg_insurance_response" />
  <bpmn:error id="Error_FinancialPayment" name="FINANCIAL_PAYMENT_ERROR" errorCode="FIN_PAYMENT" />
  <bpmn:error id="Error_FinancialEstimate" name="FINANCIAL_ESTIMATE_ERROR" errorCode="FIN_ESTIMATE" />
  <bpmndi:BPMNDiagram id="BPMNDiagram_SP_RC_014">
