<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DQ_FRESHNESS_002"
             name="DQ_FRESHNESS_002"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_DQ_FRESHNESS_002" name="[SP-PS-001 | analytics] Freshness Action Routing" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DQ_FRESHNESS_002" hitPolicy="FIRST">
      <input id="Input_freshnessLevel_DQ_FRESHNESS_002" label="Freshness Level">
        <inputExpression id="InputExpression_freshnessLevel_DQ_FRESHNESS_002" typeRef="string">
          <text>freshnessLevel</text>
        </inputExpression>
      </input>
      <input id="Input_criticalityLevel_DQ_FRESHNESS_002" label="Criticality Level">
        <inputExpression id="InputExpression_criticalityLevel_DQ_FRESHNESS_002" typeRef="string">
          <text>criticalityLevel</text>
        </inputExpression>
      </input>
      <input id="Input_affectedSystems_DQ_FRESHNESS_002" label="Affected Systems">
        <inputExpression id="InputExpression_affectedSystems_DQ_FRESHNESS_002" typeRef="number">
          <text>affectedSystems</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_DQ_FRESHNESS_002" label="Resultado" name="resultado" typeRef="string" />
      <output id="Output_observacao_DQ_FRESHNESS_002" label="Observação" name="observacao" typeRef="string" />
      <output id="Output_acaoRecomendada_DQ_FRESHNESS_002" label="Ação Recomendada" name="acaoRecomendada" typeRef="string" />
      <output id="Output_alertasConformidade_DQ_FRESHNESS_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string" />
      <output id="Output_riscoDenial_DQ_FRESHNESS_002" label="Risco Denial" name="riscoDenial" typeRef="string" />
      <rule id="Rule_DQ_FRESHNESS_002_1">
        <inputEntry id="InputEntry_DQ_FRESHNESS_002_1_1"><text>"STALE"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_FRESHNESS_002_1_2"><text>"HIGH"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_FRESHNESS_002_1_3"><text>&gt;= 3</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_1_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_1_2"><text>"Dados críticos obsoletos afetando múltiplos sistemas"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_1_3"><text>"Ativar protocolo de sincronização emergencial"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_1_4"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_1_5"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_FRESHNESS_002_2">
        <inputEntry id="InputEntry_DQ_FRESHNESS_002_2_1"><text>"STALE"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_FRESHNESS_002_2_2"><text>"HIGH"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_FRESHNESS_002_2_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_2_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_2_2"><text>"Dados críticos obsoletos"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_2_3"><text>"Forçar refresh imediato da fonte"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_2_4"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_2_5"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_FRESHNESS_002_3">
        <inputEntry id="InputEntry_DQ_FRESHNESS_002_3_1"><text>"AGING"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_FRESHNESS_002_3_2"><text>"MEDIUM"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_FRESHNESS_002_3_3"><text>&gt;= 2</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_3_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_3_2"><text>"Dados envelhecidos afetando múltiplos sistemas"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_3_3"><text>"Agendar sincronização prioritária em 4h"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_3_4"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_3_5"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_FRESHNESS_002_4">
        <inputEntry id="InputEntry_DQ_FRESHNESS_002_4_1"><text>"FRESH"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_FRESHNESS_002_4_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_FRESHNESS_002_4_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_4_1"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_4_2"><text>"Dados atualizados dentro do prazo esperado"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_4_3"><text>"Manter cadência de sincronização padrão"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_4_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_4_5"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_FRESHNESS_002_5">
        <inputEntry id="InputEntry_DQ_FRESHNESS_002_5_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_FRESHNESS_002_5_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_FRESHNESS_002_5_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_5_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_5_2"><text>"Combinação de freshness e criticidade não mapeada"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_5_3"><text>"Avaliar e definir ação apropriada"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_5_4"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_FRESHNESS_002_5_5"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DQ_FRESHNESS_002">
      <dmndi:DMNShape id="DMNShape_DQ_FRESHNESS_002" dmnElementRef="Decision_DQ_FRESHNESS_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
