<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DQ_TIMELINESS_001"
             name="DQ_TIMELINESS_001"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_DQ_TIMELINESS_001" name="[SP-PS-001 | analytics] Timeliness Assessment By Document Type" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DQ_TIMELINESS_001" hitPolicy="FIRST">
      <input id="Input_documentType_DQ_TIMELINESS_001" label="Document Type">
        <inputExpression id="InputExpression_documentType_DQ_TIMELINESS_001" typeRef="string">
          <text>documentType</text>
        </inputExpression>
      </input>
      <input id="Input_hoursDelay_DQ_TIMELINESS_001" label="Hours Delay">
        <inputExpression id="InputExpression_hoursDelay_DQ_TIMELINESS_001" typeRef="number">
          <text>hoursDelay</text>
        </inputExpression>
      </input>
      <input id="Input_isUrgent_DQ_TIMELINESS_001" label="Is Urgent">
        <inputExpression id="InputExpression_isUrgent_DQ_TIMELINESS_001" typeRef="boolean">
          <text>isUrgent</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_DQ_TIMELINESS_001" label="Resultado" name="resultado" typeRef="string" />
      <output id="Output_observacao_DQ_TIMELINESS_001" label="Observação" name="observacao" typeRef="string" />
      <output id="Output_acaoRecomendada_DQ_TIMELINESS_001" label="Ação Recomendada" name="acaoRecomendada" typeRef="string" />
      <output id="Output_alertasConformidade_DQ_TIMELINESS_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string" />
      <output id="Output_riscoDenial_DQ_TIMELINESS_001" label="Risco Denial" name="riscoDenial" typeRef="string" />
      <rule id="Rule_DQ_TIMELINESS_001_1">
        <inputEntry id="InputEntry_DQ_TIMELINESS_001_1_1"><text>"EMERGENCY_REPORT"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_TIMELINESS_001_1_2"><text>&gt; 2</text></inputEntry>
        <inputEntry id="InputEntry_DQ_TIMELINESS_001_1_3"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_1_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_1_2"><text>"Relatório de emergência atrasado (&gt;2h)"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_1_3"><text>"Escalar para supervisor e priorizar processamento"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_1_4"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_1_5"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_TIMELINESS_001_2">
        <inputEntry id="InputEntry_DQ_TIMELINESS_001_2_1"><text>"LAB_CRITICAL_RESULT"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_TIMELINESS_001_2_2"><text>&gt; 4</text></inputEntry>
        <inputEntry id="InputEntry_DQ_TIMELINESS_001_2_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_2_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_2_2"><text>"Resultado crítico de laboratório atrasado (&gt;4h)"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_2_3"><text>"Notificar médico imediatamente e registrar atraso"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_2_4"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_2_5"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_TIMELINESS_001_3">
        <inputEntry id="InputEntry_DQ_TIMELINESS_001_3_1"><text>"DISCHARGE_SUMMARY"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_TIMELINESS_001_3_2"><text>[24..72]</text></inputEntry>
        <inputEntry id="InputEntry_DQ_TIMELINESS_001_3_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_3_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_3_2"><text>"Sumário de alta atrasado (24-72h)"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_3_3"><text>"Notificar médico responsável para completar sumário"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_3_4"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_3_5"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_TIMELINESS_001_4">
        <inputEntry id="InputEntry_DQ_TIMELINESS_001_4_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_TIMELINESS_001_4_2"><text>&lt; 24</text></inputEntry>
        <inputEntry id="InputEntry_DQ_TIMELINESS_001_4_3"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_4_1"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_4_2"><text>"Documento dentro do prazo esperado (&lt;24h)"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_4_3"><text>"Processar documento normalmente"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_4_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_4_5"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_TIMELINESS_001_5">
        <inputEntry id="InputEntry_DQ_TIMELINESS_001_5_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_TIMELINESS_001_5_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_TIMELINESS_001_5_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_5_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_5_2"><text>"Tipo de documento não mapeado para timeliness"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_5_3"><text>"Definir SLA para este tipo de documento"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_5_4"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_TIMELINESS_001_5_5"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DQ_TIMELINESS_001">
      <dmndi:DMNShape id="DMNShape_DQ_TIMELINESS_001" dmnElementRef="Decision_DQ_TIMELINESS_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
