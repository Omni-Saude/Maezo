<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DQ_VALIDATION_003"
             name="DQ_VALIDATION_003"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_DQ_VALIDATION_003" name="[SP-PS-001 | analytics] Field-Level Validation Lab Results" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DQ_VALIDATION_003" hitPolicy="FIRST">
      <input id="Input_fieldName_DQ_VALIDATION_003" label="Field Name">
        <inputExpression id="InputExpression_fieldName_DQ_VALIDATION_003" typeRef="string">
          <text>fieldName</text>
        </inputExpression>
      </input>
      <input id="Input_valueInRange_DQ_VALIDATION_003" label="Value In Range">
        <inputExpression id="InputExpression_valueInRange_DQ_VALIDATION_003" typeRef="boolean">
          <text>valueInRange</text>
        </inputExpression>
      </input>
      <input id="Input_unitValid_DQ_VALIDATION_003" label="Unit Valid">
        <inputExpression id="InputExpression_unitValid_DQ_VALIDATION_003" typeRef="boolean">
          <text>unitValid</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_DQ_VALIDATION_003" label="Resultado" name="resultado" typeRef="string" />
      <output id="Output_observacao_DQ_VALIDATION_003" label="Observação" name="observacao" typeRef="string" />
      <output id="Output_acaoRecomendada_DQ_VALIDATION_003" label="Ação Recomendada" name="acaoRecomendada" typeRef="string" />
      <output id="Output_alertasConformidade_DQ_VALIDATION_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string" />
      <output id="Output_riscoDenial_DQ_VALIDATION_003" label="Risco Denial" name="riscoDenial" typeRef="string" />
      <rule id="Rule_DQ_VALIDATION_003_1">
        <inputEntry id="InputEntry_DQ_VALIDATION_003_1_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_VALIDATION_003_1_2"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_DQ_VALIDATION_003_1_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_1_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_1_2"><text>"Valor laboratorial fora da faixa aceitável"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_1_3"><text>"Solicitar reteste e validação pelo laboratório"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_1_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_1_5"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_VALIDATION_003_2">
        <inputEntry id="InputEntry_DQ_VALIDATION_003_2_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_VALIDATION_003_2_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_VALIDATION_003_2_3"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_2_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_2_2"><text>"Unidade de medida inválida ou incompatível"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_2_3"><text>"Padronizar unidade conforme tabela de referência"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_2_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_2_5"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_VALIDATION_003_3">
        <inputEntry id="InputEntry_DQ_VALIDATION_003_3_1"><text>"HEMOGLOBINA", "GLICOSE", "COLESTEROL"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_VALIDATION_003_3_2"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_DQ_VALIDATION_003_3_3"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_3_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_3_2"><text>"Resultado crítico dentro de faixa válida"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_3_3"><text>"Notificar médico responsável sobre resultado crítico"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_3_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_3_5"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_VALIDATION_003_4">
        <inputEntry id="InputEntry_DQ_VALIDATION_003_4_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_VALIDATION_003_4_2"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_DQ_VALIDATION_003_4_3"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_4_1"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_4_2"><text>"Resultado laboratorial válido"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_4_3"><text>"Disponibilizar resultado para equipe clínica"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_4_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_4_5"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_VALIDATION_003_5">
        <inputEntry id="InputEntry_DQ_VALIDATION_003_5_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_VALIDATION_003_5_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_VALIDATION_003_5_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_5_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_5_2"><text>"Exame não mapeado ou regras incompletas"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_5_3"><text>"Consultar catálogo de exames e definir faixas"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_5_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_VALIDATION_003_5_5"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DQ_VALIDATION_003">
      <dmndi:DMNShape id="DMNShape_DQ_VALIDATION_003" dmnElementRef="Decision_DQ_VALIDATION_003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
