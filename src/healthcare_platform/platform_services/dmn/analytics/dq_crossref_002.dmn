<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DQ_CROSSREF_002"
             name="DQ_CROSSREF_002"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_DQ_CROSSREF_002" name="[SP-PS-001 | analytics] Cross-Reference Resolution Actions" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DQ_CROSSREF_002" hitPolicy="FIRST">
      <input id="Input_discrepancyType_DQ_CROSSREF_002" label="Discrepancy Type">
        <inputExpression id="InputExpression_discrepancyType_DQ_CROSSREF_002" typeRef="string">
          <text>discrepancyType</text>
        </inputExpression>
      </input>
      <input id="Input_discrepancyCount_DQ_CROSSREF_002" label="Discrepancy Count">
        <inputExpression id="InputExpression_discrepancyCount_DQ_CROSSREF_002" typeRef="number">
          <text>discrepancyCount</text>
        </inputExpression>
      </input>
      <input id="Input_isPriority_DQ_CROSSREF_002" label="Is Priority">
        <inputExpression id="InputExpression_isPriority_DQ_CROSSREF_002" typeRef="boolean">
          <text>isPriority</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_DQ_CROSSREF_002" label="Resultado" name="resultado" typeRef="string" />
      <output id="Output_observacao_DQ_CROSSREF_002" label="Observação" name="observacao" typeRef="string" />
      <output id="Output_acaoRecomendada_DQ_CROSSREF_002" label="Ação Recomendada" name="acaoRecomendada" typeRef="string" />
      <output id="Output_alertasConformidade_DQ_CROSSREF_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string" />
      <output id="Output_riscoDenial_DQ_CROSSREF_002" label="Risco Denial" name="riscoDenial" typeRef="string" />
      <rule id="Rule_DQ_CROSSREF_002_1">
        <inputEntry id="InputEntry_DQ_CROSSREF_002_1_1"><text>"MISSING_SOURCE"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_CROSSREF_002_1_2"><text>&gt; 100</text></inputEntry>
        <inputEntry id="InputEntry_DQ_CROSSREF_002_1_3"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_1_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_1_2"><text>"Registros prioritários ausentes no sistema origem (&gt;100)"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_1_3"><text>"Executar carga retroativa do sistema origem"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_1_4"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_1_5"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_CROSSREF_002_2">
        <inputEntry id="InputEntry_DQ_CROSSREF_002_2_1"><text>"DUPLICATE_TARGET"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_CROSSREF_002_2_2"><text>&gt; 50</text></inputEntry>
        <inputEntry id="InputEntry_DQ_CROSSREF_002_2_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_2_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_2_2"><text>"Duplicações em massa no sistema destino (&gt;50)"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_2_3"><text>"Executar deduplicação e ajustar lógica de matching"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_2_4"><text>"DUP"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_2_5"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_CROSSREF_002_3">
        <inputEntry id="InputEntry_DQ_CROSSREF_002_3_1"><text>"DATA_MISMATCH"</text></inputEntry>
        <inputEntry id="InputEntry_DQ_CROSSREF_002_3_2"><text>[10..50]</text></inputEntry>
        <inputEntry id="InputEntry_DQ_CROSSREF_002_3_3"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_3_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_3_2"><text>"Divergências de dados em registros prioritários (10-50)"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_3_3"><text>"Revisar manualmente e definir fonte autoritativa"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_3_4"><text>"DUP"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_3_5"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_CROSSREF_002_4">
        <inputEntry id="InputEntry_DQ_CROSSREF_002_4_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_CROSSREF_002_4_2"><text>&lt; 10</text></inputEntry>
        <inputEntry id="InputEntry_DQ_CROSSREF_002_4_3"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_4_1"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_4_2"><text>"Discrepâncias pontuais de baixo impacto (&lt;10)"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_4_3"><text>"Incluir em fila de revisão de rotina"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_4_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_4_5"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_DQ_CROSSREF_002_5">
        <inputEntry id="InputEntry_DQ_CROSSREF_002_5_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_CROSSREF_002_5_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DQ_CROSSREF_002_5_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_5_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_5_2"><text>"Tipo de discrepância não mapeado"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_5_3"><text>"Classificar discrepância e definir resolução"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_5_4"><text>"DUP"</text></outputEntry>
        <outputEntry id="OutputEntry_DQ_CROSSREF_002_5_5"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DQ_CROSSREF_002">
      <dmndi:DMNShape id="DMNShape_DQ_CROSSREF_002" dmnElementRef="Decision_DQ_CROSSREF_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
