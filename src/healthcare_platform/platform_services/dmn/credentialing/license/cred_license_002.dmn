<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  CRED-LICENSE-002 - Registro Conselho Enfermagem (COREN)
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: CRED-LICENSE
  Perspectiva: HOSPITAL (Administrativo - Licenças Profissionais)

  ============================================================================
  INDICACOES (Quando PROSSEGUIR):
  ============================================================================
  - COREN ativo e válido
  - Categoria compatível com o procedimento
  - Profissional habilitado para atuar

  ============================================================================
  CONTRAINDICACOES (Quando BLOQUEAR):
  ============================================================================
  - Sem COREN ou COREN inativo
  - Categoria incompatível com procedimento
  - COREN suspenso ou cassado

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Lei 7.498/1986 - Exercício da Enfermagem
  - Resolução COFEN 564/2017 - Código de Ética
  - Decreto 94.406/1987
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_CRED_LICENSE_002"
             name="Registro Conselho Enfermagem (COREN)"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_CRED_LICENSE_002" name="[SP-PS-002 | credentialing/license] Registro COREN" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_CRED_LICENSE_002" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_CRED_LICENSE_002" label="Tem COREN">
        <inputExpression id="InputExpression_1_CRED_LICENSE_002" typeRef="boolean">
          <text>temCOREN</text>
        </inputExpression>
      </input>

      <input id="Input_2_CRED_LICENSE_002" label="COREN Ativo">
        <inputExpression id="InputExpression_2_CRED_LICENSE_002" typeRef="boolean">
          <text>corenAtivo</text>
        </inputExpression>
      </input>

      <input id="Input_3_CRED_LICENSE_002" label="Categoria Enfermagem">
        <inputExpression id="InputExpression_3_CRED_LICENSE_002" typeRef="string">
          <text>categoriaEnfermagem</text>
        </inputExpression>
        <inputValues id="InputValues_3_CRED_LICENSE_002">
          <text>"ENFERMEIRO", "TECNICO", "AUXILIAR"</text>
        </inputValues>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_CRED_LICENSE_002" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_CRED_LICENSE_002" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_CRED_LICENSE_002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_CRED_LICENSE_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_CRED_LICENSE_002" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA B1: Bloqueio - Sem COREN -->
      <rule id="Rule_Bloqueio_1_CRED_LICENSE_002">
        <description>Profissional sem COREN</description>
        <inputEntry id="InputEntry_B1_1_CRED_LICENSE_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_CRED_LICENSE_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_CRED_LICENSE_002"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B1_1_CRED_LICENSE_002"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_2_CRED_LICENSE_002"><text>"Profissional de enfermagem sem COREN. Não habilitado para atuar."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_3_CRED_LICENSE_002"><text>"Registrar profissional no COREN antes de permitir atuação."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_4_CRED_LICENSE_002"><text>"CRED"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_5_CRED_LICENSE_002"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA B2: Bloqueio - COREN inativo -->
      <rule id="Rule_Bloqueio_2_CRED_LICENSE_002">
        <description>COREN inativo ou suspenso</description>
        <inputEntry id="InputEntry_B2_1_CRED_LICENSE_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_CRED_LICENSE_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_CRED_LICENSE_002"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B2_1_CRED_LICENSE_002"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_2_CRED_LICENSE_002"><text>"COREN do profissional está inativo ou suspenso."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_3_CRED_LICENSE_002"><text>"Regularizar situação do COREN ou substituir profissional."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_4_CRED_LICENSE_002"><text>"CRED"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_5_CRED_LICENSE_002"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA P1: Aprovado - COREN ativo -->
      <rule id="Rule_Aprovado_1_CRED_LICENSE_002">
        <description>COREN ativo e regular</description>
        <inputEntry id="InputEntry_P1_1_CRED_LICENSE_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_CRED_LICENSE_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_CRED_LICENSE_002"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_CRED_LICENSE_002"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_2_CRED_LICENSE_002"><text>"Profissional com COREN ativo e regular no conselho de enfermagem."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_3_CRED_LICENSE_002"><text>"Prosseguir com faturamento conforme procedimento padrão."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_4_CRED_LICENSE_002"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_5_CRED_LICENSE_002"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisão manual -->
      <rule id="Rule_Fallback_CRED_LICENSE_002">
        <description>Regra padrão - Requer avaliação manual</description>
        <inputEntry id="InputEntry_F_1_CRED_LICENSE_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_CRED_LICENSE_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_CRED_LICENSE_002"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_CRED_LICENSE_002"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_CRED_LICENSE_002"><text>"Situação requer análise manual por não corresponder a nenhum critério automático."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_CRED_LICENSE_002"><text>"Encaminhar para auditoria administrativa para avaliação caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_CRED_LICENSE_002"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_CRED_LICENSE_002"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_CRED_LICENSE_002">
      <dmndi:DMNShape id="DMNShape_Decision_CRED_LICENSE_002" dmnElementRef="Decision_CRED_LICENSE_002">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
