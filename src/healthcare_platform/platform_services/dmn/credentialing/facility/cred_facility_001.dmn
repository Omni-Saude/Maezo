<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  CRED-FACILITY-001 - Habilitação Serviço Alta Complexidade
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: CRED-FACILITY
  Perspectiva: HOSPITAL (Administrativo - Habilitação de Serviços)

  ============================================================================
  INDICACOES (Quando PROSSEGUIR):
  ============================================================================
  - Serviço habilitado para alta complexidade
  - Portaria SUS vigente e válida
  - Hospital autorizado para o tipo de serviço

  ============================================================================
  CONTRAINDICACOES (Quando BLOQUEAR):
  ============================================================================
  - Serviço sem habilitação de alta complexidade
  - Portaria SUS vencida ou inexistente
  - Tipo de serviço não autorizado

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Portaria MS/SAS específica por habilitação
  - CNES - Cadastro habilitações
  - RN 259/2011 ANS - Rol de procedimentos
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_CRED_FACILITY_001"
             name="Habilitação Serviço Alta Complexidade"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_CRED_FACILITY_001" name="[SP-PS-002 | credentialing/facility] Habilitação Alta Complexidade" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_CRED_FACILITY_001" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_CRED_FACILITY_001" label="Habilitação Alta Complexidade">
        <inputExpression id="InputExpression_1_CRED_FACILITY_001" typeRef="boolean">
          <text>habilitacaoAltaComplexidade</text>
        </inputExpression>
      </input>

      <input id="Input_2_CRED_FACILITY_001" label="Tipo Serviço">
        <inputExpression id="InputExpression_2_CRED_FACILITY_001" typeRef="string">
          <text>tipoServico</text>
        </inputExpression>
        <inputValues id="InputValues_2_CRED_FACILITY_001">
          <text>"ONCOLOGIA", "CARDIO", "NEURO", "TRANSPLANTE"</text>
        </inputValues>
      </input>

      <input id="Input_3_CRED_FACILITY_001" label="Portaria SUS">
        <inputExpression id="InputExpression_3_CRED_FACILITY_001" typeRef="boolean">
          <text>portariaSUS</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_CRED_FACILITY_001" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_CRED_FACILITY_001" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_CRED_FACILITY_001" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_CRED_FACILITY_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_CRED_FACILITY_001" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA B1: Bloqueio - Sem habilitação -->
      <rule id="Rule_Bloqueio_1_CRED_FACILITY_001">
        <description>Hospital sem habilitação para alta complexidade</description>
        <inputEntry id="InputEntry_B1_1_CRED_FACILITY_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_CRED_FACILITY_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_CRED_FACILITY_001"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B1_1_CRED_FACILITY_001"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_2_CRED_FACILITY_001"><text>"Hospital não possui habilitação para serviço de alta complexidade."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_3_CRED_FACILITY_001"><text>"Solicitar habilitação junto ao Ministério da Saúde ou não faturar procedimento."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_4_CRED_FACILITY_001"><text>"CRED"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_5_CRED_FACILITY_001"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA B2: Bloqueio - Sem portaria SUS -->
      <rule id="Rule_Bloqueio_2_CRED_FACILITY_001">
        <description>Habilitação sem portaria SUS válida</description>
        <inputEntry id="InputEntry_B2_1_CRED_FACILITY_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_CRED_FACILITY_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_CRED_FACILITY_001"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_B2_1_CRED_FACILITY_001"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_2_CRED_FACILITY_001"><text>"Habilitação sem portaria SUS vigente ou válida."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_3_CRED_FACILITY_001"><text>"Renovar portaria de habilitação junto ao Ministério da Saúde."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_4_CRED_FACILITY_001"><text>"CRED"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_5_CRED_FACILITY_001"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA P1: Aprovado - Habilitação válida -->
      <rule id="Rule_Aprovado_1_CRED_FACILITY_001">
        <description>Hospital habilitado com portaria vigente</description>
        <inputEntry id="InputEntry_P1_1_CRED_FACILITY_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_CRED_FACILITY_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_CRED_FACILITY_001"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_CRED_FACILITY_001"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_2_CRED_FACILITY_001"><text>"Hospital habilitado para alta complexidade com portaria SUS vigente."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_3_CRED_FACILITY_001"><text>"Prosseguir com faturamento conforme procedimento padrão."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_4_CRED_FACILITY_001"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_5_CRED_FACILITY_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisão manual -->
      <rule id="Rule_Fallback_CRED_FACILITY_001">
        <description>Regra padrão - Requer avaliação manual</description>
        <inputEntry id="InputEntry_F_1_CRED_FACILITY_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_CRED_FACILITY_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_CRED_FACILITY_001"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_CRED_FACILITY_001"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_CRED_FACILITY_001"><text>"Situação requer análise manual por não corresponder a nenhum critério automático."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_CRED_FACILITY_001"><text>"Encaminhar para auditoria administrativa para avaliação caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_CRED_FACILITY_001"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_CRED_FACILITY_001"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_CRED_FACILITY_001">
      <dmndi:DMNShape id="DMNShape_Decision_CRED_FACILITY_001" dmnElementRef="Decision_CRED_FACILITY_001">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
