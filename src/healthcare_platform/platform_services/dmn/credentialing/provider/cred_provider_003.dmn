<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  CRED-PROVIDER-003 - Credenciamento Ativo na Operadora
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: CRED-PROVIDER
  Perspectiva: HOSPITAL (Administrativo - Credenciamento Médico)

  ============================================================================
  INDICACOES (Quando PROSSEGUIR):
  ============================================================================
  - Credenciamento ativo na operadora
  - Contrato vigente entre médico e operadora
  - Médico autorizado a atender beneficiários da operadora

  ============================================================================
  CONTRAINDICACOES (Quando BLOQUEAR):
  ============================================================================
  - Credenciamento inativo ou suspenso
  - Médico sem credenciamento na operadora
  - Contrato vencido ou rescindido

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Lei 9.656/1998 - Planos de saúde
  - RN 363/2014 ANS - Credenciamento
  - Contrato entre operadora e prestador
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_CRED_PROVIDER_003"
             name="Credenciamento Ativo na Operadora"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_CRED_PROVIDER_003" name="[SP-PS-002 | credentialing/provider] Credenciamento Ativo na Operadora" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_CRED_PROVIDER_003" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_CRED_PROVIDER_003" label="Credenciamento Ativo">
        <inputExpression id="InputExpression_1_CRED_PROVIDER_003" typeRef="boolean">
          <text>credenciamentoAtivo</text>
        </inputExpression>
      </input>

      <input id="Input_2_CRED_PROVIDER_003" label="Operadora">
        <inputExpression id="InputExpression_2_CRED_PROVIDER_003" typeRef="string">
          <text>operadora</text>
        </inputExpression>
      </input>

      <input id="Input_3_CRED_PROVIDER_003" label="Dias desde Credenciamento">
        <inputExpression id="InputExpression_3_CRED_PROVIDER_003" typeRef="integer">
          <text>diasDesdeCredenciamento</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_CRED_PROVIDER_003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_CRED_PROVIDER_003" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_CRED_PROVIDER_003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_CRED_PROVIDER_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_CRED_PROVIDER_003" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA B1: Bloqueio - Credenciamento inativo -->
      <rule id="Rule_Bloqueio_1_CRED_PROVIDER_003">
        <description>Médico sem credenciamento ativo na operadora</description>
        <inputEntry id="InputEntry_B1_1_CRED_PROVIDER_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_CRED_PROVIDER_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_CRED_PROVIDER_003"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B1_1_CRED_PROVIDER_003"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_2_CRED_PROVIDER_003"><text>"Médico não possui credenciamento ativo na operadora do beneficiário."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_3_CRED_PROVIDER_003"><text>"Ativar credenciamento do médico ou substituir por médico credenciado."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_4_CRED_PROVIDER_003"><text>"CRED"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_5_CRED_PROVIDER_003"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA A1: Alerta - Credenciamento muito recente -->
      <rule id="Rule_Alerta_1_CRED_PROVIDER_003">
        <description>Credenciamento com menos de 30 dias</description>
        <inputEntry id="InputEntry_A1_1_CRED_PROVIDER_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_CRED_PROVIDER_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_CRED_PROVIDER_003"><text>&lt; 30</text></inputEntry>
        <outputEntry id="OutputEntry_A1_1_CRED_PROVIDER_003"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_2_CRED_PROVIDER_003"><text>"Credenciamento do médico é muito recente. Validar junto à operadora."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_3_CRED_PROVIDER_003"><text>"Confirmar ativação do credenciamento junto à operadora antes de faturar."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_4_CRED_PROVIDER_003"><text>"CRED"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_5_CRED_PROVIDER_003"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA P1: Aprovado - Credenciamento ativo estabelecido -->
      <rule id="Rule_Aprovado_1_CRED_PROVIDER_003">
        <description>Médico credenciado há mais de 30 dias</description>
        <inputEntry id="InputEntry_P1_1_CRED_PROVIDER_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_CRED_PROVIDER_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_CRED_PROVIDER_003"><text>&gt;= 30</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_CRED_PROVIDER_003"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_2_CRED_PROVIDER_003"><text>"Médico possui credenciamento ativo e estabelecido na operadora."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_3_CRED_PROVIDER_003"><text>"Prosseguir com faturamento conforme procedimento padrão."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_4_CRED_PROVIDER_003"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_5_CRED_PROVIDER_003"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisão manual -->
      <rule id="Rule_Fallback_CRED_PROVIDER_003">
        <description>Regra padrão - Requer avaliação manual</description>
        <inputEntry id="InputEntry_F_1_CRED_PROVIDER_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_CRED_PROVIDER_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_CRED_PROVIDER_003"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_CRED_PROVIDER_003"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_CRED_PROVIDER_003"><text>"Situação requer análise manual por não corresponder a nenhum critério automático."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_CRED_PROVIDER_003"><text>"Encaminhar para auditoria administrativa para avaliação caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_CRED_PROVIDER_003"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_CRED_PROVIDER_003"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_CRED_PROVIDER_003">
      <dmndi:DMNShape id="DMNShape_Decision_CRED_PROVIDER_003" dmnElementRef="Decision_CRED_PROVIDER_003">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
