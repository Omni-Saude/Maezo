<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  CRED-PROVIDER-001 - CRM Médico Ativo no Estado
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: CRED-PROVIDER
  Perspectiva: HOSPITAL (Administrativo - Credenciamento Médico)

  ============================================================================
  INDICACOES (Quando PROSSEGUIR):
  ============================================================================
  - CRM ativo no estado do hospital
  - Registro regular no conselho regional
  - Médico habilitado para exercer a medicina no estado

  ============================================================================
  CONTRAINDICACOES (Quando BLOQUEAR):
  ============================================================================
  - CRM inativo ou suspenso
  - CRM de outro estado sem registro secundário
  - Médico com pendências no CRM

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Lei 3.268/1957 - Conselhos de Medicina
  - Resolução CFM 2.145/2016
  - Código de Ética Médica
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_CRED_PROVIDER_001"
             name="CRM Médico Ativo no Estado"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_CRED_PROVIDER_001" name="[SP-PS-002 | credentialing/provider] CRM Médico Ativo no Estado" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_CRED_PROVIDER_001" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_CRED_PROVIDER_001" label="CRM Ativo">
        <inputExpression id="InputExpression_1_CRED_PROVIDER_001" typeRef="boolean">
          <text>crmAtivo</text>
        </inputExpression>
      </input>

      <input id="Input_2_CRED_PROVIDER_001" label="Estado CRM">
        <inputExpression id="InputExpression_2_CRED_PROVIDER_001" typeRef="string">
          <text>estadoCRM</text>
        </inputExpression>
      </input>

      <input id="Input_3_CRED_PROVIDER_001" label="Estado Hospital">
        <inputExpression id="InputExpression_3_CRED_PROVIDER_001" typeRef="string">
          <text>estadoHospital</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_CRED_PROVIDER_001" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_CRED_PROVIDER_001" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_CRED_PROVIDER_001" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_CRED_PROVIDER_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_CRED_PROVIDER_001" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA B1: Bloqueio - CRM inativo -->
      <rule id="Rule_Bloqueio_1_CRED_PROVIDER_001">
        <description>CRM inativo ou suspenso</description>
        <inputEntry id="InputEntry_B1_1_CRED_PROVIDER_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_CRED_PROVIDER_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_CRED_PROVIDER_001"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B1_1_CRED_PROVIDER_001"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_2_CRED_PROVIDER_001"><text>"CRM do médico está inativo ou suspenso. Médico não habilitado para exercer."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_3_CRED_PROVIDER_001"><text>"Regularizar situação do CRM junto ao conselho regional ou substituir médico."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_4_CRED_PROVIDER_001"><text>"CRED"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_5_CRED_PROVIDER_001"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA A1: Alerta - CRM de outro estado -->
      <rule id="Rule_Alerta_1_CRED_PROVIDER_001">
        <description>CRM de estado diferente do hospital</description>
        <inputEntry id="InputEntry_A1_1_CRED_PROVIDER_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_CRED_PROVIDER_001"><text>not(estadoHospital)</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_CRED_PROVIDER_001"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_A1_1_CRED_PROVIDER_001"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_2_CRED_PROVIDER_001"><text>"CRM do médico é de estado diferente do hospital. Verificar registro secundário."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_3_CRED_PROVIDER_001"><text>"Confirmar que médico possui registro secundário no estado do hospital."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_4_CRED_PROVIDER_001"><text>"CRED"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_5_CRED_PROVIDER_001"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA P1: Aprovado - CRM ativo no estado -->
      <rule id="Rule_Aprovado_1_CRED_PROVIDER_001">
        <description>CRM ativo e do mesmo estado do hospital</description>
        <inputEntry id="InputEntry_P1_1_CRED_PROVIDER_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_CRED_PROVIDER_001"><text>estadoHospital</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_CRED_PROVIDER_001"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_CRED_PROVIDER_001"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_2_CRED_PROVIDER_001"><text>"CRM ativo no estado do hospital. Médico habilitado para atuar."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_3_CRED_PROVIDER_001"><text>"Prosseguir com faturamento conforme procedimento padrão."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_4_CRED_PROVIDER_001"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_5_CRED_PROVIDER_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisão manual -->
      <rule id="Rule_Fallback_CRED_PROVIDER_001">
        <description>Regra padrão - Requer avaliação manual</description>
        <inputEntry id="InputEntry_F_1_CRED_PROVIDER_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_CRED_PROVIDER_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_CRED_PROVIDER_001"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_CRED_PROVIDER_001"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_CRED_PROVIDER_001"><text>"Situação requer análise manual por não corresponder a nenhum critério automático."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_CRED_PROVIDER_001"><text>"Encaminhar para auditoria administrativa para avaliação caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_CRED_PROVIDER_001"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_CRED_PROVIDER_001"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_CRED_PROVIDER_001">
      <dmndi:DMNShape id="DMNShape_Decision_CRED_PROVIDER_001" dmnElementRef="Decision_CRED_PROVIDER_001">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
