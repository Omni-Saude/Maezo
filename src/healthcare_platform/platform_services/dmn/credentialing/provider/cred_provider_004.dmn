<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  CRED-PROVIDER-004 - Corpo Clínico Vínculo Hospital Válido
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: CRED-PROVIDER
  Perspectiva: HOSPITAL (Administrativo - Corpo Clínico)

  ============================================================================
  INDICACOES (Quando PROSSEGUIR):
  ============================================================================
  - Vínculo ativo do médico com o hospital
  - Documentação de vínculo completa e válida
  - Tipo de vínculo apropriado (efetivo, credenciado, visitante)

  ============================================================================
  CONTRAINDICACOES (Quando BLOQUEAR):
  ============================================================================
  - Médico sem vínculo ativo com o hospital
  - Documentação de vínculo ausente ou vencida
  - Tipo de vínculo não autorizado para o procedimento

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Lei 12.842/2013 - Ato médico
  - Resolução CFM 2.145/2016
  - Regimento Interno do Hospital
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_CRED_PROVIDER_004"
             name="Corpo Clínico Vínculo Hospital Válido"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_CRED_PROVIDER_004" name="[SP-PS-002 | credentialing/provider] Vínculo Hospital Válido" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_CRED_PROVIDER_004" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_CRED_PROVIDER_004" label="Vínculo Ativo">
        <inputExpression id="InputExpression_1_CRED_PROVIDER_004" typeRef="boolean">
          <text>vinculoAtivo</text>
        </inputExpression>
      </input>

      <input id="Input_2_CRED_PROVIDER_004" label="Tipo Vínculo">
        <inputExpression id="InputExpression_2_CRED_PROVIDER_004" typeRef="string">
          <text>tipoVinculo</text>
        </inputExpression>
        <inputValues id="InputValues_2_CRED_PROVIDER_004">
          <text>"EFETIVO", "CREDENCIADO", "VISITANTE"</text>
        </inputValues>
      </input>

      <input id="Input_3_CRED_PROVIDER_004" label="Documentação Vínculo">
        <inputExpression id="InputExpression_3_CRED_PROVIDER_004" typeRef="boolean">
          <text>documentacaoVinculo</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_CRED_PROVIDER_004" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_CRED_PROVIDER_004" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_CRED_PROVIDER_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_CRED_PROVIDER_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_CRED_PROVIDER_004" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA B1: Bloqueio - Sem vínculo ativo -->
      <rule id="Rule_Bloqueio_1_CRED_PROVIDER_004">
        <description>Médico sem vínculo ativo com o hospital</description>
        <inputEntry id="InputEntry_B1_1_CRED_PROVIDER_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_CRED_PROVIDER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_CRED_PROVIDER_004"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B1_1_CRED_PROVIDER_004"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_2_CRED_PROVIDER_004"><text>"Médico não possui vínculo ativo com o hospital no corpo clínico."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_3_CRED_PROVIDER_004"><text>"Ativar vínculo do médico no corpo clínico antes de permitir atendimentos."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_4_CRED_PROVIDER_004"><text>"CRED"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_5_CRED_PROVIDER_004"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA B2: Bloqueio - Documentação ausente -->
      <rule id="Rule_Bloqueio_2_CRED_PROVIDER_004">
        <description>Vínculo ativo mas documentação incompleta</description>
        <inputEntry id="InputEntry_B2_1_CRED_PROVIDER_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_CRED_PROVIDER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_CRED_PROVIDER_004"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_B2_1_CRED_PROVIDER_004"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_2_CRED_PROVIDER_004"><text>"Médico possui vínculo ativo mas documentação está incompleta ou vencida."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_3_CRED_PROVIDER_004"><text>"Completar documentação de vínculo no corpo clínico antes de faturar."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_4_CRED_PROVIDER_004"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_5_CRED_PROVIDER_004"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA A1: Alerta - Médico visitante -->
      <rule id="Rule_Alerta_1_CRED_PROVIDER_004">
        <description>Médico com vínculo visitante requer validação</description>
        <inputEntry id="InputEntry_A1_1_CRED_PROVIDER_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_CRED_PROVIDER_004"><text>"VISITANTE"</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_CRED_PROVIDER_004"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_A1_1_CRED_PROVIDER_004"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_2_CRED_PROVIDER_004"><text>"Médico possui vínculo visitante. Validar autorização para o procedimento."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_3_CRED_PROVIDER_004"><text>"Confirmar autorização do corpo clínico para médico visitante executar procedimento."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_4_CRED_PROVIDER_004"><text>"CRED"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_5_CRED_PROVIDER_004"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA P1: Aprovado - Vínculo efetivo ou credenciado válido -->
      <rule id="Rule_Aprovado_1_CRED_PROVIDER_004">
        <description>Vínculo ativo com documentação completa</description>
        <inputEntry id="InputEntry_P1_1_CRED_PROVIDER_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_CRED_PROVIDER_004"><text>"EFETIVO", "CREDENCIADO"</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_CRED_PROVIDER_004"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_CRED_PROVIDER_004"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_2_CRED_PROVIDER_004"><text>"Médico possui vínculo ativo e documentação completa no corpo clínico do hospital."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_3_CRED_PROVIDER_004"><text>"Prosseguir com faturamento conforme procedimento padrão."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_4_CRED_PROVIDER_004"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_5_CRED_PROVIDER_004"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisão manual -->
      <rule id="Rule_Fallback_CRED_PROVIDER_004">
        <description>Regra padrão - Requer avaliação manual</description>
        <inputEntry id="InputEntry_F_1_CRED_PROVIDER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_CRED_PROVIDER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_CRED_PROVIDER_004"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_CRED_PROVIDER_004"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_CRED_PROVIDER_004"><text>"Situação requer análise manual por não corresponder a nenhum critério automático."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_CRED_PROVIDER_004"><text>"Encaminhar para auditoria administrativa para avaliação caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_CRED_PROVIDER_004"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_CRED_PROVIDER_004"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_CRED_PROVIDER_004">
      <dmndi:DMNShape id="DMNShape_Decision_CRED_PROVIDER_004" dmnElementRef="Decision_CRED_PROVIDER_004">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
