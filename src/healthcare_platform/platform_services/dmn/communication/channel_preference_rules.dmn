<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:biodi="http://bpmn.io/schema/dmn/biodi/2.0"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             id="Definitions_channel_preference"
             name="Channel Preference Rules"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="channel_preference_rules" name="[SP-PS-004 | communication] Channel Preference Rules" camunda:historyTimeToLive="180">
    <informationRequirement>
      <requiredInput href="#InputData_patientAge"/>
    </informationRequirement>
    <informationRequirement>
      <requiredInput href="#InputData_hasWhatsApp"/>
    </informationRequirement>
    <informationRequirement>
      <requiredInput href="#InputData_preferredChannel"/>
    </informationRequirement>
    <informationRequirement>
      <requiredInput href="#InputData_messageType"/>
    </informationRequirement>

    <decisionTable id="DecisionTable_channel" hitPolicy="FIRST">
      <input id="Input_patientAge_channel_preference_rules" label="Patient Age" camunda:inputVariable="patientAge">
        <inputExpression id="InputExpression_patientAge_channel_preference_rules" typeRef="integer">
          <text>patientAge</text>
        </inputExpression>
      </input>

      <input id="Input_hasWhatsApp_channel_preference_rules" label="Has WhatsApp" camunda:inputVariable="hasWhatsApp">
        <inputExpression id="InputExpression_hasWhatsApp_channel_preference_rules" typeRef="boolean">
          <text>hasWhatsApp</text>
        </inputExpression>
      </input>

      <input id="Input_preferredChannel_channel_preference_rules" label="Preferred Channel" camunda:inputVariable="preferredChannel">
        <inputExpression id="InputExpression_preferredChannel_channel_preference_rules" typeRef="string">
          <text>preferredChannel</text>
        </inputExpression>
        <inputValues id="UnaryTests_preferredChannel_channel_preference_rules">
          <text>"whatsapp","sms","email","any"</text>
        </inputValues>
      </input>

      <input id="Input_messageType_channel_preference_rules" label="Message Type" camunda:inputVariable="messageType">
        <inputExpression id="InputExpression_messageType_channel_preference_rules" typeRef="string">
          <text>messageType</text>
        </inputExpression>
        <inputValues id="UnaryTests_messageType_channel_preference_rules">
          <text>"notification","interactive","document"</text>
        </inputValues>
      </input>

      <output id="Output_primaryChannel_channel_preference_rules" label="Primary Channel" name="primaryChannel" typeRef="string">
        <outputValues id="UnaryTests_primaryChannel_channel_preference_rules">
          <text>"whatsapp","sms","email"</text>
        </outputValues>
      </output>
      <output id="Output_fallbackChannel_channel_preference_rules" label="Fallback Channel" name="fallbackChannel" typeRef="string">
        <outputValues id="UnaryTests_fallbackChannel_channel_preference_rules">
          <text>"whatsapp","sms","email"</text>
        </outputValues>
      </output>

      <!-- Rule 1: Interactive messages with WhatsApp available -->
      <rule id="Rule_interactive_whatsapp_channel_preference_rules">
        <description>Interactive messages: prefer WhatsApp for rich interactions, fallback to SMS</description>
        <inputEntry id="InputEntry_r1_patientAge_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r1_hasWhatsApp_channel_preference_rules">
          <text>true</text>
        </inputEntry>
        <inputEntry id="InputEntry_r1_preferredChannel_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r1_messageType_channel_preference_rules">
          <text>"interactive"</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r1_primaryChannel_channel_preference_rules">
          <text>"whatsapp"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r1_fallbackChannel_channel_preference_rules">
          <text>"sms"</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: Interactive messages without WhatsApp -->
      <rule id="Rule_interactive_no_whatsapp_channel_preference_rules">
        <description>Interactive messages without WhatsApp: use SMS, fallback to email</description>
        <inputEntry id="InputEntry_r2_patientAge_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r2_hasWhatsApp_channel_preference_rules">
          <text>false</text>
        </inputEntry>
        <inputEntry id="InputEntry_r2_preferredChannel_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r2_messageType_channel_preference_rules">
          <text>"interactive"</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r2_primaryChannel_channel_preference_rules">
          <text>"sms"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r2_fallbackChannel_channel_preference_rules">
          <text>"email"</text>
        </outputEntry>
      </rule>

      <!-- Rule 3: Document messages with WhatsApp -->
      <rule id="Rule_document_whatsapp_channel_preference_rules">
        <description>Document messages: WhatsApp supports rich media and PDFs, fallback to email</description>
        <inputEntry id="InputEntry_r3_patientAge_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r3_hasWhatsApp_channel_preference_rules">
          <text>true</text>
        </inputEntry>
        <inputEntry id="InputEntry_r3_preferredChannel_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r3_messageType_channel_preference_rules">
          <text>"document"</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r3_primaryChannel_channel_preference_rules">
          <text>"whatsapp"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r3_fallbackChannel_channel_preference_rules">
          <text>"email"</text>
        </outputEntry>
      </rule>

      <!-- Rule 4: Document messages without WhatsApp -->
      <rule id="Rule_document_no_whatsapp_channel_preference_rules">
        <description>Document messages without WhatsApp: email is best for attachments</description>
        <inputEntry id="InputEntry_r4_patientAge_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r4_hasWhatsApp_channel_preference_rules">
          <text>false</text>
        </inputEntry>
        <inputEntry id="InputEntry_r4_preferredChannel_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r4_messageType_channel_preference_rules">
          <text>"document"</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r4_primaryChannel_channel_preference_rules">
          <text>"email"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r4_fallbackChannel_channel_preference_rules">
          <text>"sms"</text>
        </outputEntry>
      </rule>

      <!-- Rule 5: Elderly patients - simple notification -->
      <rule id="Rule_elderly_notification_channel_preference_rules">
        <description>Elderly patients (70+) with notifications: prefer simpler SMS channel</description>
        <inputEntry id="InputEntry_r5_patientAge_channel_preference_rules">
          <text>&gt; 70</text>
        </inputEntry>
        <inputEntry id="InputEntry_r5_hasWhatsApp_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r5_preferredChannel_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r5_messageType_channel_preference_rules">
          <text>"notification"</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r5_primaryChannel_channel_preference_rules">
          <text>"sms"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r5_fallbackChannel_channel_preference_rules">
          <text>"email"</text>
        </outputEntry>
      </rule>

      <!-- Rule 6: Elderly patients - interactive with WhatsApp -->
      <rule id="Rule_elderly_interactive_whatsapp_channel_preference_rules">
        <description>Elderly patients (70+) with WhatsApp and interactive: still use WhatsApp for familiarity</description>
        <inputEntry id="InputEntry_r6_patientAge_channel_preference_rules">
          <text>&gt; 70</text>
        </inputEntry>
        <inputEntry id="InputEntry_r6_hasWhatsApp_channel_preference_rules">
          <text>true</text>
        </inputEntry>
        <inputEntry id="InputEntry_r6_preferredChannel_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r6_messageType_channel_preference_rules">
          <text>"interactive"</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r6_primaryChannel_channel_preference_rules">
          <text>"whatsapp"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r6_fallbackChannel_channel_preference_rules">
          <text>"sms"</text>
        </outputEntry>
      </rule>

      <!-- Rule 7: User preference WhatsApp with capability -->
      <rule id="Rule_preference_whatsapp_channel_preference_rules">
        <description>User explicitly prefers WhatsApp and has it enabled</description>
        <inputEntry id="InputEntry_r7_patientAge_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r7_hasWhatsApp_channel_preference_rules">
          <text>true</text>
        </inputEntry>
        <inputEntry id="InputEntry_r7_preferredChannel_channel_preference_rules">
          <text>"whatsapp"</text>
        </inputEntry>
        <inputEntry id="InputEntry_r7_messageType_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r7_primaryChannel_channel_preference_rules">
          <text>"whatsapp"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r7_fallbackChannel_channel_preference_rules">
          <text>"sms"</text>
        </outputEntry>
      </rule>

      <!-- Rule 8: User preference SMS -->
      <rule id="Rule_preference_sms_channel_preference_rules">
        <description>User explicitly prefers SMS</description>
        <inputEntry id="InputEntry_r8_patientAge_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r8_hasWhatsApp_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r8_preferredChannel_channel_preference_rules">
          <text>"sms"</text>
        </inputEntry>
        <inputEntry id="InputEntry_r8_messageType_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r8_primaryChannel_channel_preference_rules">
          <text>"sms"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r8_fallbackChannel_channel_preference_rules">
          <text>"whatsapp"</text>
        </outputEntry>
      </rule>

      <!-- Rule 9: User preference email -->
      <rule id="Rule_preference_email_channel_preference_rules">
        <description>User explicitly prefers email</description>
        <inputEntry id="InputEntry_r9_patientAge_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r9_hasWhatsApp_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r9_preferredChannel_channel_preference_rules">
          <text>"email"</text>
        </inputEntry>
        <inputEntry id="InputEntry_r9_messageType_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r9_primaryChannel_channel_preference_rules">
          <text>"email"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r9_fallbackChannel_channel_preference_rules">
          <text>"whatsapp"</text>
        </outputEntry>
      </rule>

      <!-- Rule 10: Default with WhatsApp -->
      <rule id="Rule_default_whatsapp_channel_preference_rules">
        <description>Default case with WhatsApp available: use WhatsApp with email fallback</description>
        <inputEntry id="InputEntry_r10_patientAge_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r10_hasWhatsApp_channel_preference_rules">
          <text>true</text>
        </inputEntry>
        <inputEntry id="InputEntry_r10_preferredChannel_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r10_messageType_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r10_primaryChannel_channel_preference_rules">
          <text>"whatsapp"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r10_fallbackChannel_channel_preference_rules">
          <text>"email"</text>
        </outputEntry>
      </rule>

      <!-- Rule 11: Default without WhatsApp -->
      <rule id="Rule_default_no_whatsapp_channel_preference_rules">
        <description>Default case without WhatsApp: use SMS with email fallback</description>
        <inputEntry id="InputEntry_r11_patientAge_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r11_hasWhatsApp_channel_preference_rules">
          <text>false</text>
        </inputEntry>
        <inputEntry id="InputEntry_r11_preferredChannel_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_r11_messageType_channel_preference_rules">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_r11_primaryChannel_channel_preference_rules">
          <text>"sms"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_r11_fallbackChannel_channel_preference_rules">
          <text>"email"</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <inputData id="InputData_patientAge_channel_preference_rules" name="Patient Age"/>
  <inputData id="InputData_hasWhatsApp_channel_preference_rules" name="Has WhatsApp"/>
  <inputData id="InputData_preferredChannel_channel_preference_rules" name="Preferred Channel"/>
  <inputData id="InputData_messageType_channel_preference_rules" name="Message Type"/>


  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_channel_preference_rules">
      <dmndi:DMNShape id="DMNShape_channel_preference_rules" dmnElementRef="channel_preference_rules">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
