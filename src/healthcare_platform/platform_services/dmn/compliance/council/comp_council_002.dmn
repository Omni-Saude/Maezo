<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-COUNCIL-002 - Registro COREN Enfermagem
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-COUNCIL
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_COUNCIL_002" name="Registro COREN Enfermagem" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_COUNCIL_002" name="[SP-PS-001 | compliance/council] Validacao Registro COREN" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_COUNCIL_002" hitPolicy="FIRST">

      <input id="Input_1_COMP_COUNCIL_002" label="Categoria COREN">
        <inputExpression id="InputExpression_1_COMP_COUNCIL_002" typeRef="string">
          <text>categoriaCOREN</text>
        </inputExpression>
        <inputValues><text>"ENFERMEIRO", "TECNICO", "AUXILIAR", "OBSTETRA"</text></inputValues>
      </input>

      <input id="Input_2_COMP_COUNCIL_002" label="Situacao Registro">
        <inputExpression id="InputExpression_2_COMP_COUNCIL_002" typeRef="string">
          <text>situacaoRegistro</text>
        </inputExpression>
        <inputValues><text>"ATIVO", "SUSPENSO", "CASSADO", "CANCELADO", "PENDENTE"</text></inputValues>
      </input>

      <input id="Input_3_COMP_COUNCIL_002" label="Responsabilidade Tecnica Regular">
        <inputExpression id="InputExpression_3_COMP_COUNCIL_002" typeRef="boolean">
          <text>responsabilidadeTecnicaRegular</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_COUNCIL_002" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_COUNCIL_002" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_COUNCIL_002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_COUNCIL_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_COUNCIL_002" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_COUNCIL_002">
        <description>Registro COREN cassado - Bloqueio obrigatorio</description>
        <inputEntry id="InputEntry_B1_1_COMP_COUNCIL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_COUNCIL_002"><text>"CASSADO"</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_COUNCIL_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_COUNCIL_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_COUNCIL_002"><text>"Registro COREN cassado. Profissional de enfermagem impedido de exercer. Conforme Lei 5.905/1973, bloqueio imediato."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_COUNCIL_002"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_COUNCIL_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_COUNCIL_002"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_2_COMP_COUNCIL_002">
        <description>Registro COREN suspenso - Bloqueio</description>
        <inputEntry id="InputEntry_B2_1_COMP_COUNCIL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_COUNCIL_002"><text>"SUSPENSO"</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_COUNCIL_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_COMP_COUNCIL_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_COMP_COUNCIL_002"><text>"Registro COREN suspenso. Profissional temporariamente impedido. Verificar motivo da suspensao junto ao COREN regional."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_COMP_COUNCIL_002"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_4_COMP_COUNCIL_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_5_COMP_COUNCIL_002"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_3_COMP_COUNCIL_002">
        <description>RT de enfermagem irregular - Bloqueio</description>
        <inputEntry id="InputEntry_B3_1_COMP_COUNCIL_002"><text>"ENFERMEIRO"</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_COMP_COUNCIL_002"><text>"ATIVO"</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_COMP_COUNCIL_002"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_B3_1_COMP_COUNCIL_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B3_2_COMP_COUNCIL_002"><text>"Responsabilidade Tecnica de enfermagem irregular. Hospital deve ter RT conforme Lei 7.498/1986. Regularizar imediatamente."</text></outputEntry>
<outputEntry id="OutputEntry_B3_3_COMP_COUNCIL_002"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_4_COMP_COUNCIL_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_5_COMP_COUNCIL_002"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_4_COMP_COUNCIL_002">
        <description>Registro COREN cancelado - Bloqueio</description>
        <inputEntry id="InputEntry_B4_1_COMP_COUNCIL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B4_2_COMP_COUNCIL_002"><text>"CANCELADO"</text></inputEntry>
        <inputEntry id="InputEntry_B4_3_COMP_COUNCIL_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B4_1_COMP_COUNCIL_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B4_2_COMP_COUNCIL_002"><text>"Registro COREN cancelado. Profissional sem habilitacao para exercicio da enfermagem. Bloqueio de escalas e faturamento."</text></outputEntry>
<outputEntry id="OutputEntry_B4_3_COMP_COUNCIL_002"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_4_4_COMP_COUNCIL_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_4_5_COMP_COUNCIL_002"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_COUNCIL_002">
        <description>Registro COREN pendente - Regularizar</description>
        <inputEntry id="InputEntry_A1_1_COMP_COUNCIL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_COUNCIL_002"><text>"PENDENTE"</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_COUNCIL_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_COUNCIL_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_COUNCIL_002"><text>"Registro COREN com pendencias. Regularizar anuidade ou documentacao para evitar suspensao do registro."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_COUNCIL_002"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_COUNCIL_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_COUNCIL_002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_COUNCIL_002">
        <description>Enfermeiro com RT regular</description>
        <inputEntry id="InputEntry_P1_1_COMP_COUNCIL_002"><text>"ENFERMEIRO"</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_COUNCIL_002"><text>"ATIVO"</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_COUNCIL_002"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_COUNCIL_002"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_COUNCIL_002"><text>"Registro COREN ativo e responsabilidade tecnica regular. Enfermeiro habilitado. Faturamento autorizado."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_COUNCIL_002"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_COUNCIL_002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_COUNCIL_002"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_2_COMP_COUNCIL_002">
        <description>Tecnico ou Auxiliar com registro ativo</description>
        <inputEntry id="InputEntry_P2_1_COMP_COUNCIL_002"><text>"TECNICO", "AUXILIAR"</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_COMP_COUNCIL_002"><text>"ATIVO"</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_COMP_COUNCIL_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_COMP_COUNCIL_002"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_COMP_COUNCIL_002"><text>"Registro COREN ativo. Profissional habilitado para atuar sob supervisao de enfermeiro. Escala autorizada."</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_COMP_COUNCIL_002"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_2_4_COMP_COUNCIL_002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_2_5_COMP_COUNCIL_002"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_COUNCIL_002">
        <description>Caso padrao - Revisao manual necessaria</description>
        <inputEntry id="InputEntry_F_1_COMP_COUNCIL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_COUNCIL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_COUNCIL_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_COUNCIL_002"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_COUNCIL_002"><text>"Status do registro COREN requer verificacao manual. Consultar portal do COREN para confirmar situacao cadastral."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_COUNCIL_002"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_COUNCIL_002_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_COUNCIL_002_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_COUNCIL_002">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_COUNCIL_002" dmnElementRef="Decision_COMP_COUNCIL_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>