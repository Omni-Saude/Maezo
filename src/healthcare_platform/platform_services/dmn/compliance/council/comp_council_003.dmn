<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-COUNCIL-003 - Registro CRF Farmacia
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-COUNCIL
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_COUNCIL_003" name="Registro CRF Farmacia" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_COUNCIL_003" name="[SP-PS-001 | compliance/council] Validacao Registro CRF" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_COUNCIL_003" hitPolicy="FIRST">

      <input id="Input_1_COMP_COUNCIL_003" label="Situacao CRF">
        <inputExpression id="InputExpression_1_COMP_COUNCIL_003" typeRef="string">
          <text>situacaoCRF</text>
        </inputExpression>
        <inputValues><text>"ATIVO", "SUSPENSO", "CASSADO", "CANCELADO", "PENDENTE"</text></inputValues>
      </input>

      <input id="Input_2_COMP_COUNCIL_003" label="RT Farmacia Regular">
        <inputExpression id="InputExpression_2_COMP_COUNCIL_003" typeRef="boolean">
          <text>rtFarmaciaRegular</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_COUNCIL_003" label="Status Licenca Especial">
        <inputExpression id="InputExpression_3_COMP_COUNCIL_003" typeRef="string">
          <text>statusLicencaEspecial</text>
        </inputExpression>
        <inputValues><text>"VIGENTE", "VENCIDA", "NAO_APLICAVEL", "EM_RENOVACAO"</text></inputValues>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_COUNCIL_003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_COUNCIL_003" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_COUNCIL_003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_COUNCIL_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_COUNCIL_003" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_COUNCIL_003">
        <description>Registro CRF cassado - Bloqueio obrigatorio</description>
        <inputEntry id="InputEntry_B1_1_COMP_COUNCIL_003"><text>"CASSADO"</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_COUNCIL_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_COUNCIL_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_COUNCIL_003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_COUNCIL_003"><text>"Registro CRF cassado. Farmaceutico impedido de exercer. Farmacia hospitalar sem habilitacao legal. Bloqueio imediato."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_COUNCIL_003"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_COUNCIL_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_COUNCIL_003"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_2_COMP_COUNCIL_003">
        <description>Registro CRF suspenso - Bloqueio</description>
        <inputEntry id="InputEntry_B2_1_COMP_COUNCIL_003"><text>"SUSPENSO"</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_COUNCIL_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_COUNCIL_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_COMP_COUNCIL_003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_COMP_COUNCIL_003"><text>"Registro CRF suspenso. Farmaceutico temporariamente impedido. Verificar motivo junto ao CRF regional."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_COMP_COUNCIL_003"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_4_COMP_COUNCIL_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_5_COMP_COUNCIL_003"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_3_COMP_COUNCIL_003">
        <description>Farmacia sem responsavel tecnico - Bloqueio</description>
        <inputEntry id="InputEntry_B3_1_COMP_COUNCIL_003"><text>"ATIVO"</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_COMP_COUNCIL_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_COMP_COUNCIL_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B3_1_COMP_COUNCIL_003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B3_2_COMP_COUNCIL_003"><text>"Farmacia hospitalar sem Responsavel Tecnico regular. Conforme Lei 3.820/1960, operacao irregular. Regularizar RT."</text></outputEntry>
<outputEntry id="OutputEntry_B3_3_COMP_COUNCIL_003"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_4_COMP_COUNCIL_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_5_COMP_COUNCIL_003"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_4_COMP_COUNCIL_003">
        <description>Licenca especial vencida para controlados - Bloqueio</description>
        <inputEntry id="InputEntry_B4_1_COMP_COUNCIL_003"><text>"ATIVO"</text></inputEntry>
        <inputEntry id="InputEntry_B4_2_COMP_COUNCIL_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B4_3_COMP_COUNCIL_003"><text>"VENCIDA"</text></inputEntry>
<outputEntry id="OutputEntry_B4_1_COMP_COUNCIL_003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B4_2_COMP_COUNCIL_003"><text>"Licenca especial ANVISA vencida para substancias controladas. Portaria 344/98. Dispensacao de controlados bloqueada."</text></outputEntry>
<outputEntry id="OutputEntry_B4_3_COMP_COUNCIL_003"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_4_4_COMP_COUNCIL_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_4_5_COMP_COUNCIL_003"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_COUNCIL_003">
        <description>Licenca especial em renovacao - Acompanhamento</description>
        <inputEntry id="InputEntry_A1_1_COMP_COUNCIL_003"><text>"ATIVO"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_COUNCIL_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_COUNCIL_003"><text>"EM_RENOVACAO"</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_COUNCIL_003"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_COUNCIL_003"><text>"Licenca especial em processo de renovacao. Acompanhar tramitacao na ANVISA. Operacao permitida com protocolo."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_COUNCIL_003"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_COUNCIL_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_COUNCIL_003"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_2_COMP_COUNCIL_003">
        <description>Registro CRF com pendencias - Regularizar</description>
        <inputEntry id="InputEntry_A2_1_COMP_COUNCIL_003"><text>"PENDENTE"</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_COMP_COUNCIL_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_COMP_COUNCIL_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_COMP_COUNCIL_003"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_COMP_COUNCIL_003"><text>"Registro CRF com pendencias. Regularizar anuidade ou documentacao para evitar suspensao."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_COMP_COUNCIL_003"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_4_COMP_COUNCIL_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_5_COMP_COUNCIL_003"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_COUNCIL_003">
        <description>Farmacia com CRF e licenca especial regulares</description>
        <inputEntry id="InputEntry_P1_1_COMP_COUNCIL_003"><text>"ATIVO"</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_COUNCIL_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_COUNCIL_003"><text>"VIGENTE"</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_COUNCIL_003"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_COUNCIL_003"><text>"Registro CRF ativo, RT regular e licenca especial vigente. Farmacia hospitalar autorizada para todas as dispensacoes."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_COUNCIL_003"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_COUNCIL_003"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_COUNCIL_003"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_2_COMP_COUNCIL_003">
        <description>Farmacia sem necessidade de licenca especial</description>
        <inputEntry id="InputEntry_P2_1_COMP_COUNCIL_003"><text>"ATIVO"</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_COMP_COUNCIL_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_COMP_COUNCIL_003"><text>"NAO_APLICAVEL"</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_COMP_COUNCIL_003"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_COMP_COUNCIL_003"><text>"Registro CRF ativo e RT regular. Farmacia nao dispensa controlados. Operacao autorizada."</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_COMP_COUNCIL_003"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_2_4_COMP_COUNCIL_003"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_2_5_COMP_COUNCIL_003"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_COUNCIL_003">
        <description>Caso padrao - Revisao manual necessaria</description>
        <inputEntry id="InputEntry_F_1_COMP_COUNCIL_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_COUNCIL_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_COUNCIL_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_COUNCIL_003"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_COUNCIL_003"><text>"Status do registro CRF requer verificacao manual. Consultar CRF e verificar licenca especial ANVISA."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_COUNCIL_003"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_COUNCIL_003_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_COUNCIL_003_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_COUNCIL_003">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_COUNCIL_003" dmnElementRef="Decision_COMP_COUNCIL_003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>