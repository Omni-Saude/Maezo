<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-TISS-004 - Validacao Formato Codigos
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-TISS
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_TISS_004" name="Validacao Formato Codigos" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_TISS_004" name="[SP-PS-001 | compliance/tiss] Validacao Formato Codigos" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_TISS_004" hitPolicy="FIRST">

      <input id="Input_1_COMP_TISS_004" label="Codigo TUSS Valido">
        <inputExpression id="InputExpression_1_COMP_TISS_004" typeRef="boolean">
          <text>codigoTussValido</text>
        </inputExpression>
      </input>

      <input id="Input_2_COMP_TISS_004" label="Codigo CID Valido">
        <inputExpression id="InputExpression_2_COMP_TISS_004" typeRef="boolean">
          <text>codigoCidValido</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_TISS_004" label="Formato Codigo Valido">
        <inputExpression id="InputExpression_3_COMP_TISS_004" typeRef="boolean">
          <text>formatoCodigoValido</text>
        </inputExpression>
      </input>

      <input id="Input_4_COMP_TISS_004" label="Digito Verificador OK">
        <inputExpression id="InputExpression_4_COMP_TISS_004" typeRef="boolean">
          <text>digitoVerificadorOk</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_TISS_004" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_TISS_004" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_TISS_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_TISS_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_TISS_004" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_TISS_004">
        <description>Codigo TUSS com formato invalido</description>
        <inputEntry id="InputEntry_B1_1_COMP_TISS_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_TISS_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_TISS_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_COMP_TISS_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_TISS_004"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_TISS_004"><text>"Codigo TUSS com formato invalido. Deve conter 8 digitos numericos conforme tabela TUSS vigente."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_TISS_004"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_TISS_004"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_TISS_004"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_2_COMP_TISS_004">
        <description>Codigo CID-10 com formato invalido</description>
        <inputEntry id="InputEntry_B2_1_COMP_TISS_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_TISS_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_TISS_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_COMP_TISS_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_COMP_TISS_004"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_COMP_TISS_004"><text>"Codigo CID-10 com formato invalido. Deve seguir padrao letra + digitos (ex: C50.9, I25.1)."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_COMP_TISS_004"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_4_COMP_TISS_004"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_5_COMP_TISS_004"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_3_COMP_TISS_004">
        <description>Formato de codigo geral invalido</description>
        <inputEntry id="InputEntry_B3_1_COMP_TISS_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_COMP_TISS_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_COMP_TISS_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B3_4_COMP_TISS_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B3_1_COMP_TISS_004"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B3_2_COMP_TISS_004"><text>"Formato de codigo invalido. Verificar CNES (7 digitos), CNPJ (14 digitos), CPF (11 digitos)."</text></outputEntry>
<outputEntry id="OutputEntry_B3_3_COMP_TISS_004"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_4_COMP_TISS_004"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_5_COMP_TISS_004"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_TISS_004">
        <description>Digito verificador incorreto</description>
        <inputEntry id="InputEntry_A1_1_COMP_TISS_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_TISS_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_TISS_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_COMP_TISS_004"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_TISS_004"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_TISS_004"><text>"Digito verificador incorreto em CNPJ ou CPF. Verificar dados cadastrais do prestador ou beneficiario."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_TISS_004"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_TISS_004"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_TISS_004"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_TISS_004">
        <description>Todos codigos com formato valido</description>
        <inputEntry id="InputEntry_P1_1_COMP_TISS_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_TISS_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_TISS_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_COMP_TISS_004"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_TISS_004"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_TISS_004"><text>"Todos codigos (TUSS, CID, CNES, CNPJ, CPF) com formato valido. Verificacao de integridade OK."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_TISS_004"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_TISS_004"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_TISS_004"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_TISS_004">
        <description>Caso padrao - Revisar formatos de codigo</description>
        <inputEntry id="InputEntry_F_1_COMP_TISS_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_TISS_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_TISS_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_COMP_TISS_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_TISS_004"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_TISS_004"><text>"Verificar formato de todos codigos: TUSS (8 dig), CID-10, CNES (7 dig), CNPJ (14 dig), CPF (11 dig)."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_TISS_004"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_TISS_004_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_TISS_004_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_TISS_004">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_TISS_004" dmnElementRef="Decision_COMP_TISS_004">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>