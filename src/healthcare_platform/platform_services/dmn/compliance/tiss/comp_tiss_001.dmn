<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-TISS-001 - Validacao Formato Guia TISS
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-TISS
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_TISS_001" name="Validacao Formato Guia TISS" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_TISS_001" name="[SP-PS-001 | compliance/tiss] Validacao Formato Guia TISS" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_TISS_001" hitPolicy="FIRST">

      <input id="Input_1_COMP_TISS_001" label="Tipo Guia">
        <inputExpression id="InputExpression_1_COMP_TISS_001" typeRef="string">
          <text>tipoGuia</text>
        </inputExpression>
        <inputValues><text>"SP_SADT", "CONSULTA", "INTERNACAO", "HONORARIOS", "RESUMO_INTERNACAO", "ODONTOLOGICO"</text></inputValues>
      </input>

      <input id="Input_2_COMP_TISS_001" label="Formato Valido">
        <inputExpression id="InputExpression_2_COMP_TISS_001" typeRef="boolean">
          <text>formatoValido</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_TISS_001" label="Estrutura XML Correta">
        <inputExpression id="InputExpression_3_COMP_TISS_001" typeRef="boolean">
          <text>estruturaXmlCorreta</text>
        </inputExpression>
      </input>

      <input id="Input_4_COMP_TISS_001" label="Schema Validado">
        <inputExpression id="InputExpression_4_COMP_TISS_001" typeRef="boolean">
          <text>schemaValidado</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_TISS_001" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_TISS_001" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_TISS_001" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_TISS_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_TISS_001" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_TISS_001">
        <description>Tipo de guia nao reconhecido pelo padrao TISS</description>
        <inputEntry id="InputEntry_B1_1_COMP_TISS_001"><text>not("SP_SADT", "CONSULTA", "INTERNACAO", "HONORARIOS", "RESUMO_INTERNACAO", "ODONTOLOGICO")</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_TISS_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_TISS_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_COMP_TISS_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_TISS_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_TISS_001"><text>"Tipo de guia nao reconhecido pelo padrao TISS. Utilizar tipo valido: SP_SADT, CONSULTA, INTERNACAO, HONORARIOS, RESUMO_INTERNACAO ou ODONTOLOGICO."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_TISS_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_TISS_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_TISS_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_2_COMP_TISS_001">
        <description>Formato da guia nao atende padrao TISS</description>
        <inputEntry id="InputEntry_B2_1_COMP_TISS_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_TISS_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_TISS_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_COMP_TISS_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_COMP_TISS_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_COMP_TISS_001"><text>"Formato da guia nao atende padrao TISS. Corrigir estrutura conforme especificacao ANS vigente."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_COMP_TISS_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_4_COMP_TISS_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_5_COMP_TISS_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_3_COMP_TISS_001">
        <description>Estrutura XML mal formada</description>
        <inputEntry id="InputEntry_B3_1_COMP_TISS_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_COMP_TISS_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_COMP_TISS_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B3_4_COMP_TISS_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B3_1_COMP_TISS_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B3_2_COMP_TISS_001"><text>"Estrutura XML mal formada. Verificar tags, namespaces e encoding UTF-8."</text></outputEntry>
<outputEntry id="OutputEntry_B3_3_COMP_TISS_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_4_COMP_TISS_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_5_COMP_TISS_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_TISS_001">
        <description>Schema XSD nao validado</description>
        <inputEntry id="InputEntry_A1_1_COMP_TISS_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_TISS_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_TISS_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_COMP_TISS_001"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_TISS_001"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_TISS_001"><text>"XML bem formado mas nao validou contra schema XSD TISS. Verificar versao do schema e elementos obrigatorios."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_TISS_001"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_TISS_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_TISS_001"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_TISS_001">
        <description>Guia SP/SADT com formato valido</description>
        <inputEntry id="InputEntry_P1_1_COMP_TISS_001"><text>"SP_SADT"</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_TISS_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_TISS_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_COMP_TISS_001"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_TISS_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_TISS_001"><text>"Guia SP/SADT com formato TISS valido. Schema validado. Prosseguir com envio."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_TISS_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_TISS_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_TISS_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_2_COMP_TISS_001">
        <description>Guia Internacao com formato valido</description>
        <inputEntry id="InputEntry_P2_1_COMP_TISS_001"><text>"INTERNACAO"</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_COMP_TISS_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_COMP_TISS_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_COMP_TISS_001"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_COMP_TISS_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_COMP_TISS_001"><text>"Guia de Internacao com formato TISS valido. Schema validado. Prosseguir com envio."</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_COMP_TISS_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_2_4_COMP_TISS_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_2_5_COMP_TISS_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_3_COMP_TISS_001">
        <description>Guia com formato TISS valido</description>
        <inputEntry id="InputEntry_P3_1_COMP_TISS_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P3_2_COMP_TISS_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P3_3_COMP_TISS_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P3_4_COMP_TISS_001"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P3_1_COMP_TISS_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P3_2_COMP_TISS_001"><text>"Guia TISS com formato valido, estrutura XML correta e schema validado. Pronto para envio."</text></outputEntry>
<outputEntry id="OutputEntry_P3_3_COMP_TISS_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_3_4_COMP_TISS_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_3_5_COMP_TISS_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_TISS_001">
        <description>Caso padrao - Revisar formato da guia</description>
        <inputEntry id="InputEntry_F_1_COMP_TISS_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_TISS_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_TISS_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_COMP_TISS_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_TISS_001"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_TISS_001"><text>"Verificar tipo de guia, formato, estrutura XML e validacao contra schema XSD TISS."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_TISS_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_TISS_001_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_TISS_001_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_TISS_001">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_TISS_001" dmnElementRef="Decision_COMP_TISS_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>