<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-TISS-005 - Formato Submissao Eletronica
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-TISS
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_TISS_005" name="Formato Submissao Eletronica" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_TISS_005" name="[SP-PS-001 | compliance/tiss] Validacao Submissao Eletronica" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_TISS_005" hitPolicy="FIRST">

      <input id="Input_1_COMP_TISS_005" label="Submissao Eletronica">
        <inputExpression id="InputExpression_1_COMP_TISS_005" typeRef="boolean">
          <text>submissaoEletronica</text>
        </inputExpression>
      </input>

      <input id="Input_2_COMP_TISS_005" label="Certificado Digital Valido">
        <inputExpression id="InputExpression_2_COMP_TISS_005" typeRef="boolean">
          <text>certificadoDigitalValido</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_TISS_005" label="Assinatura Digital OK">
        <inputExpression id="InputExpression_3_COMP_TISS_005" typeRef="boolean">
          <text>assinaturaDigitalOk</text>
        </inputExpression>
      </input>

      <input id="Input_4_COMP_TISS_005" label="Webservice Disponivel">
        <inputExpression id="InputExpression_4_COMP_TISS_005" typeRef="boolean">
          <text>webserviceDisponivel</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_TISS_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_TISS_005" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_TISS_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_TISS_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_TISS_005" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Alertar_1_COMP_TISS_005">
        <description>Submissao manual - Verificar se convenio aceita</description>
        <inputEntry id="InputEntry_A1_1_COMP_TISS_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_TISS_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_TISS_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_COMP_TISS_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_TISS_005"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_TISS_005"><text>"Submissao manual selecionada. Verificar se convenio aceita guias fisicas. Maioria exige submissao eletronica."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_TISS_005"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_TISS_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_TISS_005"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_1_COMP_TISS_005">
        <description>Certificado digital invalido ou expirado</description>
        <inputEntry id="InputEntry_B1_1_COMP_TISS_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_TISS_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_TISS_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_COMP_TISS_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_TISS_005"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_TISS_005"><text>"Certificado digital invalido ou expirado. Renovar certificado A1 ou A3 ICP-Brasil junto a autoridade certificadora."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_TISS_005"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_TISS_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_TISS_005"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_2_COMP_TISS_005">
        <description>Assinatura digital XMLDSig invalida</description>
        <inputEntry id="InputEntry_B2_1_COMP_TISS_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_TISS_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_TISS_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_COMP_TISS_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_COMP_TISS_005"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_COMP_TISS_005"><text>"Assinatura digital XMLDSig invalida. Verificar integridade do XML e processo de assinatura."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_COMP_TISS_005"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_4_COMP_TISS_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_5_COMP_TISS_005"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_2_COMP_TISS_005">
        <description>Webservice TISS indisponivel</description>
        <inputEntry id="InputEntry_A2_1_COMP_TISS_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_COMP_TISS_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_COMP_TISS_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_COMP_TISS_005"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_COMP_TISS_005"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_COMP_TISS_005"><text>"Webservice TISS do convenio indisponivel. Tentar novamente em alguns minutos ou contatar suporte tecnico."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_COMP_TISS_005"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_4_COMP_TISS_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_5_COMP_TISS_005"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_TISS_005">
        <description>Submissao eletronica pronta</description>
        <inputEntry id="InputEntry_P1_1_COMP_TISS_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_TISS_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_TISS_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_COMP_TISS_005"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_TISS_005"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_TISS_005"><text>"Submissao eletronica validada. Certificado OK, assinatura OK, webservice disponivel. Transmitir guia."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_TISS_005"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_TISS_005"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_TISS_005"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_TISS_005">
        <description>Caso padrao - Revisar requisitos submissao</description>
        <inputEntry id="InputEntry_F_1_COMP_TISS_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_TISS_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_TISS_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_COMP_TISS_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_TISS_005"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_TISS_005"><text>"Verificar requisitos de submissao: certificado digital, assinatura XMLDSig, disponibilidade webservice."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_TISS_005"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_TISS_005_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_TISS_005_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_TISS_005">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_TISS_005" dmnElementRef="Decision_COMP_TISS_005">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>