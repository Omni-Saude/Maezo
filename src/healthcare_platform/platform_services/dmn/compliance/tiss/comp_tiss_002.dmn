<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-TISS-002 - Conformidade Versao TISS
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-TISS
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_TISS_002" name="Conformidade Versao TISS" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_TISS_002" name="[SP-PS-001 | compliance/tiss] Validacao Versao TISS" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_TISS_002" hitPolicy="FIRST">

      <input id="Input_1_COMP_TISS_002" label="Versao TISS">
        <inputExpression id="InputExpression_1_COMP_TISS_002" typeRef="string">
          <text>versaoTISS</text>
        </inputExpression>
        <inputValues><text>"4.01.00", "4.00.00", "3.05.00", "3.04.00", "OUTRA"</text></inputValues>
      </input>

      <input id="Input_2_COMP_TISS_002" label="Versao Aceita Convenio">
        <inputExpression id="InputExpression_2_COMP_TISS_002" typeRef="boolean">
          <text>versaoAceitaConvenio</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_TISS_002" label="Data Vigencia Versao">
        <inputExpression id="InputExpression_3_COMP_TISS_002" typeRef="boolean">
          <text>versaoVigente</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_TISS_002" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_TISS_002" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_TISS_002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_TISS_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_TISS_002" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_TISS_002">
        <description>Versao TISS 3.04.00 ou anterior - Nao suportada</description>
        <inputEntry id="InputEntry_B1_1_COMP_TISS_002"><text>"3.04.00", "OUTRA"</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_TISS_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_TISS_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_TISS_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_TISS_002"><text>"Versao TISS nao suportada. Atualizar para versao 4.01.00 ou superior conforme RN ANS vigente."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_TISS_002"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_TISS_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_TISS_002"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_TISS_002">
        <description>Versao TISS 3.05.00 - Depreciada</description>
        <inputEntry id="InputEntry_A1_1_COMP_TISS_002"><text>"3.05.00"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_TISS_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_TISS_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_TISS_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_TISS_002"><text>"Versao TISS 3.05.00 depreciada. Atualizar para 4.01.00. Alguns convenios podem rejeitar."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_TISS_002"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_TISS_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_TISS_002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_2_COMP_TISS_002">
        <description>Versao TISS 4.00.00 - Aceita mas nao recomendada</description>
        <inputEntry id="InputEntry_A2_1_COMP_TISS_002"><text>"4.00.00"</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_COMP_TISS_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_COMP_TISS_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_COMP_TISS_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_COMP_TISS_002"><text>"Versao TISS 4.00.00 aceita pelo convenio. Recomendado atualizar para 4.01.00 para melhor compatibilidade."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_COMP_TISS_002"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_4_COMP_TISS_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_5_COMP_TISS_002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_2_COMP_TISS_002">
        <description>Versao nao aceita pelo convenio</description>
        <inputEntry id="InputEntry_B2_1_COMP_TISS_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_TISS_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_TISS_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_COMP_TISS_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_COMP_TISS_002"><text>"Versao TISS nao aceita pelo convenio. Verificar versao exigida e atualizar sistema."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_COMP_TISS_002"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_4_COMP_TISS_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_5_COMP_TISS_002"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_TISS_002">
        <description>Versao TISS 4.01.00 - Versao atual</description>
        <inputEntry id="InputEntry_P1_1_COMP_TISS_002"><text>"4.01.00"</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_TISS_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_TISS_002"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_TISS_002"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_TISS_002"><text>"Versao TISS 4.01.00 vigente e aceita pelo convenio. Conformidade total."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_TISS_002"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_TISS_002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_TISS_002"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_TISS_002">
        <description>Caso padrao - Revisar versao TISS</description>
        <inputEntry id="InputEntry_F_1_COMP_TISS_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_TISS_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_TISS_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_TISS_002"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_TISS_002"><text>"Verificar versao TISS utilizada, compatibilidade com convenio e vigencia da versao."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_TISS_002"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_TISS_002_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_TISS_002_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_TISS_002">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_TISS_002" dmnElementRef="Decision_COMP_TISS_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>