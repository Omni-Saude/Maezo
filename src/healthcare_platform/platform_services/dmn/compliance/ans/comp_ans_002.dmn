<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-ANS-002 - Prazo Resposta Autorizacao
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-ANS
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_ANS_002" name="Prazo Resposta Autorizacao" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_ANS_002" name="[SP-PS-001 | compliance/ans] Validacao Prazo Resposta Autorizacao" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_ANS_002" hitPolicy="FIRST">

      <input id="Input_1_COMP_ANS_002" label="Tipo Solicitacao">
        <inputExpression id="InputExpression_1_COMP_ANS_002" typeRef="string">
          <text>tipoSolicitacao</text>
        </inputExpression>
        <inputValues><text>"EMERGENCIA", "URGENCIA", "INTERNACAO_ELETIVA", "ALTA_COMPLEXIDADE", "DEMAIS"</text></inputValues>
      </input>

      <input id="Input_2_COMP_ANS_002" label="Prazo Resposta (dias)">
        <inputExpression id="InputExpression_2_COMP_ANS_002" typeRef="number">
          <text>prazoResposta</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_ANS_002" label="Resposta Recebida">
        <inputExpression id="InputExpression_3_COMP_ANS_002" typeRef="boolean">
          <text>respostaRecebida</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_ANS_002" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_ANS_002" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_ANS_002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_ANS_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_ANS_002" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_ANS_002">
        <description>Emergencia sem resposta imediata - Autorizacao tacita</description>
        <inputEntry id="InputEntry_B1_1_COMP_ANS_002"><text>"EMERGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_ANS_002"><text>&gt; 0</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_ANS_002"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_ANS_002"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_ANS_002"><text>"Emergencia sem resposta imediata. Autorizacao tacita conforme RN 566/2022. Registrar protocolo para cobranca."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_ANS_002"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_ANS_002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_ANS_002"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_ANS_002">
        <description>Urgencia com prazo excedido - Autorizacao tacita</description>
        <inputEntry id="InputEntry_A1_1_COMP_ANS_002"><text>"URGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_ANS_002"><text>&gt; 1</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_ANS_002"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_ANS_002"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_ANS_002"><text>"Urgencia sem resposta em 24h. Autorizacao tacita aplicavel. Registrar protocolo ANS para glosa indevida."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_ANS_002"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_ANS_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_ANS_002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_2_COMP_ANS_002">
        <description>Internacao eletiva prazo excedido</description>
        <inputEntry id="InputEntry_A2_1_COMP_ANS_002"><text>"INTERNACAO_ELETIVA"</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_COMP_ANS_002"><text>&gt; 5</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_COMP_ANS_002"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_COMP_ANS_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_COMP_ANS_002"><text>"Internacao eletiva sem resposta em 5 dias uteis. Considerar autorizacao tacita ou acionar ANS."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_COMP_ANS_002"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_4_COMP_ANS_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_5_COMP_ANS_002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_3_COMP_ANS_002">
        <description>Alta complexidade prazo excedido</description>
        <inputEntry id="InputEntry_A3_1_COMP_ANS_002"><text>"ALTA_COMPLEXIDADE"</text></inputEntry>
        <inputEntry id="InputEntry_A3_2_COMP_ANS_002"><text>&gt; 10</text></inputEntry>
        <inputEntry id="InputEntry_A3_3_COMP_ANS_002"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_A3_1_COMP_ANS_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A3_2_COMP_ANS_002"><text>"Alta complexidade sem resposta em 10 dias uteis. Prazo regulamentar excedido. Acionar SAC convenio."</text></outputEntry>
<outputEntry id="OutputEntry_A3_3_COMP_ANS_002"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_3_4_COMP_ANS_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_3_5_COMP_ANS_002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_4_COMP_ANS_002">
        <description>Demais procedimentos prazo excedido</description>
        <inputEntry id="InputEntry_A4_1_COMP_ANS_002"><text>"DEMAIS"</text></inputEntry>
        <inputEntry id="InputEntry_A4_2_COMP_ANS_002"><text>&gt; 5</text></inputEntry>
        <inputEntry id="InputEntry_A4_3_COMP_ANS_002"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_A4_1_COMP_ANS_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A4_2_COMP_ANS_002"><text>"Procedimento sem resposta em 5 dias uteis. Considerar autorizacao tacita conforme RN 566/2022."</text></outputEntry>
<outputEntry id="OutputEntry_A4_3_COMP_ANS_002"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_4_4_COMP_ANS_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_4_5_COMP_ANS_002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_ANS_002">
        <description>Resposta recebida dentro do prazo</description>
        <inputEntry id="InputEntry_P1_1_COMP_ANS_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_ANS_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_ANS_002"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_ANS_002"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_ANS_002"><text>"Resposta do convenio recebida. Verificar conteudo da autorizacao e prosseguir com faturamento."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_ANS_002"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_ANS_002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_ANS_002"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_ANS_002">
        <description>Caso padrao - Aguardar prazo</description>
        <inputEntry id="InputEntry_F_1_COMP_ANS_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_ANS_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_ANS_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_ANS_002"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_ANS_002"><text>"Aguardando resposta do convenio dentro do prazo regulamentar. Monitorar vencimento."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_ANS_002"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_ANS_002_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_ANS_002_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_ANS_002">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_ANS_002" dmnElementRef="Decision_COMP_ANS_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>