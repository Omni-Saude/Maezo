<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-ANS-004 - Protecao Direitos Consumidor
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-ANS
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_ANS_004" name="Protecao Direitos Consumidor" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_ANS_004" name="[SP-PS-001 | compliance/ans] Validacao Direitos Consumidor" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_ANS_004" hitPolicy="FIRST">

      <input id="Input_1_COMP_ANS_004" label="Negativa Justificada">
        <inputExpression id="InputExpression_1_COMP_ANS_004" typeRef="boolean">
          <text>negativaJustificada</text>
        </inputExpression>
      </input>

      <input id="Input_2_COMP_ANS_004" label="Clausula Contratual Clara">
        <inputExpression id="InputExpression_2_COMP_ANS_004" typeRef="boolean">
          <text>clausulaContratualClara</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_ANS_004" label="Informacao Prestada">
        <inputExpression id="InputExpression_3_COMP_ANS_004" typeRef="boolean">
          <text>informacaoPrestada</text>
        </inputExpression>
      </input>

      <input id="Input_4_COMP_ANS_004" label="Prazo Legal Cumprido">
        <inputExpression id="InputExpression_4_COMP_ANS_004" typeRef="boolean">
          <text>prazoLegalCumprido</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_ANS_004" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_ANS_004" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_ANS_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_ANS_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_ANS_004" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Alertar_1_COMP_ANS_004">
        <description>Negativa sem justificativa fundamentada - Violacao CDC Art. 51</description>
        <inputEntry id="InputEntry_A1_1_COMP_ANS_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_ANS_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_ANS_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_COMP_ANS_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_ANS_004"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_ANS_004"><text>"Negativa do convenio sem justificativa fundamentada. Possivel violacao CDC Art. 51. Solicitar justificativa por escrito."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_ANS_004"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_ANS_004"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_ANS_004"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_2_COMP_ANS_004">
        <description>Clausula contratual obscura - CDC Art. 47</description>
        <inputEntry id="InputEntry_A2_1_COMP_ANS_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_COMP_ANS_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_COMP_ANS_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_COMP_ANS_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_COMP_ANS_004"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_COMP_ANS_004"><text>"Clausula contratual obscura ou ambigua. CDC Art. 47 determina interpretacao favoravel ao consumidor. Contestar negativa."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_COMP_ANS_004"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_4_COMP_ANS_004"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_5_COMP_ANS_004"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_3_COMP_ANS_004">
        <description>Falta de informacao clara ao beneficiario</description>
        <inputEntry id="InputEntry_A3_1_COMP_ANS_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_2_COMP_ANS_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_3_COMP_ANS_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A3_4_COMP_ANS_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A3_1_COMP_ANS_004"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A3_2_COMP_ANS_004"><text>"Beneficiario nao foi informado adequadamente. CDC Art. 6 garante direito a informacao. Documentar comunicacao."</text></outputEntry>
<outputEntry id="OutputEntry_A3_3_COMP_ANS_004"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_3_4_COMP_ANS_004"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_3_5_COMP_ANS_004"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_ANS_004">
        <description>Prazo legal excedido - Autorizacao tacita</description>
        <inputEntry id="InputEntry_P1_1_COMP_ANS_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_ANS_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_ANS_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_COMP_ANS_004"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_ANS_004"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_ANS_004"><text>"Convenio nao cumpriu prazo legal de resposta. Autorizacao tacita aplicavel. Faturar e registrar protocolo para recurso."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_ANS_004"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_ANS_004"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_ANS_004"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_2_COMP_ANS_004">
        <description>Todos direitos do consumidor preservados</description>
        <inputEntry id="InputEntry_P2_1_COMP_ANS_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_COMP_ANS_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_COMP_ANS_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_COMP_ANS_004"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_COMP_ANS_004"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_COMP_ANS_004"><text>"Direitos do consumidor preservados. Processo em conformidade com CDC e Lei 9.656/98."</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_COMP_ANS_004"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_2_4_COMP_ANS_004"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_2_5_COMP_ANS_004"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_ANS_004">
        <description>Caso padrao - Revisar conformidade CDC</description>
        <inputEntry id="InputEntry_F_1_COMP_ANS_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_ANS_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_ANS_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_COMP_ANS_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_ANS_004"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_ANS_004"><text>"Verificar conformidade com CDC e Lei 9.656/98. Analisar justificativas e clausulas contratuais."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_ANS_004"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_ANS_004_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_ANS_004_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_ANS_004">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_ANS_004" dmnElementRef="Decision_COMP_ANS_004">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>