<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-ANS-001 - Cobertura ROL ANS
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-ANS
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_ANS_001" name="Cobertura ROL ANS" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_ANS_001" name="[SP-PS-001 | compliance/ans] Validacao Cobertura ROL ANS" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_ANS_001" hitPolicy="FIRST">

      <input id="Input_1_COMP_ANS_001" label="Dentro do ROL ANS">
        <inputExpression id="InputExpression_1_COMP_ANS_001" typeRef="boolean">
          <text>dentroDoRolANS</text>
        </inputExpression>
      </input>

      <input id="Input_2_COMP_ANS_001" label="Coberto pelo Contrato">
        <inputExpression id="InputExpression_2_COMP_ANS_001" typeRef="boolean">
          <text>cobertoContrato</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_ANS_001" label="Indicacao Clinica Valida">
        <inputExpression id="InputExpression_3_COMP_ANS_001" typeRef="boolean">
          <text>indicacaoClinicaValida</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_ANS_001" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_ANS_001" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_ANS_001" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_ANS_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_ANS_001" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_ANS_001">
        <description>Procedimento fora do ROL ANS - Bloqueio obrigatorio</description>
        <inputEntry id="InputEntry_B1_1_COMP_ANS_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_ANS_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_ANS_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_ANS_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_ANS_001"><text>"Procedimento nao consta no ROL ANS vigente (RN 465/2021). Cobranca particular ou verificar rol exemplificativo Lei 14.454/2022."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_ANS_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_ANS_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_ANS_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_2_COMP_ANS_001">
        <description>Sem cobertura contratual - Bloqueio</description>
        <inputEntry id="InputEntry_B2_1_COMP_ANS_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_ANS_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_ANS_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_COMP_ANS_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_COMP_ANS_001"><text>"Procedimento no ROL mas sem cobertura contratual. Verificar segmentacao do plano ou carencia."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_COMP_ANS_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_4_COMP_ANS_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_5_COMP_ANS_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_ANS_001">
        <description>Indicacao clinica nao validada - Requer justificativa</description>
        <inputEntry id="InputEntry_A1_1_COMP_ANS_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_ANS_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_ANS_001"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_ANS_001"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_ANS_001"><text>"Procedimento coberto mas indicacao clinica requer validacao. Anexar justificativa medica conforme DUT."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_ANS_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_ANS_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_ANS_001"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_ANS_001">
        <description>Cobertura ROL, contrato e indicacao clinica OK</description>
        <inputEntry id="InputEntry_P1_1_COMP_ANS_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_ANS_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_ANS_001"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_ANS_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_ANS_001"><text>"Procedimento dentro do ROL ANS, com cobertura contratual e indicacao clinica validada. Faturamento autorizado."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_ANS_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_ANS_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_ANS_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_ANS_001">
        <description>Caso padrao - Revisao manual necessaria</description>
        <inputEntry id="InputEntry_F_1_COMP_ANS_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_ANS_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_ANS_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_ANS_001"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_ANS_001"><text>"Criterios automaticos nao satisfeitos. Verificar: status ROL ANS, cobertura contratual, indicacao clinica."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_ANS_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_ANS_001_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_ANS_001_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_ANS_001">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_ANS_001" dmnElementRef="Decision_COMP_ANS_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>