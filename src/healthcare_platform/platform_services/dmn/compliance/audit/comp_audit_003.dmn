<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-AUDIT-003 - Logging de Acoes do Usuario
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-AUDIT
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_AUDIT_003" name="Logging de Acoes do Usuario" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_AUDIT_003" name="[SP-PS-001 | compliance/audit] Validacao Logging de Acoes" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_AUDIT_003" hitPolicy="FIRST">

      <input id="Input_1_COMP_AUDIT_003" label="Usuario Registrado">
        <inputExpression id="InputExpression_1_COMP_AUDIT_003" typeRef="boolean">
          <text>usuarioRegistrado</text>
        </inputExpression>
      </input>

      <input id="Input_2_COMP_AUDIT_003" label="Acao Logada">
        <inputExpression id="InputExpression_2_COMP_AUDIT_003" typeRef="boolean">
          <text>acaoLogada</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_AUDIT_003" label="IP Registrado">
        <inputExpression id="InputExpression_3_COMP_AUDIT_003" typeRef="boolean">
          <text>ipRegistrado</text>
        </inputExpression>
      </input>

      <input id="Input_4_COMP_AUDIT_003" label="Tipo Acao">
        <inputExpression id="InputExpression_4_COMP_AUDIT_003" typeRef="string">
          <text>tipoAcao</text>
        </inputExpression>
        <inputValues><text>"LOGIN", "LOGOUT", "CRIACAO", "ALTERACAO", "EXCLUSAO", "CONSULTA", "ACESSO_NEGADO"</text></inputValues>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_AUDIT_003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_AUDIT_003" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_AUDIT_003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_AUDIT_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_AUDIT_003" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_AUDIT_003">
        <description>Usuario nao registrado em acao critica</description>
        <inputEntry id="InputEntry_B1_1_COMP_AUDIT_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_AUDIT_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_AUDIT_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_COMP_AUDIT_003"><text>"CRIACAO", "ALTERACAO", "EXCLUSAO"</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_AUDIT_003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_AUDIT_003"><text>"CRITICO: Acao critica sem usuario registrado. Violacao de seguranca. Requer autenticacao."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_AUDIT_003"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_AUDIT_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_AUDIT_003"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_2_COMP_AUDIT_003">
        <description>Acao nao registrada no log</description>
        <inputEntry id="InputEntry_B2_1_COMP_AUDIT_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_AUDIT_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_AUDIT_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_COMP_AUDIT_003"><text>"CRIACAO", "ALTERACAO", "EXCLUSAO"</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_COMP_AUDIT_003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_COMP_AUDIT_003"><text>"Acao critica NAO REGISTRADA no log. Sistema de logging falhou. Verificar antes de prosseguir."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_COMP_AUDIT_003"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_4_COMP_AUDIT_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_5_COMP_AUDIT_003"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_AUDIT_003">
        <description>Tentativa de acesso negado</description>
        <inputEntry id="InputEntry_A1_1_COMP_AUDIT_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_AUDIT_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_AUDIT_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_COMP_AUDIT_003"><text>"ACESSO_NEGADO"</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_AUDIT_003"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_AUDIT_003"><text>"Tentativa de acesso negado registrada. Verificar se tentativa legitima ou possivel ataque."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_AUDIT_003"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_AUDIT_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_AUDIT_003"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_2_COMP_AUDIT_003">
        <description>IP de origem nao registrado</description>
        <inputEntry id="InputEntry_A2_1_COMP_AUDIT_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_COMP_AUDIT_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_COMP_AUDIT_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_COMP_AUDIT_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_COMP_AUDIT_003"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_COMP_AUDIT_003"><text>"IP de origem nao registrado. Dificulta rastreamento em caso de incidente. Configurar registro de IP."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_COMP_AUDIT_003"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_4_COMP_AUDIT_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_5_COMP_AUDIT_003"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_AUDIT_003">
        <description>Logging de acoes completo</description>
        <inputEntry id="InputEntry_P1_1_COMP_AUDIT_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_AUDIT_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_AUDIT_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_COMP_AUDIT_003"><text>"LOGIN", "LOGOUT", "CRIACAO", "ALTERACAO", "EXCLUSAO", "CONSULTA"</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_AUDIT_003"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_AUDIT_003"><text>"Logging de acoes completo. Usuario, acao e IP registrados corretamente."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_AUDIT_003"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_AUDIT_003"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_AUDIT_003"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_AUDIT_003">
        <description>Caso padrao - Revisar logging</description>
        <inputEntry id="InputEntry_F_1_COMP_AUDIT_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_AUDIT_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_AUDIT_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_COMP_AUDIT_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_AUDIT_003"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_AUDIT_003"><text>"Verificar configuracao de logging: usuario, acao, IP e tipo de acao."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_AUDIT_003"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_AUDIT_003_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_AUDIT_003_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_AUDIT_003">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_AUDIT_003" dmnElementRef="Decision_COMP_AUDIT_003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>