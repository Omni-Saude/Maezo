<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-AUDIT-004 - Validacao de Timestamp
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-AUDIT
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_AUDIT_004" name="Validacao de Timestamp" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_AUDIT_004" name="[SP-PS-001 | compliance/audit] Validacao de Timestamp" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_AUDIT_004" hitPolicy="FIRST">

      <input id="Input_1_COMP_AUDIT_004" label="Timestamp Valido">
        <inputExpression id="InputExpression_1_COMP_AUDIT_004" typeRef="boolean">
          <text>timestampValido</text>
        </inputExpression>
      </input>

      <input id="Input_2_COMP_AUDIT_004" label="Formato ISO 8601">
        <inputExpression id="InputExpression_2_COMP_AUDIT_004" typeRef="boolean">
          <text>formatoIso8601</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_AUDIT_004" label="Fuso Horario Definido">
        <inputExpression id="InputExpression_3_COMP_AUDIT_004" typeRef="boolean">
          <text>fusoHorarioDefinido</text>
        </inputExpression>
      </input>

      <input id="Input_4_COMP_AUDIT_004" label="Sincronizado NTP">
        <inputExpression id="InputExpression_4_COMP_AUDIT_004" typeRef="boolean">
          <text>sincronizadoNtp</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_AUDIT_004" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_AUDIT_004" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_AUDIT_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_AUDIT_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_AUDIT_004" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_AUDIT_004">
        <description>Timestamp invalido ou ausente</description>
        <inputEntry id="InputEntry_B1_1_COMP_AUDIT_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_AUDIT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_AUDIT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_COMP_AUDIT_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_AUDIT_004"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_AUDIT_004"><text>"Timestamp INVALIDO ou AUSENTE. Obrigatorio para ordem cronologica de eventos. Corrigir imediatamente."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_AUDIT_004"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_AUDIT_004"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_AUDIT_004"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_AUDIT_004">
        <description>Formato nao segue padrao ISO 8601</description>
        <inputEntry id="InputEntry_A1_1_COMP_AUDIT_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_AUDIT_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_AUDIT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_COMP_AUDIT_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_AUDIT_004"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_AUDIT_004"><text>"Formato de timestamp nao segue ISO 8601. Recomendado padronizar para interoperabilidade."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_AUDIT_004"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_AUDIT_004"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_AUDIT_004"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_2_COMP_AUDIT_004">
        <description>Fuso horario nao definido</description>
        <inputEntry id="InputEntry_A2_1_COMP_AUDIT_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_COMP_AUDIT_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_COMP_AUDIT_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_COMP_AUDIT_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_COMP_AUDIT_004"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_COMP_AUDIT_004"><text>"Fuso horario nao definido no timestamp. Pode causar ambiguidade. Usar UTC ou fuso local explicito."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_COMP_AUDIT_004"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_4_COMP_AUDIT_004"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_5_COMP_AUDIT_004"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_3_COMP_AUDIT_004">
        <description>Servidor nao sincronizado com NTP</description>
        <inputEntry id="InputEntry_A3_1_COMP_AUDIT_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A3_2_COMP_AUDIT_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A3_3_COMP_AUDIT_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A3_4_COMP_AUDIT_004"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_A3_1_COMP_AUDIT_004"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A3_2_COMP_AUDIT_004"><text>"Servidor nao sincronizado com NTP. Timestamps podem ter desvio. Configurar sincronizacao NTP."</text></outputEntry>
<outputEntry id="OutputEntry_A3_3_COMP_AUDIT_004"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_3_4_COMP_AUDIT_004"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_3_5_COMP_AUDIT_004"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_AUDIT_004">
        <description>Timestamp completo e corretamente configurado</description>
        <inputEntry id="InputEntry_P1_1_COMP_AUDIT_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_AUDIT_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_AUDIT_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_COMP_AUDIT_004"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_AUDIT_004"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_AUDIT_004"><text>"Timestamp valido: formato ISO 8601, fuso horario definido, sincronizado via NTP."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_AUDIT_004"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_AUDIT_004"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_AUDIT_004"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_AUDIT_004">
        <description>Caso padrao - Revisar timestamp</description>
        <inputEntry id="InputEntry_F_1_COMP_AUDIT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_AUDIT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_AUDIT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_COMP_AUDIT_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_AUDIT_004"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_AUDIT_004"><text>"Verificar configuracao de timestamp: validade, formato, fuso horario e sincronizacao NTP."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_AUDIT_004"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_AUDIT_004_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_AUDIT_004_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_AUDIT_004">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_AUDIT_004" dmnElementRef="Decision_COMP_AUDIT_004">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>