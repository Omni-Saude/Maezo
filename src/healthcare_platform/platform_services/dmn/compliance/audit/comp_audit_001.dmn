<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-AUDIT-001 - Trilha de Auditoria Completa
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-AUDIT
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_AUDIT_001" name="Trilha de Auditoria Completa" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_AUDIT_001" name="[SP-PS-001 | compliance/audit] Validacao Trilha de Auditoria" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_AUDIT_001" hitPolicy="FIRST">

      <input id="Input_1_COMP_AUDIT_001" label="Tem Audit Trail">
        <inputExpression id="InputExpression_1_COMP_AUDIT_001" typeRef="boolean">
          <text>temAuditTrail</text>
        </inputExpression>
      </input>

      <input id="Input_2_COMP_AUDIT_001" label="Decisoes Registradas">
        <inputExpression id="InputExpression_2_COMP_AUDIT_001" typeRef="boolean">
          <text>decisoesRegistradas</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_AUDIT_001" label="Usuario Identificado">
        <inputExpression id="InputExpression_3_COMP_AUDIT_001" typeRef="boolean">
          <text>usuarioIdentificado</text>
        </inputExpression>
      </input>

      <input id="Input_4_COMP_AUDIT_001" label="Justificativas Completas">
        <inputExpression id="InputExpression_4_COMP_AUDIT_001" typeRef="boolean">
          <text>justificativasCompletas</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_AUDIT_001" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_AUDIT_001" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_AUDIT_001" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_AUDIT_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_AUDIT_001" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_AUDIT_001">
        <description>Trilha de auditoria ausente</description>
        <inputEntry id="InputEntry_B1_1_COMP_AUDIT_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_AUDIT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_AUDIT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_COMP_AUDIT_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_AUDIT_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_AUDIT_001"><text>"Trilha de auditoria AUSENTE. Obrigatorio para rastreabilidade. Ativar logging antes de prosseguir."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_AUDIT_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_AUDIT_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_AUDIT_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_2_COMP_AUDIT_001">
        <description>Decisoes automaticas nao registradas</description>
        <inputEntry id="InputEntry_B2_1_COMP_AUDIT_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_AUDIT_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_AUDIT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_COMP_AUDIT_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_COMP_AUDIT_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_COMP_AUDIT_001"><text>"Decisoes automaticas nao estao sendo registradas. Impossivel auditar processo. Corrigir configuracao."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_COMP_AUDIT_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_4_COMP_AUDIT_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_5_COMP_AUDIT_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_AUDIT_001">
        <description>Usuario responsavel nao identificado</description>
        <inputEntry id="InputEntry_A1_1_COMP_AUDIT_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_AUDIT_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_AUDIT_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_COMP_AUDIT_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_AUDIT_001"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_AUDIT_001"><text>"Usuario responsavel nao identificado nos registros. Adicionar identificacao de usuario para responsabilizacao."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_AUDIT_001"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_AUDIT_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_AUDIT_001"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_2_COMP_AUDIT_001">
        <description>Justificativas de decisao incompletas</description>
        <inputEntry id="InputEntry_A2_1_COMP_AUDIT_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_COMP_AUDIT_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_COMP_AUDIT_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_COMP_AUDIT_001"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_COMP_AUDIT_001"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_COMP_AUDIT_001"><text>"Justificativas de decisao incompletas. Incluir motivo detalhado para cada decisao automatica."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_COMP_AUDIT_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_4_COMP_AUDIT_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_5_COMP_AUDIT_001"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_AUDIT_001">
        <description>Trilha de auditoria completa e valida</description>
        <inputEntry id="InputEntry_P1_1_COMP_AUDIT_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_AUDIT_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_AUDIT_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_COMP_AUDIT_001"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_AUDIT_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_AUDIT_001"><text>"Trilha de auditoria completa. Decisoes registradas, usuarios identificados, justificativas documentadas."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_AUDIT_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_AUDIT_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_AUDIT_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_AUDIT_001">
        <description>Caso padrao - Revisar trilha de auditoria</description>
        <inputEntry id="InputEntry_F_1_COMP_AUDIT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_AUDIT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_AUDIT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_COMP_AUDIT_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_AUDIT_001"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_AUDIT_001"><text>"Verificar configuracao de trilha de auditoria: logging, registro de decisoes, usuarios e justificativas."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_AUDIT_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_AUDIT_001_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_AUDIT_001_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_AUDIT_001">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_AUDIT_001" dmnElementRef="Decision_COMP_AUDIT_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>