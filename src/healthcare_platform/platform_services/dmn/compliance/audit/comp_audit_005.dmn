<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-AUDIT-005 - Cadeia de Rastreabilidade
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-AUDIT
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_AUDIT_005" name="Cadeia de Rastreabilidade" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_AUDIT_005" name="[SP-PS-001 | compliance/audit] Validacao Cadeia de Rastreabilidade" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_AUDIT_005" hitPolicy="FIRST">

      <input id="Input_1_COMP_AUDIT_005" label="Cadeia Rastreabilidade OK">
        <inputExpression id="InputExpression_1_COMP_AUDIT_005" typeRef="boolean">
          <text>cadeiaRastreabilidade</text>
        </inputExpression>
      </input>

      <input id="Input_2_COMP_AUDIT_005" label="ID Transacao Unico">
        <inputExpression id="InputExpression_2_COMP_AUDIT_005" typeRef="boolean">
          <text>idTransacaoUnico</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_AUDIT_005" label="Correlacao Ativa">
        <inputExpression id="InputExpression_3_COMP_AUDIT_005" typeRef="boolean">
          <text>correlacaoAtiva</text>
        </inputExpression>
      </input>

      <input id="Input_4_COMP_AUDIT_005" label="Integridade Verificavel">
        <inputExpression id="InputExpression_4_COMP_AUDIT_005" typeRef="boolean">
          <text>integridadeVerificavel</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_AUDIT_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_AUDIT_005" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_AUDIT_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_AUDIT_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_AUDIT_005" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_AUDIT_005">
        <description>Cadeia de rastreabilidade quebrada ou ausente</description>
        <inputEntry id="InputEntry_B1_1_COMP_AUDIT_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_AUDIT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_AUDIT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_COMP_AUDIT_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_AUDIT_005"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_AUDIT_005"><text>"Cadeia de rastreabilidade QUEBRADA. Impossivel auditar processo end-to-end. Reconstruir cadeia."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_AUDIT_005"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_AUDIT_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_AUDIT_005"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_2_COMP_AUDIT_005">
        <description>ID de transacao duplicado ou ausente</description>
        <inputEntry id="InputEntry_B2_1_COMP_AUDIT_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_AUDIT_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_AUDIT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_COMP_AUDIT_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_COMP_AUDIT_005"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_COMP_AUDIT_005"><text>"ID de transacao NAO UNICO ou ausente. Gera ambiguidade na auditoria. Usar UUID ou sequencial unico."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_COMP_AUDIT_005"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_4_COMP_AUDIT_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_5_COMP_AUDIT_005"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_AUDIT_005">
        <description>Correlacao entre transacoes inativa</description>
        <inputEntry id="InputEntry_A1_1_COMP_AUDIT_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_AUDIT_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_AUDIT_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_COMP_AUDIT_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_AUDIT_005"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_AUDIT_005"><text>"Correlacao entre transacoes nao ativa. Dificulta rastrear fluxo completo. Implementar correlation ID."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_AUDIT_005"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_AUDIT_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_AUDIT_005"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_2_COMP_AUDIT_005">
        <description>Integridade da cadeia nao verificavel</description>
        <inputEntry id="InputEntry_A2_1_COMP_AUDIT_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_COMP_AUDIT_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_COMP_AUDIT_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_COMP_AUDIT_005"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_COMP_AUDIT_005"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_COMP_AUDIT_005"><text>"Integridade da cadeia nao verificavel. Considerar hash chain ou assinatura digital para garantir integridade."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_COMP_AUDIT_005"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_4_COMP_AUDIT_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_5_COMP_AUDIT_005"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_AUDIT_005">
        <description>Cadeia de rastreabilidade completa e integra</description>
        <inputEntry id="InputEntry_P1_1_COMP_AUDIT_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_AUDIT_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_AUDIT_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_COMP_AUDIT_005"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_AUDIT_005"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_AUDIT_005"><text>"Rastreabilidade completa: IDs unicos, correlacao ativa, integridade verificavel. Auditoria end-to-end garantida."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_AUDIT_005"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_AUDIT_005"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_AUDIT_005"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_AUDIT_005">
        <description>Caso padrao - Revisar rastreabilidade</description>
        <inputEntry id="InputEntry_F_1_COMP_AUDIT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_AUDIT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_AUDIT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_COMP_AUDIT_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_AUDIT_005"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_AUDIT_005"><text>"Verificar cadeia de rastreabilidade: IDs unicos, correlacao, e mecanismos de integridade."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_AUDIT_005"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_AUDIT_005_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_AUDIT_005_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_AUDIT_005">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_AUDIT_005" dmnElementRef="Decision_COMP_AUDIT_005">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>