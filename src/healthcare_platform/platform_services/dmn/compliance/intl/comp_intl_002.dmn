<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-INTL-002 - Reembolso Internacional
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-INTL
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_INTL_002" name="Reembolso Internacional" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_INTL_002" name="[SP-PS-001 | compliance/intl] Validar Reembolso Internacional" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_INTL_002" hitPolicy="FIRST">

      <input id="Input_1_COMP_INTL_002" label="Moeda Origem">
        <inputExpression id="InputExpression_1_COMP_INTL_002" typeRef="string">
          <text>moedaOrigem</text>
        </inputExpression>
        <inputValues><text>"USD", "EUR", "GBP", "ARS", "PYG", "UYU", "outras"</text></inputValues>
      </input>

      <input id="Input_2_COMP_INTL_002" label="Taxa Conversao Valida">
        <inputExpression id="InputExpression_2_COMP_INTL_002" typeRef="boolean">
          <text>taxaConversaoValida</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_INTL_002" label="Variacao Taxa Aceitavel">
        <inputExpression id="InputExpression_3_COMP_INTL_002" typeRef="boolean">
          <text>variacaoTaxaAceitavel</text>
        </inputExpression>
      </input>

      <input id="Input_4_COMP_INTL_002" label="Documentacao Traduzida">
        <inputExpression id="InputExpression_4_COMP_INTL_002" typeRef="boolean">
          <text>documentacaoTraduzida</text>
        </inputExpression>
      </input>

      <input id="Input_5_COMP_INTL_002" label="Traducao Juramentada">
        <inputExpression id="InputExpression_5_COMP_INTL_002" typeRef="boolean">
          <text>traducaoJuramentada</text>
        </inputExpression>
      </input>

      <input id="Input_6_COMP_INTL_002" label="Documentacao Exterior Completa">
        <inputExpression id="InputExpression_6_COMP_INTL_002" typeRef="boolean">
          <text>documentacaoExteriorCompleta</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_INTL_002" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_INTL_002" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_INTL_002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_INTL_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_INTL_002" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Block_1_COMP_INTL_002">
        <description>Bloquear documentacao nao traduzida</description>
        <inputEntry id="InputEntry_B1_1_COMP_INTL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_INTL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_INTL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_COMP_INTL_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_5_COMP_INTL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_6_COMP_INTL_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_INTL_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_INTL_002"><text>"Documentacao medica sem traducao para portugues. Impossibilita reembolso internacional."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_INTL_002"><text>"Providenciar traducao dos documentos antes de submeter reembolso."</text></outputEntry>
<outputEntry id="Rule_Block_1_outputEntry_alertasConformidade_COMP_INTL_002"><text>"DOC"</text></outputEntry>
<outputEntry id="Rule_Block_1_outputEntry_riscoDenial_COMP_INTL_002"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Block_2_COMP_INTL_002">
        <description>Bloquear taxa de conversao invalida</description>
        <inputEntry id="InputEntry_B2_1_COMP_INTL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_INTL_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_INTL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_COMP_INTL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_5_COMP_INTL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_6_COMP_INTL_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_COMP_INTL_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_COMP_INTL_002"><text>"Taxa de conversao de moeda nao validada pelo Banco Central na data do atendimento."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_COMP_INTL_002"><text>"Utilizar taxa PTAX do Banco Central da data do atendimento."</text></outputEntry>
<outputEntry id="Rule_Block_2_outputEntry_alertasConformidade_COMP_INTL_002"><text>"DOC"</text></outputEntry>
<outputEntry id="Rule_Block_2_outputEntry_riscoDenial_COMP_INTL_002"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Block_3_COMP_INTL_002">
        <description>Bloquear documentacao exterior incompleta</description>
        <inputEntry id="InputEntry_B3_1_COMP_INTL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_COMP_INTL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_COMP_INTL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_4_COMP_INTL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B3_5_COMP_INTL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_6_COMP_INTL_002"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_B3_1_COMP_INTL_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B3_2_COMP_INTL_002"><text>"Documentacao do exterior incompleta. Faltam comprovantes ou notas fiscais originais."</text></outputEntry>
<outputEntry id="OutputEntry_B3_3_COMP_INTL_002"><text>"Solicitar documentos originais do prestador estrangeiro."</text></outputEntry>
<outputEntry id="Rule_Block_3_outputEntry_alertasConformidade_COMP_INTL_002"><text>"DOC"</text></outputEntry>
<outputEntry id="Rule_Block_3_outputEntry_riscoDenial_COMP_INTL_002"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alert_1_COMP_INTL_002">
        <description>Alertar traducao parcial</description>
        <inputEntry id="InputEntry_A1_1_COMP_INTL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_INTL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_INTL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_COMP_INTL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_COMP_INTL_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_6_COMP_INTL_002"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_INTL_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_INTL_002"><text>"Traducao disponivel mas nao juramentada. Alguns planos exigem traducao juramentada."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_INTL_002"><text>"Verificar exigencia do plano e providenciar traducao juramentada se necessario."</text></outputEntry>
<outputEntry id="Rule_Alert_1_outputEntry_alertasConformidade_COMP_INTL_002"><text>"DOC"</text></outputEntry>
<outputEntry id="Rule_Alert_1_outputEntry_riscoDenial_COMP_INTL_002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alert_2_COMP_INTL_002">
        <description>Alertar variacao na taxa de conversao</description>
        <inputEntry id="InputEntry_A2_1_COMP_INTL_002"><text>"USD", "EUR", "GBP"</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_COMP_INTL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_COMP_INTL_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_COMP_INTL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_5_COMP_INTL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_6_COMP_INTL_002"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_COMP_INTL_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_COMP_INTL_002"><text>"Variacao de taxa de cambio acima de 5% desde data do atendimento. Pode haver ajuste no valor."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_COMP_INTL_002"><text>"Documentar taxa utilizada e possivel impacto de variacao cambial."</text></outputEntry>
<outputEntry id="Rule_Alert_2_outputEntry_alertasConformidade_COMP_INTL_002"><text>"DOC"</text></outputEntry>
<outputEntry id="Rule_Alert_2_outputEntry_riscoDenial_COMP_INTL_002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_1_COMP_INTL_002">
        <description>Prosseguir com documentacao completa e traducao juramentada</description>
        <inputEntry id="InputEntry_P1_1_COMP_INTL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_INTL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_INTL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_COMP_INTL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_5_COMP_INTL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_6_COMP_INTL_002"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_INTL_002"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_INTL_002"><text>"Documentacao internacional completa com traducao juramentada. Reembolso pode ser processado."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_INTL_002"><text>"Submeter solicitacao de reembolso internacional com toda documentacao."</text></outputEntry>
<outputEntry id="Rule_Proceed_1_outputEntry_alertasConformidade_COMP_INTL_002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Proceed_1_outputEntry_riscoDenial_COMP_INTL_002"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_2_COMP_INTL_002">
        <description>Prosseguir moedas Mercosul com documentacao simplificada</description>
        <inputEntry id="InputEntry_P2_1_COMP_INTL_002"><text>"ARS", "PYG", "UYU"</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_COMP_INTL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_COMP_INTL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_COMP_INTL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_5_COMP_INTL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_6_COMP_INTL_002"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_COMP_INTL_002"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_COMP_INTL_002"><text>"Reembolso de pais Mercosul com documentacao traduzida. Processo simplificado aplicavel."</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_COMP_INTL_002"><text>"Utilizar processo de reembolso simplificado Mercosul."</text></outputEntry>
<outputEntry id="Rule_Proceed_2_outputEntry_alertasConformidade_COMP_INTL_002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Proceed_2_outputEntry_riscoDenial_COMP_INTL_002"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_INTL_002">
        <description>Caso padrao - revisar manualmente</description>
        <inputEntry id="InputEntry_F_1_COMP_INTL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_INTL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_INTL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_COMP_INTL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_COMP_INTL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_6_COMP_INTL_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_INTL_002"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_INTL_002"><text>"Dados insuficientes para validar reembolso internacional."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_INTL_002"><text>"Verificar moeda, taxa de conversao, traducao e documentacao completa."</text></outputEntry>
<outputEntry id="Rule_Fallback_outputEntry_alertasConformidade_COMP_INTL_002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Fallback_outputEntry_riscoDenial_COMP_INTL_002"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_INTL_002">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_INTL_002" dmnElementRef="Decision_COMP_INTL_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>