<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-ACCRED-008 - Alvara Funcionamento
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-ACCRED
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_ACCRED_008" name="Alvara Funcionamento" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_ACCRED_008" name="[SP-PS-001 | compliance/accred] Validacao Alvara Funcionamento" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_ACCRED_008" hitPolicy="FIRST">

      <input id="Input_1_COMP_ACCRED_008" label="Tipo Alvara">
        <inputExpression id="InputExpression_1_COMP_ACCRED_008" typeRef="string">
          <text>tipoAlvara</text>
        </inputExpression>
        <inputValues><text>"FUNCIONAMENTO", "BOMBEIROS", "HABITE_SE", "SANITARIO", "AMBIENTAL"</text></inputValues>
      </input>

      <input id="Input_2_COMP_ACCRED_008" label="Status Alvara">
        <inputExpression id="InputExpression_2_COMP_ACCRED_008" typeRef="string">
          <text>statusAlvara</text>
        </inputExpression>
        <inputValues><text>"VIGENTE", "VENCIDO", "SUSPENSO", "CASSADO", "EM_RENOVACAO"</text></inputValues>
      </input>

      <input id="Input_3_COMP_ACCRED_008" label="Dias ate Validade">
        <inputExpression id="InputExpression_3_COMP_ACCRED_008" typeRef="number">
          <text>diasAteValidade</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_ACCRED_008" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_ACCRED_008" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_ACCRED_008" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_ACCRED_008" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_ACCRED_008" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_ACCRED_008">
        <description>Alvara cassado - Bloqueio obrigatorio</description>
        <inputEntry id="InputEntry_B1_1_COMP_ACCRED_008"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_ACCRED_008"><text>"CASSADO"</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_ACCRED_008"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_ACCRED_008"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_ACCRED_008"><text>"Alvara de funcionamento cassado. Hospital impedido de operar legalmente. Situacao critica requer acao juridica."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_ACCRED_008"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_ACCRED_008"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_ACCRED_008"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_2_COMP_ACCRED_008">
        <description>Alvara suspenso - Bloqueio</description>
        <inputEntry id="InputEntry_B2_1_COMP_ACCRED_008"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_ACCRED_008"><text>"SUSPENSO"</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_ACCRED_008"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_COMP_ACCRED_008"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_COMP_ACCRED_008"><text>"Alvara de funcionamento suspenso. Verificar auto de infracao e requisitos para reativacao junto ao orgao emissor."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_COMP_ACCRED_008"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_4_COMP_ACCRED_008"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_5_COMP_ACCRED_008"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_3_COMP_ACCRED_008">
        <description>Alvara vencido - Bloqueio</description>
        <inputEntry id="InputEntry_B3_1_COMP_ACCRED_008"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_COMP_ACCRED_008"><text>"VENCIDO"</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_COMP_ACCRED_008"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B3_1_COMP_ACCRED_008"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B3_2_COMP_ACCRED_008"><text>"Alvara de funcionamento vencido. Funcionamento irregular sujeito a multas. Providenciar renovacao imediata."</text></outputEntry>
<outputEntry id="OutputEntry_B3_3_COMP_ACCRED_008"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_4_COMP_ACCRED_008"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_5_COMP_ACCRED_008"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_ACCRED_008">
        <description>Alvara vencendo em 60 dias - Alerta</description>
        <inputEntry id="InputEntry_A1_1_COMP_ACCRED_008"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_ACCRED_008"><text>"VIGENTE"</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_ACCRED_008"><text>[0..60]</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_ACCRED_008"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_ACCRED_008"><text>"Alvara de funcionamento vence em menos de 60 dias. Iniciar processo de renovacao junto a Prefeitura/Bombeiros."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_ACCRED_008"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_ACCRED_008"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_ACCRED_008"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_2_COMP_ACCRED_008">
        <description>Alvara em renovacao - Acompanhamento</description>
        <inputEntry id="InputEntry_A2_1_COMP_ACCRED_008"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_COMP_ACCRED_008"><text>"EM_RENOVACAO"</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_COMP_ACCRED_008"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_COMP_ACCRED_008"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_COMP_ACCRED_008"><text>"Alvara em processo de renovacao. Acompanhar tramitacao. Funcionamento permitido com protocolo de renovacao."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_COMP_ACCRED_008"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_4_COMP_ACCRED_008"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_5_COMP_ACCRED_008"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_ACCRED_008">
        <description>Alvara de funcionamento regular</description>
        <inputEntry id="InputEntry_P1_1_COMP_ACCRED_008"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_ACCRED_008"><text>"VIGENTE"</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_ACCRED_008"><text>&gt; 60</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_ACCRED_008"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_ACCRED_008"><text>"Alvara de funcionamento vigente e regular. Hospital em conformidade com legislacao municipal. Operacao autorizada."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_ACCRED_008"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_ACCRED_008"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_ACCRED_008"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_ACCRED_008">
        <description>Caso padrao - Revisao manual necessaria</description>
        <inputEntry id="InputEntry_F_1_COMP_ACCRED_008"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_ACCRED_008"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_ACCRED_008"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_ACCRED_008"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_ACCRED_008"><text>"Status do alvara de funcionamento requer verificacao manual. Conferir documento, orgao emissor e validade."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_ACCRED_008"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_ACCRED_008_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_ACCRED_008_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_ACCRED_008">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_ACCRED_008" dmnElementRef="Decision_COMP_ACCRED_008">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>