<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-ACCRED-003 - Licenca Vigilancia Sanitaria
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-ACCRED
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_ACCRED_003" name="Licenca Vigilancia Sanitaria" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_ACCRED_003" name="[SP-PS-001 | compliance/accred] Validacao Licenca VISA" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_ACCRED_003" hitPolicy="FIRST">

      <input id="Input_1_COMP_ACCRED_003" label="Status Alvara Sanitario">
        <inputExpression id="InputExpression_1_COMP_ACCRED_003" typeRef="string">
          <text>statusAlvaraSanitario</text>
        </inputExpression>
        <inputValues><text>"VIGENTE", "VENCIDO", "SUSPENSO", "CASSADO", "EM_RENOVACAO"</text></inputValues>
      </input>

      <input id="Input_2_COMP_ACCRED_003" label="Dias ate Renovacao">
        <inputExpression id="InputExpression_2_COMP_ACCRED_003" typeRef="number">
          <text>diasAteRenovacao</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_ACCRED_003" label="Pendencias VISA">
        <inputExpression id="InputExpression_3_COMP_ACCRED_003" typeRef="number">
          <text>pendenciasVISA</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_ACCRED_003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_ACCRED_003" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_ACCRED_003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_ACCRED_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_ACCRED_003" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_ACCRED_003">
        <description>Alvara sanitario cassado - Bloqueio obrigatorio</description>
        <inputEntry id="InputEntry_B1_1_COMP_ACCRED_003"><text>"CASSADO"</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_ACCRED_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_ACCRED_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_ACCRED_003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_ACCRED_003"><text>"Alvara sanitario cassado pela VISA. Hospital impedido de funcionar. Situacao critica conforme Lei 6.437/1977."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_ACCRED_003"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_ACCRED_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_ACCRED_003"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_2_COMP_ACCRED_003">
        <description>Alvara sanitario suspenso - Bloqueio</description>
        <inputEntry id="InputEntry_B2_1_COMP_ACCRED_003"><text>"SUSPENSO"</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_ACCRED_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_ACCRED_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_COMP_ACCRED_003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_COMP_ACCRED_003"><text>"Alvara sanitario suspenso. Verificar auto de infracao e implementar acoes corretivas exigidas pela VISA."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_COMP_ACCRED_003"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_4_COMP_ACCRED_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_5_COMP_ACCRED_003"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_3_COMP_ACCRED_003">
        <description>Alvara sanitario vencido - Bloqueio</description>
        <inputEntry id="InputEntry_B3_1_COMP_ACCRED_003"><text>"VENCIDO"</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_COMP_ACCRED_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_COMP_ACCRED_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B3_1_COMP_ACCRED_003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B3_2_COMP_ACCRED_003"><text>"Alvara sanitario vencido. Funcionamento irregular perante VISA. Providenciar renovacao urgente."</text></outputEntry>
<outputEntry id="OutputEntry_B3_3_COMP_ACCRED_003"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_4_COMP_ACCRED_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_5_COMP_ACCRED_003"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_ACCRED_003">
        <description>Alvara vencendo em 90 dias - Alerta</description>
        <inputEntry id="InputEntry_A1_1_COMP_ACCRED_003"><text>"VIGENTE"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_ACCRED_003"><text>[0..90]</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_ACCRED_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_ACCRED_003"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_ACCRED_003"><text>"Alvara sanitario vence em menos de 90 dias. Iniciar processo de renovacao junto a VISA. Prazo medio: 60-90 dias."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_ACCRED_003"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_ACCRED_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_ACCRED_003"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_2_COMP_ACCRED_003">
        <description>Em renovacao - Acompanhamento</description>
        <inputEntry id="InputEntry_A2_1_COMP_ACCRED_003"><text>"EM_RENOVACAO"</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_COMP_ACCRED_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_COMP_ACCRED_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_COMP_ACCRED_003"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_COMP_ACCRED_003"><text>"Alvara em processo de renovacao. Acompanhar tramitacao na VISA. Funcionamento permitido com protocolo."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_COMP_ACCRED_003"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_4_COMP_ACCRED_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_5_COMP_ACCRED_003"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_3_COMP_ACCRED_003">
        <description>Pendencias VISA existentes - Monitoramento</description>
        <inputEntry id="InputEntry_A3_1_COMP_ACCRED_003"><text>"VIGENTE"</text></inputEntry>
        <inputEntry id="InputEntry_A3_2_COMP_ACCRED_003"><text>&gt; 90</text></inputEntry>
        <inputEntry id="InputEntry_A3_3_COMP_ACCRED_003"><text>&gt; 0</text></inputEntry>
<outputEntry id="OutputEntry_A3_1_COMP_ACCRED_003"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A3_2_COMP_ACCRED_003"><text>"Existem pendencias documentais ou de adequacao junto a VISA. Resolver antes da proxima inspecao."</text></outputEntry>
<outputEntry id="OutputEntry_A3_3_COMP_ACCRED_003"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_3_4_COMP_ACCRED_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_3_5_COMP_ACCRED_003"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_ACCRED_003">
        <description>Alvara sanitario regular</description>
        <inputEntry id="InputEntry_P1_1_COMP_ACCRED_003"><text>"VIGENTE"</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_ACCRED_003"><text>&gt; 90</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_ACCRED_003"><text>0</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_ACCRED_003"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_ACCRED_003"><text>"Alvara sanitario vigente e sem pendencias. Hospital em conformidade com VISA. Faturamento autorizado."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_ACCRED_003"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_ACCRED_003"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_ACCRED_003"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_ACCRED_003">
        <description>Caso padrao - Revisao manual necessaria</description>
        <inputEntry id="InputEntry_F_1_COMP_ACCRED_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_ACCRED_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_ACCRED_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_ACCRED_003"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_ACCRED_003"><text>"Status do alvara sanitario requer verificacao manual. Conferir documento, validade e pendencias junto a VISA."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_ACCRED_003"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_ACCRED_003_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_ACCRED_003_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_ACCRED_003">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_ACCRED_003" dmnElementRef="Decision_COMP_ACCRED_003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>