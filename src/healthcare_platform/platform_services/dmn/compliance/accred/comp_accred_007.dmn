<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-ACCRED-007 - Credenciamento Operadora
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-ACCRED
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_ACCRED_007" name="Credenciamento Operadora" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_ACCRED_007" name="[SP-PS-001 | compliance/accred] Validacao Credenciamento Operadora" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_ACCRED_007" hitPolicy="FIRST">

      <input id="Input_1_COMP_ACCRED_007" label="Status Contrato">
        <inputExpression id="InputExpression_1_COMP_ACCRED_007" typeRef="string">
          <text>statusContrato</text>
        </inputExpression>
        <inputValues><text>"VIGENTE", "ENCERRADO", "SUSPENSO", "RESCINDIDO", "EM_RENOVACAO"</text></inputValues>
      </input>

      <input id="Input_2_COMP_ACCRED_007" label="Dias ate Vencimento">
        <inputExpression id="InputExpression_2_COMP_ACCRED_007" typeRef="number">
          <text>diasAteVencimento</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_ACCRED_007" label="Documentacao Pendente">
        <inputExpression id="InputExpression_3_COMP_ACCRED_007" typeRef="boolean">
          <text>documentacaoPendente</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_ACCRED_007" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_ACCRED_007" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_ACCRED_007" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_ACCRED_007" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_ACCRED_007" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_ACCRED_007">
        <description>Contrato rescindido - Bloqueio obrigatorio</description>
        <inputEntry id="InputEntry_B1_1_COMP_ACCRED_007"><text>"RESCINDIDO"</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_ACCRED_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_ACCRED_007"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_ACCRED_007"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_ACCRED_007"><text>"Contrato com operadora rescindido. Hospital nao pode atender beneficiarios desta operadora. Faturamento bloqueado."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_ACCRED_007"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_ACCRED_007"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_ACCRED_007"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_2_COMP_ACCRED_007">
        <description>Contrato encerrado - Bloqueio</description>
        <inputEntry id="InputEntry_B2_1_COMP_ACCRED_007"><text>"ENCERRADO"</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_ACCRED_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_ACCRED_007"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_COMP_ACCRED_007"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_COMP_ACCRED_007"><text>"Contrato com operadora encerrado. Verificar possibilidade de renovacao ou novo credenciamento conforme RN 363/2014."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_COMP_ACCRED_007"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_4_COMP_ACCRED_007"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_5_COMP_ACCRED_007"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_3_COMP_ACCRED_007">
        <description>Credenciamento suspenso pela operadora - Bloqueio</description>
        <inputEntry id="InputEntry_B3_1_COMP_ACCRED_007"><text>"SUSPENSO"</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_COMP_ACCRED_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_COMP_ACCRED_007"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B3_1_COMP_ACCRED_007"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B3_2_COMP_ACCRED_007"><text>"Credenciamento suspenso pela operadora. Verificar pendencias contratuais ou financeiras. Faturamento temporariamente bloqueado."</text></outputEntry>
<outputEntry id="OutputEntry_B3_3_COMP_ACCRED_007"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_4_COMP_ACCRED_007"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_5_COMP_ACCRED_007"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_ACCRED_007">
        <description>Contrato vencendo - Iniciar renovacao</description>
        <inputEntry id="InputEntry_A1_1_COMP_ACCRED_007"><text>"VIGENTE"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_ACCRED_007"><text>[0..90]</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_ACCRED_007"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_ACCRED_007"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_ACCRED_007"><text>"Contrato de credenciamento vence em menos de 90 dias. Iniciar processo de renovacao. Negociar termos e valores."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_ACCRED_007"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_ACCRED_007"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_ACCRED_007"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_2_COMP_ACCRED_007">
        <description>Contrato em renovacao - Acompanhamento</description>
        <inputEntry id="InputEntry_A2_1_COMP_ACCRED_007"><text>"EM_RENOVACAO"</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_COMP_ACCRED_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_COMP_ACCRED_007"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_COMP_ACCRED_007"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_COMP_ACCRED_007"><text>"Contrato em processo de renovacao. Acompanhar negociacao. Atendimento permitido ate conclusao."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_COMP_ACCRED_007"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_4_COMP_ACCRED_007"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_5_COMP_ACCRED_007"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_3_COMP_ACCRED_007">
        <description>Documentacao contratual pendente - Regularizar</description>
        <inputEntry id="InputEntry_A3_1_COMP_ACCRED_007"><text>"VIGENTE"</text></inputEntry>
        <inputEntry id="InputEntry_A3_2_COMP_ACCRED_007"><text>&gt; 90</text></inputEntry>
        <inputEntry id="InputEntry_A3_3_COMP_ACCRED_007"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_A3_1_COMP_ACCRED_007"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A3_2_COMP_ACCRED_007"><text>"Documentacao contratual pendente de entrega ou atualizacao. Regularizar para evitar suspensao do credenciamento."</text></outputEntry>
<outputEntry id="OutputEntry_A3_3_COMP_ACCRED_007"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_3_4_COMP_ACCRED_007"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_3_5_COMP_ACCRED_007"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_ACCRED_007">
        <description>Credenciamento vigente e regular</description>
        <inputEntry id="InputEntry_P1_1_COMP_ACCRED_007"><text>"VIGENTE"</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_ACCRED_007"><text>&gt; 90</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_ACCRED_007"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_ACCRED_007"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_ACCRED_007"><text>"Credenciamento com operadora vigente e regular. Documentacao completa. Faturamento autorizado conforme contrato."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_ACCRED_007"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_ACCRED_007"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_ACCRED_007"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_ACCRED_007">
        <description>Caso padrao - Revisao manual necessaria</description>
        <inputEntry id="InputEntry_F_1_COMP_ACCRED_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_ACCRED_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_ACCRED_007"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_ACCRED_007"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_ACCRED_007"><text>"Status do credenciamento requer verificacao manual. Conferir contrato, vigencia e documentacao junto a operadora."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_ACCRED_007"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_ACCRED_007_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_ACCRED_007_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_ACCRED_007">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_ACCRED_007" dmnElementRef="Decision_COMP_ACCRED_007">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>