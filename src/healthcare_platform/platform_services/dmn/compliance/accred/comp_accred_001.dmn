<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-ACCRED-001 - Certificacao ONA
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-ACCRED
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_ACCRED_001" name="Certificacao ONA" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_ACCRED_001" name="[SP-PS-001 | compliance/accred] Validacao Certificacao ONA" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_ACCRED_001" hitPolicy="FIRST">

      <input id="Input_1_COMP_ACCRED_001" label="Nivel ONA">
        <inputExpression id="InputExpression_1_COMP_ACCRED_001" typeRef="string">
          <text>nivelONA</text>
        </inputExpression>
        <inputValues><text>"NIVEL_1", "NIVEL_2", "NIVEL_3", "SEM_CERTIFICACAO", "SUSPENSA"</text></inputValues>
      </input>

      <input id="Input_2_COMP_ACCRED_001" label="Dias ate Validade">
        <inputExpression id="InputExpression_2_COMP_ACCRED_001" typeRef="number">
          <text>diasAteValidade</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_ACCRED_001" label="Nao Conformidades Criticas">
        <inputExpression id="InputExpression_3_COMP_ACCRED_001" typeRef="number">
          <text>naoConformidadesCriticas</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_ACCRED_001" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_ACCRED_001" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_ACCRED_001" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_ACCRED_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_ACCRED_001" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_ACCRED_001">
        <description>Certificacao ONA expirada - Bloqueio obrigatorio</description>
        <inputEntry id="InputEntry_B1_1_COMP_ACCRED_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_ACCRED_001"><text>&lt; 0</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_ACCRED_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_ACCRED_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_ACCRED_001"><text>"Certificacao ONA expirada. Necessario renovacao imediata conforme Manual ONA. Prestador pode ter restricoes com operadoras."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_ACCRED_001"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_ACCRED_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_ACCRED_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_2_COMP_ACCRED_001">
        <description>Certificacao ONA suspensa - Bloqueio</description>
        <inputEntry id="InputEntry_B2_1_COMP_ACCRED_001"><text>"SUSPENSA"</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_ACCRED_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_ACCRED_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_COMP_ACCRED_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_COMP_ACCRED_001"><text>"Certificacao ONA suspensa pela acreditadora. Verificar motivo da suspensao e plano de regularizacao."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_COMP_ACCRED_001"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_4_COMP_ACCRED_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_5_COMP_ACCRED_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_3_COMP_ACCRED_001">
        <description>Nao conformidades criticas pendentes - Bloqueio</description>
        <inputEntry id="InputEntry_B3_1_COMP_ACCRED_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_COMP_ACCRED_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_COMP_ACCRED_001"><text>&gt; 3</text></inputEntry>
<outputEntry id="OutputEntry_B3_1_COMP_ACCRED_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B3_2_COMP_ACCRED_001"><text>"Excesso de nao conformidades criticas (&gt;3). Risco a seguranca do paciente. Acoes corretivas imediatas necessarias."</text></outputEntry>
<outputEntry id="OutputEntry_B3_3_COMP_ACCRED_001"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_4_COMP_ACCRED_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_5_COMP_ACCRED_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_ACCRED_001">
        <description>Certificacao vencendo em 90 dias - Alerta</description>
        <inputEntry id="InputEntry_A1_1_COMP_ACCRED_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_ACCRED_001"><text>[0..90]</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_ACCRED_001"><text>&lt;= 3</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_ACCRED_001"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_ACCRED_001"><text>"Certificacao ONA vence em menos de 90 dias. Agendar auditoria de recertificacao. Iniciar processo de renovacao."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_ACCRED_001"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_ACCRED_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_ACCRED_001"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_2_COMP_ACCRED_001">
        <description>Nao conformidades pendentes - Monitoramento</description>
        <inputEntry id="InputEntry_A2_1_COMP_ACCRED_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_COMP_ACCRED_001"><text>&gt; 90</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_COMP_ACCRED_001"><text>[1..3]</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_COMP_ACCRED_001"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_COMP_ACCRED_001"><text>"Existem nao conformidades pendentes de resolucao. Acompanhar plano de acao e prazos de correcao."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_COMP_ACCRED_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_4_COMP_ACCRED_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_5_COMP_ACCRED_001"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_ACCRED_001">
        <description>Certificacao ONA Nivel 3 - Excelencia</description>
        <inputEntry id="InputEntry_P1_1_COMP_ACCRED_001"><text>"NIVEL_3"</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_ACCRED_001"><text>&gt; 90</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_ACCRED_001"><text>0</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_ACCRED_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_ACCRED_001"><text>"Certificacao ONA Nivel 3 (Excelencia) vigente. Maximo padrao de qualidade. Faturamento autorizado sem restricoes."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_ACCRED_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_ACCRED_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_ACCRED_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_2_COMP_ACCRED_001">
        <description>Certificacao ONA Nivel 1 ou 2 vigente</description>
        <inputEntry id="InputEntry_P2_1_COMP_ACCRED_001"><text>"NIVEL_1", "NIVEL_2"</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_COMP_ACCRED_001"><text>&gt; 90</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_COMP_ACCRED_001"><text>0</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_COMP_ACCRED_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_COMP_ACCRED_001"><text>"Certificacao ONA vigente e sem pendencias. Hospital acreditado. Faturamento autorizado."</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_COMP_ACCRED_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_2_4_COMP_ACCRED_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_2_5_COMP_ACCRED_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_ACCRED_001">
        <description>Caso padrao - Revisao manual necessaria</description>
        <inputEntry id="InputEntry_F_1_COMP_ACCRED_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_ACCRED_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_ACCRED_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_ACCRED_001"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_ACCRED_001"><text>"Status de acreditacao ONA requer verificacao manual. Conferir certificado, validade e relatorio de nao conformidades."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_ACCRED_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_ACCRED_001_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_ACCRED_001_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_ACCRED_001">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_ACCRED_001" dmnElementRef="Decision_COMP_ACCRED_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>