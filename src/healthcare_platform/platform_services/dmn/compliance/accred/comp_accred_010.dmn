<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-ACCRED-010 - Certificacao Ambiental
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-ACCRED
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_ACCRED_010" name="Certificacao Ambiental" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_ACCRED_010" name="[SP-PS-001 | compliance/accred] Validacao Certificacao Ambiental" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_ACCRED_010" hitPolicy="FIRST">

      <input id="Input_1_COMP_ACCRED_010" label="Status Licenca Ambiental">
        <inputExpression id="InputExpression_1_COMP_ACCRED_010" typeRef="string">
          <text>statusLicencaAmbiental</text>
        </inputExpression>
        <inputValues><text>"VIGENTE", "VENCIDA", "SUSPENSA", "CASSADA", "EM_RENOVACAO"</text></inputValues>
      </input>

      <input id="Input_2_COMP_ACCRED_010" label="Condicionantes Pendentes">
        <inputExpression id="InputExpression_2_COMP_ACCRED_010" typeRef="number">
          <text>condicionantesPendentes</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_ACCRED_010" label="Relatorios Atrasados">
        <inputExpression id="InputExpression_3_COMP_ACCRED_010" typeRef="number">
          <text>relatoriosAtrasados</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_ACCRED_010" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_ACCRED_010" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_ACCRED_010" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_ACCRED_010" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_ACCRED_010" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_ACCRED_010">
        <description>Licenca ambiental cassada - Bloqueio obrigatorio</description>
        <inputEntry id="InputEntry_B1_1_COMP_ACCRED_010"><text>"CASSADA"</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_ACCRED_010"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_ACCRED_010"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_ACCRED_010"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_ACCRED_010"><text>"Licenca ambiental cassada pelo orgao ambiental. Infracao grave a Lei 6.938/1981. Hospital sob risco de interdicao."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_ACCRED_010"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_ACCRED_010"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_ACCRED_010"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_2_COMP_ACCRED_010">
        <description>Licenca ambiental suspensa - Bloqueio</description>
        <inputEntry id="InputEntry_B2_1_COMP_ACCRED_010"><text>"SUSPENSA"</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_ACCRED_010"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_ACCRED_010"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_COMP_ACCRED_010"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_COMP_ACCRED_010"><text>"Licenca ambiental suspensa. Verificar autos de infracao e implementar TAC (Termo de Ajustamento de Conduta)."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_COMP_ACCRED_010"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_4_COMP_ACCRED_010"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_5_COMP_ACCRED_010"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_3_COMP_ACCRED_010">
        <description>Licenca ambiental vencida - Bloqueio</description>
        <inputEntry id="InputEntry_B3_1_COMP_ACCRED_010"><text>"VENCIDA"</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_COMP_ACCRED_010"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_COMP_ACCRED_010"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B3_1_COMP_ACCRED_010"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B3_2_COMP_ACCRED_010"><text>"Licenca ambiental vencida. Funcionamento irregular perante orgao ambiental. Providenciar renovacao urgente (LO)."</text></outputEntry>
<outputEntry id="OutputEntry_B3_3_COMP_ACCRED_010"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_4_COMP_ACCRED_010"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_5_COMP_ACCRED_010"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_ACCRED_010">
        <description>Condicionantes ambientais pendentes - Alerta</description>
        <inputEntry id="InputEntry_A1_1_COMP_ACCRED_010"><text>"VIGENTE"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_ACCRED_010"><text>&gt; 0</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_ACCRED_010"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_ACCRED_010"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_ACCRED_010"><text>"Condicionantes da licenca ambiental pendentes de cumprimento. Risco de suspensao. Implementar acoes corretivas."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_ACCRED_010"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_ACCRED_010"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_ACCRED_010"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_2_COMP_ACCRED_010">
        <description>Relatorios ambientais atrasados - Alerta</description>
        <inputEntry id="InputEntry_A2_1_COMP_ACCRED_010"><text>"VIGENTE"</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_COMP_ACCRED_010"><text>0</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_COMP_ACCRED_010"><text>&gt; 0</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_COMP_ACCRED_010"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_COMP_ACCRED_010"><text>"Relatorios ambientais periodicos atrasados (PGRSS, monitoramento). Entregar ao orgao ambiental para evitar notificacao."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_COMP_ACCRED_010"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_4_COMP_ACCRED_010"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_5_COMP_ACCRED_010"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_3_COMP_ACCRED_010">
        <description>Licenca em renovacao - Acompanhamento</description>
        <inputEntry id="InputEntry_A3_1_COMP_ACCRED_010"><text>"EM_RENOVACAO"</text></inputEntry>
        <inputEntry id="InputEntry_A3_2_COMP_ACCRED_010"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_3_COMP_ACCRED_010"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A3_1_COMP_ACCRED_010"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A3_2_COMP_ACCRED_010"><text>"Licenca ambiental em processo de renovacao. Acompanhar tramitacao no orgao ambiental. Funcionamento permitido."</text></outputEntry>
<outputEntry id="OutputEntry_A3_3_COMP_ACCRED_010"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_3_4_COMP_ACCRED_010"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_3_5_COMP_ACCRED_010"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_ACCRED_010">
        <description>Licenca ambiental regular e conforme</description>
        <inputEntry id="InputEntry_P1_1_COMP_ACCRED_010"><text>"VIGENTE"</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_ACCRED_010"><text>0</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_ACCRED_010"><text>0</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_ACCRED_010"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_ACCRED_010"><text>"Licenca ambiental vigente, condicionantes atendidas e relatorios em dia. Hospital em conformidade ambiental. Operacao autorizada."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_ACCRED_010"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_ACCRED_010"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_ACCRED_010"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_ACCRED_010">
        <description>Caso padrao - Revisao manual necessaria</description>
        <inputEntry id="InputEntry_F_1_COMP_ACCRED_010"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_ACCRED_010"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_ACCRED_010"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_ACCRED_010"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_ACCRED_010"><text>"Status da licenca ambiental requer verificacao manual. Conferir LO, condicionantes, PGRSS e relatorios."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_ACCRED_010"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_ACCRED_010_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_ACCRED_010_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_ACCRED_010">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_ACCRED_010" dmnElementRef="Decision_COMP_ACCRED_010">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>