<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-ACCRED-006 - Habilitacao Ministerio Saude
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-ACCRED
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_ACCRED_006" name="Habilitacao Ministerio Saude" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_ACCRED_006" name="[SP-PS-001 | compliance/accred] Validacao Habilitacao MS" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_ACCRED_006" hitPolicy="FIRST">

      <input id="Input_1_COMP_ACCRED_006" label="Tipo Habilitacao">
        <inputExpression id="InputExpression_1_COMP_ACCRED_006" typeRef="string">
          <text>tipoHabilitacao</text>
        </inputExpression>
        <inputValues><text>"ONCOLOGIA", "UTI", "ALTA_COMPLEXIDADE", "TRANSPLANTE", "CARDIOVASCULAR", "NEUROLOGIA"</text></inputValues>
      </input>

      <input id="Input_2_COMP_ACCRED_006" label="Status Portaria">
        <inputExpression id="InputExpression_2_COMP_ACCRED_006" typeRef="string">
          <text>statusPortaria</text>
        </inputExpression>
        <inputValues><text>"VIGENTE", "REVOGADA", "SUSPENSA", "EM_RENOVACAO", "NAO_HABILITADO"</text></inputValues>
      </input>

      <input id="Input_3_COMP_ACCRED_006" label="Requisitos Pendentes">
        <inputExpression id="InputExpression_3_COMP_ACCRED_006" typeRef="number">
          <text>requisitosPendentes</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_ACCRED_006" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_ACCRED_006" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_ACCRED_006" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_ACCRED_006" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_ACCRED_006" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_ACCRED_006">
        <description>Portaria de habilitacao revogada - Bloqueio</description>
        <inputEntry id="InputEntry_B1_1_COMP_ACCRED_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_ACCRED_006"><text>"REVOGADA"</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_ACCRED_006"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_ACCRED_006"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_ACCRED_006"><text>"Portaria de habilitacao MS revogada. Hospital perdeu habilitacao. Servicos de alta complexidade nao podem ser faturados."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_ACCRED_006"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_ACCRED_006"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_ACCRED_006"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_2_COMP_ACCRED_006">
        <description>Habilitacao suspensa - Bloqueio</description>
        <inputEntry id="InputEntry_B2_1_COMP_ACCRED_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_ACCRED_006"><text>"SUSPENSA"</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_ACCRED_006"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_COMP_ACCRED_006"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_COMP_ACCRED_006"><text>"Habilitacao MS suspensa por descumprimento de requisitos. Verificar notificacao e implementar adequacoes."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_COMP_ACCRED_006"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_4_COMP_ACCRED_006"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_5_COMP_ACCRED_006"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_3_COMP_ACCRED_006">
        <description>Servico nao habilitado - Bloqueio</description>
        <inputEntry id="InputEntry_B3_1_COMP_ACCRED_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_COMP_ACCRED_006"><text>"NAO_HABILITADO"</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_COMP_ACCRED_006"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B3_1_COMP_ACCRED_006"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B3_2_COMP_ACCRED_006"><text>"Hospital nao possui habilitacao MS para este servico. Faturamento SUS/alta complexidade bloqueado. Solicitar habilitacao."</text></outputEntry>
<outputEntry id="OutputEntry_B3_3_COMP_ACCRED_006"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_4_COMP_ACCRED_006"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_5_COMP_ACCRED_006"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_ACCRED_006">
        <description>Requisitos tecnicos pendentes - Alerta</description>
        <inputEntry id="InputEntry_A1_1_COMP_ACCRED_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_ACCRED_006"><text>"VIGENTE"</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_ACCRED_006"><text>&gt; 0</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_ACCRED_006"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_ACCRED_006"><text>"Existem requisitos tecnicos pendentes de adequacao. Risco de suspensao da habilitacao em proxima vistoria MS."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_ACCRED_006"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_ACCRED_006"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_ACCRED_006"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_2_COMP_ACCRED_006">
        <description>Habilitacao em renovacao - Acompanhamento</description>
        <inputEntry id="InputEntry_A2_1_COMP_ACCRED_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_COMP_ACCRED_006"><text>"EM_RENOVACAO"</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_COMP_ACCRED_006"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_COMP_ACCRED_006"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_COMP_ACCRED_006"><text>"Habilitacao MS em processo de renovacao. Acompanhar tramitacao. Funcionamento permitido ate decisao final."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_COMP_ACCRED_006"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_4_COMP_ACCRED_006"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_5_COMP_ACCRED_006"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_ACCRED_006">
        <description>Habilitacao MS vigente e conforme</description>
        <inputEntry id="InputEntry_P1_1_COMP_ACCRED_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_ACCRED_006"><text>"VIGENTE"</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_ACCRED_006"><text>0</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_ACCRED_006"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_ACCRED_006"><text>"Habilitacao MS vigente e todos requisitos atendidos. Servico de alta complexidade autorizado. Faturamento SUS liberado."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_ACCRED_006"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_ACCRED_006"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_ACCRED_006"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_ACCRED_006">
        <description>Caso padrao - Revisao manual necessaria</description>
        <inputEntry id="InputEntry_F_1_COMP_ACCRED_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_ACCRED_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_ACCRED_006"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_ACCRED_006"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_ACCRED_006"><text>"Status da habilitacao MS requer verificacao manual. Conferir portaria, numero DOU e requisitos tecnicos."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_ACCRED_006"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_ACCRED_006_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_ACCRED_006_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_ACCRED_006">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_ACCRED_006" dmnElementRef="Decision_COMP_ACCRED_006">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>