<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-LGPD-006 - Consentimento Telemedicina
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-LGPD
  Perspectiva: HOSPITAL (Compliance & Privacy)

  ============================================================================
  INDICACOES (Quando PROSSEGUIR):
  ============================================================================
  - Paciente forneceu consentimento valido para telemedicina
  - Tipo de consentimento compativel com modalidade de atendimento
  - Dados compartilhados conforme autorizacao

  ============================================================================
  CONTRAINDICACOES (Quando BLOQUEAR):
  ============================================================================
  - Ausencia de consentimento para telemedicina
  - Tipo de consentimento incompativel (presencial para teleconferencia)
  - Compartilhamento de dados sem autorizacao expressa

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Lei 13.709/2018 LGPD Art. 7 (Bases Legais) e Art. 11 (Dados Sensiveis)
  - CFM Resolucao 2.314/2022 (Telemedicina)
  - Portaria MS 467/2020 (Telemedicina SUS)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_COMP_LGPD_006"
             name="Consentimento Telemedicina"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_LGPD_006" name="[SP-PS-001 | compliance/lgpd] Consentimento Telemedicina" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_LGPD_006" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_COMP_LGPD_006" label="Tem Consentimento">
        <inputExpression id="InputExpression_1_COMP_LGPD_006" typeRef="boolean">
          <text>temConsentimento</text>
        </inputExpression>
      </input>

      <input id="Input_2_COMP_LGPD_006" label="Tipo Consentimento">
        <inputExpression id="InputExpression_2_COMP_LGPD_006" typeRef="string">
          <text>tipoConsentimento</text>
        </inputExpression>
        <inputValues id="InputValues_2_COMP_LGPD_006">
          <text>"PRESENCIAL", "TELEMEDICINA", "EMERGENCIA"</text>
        </inputValues>
      </input>

      <input id="Input_3_COMP_LGPD_006" label="Dados Compartilhados">
        <inputExpression id="InputExpression_3_COMP_LGPD_006" typeRef="string">
          <text>dadosCompartilhados</text>
        </inputExpression>
        <inputValues id="InputValues_3_COMP_LGPD_006">
          <text>"CLINICO", "ADMINISTRATIVO", "COMPLETO"</text>
        </inputValues>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_LGPD_006" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_LGPD_006" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_LGPD_006" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_LGPD_006" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_LGPD_006" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA B1: Bloqueio - Sem consentimento -->
      <rule id="Rule_Bloqueio_1_COMP_LGPD_006">
        <description>Atendimento telemedicina sem consentimento valido</description>
        <inputEntry id="InputEntry_B1_1_COMP_LGPD_006"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_LGPD_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_LGPD_006"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B1_1_COMP_LGPD_006"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_2_COMP_LGPD_006"><text>"Atendimento de telemedicina requer consentimento expresso do paciente conforme LGPD Art. 7 e Res. CFM 2.314/2022."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_3_COMP_LGPD_006"><text>"Obter consentimento informado do paciente antes de prosseguir com atendimento remoto. Registrar no prontuario."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_4_COMP_LGPD_006"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_5_COMP_LGPD_006"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA B2: Bloqueio - Tipo consentimento incompativel -->
      <rule id="Rule_Bloqueio_2_COMP_LGPD_006">
        <description>Consentimento presencial usado para telemedicina</description>
        <inputEntry id="InputEntry_B2_1_COMP_LGPD_006"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_LGPD_006"><text>"PRESENCIAL"</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_LGPD_006"><text>"COMPLETO"</text></inputEntry>
        <outputEntry id="OutputEntry_B2_1_COMP_LGPD_006"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_2_COMP_LGPD_006"><text>"Consentimento presencial nao autoriza telemedicina. Modalidade remota requer consentimento especifico conforme CFM 2.314/2022 Art. 5."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_3_COMP_LGPD_006"><text>"Obter novo consentimento especifico para telemedicina com esclarecimento das diferencas da modalidade."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_4_COMP_LGPD_006"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_5_COMP_LGPD_006"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA A1: Alerta - Dados completos compartilhados -->
      <rule id="Rule_Alerta_1_COMP_LGPD_006">
        <description>Compartilhamento amplo de dados requer revisao</description>
        <inputEntry id="InputEntry_A1_1_COMP_LGPD_006"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_LGPD_006"><text>"TELEMEDICINA"</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_LGPD_006"><text>"COMPLETO"</text></inputEntry>
        <outputEntry id="OutputEntry_A1_1_COMP_LGPD_006"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_2_COMP_LGPD_006"><text>"Compartilhamento de dados completos requer justificativa. Verificar se minimizacao de dados (LGPD Art. 6 III) foi aplicada."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_3_COMP_LGPD_006"><text>"Documentar justificativa para compartilhamento amplo. Avaliar se dados clinicos essenciais seriam suficientes."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_4_COMP_LGPD_006"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_5_COMP_LGPD_006"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA P1: Aprovado - Consentimento telemedicina valido -->
      <rule id="Rule_Aprovado_1_COMP_LGPD_006">
        <description>Consentimento telemedicina ou emergencia com dados apropriados</description>
        <inputEntry id="InputEntry_P1_1_COMP_LGPD_006"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_LGPD_006"><text>"TELEMEDICINA", "EMERGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_LGPD_006"><text>"CLINICO", "ADMINISTRATIVO"</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_COMP_LGPD_006"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_2_COMP_LGPD_006"><text>"Consentimento valido para telemedicina. Compartilhamento de dados conforme principio da minimizacao. Atendimento autorizado."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_3_COMP_LGPD_006"><text>"Prosseguir com atendimento de telemedicina. Registrar consentimento e modalidade no prontuario eletronico."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_4_COMP_LGPD_006"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_5_COMP_LGPD_006"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisao manual -->
      <rule id="Rule_Fallback_COMP_LGPD_006">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_COMP_LGPD_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_LGPD_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_LGPD_006"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_COMP_LGPD_006"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_COMP_LGPD_006"><text>"Situacao de consentimento telemedicina requer analise manual. Verificar tipo, abrangencia e validade do consentimento."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_COMP_LGPD_006"><text>"Encaminhar para DPO (Data Protection Officer) para avaliacao de conformidade LGPD antes de prosseguir."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_COMP_LGPD_006"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_COMP_LGPD_006"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_LGPD_006">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_LGPD_006" dmnElementRef="Decision_COMP_LGPD_006">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
