<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-LGPD-003 - Politica Retencao Dados
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-LGPD
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_LGPD_003" name="Politica Retencao Dados" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_LGPD_003" name="[SP-PS-001 | compliance/lgpd] Validacao Politica de Retencao de Dados" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_LGPD_003" hitPolicy="FIRST">

      <input id="Input_1_COMP_LGPD_003" label="Tempo Armazenamento Anos">
        <inputExpression id="InputExpression_1_COMP_LGPD_003" typeRef="number">
          <text>tempoArmazenamentoAnos</text>
        </inputExpression>
      </input>

      <input id="Input_2_COMP_LGPD_003" label="Tipo Dado">
        <inputExpression id="InputExpression_2_COMP_LGPD_003" typeRef="string">
          <text>tipoDado</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_LGPD_003" label="Base Juridica">
        <inputExpression id="InputExpression_3_COMP_LGPD_003" typeRef="string">
          <text>baseJuridica</text>
        </inputExpression>
      </input>

      <input id="Input_4_COMP_LGPD_003" label="Paciente Menor">
        <inputExpression id="InputExpression_4_COMP_LGPD_003" typeRef="boolean">
          <text>pacienteMenor</text>
        </inputExpression>
      </input>

      <input id="Input_5_COMP_LGPD_003" label="Solicitacao Eliminacao">
        <inputExpression id="InputExpression_5_COMP_LGPD_003" typeRef="boolean">
          <text>solicitacaoEliminacao</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_LGPD_003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_LGPD_003" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_LGPD_003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_LGPD_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_LGPD_003" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_LGPD_003">
        <description>Prontuario excede 20 anos sem justificativa legal</description>
        <inputEntry id="InputEntry_B1_1_COMP_LGPD_003"><text>&gt; 20</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_LGPD_003"><text>"PRONTUARIO"</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_LGPD_003"><text>"NENHUMA"</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_COMP_LGPD_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_5_COMP_LGPD_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_LGPD_003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_LGPD_003"><text>"Prontuario excede periodo de 20 anos (CFM 1.821/2007) sem base juridica vigente. Iniciar processo de eliminacao segura conforme LGPD Art. 16."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_LGPD_003"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_LGPD_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_LGPD_003"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_2_COMP_LGPD_003">
        <description>Solicitacao de eliminacao para dados marketing/comercial</description>
        <inputEntry id="InputEntry_B2_1_COMP_LGPD_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_LGPD_003"><text>"MARKETING"</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_LGPD_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_COMP_LGPD_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_5_COMP_LGPD_003"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_COMP_LGPD_003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_COMP_LGPD_003"><text>"Titular solicitou eliminacao de dados de marketing. Atender pedido conforme LGPD Art. 18, VI em ate 15 dias."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_COMP_LGPD_003"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_4_COMP_LGPD_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_5_COMP_LGPD_003"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_3_COMP_LGPD_003">
        <description>Dados administrativos excedem 5 anos</description>
        <inputEntry id="InputEntry_B3_1_COMP_LGPD_003"><text>&gt; 5</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_COMP_LGPD_003"><text>"ADMINISTRATIVO"</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_COMP_LGPD_003"><text>"NENHUMA"</text></inputEntry>
        <inputEntry id="InputEntry_B3_4_COMP_LGPD_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_5_COMP_LGPD_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B3_1_COMP_LGPD_003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B3_2_COMP_LGPD_003"><text>"Dados administrativos excedem 5 anos de retencao. Avaliar necessidade e proceder eliminacao conforme LGPD Art. 15."</text></outputEntry>
<outputEntry id="OutputEntry_B3_3_COMP_LGPD_003"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_4_COMP_LGPD_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_5_COMP_LGPD_003"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_LGPD_003">
        <description>Prontuario proximo ao limite de 20 anos</description>
        <inputEntry id="InputEntry_A1_1_COMP_LGPD_003"><text>[18..20]</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_LGPD_003"><text>"PRONTUARIO"</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_LGPD_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_COMP_LGPD_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_COMP_LGPD_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_LGPD_003"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_LGPD_003"><text>"Prontuario proximo ao limite de 20 anos. Avaliar necessidade de retencao por valor historico ou procedemento de eliminacao."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_LGPD_003"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_LGPD_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_LGPD_003"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_2_COMP_LGPD_003">
        <description>Solicitacao eliminacao de prontuario - Avaliar obrigacao legal</description>
        <inputEntry id="InputEntry_A2_1_COMP_LGPD_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_COMP_LGPD_003"><text>"PRONTUARIO"</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_COMP_LGPD_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_COMP_LGPD_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_5_COMP_LGPD_003"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_COMP_LGPD_003"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_COMP_LGPD_003"><text>"Titular solicitou eliminacao de prontuario. Prontuario deve ser mantido por obrigacao legal (CFM 1.821/2007). Informar titular sobre excecao LGPD Art. 16, I."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_COMP_LGPD_003"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_4_COMP_LGPD_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_5_COMP_LGPD_003"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_LGPD_003">
        <description>Prontuario de menor - Retencao ate maioridade + 20 anos</description>
        <inputEntry id="InputEntry_P1_1_COMP_LGPD_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_LGPD_003"><text>"PRONTUARIO"</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_LGPD_003"><text>"OBRIGACAO_LEGAL"</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_COMP_LGPD_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_5_COMP_LGPD_003"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_LGPD_003"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_LGPD_003"><text>"Prontuario de menor de idade. Retencao obrigatoria ate maioridade + 20 anos conforme ECA e CFM 1.821/2007."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_LGPD_003"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_LGPD_003"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_LGPD_003"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_2_COMP_LGPD_003">
        <description>Prontuario dentro do prazo de 20 anos</description>
        <inputEntry id="InputEntry_P2_1_COMP_LGPD_003"><text>&lt; 18</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_COMP_LGPD_003"><text>"PRONTUARIO"</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_COMP_LGPD_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_COMP_LGPD_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P2_5_COMP_LGPD_003"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_COMP_LGPD_003"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_COMP_LGPD_003"><text>"Prontuario dentro do prazo legal de 20 anos. Manutencao em conformidade com CFM 1.821/2007 e LGPD Art. 16, I."</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_COMP_LGPD_003"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_2_4_COMP_LGPD_003"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_2_5_COMP_LGPD_003"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_LGPD_003">
        <description>Caso padrao - Revisao manual necessaria</description>
        <inputEntry id="InputEntry_F_1_COMP_LGPD_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_LGPD_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_LGPD_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_COMP_LGPD_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_COMP_LGPD_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_LGPD_003"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_LGPD_003"><text>"Politica de retencao nao determinada automaticamente. Encaminhar para DPO avaliar prazos legais aplicaveis."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_LGPD_003"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_LGPD_003_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_LGPD_003_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_LGPD_003">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_LGPD_003" dmnElementRef="Decision_COMP_LGPD_003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>