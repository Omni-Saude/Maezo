<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-LGPD-005 - Notificacao Incidente Seguranca
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-LGPD
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_LGPD_005" name="Notificacao Incidente Seguranca" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_LGPD_005" name="[SP-PS-001 | compliance/lgpd] Validacao Notificacao de Incidente de Seguranca" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_LGPD_005" hitPolicy="FIRST">

      <input id="Input_1_COMP_LGPD_005" label="Tipo Incidente">
        <inputExpression id="InputExpression_1_COMP_LGPD_005" typeRef="string">
          <text>tipoIncidente</text>
        </inputExpression>
      </input>

      <input id="Input_2_COMP_LGPD_005" label="Gravidade">
        <inputExpression id="InputExpression_2_COMP_LGPD_005" typeRef="string">
          <text>gravidade</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_LGPD_005" label="Horas Desde Deteccao">
        <inputExpression id="InputExpression_3_COMP_LGPD_005" typeRef="number">
          <text>horasDesdeDeteccao</text>
        </inputExpression>
      </input>

      <input id="Input_4_COMP_LGPD_005" label="ANPD Notificada">
        <inputExpression id="InputExpression_4_COMP_LGPD_005" typeRef="boolean">
          <text>anpdNotificada</text>
        </inputExpression>
      </input>

      <input id="Input_5_COMP_LGPD_005" label="Titulares Notificados">
        <inputExpression id="InputExpression_5_COMP_LGPD_005" typeRef="boolean">
          <text>titularesNotificados</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_LGPD_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_LGPD_005" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_LGPD_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_LGPD_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_LGPD_005" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_LGPD_005">
        <description>Incidente grave sem notificacao ANPD - Violacao Art. 48</description>
        <inputEntry id="InputEntry_B1_1_COMP_LGPD_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_LGPD_005"><text>"CRITICA"</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_LGPD_005"><text>&gt; 72</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_COMP_LGPD_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_5_COMP_LGPD_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_LGPD_005"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_LGPD_005"><text>"CRITICO: Incidente grave sem notificacao a ANPD apos 72 horas. Violacao LGPD Art. 48. Notificar IMEDIATAMENTE e documentar justificativa do atraso."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_LGPD_005"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_LGPD_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_LGPD_005"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_2_COMP_LGPD_005">
        <description>Vazamento de dados de saude sem notificacao aos titulares</description>
        <inputEntry id="InputEntry_B2_1_COMP_LGPD_005"><text>"VAZAMENTO"</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_LGPD_005"><text>"CRITICA", "ALTA"</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_LGPD_005"><text>&gt; 48</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_COMP_LGPD_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_5_COMP_LGPD_005"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_COMP_LGPD_005"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_COMP_LGPD_005"><text>"Vazamento de dados sensiveis de saude sem notificacao aos titulares. LGPD Art. 48, par. 1 exige comunicacao quando houver risco. Notificar imediatamente."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_COMP_LGPD_005"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_4_COMP_LGPD_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_5_COMP_LGPD_005"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_3_COMP_LGPD_005">
        <description>Ataque ransomware requer acao imediata</description>
        <inputEntry id="InputEntry_B3_1_COMP_LGPD_005"><text>"RANSOMWARE"</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_COMP_LGPD_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_COMP_LGPD_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_4_COMP_LGPD_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B3_5_COMP_LGPD_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B3_1_COMP_LGPD_005"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B3_2_COMP_LGPD_005"><text>"Ataque ransomware detectado. Isolar sistemas afetados IMEDIATAMENTE. Notificar ANPD, acionar CSIRT e avaliar comunicacao aos titulares."</text></outputEntry>
<outputEntry id="OutputEntry_B3_3_COMP_LGPD_005"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_4_COMP_LGPD_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_5_COMP_LGPD_005"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_LGPD_005">
        <description>Incidente medio - Prazo de notificacao proximo</description>
        <inputEntry id="InputEntry_A1_1_COMP_LGPD_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_LGPD_005"><text>"MEDIA"</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_LGPD_005"><text>[48..72]</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_COMP_LGPD_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_COMP_LGPD_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_LGPD_005"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_LGPD_005"><text>"Incidente de gravidade media proximo ao prazo de 72h para notificacao ANPD. Avaliar necessidade de comunicacao conforme Res. CD/ANPD 15/2024."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_LGPD_005"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_LGPD_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_LGPD_005"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_2_COMP_LGPD_005">
        <description>Incidente alta gravidade - Notificar com urgencia</description>
        <inputEntry id="InputEntry_A2_1_COMP_LGPD_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_COMP_LGPD_005"><text>"ALTA"</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_COMP_LGPD_005"><text>&lt;= 48</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_COMP_LGPD_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A2_5_COMP_LGPD_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_COMP_LGPD_005"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_COMP_LGPD_005"><text>"Incidente de alta gravidade. Preparar notificacao a ANPD e avaliar comunicacao aos titulares. Prazo recomendado: 72 horas."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_COMP_LGPD_005"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_4_COMP_LGPD_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_5_COMP_LGPD_005"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_3_COMP_LGPD_005">
        <description>ANPD notificada - Avaliar notificacao aos titulares</description>
        <inputEntry id="InputEntry_A3_1_COMP_LGPD_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_2_COMP_LGPD_005"><text>"CRITICA", "ALTA"</text></inputEntry>
        <inputEntry id="InputEntry_A3_3_COMP_LGPD_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_4_COMP_LGPD_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A3_5_COMP_LGPD_005"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_A3_1_COMP_LGPD_005"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A3_2_COMP_LGPD_005"><text>"ANPD notificada. Avaliar necessidade de notificacao direta aos titulares afetados conforme orientacao da ANPD e LGPD Art. 48."</text></outputEntry>
<outputEntry id="OutputEntry_A3_3_COMP_LGPD_005"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_3_4_COMP_LGPD_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_3_5_COMP_LGPD_005"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_LGPD_005">
        <description>Incidente baixo impacto - Documentar internamente</description>
        <inputEntry id="InputEntry_P1_1_COMP_LGPD_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_LGPD_005"><text>"BAIXA"</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_LGPD_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_COMP_LGPD_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_5_COMP_LGPD_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_LGPD_005"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_LGPD_005"><text>"Incidente de baixa gravidade. Notificacao a ANPD nao obrigatoria. Documentar internamente e implementar medidas corretivas."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_LGPD_005"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_LGPD_005"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_LGPD_005"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_2_COMP_LGPD_005">
        <description>Incidente com todas notificacoes realizadas</description>
        <inputEntry id="InputEntry_P2_1_COMP_LGPD_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_COMP_LGPD_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_COMP_LGPD_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_COMP_LGPD_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_5_COMP_LGPD_005"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_COMP_LGPD_005"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_COMP_LGPD_005"><text>"Incidente com notificacoes completas (ANPD e titulares). Continuar monitoramento e implementar plano de remediacacao."</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_COMP_LGPD_005"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_2_4_COMP_LGPD_005"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_2_5_COMP_LGPD_005"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_LGPD_005">
        <description>Caso padrao - Revisao manual necessaria</description>
        <inputEntry id="InputEntry_F_1_COMP_LGPD_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_LGPD_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_LGPD_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_COMP_LGPD_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_COMP_LGPD_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_LGPD_005"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_LGPD_005"><text>"Incidente requer analise do DPO e CSIRT para classificacao e definicao de notificacoes conforme LGPD Art. 48."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_LGPD_005"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_LGPD_005_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_LGPD_005_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_LGPD_005">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_LGPD_005" dmnElementRef="Decision_COMP_LGPD_005">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>