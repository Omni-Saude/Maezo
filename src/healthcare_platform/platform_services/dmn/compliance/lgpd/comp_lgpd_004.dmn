<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-LGPD-004 - Portabilidade Dados Paciente
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-LGPD
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_LGPD_004" name="Portabilidade Dados Paciente" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_LGPD_004" name="[SP-PS-001 | compliance/lgpd] Validacao Portabilidade de Dados" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_LGPD_004" hitPolicy="FIRST">

      <input id="Input_1_COMP_LGPD_004" label="Solicitacao Portabilidade">
        <inputExpression id="InputExpression_1_COMP_LGPD_004" typeRef="boolean">
          <text>solicitacaoPortabilidade</text>
        </inputExpression>
      </input>

      <input id="Input_2_COMP_LGPD_004" label="Identidade Verificada">
        <inputExpression id="InputExpression_2_COMP_LGPD_004" typeRef="boolean">
          <text>identidadeVerificada</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_LGPD_004" label="Formato Padrao Disponivel">
        <inputExpression id="InputExpression_3_COMP_LGPD_004" typeRef="boolean">
          <text>formatoPadraoDisponivel</text>
        </inputExpression>
      </input>

      <input id="Input_4_COMP_LGPD_004" label="Dias Desde Solicitacao">
        <inputExpression id="InputExpression_4_COMP_LGPD_004" typeRef="number">
          <text>diasDesdeSolicitacao</text>
        </inputExpression>
      </input>

      <input id="Input_5_COMP_LGPD_004" label="Destino Portabilidade">
        <inputExpression id="InputExpression_5_COMP_LGPD_004" typeRef="string">
          <text>destinoPortabilidade</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_LGPD_004" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_LGPD_004" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_LGPD_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_LGPD_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_LGPD_004" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_LGPD_004">
        <description>Prazo de 15 dias excedido - Violacao LGPD Art. 18</description>
        <inputEntry id="InputEntry_B1_1_COMP_LGPD_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_LGPD_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_LGPD_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_COMP_LGPD_004"><text>&gt; 15</text></inputEntry>
        <inputEntry id="InputEntry_B1_5_COMP_LGPD_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_LGPD_004"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_LGPD_004"><text>"URGENTE: Prazo de 15 dias para portabilidade excedido (LGPD Art. 18, par. 3). Providenciar imediatamente e documentar justificativa para ANPD."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_LGPD_004"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_LGPD_004"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_LGPD_004"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_2_COMP_LGPD_004">
        <description>Solicitacao sem verificacao de identidade do titular</description>
        <inputEntry id="InputEntry_B2_1_COMP_LGPD_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_LGPD_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_LGPD_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_COMP_LGPD_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_5_COMP_LGPD_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_COMP_LGPD_004"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_COMP_LGPD_004"><text>"Identidade do titular nao verificada. Exigir documento de identificacao antes de prosseguir para evitar vazamento de dados (LGPD Art. 6, VII)."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_COMP_LGPD_004"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_4_COMP_LGPD_004"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_5_COMP_LGPD_004"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_LGPD_004">
        <description>Prazo proximo ao limite - 75% consumido</description>
        <inputEntry id="InputEntry_A1_1_COMP_LGPD_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_LGPD_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_LGPD_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_COMP_LGPD_004"><text>[11..15]</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_COMP_LGPD_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_LGPD_004"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_LGPD_004"><text>"ATENCAO: Prazo de portabilidade proximo ao limite. Restam menos de 5 dias para atender solicitacao conforme LGPD Art. 18, par. 3."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_LGPD_004"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_LGPD_004"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_LGPD_004"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_2_COMP_LGPD_004">
        <description>Formato estruturado nao disponivel - Adaptar dados</description>
        <inputEntry id="InputEntry_A2_1_COMP_LGPD_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_COMP_LGPD_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_COMP_LGPD_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_COMP_LGPD_004"><text>&lt;= 10</text></inputEntry>
        <inputEntry id="InputEntry_A2_5_COMP_LGPD_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_COMP_LGPD_004"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_COMP_LGPD_004"><text>"Dados nao disponiveis em formato estruturado padrao. Converter para formato interoperavel (JSON, XML, CSV) conforme LGPD Art. 40."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_COMP_LGPD_004"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_4_COMP_LGPD_004"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_5_COMP_LGPD_004"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_3_COMP_LGPD_004">
        <description>Portabilidade para operadora - Formato TISS</description>
        <inputEntry id="InputEntry_A3_1_COMP_LGPD_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A3_2_COMP_LGPD_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A3_3_COMP_LGPD_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_4_COMP_LGPD_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_5_COMP_LGPD_004"><text>"OPERADORA"</text></inputEntry>
<outputEntry id="OutputEntry_A3_1_COMP_LGPD_004"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A3_2_COMP_LGPD_004"><text>"Portabilidade para operadora de saude. Verificar compatibilidade com padrao TISS e requisitos ANS RN 389/2015."</text></outputEntry>
<outputEntry id="OutputEntry_A3_3_COMP_LGPD_004"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_3_4_COMP_LGPD_004"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_3_5_COMP_LGPD_004"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_LGPD_004">
        <description>Solicitacao valida - Processar portabilidade</description>
        <inputEntry id="InputEntry_P1_1_COMP_LGPD_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_LGPD_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_LGPD_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_COMP_LGPD_004"><text>&lt;= 10</text></inputEntry>
        <inputEntry id="InputEntry_P1_5_COMP_LGPD_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_LGPD_004"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_LGPD_004"><text>"Solicitacao de portabilidade validada. Preparar dados em formato estruturado e enviar ao destino indicado dentro do prazo legal."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_LGPD_004"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_LGPD_004"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_LGPD_004"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_2_COMP_LGPD_004">
        <description>Sem solicitacao de portabilidade ativa</description>
        <inputEntry id="InputEntry_P2_1_COMP_LGPD_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_COMP_LGPD_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_COMP_LGPD_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_COMP_LGPD_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_5_COMP_LGPD_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_COMP_LGPD_004"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_COMP_LGPD_004"><text>"Nenhuma solicitacao de portabilidade ativa. Dados mantidos conforme politica de retencao vigente."</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_COMP_LGPD_004"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_2_4_COMP_LGPD_004"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_2_5_COMP_LGPD_004"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_LGPD_004">
        <description>Caso padrao - Revisao manual necessaria</description>
        <inputEntry id="InputEntry_F_1_COMP_LGPD_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_LGPD_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_LGPD_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_COMP_LGPD_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_COMP_LGPD_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_LGPD_004"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_LGPD_004"><text>"Solicitacao de portabilidade requer analise manual. Encaminhar para DPO avaliar viabilidade tecnica e prazo."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_LGPD_004"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_LGPD_004_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_LGPD_004_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_LGPD_004">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_LGPD_004" dmnElementRef="Decision_COMP_LGPD_004">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>