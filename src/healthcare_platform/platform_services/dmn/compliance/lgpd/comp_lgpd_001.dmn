<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-LGPD-001 - Validacao Consentimento Paciente
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-LGPD
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_LGPD_001" name="Validacao Consentimento Paciente" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_LGPD_001" name="[SP-PS-001 | compliance/lgpd] Validacao Consentimento Paciente LGPD" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_LGPD_001" hitPolicy="FIRST">

      <input id="Input_1_COMP_LGPD_001" label="Tem Consentimento">
        <inputExpression id="InputExpression_1_COMP_LGPD_001" typeRef="boolean">
          <text>temConsentimento</text>
        </inputExpression>
      </input>

      <input id="Input_2_COMP_LGPD_001" label="Consentimento Expirado">
        <inputExpression id="InputExpression_2_COMP_LGPD_001" typeRef="boolean">
          <text>consentimentoExpirado</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_LGPD_001" label="Tipo Tratamento">
        <inputExpression id="InputExpression_3_COMP_LGPD_001" typeRef="string">
          <text>tipoTratamento</text>
        </inputExpression>
      </input>

      <input id="Input_4_COMP_LGPD_001" label="Categoria Exame">
        <inputExpression id="InputExpression_4_COMP_LGPD_001" typeRef="string">
          <text>categoriaExame</text>
        </inputExpression>
      </input>

      <input id="Input_5_COMP_LGPD_001" label="Dias Ate Vencimento">
        <inputExpression id="InputExpression_5_COMP_LGPD_001" typeRef="number">
          <text>diasAteVencimento</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_LGPD_001" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_LGPD_001" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_LGPD_001" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_LGPD_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_LGPD_001" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_LGPD_001">
        <description>Ausencia de consentimento - Bloqueio obrigatorio LGPD Art. 7</description>
        <inputEntry id="InputEntry_B1_1_COMP_LGPD_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_LGPD_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_LGPD_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_COMP_LGPD_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_5_COMP_LGPD_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_LGPD_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_LGPD_001"><text>"Paciente sem consentimento registrado. Obter TCLE conforme LGPD Art. 7 e Art. 11 antes de prosseguir com tratamento de dados sensiveis de saude."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_LGPD_001"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_LGPD_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_LGPD_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_2_COMP_LGPD_001">
        <description>Consentimento expirado - Renovacao necessaria</description>
        <inputEntry id="InputEntry_B2_1_COMP_LGPD_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_LGPD_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_LGPD_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_COMP_LGPD_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_5_COMP_LGPD_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_COMP_LGPD_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_COMP_LGPD_001"><text>"Consentimento expirado. Solicitar renovacao do TCLE antes de continuar tratamento. LGPD Art. 8 - consentimento deve ser especifico e destacado."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_COMP_LGPD_001"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_4_COMP_LGPD_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_2_5_COMP_LGPD_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloquear_3_COMP_LGPD_001">
        <description>Exame genetico requer consentimento especifico</description>
        <inputEntry id="InputEntry_B3_1_COMP_LGPD_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_COMP_LGPD_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_COMP_LGPD_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_4_COMP_LGPD_001"><text>"GENETICO"</text></inputEntry>
        <inputEntry id="InputEntry_B3_5_COMP_LGPD_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B3_1_COMP_LGPD_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B3_2_COMP_LGPD_001"><text>"Exames geneticos requerem consentimento especifico e destacado conforme LGPD Art. 11 paragrafo 4. Obter autorizacao adicional."</text></outputEntry>
<outputEntry id="OutputEntry_B3_3_COMP_LGPD_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_4_COMP_LGPD_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_3_5_COMP_LGPD_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_LGPD_001">
        <description>Consentimento proximo ao vencimento - Alertar para renovacao</description>
        <inputEntry id="InputEntry_A1_1_COMP_LGPD_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_LGPD_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_LGPD_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_COMP_LGPD_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_COMP_LGPD_001"><text>&lt;= 30</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_LGPD_001"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_LGPD_001"><text>"Consentimento proximo ao vencimento. Providenciar renovacao do TCLE em ate 30 dias para continuidade do tratamento."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_LGPD_001"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_LGPD_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_LGPD_001"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_2_COMP_LGPD_001">
        <description>Pesquisa clinica requer consentimento adicional</description>
        <inputEntry id="InputEntry_A2_1_COMP_LGPD_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_COMP_LGPD_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_COMP_LGPD_001"><text>"PESQUISA"</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_COMP_LGPD_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_5_COMP_LGPD_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_COMP_LGPD_001"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_COMP_LGPD_001"><text>"Uso para pesquisa requer consentimento especifico e aprovacao CEP/CONEP. Verificar TCLE de pesquisa e parecer etico."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_COMP_LGPD_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_4_COMP_LGPD_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_5_COMP_LGPD_001"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_LGPD_001">
        <description>Consentimento valido - Tratamento autorizado</description>
        <inputEntry id="InputEntry_P1_1_COMP_LGPD_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_LGPD_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_LGPD_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_COMP_LGPD_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_5_COMP_LGPD_001"><text>&gt; 30</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_LGPD_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_LGPD_001"><text>"Consentimento valido e vigente. Tratamento de dados autorizado conforme LGPD. Manter registro de auditoria."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_LGPD_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_LGPD_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_LGPD_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_LGPD_001">
        <description>Caso padrao - Revisao manual necessaria</description>
        <inputEntry id="InputEntry_F_1_COMP_LGPD_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_LGPD_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_LGPD_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_COMP_LGPD_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_COMP_LGPD_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_LGPD_001"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_LGPD_001"><text>"Situacao nao prevista nas regras automaticas. Encaminhar para DPO (Encarregado de Dados) para analise conforme LGPD Art. 41."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_LGPD_001"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_LGPD_001_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_LGPD_001_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_LGPD_001">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_LGPD_001" dmnElementRef="Decision_COMP_LGPD_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>