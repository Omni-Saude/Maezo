<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-LGPD-007 - Compartilhamento Dados com Operadora
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-LGPD
  Perspectiva: HOSPITAL (Compliance & Privacy)

  ============================================================================
  INDICACOES (Quando PROSSEGUIR):
  ============================================================================
  - Paciente autorizou compartilhamento com operadora de saude
  - Finalidade do compartilhamento explicita e legitima
  - Dados compartilhados limitados ao necessario

  ============================================================================
  CONTRAINDICACOES (Quando BLOQUEAR):
  ============================================================================
  - Ausencia de consentimento para compartilhamento
  - Compartilhamento sem finalidade explicita
  - Envio de dados sensiveis sem base legal adequada

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Lei 13.709/2018 LGPD Art. 7 IX (Tratamento compartilhado)
  - RN ANS 412/2016 (Padrao TISS - Privacidade)
  - CFM Resolucao 1.821/2007 (Sigilo Medico)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_COMP_LGPD_007"
             name="Compartilhamento Dados com Operadora"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_LGPD_007" name="[SP-PS-001 | compliance/lgpd] Compartilhamento Dados com Operadora" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_LGPD_007" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_COMP_LGPD_007" label="Tem Consentimento">
        <inputExpression id="InputExpression_1_COMP_LGPD_007" typeRef="boolean">
          <text>temConsentimento</text>
        </inputExpression>
      </input>

      <input id="Input_2_COMP_LGPD_007" label="Tipo Consentimento">
        <inputExpression id="InputExpression_2_COMP_LGPD_007" typeRef="string">
          <text>tipoConsentimento</text>
        </inputExpression>
        <inputValues id="InputValues_2_COMP_LGPD_007">
          <text>"PRESENCIAL", "TELEMEDICINA", "EMERGENCIA"</text>
        </inputValues>
      </input>

      <input id="Input_3_COMP_LGPD_007" label="Dados Compartilhados">
        <inputExpression id="InputExpression_3_COMP_LGPD_007" typeRef="string">
          <text>dadosCompartilhados</text>
        </inputExpression>
        <inputValues id="InputValues_3_COMP_LGPD_007">
          <text>"CLINICO", "ADMINISTRATIVO", "COMPLETO"</text>
        </inputValues>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_LGPD_007" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_LGPD_007" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_LGPD_007" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_LGPD_007" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_LGPD_007" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA B1: Bloqueio - Sem consentimento -->
      <rule id="Rule_Bloqueio_1_COMP_LGPD_007">
        <description>Compartilhamento com operadora sem consentimento</description>
        <inputEntry id="InputEntry_B1_1_COMP_LGPD_007"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_LGPD_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_LGPD_007"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B1_1_COMP_LGPD_007"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_2_COMP_LGPD_007"><text>"Compartilhamento de dados com operadora requer consentimento expresso do paciente conforme LGPD Art. 7 IX e CFM Res. 1.821/2007."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_3_COMP_LGPD_007"><text>"Obter consentimento especifico para compartilhamento com operadora antes de enviar guias ou documentacao clinica."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_4_COMP_LGPD_007"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_5_COMP_LGPD_007"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA B2: Bloqueio - Dados completos sem emergencia -->
      <rule id="Rule_Bloqueio_2_COMP_LGPD_007">
        <description>Compartilhamento completo sem justificativa de emergencia</description>
        <inputEntry id="InputEntry_B2_1_COMP_LGPD_007"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_LGPD_007"><text>"PRESENCIAL", "TELEMEDICINA"</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_COMP_LGPD_007"><text>"COMPLETO"</text></inputEntry>
        <outputEntry id="OutputEntry_B2_1_COMP_LGPD_007"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_2_COMP_LGPD_007"><text>"Compartilhamento de dados completos com operadora viola principio da minimizacao (LGPD Art. 6 III). Apenas dados necessarios para autorizacao/faturamento."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_3_COMP_LGPD_007"><text>"Limitar compartilhamento a dados administrativos e clinicos essenciais (CID, procedimento, justificativa). Excluir anamnese completa."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_4_COMP_LGPD_007"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_5_COMP_LGPD_007"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA A1: Alerta - Dados clinicos amplos -->
      <rule id="Rule_Alerta_1_COMP_LGPD_007">
        <description>Compartilhamento de dados clinicos requer documentacao</description>
        <inputEntry id="InputEntry_A1_1_COMP_LGPD_007"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_LGPD_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_LGPD_007"><text>"CLINICO"</text></inputEntry>
        <outputEntry id="OutputEntry_A1_1_COMP_LGPD_007"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_2_COMP_LGPD_007"><text>"Compartilhamento de dados clinicos com operadora. Verificar se finalidade esta documentada e limitada a autorizacao/auditoria."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_3_COMP_LGPD_007"><text>"Documentar finalidade especifica do compartilhamento. Revisar relatorio de impacto a privacidade (RIPD) se aplicavel."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_4_COMP_LGPD_007"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_5_COMP_LGPD_007"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA P1: Aprovado - Dados administrativos -->
      <rule id="Rule_Aprovado_1_COMP_LGPD_007">
        <description>Compartilhamento de dados administrativos autorizado</description>
        <inputEntry id="InputEntry_P1_1_COMP_LGPD_007"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_LGPD_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_LGPD_007"><text>"ADMINISTRATIVO"</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_COMP_LGPD_007"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_2_COMP_LGPD_007"><text>"Compartilhamento de dados administrativos com operadora autorizado. Finalidade: faturamento e autorizacao conforme RN ANS 412/2016."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_3_COMP_LGPD_007"><text>"Prosseguir com envio de guia TISS. Garantir criptografia em transito (TLS 1.2+) e anonimizacao quando possivel."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_4_COMP_LGPD_007"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_5_COMP_LGPD_007"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA P2: Aprovado - Emergencia com dados completos -->
      <rule id="Rule_Aprovado_2_COMP_LGPD_007">
        <description>Emergencia justifica compartilhamento amplo</description>
        <inputEntry id="InputEntry_P2_1_COMP_LGPD_007"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_COMP_LGPD_007"><text>"EMERGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_COMP_LGPD_007"><text>"COMPLETO"</text></inputEntry>
        <outputEntry id="OutputEntry_P2_1_COMP_LGPD_007"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P2_2_COMP_LGPD_007"><text>"Situacao de emergencia justifica compartilhamento amplo conforme LGPD Art. 7 VII (protecao a vida). Documentar natureza da emergencia."</text></outputEntry>
        <outputEntry id="OutputEntry_P2_3_COMP_LGPD_007"><text>"Prosseguir com compartilhamento. Registrar justificativa de emergencia no prontuario. Notificar paciente posteriormente."</text></outputEntry>
        <outputEntry id="OutputEntry_P2_4_COMP_LGPD_007"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P2_5_COMP_LGPD_007"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisao manual -->
      <rule id="Rule_Fallback_COMP_LGPD_007">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_COMP_LGPD_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_LGPD_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_LGPD_007"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_COMP_LGPD_007"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_COMP_LGPD_007"><text>"Situacao de compartilhamento com operadora requer analise manual. Verificar consentimento, finalidade e abrangencia dos dados."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_COMP_LGPD_007"><text>"Encaminhar para DPO para avaliacao de conformidade LGPD e adequacao ao principio da minimizacao."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_COMP_LGPD_007"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_COMP_LGPD_007"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_LGPD_007">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_LGPD_007" dmnElementRef="Decision_COMP_LGPD_007">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
