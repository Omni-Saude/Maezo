<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-VIGIL-004 - Certificado do Corpo de Bombeiros
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-VIGIL
  Perspectiva: HOSPITAL (Administrativo - Segurança)

  ============================================================================
  INDICACOES (Quando PROSSEGUIR):
  ============================================================================
  - Certificado do Corpo de Bombeiros válido
  - Mais de 90 dias para vencimento
  - Hospital regular em segurança contra incêndio

  ============================================================================
  CONTRAINDICACOES (Quando BLOQUEAR):
  ============================================================================
  - Certificado vencido
  - Hospital sem certificado válido
  - Irregularidade detectada em vistoria do Corpo de Bombeiros

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Legislação estadual/municipal de segurança contra incêndio
  - NBR 13434 - Sinalização de segurança
  - NBR 9077 - Saídas de emergência
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_COMP_VIGIL_004"
             name="Certificado do Corpo de Bombeiros"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_VIGIL_004" name="[SP-PS-001 | compliance/vigil] Certificado do Corpo de Bombeiros" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_VIGIL_004" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_COMP_VIGIL_004" label="Certificado Válido">
        <inputExpression id="InputExpression_1_COMP_VIGIL_004" typeRef="boolean">
          <text>certificadoValido</text>
        </inputExpression>
      </input>

      <input id="Input_2_COMP_VIGIL_004" label="Dias para Vencimento">
        <inputExpression id="InputExpression_2_COMP_VIGIL_004" typeRef="integer">
          <text>diasVencimento</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_VIGIL_004" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_VIGIL_004" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_VIGIL_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_VIGIL_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_VIGIL_004" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA B1: Bloqueio - Certificado vencido -->
      <rule id="Rule_Bloqueio_1_COMP_VIGIL_004">
        <description>Certificado do Corpo de Bombeiros vencido</description>
        <inputEntry id="InputEntry_B1_1_COMP_VIGIL_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_VIGIL_004"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B1_1_COMP_VIGIL_004"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_2_COMP_VIGIL_004"><text>"Certificado do Corpo de Bombeiros vencido. Hospital irregular em segurança contra incêndio."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_3_COMP_VIGIL_004"><text>"Solicitar vistoria urgente do Corpo de Bombeiros para renovação do certificado."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_4_COMP_VIGIL_004"><text>"CRED"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_5_COMP_VIGIL_004"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA A1: Alerta - Vencimento próximo (30-90 dias) -->
      <rule id="Rule_Alerta_1_COMP_VIGIL_004">
        <description>Certificado próximo ao vencimento</description>
        <inputEntry id="InputEntry_A1_1_COMP_VIGIL_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_VIGIL_004"><text>[30..90]</text></inputEntry>
        <outputEntry id="OutputEntry_A1_1_COMP_VIGIL_004"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_2_COMP_VIGIL_004"><text>"Certificado do Corpo de Bombeiros vigente mas próximo ao vencimento."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_3_COMP_VIGIL_004"><text>"Agendar vistoria do Corpo de Bombeiros nos próximos 30 dias."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_4_COMP_VIGIL_004"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_5_COMP_VIGIL_004"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA P1: Aprovado - Certificado válido com prazo adequado -->
      <rule id="Rule_Aprovado_1_COMP_VIGIL_004">
        <description>Certificado do Corpo de Bombeiros válido e regular</description>
        <inputEntry id="InputEntry_P1_1_COMP_VIGIL_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_VIGIL_004"><text>&gt; 90</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_COMP_VIGIL_004"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_2_COMP_VIGIL_004"><text>"Certificado do Corpo de Bombeiros válido e regular em segurança contra incêndio."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_3_COMP_VIGIL_004"><text>"Prosseguir com faturamento conforme procedimento padrão."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_4_COMP_VIGIL_004"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_5_COMP_VIGIL_004"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisão manual -->
      <rule id="Rule_Fallback_COMP_VIGIL_004">
        <description>Regra padrão - Requer avaliação manual</description>
        <inputEntry id="InputEntry_F_1_COMP_VIGIL_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_VIGIL_004"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_COMP_VIGIL_004"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_COMP_VIGIL_004"><text>"Situação requer análise manual por não corresponder a nenhum critério automático."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_COMP_VIGIL_004"><text>"Encaminhar para auditoria administrativa para avaliação caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_COMP_VIGIL_004"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_COMP_VIGIL_004"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_VIGIL_004">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_VIGIL_004" dmnElementRef="Decision_COMP_VIGIL_004">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
