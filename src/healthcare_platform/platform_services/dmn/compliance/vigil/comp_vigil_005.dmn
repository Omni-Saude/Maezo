<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-VIGIL-005 - Responsável Técnico Registrado no CRM
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-VIGIL
  Perspectiva: HOSPITAL (Administrativo - Responsabilidade Técnica)

  ============================================================================
  INDICACOES (Quando PROSSEGUIR):
  ============================================================================
  - Responsável técnico registrado no CRM
  - CRM ativo e sem pendências
  - Hospital com responsabilidade técnica regular

  ============================================================================
  CONTRAINDICACOES (Quando BLOQUEAR):
  ============================================================================
  - Hospital sem responsável técnico registrado
  - CRM do responsável técnico inativo ou suspenso
  - Pendências no registro de responsabilidade técnica

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Lei 3.268/1957 - Conselhos de Medicina
  - Resolução CFM 2.145/2016 - Responsabilidade técnica
  - RDC ANVISA 50/2002
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_COMP_VIGIL_005"
             name="Responsável Técnico Registrado no CRM"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_VIGIL_005" name="[SP-PS-001 | compliance/vigil] Responsável Técnico Registrado no CRM" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_VIGIL_005" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_COMP_VIGIL_005" label="Responsável Registrado">
        <inputExpression id="InputExpression_1_COMP_VIGIL_005" typeRef="boolean">
          <text>responsavelRegistrado</text>
        </inputExpression>
      </input>

      <input id="Input_2_COMP_VIGIL_005" label="CRM Ativo">
        <inputExpression id="InputExpression_2_COMP_VIGIL_005" typeRef="boolean">
          <text>crmAtivo</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_VIGIL_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_VIGIL_005" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_VIGIL_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_VIGIL_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_VIGIL_005" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA B1: Bloqueio - Sem responsável técnico registrado -->
      <rule id="Rule_Bloqueio_1_COMP_VIGIL_005">
        <description>Hospital sem responsável técnico registrado</description>
        <inputEntry id="InputEntry_B1_1_COMP_VIGIL_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_VIGIL_005"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B1_1_COMP_VIGIL_005"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_2_COMP_VIGIL_005"><text>"Hospital sem responsável técnico registrado no CRM."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_3_COMP_VIGIL_005"><text>"Registrar urgentemente responsável técnico junto ao CRM estadual."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_4_COMP_VIGIL_005"><text>"CRED"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_5_COMP_VIGIL_005"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA B2: Bloqueio - CRM inativo -->
      <rule id="Rule_Bloqueio_2_COMP_VIGIL_005">
        <description>CRM do responsável técnico inativo</description>
        <inputEntry id="InputEntry_B2_1_COMP_VIGIL_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_COMP_VIGIL_005"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_B2_1_COMP_VIGIL_005"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_2_COMP_VIGIL_005"><text>"CRM do responsável técnico está inativo ou suspenso."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_3_COMP_VIGIL_005"><text>"Regularizar situação do CRM ou designar novo responsável técnico com CRM ativo."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_4_COMP_VIGIL_005"><text>"CRED"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_5_COMP_VIGIL_005"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA P1: Aprovado - Responsável técnico regular -->
      <rule id="Rule_Aprovado_1_COMP_VIGIL_005">
        <description>Responsável técnico registrado e CRM ativo</description>
        <inputEntry id="InputEntry_P1_1_COMP_VIGIL_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_VIGIL_005"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_COMP_VIGIL_005"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_2_COMP_VIGIL_005"><text>"Responsável técnico registrado no CRM e com registro ativo."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_3_COMP_VIGIL_005"><text>"Prosseguir com faturamento conforme procedimento padrão."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_4_COMP_VIGIL_005"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_5_COMP_VIGIL_005"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisão manual -->
      <rule id="Rule_Fallback_COMP_VIGIL_005">
        <description>Regra padrão - Requer avaliação manual</description>
        <inputEntry id="InputEntry_F_1_COMP_VIGIL_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_VIGIL_005"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_COMP_VIGIL_005"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_COMP_VIGIL_005"><text>"Situação requer análise manual por não corresponder a nenhum critério automático."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_COMP_VIGIL_005"><text>"Encaminhar para auditoria administrativa para avaliação caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_COMP_VIGIL_005"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_COMP_VIGIL_005"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_VIGIL_005">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_VIGIL_005" dmnElementRef="Decision_COMP_VIGIL_005">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
