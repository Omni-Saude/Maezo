<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-VIGIL-001 - Licença Sanitária Vigente
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-VIGIL
  Perspectiva: HOSPITAL (Administrativo - Vigilância Sanitária)

  ============================================================================
  INDICACOES (Quando PROSSEGUIR):
  ============================================================================
  - Licença sanitária vigente e dentro do prazo de validade
  - Mais de 90 dias para vencimento
  - Hospital regular perante vigilância sanitária

  ============================================================================
  CONTRAINDICACOES (Quando BLOQUEAR):
  ============================================================================
  - Licença sanitária vencida
  - Hospital sem licença sanitária válida
  - Irregularidade detectada na vigilância sanitária

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Lei 6.437/1977 - Infrações sanitárias
  - RDC ANVISA 50/2002 - Regulamento técnico
  - Legislação estadual/municipal de vigilância sanitária
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_COMP_VIGIL_001"
             name="Licença Sanitária Vigente"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_VIGIL_001" name="[SP-PS-001 | compliance/vigil] Licença Sanitária Vigente" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_VIGIL_001" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_COMP_VIGIL_001" label="Licença Vigente">
        <inputExpression id="InputExpression_1_COMP_VIGIL_001" typeRef="boolean">
          <text>licencaVigente</text>
        </inputExpression>
      </input>

      <input id="Input_2_COMP_VIGIL_001" label="Dias para Vencimento">
        <inputExpression id="InputExpression_2_COMP_VIGIL_001" typeRef="integer">
          <text>diasVencimento</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_VIGIL_001" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_VIGIL_001" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_VIGIL_001" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_VIGIL_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_VIGIL_001" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA B1: Bloqueio - Licença vencida -->
      <rule id="Rule_Bloqueio_1_COMP_VIGIL_001">
        <description>Licença sanitária vencida</description>
        <inputEntry id="InputEntry_B1_1_COMP_VIGIL_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_VIGIL_001"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B1_1_COMP_VIGIL_001"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_2_COMP_VIGIL_001"><text>"Licença sanitária vencida. Hospital irregular perante vigilância sanitária."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_3_COMP_VIGIL_001"><text>"Solicitar renovação urgente da licença sanitária junto à vigilância sanitária local."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_4_COMP_VIGIL_001"><text>"CRED"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_5_COMP_VIGIL_001"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA A1: Alerta - Vencimento próximo (30-90 dias) -->
      <rule id="Rule_Alerta_1_COMP_VIGIL_001">
        <description>Licença próxima ao vencimento</description>
        <inputEntry id="InputEntry_A1_1_COMP_VIGIL_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_VIGIL_001"><text>[30..90]</text></inputEntry>
        <outputEntry id="OutputEntry_A1_1_COMP_VIGIL_001"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_2_COMP_VIGIL_001"><text>"Licença sanitária vigente mas próxima ao vencimento."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_3_COMP_VIGIL_001"><text>"Iniciar processo de renovação da licença sanitária nos próximos 30 dias."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_4_COMP_VIGIL_001"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_5_COMP_VIGIL_001"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA P1: Aprovado - Licença vigente com prazo adequado -->
      <rule id="Rule_Aprovado_1_COMP_VIGIL_001">
        <description>Licença sanitária vigente e regular</description>
        <inputEntry id="InputEntry_P1_1_COMP_VIGIL_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_VIGIL_001"><text>&gt; 90</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_COMP_VIGIL_001"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_2_COMP_VIGIL_001"><text>"Licença sanitária vigente e regular perante vigilância sanitária."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_3_COMP_VIGIL_001"><text>"Prosseguir com faturamento conforme procedimento padrão."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_4_COMP_VIGIL_001"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_5_COMP_VIGIL_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisão manual -->
      <rule id="Rule_Fallback_COMP_VIGIL_001">
        <description>Regra padrão - Requer avaliação manual</description>
        <inputEntry id="InputEntry_F_1_COMP_VIGIL_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_VIGIL_001"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_COMP_VIGIL_001"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_COMP_VIGIL_001"><text>"Situação requer análise manual por não corresponder a nenhum critério automático."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_COMP_VIGIL_001"><text>"Encaminhar para auditoria administrativa para avaliação caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_COMP_VIGIL_001"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_COMP_VIGIL_001"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_VIGIL_001">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_VIGIL_001" dmnElementRef="Decision_COMP_VIGIL_001">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
