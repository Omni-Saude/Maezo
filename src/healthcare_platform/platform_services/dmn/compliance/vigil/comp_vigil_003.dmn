<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-VIGIL-003 - Alvará de Funcionamento Válido
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-VIGIL
  Perspectiva: HOSPITAL (Administrativo - Vigilância Sanitária)

  ============================================================================
  INDICACOES (Quando PROSSEGUIR):
  ============================================================================
  - Alvará de funcionamento válido e dentro do prazo
  - Mais de 90 dias para vencimento
  - Hospital regular perante prefeitura municipal

  ============================================================================
  CONTRAINDICACOES (Quando BLOQUEAR):
  ============================================================================
  - Alvará de funcionamento vencido
  - Hospital sem alvará válido
  - Pendências detectadas na prefeitura

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Lei Orgânica Municipal
  - Código de Posturas Municipal
  - Lei 8.080/1990 - Lei Orgânica da Saúde
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_COMP_VIGIL_003"
             name="Alvará de Funcionamento Válido"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_VIGIL_003" name="[SP-PS-001 | compliance/vigil] Alvará de Funcionamento Válido" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_VIGIL_003" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_COMP_VIGIL_003" label="Alvará Válido">
        <inputExpression id="InputExpression_1_COMP_VIGIL_003" typeRef="boolean">
          <text>alvaraValido</text>
        </inputExpression>
      </input>

      <input id="Input_2_COMP_VIGIL_003" label="Dias para Vencimento">
        <inputExpression id="InputExpression_2_COMP_VIGIL_003" typeRef="integer">
          <text>diasVencimento</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_VIGIL_003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_VIGIL_003" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_VIGIL_003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_VIGIL_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_VIGIL_003" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA B1: Bloqueio - Alvará vencido -->
      <rule id="Rule_Bloqueio_1_COMP_VIGIL_003">
        <description>Alvará de funcionamento vencido</description>
        <inputEntry id="InputEntry_B1_1_COMP_VIGIL_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_VIGIL_003"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B1_1_COMP_VIGIL_003"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_2_COMP_VIGIL_003"><text>"Alvará de funcionamento vencido. Hospital irregular perante prefeitura municipal."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_3_COMP_VIGIL_003"><text>"Solicitar renovação urgente do alvará junto à prefeitura municipal."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_4_COMP_VIGIL_003"><text>"CRED"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_5_COMP_VIGIL_003"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA A1: Alerta - Vencimento próximo (30-90 dias) -->
      <rule id="Rule_Alerta_1_COMP_VIGIL_003">
        <description>Alvará próximo ao vencimento</description>
        <inputEntry id="InputEntry_A1_1_COMP_VIGIL_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_VIGIL_003"><text>[30..90]</text></inputEntry>
        <outputEntry id="OutputEntry_A1_1_COMP_VIGIL_003"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_2_COMP_VIGIL_003"><text>"Alvará de funcionamento vigente mas próximo ao vencimento."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_3_COMP_VIGIL_003"><text>"Iniciar processo de renovação do alvará nos próximos 30 dias."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_4_COMP_VIGIL_003"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_5_COMP_VIGIL_003"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA P1: Aprovado - Alvará válido com prazo adequado -->
      <rule id="Rule_Aprovado_1_COMP_VIGIL_003">
        <description>Alvará de funcionamento válido e regular</description>
        <inputEntry id="InputEntry_P1_1_COMP_VIGIL_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_VIGIL_003"><text>&gt; 90</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_COMP_VIGIL_003"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_2_COMP_VIGIL_003"><text>"Alvará de funcionamento válido e regular perante prefeitura municipal."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_3_COMP_VIGIL_003"><text>"Prosseguir com faturamento conforme procedimento padrão."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_4_COMP_VIGIL_003"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_5_COMP_VIGIL_003"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisão manual -->
      <rule id="Rule_Fallback_COMP_VIGIL_003">
        <description>Regra padrão - Requer avaliação manual</description>
        <inputEntry id="InputEntry_F_1_COMP_VIGIL_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_VIGIL_003"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_COMP_VIGIL_003"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_COMP_VIGIL_003"><text>"Situação requer análise manual por não corresponder a nenhum critério automático."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_COMP_VIGIL_003"><text>"Encaminhar para auditoria administrativa para avaliação caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_COMP_VIGIL_003"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_COMP_VIGIL_003"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_VIGIL_003">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_VIGIL_003" dmnElementRef="Decision_COMP_VIGIL_003">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
