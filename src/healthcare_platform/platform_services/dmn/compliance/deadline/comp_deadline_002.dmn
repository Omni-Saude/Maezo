<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COMP-DEADLINE-002 - Prazo Reapresentacao
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: COMP-DEADLINE
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_COMP_DEADLINE_002" name="Prazo Reapresentacao" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COMP_DEADLINE_002" name="[SP-PS-001 | compliance/deadline] Validacao Prazo Reapresentacao" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COMP_DEADLINE_002" hitPolicy="FIRST">

      <input id="Input_1_COMP_DEADLINE_002" label="Dias Desde Glosa">
        <inputExpression id="InputExpression_1_COMP_DEADLINE_002" typeRef="number">
          <text>diasDesdeGlosa</text>
        </inputExpression>
      </input>

      <input id="Input_2_COMP_DEADLINE_002" label="Correcoes Realizadas">
        <inputExpression id="InputExpression_2_COMP_DEADLINE_002" typeRef="boolean">
          <text>correcoesRealizadas</text>
        </inputExpression>
      </input>

      <input id="Input_3_COMP_DEADLINE_002" label="Documentacao Anexada">
        <inputExpression id="InputExpression_3_COMP_DEADLINE_002" typeRef="boolean">
          <text>documentacaoAnexada</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_COMP_DEADLINE_002" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_COMP_DEADLINE_002" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_COMP_DEADLINE_002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_COMP_DEADLINE_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_COMP_DEADLINE_002" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_COMP_DEADLINE_002">
        <description>Prazo de 30 dias para reapresentacao excedido</description>
        <inputEntry id="InputEntry_B1_1_COMP_DEADLINE_002"><text>&gt; 30</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_COMP_DEADLINE_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_COMP_DEADLINE_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_COMP_DEADLINE_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_COMP_DEADLINE_002"><text>"Prazo de 30 dias para reapresentacao EXCEDIDO. Iniciar processo de recurso de primeira instancia ou registrar perda."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_COMP_DEADLINE_002"><text>"PRAZO_EXCEDIDO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_4_COMP_DEADLINE_002"><text>"PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Bloquear_1_5_COMP_DEADLINE_002"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_COMP_DEADLINE_002">
        <description>Alerta critico - Menos de 5 dias para vencimento</description>
        <inputEntry id="InputEntry_A1_1_COMP_DEADLINE_002"><text>[26..30]</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_COMP_DEADLINE_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_COMP_DEADLINE_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_COMP_DEADLINE_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_COMP_DEADLINE_002"><text>"URGENTE: Menos de 5 dias para vencimento do prazo de reapresentacao. Finalizar correcoes e submeter IMEDIATAMENTE."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_COMP_DEADLINE_002"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_4_COMP_DEADLINE_002"><text>"PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_1_5_COMP_DEADLINE_002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_2_COMP_DEADLINE_002">
        <description>Alerta proximidade - Menos de 10 dias para vencimento</description>
        <inputEntry id="InputEntry_A2_1_COMP_DEADLINE_002"><text>[21..25]</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_COMP_DEADLINE_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_COMP_DEADLINE_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_COMP_DEADLINE_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_COMP_DEADLINE_002"><text>"Atencao: Menos de 10 dias para vencimento do prazo de reapresentacao. Priorizar correcoes."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_COMP_DEADLINE_002"><text>"ALERTA_PROXIMIDADE"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_4_COMP_DEADLINE_002"><text>"PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_2_5_COMP_DEADLINE_002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_3_COMP_DEADLINE_002">
        <description>Correcoes nao realizadas</description>
        <inputEntry id="InputEntry_A3_1_COMP_DEADLINE_002"><text>[0..20]</text></inputEntry>
        <inputEntry id="InputEntry_A3_2_COMP_DEADLINE_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A3_3_COMP_DEADLINE_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A3_1_COMP_DEADLINE_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A3_2_COMP_DEADLINE_002"><text>"Correcoes nao realizadas. Analisar motivo da glosa e efetuar correcoes necessarias antes de reapresentar."</text></outputEntry>
<outputEntry id="OutputEntry_A3_3_COMP_DEADLINE_002"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_3_4_COMP_DEADLINE_002"><text>"PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_3_5_COMP_DEADLINE_002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_4_COMP_DEADLINE_002">
        <description>Documentacao complementar nao anexada</description>
        <inputEntry id="InputEntry_A4_1_COMP_DEADLINE_002"><text>[0..20]</text></inputEntry>
        <inputEntry id="InputEntry_A4_2_COMP_DEADLINE_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A4_3_COMP_DEADLINE_002"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_A4_1_COMP_DEADLINE_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A4_2_COMP_DEADLINE_002"><text>"Documentacao complementar nao anexada. Anexar documentos que justifiquem a correcao antes de reapresentar."</text></outputEntry>
<outputEntry id="OutputEntry_A4_3_COMP_DEADLINE_002"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_4_4_COMP_DEADLINE_002"><text>"PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Alertar_4_5_COMP_DEADLINE_002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_COMP_DEADLINE_002">
        <description>Pronto para reapresentacao</description>
        <inputEntry id="InputEntry_P1_1_COMP_DEADLINE_002"><text>[0..20]</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_COMP_DEADLINE_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_COMP_DEADLINE_002"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_COMP_DEADLINE_002"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_COMP_DEADLINE_002"><text>"Reapresentacao dentro do prazo com correcoes e documentacao OK. Submeter ao convenio."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_COMP_DEADLINE_002"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_4_COMP_DEADLINE_002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Prosseguir_1_5_COMP_DEADLINE_002"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_COMP_DEADLINE_002">
        <description>Caso padrao - Revisar reapresentacao</description>
        <inputEntry id="InputEntry_F_1_COMP_DEADLINE_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_COMP_DEADLINE_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_COMP_DEADLINE_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_COMP_DEADLINE_002"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_COMP_DEADLINE_002"><text>"Verificar data da glosa, correcoes realizadas e documentacao anexada."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_COMP_DEADLINE_002"><text>"DENTRO_PRAZO"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_DEADLINE_002_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_COMP_DEADLINE_002_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COMP_DEADLINE_002">
      <dmndi:DMNShape id="DMNShape_Decision_COMP_DEADLINE_002" dmnElementRef="Decision_COMP_DEADLINE_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>