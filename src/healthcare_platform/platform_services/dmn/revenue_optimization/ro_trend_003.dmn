<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_RO_TREND_003"
             name="RO_TREND_003"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_RO_TREND_003" name="[SP-RC-010 | revenue_optimization] Revenue Alert Thresholds" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_RO_TREND_003" hitPolicy="FIRST">
      <input id="Input_deviationPercentage_RO_TREND_003" label="Deviation Percentage">
        <inputExpression id="InputExpression_deviationPercentage_RO_TREND_003" typeRef="number">
          <text>deviationPercentage</text>
        </inputExpression>
      </input>
      <input id="Input_forecastHorizon_RO_TREND_003" label="Forecast Horizon (months)">
        <inputExpression id="InputExpression_forecastHorizon_RO_TREND_003" typeRef="number">
          <text>forecastHorizon</text>
        </inputExpression>
      </input>
      <input id="Input_confidenceLevel_RO_TREND_003" label="Confidence Level">
        <inputExpression id="InputExpression_confidenceLevel_RO_TREND_003" typeRef="number">
          <text>confidenceLevel</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_RO_TREND_003" label="Resultado" name="resultado" typeRef="string" />
      <output id="Output_observacao_RO_TREND_003" label="Observação" name="observacao" typeRef="string" />
      <output id="Output_acaoRecomendada_RO_TREND_003" label="Ação Recomendada" name="acaoRecomendada" typeRef="string" />
      <output id="Output_alertasConformidade_RO_TREND_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string" />
      <output id="Output_riscoDenial_RO_TREND_003" label="Risco Denial" name="riscoDenial" typeRef="string" />
      <rule id="Rule_RO_TREND_003_1">
        <inputEntry id="InputEntry_RO_TREND_003_1_1"><text>&gt; 0.25</text></inputEntry>
        <inputEntry id="InputEntry_RO_TREND_003_1_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_TREND_003_1_3"><text>&gt; 0.8</text></inputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_1_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_1_2"><text>"Desvio crítico do forecast (&gt;25%) com alta confiança"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_1_3"><text>"Investigar causa raiz e revisar projeções imediatamente"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_1_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_1_5"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_TREND_003_2">
        <inputEntry id="InputEntry_RO_TREND_003_2_1"><text>&gt; 0.15</text></inputEntry>
        <inputEntry id="InputEntry_RO_TREND_003_2_2"><text>&lt;= 3</text></inputEntry>
        <inputEntry id="InputEntry_RO_TREND_003_2_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_2_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_2_2"><text>"Desvio significativo (&gt;15%) no curto prazo (&lt;=3m)"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_2_3"><text>"Análise urgente de fatores conjunturais"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_2_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_2_5"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_TREND_003_3">
        <inputEntry id="InputEntry_RO_TREND_003_3_1"><text>[0.1..0.25]</text></inputEntry>
        <inputEntry id="InputEntry_RO_TREND_003_3_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_TREND_003_3_3"><text>[0.6..0.8]</text></inputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_3_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_3_2"><text>"Desvio moderado (10-25%) com confiança média"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_3_3"><text>"Monitorar de perto e preparar ajustes de estratégia"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_3_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_3_5"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_TREND_003_4">
        <inputEntry id="InputEntry_RO_TREND_003_4_1"><text>&lt; 0.1</text></inputEntry>
        <inputEntry id="InputEntry_RO_TREND_003_4_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_TREND_003_4_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_4_1"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_4_2"><text>"Desvio dentro da margem aceitável (&lt;10%)"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_4_3"><text>"Continuar monitoramento de rotina"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_4_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_4_5"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_TREND_003_5">
        <inputEntry id="InputEntry_RO_TREND_003_5_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_TREND_003_5_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_TREND_003_5_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_5_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_5_2"><text>"Dados insuficientes para determinar criticidade"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_5_3"><text>"Validar métricas e recalcular intervalos de confiança"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_5_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_003_5_5"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RO_TREND_003">
      <dmndi:DMNShape id="DMNShape_RO_TREND_003" dmnElementRef="Decision_RO_TREND_003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
