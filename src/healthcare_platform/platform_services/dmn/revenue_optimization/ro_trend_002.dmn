<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_RO_TREND_002"
             name="RO_TREND_002"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_RO_TREND_002" name="[SP-RC-010 | revenue_optimization] Revenue Forecast Model Selection" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_RO_TREND_002" hitPolicy="FIRST">
      <input id="Input_dataPoints_RO_TREND_002" label="Data Points">
        <inputExpression id="InputExpression_dataPoints_RO_TREND_002" typeRef="number">
          <text>dataPoints</text>
        </inputExpression>
      </input>
      <input id="Input_seasonalityStrength_RO_TREND_002" label="Seasonality Strength">
        <inputExpression id="InputExpression_seasonalityStrength_RO_TREND_002" typeRef="string">
          <text>seasonalityStrength</text>
        </inputExpression>
      </input>
      <input id="Input_trendStability_RO_TREND_002" label="Trend Stability">
        <inputExpression id="InputExpression_trendStability_RO_TREND_002" typeRef="string">
          <text>trendStability</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_RO_TREND_002" label="Resultado" name="resultado" typeRef="string" />
      <output id="Output_observacao_RO_TREND_002" label="Observação" name="observacao" typeRef="string" />
      <output id="Output_acaoRecomendada_RO_TREND_002" label="Ação Recomendada" name="acaoRecomendada" typeRef="string" />
      <output id="Output_alertasConformidade_RO_TREND_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string" />
      <output id="Output_riscoDenial_RO_TREND_002" label="Risco Denial" name="riscoDenial" typeRef="string" />
      <rule id="Rule_RO_TREND_002_1">
        <inputEntry id="InputEntry_RO_TREND_002_1_1"><text>&lt; 12</text></inputEntry>
        <inputEntry id="InputEntry_RO_TREND_002_1_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_TREND_002_1_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_1_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_1_2"><text>"Dados insuficientes para forecast confiável (&lt;12 meses)"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_1_3"><text>"Aguardar mais dados ou usar heurística simples"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_1_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_1_5"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_TREND_002_2">
        <inputEntry id="InputEntry_RO_TREND_002_2_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_TREND_002_2_2"><text>"STRONG"</text></inputEntry>
        <inputEntry id="InputEntry_RO_TREND_002_2_3"><text>"VOLATILE"</text></inputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_2_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_2_2"><text>"Forte sazonalidade com tendência volátil - modelo complexo necessário"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_2_3"><text>"Usar SARIMA ou modelo ensemble avançado"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_2_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_2_5"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_TREND_002_3">
        <inputEntry id="InputEntry_RO_TREND_002_3_1"><text>[12..24)</text></inputEntry>
        <inputEntry id="InputEntry_RO_TREND_002_3_2"><text>"MODERATE", "WEAK"</text></inputEntry>
        <inputEntry id="InputEntry_RO_TREND_002_3_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_3_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_3_2"><text>"Dados limitados (12-24m) com sazonalidade fraca/moderada"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_3_3"><text>"Usar modelo linear com ajuste sazonal simples"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_3_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_3_5"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_TREND_002_4">
        <inputEntry id="InputEntry_RO_TREND_002_4_1"><text>&gt;= 24</text></inputEntry>
        <inputEntry id="InputEntry_RO_TREND_002_4_2"><text>"STRONG"</text></inputEntry>
        <inputEntry id="InputEntry_RO_TREND_002_4_3"><text>"STABLE"</text></inputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_4_1"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_4_2"><text>"Dados robustos (&gt;=24m) com padrões estáveis"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_4_3"><text>"Usar SARIMA ou Prophet para forecast preciso"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_4_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_4_5"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_TREND_002_5">
        <inputEntry id="InputEntry_RO_TREND_002_5_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_TREND_002_5_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_TREND_002_5_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_5_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_5_2"><text>"Combinação de características não mapeada"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_5_3"><text>"Análise exploratória e seleção customizada de modelo"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_5_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_TREND_002_5_5"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RO_TREND_002">
      <dmndi:DMNShape id="DMNShape_RO_TREND_002" dmnElementRef="Decision_RO_TREND_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
