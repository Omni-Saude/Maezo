<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_RO_POTENTIAL_003"
             name="RO_POTENTIAL_003"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_RO_POTENTIAL_003" name="[SP-RC-010 | revenue_optimization] Revenue Scenario Prioritization" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_RO_POTENTIAL_003" hitPolicy="FIRST">
      <input id="Input_riskLevel_RO_POTENTIAL_003" label="Risk Level">
        <inputExpression id="InputExpression_riskLevel_RO_POTENTIAL_003" typeRef="string">
          <text>riskLevel</text>
        </inputExpression>
      </input>
      <input id="Input_confidenceLevel_RO_POTENTIAL_003" label="Confidence Level">
        <inputExpression id="InputExpression_confidenceLevel_RO_POTENTIAL_003" typeRef="number">
          <text>confidenceLevel</text>
        </inputExpression>
      </input>
      <input id="Input_timeToImplement_RO_POTENTIAL_003" label="Time To Implement (days)">
        <inputExpression id="InputExpression_timeToImplement_RO_POTENTIAL_003" typeRef="number">
          <text>timeToImplement</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_RO_POTENTIAL_003" label="Resultado" name="resultado" typeRef="string" />
      <output id="Output_observacao_RO_POTENTIAL_003" label="Observação" name="observacao" typeRef="string" />
      <output id="Output_acaoRecomendada_RO_POTENTIAL_003" label="Ação Recomendada" name="acaoRecomendada" typeRef="string" />
      <output id="Output_alertasConformidade_RO_POTENTIAL_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string" />
      <output id="Output_riscoDenial_RO_POTENTIAL_003" label="Risco Denial" name="riscoDenial" typeRef="string" />
      <rule id="Rule_RO_POTENTIAL_003_1">
        <inputEntry id="InputEntry_RO_POTENTIAL_003_1_1"><text>"HIGH"</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_003_1_2"><text>&lt; 0.6</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_003_1_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_1_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_1_2"><text>"Alto risco com baixa confiança (&lt;60%) - não recomendado"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_1_3"><text>"Descartar cenário ou coletar mais evidências"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_1_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_1_5"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_POTENTIAL_003_2">
        <inputEntry id="InputEntry_RO_POTENTIAL_003_2_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_003_2_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_003_2_3"><text>&gt; 180</text></inputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_2_1"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_2_2"><text>"Prazo muito longo para implementação (&gt;180d)"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_2_3"><text>"Dividir em fases menores ou reavaliar viabilidade"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_2_4"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_2_5"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_POTENTIAL_003_3">
        <inputEntry id="InputEntry_RO_POTENTIAL_003_3_1"><text>"MEDIUM"</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_003_3_2"><text>[0.6..0.8]</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_003_3_3"><text>[30..90]</text></inputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_3_1"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_3_2"><text>"Risco médio, confiança moderada (60-80%), prazo viável (30-90d)"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_3_3"><text>"Incluir em pipeline com análise de contingência"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_3_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_3_5"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_POTENTIAL_003_4">
        <inputEntry id="InputEntry_RO_POTENTIAL_003_4_1"><text>"LOW"</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_003_4_2"><text>&gt; 0.8</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_003_4_3"><text>&lt; 30</text></inputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_4_1"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_4_2"><text>"Baixo risco, alta confiança (&gt;80%), implementação rápida (&lt;30d)"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_4_3"><text>"Priorizar para próximo ciclo - quick win"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_4_4"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_4_5"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_RO_POTENTIAL_003_5">
        <inputEntry id="InputEntry_RO_POTENTIAL_003_5_1"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_003_5_2"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RO_POTENTIAL_003_5_3"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_5_1"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_5_2"><text>"Cenário não totalmente caracterizado"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_5_3"><text>"Completar análise de risco, confiança e prazo"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_5_4"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_RO_POTENTIAL_003_5_5"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RO_POTENTIAL_003">
      <dmndi:DMNShape id="DMNShape_RO_POTENTIAL_003" dmnElementRef="Decision_RO_POTENTIAL_003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
