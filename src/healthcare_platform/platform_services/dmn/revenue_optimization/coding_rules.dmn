<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="coding_rules"
             name="Coding Opportunity Rules"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="decision_coding_rules" name="[SP-RC-010 | revenue_optimization] Coding Optimization Decision" camunda:historyTimeToLive="180">
    <decisionTable id="dt_coding_rules" hitPolicy="FIRST">
      <input id="input_1_coding_rules" label="Documentation Completeness">
        <inputExpression id="ie_1_coding_rules" typeRef="number">
          <text>doc_completeness</text>
        </inputExpression>
      </input>
      <input id="input_2_coding_rules" label="Potential Upcode">
        <inputExpression id="ie_2_coding_rules" typeRef="string">
          <text>potential_upcode</text>
        </inputExpression>
      </input>
      <output id="output_resultado_coding_rules" label="resultado" name="resultado" typeRef="string"/>
      <output id="output_acao_coding_rules" label="acao" name="acao" typeRef="string"/>
      <output id="output_risco_coding_rules" label="risco" name="risco" typeRef="string"/>
      <rule id="rule_1_coding_rules">
        <inputEntry id="ie1_1_coding_rules"><text>&gt; 85</text></inputEntry>
        <inputEntry id="ie1_2_coding_rules"><text>"yes"</text></inputEntry>
        <outputEntry id="oe1_1_coding_rules"><text>"UPCODE_SEGURO"</text></outputEntry>
        <outputEntry id="oe1_2_coding_rules"><text>"Documentação suporta código superior"</text></outputEntry>
        <outputEntry id="oe1_3_coding_rules"><text>"baixo"</text></outputEntry>
      </rule>
      <rule id="rule_2_coding_rules">
        <inputEntry id="ie2_1_coding_rules"><text>&lt; 70</text></inputEntry>
        <inputEntry id="ie2_2_coding_rules"><text>"yes"</text></inputEntry>
        <outputEntry id="oe2_1_coding_rules"><text>"DOC_ADICIONAL"</text></outputEntry>
        <outputEntry id="oe2_2_coding_rules"><text>"Solicitar documentação adicional"</text></outputEntry>
        <outputEntry id="oe2_3_coding_rules"><text>"medio"</text></outputEntry>
      </rule>
      <rule id="rule_3_coding_rules">
        <inputEntry id="ie3_1_coding_rules"><text>&gt; 85</text></inputEntry>
        <inputEntry id="ie3_2_coding_rules"><text>"no"</text></inputEntry>
        <outputEntry id="oe3_1_coding_rules"><text>"CODIGO_CORRETO"</text></outputEntry>
        <outputEntry id="oe3_2_coding_rules"><text>"Código atual é adequado"</text></outputEntry>
        <outputEntry id="oe3_3_coding_rules"><text>"baixo"</text></outputEntry>
      </rule>
      <rule id="rule_4_coding_rules">
        <inputEntry id="ie4_1_coding_rules"><text>&lt; 70</text></inputEntry>
        <inputEntry id="ie4_2_coding_rules"><text>"no"</text></inputEntry>
        <outputEntry id="oe4_1_coding_rules"><text>"MELHORAR_DOC"</text></outputEntry>
        <outputEntry id="oe4_2_coding_rules"><text>"Melhorar documentação clínica"</text></outputEntry>
        <outputEntry id="oe4_3_coding_rules"><text>"medio"</text></outputEntry>
      </rule>
      <rule id="rule_5_coding_rules">
        <inputEntry id="ie5_1_coding_rules"><text>-</text></inputEntry>
        <inputEntry id="ie5_2_coding_rules"><text>-</text></inputEntry>
        <outputEntry id="oe5_1_coding_rules"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe5_2_coding_rules"><text>"Revisar codificação"</text></outputEntry>
        <outputEntry id="oe5_3_coding_rules"><text>"baixo"</text></outputEntry>
      </rule>
      <rule id="rule_6_coding_rules">
        <inputEntry id="ie6_1_coding_rules"><text>-</text></inputEntry>
        <inputEntry id="ie6_2_coding_rules"><text>-</text></inputEntry>
        <outputEntry id="oe6_1_coding_rules"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe6_2_coding_rules"><text>"Processar normalmente"</text></outputEntry>
        <outputEntry id="oe6_3_coding_rules"><text>"baixo"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_coding_rules">
      <dmndi:DMNShape id="DMNShape_decision_coding_rules" dmnElementRef="decision_coding_rules">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
