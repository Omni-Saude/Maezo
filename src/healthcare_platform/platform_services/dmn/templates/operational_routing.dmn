<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_OPERATIONAL_ROUTING_TEMPLATE"
             name="OPERATIONAL_ROUTING Template"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- TEMPLATE: OPERATIONAL_ROUTING v1.0.0
       Archetype: "Where/when/who should handle this?"
       Outputs: 3 (destino, prioridade, restricao)
       Hit Policy: FIRST (most constrained match wins) or COLLECT (multiple destinations)
       Inputs: Domain-specific. Replace placeholders below.

       Covers: OR allocation, surgical team assignment, notification timing,
               queue routing, channel selection, scheduling priority.
  -->

  <decision id="Decision_TEMPLATE_ID" name="TEMPLATE_NAME" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_TEMPLATE_ID" hitPolicy="FIRST">

      <!-- === INPUTS (replace with domain-specific) === -->

      <input id="Input_1_TEMPLATE_ID" label="Input 1">
        <inputExpression id="InputExpr_1_TEMPLATE_ID" typeRef="string">
          <text>inputVariable1</text>
        </inputExpression>
      </input>

      <input id="Input_2_TEMPLATE_ID" label="Input 2">
        <inputExpression id="InputExpr_2_TEMPLATE_ID" typeRef="string">
          <text>inputVariable2</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS (standardized — do not modify) === -->

      <output id="Output_destino_TEMPLATE_ID" label="Destino" name="destino" typeRef="string"/>

      <output id="Output_prioridade_TEMPLATE_ID" label="Prioridade" name="prioridade" typeRef="number"/>

      <output id="Output_restricao_TEMPLATE_ID" label="Restricao" name="restricao" typeRef="string"/>

      <!-- === RULES (ordered: most constrained/urgent first) === -->

      <!-- Rule 1: Highest priority routing -->
      <rule id="Rule_urgent_TEMPLATE_ID">
        <description>CUSTOMIZE: urgent routing condition</description>
        <inputEntry id="IE_urg_1_TEMPLATE_ID"><text></text></inputEntry>
        <inputEntry id="IE_urg_2_TEMPLATE_ID"><text></text></inputEntry>
        <outputEntry id="OE_urg_dest_TEMPLATE_ID"><text>"CUSTOMIZE: target"</text></outputEntry>
        <outputEntry id="OE_urg_prio_TEMPLATE_ID"><text>1</text></outputEntry>
        <outputEntry id="OE_urg_restr_TEMPLATE_ID"><text>"CUSTOMIZE: constraint"</text></outputEntry>
      </rule>

      <!-- Rule 2: Standard routing -->
      <rule id="Rule_standard_TEMPLATE_ID">
        <description>CUSTOMIZE: standard routing</description>
        <inputEntry id="IE_std_1_TEMPLATE_ID"><text></text></inputEntry>
        <inputEntry id="IE_std_2_TEMPLATE_ID"><text></text></inputEntry>
        <outputEntry id="OE_std_dest_TEMPLATE_ID"><text>"CUSTOMIZE"</text></outputEntry>
        <outputEntry id="OE_std_prio_TEMPLATE_ID"><text>3</text></outputEntry>
        <outputEntry id="OE_std_restr_TEMPLATE_ID"><text></text></outputEntry>
      </rule>

      <!-- Fallback: Default routing -->
      <rule id="Rule_fallback_TEMPLATE_ID">
        <description>Default routing — lowest priority</description>
        <inputEntry id="IE_fb_1_TEMPLATE_ID"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2_TEMPLATE_ID"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_dest_TEMPLATE_ID"><text>"FILA_GERAL"</text></outputEntry>
        <outputEntry id="OE_fb_prio_TEMPLATE_ID"><text>5</text></outputEntry>
        <outputEntry id="OE_fb_restr_TEMPLATE_ID"><text>"Nenhuma restricao"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1_TEMPLATE_ID">
      <dmndi:DMNShape id="DMNShape_Decision_TEMPLATE_ID" dmnElementRef="Decision_TEMPLATE_ID">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
