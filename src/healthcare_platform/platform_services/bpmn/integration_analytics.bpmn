<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                   xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                   xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                   xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                   xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                   id="Definitions_SUB_09"
                   targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="integration_analytics_process" name="SUB_09: Integration and Analytics" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="start_integration_analytics" name="Start Integration &amp; Analytics">
      <bpmn:outgoing>flow_to_sync_erp</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="sync_erp_data" name="Sync ERP Data" camunda:type="external" camunda:topic="platform.sync_erp_data">
      <bpmn:incoming>flow_to_sync_erp</bpmn:incoming>
      <bpmn:outgoing>flow_to_integrate_lab</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="integrate_laboratory" name="Integrate Laboratory" camunda:type="external" camunda:topic="platform.integrate_laboratory">
      <bpmn:incoming>flow_to_integrate_lab</bpmn:incoming>
      <bpmn:outgoing>flow_to_integrate_imaging</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="integrate_imaging" name="Integrate Imaging" camunda:type="external" camunda:topic="platform.integrate_imaging">
      <bpmn:incoming>flow_to_integrate_imaging</bpmn:incoming>
      <bpmn:outgoing>flow_to_aggregate_clinical</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="aggregate_clinical_metrics" name="Aggregate Clinical Metrics" camunda:type="external" camunda:topic="platform.aggregate_clinical_metrics">
      <bpmn:incoming>flow_to_aggregate_clinical</bpmn:incoming>
      <bpmn:outgoing>flow_to_calculate_operational</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="calculate_operational_metrics" name="Calculate Operational Metrics" camunda:type="external" camunda:topic="platform.calculate_operational_metrics">
      <bpmn:incoming>flow_to_calculate_operational</bpmn:incoming>
      <bpmn:outgoing>flow_to_analyze_financial</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="analyze_financial_performance" name="Analyze Financial Performance" camunda:type="external" camunda:topic="platform.analyze_financial_performance">
      <bpmn:incoming>flow_to_analyze_financial</bpmn:incoming>
      <bpmn:outgoing>flow_to_generate_dashboard</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="generate_executive_dashboard" name="Generate Executive Dashboard" camunda:type="external" camunda:topic="platform.generate_executive_dashboard">
      <bpmn:incoming>flow_to_generate_dashboard</bpmn:incoming>
      <bpmn:outgoing>flow_to_detect_quality</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="detect_data_quality_issues" name="Detect Data Quality Issues" camunda:type="external" camunda:topic="platform.detect_data_quality_issues">
      <bpmn:incoming>flow_to_detect_quality</bpmn:incoming>
      <bpmn:outgoing>flow_to_reconcile_sources</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="reconcile_data_sources" name="Reconcile Data Sources" camunda:type="external" camunda:topic="platform.reconcile_data_sources">
      <bpmn:incoming>flow_to_reconcile_sources</bpmn:incoming>
      <bpmn:outgoing>flow_to_export_warehouse</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="export_to_datawarehouse" name="Export to Datawarehouse" camunda:type="external" camunda:topic="platform.export_to_datawarehouse">
      <bpmn:incoming>flow_to_export_warehouse</bpmn:incoming>
      <bpmn:outgoing>flow_to_generate_reports</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="generate_regulatory_reports" name="Generate Regulatory Reports" camunda:type="external" camunda:topic="platform.generate_regulatory_reports">
      <bpmn:incoming>flow_to_generate_reports</bpmn:incoming>
      <bpmn:outgoing>flow_to_track_process</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="track_process_performance" name="Track Process Performance" camunda:type="external" camunda:topic="platform.track_process_performance">
      <bpmn:incoming>flow_to_track_process</bpmn:incoming>
      <bpmn:outgoing>flow_to_monitor_health</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="monitor_system_health" name="Monitor System Health" camunda:type="external" camunda:topic="platform.monitor_system_health">
      <bpmn:incoming>flow_to_monitor_health</bpmn:incoming>
      <bpmn:outgoing>flow_to_alert_anomalies</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="alert_on_anomalies" name="Alert on Anomalies" camunda:type="external" camunda:topic="platform.alert_on_anomalies">
      <bpmn:incoming>flow_to_alert_anomalies</bpmn:incoming>
      <bpmn:outgoing>flow_to_archive_data</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="archive_historical_data" name="Archive Historical Data" camunda:type="external" camunda:topic="platform.archive_historical_data">
      <bpmn:incoming>flow_to_archive_data</bpmn:incoming>
      <bpmn:outgoing>flow_to_end</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="end_integration_analytics" name="End Integration &amp; Analytics">
      <bpmn:incoming>flow_to_end</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="flow_to_sync_erp" sourceRef="start_integration_analytics" targetRef="sync_erp_data" />
    <bpmn:sequenceFlow id="flow_to_integrate_lab" sourceRef="sync_erp_data" targetRef="integrate_laboratory" />
    <bpmn:sequenceFlow id="flow_to_integrate_imaging" sourceRef="integrate_laboratory" targetRef="integrate_imaging" />
    <bpmn:sequenceFlow id="flow_to_aggregate_clinical" sourceRef="integrate_imaging" targetRef="aggregate_clinical_metrics" />
    <bpmn:sequenceFlow id="flow_to_calculate_operational" sourceRef="aggregate_clinical_metrics" targetRef="calculate_operational_metrics" />
    <bpmn:sequenceFlow id="flow_to_analyze_financial" sourceRef="calculate_operational_metrics" targetRef="analyze_financial_performance" />
    <bpmn:sequenceFlow id="flow_to_generate_dashboard" sourceRef="analyze_financial_performance" targetRef="generate_executive_dashboard" />
    <bpmn:sequenceFlow id="flow_to_detect_quality" sourceRef="generate_executive_dashboard" targetRef="detect_data_quality_issues" />
    <bpmn:sequenceFlow id="flow_to_reconcile_sources" sourceRef="detect_data_quality_issues" targetRef="reconcile_data_sources" />
    <bpmn:sequenceFlow id="flow_to_export_warehouse" sourceRef="reconcile_data_sources" targetRef="export_to_datawarehouse" />
    <bpmn:sequenceFlow id="flow_to_generate_reports" sourceRef="export_to_datawarehouse" targetRef="generate_regulatory_reports" />
    <bpmn:sequenceFlow id="flow_to_track_process" sourceRef="generate_regulatory_reports" targetRef="track_process_performance" />
    <bpmn:sequenceFlow id="flow_to_monitor_health" sourceRef="track_process_performance" targetRef="monitor_system_health" />
    <bpmn:sequenceFlow id="flow_to_alert_anomalies" sourceRef="monitor_system_health" targetRef="alert_on_anomalies" />
    <bpmn:sequenceFlow id="flow_to_archive_data" sourceRef="alert_on_anomalies" targetRef="archive_historical_data" />
    <bpmn:sequenceFlow id="flow_to_end" sourceRef="archive_historical_data" targetRef="end_integration_analytics" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="integration_analytics_process">
      <!-- Row 1: Start + 7 tasks -->
      <bpmndi:BPMNShape id="Shape_start" bpmnElement="start_integration_analytics">
        <dc:Bounds x="160" y="98" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="128" y="141" width="100" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_sync_erp" bpmnElement="sync_erp_data">
        <dc:Bounds x="260" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_integrate_lab" bpmnElement="integrate_laboratory">
        <dc:Bounds x="430" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_integrate_imaging" bpmnElement="integrate_imaging">
        <dc:Bounds x="600" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_aggregate_clinical" bpmnElement="aggregate_clinical_metrics">
        <dc:Bounds x="770" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_calculate_operational" bpmnElement="calculate_operational_metrics">
        <dc:Bounds x="940" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_analyze_financial" bpmnElement="analyze_financial_performance">
        <dc:Bounds x="1110" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_generate_dashboard" bpmnElement="generate_executive_dashboard">
        <dc:Bounds x="1280" y="78" width="100" height="80" />
      </bpmndi:BPMNShape>
      <!-- Row 2: 8 tasks + End -->
      <bpmndi:BPMNShape id="Shape_detect_quality" bpmnElement="detect_data_quality_issues">
        <dc:Bounds x="260" y="250" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_reconcile_sources" bpmnElement="reconcile_data_sources">
        <dc:Bounds x="430" y="250" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_export_warehouse" bpmnElement="export_to_datawarehouse">
        <dc:Bounds x="600" y="250" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_generate_reports" bpmnElement="generate_regulatory_reports">
        <dc:Bounds x="770" y="250" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_track_process" bpmnElement="track_process_performance">
        <dc:Bounds x="940" y="250" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_monitor_health" bpmnElement="monitor_system_health">
        <dc:Bounds x="1110" y="250" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_alert_anomalies" bpmnElement="alert_on_anomalies">
        <dc:Bounds x="1280" y="250" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_archive_data" bpmnElement="archive_historical_data">
        <dc:Bounds x="1450" y="250" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_end" bpmnElement="end_integration_analytics">
        <dc:Bounds x="1622" y="272" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1590" y="315" width="100" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <!-- Row 1 edges -->
      <bpmndi:BPMNEdge id="Edge_to_sync_erp" bpmnElement="flow_to_sync_erp">
        <di:waypoint x="196" y="116" />
        <di:waypoint x="260" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_to_integrate_lab" bpmnElement="flow_to_integrate_lab">
        <di:waypoint x="360" y="118" />
        <di:waypoint x="430" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_to_integrate_imaging" bpmnElement="flow_to_integrate_imaging">
        <di:waypoint x="530" y="118" />
        <di:waypoint x="600" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_to_aggregate_clinical" bpmnElement="flow_to_aggregate_clinical">
        <di:waypoint x="700" y="118" />
        <di:waypoint x="770" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_to_calculate_operational" bpmnElement="flow_to_calculate_operational">
        <di:waypoint x="870" y="118" />
        <di:waypoint x="940" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_to_analyze_financial" bpmnElement="flow_to_analyze_financial">
        <di:waypoint x="1040" y="118" />
        <di:waypoint x="1110" y="118" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_to_generate_dashboard" bpmnElement="flow_to_generate_dashboard">
        <di:waypoint x="1210" y="118" />
        <di:waypoint x="1280" y="118" />
      </bpmndi:BPMNEdge>
      <!-- Connecting edge Row 1 → Row 2 -->
      <bpmndi:BPMNEdge id="Edge_to_detect_quality" bpmnElement="flow_to_detect_quality">
        <di:waypoint x="1330" y="158" />
        <di:waypoint x="1330" y="200" />
        <di:waypoint x="310" y="200" />
        <di:waypoint x="310" y="250" />
      </bpmndi:BPMNEdge>
      <!-- Row 2 edges -->
      <bpmndi:BPMNEdge id="Edge_to_reconcile_sources" bpmnElement="flow_to_reconcile_sources">
        <di:waypoint x="360" y="290" />
        <di:waypoint x="430" y="290" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_to_export_warehouse" bpmnElement="flow_to_export_warehouse">
        <di:waypoint x="530" y="290" />
        <di:waypoint x="600" y="290" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_to_generate_reports" bpmnElement="flow_to_generate_reports">
        <di:waypoint x="700" y="290" />
        <di:waypoint x="770" y="290" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_to_track_process" bpmnElement="flow_to_track_process">
        <di:waypoint x="870" y="290" />
        <di:waypoint x="940" y="290" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_to_monitor_health" bpmnElement="flow_to_monitor_health">
        <di:waypoint x="1040" y="290" />
        <di:waypoint x="1110" y="290" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_to_alert_anomalies" bpmnElement="flow_to_alert_anomalies">
        <di:waypoint x="1210" y="290" />
        <di:waypoint x="1280" y="290" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_to_archive_data" bpmnElement="flow_to_archive_data">
        <di:waypoint x="1380" y="290" />
        <di:waypoint x="1450" y="290" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_to_end" bpmnElement="flow_to_end">
        <di:waypoint x="1550" y="290" />
        <di:waypoint x="1622" y="290" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
