<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_Credentialing"
                  targetNamespace="http://cib7.health/platform/credentialing"
                  exporter="Claude Code"
                  exporterVersion="1.0">

  <bpmn:process id="Process_Credentialing" name="SP-PS-002 Provider Credentialing" isExecutable="true" camunda:historyTimeToLive="30">

    <!-- Start: Credentialing request received for a provider -->
    <bpmn:startEvent id="Start_CredentialRequest" name="Credentialing Request Received">
      <bpmn:outgoing>Flow_ToVerifyLicense</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Step 1: Verify provider's professional license -->
    <bpmn:serviceTask id="Task_VerifyLicense" name="Verify Professional License"
                      camunda:type="external" camunda:topic="credentialing.license">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="dmnTable">cred_license_001</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToVerifyLicense</bpmn:incoming>
      <bpmn:outgoing>Flow_ToCheckFacility</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Timer boundary: credential verification timeout (30 days) -->
    <bpmn:boundaryEvent id="Boundary_LicenseTimeout" name="Verification Timeout"
                        attachedToRef="Task_VerifyLicense" cancelActivity="true">
      <bpmn:outgoing>Flow_TimeoutToEnd</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_License">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P30D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>

    <!-- Step 2: Check facility privileges -->
    <bpmn:serviceTask id="Task_CheckFacility" name="Check Facility Privileges"
                      camunda:type="external" camunda:topic="credentialing.facility">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="dmnTable">cred_facility_001</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToCheckFacility</bpmn:incoming>
      <bpmn:outgoing>Flow_ToValidateProvider</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Step 3: Validate provider qualifications -->
    <bpmn:serviceTask id="Task_ValidateProvider" name="Validate Provider Qualifications"
                      camunda:type="external" camunda:topic="credentialing.provider">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="dmnTable">cred_provider_001</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToValidateProvider</bpmn:incoming>
      <bpmn:outgoing>Flow_ToApprovalGateway</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Gateway: Approval decision -->
    <bpmn:exclusiveGateway id="Gateway_Approval" name="Approved?" default="Flow_Rejected">
      <bpmn:incoming>Flow_ToApprovalGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Approved</bpmn:outgoing>
      <bpmn:outgoing>Flow_Rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Approved path: activate credentials -->
    <bpmn:serviceTask id="Task_ActivateCredentials" name="Activate Provider Credentials"
                      camunda:type="external" camunda:topic="credentialing.activation">
      <bpmn:incoming>Flow_Approved</bpmn:incoming>
      <bpmn:outgoing>Flow_ActivateToEnd</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Rejected path: send rejection notice -->
    <bpmn:serviceTask id="Task_SendRejection" name="Send Rejection Notice"
                      camunda:type="external" camunda:topic="credentialing.notification">
      <bpmn:incoming>Flow_Rejected</bpmn:incoming>
      <bpmn:outgoing>Flow_RejectToEnd</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Timeout path: expire pending request -->
    <bpmn:serviceTask id="Task_ExpireRequest" name="Expire Pending Request"
                      camunda:type="external" camunda:topic="credentialing.expiration">
      <bpmn:incoming>Flow_TimeoutToEnd</bpmn:incoming>
      <bpmn:outgoing>Flow_ExpireToEnd</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Merge before end -->
    <bpmn:exclusiveGateway id="Gateway_MergeEnd" name="Merge">
      <bpmn:incoming>Flow_ActivateToEnd</bpmn:incoming>
      <bpmn:incoming>Flow_RejectToEnd</bpmn:incoming>
      <bpmn:incoming>Flow_ExpireToEnd</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEnd</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="End_CredentialComplete" name="Credentialing Complete">
      <bpmn:incoming>Flow_ToEnd</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="Flow_ToVerifyLicense" sourceRef="Start_CredentialRequest" targetRef="Task_VerifyLicense"/>
    <bpmn:sequenceFlow id="Flow_ToCheckFacility" sourceRef="Task_VerifyLicense" targetRef="Task_CheckFacility"/>
    <bpmn:sequenceFlow id="Flow_ToValidateProvider" sourceRef="Task_CheckFacility" targetRef="Task_ValidateProvider"/>
    <bpmn:sequenceFlow id="Flow_ToApprovalGateway" sourceRef="Task_ValidateProvider" targetRef="Gateway_Approval"/>
    <bpmn:sequenceFlow id="Flow_Approved" sourceRef="Gateway_Approval" targetRef="Task_ActivateCredentials">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${credential_approved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Rejected" sourceRef="Gateway_Approval" targetRef="Task_SendRejection">
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ActivateToEnd" sourceRef="Task_ActivateCredentials" targetRef="Gateway_MergeEnd"/>
    <bpmn:sequenceFlow id="Flow_RejectToEnd" sourceRef="Task_SendRejection" targetRef="Gateway_MergeEnd"/>
    <bpmn:sequenceFlow id="Flow_TimeoutToEnd" sourceRef="Boundary_LicenseTimeout" targetRef="Task_ExpireRequest"/>
    <bpmn:sequenceFlow id="Flow_ExpireToEnd" sourceRef="Task_ExpireRequest" targetRef="Gateway_MergeEnd"/>
    <bpmn:sequenceFlow id="Flow_ToEnd" sourceRef="Gateway_MergeEnd" targetRef="End_CredentialComplete"/>

  </bpmn:process>

  <!-- Diagram Interchange -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_Credentialing">
    <bpmndi:BPMNPlane id="BPMNPlane_Credentialing" bpmnElement="Process_Credentialing">

      <bpmndi:BPMNShape id="Shape_Start" bpmnElement="Start_CredentialRequest">
        <dc:Bounds x="152" y="202" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_VerifyLicense" bpmnElement="Task_VerifyLicense">
        <dc:Bounds x="240" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_BoundaryTimeout" bpmnElement="Boundary_LicenseTimeout">
        <dc:Bounds x="272" y="242" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_CheckFacility" bpmnElement="Task_CheckFacility">
        <dc:Bounds x="400" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_ValidateProvider" bpmnElement="Task_ValidateProvider">
        <dc:Bounds x="560" y="180" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_GatewayApproval" bpmnElement="Gateway_Approval" isMarkerVisible="true">
        <dc:Bounds x="715" y="195" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Activate" bpmnElement="Task_ActivateCredentials">
        <dc:Bounds x="820" y="100" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Rejection" bpmnElement="Task_SendRejection">
        <dc:Bounds x="820" y="260" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_ExpireRequest" bpmnElement="Task_ExpireRequest">
        <dc:Bounds x="400" y="340" width="100" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_MergeEnd" bpmnElement="Gateway_MergeEnd" isMarkerVisible="true">
        <dc:Bounds x="985" y="195" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_End" bpmnElement="End_CredentialComplete">
        <dc:Bounds x="1092" y="202" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Edge_ToVerifyLicense" bpmnElement="Flow_ToVerifyLicense">
        <di:waypoint x="188" y="220"/>
        <di:waypoint x="240" y="220"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_ToCheckFacility" bpmnElement="Flow_ToCheckFacility">
        <di:waypoint x="340" y="220"/>
        <di:waypoint x="400" y="220"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_ToValidateProvider" bpmnElement="Flow_ToValidateProvider">
        <di:waypoint x="500" y="220"/>
        <di:waypoint x="560" y="220"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_ToApprovalGateway" bpmnElement="Flow_ToApprovalGateway">
        <di:waypoint x="660" y="220"/>
        <di:waypoint x="715" y="220"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Approved" bpmnElement="Flow_Approved">
        <di:waypoint x="740" y="195"/>
        <di:waypoint x="740" y="140"/>
        <di:waypoint x="820" y="140"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Rejected" bpmnElement="Flow_Rejected">
        <di:waypoint x="740" y="245"/>
        <di:waypoint x="740" y="300"/>
        <di:waypoint x="820" y="300"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_ActivateToEnd" bpmnElement="Flow_ActivateToEnd">
        <di:waypoint x="920" y="140"/>
        <di:waypoint x="1010" y="140"/>
        <di:waypoint x="1010" y="195"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_RejectToEnd" bpmnElement="Flow_RejectToEnd">
        <di:waypoint x="920" y="300"/>
        <di:waypoint x="1010" y="300"/>
        <di:waypoint x="1010" y="245"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_TimeoutToEnd" bpmnElement="Flow_TimeoutToEnd">
        <di:waypoint x="290" y="278"/>
        <di:waypoint x="290" y="380"/>
        <di:waypoint x="400" y="380"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_ExpireToEnd" bpmnElement="Flow_ExpireToEnd">
        <di:waypoint x="500" y="380"/>
        <di:waypoint x="1010" y="380"/>
        <di:waypoint x="1010" y="245"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_ToEnd" bpmnElement="Flow_ToEnd">
        <di:waypoint x="1035" y="220"/>
        <di:waypoint x="1092" y="220"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
