<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="definitions_surg_coord_005"
             name="OR Turnover Optimization"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="surg_coord_005" name="[SP-CO-007 | surgical_services/surgical_coordination] OR Turnover Optimization" camunda:historyTimeToLive="180">
    <decisionTable id="dt_surg_coord_005" hitPolicy="FIRST">
      <input id="input_1_surg_coord_005" label="Previous Case Complexity">
        <inputExpression id="inputExpr_1_surg_coord_005" typeRef="string">
          <text>previousCaseComplexity</text>
        </inputExpression>
      </input>
      <input id="input_2_surg_coord_005" label="Cleaning Level">
        <inputExpression id="inputExpr_2_surg_coord_005" typeRef="string">
          <text>cleaningLevel</text>
        </inputExpression>
      </input>
      <input id="input_3_surg_coord_005" label="Next Case Setup Needs">
        <inputExpression id="inputExpr_3_surg_coord_005" typeRef="string">
          <text>nextCaseSetupNeeds</text>
        </inputExpression>
      </input>
      <input id="input_4_surg_coord_005" label="Turnaround Time Minutes">
        <inputExpression id="inputExpr_4_surg_coord_005" typeRef="number">
          <text>turnaroundTimeMinutes</text>
        </inputExpression>
      </input>
      <output id="output_resultado_surg_coord_005" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao_surg_coord_005" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco_surg_coord_005" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1_surg_coord_005">
        <inputEntry id="ie_1_1_surg_coord_005"><text>"simple"</text></inputEntry>
        <inputEntry id="ie_1_2_surg_coord_005"><text>"standard"</text></inputEntry>
        <inputEntry id="ie_1_3_surg_coord_005"><text>"minimal"</text></inputEntry>
        <inputEntry id="ie_1_4_surg_coord_005"><text>&lt;= 30</text></inputEntry>
        <outputEntry id="oe_1_resultado_surg_coord_005"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao_surg_coord_005"><text>"Optimal turnover time - standard cleaning and setup completed within target"</text></outputEntry>
        <outputEntry id="oe_1_risco_surg_coord_005"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2_surg_coord_005">
        <inputEntry id="ie_2_1_surg_coord_005"><text>"complex"</text></inputEntry>
        <inputEntry id="ie_2_2_surg_coord_005"><text>"enhanced"</text></inputEntry>
        <inputEntry id="ie_2_3_surg_coord_005"><text>"extensive"</text></inputEntry>
        <inputEntry id="ie_2_4_surg_coord_005"><text>&lt;= 60</text></inputEntry>
        <outputEntry id="oe_2_resultado_surg_coord_005"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_2_acao_surg_coord_005"><text>"Complex case turnover - enhanced cleaning and extensive setup within acceptable time"</text></outputEntry>
        <outputEntry id="oe_2_risco_surg_coord_005"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_3_surg_coord_005">
        <inputEntry id="ie_3_1_surg_coord_005"><text>-</text></inputEntry>
        <inputEntry id="ie_3_2_surg_coord_005"><text>"terminal"</text></inputEntry>
        <inputEntry id="ie_3_3_surg_coord_005"><text>-</text></inputEntry>
        <inputEntry id="ie_3_4_surg_coord_005"><text>&lt;= 90</text></inputEntry>
        <outputEntry id="oe_3_resultado_surg_coord_005"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_3_acao_surg_coord_005"><text>"Terminal cleaning required - extended turnover time acceptable for infection control"</text></outputEntry>
        <outputEntry id="oe_3_risco_surg_coord_005"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_4_surg_coord_005">
        <inputEntry id="ie_4_1_surg_coord_005"><text>"simple"</text></inputEntry>
        <inputEntry id="ie_4_2_surg_coord_005"><text>"standard"</text></inputEntry>
        <inputEntry id="ie_4_3_surg_coord_005"><text>"minimal"</text></inputEntry>
        <inputEntry id="ie_4_4_surg_coord_005"><text>&gt; 45</text></inputEntry>
        <outputEntry id="oe_4_resultado_surg_coord_005"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_4_acao_surg_coord_005"><text>"Excessive turnover time - review workflow inefficiencies, staff training needed"</text></outputEntry>
        <outputEntry id="oe_4_risco_surg_coord_005"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_5_surg_coord_005">
        <inputEntry id="ie_5_1_surg_coord_005"><text>-</text></inputEntry>
        <inputEntry id="ie_5_2_surg_coord_005"><text>-</text></inputEntry>
        <inputEntry id="ie_5_3_surg_coord_005"><text>"specialty_equipment"</text></inputEntry>
        <inputEntry id="ie_5_4_surg_coord_005"><text>&lt;= 75</text></inputEntry>
        <outputEntry id="oe_5_resultado_surg_coord_005"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_5_acao_surg_coord_005"><text>"Specialty equipment setup - extended turnover justified for complex equipment preparation"</text></outputEntry>
        <outputEntry id="oe_5_risco_surg_coord_005"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_surg_coord_005">
      <dmndi:DMNShape id="DMNShape_surg_coord_005" dmnElementRef="surg_coord_005">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
