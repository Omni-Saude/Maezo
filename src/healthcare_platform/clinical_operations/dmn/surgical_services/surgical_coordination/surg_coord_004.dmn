<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="definitions_surg_coord_004"
             name="Discharge Criteria Assessment"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="surg_coord_004" name="[SP-CO-007 | surgical_services/surgical_coordination] Discharge Criteria Assessment" camunda:historyTimeToLive="180">
    <decisionTable id="dt_surg_coord_004" hitPolicy="FIRST">
      <input id="input_1_surg_coord_004" label="Mobility Restored">
        <inputExpression id="inputExpr_1_surg_coord_004" typeRef="boolean">
          <text>mobilityRestored</text>
        </inputExpression>
      </input>
      <input id="input_2_surg_coord_004" label="Pain Managed">
        <inputExpression id="inputExpr_2_surg_coord_004" typeRef="boolean">
          <text>painManaged</text>
        </inputExpression>
      </input>
      <input id="input_3_surg_coord_004" label="Wound Clean">
        <inputExpression id="inputExpr_3_surg_coord_004" typeRef="boolean">
          <text>woundClean</text>
        </inputExpression>
      </input>
      <input id="input_4_surg_coord_004" label="Instructions Given">
        <inputExpression id="inputExpr_4_surg_coord_004" typeRef="boolean">
          <text>instructionsGiven</text>
        </inputExpression>
      </input>
      <input id="input_5_surg_coord_004" label="Follow Up Scheduled">
        <inputExpression id="inputExpr_5_surg_coord_004" typeRef="boolean">
          <text>followUpScheduled</text>
        </inputExpression>
      </input>
      <output id="output_resultado_surg_coord_004" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao_surg_coord_004" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco_surg_coord_004" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1_surg_coord_004">
        <inputEntry id="ie_1_1_surg_coord_004"><text>true</text></inputEntry>
        <inputEntry id="ie_1_2_surg_coord_004"><text>true</text></inputEntry>
        <inputEntry id="ie_1_3_surg_coord_004"><text>true</text></inputEntry>
        <inputEntry id="ie_1_4_surg_coord_004"><text>true</text></inputEntry>
        <inputEntry id="ie_1_5_surg_coord_004"><text>true</text></inputEntry>
        <outputEntry id="oe_1_resultado_surg_coord_004"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao_surg_coord_004"><text>"All discharge criteria met - patient ready for home discharge, prescriptions provided"</text></outputEntry>
        <outputEntry id="oe_1_risco_surg_coord_004"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2_surg_coord_004">
        <inputEntry id="ie_2_1_surg_coord_004"><text>false</text></inputEntry>
        <inputEntry id="ie_2_2_surg_coord_004"><text>-</text></inputEntry>
        <inputEntry id="ie_2_3_surg_coord_004"><text>-</text></inputEntry>
        <inputEntry id="ie_2_4_surg_coord_004"><text>-</text></inputEntry>
        <inputEntry id="ie_2_5_surg_coord_004"><text>-</text></inputEntry>
        <outputEntry id="oe_2_resultado_surg_coord_004"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_2_acao_surg_coord_004"><text>"Mobility not restored - PT assessment required, consider extended stay or rehab facility"</text></outputEntry>
        <outputEntry id="oe_2_risco_surg_coord_004"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_3_surg_coord_004">
        <inputEntry id="ie_3_1_surg_coord_004"><text>-</text></inputEntry>
        <inputEntry id="ie_3_2_surg_coord_004"><text>false</text></inputEntry>
        <inputEntry id="ie_3_3_surg_coord_004"><text>-</text></inputEntry>
        <inputEntry id="ie_3_4_surg_coord_004"><text>-</text></inputEntry>
        <inputEntry id="ie_3_5_surg_coord_004"><text>-</text></inputEntry>
        <outputEntry id="oe_3_resultado_surg_coord_004"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_3_acao_surg_coord_004"><text>"Pain not controlled - optimize pain regimen, pain service consult, delay discharge"</text></outputEntry>
        <outputEntry id="oe_3_risco_surg_coord_004"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_4_surg_coord_004">
        <inputEntry id="ie_4_1_surg_coord_004"><text>-</text></inputEntry>
        <inputEntry id="ie_4_2_surg_coord_004"><text>-</text></inputEntry>
        <inputEntry id="ie_4_3_surg_coord_004"><text>false</text></inputEntry>
        <inputEntry id="ie_4_4_surg_coord_004"><text>-</text></inputEntry>
        <inputEntry id="ie_4_5_surg_coord_004"><text>-</text></inputEntry>
        <outputEntry id="oe_4_resultado_surg_coord_004"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_4_acao_surg_coord_004"><text>"CRITICAL: Wound issues - surgical team evaluation, possible infection, delay discharge"</text></outputEntry>
        <outputEntry id="oe_4_risco_surg_coord_004"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_5_surg_coord_004">
        <inputEntry id="ie_5_1_surg_coord_004"><text>true</text></inputEntry>
        <inputEntry id="ie_5_2_surg_coord_004"><text>true</text></inputEntry>
        <inputEntry id="ie_5_3_surg_coord_004"><text>true</text></inputEntry>
        <inputEntry id="ie_5_4_surg_coord_004"><text>-</text></inputEntry>
        <inputEntry id="ie_5_5_surg_coord_004"><text>false</text></inputEntry>
        <outputEntry id="oe_5_resultado_surg_coord_004"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_5_acao_surg_coord_004"><text>"No follow-up scheduled - schedule clinic appointment before discharge, cannot release without"</text></outputEntry>
        <outputEntry id="oe_5_risco_surg_coord_004"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_surg_coord_004">
      <dmndi:DMNShape id="DMNShape_surg_coord_004" dmnElementRef="surg_coord_004">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
