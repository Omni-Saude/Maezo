<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="definitions_surg_coord_007"
             name="Count Verification Rules"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="surg_coord_007" name="[SP-CO-007 | surgical_services/surgical_coordination] Count Verification Rules" camunda:historyTimeToLive="180">
    <decisionTable id="dt_surg_coord_007" hitPolicy="FIRST">
      <input id="input_1_surg_coord_007" label="Instrument Count Pre">
        <inputExpression id="inputExpr_1_surg_coord_007" typeRef="number">
          <text>instrumentCountPre</text>
        </inputExpression>
      </input>
      <input id="input_2_surg_coord_007" label="Instrument Count Post">
        <inputExpression id="inputExpr_2_surg_coord_007" typeRef="number">
          <text>instrumentCountPost</text>
        </inputExpression>
      </input>
      <input id="input_3_surg_coord_007" label="Sponge Count Pre">
        <inputExpression id="inputExpr_3_surg_coord_007" typeRef="number">
          <text>spongeCountPre</text>
        </inputExpression>
      </input>
      <input id="input_4_surg_coord_007" label="Sponge Count Post">
        <inputExpression id="inputExpr_4_surg_coord_007" typeRef="number">
          <text>spongeCountPost</text>
        </inputExpression>
      </input>
      <input id="input_5_surg_coord_007" label="Needle Count Match">
        <inputExpression id="inputExpr_5_surg_coord_007" typeRef="boolean">
          <text>needleCountMatch</text>
        </inputExpression>
      </input>
      <output id="output_resultado_surg_coord_007" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao_surg_coord_007" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco_surg_coord_007" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1_surg_coord_007">
        <inputEntry id="ie_1_1_surg_coord_007"><text>instrumentCountPre</text></inputEntry>
        <inputEntry id="ie_1_2_surg_coord_007"><text>instrumentCountPost</text></inputEntry>
        <inputEntry id="ie_1_3_surg_coord_007"><text>spongeCountPre</text></inputEntry>
        <inputEntry id="ie_1_4_surg_coord_007"><text>spongeCountPost</text></inputEntry>
        <inputEntry id="ie_1_5_surg_coord_007"><text>true</text></inputEntry>
        <outputEntry id="oe_1_resultado_surg_coord_007"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao_surg_coord_007"><text>"All counts correct - instruments, sponges, and needles match, proceed with closure"</text></outputEntry>
        <outputEntry id="oe_1_risco_surg_coord_007"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2_surg_coord_007">
        <inputEntry id="ie_2_1_surg_coord_007"><text>not(instrumentCountPre = instrumentCountPost)</text></inputEntry>
        <inputEntry id="ie_2_2_surg_coord_007"><text>-</text></inputEntry>
        <inputEntry id="ie_2_3_surg_coord_007"><text>-</text></inputEntry>
        <inputEntry id="ie_2_4_surg_coord_007"><text>-</text></inputEntry>
        <inputEntry id="ie_2_5_surg_coord_007"><text>-</text></inputEntry>
        <outputEntry id="oe_2_resultado_surg_coord_007"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_2_acao_surg_coord_007"><text>"CRITICAL: Instrument count incorrect - search surgical field, recount, X-ray if needed"</text></outputEntry>
        <outputEntry id="oe_2_risco_surg_coord_007"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_3_surg_coord_007">
        <inputEntry id="ie_3_1_surg_coord_007"><text>-</text></inputEntry>
        <inputEntry id="ie_3_2_surg_coord_007"><text>-</text></inputEntry>
        <inputEntry id="ie_3_3_surg_coord_007"><text>not(spongeCountPre = spongeCountPost)</text></inputEntry>
        <inputEntry id="ie_3_4_surg_coord_007"><text>-</text></inputEntry>
        <inputEntry id="ie_3_5_surg_coord_007"><text>-</text></inputEntry>
        <outputEntry id="oe_3_resultado_surg_coord_007"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_3_acao_surg_coord_007"><text>"CRITICAL: Sponge count incorrect - search field thoroughly, obtain X-ray before closure"</text></outputEntry>
        <outputEntry id="oe_3_risco_surg_coord_007"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_4_surg_coord_007">
        <inputEntry id="ie_4_1_surg_coord_007"><text>-</text></inputEntry>
        <inputEntry id="ie_4_2_surg_coord_007"><text>-</text></inputEntry>
        <inputEntry id="ie_4_3_surg_coord_007"><text>-</text></inputEntry>
        <inputEntry id="ie_4_4_surg_coord_007"><text>-</text></inputEntry>
        <inputEntry id="ie_4_5_surg_coord_007"><text>false</text></inputEntry>
        <outputEntry id="oe_4_resultado_surg_coord_007"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_4_acao_surg_coord_007"><text>"CRITICAL: Needle count incorrect - search drapes and field, account for all needles before closure"</text></outputEntry>
        <outputEntry id="oe_4_risco_surg_coord_007"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_5_surg_coord_007">
        <inputEntry id="ie_5_1_surg_coord_007"><text>instrumentCountPre</text></inputEntry>
        <inputEntry id="ie_5_2_surg_coord_007"><text>instrumentCountPost</text></inputEntry>
        <inputEntry id="ie_5_3_surg_coord_007"><text>spongeCountPre</text></inputEntry>
        <inputEntry id="ie_5_4_surg_coord_007"><text>spongeCountPost</text></inputEntry>
        <inputEntry id="ie_5_5_surg_coord_007"><text>true</text></inputEntry>
        <outputEntry id="oe_5_resultado_surg_coord_007"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_5_acao_surg_coord_007"><text>"Final count verification complete - document correct counts in operative record"</text></outputEntry>
        <outputEntry id="oe_5_risco_surg_coord_007"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_surg_coord_007">
      <dmndi:DMNShape id="DMNShape_surg_coord_007" dmnElementRef="surg_coord_007">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
