<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="definitions_surg_safety_003"
             name="WHO Sign-Out Checklist"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="surg_safety_003" name="[SP-CO-007 | surgical_services/surgical_safety] WHO Sign-Out Checklist" camunda:historyTimeToLive="180">
    <decisionTable id="dt_surg_safety_003" hitPolicy="FIRST">
      <input id="input_1_surg_safety_003" label="Instrument Count Correct">
        <inputExpression id="inputExpr_1_surg_safety_003" typeRef="boolean">
          <text>instrumentCountCorrect</text>
        </inputExpression>
      </input>
      <input id="input_2_surg_safety_003" label="Specimen Labeled">
        <inputExpression id="inputExpr_2_surg_safety_003" typeRef="boolean">
          <text>specimenLabeled</text>
        </inputExpression>
      </input>
      <input id="input_3_surg_safety_003" label="Equipment Issues Documented">
        <inputExpression id="inputExpr_3_surg_safety_003" typeRef="boolean">
          <text>equipmentIssuesDocumented</text>
        </inputExpression>
      </input>
      <input id="input_4_surg_safety_003" label="Recovery Plan Communicated">
        <inputExpression id="inputExpr_4_surg_safety_003" typeRef="boolean">
          <text>recoveryPlanCommunicated</text>
        </inputExpression>
      </input>
      <output id="output_resultado_surg_safety_003" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao_surg_safety_003" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco_surg_safety_003" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1_surg_safety_003">
        <inputEntry id="ie_1_1_surg_safety_003"><text>true</text></inputEntry>
        <inputEntry id="ie_1_2_surg_safety_003"><text>true</text></inputEntry>
        <inputEntry id="ie_1_3_surg_safety_003"><text>true</text></inputEntry>
        <inputEntry id="ie_1_4_surg_safety_003"><text>true</text></inputEntry>
        <outputEntry id="oe_1_resultado_surg_safety_003"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao_surg_safety_003"><text>"Sign-out complete - patient ready for recovery room transfer"</text></outputEntry>
        <outputEntry id="oe_1_risco_surg_safety_003"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2_surg_safety_003">
        <inputEntry id="ie_2_1_surg_safety_003"><text>false</text></inputEntry>
        <inputEntry id="ie_2_2_surg_safety_003"><text>-</text></inputEntry>
        <inputEntry id="ie_2_3_surg_safety_003"><text>-</text></inputEntry>
        <inputEntry id="ie_2_4_surg_safety_003"><text>-</text></inputEntry>
        <outputEntry id="oe_2_resultado_surg_safety_003"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_2_acao_surg_safety_003"><text>"CRITICAL: Instrument/sponge count incorrect - perform X-ray and recount before closure"</text></outputEntry>
        <outputEntry id="oe_2_risco_surg_safety_003"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_3_surg_safety_003">
        <inputEntry id="ie_3_1_surg_safety_003"><text>true</text></inputEntry>
        <inputEntry id="ie_3_2_surg_safety_003"><text>false</text></inputEntry>
        <inputEntry id="ie_3_3_surg_safety_003"><text>-</text></inputEntry>
        <inputEntry id="ie_3_4_surg_safety_003"><text>-</text></inputEntry>
        <outputEntry id="oe_3_resultado_surg_safety_003"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_3_acao_surg_safety_003"><text>"Specimen not labeled - circulating nurse must label specimen immediately"</text></outputEntry>
        <outputEntry id="oe_3_risco_surg_safety_003"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_4_surg_safety_003">
        <inputEntry id="ie_4_1_surg_safety_003"><text>true</text></inputEntry>
        <inputEntry id="ie_4_2_surg_safety_003"><text>true</text></inputEntry>
        <inputEntry id="ie_4_3_surg_safety_003"><text>false</text></inputEntry>
        <inputEntry id="ie_4_4_surg_safety_003"><text>-</text></inputEntry>
        <outputEntry id="oe_4_resultado_surg_safety_003"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_4_acao_surg_safety_003"><text>"Equipment issues not documented - document any equipment malfunctions for quality tracking"</text></outputEntry>
        <outputEntry id="oe_4_risco_surg_safety_003"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_5_surg_safety_003">
        <inputEntry id="ie_5_1_surg_safety_003"><text>true</text></inputEntry>
        <inputEntry id="ie_5_2_surg_safety_003"><text>true</text></inputEntry>
        <inputEntry id="ie_5_3_surg_safety_003"><text>true</text></inputEntry>
        <inputEntry id="ie_5_4_surg_safety_003"><text>false</text></inputEntry>
        <outputEntry id="oe_5_resultado_surg_safety_003"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_5_acao_surg_safety_003"><text>"Recovery plan not communicated - surgeon must communicate key concerns to PACU team"</text></outputEntry>
        <outputEntry id="oe_5_risco_surg_safety_003"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_surg_safety_003">
      <dmndi:DMNShape id="DMNShape_surg_safety_003" dmnElementRef="surg_safety_003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
