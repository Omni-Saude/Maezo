<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="definitions_surg_safety_001"
             name="WHO Sign-In Checklist Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="surg_safety_001" name="[SP-CO-007 | surgical_services/surgical_safety] WHO Sign-In Checklist Validation" camunda:historyTimeToLive="180">
    <decisionTable id="dt_surg_safety_001" hitPolicy="FIRST">
      <input id="input_1_surg_safety_001" label="Patient Identity Confirmed">
        <inputExpression id="inputExpr_1_surg_safety_001" typeRef="boolean">
          <text>patientIdentityConfirmed</text>
        </inputExpression>
      </input>
      <input id="input_2_surg_safety_001" label="Site Marked">
        <inputExpression id="inputExpr_2_surg_safety_001" typeRef="boolean">
          <text>siteMarked</text>
        </inputExpression>
      </input>
      <input id="input_3_surg_safety_001" label="Anesthesia Check Complete">
        <inputExpression id="inputExpr_3_surg_safety_001" typeRef="boolean">
          <text>anesthesiaCheckComplete</text>
        </inputExpression>
      </input>
      <input id="input_4_surg_safety_001" label="Pulse Oximeter Functioning">
        <inputExpression id="inputExpr_4_surg_safety_001" typeRef="boolean">
          <text>pulseOximeterFunctioning</text>
        </inputExpression>
      </input>
      <output id="output_resultado_surg_safety_001" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao_surg_safety_001" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco_surg_safety_001" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1_surg_safety_001">
        <inputEntry id="ie_1_1_surg_safety_001"><text>true</text></inputEntry>
        <inputEntry id="ie_1_2_surg_safety_001"><text>true</text></inputEntry>
        <inputEntry id="ie_1_3_surg_safety_001"><text>true</text></inputEntry>
        <inputEntry id="ie_1_4_surg_safety_001"><text>true</text></inputEntry>
        <outputEntry id="oe_1_resultado_surg_safety_001"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao_surg_safety_001"><text>"All WHO sign-in criteria met - proceed to anesthesia induction"</text></outputEntry>
        <outputEntry id="oe_1_risco_surg_safety_001"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2_surg_safety_001">
        <inputEntry id="ie_2_1_surg_safety_001"><text>false</text></inputEntry>
        <inputEntry id="ie_2_2_surg_safety_001"><text>-</text></inputEntry>
        <inputEntry id="ie_2_3_surg_safety_001"><text>-</text></inputEntry>
        <inputEntry id="ie_2_4_surg_safety_001"><text>-</text></inputEntry>
        <outputEntry id="oe_2_resultado_surg_safety_001"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_2_acao_surg_safety_001"><text>"CRITICAL: Patient identity not confirmed - stop procedure immediately"</text></outputEntry>
        <outputEntry id="oe_2_risco_surg_safety_001"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_3_surg_safety_001">
        <inputEntry id="ie_3_1_surg_safety_001"><text>true</text></inputEntry>
        <inputEntry id="ie_3_2_surg_safety_001"><text>false</text></inputEntry>
        <inputEntry id="ie_3_3_surg_safety_001"><text>-</text></inputEntry>
        <inputEntry id="ie_3_4_surg_safety_001"><text>-</text></inputEntry>
        <outputEntry id="oe_3_resultado_surg_safety_001"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_3_acao_surg_safety_001"><text>"Surgical site not marked - surgeon must mark site before proceeding"</text></outputEntry>
        <outputEntry id="oe_3_risco_surg_safety_001"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_4_surg_safety_001">
        <inputEntry id="ie_4_1_surg_safety_001"><text>true</text></inputEntry>
        <inputEntry id="ie_4_2_surg_safety_001"><text>true</text></inputEntry>
        <inputEntry id="ie_4_3_surg_safety_001"><text>false</text></inputEntry>
        <inputEntry id="ie_4_4_surg_safety_001"><text>-</text></inputEntry>
        <outputEntry id="oe_4_resultado_surg_safety_001"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_4_acao_surg_safety_001"><text>"Anesthesia safety check incomplete - anesthesiologist must complete checklist"</text></outputEntry>
        <outputEntry id="oe_4_risco_surg_safety_001"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_5_surg_safety_001">
        <inputEntry id="ie_5_1_surg_safety_001"><text>true</text></inputEntry>
        <inputEntry id="ie_5_2_surg_safety_001"><text>true</text></inputEntry>
        <inputEntry id="ie_5_3_surg_safety_001"><text>true</text></inputEntry>
        <inputEntry id="ie_5_4_surg_safety_001"><text>false</text></inputEntry>
        <outputEntry id="oe_5_resultado_surg_safety_001"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_5_acao_surg_safety_001"><text>"Pulse oximeter not functioning - replace equipment before anesthesia induction"</text></outputEntry>
        <outputEntry id="oe_5_risco_surg_safety_001"><text>"CRITICO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_surg_safety_001">
      <dmndi:DMNShape id="DMNShape_surg_safety_001" dmnElementRef="surg_safety_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
