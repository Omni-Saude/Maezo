<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="definitions_surg_safety_012"
             name="Surgical Timeout Rules"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="surg_safety_012" name="[SP-CO-007 | surgical_services/surgical_safety] Surgical Timeout Rules" camunda:historyTimeToLive="180">
    <decisionTable id="dt_surg_safety_012" hitPolicy="FIRST">
      <input id="input_1_surg_safety_012" label="All Team Present">
        <inputExpression id="inputExpr_1_surg_safety_012" typeRef="boolean">
          <text>allTeamPresent</text>
        </inputExpression>
      </input>
      <input id="input_2_surg_safety_012" label="Patient Confirmed">
        <inputExpression id="inputExpr_2_surg_safety_012" typeRef="boolean">
          <text>patientConfirmed</text>
        </inputExpression>
      </input>
      <input id="input_3_surg_safety_012" label="Procedure Confirmed">
        <inputExpression id="inputExpr_3_surg_safety_012" typeRef="boolean">
          <text>procedureConfirmed</text>
        </inputExpression>
      </input>
      <input id="input_4_surg_safety_012" label="Equipment Ready">
        <inputExpression id="inputExpr_4_surg_safety_012" typeRef="boolean">
          <text>equipmentReady</text>
        </inputExpression>
      </input>
      <input id="input_5_surg_safety_012" label="Timeout Documented">
        <inputExpression id="inputExpr_5_surg_safety_012" typeRef="boolean">
          <text>timeoutDocumented</text>
        </inputExpression>
      </input>
      <output id="output_resultado_surg_safety_012" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao_surg_safety_012" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco_surg_safety_012" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1_surg_safety_012">
        <inputEntry id="ie_1_1_surg_safety_012"><text>true</text></inputEntry>
        <inputEntry id="ie_1_2_surg_safety_012"><text>true</text></inputEntry>
        <inputEntry id="ie_1_3_surg_safety_012"><text>true</text></inputEntry>
        <inputEntry id="ie_1_4_surg_safety_012"><text>true</text></inputEntry>
        <inputEntry id="ie_1_5_surg_safety_012"><text>true</text></inputEntry>
        <outputEntry id="oe_1_resultado_surg_safety_012"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao_surg_safety_012"><text>"Surgical timeout complete and documented - all safety criteria met, proceed with incision"</text></outputEntry>
        <outputEntry id="oe_1_risco_surg_safety_012"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2_surg_safety_012">
        <inputEntry id="ie_2_1_surg_safety_012"><text>false</text></inputEntry>
        <inputEntry id="ie_2_2_surg_safety_012"><text>-</text></inputEntry>
        <inputEntry id="ie_2_3_surg_safety_012"><text>-</text></inputEntry>
        <inputEntry id="ie_2_4_surg_safety_012"><text>-</text></inputEntry>
        <inputEntry id="ie_2_5_surg_safety_012"><text>-</text></inputEntry>
        <outputEntry id="oe_2_resultado_surg_safety_012"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_2_acao_surg_safety_012"><text>"CRITICAL: Not all team members present - wait for all required team members before timeout"</text></outputEntry>
        <outputEntry id="oe_2_risco_surg_safety_012"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_3_surg_safety_012">
        <inputEntry id="ie_3_1_surg_safety_012"><text>true</text></inputEntry>
        <inputEntry id="ie_3_2_surg_safety_012"><text>false</text></inputEntry>
        <inputEntry id="ie_3_3_surg_safety_012"><text>-</text></inputEntry>
        <inputEntry id="ie_3_4_surg_safety_012"><text>-</text></inputEntry>
        <inputEntry id="ie_3_5_surg_safety_012"><text>-</text></inputEntry>
        <outputEntry id="oe_3_resultado_surg_safety_012"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_3_acao_surg_safety_012"><text>"CRITICAL: Patient identity not confirmed - verify patient with two identifiers before proceeding"</text></outputEntry>
        <outputEntry id="oe_3_risco_surg_safety_012"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_4_surg_safety_012">
        <inputEntry id="ie_4_1_surg_safety_012"><text>true</text></inputEntry>
        <inputEntry id="ie_4_2_surg_safety_012"><text>true</text></inputEntry>
        <inputEntry id="ie_4_3_surg_safety_012"><text>true</text></inputEntry>
        <inputEntry id="ie_4_4_surg_safety_012"><text>false</text></inputEntry>
        <inputEntry id="ie_4_5_surg_safety_012"><text>-</text></inputEntry>
        <outputEntry id="oe_4_resultado_surg_safety_012"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_4_acao_surg_safety_012"><text>"Equipment not ready - ensure all required equipment and implants available before proceeding"</text></outputEntry>
        <outputEntry id="oe_4_risco_surg_safety_012"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_5_surg_safety_012">
        <inputEntry id="ie_5_1_surg_safety_012"><text>true</text></inputEntry>
        <inputEntry id="ie_5_2_surg_safety_012"><text>true</text></inputEntry>
        <inputEntry id="ie_5_3_surg_safety_012"><text>true</text></inputEntry>
        <inputEntry id="ie_5_4_surg_safety_012"><text>true</text></inputEntry>
        <inputEntry id="ie_5_5_surg_safety_012"><text>false</text></inputEntry>
        <outputEntry id="oe_5_resultado_surg_safety_012"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_5_acao_surg_safety_012"><text>"Timeout not documented - circulating nurse must document timeout completion in medical record"</text></outputEntry>
        <outputEntry id="oe_5_risco_surg_safety_012"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_surg_safety_012">
      <dmndi:DMNShape id="DMNShape_surg_safety_012" dmnElementRef="surg_safety_012">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
