<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="definitions_surg_outcome_002"
             name="Readmission Prediction"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="surg_outcome_002" name="[SP-CO-007 | surgical_services/surgical_outcomes] Readmission Prediction" camunda:historyTimeToLive="180">
    <decisionTable id="dt_surg_outcome_002" hitPolicy="FIRST">
      <input id="input_1_surg_outcome_002" label="Procedure Type">
        <inputExpression id="inputExpr_1_surg_outcome_002" typeRef="string">
          <text>procedureType</text>
        </inputExpression>
      </input>
      <input id="input_2_surg_outcome_002" label="Discharge Day">
        <inputExpression id="inputExpr_2_surg_outcome_002" typeRef="number">
          <text>dischargeDay</text>
        </inputExpression>
      </input>
      <input id="input_3_surg_outcome_002" label="Complications During Surgery">
        <inputExpression id="inputExpr_3_surg_outcome_002" typeRef="boolean">
          <text>complicationsDuringSurgery</text>
        </inputExpression>
      </input>
      <input id="input_4_surg_outcome_002" label="Social Support">
        <inputExpression id="inputExpr_4_surg_outcome_002" typeRef="string">
          <text>socialSupport</text>
        </inputExpression>
      </input>
      <output id="output_resultado_surg_outcome_002" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao_surg_outcome_002" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco_surg_outcome_002" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1_surg_outcome_002">
        <inputEntry id="ie_1_1_surg_outcome_002"><text>"orthopedic","general"</text></inputEntry>
        <inputEntry id="ie_1_2_surg_outcome_002"><text>[2..4]</text></inputEntry>
        <inputEntry id="ie_1_3_surg_outcome_002"><text>false</text></inputEntry>
        <inputEntry id="ie_1_4_surg_outcome_002"><text>"good"</text></inputEntry>
        <outputEntry id="oe_1_resultado_surg_outcome_002"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao_surg_outcome_002"><text>"Low readmission risk (&lt;5%) - standard discharge planning, routine follow-up in 2 weeks"</text></outputEntry>
        <outputEntry id="oe_1_risco_surg_outcome_002"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2_surg_outcome_002">
        <inputEntry id="ie_2_1_surg_outcome_002"><text>"cardiac","vascular"</text></inputEntry>
        <inputEntry id="ie_2_2_surg_outcome_002"><text>-</text></inputEntry>
        <inputEntry id="ie_2_3_surg_outcome_002"><text>false</text></inputEntry>
        <inputEntry id="ie_2_4_surg_outcome_002"><text>"good"</text></inputEntry>
        <outputEntry id="oe_2_resultado_surg_outcome_002"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_2_acao_surg_outcome_002"><text>"Moderate risk (10-15%) - discharge phone call day 2, early follow-up in 1 week"</text></outputEntry>
        <outputEntry id="oe_2_risco_surg_outcome_002"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_3_surg_outcome_002">
        <inputEntry id="ie_3_1_surg_outcome_002"><text>-</text></inputEntry>
        <inputEntry id="ie_3_2_surg_outcome_002"><text>&lt; 2</text></inputEntry>
        <inputEntry id="ie_3_3_surg_outcome_002"><text>-</text></inputEntry>
        <inputEntry id="ie_3_4_surg_outcome_002"><text>-</text></inputEntry>
        <outputEntry id="oe_3_resultado_surg_outcome_002"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_3_acao_surg_outcome_002"><text>"Early discharge - higher readmission risk, arrange 48hr home health visit, phone follow-up"</text></outputEntry>
        <outputEntry id="oe_3_risco_surg_outcome_002"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_4_surg_outcome_002">
        <inputEntry id="ie_4_1_surg_outcome_002"><text>-</text></inputEntry>
        <inputEntry id="ie_4_2_surg_outcome_002"><text>-</text></inputEntry>
        <inputEntry id="ie_4_3_surg_outcome_002"><text>true</text></inputEntry>
        <inputEntry id="ie_4_4_surg_outcome_002"><text>-</text></inputEntry>
        <outputEntry id="oe_4_resultado_surg_outcome_002"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_4_acao_surg_outcome_002"><text>"Intraop complications - high risk (20-30%), extended monitoring before discharge, early clinic visit"</text></outputEntry>
        <outputEntry id="oe_4_risco_surg_outcome_002"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_5_surg_outcome_002">
        <inputEntry id="ie_5_1_surg_outcome_002"><text>-</text></inputEntry>
        <inputEntry id="ie_5_2_surg_outcome_002"><text>-</text></inputEntry>
        <inputEntry id="ie_5_3_surg_outcome_002"><text>-</text></inputEntry>
        <inputEntry id="ie_5_4_surg_outcome_002"><text>"poor","none"</text></inputEntry>
        <outputEntry id="oe_5_resultado_surg_outcome_002"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_5_acao_surg_outcome_002"><text>"Poor social support - high readmission risk, social work consult, consider rehab facility"</text></outputEntry>
        <outputEntry id="oe_5_risco_surg_outcome_002"><text>"ALTO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_surg_outcome_002">
      <dmndi:DMNShape id="DMNShape_surg_outcome_002" dmnElementRef="surg_outcome_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
