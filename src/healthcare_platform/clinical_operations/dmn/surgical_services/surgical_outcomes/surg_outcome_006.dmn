<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="definitions_surg_outcome_006"
             name="Pain Management Protocol"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="surg_outcome_006" name="[SP-CO-007 | surgical_services/surgical_outcomes] Pain Management Protocol" camunda:historyTimeToLive="180">
    <decisionTable id="dt_surg_outcome_006" hitPolicy="FIRST">
      <input id="input_1_surg_outcome_006" label="Procedure Type">
        <inputExpression id="inputExpr_1_surg_outcome_006" typeRef="string">
          <text>procedureType</text>
        </inputExpression>
      </input>
      <input id="input_2_surg_outcome_006" label="Pain Severity">
        <inputExpression id="inputExpr_2_surg_outcome_006" typeRef="number">
          <text>painSeverity</text>
        </inputExpression>
      </input>
      <input id="input_3_surg_outcome_006" label="Opioid History">
        <inputExpression id="inputExpr_3_surg_outcome_006" typeRef="string">
          <text>opioidHistory</text>
        </inputExpression>
      </input>
      <input id="input_4_surg_outcome_006" label="Kidney Function">
        <inputExpression id="inputExpr_4_surg_outcome_006" typeRef="string">
          <text>kidneyFunction</text>
        </inputExpression>
      </input>
      <output id="output_resultado_surg_outcome_006" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao_surg_outcome_006" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco_surg_outcome_006" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1_surg_outcome_006">
        <inputEntry id="ie_1_1_surg_outcome_006"><text>"minor"</text></inputEntry>
        <inputEntry id="ie_1_2_surg_outcome_006"><text>[0..3]</text></inputEntry>
        <inputEntry id="ie_1_3_surg_outcome_006"><text>"none"</text></inputEntry>
        <inputEntry id="ie_1_4_surg_outcome_006"><text>"normal"</text></inputEntry>
        <outputEntry id="oe_1_resultado_surg_outcome_006"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao_surg_outcome_006"><text>"Mild pain protocol - acetaminophen/NSAID combination, ice, early mobilization"</text></outputEntry>
        <outputEntry id="oe_1_risco_surg_outcome_006"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2_surg_outcome_006">
        <inputEntry id="ie_2_1_surg_outcome_006"><text>"moderate"</text></inputEntry>
        <inputEntry id="ie_2_2_surg_outcome_006"><text>[4..6]</text></inputEntry>
        <inputEntry id="ie_2_3_surg_outcome_006"><text>"none","limited"</text></inputEntry>
        <inputEntry id="ie_2_4_surg_outcome_006"><text>"normal"</text></inputEntry>
        <outputEntry id="oe_2_resultado_surg_outcome_006"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_2_acao_surg_outcome_006"><text>"Moderate pain - multimodal analgesia, short-acting opioid PRN, regional block if available"</text></outputEntry>
        <outputEntry id="oe_2_risco_surg_outcome_006"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_3_surg_outcome_006">
        <inputEntry id="ie_3_1_surg_outcome_006"><text>"major"</text></inputEntry>
        <inputEntry id="ie_3_2_surg_outcome_006"><text>[7..10]</text></inputEntry>
        <inputEntry id="ie_3_3_surg_outcome_006"><text>"none","limited"</text></inputEntry>
        <inputEntry id="ie_3_4_surg_outcome_006"><text>"normal"</text></inputEntry>
        <outputEntry id="oe_3_resultado_surg_outcome_006"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_3_acao_surg_outcome_006"><text>"Severe pain - PCA or epidural, multimodal adjuncts, pain service consult"</text></outputEntry>
        <outputEntry id="oe_3_risco_surg_outcome_006"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_4_surg_outcome_006">
        <inputEntry id="ie_4_1_surg_outcome_006"><text>-</text></inputEntry>
        <inputEntry id="ie_4_2_surg_outcome_006"><text>-</text></inputEntry>
        <inputEntry id="ie_4_3_surg_outcome_006"><text>"chronic_opioid_use"</text></inputEntry>
        <inputEntry id="ie_4_4_surg_outcome_006"><text>-</text></inputEntry>
        <outputEntry id="oe_4_resultado_surg_outcome_006"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_4_acao_surg_outcome_006"><text>"Opioid tolerant patient - continue home opioids, add 50-100% for acute pain, pain service consult required"</text></outputEntry>
        <outputEntry id="oe_4_risco_surg_outcome_006"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_5_surg_outcome_006">
        <inputEntry id="ie_5_1_surg_outcome_006"><text>-</text></inputEntry>
        <inputEntry id="ie_5_2_surg_outcome_006"><text>-</text></inputEntry>
        <inputEntry id="ie_5_3_surg_outcome_006"><text>-</text></inputEntry>
        <inputEntry id="ie_5_4_surg_outcome_006"><text>"severe_ckd","dialysis"</text></inputEntry>
        <outputEntry id="oe_5_resultado_surg_outcome_006"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_5_acao_surg_outcome_006"><text>"Renal impairment - avoid NSAIDs, reduce opioid doses by 50%, prefer shorter-acting agents, nephrology input"</text></outputEntry>
        <outputEntry id="oe_5_risco_surg_outcome_006"><text>"ALTO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_surg_outcome_006">
      <dmndi:DMNShape id="DMNShape_surg_outcome_006" dmnElementRef="surg_outcome_006">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
