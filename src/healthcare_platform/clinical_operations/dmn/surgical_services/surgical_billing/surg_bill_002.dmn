<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="definitions_surg_bill_002"
             name="Implant Tracking Rules"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="surg_bill_002" name="[SP-CO-007 | surgical_services/surgical_billing] Implant Tracking Rules" camunda:historyTimeToLive="180">
    <decisionTable id="dt_surg_bill_002" hitPolicy="FIRST">
      <input id="input_1_surg_bill_002" label="Implant Type">
        <inputExpression id="inputExpr_1_surg_bill_002" typeRef="string">
          <text>implantType</text>
        </inputExpression>
      </input>
      <input id="input_2_surg_bill_002" label="Manufacturer">
        <inputExpression id="inputExpr_2_surg_bill_002" typeRef="string">
          <text>manufacturer</text>
        </inputExpression>
      </input>
      <input id="input_3_surg_bill_002" label="Lot Number">
        <inputExpression id="inputExpr_3_surg_bill_002" typeRef="boolean">
          <text>lotNumber</text>
        </inputExpression>
      </input>
      <input id="input_4_surg_bill_002" label="Expiration Valid">
        <inputExpression id="inputExpr_4_surg_bill_002" typeRef="boolean">
          <text>expirationValid</text>
        </inputExpression>
      </input>
      <output id="output_resultado_surg_bill_002" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao_surg_bill_002" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco_surg_bill_002" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1_surg_bill_002">
        <inputEntry id="ie_1_1_surg_bill_002"><text>"orthopedic","cardiac","neurostimulator"</text></inputEntry>
        <inputEntry id="ie_1_2_surg_bill_002"><text>"approved_vendor"</text></inputEntry>
        <inputEntry id="ie_1_3_surg_bill_002"><text>true</text></inputEntry>
        <inputEntry id="ie_1_4_surg_bill_002"><text>true</text></inputEntry>
        <outputEntry id="oe_1_resultado_surg_bill_002"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao_surg_bill_002"><text>"Implant fully documented - lot number, expiration valid, proceed with implantation and billing"</text></outputEntry>
        <outputEntry id="oe_1_risco_surg_bill_002"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2_surg_bill_002">
        <inputEntry id="ie_2_1_surg_bill_002"><text>-</text></inputEntry>
        <inputEntry id="ie_2_2_surg_bill_002"><text>-</text></inputEntry>
        <inputEntry id="ie_2_3_surg_bill_002"><text>false</text></inputEntry>
        <inputEntry id="ie_2_4_surg_bill_002"><text>-</text></inputEntry>
        <outputEntry id="oe_2_resultado_surg_bill_002"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_2_acao_surg_bill_002"><text>"CRITICAL: Lot number not documented - obtain and document lot number before implantation"</text></outputEntry>
        <outputEntry id="oe_2_risco_surg_bill_002"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_3_surg_bill_002">
        <inputEntry id="ie_3_1_surg_bill_002"><text>-</text></inputEntry>
        <inputEntry id="ie_3_2_surg_bill_002"><text>-</text></inputEntry>
        <inputEntry id="ie_3_3_surg_bill_002"><text>true</text></inputEntry>
        <inputEntry id="ie_3_4_surg_bill_002"><text>false</text></inputEntry>
        <outputEntry id="oe_3_resultado_surg_bill_002"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_3_acao_surg_bill_002"><text>"CRITICAL: Expired implant - do not implant, obtain replacement with valid expiration"</text></outputEntry>
        <outputEntry id="oe_3_risco_surg_bill_002"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_4_surg_bill_002">
        <inputEntry id="ie_4_1_surg_bill_002"><text>-</text></inputEntry>
        <inputEntry id="ie_4_2_surg_bill_002"><text>"non_approved_vendor"</text></inputEntry>
        <inputEntry id="ie_4_3_surg_bill_002"><text>true</text></inputEntry>
        <inputEntry id="ie_4_4_surg_bill_002"><text>true</text></inputEntry>
        <outputEntry id="oe_4_resultado_surg_bill_002"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_4_acao_surg_bill_002"><text>"Non-approved vendor - verify institutional approval and payer coverage before proceeding"</text></outputEntry>
        <outputEntry id="oe_4_risco_surg_bill_002"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_5_surg_bill_002">
        <inputEntry id="ie_5_1_surg_bill_002"><text>"mesh","suture"</text></inputEntry>
        <inputEntry id="ie_5_2_surg_bill_002"><text>"approved_vendor"</text></inputEntry>
        <inputEntry id="ie_5_3_surg_bill_002"><text>true</text></inputEntry>
        <inputEntry id="ie_5_4_surg_bill_002"><text>true</text></inputEntry>
        <outputEntry id="oe_5_resultado_surg_bill_002"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_5_acao_surg_bill_002"><text>"Standard implant documented - lot tracking complete, bill as surgical supply"</text></outputEntry>
        <outputEntry id="oe_5_risco_surg_bill_002"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_surg_bill_002">
      <dmndi:DMNShape id="DMNShape_surg_bill_002" dmnElementRef="surg_bill_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
