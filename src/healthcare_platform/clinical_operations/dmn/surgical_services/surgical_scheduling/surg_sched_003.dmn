<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="definitions_surg_sched_003"
             name="Team Assignment Rules"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="surg_sched_003" name="[SP-CO-007 | surgical_services/surgical_scheduling] Team Assignment Rules" camunda:historyTimeToLive="180">
    <decisionTable id="dt_surg_sched_003" hitPolicy="FIRST">
      <input id="input_1_surg_sched_003" label="Procedure Complexity">
        <inputExpression id="inputExpr_1_surg_sched_003" typeRef="string">
          <text>procedureComplexity</text>
        </inputExpression>
      </input>
      <input id="input_2_surg_sched_003" label="Specialty Required">
        <inputExpression id="inputExpr_2_surg_sched_003" typeRef="string">
          <text>specialtyRequired</text>
        </inputExpression>
      </input>
      <input id="input_3_surg_sched_003" label="Surgeon Availability">
        <inputExpression id="inputExpr_3_surg_sched_003" typeRef="boolean">
          <text>surgeonAvailability</text>
        </inputExpression>
      </input>
      <input id="input_4_surg_sched_003" label="Anesthesiologist Availability">
        <inputExpression id="inputExpr_4_surg_sched_003" typeRef="boolean">
          <text>anesthesiologistAvailability</text>
        </inputExpression>
      </input>
      <output id="output_resultado_surg_sched_003" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao_surg_sched_003" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco_surg_sched_003" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1_surg_sched_003">
        <inputEntry id="ie_1_1_surg_sched_003"><text>"high"</text></inputEntry>
        <inputEntry id="ie_1_2_surg_sched_003"><text>"cardiac","neuro"</text></inputEntry>
        <inputEntry id="ie_1_3_surg_sched_003"><text>true</text></inputEntry>
        <inputEntry id="ie_1_4_surg_sched_003"><text>true</text></inputEntry>
        <outputEntry id="oe_1_resultado_surg_sched_003"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao_surg_sched_003"><text>"Complex specialty case - assign senior surgeon, specialized anesthesiologist, experienced OR team"</text></outputEntry>
        <outputEntry id="oe_1_risco_surg_sched_003"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2_surg_sched_003">
        <inputEntry id="ie_2_1_surg_sched_003"><text>"low"</text></inputEntry>
        <inputEntry id="ie_2_2_surg_sched_003"><text>"general"</text></inputEntry>
        <inputEntry id="ie_2_3_surg_sched_003"><text>true</text></inputEntry>
        <inputEntry id="ie_2_4_surg_sched_003"><text>true</text></inputEntry>
        <outputEntry id="oe_2_resultado_surg_sched_003"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_2_acao_surg_sched_003"><text>"Routine case - assign available surgeon, standard anesthesia team, regular OR staff"</text></outputEntry>
        <outputEntry id="oe_2_risco_surg_sched_003"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_3_surg_sched_003">
        <inputEntry id="ie_3_1_surg_sched_003"><text>-</text></inputEntry>
        <inputEntry id="ie_3_2_surg_sched_003"><text>-</text></inputEntry>
        <inputEntry id="ie_3_3_surg_sched_003"><text>false</text></inputEntry>
        <inputEntry id="ie_3_4_surg_sched_003"><text>-</text></inputEntry>
        <outputEntry id="oe_3_resultado_surg_sched_003"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_3_acao_surg_sched_003"><text>"CRITICAL: Required surgeon not available - reschedule or find qualified alternate surgeon"</text></outputEntry>
        <outputEntry id="oe_3_risco_surg_sched_003"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_4_surg_sched_003">
        <inputEntry id="ie_4_1_surg_sched_003"><text>-</text></inputEntry>
        <inputEntry id="ie_4_2_surg_sched_003"><text>-</text></inputEntry>
        <inputEntry id="ie_4_3_surg_sched_003"><text>true</text></inputEntry>
        <inputEntry id="ie_4_4_surg_sched_003"><text>false</text></inputEntry>
        <outputEntry id="oe_4_resultado_surg_sched_003"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_4_acao_surg_sched_003"><text>"CRITICAL: Anesthesiologist not available - reschedule or request on-call anesthesiologist"</text></outputEntry>
        <outputEntry id="oe_4_risco_surg_sched_003"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_5_surg_sched_003">
        <inputEntry id="ie_5_1_surg_sched_003"><text>"medium"</text></inputEntry>
        <inputEntry id="ie_5_2_surg_sched_003"><text>"orthopedic","ent"</text></inputEntry>
        <inputEntry id="ie_5_3_surg_sched_003"><text>true</text></inputEntry>
        <inputEntry id="ie_5_4_surg_sched_003"><text>true</text></inputEntry>
        <outputEntry id="oe_5_resultado_surg_sched_003"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_5_acao_surg_sched_003"><text>"Moderate complexity - assign experienced surgeon, standard anesthesia, specialty-trained OR nurse"</text></outputEntry>
        <outputEntry id="oe_5_risco_surg_sched_003"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_surg_sched_003">
      <dmndi:DMNShape id="DMNShape_surg_sched_003" dmnElementRef="surg_sched_003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
