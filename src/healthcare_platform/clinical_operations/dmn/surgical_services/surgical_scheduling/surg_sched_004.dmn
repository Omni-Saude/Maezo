<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="definitions_surg_sched_004"
             name="Priority Scoring"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="surg_sched_004" name="[SP-CO-007 | surgical_services/surgical_scheduling] Priority Scoring" camunda:historyTimeToLive="180">
    <decisionTable id="dt_surg_sched_004" hitPolicy="FIRST">
      <input id="input_1_surg_sched_004" label="Clinical Urgency">
        <inputExpression id="inputExpr_1_surg_sched_004" typeRef="string">
          <text>clinicalUrgency</text>
        </inputExpression>
      </input>
      <input id="input_2_surg_sched_004" label="Waiting Time">
        <inputExpression id="inputExpr_2_surg_sched_004" typeRef="number">
          <text>waitingTime</text>
        </inputExpression>
      </input>
      <input id="input_3_surg_sched_004" label="Age Group">
        <inputExpression id="inputExpr_3_surg_sched_004" typeRef="string">
          <text>ageGroup</text>
        </inputExpression>
      </input>
      <input id="input_4_surg_sched_004" label="Comorbidity Count">
        <inputExpression id="inputExpr_4_surg_sched_004" typeRef="number">
          <text>comorbidityCount</text>
        </inputExpression>
      </input>
      <output id="output_resultado_surg_sched_004" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao_surg_sched_004" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco_surg_sched_004" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1_surg_sched_004">
        <inputEntry id="ie_1_1_surg_sched_004"><text>"emergent"</text></inputEntry>
        <inputEntry id="ie_1_2_surg_sched_004"><text>-</text></inputEntry>
        <inputEntry id="ie_1_3_surg_sched_004"><text>-</text></inputEntry>
        <inputEntry id="ie_1_4_surg_sched_004"><text>-</text></inputEntry>
        <outputEntry id="oe_1_resultado_surg_sched_004"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao_surg_sched_004"><text>"Priority score: 100 - Emergent case, immediate OR allocation required"</text></outputEntry>
        <outputEntry id="oe_1_risco_surg_sched_004"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_2_surg_sched_004">
        <inputEntry id="ie_2_1_surg_sched_004"><text>"urgent"</text></inputEntry>
        <inputEntry id="ie_2_2_surg_sched_004"><text>&gt;= 30</text></inputEntry>
        <inputEntry id="ie_2_3_surg_sched_004"><text>"pediatric","geriatric"</text></inputEntry>
        <inputEntry id="ie_2_4_surg_sched_004"><text>&gt;= 3</text></inputEntry>
        <outputEntry id="oe_2_resultado_surg_sched_004"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_2_acao_surg_sched_004"><text>"Priority score: 85 - Urgent case with multiple risk factors, schedule within 24 hours"</text></outputEntry>
        <outputEntry id="oe_2_risco_surg_sched_004"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_3_surg_sched_004">
        <inputEntry id="ie_3_1_surg_sched_004"><text>"semi_urgent"</text></inputEntry>
        <inputEntry id="ie_3_2_surg_sched_004"><text>&gt;= 60</text></inputEntry>
        <inputEntry id="ie_3_3_surg_sched_004"><text>-</text></inputEntry>
        <inputEntry id="ie_3_4_surg_sched_004"><text>[2..3]</text></inputEntry>
        <outputEntry id="oe_3_resultado_surg_sched_004"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_3_acao_surg_sched_004"><text>"Priority score: 70 - Semi-urgent with extended wait time, schedule within 7 days"</text></outputEntry>
        <outputEntry id="oe_3_risco_surg_sched_004"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_4_surg_sched_004">
        <inputEntry id="ie_4_1_surg_sched_004"><text>"elective"</text></inputEntry>
        <inputEntry id="ie_4_2_surg_sched_004"><text>&gt;= 90</text></inputEntry>
        <inputEntry id="ie_4_3_surg_sched_004"><text>"geriatric"</text></inputEntry>
        <inputEntry id="ie_4_4_surg_sched_004"><text>&gt;= 4</text></inputEntry>
        <outputEntry id="oe_4_resultado_surg_sched_004"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_4_acao_surg_sched_004"><text>"Priority score: 60 - Elective but high risk profile, prioritize over routine electives"</text></outputEntry>
        <outputEntry id="oe_4_risco_surg_sched_004"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="rule_5_surg_sched_004">
        <inputEntry id="ie_5_1_surg_sched_004"><text>"elective"</text></inputEntry>
        <inputEntry id="ie_5_2_surg_sched_004"><text>&lt; 30</text></inputEntry>
        <inputEntry id="ie_5_3_surg_sched_004"><text>"adult"</text></inputEntry>
        <inputEntry id="ie_5_4_surg_sched_004"><text>[0..1]</text></inputEntry>
        <outputEntry id="oe_5_resultado_surg_sched_004"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_5_acao_surg_sched_004"><text>"Priority score: 30 - Routine elective case, schedule based on OR availability"</text></outputEntry>
        <outputEntry id="oe_5_risco_surg_sched_004"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_surg_sched_004">
      <dmndi:DMNShape id="DMNShape_surg_sched_004" dmnElementRef="surg_sched_004">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
