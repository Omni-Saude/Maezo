<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="definitions_surg_sched_006"
             name="Case Sequencing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="surg_sched_006" name="[SP-CO-007 | surgical_services/surgical_scheduling] Case Sequencing" camunda:historyTimeToLive="180">
    <decisionTable id="dt_surg_sched_006" hitPolicy="FIRST">
      <input id="input_1_surg_sched_006" label="Infection Risk">
        <inputExpression id="inputExpr_1_surg_sched_006" typeRef="string">
          <text>infectionRisk</text>
        </inputExpression>
      </input>
      <input id="input_2_surg_sched_006" label="Procedure Type">
        <inputExpression id="inputExpr_2_surg_sched_006" typeRef="string">
          <text>procedureType</text>
        </inputExpression>
      </input>
      <input id="input_3_surg_sched_006" label="Cleanliness Level">
        <inputExpression id="inputExpr_3_surg_sched_006" typeRef="string">
          <text>cleanlinessLevel</text>
        </inputExpression>
      </input>
      <input id="input_4_surg_sched_006" label="Previous Case Contamination">
        <inputExpression id="inputExpr_4_surg_sched_006" typeRef="boolean">
          <text>previousCaseContamination</text>
        </inputExpression>
      </input>
      <output id="output_resultado_surg_sched_006" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao_surg_sched_006" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco_surg_sched_006" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1_surg_sched_006">
        <inputEntry id="ie_1_1_surg_sched_006"><text>"clean"</text></inputEntry>
        <inputEntry id="ie_1_2_surg_sched_006"><text>"orthopedic_implant","cardiac"</text></inputEntry>
        <inputEntry id="ie_1_3_surg_sched_006"><text>-</text></inputEntry>
        <inputEntry id="ie_1_4_surg_sched_006"><text>false</text></inputEntry>
        <outputEntry id="oe_1_resultado_surg_sched_006"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao_surg_sched_006"><text>"Clean case with implant - schedule as first case of the day to minimize infection risk"</text></outputEntry>
        <outputEntry id="oe_1_risco_surg_sched_006"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_2_surg_sched_006">
        <inputEntry id="ie_2_1_surg_sched_006"><text>"dirty_infected"</text></inputEntry>
        <inputEntry id="ie_2_2_surg_sched_006"><text>-</text></inputEntry>
        <inputEntry id="ie_2_3_surg_sched_006"><text>-</text></inputEntry>
        <inputEntry id="ie_2_4_surg_sched_006"><text>-</text></inputEntry>
        <outputEntry id="oe_2_resultado_surg_sched_006"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_2_acao_surg_sched_006"><text>"Dirty/infected case - schedule as last case of the day, terminal cleaning required after"</text></outputEntry>
        <outputEntry id="oe_2_risco_surg_sched_006"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_3_surg_sched_006">
        <inputEntry id="ie_3_1_surg_sched_006"><text>"clean","clean_contaminated"</text></inputEntry>
        <inputEntry id="ie_3_2_surg_sched_006"><text>-</text></inputEntry>
        <inputEntry id="ie_3_3_surg_sched_006"><text>-</text></inputEntry>
        <inputEntry id="ie_3_4_surg_sched_006"><text>true</text></inputEntry>
        <outputEntry id="oe_3_resultado_surg_sched_006"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="oe_3_acao_surg_sched_006"><text>"CRITICAL: Previous case contaminated - require terminal cleaning before clean case proceeds"</text></outputEntry>
        <outputEntry id="oe_3_risco_surg_sched_006"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_4_surg_sched_006">
        <inputEntry id="ie_4_1_surg_sched_006"><text>"clean_contaminated"</text></inputEntry>
        <inputEntry id="ie_4_2_surg_sched_006"><text>"gi","urologic"</text></inputEntry>
        <inputEntry id="ie_4_3_surg_sched_006"><text>-</text></inputEntry>
        <inputEntry id="ie_4_4_surg_sched_006"><text>false</text></inputEntry>
        <outputEntry id="oe_4_resultado_surg_sched_006"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_4_acao_surg_sched_006"><text>"Clean-contaminated case - schedule after clean cases, standard turnover cleaning adequate"</text></outputEntry>
        <outputEntry id="oe_4_risco_surg_sched_006"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_5_surg_sched_006">
        <inputEntry id="ie_5_1_surg_sched_006"><text>"contaminated"</text></inputEntry>
        <inputEntry id="ie_5_2_surg_sched_006"><text>-</text></inputEntry>
        <inputEntry id="ie_5_3_surg_sched_006"><text>-</text></inputEntry>
        <inputEntry id="ie_5_4_surg_sched_006"><text>false</text></inputEntry>
        <outputEntry id="oe_5_resultado_surg_sched_006"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_5_acao_surg_sched_006"><text>"Contaminated case - schedule late in day, enhanced cleaning protocol required after case"</text></outputEntry>
        <outputEntry id="oe_5_risco_surg_sched_006"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_surg_sched_006">
      <dmndi:DMNShape id="DMNShape_surg_sched_006" dmnElementRef="surg_sched_006">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
