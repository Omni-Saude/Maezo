<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="definitions_surg_sched_001"
             name="OR Allocation Priority"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="surg_sched_001" name="[SP-CO-007 | surgical_services/surgical_scheduling] OR Allocation Priority" camunda:historyTimeToLive="180">
    <decisionTable id="dt_surg_sched_001" hitPolicy="FIRST">
      <input id="input_1_surg_sched_001" label="Urgency Level">
        <inputExpression id="inputExpr_1_surg_sched_001" typeRef="string">
          <text>urgencyLevel</text>
        </inputExpression>
      </input>
      <input id="input_2_surg_sched_001" label="Specialty Type">
        <inputExpression id="inputExpr_2_surg_sched_001" typeRef="string">
          <text>specialtyType</text>
        </inputExpression>
      </input>
      <input id="input_3_surg_sched_001" label="Estimated Duration">
        <inputExpression id="inputExpr_3_surg_sched_001" typeRef="number">
          <text>estimatedDuration</text>
        </inputExpression>
      </input>
      <input id="input_4_surg_sched_001" label="Equipment Needs">
        <inputExpression id="inputExpr_4_surg_sched_001" typeRef="string">
          <text>equipmentNeeds</text>
        </inputExpression>
      </input>
      <output id="output_resultado_surg_sched_001" label="Resultado" name="resultado" typeRef="string"/>
      <output id="output_acao_surg_sched_001" label="Ação" name="acao" typeRef="string"/>
      <output id="output_risco_surg_sched_001" label="Risco" name="risco" typeRef="string"/>
      <rule id="rule_1_surg_sched_001">
        <inputEntry id="ie_1_1_surg_sched_001"><text>"emergent"</text></inputEntry>
        <inputEntry id="ie_1_2_surg_sched_001"><text>-</text></inputEntry>
        <inputEntry id="ie_1_3_surg_sched_001"><text>-</text></inputEntry>
        <inputEntry id="ie_1_4_surg_sched_001"><text>-</text></inputEntry>
        <outputEntry id="oe_1_resultado_surg_sched_001"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_1_acao_surg_sched_001"><text>"Emergent case - allocate next available OR immediately, bump elective cases if necessary"</text></outputEntry>
        <outputEntry id="oe_1_risco_surg_sched_001"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="rule_2_surg_sched_001">
        <inputEntry id="ie_2_1_surg_sched_001"><text>"urgent"</text></inputEntry>
        <inputEntry id="ie_2_2_surg_sched_001"><text>-</text></inputEntry>
        <inputEntry id="ie_2_3_surg_sched_001"><text>&lt; 120</text></inputEntry>
        <inputEntry id="ie_2_4_surg_sched_001"><text>"standard"</text></inputEntry>
        <outputEntry id="oe_2_resultado_surg_sched_001"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_2_acao_surg_sched_001"><text>"Urgent case - schedule within 24h in main OR suite with standard equipment"</text></outputEntry>
        <outputEntry id="oe_2_risco_surg_sched_001"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="rule_3_surg_sched_001">
        <inputEntry id="ie_3_1_surg_sched_001"><text>"elective"</text></inputEntry>
        <inputEntry id="ie_3_2_surg_sched_001"><text>"cardiac","neuro"</text></inputEntry>
        <inputEntry id="ie_3_3_surg_sched_001"><text>-</text></inputEntry>
        <inputEntry id="ie_3_4_surg_sched_001"><text>"specialized"</text></inputEntry>
        <outputEntry id="oe_3_resultado_surg_sched_001"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_3_acao_surg_sched_001"><text>"Elective specialty case - allocate to specialty OR with required equipment, schedule during regular hours"</text></outputEntry>
        <outputEntry id="oe_3_risco_surg_sched_001"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_4_surg_sched_001">
        <inputEntry id="ie_4_1_surg_sched_001"><text>"elective"</text></inputEntry>
        <inputEntry id="ie_4_2_surg_sched_001"><text>"general"</text></inputEntry>
        <inputEntry id="ie_4_3_surg_sched_001"><text>&lt; 90</text></inputEntry>
        <inputEntry id="ie_4_4_surg_sched_001"><text>"standard"</text></inputEntry>
        <outputEntry id="oe_4_resultado_surg_sched_001"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="oe_4_acao_surg_sched_001"><text>"Routine elective case - schedule in general OR based on availability, fill scheduling gaps"</text></outputEntry>
        <outputEntry id="oe_4_risco_surg_sched_001"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="rule_5_surg_sched_001">
        <inputEntry id="ie_5_1_surg_sched_001"><text>"elective"</text></inputEntry>
        <inputEntry id="ie_5_2_surg_sched_001"><text>-</text></inputEntry>
        <inputEntry id="ie_5_3_surg_sched_001"><text>&gt;= 240</text></inputEntry>
        <inputEntry id="ie_5_4_surg_sched_001"><text>-</text></inputEntry>
        <outputEntry id="oe_5_resultado_surg_sched_001"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="oe_5_acao_surg_sched_001"><text>"Long elective case - schedule as first case of day, ensure adequate turnover time, reserve ICU bed"</text></outputEntry>
        <outputEntry id="oe_5_risco_surg_sched_001"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_surg_sched_001">
      <dmndi:DMNShape id="DMNShape_surg_sched_001" dmnElementRef="surg_sched_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
