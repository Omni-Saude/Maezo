<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  Surgical Readiness Assessment - Pre-Operative Checklist Validation
  ============================================================================
  Validates all pre-operative requirements before allowing surgical procedure.
  Based on WHO Safe Surgery Saves Lives - Sign In phase.
  Hit Policy: COLLECT (gather all missing items)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_surgical_readiness"
             name="Surgical Readiness Assessment"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_surgical_readiness" name="[SP-CO-007 | surgical] Pre-Operative Readiness Evaluation" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_surgical_readiness" hitPolicy="COLLECT">

      <!-- INPUT 1: Patient ID -->
      <input id="Input_sr_1_surgical_readiness" label="Patient ID">
        <inputExpression id="InputExpr_sr_1_surgical_readiness" typeRef="string">
          <text>patientId</text>
        </inputExpression>
      </input>

      <!-- INPUT 2: Informed Consent Signed -->
      <input id="Input_sr_2_surgical_readiness" label="Consent Signed">
        <inputExpression id="InputExpr_sr_2_surgical_readiness" typeRef="boolean">
          <text>consentSigned</text>
        </inputExpression>
      </input>

      <!-- INPUT 3: Surgical Site Marked -->
      <input id="Input_sr_3_surgical_readiness" label="Site Marked">
        <inputExpression id="InputExpr_sr_3_surgical_readiness" typeRef="boolean">
          <text>siteMarked</text>
        </inputExpression>
      </input>

      <!-- INPUT 4: Anesthesia Cleared -->
      <input id="Input_sr_4_surgical_readiness" label="Anesthesia Cleared">
        <inputExpression id="InputExpr_sr_4_surgical_readiness" typeRef="boolean">
          <text>anesthesiaCleared</text>
        </inputExpression>
      </input>

      <!-- INPUT 5: Allergies Reviewed -->
      <input id="Input_sr_5_surgical_readiness" label="Allergies Reviewed">
        <inputExpression id="InputExpr_sr_5_surgical_readiness" typeRef="boolean">
          <text>allergiesReviewed</text>
        </inputExpression>
      </input>

      <!-- INPUT 6: Fasting Confirmed -->
      <input id="Input_sr_6_surgical_readiness" label="Fasting Confirmed">
        <inputExpression id="InputExpr_sr_6_surgical_readiness" typeRef="boolean">
          <text>fastingConfirmed</text>
        </inputExpression>
      </input>

      <!-- OUTPUT 1: Readiness Status -->
      <output id="Output_sr_1_surgical_readiness" label="Readiness Status" name="readinessStatus" typeRef="string">
        <outputValues id="OutputValues_sr_1_surgical_readiness">
          <text>"READY", "NOT_READY", "NEEDS_REVIEW"</text>
        </outputValues>
      </output>

      <!-- OUTPUT 2: Missing Items -->
      <output id="Output_sr_2_surgical_readiness" label="Missing Items" name="missingItems" typeRef="string"/>

      <!-- OUTPUT 3: Can Proceed -->
      <output id="Output_sr_3_surgical_readiness" label="Can Proceed" name="canProceed" typeRef="boolean"/>

      <!-- RULE 1: Consent not signed -->
      <rule id="Rule_sr_no_consent_surgical_readiness">
        <description>Informed consent is mandatory - cannot proceed without</description>
        <inputEntry id="IE_sr_1_1_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_1_2_surgical_readiness"><text>false</text></inputEntry>
        <inputEntry id="IE_sr_1_3_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_1_4_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_1_5_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_1_6_surgical_readiness"><text>-</text></inputEntry>
        <outputEntry id="OE_sr_1_1_surgical_readiness"><text>"NOT_READY"</text></outputEntry>
        <outputEntry id="OE_sr_1_2_surgical_readiness"><text>"Consentimento informado nao assinado"</text></outputEntry>
        <outputEntry id="OE_sr_1_3_surgical_readiness"><text>false</text></outputEntry>
      </rule>

      <!-- RULE 2: Site not marked -->
      <rule id="Rule_sr_no_site_mark_surgical_readiness">
        <description>Surgical site marking is mandatory per WHO protocol</description>
        <inputEntry id="IE_sr_2_1_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_2_2_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_2_3_surgical_readiness"><text>false</text></inputEntry>
        <inputEntry id="IE_sr_2_4_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_2_5_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_2_6_surgical_readiness"><text>-</text></inputEntry>
        <outputEntry id="OE_sr_2_1_surgical_readiness"><text>"NOT_READY"</text></outputEntry>
        <outputEntry id="OE_sr_2_2_surgical_readiness"><text>"Sitio cirurgico nao demarcado"</text></outputEntry>
        <outputEntry id="OE_sr_2_3_surgical_readiness"><text>false</text></outputEntry>
      </rule>

      <!-- RULE 3: Anesthesia not cleared -->
      <rule id="Rule_sr_no_anesthesia_surgical_readiness">
        <description>Anesthesia clearance is required before procedure</description>
        <inputEntry id="IE_sr_3_1_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_3_2_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_3_3_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_3_4_surgical_readiness"><text>false</text></inputEntry>
        <inputEntry id="IE_sr_3_5_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_3_6_surgical_readiness"><text>-</text></inputEntry>
        <outputEntry id="OE_sr_3_1_surgical_readiness"><text>"NOT_READY"</text></outputEntry>
        <outputEntry id="OE_sr_3_2_surgical_readiness"><text>"Avaliacao anestesica nao liberada"</text></outputEntry>
        <outputEntry id="OE_sr_3_3_surgical_readiness"><text>false</text></outputEntry>
      </rule>

      <!-- RULE 4: Allergies not reviewed -->
      <rule id="Rule_sr_no_allergies_surgical_readiness">
        <description>Allergy review is mandatory for patient safety</description>
        <inputEntry id="IE_sr_4_1_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_4_2_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_4_3_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_4_4_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_4_5_surgical_readiness"><text>false</text></inputEntry>
        <inputEntry id="IE_sr_4_6_surgical_readiness"><text>-</text></inputEntry>
        <outputEntry id="OE_sr_4_1_surgical_readiness"><text>"NEEDS_REVIEW"</text></outputEntry>
        <outputEntry id="OE_sr_4_2_surgical_readiness"><text>"Revisao de alergias pendente"</text></outputEntry>
        <outputEntry id="OE_sr_4_3_surgical_readiness"><text>false</text></outputEntry>
      </rule>

      <!-- RULE 5: Fasting not confirmed -->
      <rule id="Rule_sr_no_fasting_surgical_readiness">
        <description>Fasting confirmation required for anesthesia safety</description>
        <inputEntry id="IE_sr_5_1_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_5_2_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_5_3_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_5_4_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_5_5_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_5_6_surgical_readiness"><text>false</text></inputEntry>
        <outputEntry id="OE_sr_5_1_surgical_readiness"><text>"NOT_READY"</text></outputEntry>
        <outputEntry id="OE_sr_5_2_surgical_readiness"><text>"Jejum nao confirmado"</text></outputEntry>
        <outputEntry id="OE_sr_5_3_surgical_readiness"><text>false</text></outputEntry>
      </rule>

      <!-- RULE 6: All checks passed -->
      <rule id="Rule_sr_all_ready_surgical_readiness">
        <description>All pre-operative checks passed - patient ready for surgery</description>
        <inputEntry id="IE_sr_6_1_surgical_readiness"><text>-</text></inputEntry>
        <inputEntry id="IE_sr_6_2_surgical_readiness"><text>true</text></inputEntry>
        <inputEntry id="IE_sr_6_3_surgical_readiness"><text>true</text></inputEntry>
        <inputEntry id="IE_sr_6_4_surgical_readiness"><text>true</text></inputEntry>
        <inputEntry id="IE_sr_6_5_surgical_readiness"><text>true</text></inputEntry>
        <inputEntry id="IE_sr_6_6_surgical_readiness"><text>true</text></inputEntry>
        <outputEntry id="OE_sr_6_1_surgical_readiness"><text>"READY"</text></outputEntry>
        <outputEntry id="OE_sr_6_2_surgical_readiness"><text>"Todos os itens verificados"</text></outputEntry>
        <outputEntry id="OE_sr_6_3_surgical_readiness"><text>true</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_surgical_readiness">
      <dmndi:DMNShape id="DMNShape_surgical_readiness" dmnElementRef="Decision_surgical_readiness">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
