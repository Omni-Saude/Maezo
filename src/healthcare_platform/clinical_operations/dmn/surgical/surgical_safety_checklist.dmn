<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  Surgical Safety Checklist - WHO Safe Surgery 3-Phase Validation
  ============================================================================
  Validates WHO Safe Surgery Checklist across three phases:
  SIGN_IN (before anesthesia), TIME_OUT (before incision), SIGN_OUT (before leaving OR).
  Hit Policy: COLLECT (gather all failed items per phase)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_surgical_safety_checklist"
             name="WHO Surgical Safety Checklist"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_surgical_safety_checklist" name="[SP-CO-007 | surgical] Surgical Safety Checklist Validation" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_surgical_safety_checklist" hitPolicy="COLLECT">

      <!-- INPUT 1: Phase -->
      <input id="Input_sc_1_surgical_safety_checklist" label="Checklist Phase">
        <inputExpression id="InputExpr_sc_1_surgical_safety_checklist" typeRef="string">
          <text>phase</text>
        </inputExpression>
        <inputValues id="InputValues_sc_1_surgical_safety_checklist">
          <text>"SIGN_IN", "TIME_OUT", "SIGN_OUT"</text>
        </inputValues>
      </input>

      <!-- INPUT 2: Patient Identity Confirmed -->
      <input id="Input_sc_2_surgical_safety_checklist" label="Identity Confirmed">
        <inputExpression id="InputExpr_sc_2_surgical_safety_checklist" typeRef="boolean">
          <text>identityConfirmed</text>
        </inputExpression>
      </input>

      <!-- INPUT 3: Site/Procedure Confirmed -->
      <input id="Input_sc_3_surgical_safety_checklist" label="Site Procedure Confirmed">
        <inputExpression id="InputExpr_sc_3_surgical_safety_checklist" typeRef="boolean">
          <text>siteProcedureConfirmed</text>
        </inputExpression>
      </input>

      <!-- INPUT 4: Consent Verified -->
      <input id="Input_sc_4_surgical_safety_checklist" label="Consent Verified">
        <inputExpression id="InputExpr_sc_4_surgical_safety_checklist" typeRef="boolean">
          <text>consentVerified</text>
        </inputExpression>
      </input>

      <!-- INPUT 5: Safety Equipment Check -->
      <input id="Input_sc_5_surgical_safety_checklist" label="Equipment Check">
        <inputExpression id="InputExpr_sc_5_surgical_safety_checklist" typeRef="boolean">
          <text>equipmentCheck</text>
        </inputExpression>
      </input>

      <!-- INPUT 6: Instrument Count Correct -->
      <input id="Input_sc_6_surgical_safety_checklist" label="Instrument Count OK">
        <inputExpression id="InputExpr_sc_6_surgical_safety_checklist" typeRef="boolean">
          <text>instrumentCountCorrect</text>
        </inputExpression>
      </input>

      <!-- OUTPUT 1: Phase Complete -->
      <output id="Output_sc_1_surgical_safety_checklist" label="Phase Complete" name="phaseComplete" typeRef="boolean"/>

      <!-- OUTPUT 2: Failed Items -->
      <output id="Output_sc_2_surgical_safety_checklist" label="Failed Items" name="failedItems" typeRef="string"/>

      <!-- OUTPUT 3: Safety Score (0-100) -->
      <output id="Output_sc_3_surgical_safety_checklist" label="Safety Score" name="safetyScore" typeRef="number"/>

      <!-- OUTPUT 4: Can Proceed -->
      <output id="Output_sc_4_surgical_safety_checklist" label="Can Proceed" name="canProceed" typeRef="boolean"/>

      <!-- ======== SIGN_IN PHASE (Before Anesthesia) ======== -->

      <!-- RULE 1: Sign-In - Identity not confirmed -->
      <rule id="Rule_sc_signin_no_identity_surgical_safety_checklist">
        <description>SIGN_IN: Patient identity must be confirmed before anesthesia</description>
        <inputEntry id="IE_sc_1_1_surgical_safety_checklist"><text>"SIGN_IN"</text></inputEntry>
        <inputEntry id="IE_sc_1_2_surgical_safety_checklist"><text>false</text></inputEntry>
        <inputEntry id="IE_sc_1_3_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_1_4_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_1_5_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_1_6_surgical_safety_checklist"><text>-</text></inputEntry>
        <outputEntry id="OE_sc_1_1_surgical_safety_checklist"><text>false</text></outputEntry>
        <outputEntry id="OE_sc_1_2_surgical_safety_checklist"><text>"Identidade do paciente nao confirmada (SIGN_IN)"</text></outputEntry>
        <outputEntry id="OE_sc_1_3_surgical_safety_checklist"><text>0</text></outputEntry>
        <outputEntry id="OE_sc_1_4_surgical_safety_checklist"><text>false</text></outputEntry>
      </rule>

      <!-- RULE 2: Sign-In - Consent not verified -->
      <rule id="Rule_sc_signin_no_consent_surgical_safety_checklist">
        <description>SIGN_IN: Consent must be verified before anesthesia</description>
        <inputEntry id="IE_sc_2_1_surgical_safety_checklist"><text>"SIGN_IN"</text></inputEntry>
        <inputEntry id="IE_sc_2_2_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_2_3_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_2_4_surgical_safety_checklist"><text>false</text></inputEntry>
        <inputEntry id="IE_sc_2_5_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_2_6_surgical_safety_checklist"><text>-</text></inputEntry>
        <outputEntry id="OE_sc_2_1_surgical_safety_checklist"><text>false</text></outputEntry>
        <outputEntry id="OE_sc_2_2_surgical_safety_checklist"><text>"Consentimento nao verificado (SIGN_IN)"</text></outputEntry>
        <outputEntry id="OE_sc_2_3_surgical_safety_checklist"><text>0</text></outputEntry>
        <outputEntry id="OE_sc_2_4_surgical_safety_checklist"><text>false</text></outputEntry>
      </rule>

      <!-- RULE 3: Sign-In - All checks passed -->
      <rule id="Rule_sc_signin_ok_surgical_safety_checklist">
        <description>SIGN_IN: All sign-in checks passed</description>
        <inputEntry id="IE_sc_3_1_surgical_safety_checklist"><text>"SIGN_IN"</text></inputEntry>
        <inputEntry id="IE_sc_3_2_surgical_safety_checklist"><text>true</text></inputEntry>
        <inputEntry id="IE_sc_3_3_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_3_4_surgical_safety_checklist"><text>true</text></inputEntry>
        <inputEntry id="IE_sc_3_5_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_3_6_surgical_safety_checklist"><text>-</text></inputEntry>
        <outputEntry id="OE_sc_3_1_surgical_safety_checklist"><text>true</text></outputEntry>
        <outputEntry id="OE_sc_3_2_surgical_safety_checklist"><text>""</text></outputEntry>
        <outputEntry id="OE_sc_3_3_surgical_safety_checklist"><text>100</text></outputEntry>
        <outputEntry id="OE_sc_3_4_surgical_safety_checklist"><text>true</text></outputEntry>
      </rule>

      <!-- ======== TIME_OUT PHASE (Before Incision) ======== -->

      <!-- RULE 4: Time-Out - Site/procedure not confirmed -->
      <rule id="Rule_sc_timeout_no_site_surgical_safety_checklist">
        <description>TIME_OUT: Surgical site and procedure must be confirmed by entire team</description>
        <inputEntry id="IE_sc_4_1_surgical_safety_checklist"><text>"TIME_OUT"</text></inputEntry>
        <inputEntry id="IE_sc_4_2_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_4_3_surgical_safety_checklist"><text>false</text></inputEntry>
        <inputEntry id="IE_sc_4_4_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_4_5_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_4_6_surgical_safety_checklist"><text>-</text></inputEntry>
        <outputEntry id="OE_sc_4_1_surgical_safety_checklist"><text>false</text></outputEntry>
        <outputEntry id="OE_sc_4_2_surgical_safety_checklist"><text>"Sitio/procedimento nao confirmado pela equipe (TIME_OUT)"</text></outputEntry>
        <outputEntry id="OE_sc_4_3_surgical_safety_checklist"><text>0</text></outputEntry>
        <outputEntry id="OE_sc_4_4_surgical_safety_checklist"><text>false</text></outputEntry>
      </rule>

      <!-- RULE 5: Time-Out - Equipment check failed -->
      <rule id="Rule_sc_timeout_no_equipment_surgical_safety_checklist">
        <description>TIME_OUT: Equipment and instruments must be verified</description>
        <inputEntry id="IE_sc_5_1_surgical_safety_checklist"><text>"TIME_OUT"</text></inputEntry>
        <inputEntry id="IE_sc_5_2_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_5_3_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_5_4_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_5_5_surgical_safety_checklist"><text>false</text></inputEntry>
        <inputEntry id="IE_sc_5_6_surgical_safety_checklist"><text>-</text></inputEntry>
        <outputEntry id="OE_sc_5_1_surgical_safety_checklist"><text>false</text></outputEntry>
        <outputEntry id="OE_sc_5_2_surgical_safety_checklist"><text>"Verificacao de equipamentos falhou (TIME_OUT)"</text></outputEntry>
        <outputEntry id="OE_sc_5_3_surgical_safety_checklist"><text>25</text></outputEntry>
        <outputEntry id="OE_sc_5_4_surgical_safety_checklist"><text>false</text></outputEntry>
      </rule>

      <!-- RULE 6: Time-Out - All checks passed -->
      <rule id="Rule_sc_timeout_ok_surgical_safety_checklist">
        <description>TIME_OUT: All time-out checks passed - safe to proceed</description>
        <inputEntry id="IE_sc_6_1_surgical_safety_checklist"><text>"TIME_OUT"</text></inputEntry>
        <inputEntry id="IE_sc_6_2_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_6_3_surgical_safety_checklist"><text>true</text></inputEntry>
        <inputEntry id="IE_sc_6_4_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_6_5_surgical_safety_checklist"><text>true</text></inputEntry>
        <inputEntry id="IE_sc_6_6_surgical_safety_checklist"><text>-</text></inputEntry>
        <outputEntry id="OE_sc_6_1_surgical_safety_checklist"><text>true</text></outputEntry>
        <outputEntry id="OE_sc_6_2_surgical_safety_checklist"><text>""</text></outputEntry>
        <outputEntry id="OE_sc_6_3_surgical_safety_checklist"><text>100</text></outputEntry>
        <outputEntry id="OE_sc_6_4_surgical_safety_checklist"><text>true</text></outputEntry>
      </rule>

      <!-- ======== SIGN_OUT PHASE (Before Leaving OR) ======== -->

      <!-- RULE 7: Sign-Out - Instrument count incorrect -->
      <rule id="Rule_sc_signout_no_count_surgical_safety_checklist">
        <description>SIGN_OUT: Instrument and sponge count MUST be correct before closure</description>
        <inputEntry id="IE_sc_7_1_surgical_safety_checklist"><text>"SIGN_OUT"</text></inputEntry>
        <inputEntry id="IE_sc_7_2_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_7_3_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_7_4_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_7_5_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_7_6_surgical_safety_checklist"><text>false</text></inputEntry>
        <outputEntry id="OE_sc_7_1_surgical_safety_checklist"><text>false</text></outputEntry>
        <outputEntry id="OE_sc_7_2_surgical_safety_checklist"><text>"CRITICO: Contagem de instrumentais/compressas incorreta (SIGN_OUT)"</text></outputEntry>
        <outputEntry id="OE_sc_7_3_surgical_safety_checklist"><text>0</text></outputEntry>
        <outputEntry id="OE_sc_7_4_surgical_safety_checklist"><text>false</text></outputEntry>
      </rule>

      <!-- RULE 8: Sign-Out - All checks passed -->
      <rule id="Rule_sc_signout_ok_surgical_safety_checklist">
        <description>SIGN_OUT: All sign-out checks passed - safe to transfer patient</description>
        <inputEntry id="IE_sc_8_1_surgical_safety_checklist"><text>"SIGN_OUT"</text></inputEntry>
        <inputEntry id="IE_sc_8_2_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_8_3_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_8_4_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_8_5_surgical_safety_checklist"><text>-</text></inputEntry>
        <inputEntry id="IE_sc_8_6_surgical_safety_checklist"><text>true</text></inputEntry>
        <outputEntry id="OE_sc_8_1_surgical_safety_checklist"><text>true</text></outputEntry>
        <outputEntry id="OE_sc_8_2_surgical_safety_checklist"><text>""</text></outputEntry>
        <outputEntry id="OE_sc_8_3_surgical_safety_checklist"><text>100</text></outputEntry>
        <outputEntry id="OE_sc_8_4_surgical_safety_checklist"><text>true</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_surgical_safety_checklist">
      <dmndi:DMNShape id="DMNShape_surgical_safety_checklist" dmnElementRef="Decision_surgical_safety_checklist">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
