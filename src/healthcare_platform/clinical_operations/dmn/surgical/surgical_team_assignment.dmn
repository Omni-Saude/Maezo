<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  Surgical Team Assignment - Team Composition Decision
  ============================================================================
  Determines required surgical team composition based on procedure type,
  specialty needs, and staffing ratios.
  Hit Policy: COLLECT (gather all requirements)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_surgical_team_assignment"
             name="Surgical Team Assignment"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_surgical_team_assignment" name="[SP-CO-007 | surgical] Surgical Team Composition" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_surgical_team_assignment" hitPolicy="COLLECT">

      <!-- INPUT 1: Procedure Type -->
      <input id="Input_st_1_surgical_team_assignment" label="Procedure Type">
        <inputExpression id="InputExpr_st_1_surgical_team_assignment" typeRef="string">
          <text>procedureType</text>
        </inputExpression>
      </input>

      <!-- INPUT 2: Surgeon ID -->
      <input id="Input_st_2_surgical_team_assignment" label="Surgeon ID">
        <inputExpression id="InputExpr_st_2_surgical_team_assignment" typeRef="string">
          <text>surgeonId</text>
        </inputExpression>
      </input>

      <!-- INPUT 3: Anesthesiologist Required -->
      <input id="Input_st_3_surgical_team_assignment" label="Anesthesiologist Required">
        <inputExpression id="InputExpr_st_3_surgical_team_assignment" typeRef="boolean">
          <text>anesthesiologistRequired</text>
        </inputExpression>
      </input>

      <!-- INPUT 4: Nursing Ratio -->
      <input id="Input_st_4_surgical_team_assignment" label="Nursing Ratio">
        <inputExpression id="InputExpr_st_4_surgical_team_assignment" typeRef="string">
          <text>nursingRatio</text>
        </inputExpression>
      </input>

      <!-- INPUT 5: Specialty Needs -->
      <input id="Input_st_5_surgical_team_assignment" label="Specialty Needs">
        <inputExpression id="InputExpr_st_5_surgical_team_assignment" typeRef="string">
          <text>specialtyNeeds</text>
        </inputExpression>
      </input>

      <!-- OUTPUT 1: Required Roles -->
      <output id="Output_st_1_surgical_team_assignment" label="Required Roles" name="requiredRoles" typeRef="string"/>

      <!-- OUTPUT 2: Minimum Staff -->
      <output id="Output_st_2_surgical_team_assignment" label="Minimum Staff" name="minimumStaff" typeRef="number"/>

      <!-- OUTPUT 3: Specialist Types -->
      <output id="Output_st_3_surgical_team_assignment" label="Specialist Types" name="specialistTypes" typeRef="string"/>

      <!-- OUTPUT 4: Team Validation -->
      <output id="Output_st_4_surgical_team_assignment" label="Team Validation" name="teamValidation" typeRef="string">
        <outputValues id="OutputValues_st_4_surgical_team_assignment">
          <text>"VALID", "INCOMPLETE", "NEEDS_SPECIALIST"</text>
        </outputValues>
      </output>

      <!-- RULE 1: Cardiac surgery team -->
      <rule id="Rule_st_cardiac_surgical_team_assignment">
        <description>Cardiac surgery requires full specialized team</description>
        <inputEntry id="IE_st_1_1_surgical_team_assignment"><text>"CARDIAC"</text></inputEntry>
        <inputEntry id="IE_st_1_2_surgical_team_assignment"><text>-</text></inputEntry>
        <inputEntry id="IE_st_1_3_surgical_team_assignment"><text>-</text></inputEntry>
        <inputEntry id="IE_st_1_4_surgical_team_assignment"><text>-</text></inputEntry>
        <inputEntry id="IE_st_1_5_surgical_team_assignment"><text>-</text></inputEntry>
        <outputEntry id="OE_st_1_1_surgical_team_assignment"><text>"cirurgiao-cardiaco,primeiro-auxiliar,anestesiologista-cardiaco,perfusionista,instrumentador,circulante"</text></outputEntry>
        <outputEntry id="OE_st_1_2_surgical_team_assignment"><text>6</text></outputEntry>
        <outputEntry id="OE_st_1_3_surgical_team_assignment"><text>"perfusionista,anestesiologista-cardiaco"</text></outputEntry>
        <outputEntry id="OE_st_1_4_surgical_team_assignment"><text>"NEEDS_SPECIALIST"</text></outputEntry>
      </rule>

      <!-- RULE 2: Neurosurgery team -->
      <rule id="Rule_st_neuro_surgical_team_assignment">
        <description>Neurosurgery requires neuro-anesthesia and monitoring specialist</description>
        <inputEntry id="IE_st_2_1_surgical_team_assignment"><text>"NEUROSURGERY"</text></inputEntry>
        <inputEntry id="IE_st_2_2_surgical_team_assignment"><text>-</text></inputEntry>
        <inputEntry id="IE_st_2_3_surgical_team_assignment"><text>-</text></inputEntry>
        <inputEntry id="IE_st_2_4_surgical_team_assignment"><text>-</text></inputEntry>
        <inputEntry id="IE_st_2_5_surgical_team_assignment"><text>-</text></inputEntry>
        <outputEntry id="OE_st_2_1_surgical_team_assignment"><text>"neurocirurgiao,primeiro-auxiliar,neuro-anestesiologista,neurofisiologista,instrumentador,circulante"</text></outputEntry>
        <outputEntry id="OE_st_2_2_surgical_team_assignment"><text>6</text></outputEntry>
        <outputEntry id="OE_st_2_3_surgical_team_assignment"><text>"neurofisiologista,neuro-anestesiologista"</text></outputEntry>
        <outputEntry id="OE_st_2_4_surgical_team_assignment"><text>"NEEDS_SPECIALIST"</text></outputEntry>
      </rule>

      <!-- RULE 3: Orthopedic surgery -->
      <rule id="Rule_st_ortho_surgical_team_assignment">
        <description>Orthopedic surgery standard team</description>
        <inputEntry id="IE_st_3_1_surgical_team_assignment"><text>"ORTHOPEDIC"</text></inputEntry>
        <inputEntry id="IE_st_3_2_surgical_team_assignment"><text>-</text></inputEntry>
        <inputEntry id="IE_st_3_3_surgical_team_assignment"><text>-</text></inputEntry>
        <inputEntry id="IE_st_3_4_surgical_team_assignment"><text>-</text></inputEntry>
        <inputEntry id="IE_st_3_5_surgical_team_assignment"><text>-</text></inputEntry>
        <outputEntry id="OE_st_3_1_surgical_team_assignment"><text>"cirurgiao-ortopedista,primeiro-auxiliar,anestesiologista,instrumentador,circulante"</text></outputEntry>
        <outputEntry id="OE_st_3_2_surgical_team_assignment"><text>5</text></outputEntry>
        <outputEntry id="OE_st_3_3_surgical_team_assignment"><text>"tecnico-radiologia"</text></outputEntry>
        <outputEntry id="OE_st_3_4_surgical_team_assignment"><text>"VALID"</text></outputEntry>
      </rule>

      <!-- RULE 4: Requires anesthesiologist (general) -->
      <rule id="Rule_st_anesthesia_surgical_team_assignment">
        <description>Any procedure requiring anesthesiologist adds to team</description>
        <inputEntry id="IE_st_4_1_surgical_team_assignment"><text>-</text></inputEntry>
        <inputEntry id="IE_st_4_2_surgical_team_assignment"><text>-</text></inputEntry>
        <inputEntry id="IE_st_4_3_surgical_team_assignment"><text>true</text></inputEntry>
        <inputEntry id="IE_st_4_4_surgical_team_assignment"><text>-</text></inputEntry>
        <inputEntry id="IE_st_4_5_surgical_team_assignment"><text>-</text></inputEntry>
        <outputEntry id="OE_st_4_1_surgical_team_assignment"><text>"anestesiologista"</text></outputEntry>
        <outputEntry id="OE_st_4_2_surgical_team_assignment"><text>1</text></outputEntry>
        <outputEntry id="OE_st_4_3_surgical_team_assignment"><text>"anestesiologista"</text></outputEntry>
        <outputEntry id="OE_st_4_4_surgical_team_assignment"><text>"VALID"</text></outputEntry>
      </rule>

      <!-- RULE 5: High nursing ratio -->
      <rule id="Rule_st_high_nursing_surgical_team_assignment">
        <description>High nursing ratio requires additional nursing staff</description>
        <inputEntry id="IE_st_5_1_surgical_team_assignment"><text>-</text></inputEntry>
        <inputEntry id="IE_st_5_2_surgical_team_assignment"><text>-</text></inputEntry>
        <inputEntry id="IE_st_5_3_surgical_team_assignment"><text>-</text></inputEntry>
        <inputEntry id="IE_st_5_4_surgical_team_assignment"><text>"HIGH"</text></inputEntry>
        <inputEntry id="IE_st_5_5_surgical_team_assignment"><text>-</text></inputEntry>
        <outputEntry id="OE_st_5_1_surgical_team_assignment"><text>"instrumentador,circulante-1,circulante-2"</text></outputEntry>
        <outputEntry id="OE_st_5_2_surgical_team_assignment"><text>3</text></outputEntry>
        <outputEntry id="OE_st_5_3_surgical_team_assignment"><text>""</text></outputEntry>
        <outputEntry id="OE_st_5_4_surgical_team_assignment"><text>"VALID"</text></outputEntry>
      </rule>

      <!-- RULE 6: Fallback - minimum general surgery team -->
      <rule id="Rule_st_fallback_surgical_team_assignment">
        <description>Minimum team for standard general surgery</description>
        <inputEntry id="IE_st_6_1_surgical_team_assignment"><text>-</text></inputEntry>
        <inputEntry id="IE_st_6_2_surgical_team_assignment"><text>-</text></inputEntry>
        <inputEntry id="IE_st_6_3_surgical_team_assignment"><text>-</text></inputEntry>
        <inputEntry id="IE_st_6_4_surgical_team_assignment"><text>-</text></inputEntry>
        <inputEntry id="IE_st_6_5_surgical_team_assignment"><text>-</text></inputEntry>
        <outputEntry id="OE_st_6_1_surgical_team_assignment"><text>"cirurgiao,primeiro-auxiliar,anestesiologista,instrumentador,circulante"</text></outputEntry>
        <outputEntry id="OE_st_6_2_surgical_team_assignment"><text>5</text></outputEntry>
        <outputEntry id="OE_st_6_3_surgical_team_assignment"><text>""</text></outputEntry>
        <outputEntry id="OE_st_6_4_surgical_team_assignment"><text>"VALID"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_surgical_team_assignment">
      <dmndi:DMNShape id="DMNShape_surgical_team_assignment" dmnElementRef="Decision_surgical_team_assignment">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
