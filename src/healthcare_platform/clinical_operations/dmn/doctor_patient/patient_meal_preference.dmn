<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  PATIENT-MEAL-PREFERENCE - Preferencia Alimentar do Paciente
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: PACIENTE (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_PatientMealPreference"
             name="Preferencia Alimentar do Paciente"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_PatientMealPreference" name="[SP-CO-003 | doctor_patient] Decisao Meal Preference" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_PatientMealPreference" hitPolicy="FIRST">

      <input id="Input_dietaryRestrictions_PatientMealPreference" label="Restricoes Dieteticas">
        <inputExpression id="InputExpr_dietaryRestrictions_PatientMealPreference" typeRef="string">
          <text>dietaryRestrictions</text>
        </inputExpression>
        <inputValues><text>"DIABETICO","HIPOSODICO","RENAL","HEPATICO","NENHUMA"</text></inputValues>
      </input>

      <input id="Input_allergyCount_PatientMealPreference" label="Numero de Alergias">
        <inputExpression id="InputExpr_allergyCount_PatientMealPreference" typeRef="number">
          <text>allergyCount</text>
        </inputExpression>
      </input>

      <input id="Input_mealType_PatientMealPreference" label="Tipo de Refeicao">
        <inputExpression id="InputExpr_mealType_PatientMealPreference" typeRef="string">
          <text>mealType</text>
        </inputExpression>
        <inputValues><text>"ORAL","ENTERAL","PARENTERAL","MISTA"</text></inputValues>
      </input>

      <output id="Output_resultado_PatientMealPreference" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_PatientMealPreference" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco_PatientMealPreference" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_MealPref_1_PatientMealPreference">
        <description>Bloqueio: Múltiplas alergias sem revisão nutricional</description>
        <inputEntry id="InputEntry_MealPref_1_1_PatientMealPreference"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MealPref_1_2_PatientMealPreference"><text>&gt; 3</text></inputEntry>
        <inputEntry id="InputEntry_MealPref_1_3_PatientMealPreference"><text>"ORAL","MISTA"</text></inputEntry>
        <outputEntry id="OutputEntry_MealPref_1_resultado_PatientMealPreference"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MealPref_1_acao_PatientMealPreference"><text>"CRÍTICO: Paciente com múltiplas alergias. Avaliar com nutricionista antes de liberar dieta."</text></outputEntry>
        <outputEntry id="OutputEntry_MealPref_1_risco_PatientMealPreference"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_MealPref_2_PatientMealPreference">
        <description>Alerta: Dieta restritiva complexa</description>
        <inputEntry id="InputEntry_MealPref_2_1_PatientMealPreference"><text>"RENAL","HEPATICO"</text></inputEntry>
        <inputEntry id="InputEntry_MealPref_2_2_PatientMealPreference"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MealPref_2_3_PatientMealPreference"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_MealPref_2_resultado_PatientMealPreference"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MealPref_2_acao_PatientMealPreference"><text>"Dieta complexa. Confirmar restrições com equipe de nutrição."</text></outputEntry>
        <outputEntry id="OutputEntry_MealPref_2_risco_PatientMealPreference"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_MealPref_3_PatientMealPreference">
        <description>Alerta: Nutrição enteral/parenteral</description>
        <inputEntry id="InputEntry_MealPref_3_1_PatientMealPreference"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MealPref_3_2_PatientMealPreference"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MealPref_3_3_PatientMealPreference"><text>"ENTERAL","PARENTERAL"</text></inputEntry>
        <outputEntry id="OutputEntry_MealPref_3_resultado_PatientMealPreference"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MealPref_3_acao_PatientMealPreference"><text>"Nutrição especial. Verificar prescrição médica e fórmula adequada."</text></outputEntry>
        <outputEntry id="OutputEntry_MealPref_3_risco_PatientMealPreference"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_MealPref_4_PatientMealPreference">
        <description>Aprovado: Dieta padrão</description>
        <inputEntry id="InputEntry_MealPref_4_1_PatientMealPreference"><text>"NENHUMA","DIABETICO","HIPOSODICO"</text></inputEntry>
        <inputEntry id="InputEntry_MealPref_4_2_PatientMealPreference"><text>&lt;= 1</text></inputEntry>
        <inputEntry id="InputEntry_MealPref_4_3_PatientMealPreference"><text>"ORAL"</text></inputEntry>
        <outputEntry id="OutputEntry_MealPref_4_resultado_PatientMealPreference"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_MealPref_4_acao_PatientMealPreference"><text>"Liberar dieta conforme preferências e restrições registradas."</text></outputEntry>
        <outputEntry id="OutputEntry_MealPref_4_risco_PatientMealPreference"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_MealPref_Fallback_PatientMealPreference">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_MealPref_F_1_PatientMealPreference"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MealPref_F_2_PatientMealPreference"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MealPref_F_3_PatientMealPreference"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_MealPref_F_resultado_PatientMealPreference"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MealPref_F_acao_PatientMealPreference"><text>"Avaliar preferências alimentares manualmente."</text></outputEntry>
        <outputEntry id="OutputEntry_MealPref_F_risco_PatientMealPreference"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PatientMealPreference">
      <dmndi:DMNShape id="DMNShape_Decision_PatientMealPreference" dmnElementRef="Decision_PatientMealPreference">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
