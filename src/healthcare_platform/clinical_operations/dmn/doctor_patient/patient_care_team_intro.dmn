<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  PATIENT-CARE-TEAM-INTRO - Introducao da Equipe de Cuidados ao Paciente
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: PACIENTE (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_PatientCareTeamIntro"
             name="Introducao da Equipe de Cuidados ao Paciente"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_PatientCareTeamIntro" name="[SP-CO-003 | doctor_patient] Decisao Care Team Intro" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_PatientCareTeamIntro" hitPolicy="FIRST">

      <input id="Input_admissionType_PatientCareTeamIntro" label="Tipo de Admissao">
        <inputExpression id="InputExpr_admissionType_PatientCareTeamIntro" typeRef="string">
          <text>admissionType</text>
        </inputExpression>
        <inputValues><text>"UTI","INTERNACAO","AMBULATORIO","EMERGENCIA"</text></inputValues>
      </input>

      <input id="Input_acuityLevel_PatientCareTeamIntro" label="Nivel de Acuidade">
        <inputExpression id="InputExpr_acuityLevel_PatientCareTeamIntro" typeRef="string">
          <text>acuityLevel</text>
        </inputExpression>
        <inputValues><text>"CRITICO","GRAVE","MODERADO","ESTAVEL"</text></inputValues>
      </input>

      <input id="Input_languagePreference_PatientCareTeamIntro" label="Idioma Preferencial">
        <inputExpression id="InputExpr_languagePreference_PatientCareTeamIntro" typeRef="string">
          <text>languagePreference</text>
        </inputExpression>
        <inputValues><text>"PT","EN","ES","OUTROS"</text></inputValues>
      </input>

      <output id="Output_resultado_PatientCareTeamIntro" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_PatientCareTeamIntro" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco_PatientCareTeamIntro" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_CareTeam_1_PatientCareTeamIntro">
        <description>Bloqueio: UTI sem apresentação da equipe</description>
        <inputEntry id="InputEntry_CareTeam_1_1_PatientCareTeamIntro"><text>"UTI"</text></inputEntry>
        <inputEntry id="InputEntry_CareTeam_1_2_PatientCareTeamIntro"><text>"CRITICO"</text></inputEntry>
        <inputEntry id="InputEntry_CareTeam_1_3_PatientCareTeamIntro"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_CareTeam_1_resultado_PatientCareTeamIntro"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CareTeam_1_acao_PatientCareTeamIntro"><text>"URGENTE: Paciente crítico em UTI. Apresentar equipe multiprofissional imediatamente."</text></outputEntry>
        <outputEntry id="OutputEntry_CareTeam_1_risco_PatientCareTeamIntro"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_CareTeam_2_PatientCareTeamIntro">
        <description>Alerta: Barreira de idioma</description>
        <inputEntry id="InputEntry_CareTeam_2_1_PatientCareTeamIntro"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CareTeam_2_2_PatientCareTeamIntro"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CareTeam_2_3_PatientCareTeamIntro"><text>"EN","ES","OUTROS"</text></inputEntry>
        <outputEntry id="OutputEntry_CareTeam_2_resultado_PatientCareTeamIntro"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CareTeam_2_acao_PatientCareTeamIntro"><text>"Providenciar intérprete ou material de apresentação no idioma preferencial."</text></outputEntry>
        <outputEntry id="OutputEntry_CareTeam_2_risco_PatientCareTeamIntro"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_CareTeam_3_PatientCareTeamIntro">
        <description>Alerta: Admissão grave</description>
        <inputEntry id="InputEntry_CareTeam_3_1_PatientCareTeamIntro"><text>"INTERNACAO","EMERGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_CareTeam_3_2_PatientCareTeamIntro"><text>"GRAVE"</text></inputEntry>
        <inputEntry id="InputEntry_CareTeam_3_3_PatientCareTeamIntro"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_CareTeam_3_resultado_PatientCareTeamIntro"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CareTeam_3_acao_PatientCareTeamIntro"><text>"Apresentar equipe e plano de cuidados em até 2 horas da admissão."</text></outputEntry>
        <outputEntry id="OutputEntry_CareTeam_3_risco_PatientCareTeamIntro"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_CareTeam_4_PatientCareTeamIntro">
        <description>Aprovado: Admissão eletiva</description>
        <inputEntry id="InputEntry_CareTeam_4_1_PatientCareTeamIntro"><text>"AMBULATORIO","INTERNACAO"</text></inputEntry>
        <inputEntry id="InputEntry_CareTeam_4_2_PatientCareTeamIntro"><text>"ESTAVEL","MODERADO"</text></inputEntry>
        <inputEntry id="InputEntry_CareTeam_4_3_PatientCareTeamIntro"><text>"PT"</text></inputEntry>
        <outputEntry id="OutputEntry_CareTeam_4_resultado_PatientCareTeamIntro"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_CareTeam_4_acao_PatientCareTeamIntro"><text>"Apresentar equipe de cuidados conforme rotina padrão."</text></outputEntry>
        <outputEntry id="OutputEntry_CareTeam_4_risco_PatientCareTeamIntro"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_CareTeam_Fallback_PatientCareTeamIntro">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_CareTeam_F_1_PatientCareTeamIntro"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CareTeam_F_2_PatientCareTeamIntro"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CareTeam_F_3_PatientCareTeamIntro"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_CareTeam_F_resultado_PatientCareTeamIntro"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CareTeam_F_acao_PatientCareTeamIntro"><text>"Avaliar necessidade de apresentação da equipe."</text></outputEntry>
        <outputEntry id="OutputEntry_CareTeam_F_risco_PatientCareTeamIntro"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PatientCareTeamIntro">
      <dmndi:DMNShape id="DMNShape_Decision_PatientCareTeamIntro" dmnElementRef="Decision_PatientCareTeamIntro">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
