<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DOCTOR-PERFORMANCE-SUMMARY - Resumo de Performance do Medico
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DoctorPerformanceSummary"
             name="Resumo de Performance do Medico"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DoctorPerformanceSummary" name="[SP-CO-003 | doctor_patient] Decisao Performance Summary" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DoctorPerformanceSummary" hitPolicy="FIRST">

      <input id="Input_patientVolume_DoctorPerformanceSummary" label="Volume de Pacientes">
        <inputExpression id="InputExpr_patientVolume_DoctorPerformanceSummary" typeRef="number">
          <text>patientVolume</text>
        </inputExpression>
      </input>

      <input id="Input_outcomeScore_DoctorPerformanceSummary" label="Score de Desfecho (0-100)">
        <inputExpression id="InputExpr_outcomeScore_DoctorPerformanceSummary" typeRef="number">
          <text>outcomeScore</text>
        </inputExpression>
      </input>

      <input id="Input_complianceRate_DoctorPerformanceSummary" label="Taxa de Conformidade (%)">
        <inputExpression id="InputExpr_complianceRate_DoctorPerformanceSummary" typeRef="number">
          <text>complianceRate</text>
        </inputExpression>
      </input>

      <output id="Output_resultado_DoctorPerformanceSummary" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_DoctorPerformanceSummary" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco_DoctorPerformanceSummary" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_PerfSumm_1_DoctorPerformanceSummary">
        <description>Bloqueio: Performance crítica</description>
        <inputEntry id="InputEntry_PerfSumm_1_1_DoctorPerformanceSummary"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PerfSumm_1_2_DoctorPerformanceSummary"><text>&lt; 60</text></inputEntry>
        <inputEntry id="InputEntry_PerfSumm_1_3_DoctorPerformanceSummary"><text>&lt; 70</text></inputEntry>
        <outputEntry id="OutputEntry_PerfSumm_1_resultado_DoctorPerformanceSummary"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_PerfSumm_1_acao_DoctorPerformanceSummary"><text>"CRÍTICO: Performance abaixo do aceitável. Acionar coordenação médica para plano de melhoria."</text></outputEntry>
        <outputEntry id="OutputEntry_PerfSumm_1_risco_DoctorPerformanceSummary"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_PerfSumm_2_DoctorPerformanceSummary">
        <description>Alerta: Volume excessivo com queda de qualidade</description>
        <inputEntry id="InputEntry_PerfSumm_2_1_DoctorPerformanceSummary"><text>&gt; 50</text></inputEntry>
        <inputEntry id="InputEntry_PerfSumm_2_2_DoctorPerformanceSummary"><text>&lt; 75</text></inputEntry>
        <inputEntry id="InputEntry_PerfSumm_2_3_DoctorPerformanceSummary"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_PerfSumm_2_resultado_DoctorPerformanceSummary"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_PerfSumm_2_acao_DoctorPerformanceSummary"><text>"Volume alto com queda de qualidade. Avaliar redistribuição de carga."</text></outputEntry>
        <outputEntry id="OutputEntry_PerfSumm_2_risco_DoctorPerformanceSummary"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_PerfSumm_3_DoctorPerformanceSummary">
        <description>Alerta: Conformidade baixa</description>
        <inputEntry id="InputEntry_PerfSumm_3_1_DoctorPerformanceSummary"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PerfSumm_3_2_DoctorPerformanceSummary"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PerfSumm_3_3_DoctorPerformanceSummary"><text>&lt; 80</text></inputEntry>
        <outputEntry id="OutputEntry_PerfSumm_3_resultado_DoctorPerformanceSummary"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_PerfSumm_3_acao_DoctorPerformanceSummary"><text>"Taxa de conformidade abaixo da meta. Revisar protocolos e oferecer treinamento."</text></outputEntry>
        <outputEntry id="OutputEntry_PerfSumm_3_risco_DoctorPerformanceSummary"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_PerfSumm_4_DoctorPerformanceSummary">
        <description>Aprovado: Performance excelente</description>
        <inputEntry id="InputEntry_PerfSumm_4_1_DoctorPerformanceSummary"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PerfSumm_4_2_DoctorPerformanceSummary"><text>&gt;= 85</text></inputEntry>
        <inputEntry id="InputEntry_PerfSumm_4_3_DoctorPerformanceSummary"><text>&gt;= 90</text></inputEntry>
        <outputEntry id="OutputEntry_PerfSumm_4_resultado_DoctorPerformanceSummary"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_PerfSumm_4_acao_DoctorPerformanceSummary"><text>"Performance excelente. Reconhecer boas práticas."</text></outputEntry>
        <outputEntry id="OutputEntry_PerfSumm_4_risco_DoctorPerformanceSummary"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_PerfSumm_Fallback_DoctorPerformanceSummary">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_PerfSumm_F_1_DoctorPerformanceSummary"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PerfSumm_F_2_DoctorPerformanceSummary"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PerfSumm_F_3_DoctorPerformanceSummary"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_PerfSumm_F_resultado_DoctorPerformanceSummary"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_PerfSumm_F_acao_DoctorPerformanceSummary"><text>"Performance adequada. Manter monitoramento."</text></outputEntry>
        <outputEntry id="OutputEntry_PerfSumm_F_risco_DoctorPerformanceSummary"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorPerformanceSummary">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorPerformanceSummary" dmnElementRef="Decision_DoctorPerformanceSummary">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
