<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_ComorbidityIndex"
             name="Comorbidity Index Calculation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_ComorbidityIndex" name="[SP-CO-003 | doctor_patient] Comorbidity Index Calculation" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_ComorbidityIndex" hitPolicy="FIRST">
      <input id="Input_comorbidity_1_ComorbidityIndex" label="Charlson Comorbidity Index">
        <inputExpression id="InputExpr_comorbidity_1_ComorbidityIndex" typeRef="number"><text>charlsonIndex</text></inputExpression>
      </input>
      <input id="Input_comorbidity_2_ComorbidityIndex" label="Active Comorbidities">
        <inputExpression id="InputExpr_comorbidity_2_ComorbidityIndex" typeRef="number"><text>activeComorbidities</text></inputExpression>
      </input>
      <output id="Output_comorbidity_resultado_ComorbidityIndex" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_comorbidity_acao_ComorbidityIndex" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_comorbidity_risco_ComorbidityIndex" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>
      <rule id="Rule_comorbidity_1_ComorbidityIndex">
        <inputEntry id="IE_comorbidity_1_1_ComorbidityIndex"><text>&gt; 5</text></inputEntry>
        <inputEntry id="IE_comorbidity_1_2_ComorbidityIndex"><text>&gt; 4</text></inputEntry>
        <outputEntry id="OE_comorbidity_1_r_ComorbidityIndex"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_comorbidity_1_a_ComorbidityIndex"><text>"Alto índice de comorbidade - cuidado multidisciplinar obrigatório"</text></outputEntry>
        <outputEntry id="OE_comorbidity_1_ri_ComorbidityIndex"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_comorbidity_2_ComorbidityIndex">
        <inputEntry id="IE_comorbidity_2_1_ComorbidityIndex"><text>[3..5]</text></inputEntry>
        <inputEntry id="IE_comorbidity_2_2_ComorbidityIndex"><text>[2..4]</text></inputEntry>
        <outputEntry id="OE_comorbidity_2_r_ComorbidityIndex"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_comorbidity_2_a_ComorbidityIndex"><text>"Comorbidades moderadas - ajustar plano terapêutico"</text></outputEntry>
        <outputEntry id="OE_comorbidity_2_ri_ComorbidityIndex"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_comorbidity_3_ComorbidityIndex">
        <inputEntry id="IE_comorbidity_3_1_ComorbidityIndex"><text></text></inputEntry>
        <inputEntry id="IE_comorbidity_3_2_ComorbidityIndex"><text></text></inputEntry>
        <outputEntry id="OE_comorbidity_3_r_ComorbidityIndex"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_comorbidity_3_a_ComorbidityIndex"><text>"Baixo índice de comorbidade - protocolo padrão"</text></outputEntry>
        <outputEntry id="OE_comorbidity_3_ri_ComorbidityIndex"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_ComorbidityIndex">
      <dmndi:DMNShape id="DMNShape_Decision_ComorbidityIndex" dmnElementRef="Decision_ComorbidityIndex">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
