<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  PATIENT-TEST-RESULTS - Notificacao de Resultados de Exames ao Paciente
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: PACIENTE (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_PatientTestResults"
             name="Notificacao de Resultados de Exames ao Paciente"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_PatientTestResults" name="[SP-CO-003 | doctor_patient] Decisao Test Results" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_PatientTestResults" hitPolicy="FIRST">

      <input id="Input_testUrgency_PatientTestResults" label="Urgencia do Exame">
        <inputExpression id="InputExpr_testUrgency_PatientTestResults" typeRef="string">
          <text>testUrgency</text>
        </inputExpression>
        <inputValues><text>"STAT","URGENTE","ROTINA"</text></inputValues>
      </input>

      <input id="Input_abnormalFlags_PatientTestResults" label="Numero de Resultados Alterados">
        <inputExpression id="InputExpr_abnormalFlags_PatientTestResults" typeRef="number">
          <text>abnormalFlags</text>
        </inputExpression>
      </input>

      <input id="Input_resultAge_PatientTestResults" label="Idade do Resultado (horas)">
        <inputExpression id="InputExpr_resultAge_PatientTestResults" typeRef="number">
          <text>resultAge</text>
        </inputExpression>
      </input>

      <output id="Output_resultado_PatientTestResults" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_PatientTestResults" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco_PatientTestResults" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_TestRes_1_PatientTestResults">
        <description>Bloqueio: Resultado crítico STAT não notificado</description>
        <inputEntry id="InputEntry_TestRes_1_1_PatientTestResults"><text>"STAT"</text></inputEntry>
        <inputEntry id="InputEntry_TestRes_1_2_PatientTestResults"><text>&gt; 0</text></inputEntry>
        <inputEntry id="InputEntry_TestRes_1_3_PatientTestResults"><text>&gt; 2</text></inputEntry>
        <outputEntry id="OutputEntry_TestRes_1_resultado_PatientTestResults"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_TestRes_1_acao_PatientTestResults"><text>"CRÍTICO: Resultado STAT alterado sem notificação há &gt;2h. Contatar paciente e médico urgentemente."</text></outputEntry>
        <outputEntry id="OutputEntry_TestRes_1_risco_PatientTestResults"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_TestRes_2_PatientTestResults">
        <description>Alerta: Múltiplos resultados alterados</description>
        <inputEntry id="InputEntry_TestRes_2_1_PatientTestResults"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_TestRes_2_2_PatientTestResults"><text>&gt; 3</text></inputEntry>
        <inputEntry id="InputEntry_TestRes_2_3_PatientTestResults"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_TestRes_2_resultado_PatientTestResults"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_TestRes_2_acao_PatientTestResults"><text>"Múltiplos resultados alterados. Médico deve revisar antes de notificar paciente."</text></outputEntry>
        <outputEntry id="OutputEntry_TestRes_2_risco_PatientTestResults"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_TestRes_3_PatientTestResults">
        <description>Alerta: Resultado urgente atrasado</description>
        <inputEntry id="InputEntry_TestRes_3_1_PatientTestResults"><text>"URGENTE"</text></inputEntry>
        <inputEntry id="InputEntry_TestRes_3_2_PatientTestResults"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_TestRes_3_3_PatientTestResults"><text>&gt; 24</text></inputEntry>
        <outputEntry id="OutputEntry_TestRes_3_resultado_PatientTestResults"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_TestRes_3_acao_PatientTestResults"><text>"Resultado urgente não notificado há &gt;24h. Priorizar contato com paciente."</text></outputEntry>
        <outputEntry id="OutputEntry_TestRes_3_risco_PatientTestResults"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_TestRes_4_PatientTestResults">
        <description>Aprovado: Resultado de rotina normal</description>
        <inputEntry id="InputEntry_TestRes_4_1_PatientTestResults"><text>"ROTINA"</text></inputEntry>
        <inputEntry id="InputEntry_TestRes_4_2_PatientTestResults"><text>= 0</text></inputEntry>
        <inputEntry id="InputEntry_TestRes_4_3_PatientTestResults"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_TestRes_4_resultado_PatientTestResults"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_TestRes_4_acao_PatientTestResults"><text>"Notificar paciente sobre resultados normais via portal ou mensagem."</text></outputEntry>
        <outputEntry id="OutputEntry_TestRes_4_risco_PatientTestResults"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_TestRes_Fallback_PatientTestResults">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_TestRes_F_1_PatientTestResults"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_TestRes_F_2_PatientTestResults"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_TestRes_F_3_PatientTestResults"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_TestRes_F_resultado_PatientTestResults"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_TestRes_F_acao_PatientTestResults"><text>"Avaliar forma de notificação ao paciente."</text></outputEntry>
        <outputEntry id="OutputEntry_TestRes_F_risco_PatientTestResults"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PatientTestResults">
      <dmndi:DMNShape id="DMNShape_Decision_PatientTestResults" dmnElementRef="Decision_PatientTestResults">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
