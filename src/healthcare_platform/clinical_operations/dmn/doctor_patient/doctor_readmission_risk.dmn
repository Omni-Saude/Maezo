<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DOCTOR-READMISSION-RISK - Avaliacao de Risco de Readmissao
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DoctorReadmissionRisk"
             name="Avaliacao de Risco de Readmissao"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DoctorReadmissionRisk" name="[SP-CO-003 | doctor_patient] Decisao Readmission Risk" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DoctorReadmissionRisk" hitPolicy="FIRST">

      <input id="Input_riskScore_DoctorReadmissionRisk" label="Score de Risco (0-100)">
        <inputExpression id="InputExpr_riskScore_DoctorReadmissionRisk" typeRef="number">
          <text>riskScore</text>
        </inputExpression>
      </input>

      <input id="Input_daysPostDischarge_DoctorReadmissionRisk" label="Dias Pos-Alta">
        <inputExpression id="InputExpr_daysPostDischarge_DoctorReadmissionRisk" typeRef="number">
          <text>daysPostDischarge</text>
        </inputExpression>
      </input>

      <input id="Input_diagnosisCategory_DoctorReadmissionRisk" label="Categoria Diagnostica">
        <inputExpression id="InputExpr_diagnosisCategory_DoctorReadmissionRisk" typeRef="string">
          <text>diagnosisCategory</text>
        </inputExpression>
        <inputValues><text>"CARDIO","RESPIRATORIO","NEURO","GASTRO","OUTROS"</text></inputValues>
      </input>

      <output id="Output_resultado_DoctorReadmissionRisk" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_DoctorReadmissionRisk" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco_DoctorReadmissionRisk" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_Readm_1_DoctorReadmissionRisk">
        <description>Bloqueio: Alto risco em período crítico</description>
        <inputEntry id="InputEntry_Readm_1_1_DoctorReadmissionRisk"><text>&gt; 75</text></inputEntry>
        <inputEntry id="InputEntry_Readm_1_2_DoctorReadmissionRisk"><text>&lt; 30</text></inputEntry>
        <inputEntry id="InputEntry_Readm_1_3_DoctorReadmissionRisk"><text>"CARDIO","RESPIRATORIO"</text></inputEntry>
        <outputEntry id="OutputEntry_Readm_1_resultado_DoctorReadmissionRisk"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Readm_1_acao_DoctorReadmissionRisk"><text>"CRÍTICO: Alto risco de readmissão em 30 dias. Intensificar acompanhamento ambulatorial."</text></outputEntry>
        <outputEntry id="OutputEntry_Readm_1_risco_DoctorReadmissionRisk"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Readm_2_DoctorReadmissionRisk">
        <description>Alerta: Risco moderado</description>
        <inputEntry id="InputEntry_Readm_2_1_DoctorReadmissionRisk"><text>&gt; 50</text></inputEntry>
        <inputEntry id="InputEntry_Readm_2_2_DoctorReadmissionRisk"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Readm_2_3_DoctorReadmissionRisk"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_Readm_2_resultado_DoctorReadmissionRisk"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Readm_2_acao_DoctorReadmissionRisk"><text>"Risco moderado de readmissão. Agendar consulta de followup e orientação."</text></outputEntry>
        <outputEntry id="OutputEntry_Readm_2_risco_DoctorReadmissionRisk"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Readm_3_DoctorReadmissionRisk">
        <description>Alerta: Janela crítica pós-alta</description>
        <inputEntry id="InputEntry_Readm_3_1_DoctorReadmissionRisk"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Readm_3_2_DoctorReadmissionRisk"><text>&lt; 7</text></inputEntry>
        <inputEntry id="InputEntry_Readm_3_3_DoctorReadmissionRisk"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_Readm_3_resultado_DoctorReadmissionRisk"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Readm_3_acao_DoctorReadmissionRisk"><text>"Período crítico pós-alta. Contactar paciente para verificar evolução."</text></outputEntry>
        <outputEntry id="OutputEntry_Readm_3_risco_DoctorReadmissionRisk"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Readm_4_DoctorReadmissionRisk">
        <description>Aprovado: Baixo risco</description>
        <inputEntry id="InputEntry_Readm_4_1_DoctorReadmissionRisk"><text>&lt;= 40</text></inputEntry>
        <inputEntry id="InputEntry_Readm_4_2_DoctorReadmissionRisk"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Readm_4_3_DoctorReadmissionRisk"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_Readm_4_resultado_DoctorReadmissionRisk"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_Readm_4_acao_DoctorReadmissionRisk"><text>"Baixo risco de readmissão. Acompanhamento de rotina."</text></outputEntry>
        <outputEntry id="OutputEntry_Readm_4_risco_DoctorReadmissionRisk"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Readm_Fallback_DoctorReadmissionRisk">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_Readm_F_1_DoctorReadmissionRisk"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Readm_F_2_DoctorReadmissionRisk"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Readm_F_3_DoctorReadmissionRisk"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_Readm_F_resultado_DoctorReadmissionRisk"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Readm_F_acao_DoctorReadmissionRisk"><text>"Avaliar risco de readmissão manualmente."</text></outputEntry>
        <outputEntry id="OutputEntry_Readm_F_risco_DoctorReadmissionRisk"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorReadmissionRisk">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorReadmissionRisk" dmnElementRef="Decision_DoctorReadmissionRisk">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
