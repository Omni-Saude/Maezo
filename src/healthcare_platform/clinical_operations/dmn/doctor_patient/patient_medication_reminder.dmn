<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  PATIENT-MEDICATION-REMINDER - Lembrete de Medicacao ao Paciente
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: PACIENTE (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_PatientMedicationReminder"
             name="Lembrete de Medicacao ao Paciente"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_PatientMedicationReminder" name="[SP-CO-003 | doctor_patient] Decisao Medication Reminder" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_PatientMedicationReminder" hitPolicy="FIRST">

      <input id="Input_medicationPriority_PatientMedicationReminder" label="Prioridade da Medicacao">
        <inputExpression id="InputExpr_medicationPriority_PatientMedicationReminder" typeRef="string">
          <text>medicationPriority</text>
        </inputExpression>
        <inputValues><text>"CRITICA","ALTA","MEDIA","BAIXA"</text></inputValues>
      </input>

      <input id="Input_hoursUntilDose_PatientMedicationReminder" label="Horas ate Proxima Dose">
        <inputExpression id="InputExpr_hoursUntilDose_PatientMedicationReminder" typeRef="number">
          <text>hoursUntilDose</text>
        </inputExpression>
      </input>

      <input id="Input_interactionRisk_PatientMedicationReminder" label="Risco de Interacao">
        <inputExpression id="InputExpr_interactionRisk_PatientMedicationReminder" typeRef="string">
          <text>interactionRisk</text>
        </inputExpression>
        <inputValues><text>"ALTO","MEDIO","BAIXO"</text></inputValues>
      </input>

      <output id="Output_resultado_PatientMedicationReminder" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_PatientMedicationReminder" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco_PatientMedicationReminder" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_MedRem_1_PatientMedicationReminder">
        <description>Bloqueio: Medicação crítica atrasada</description>
        <inputEntry id="InputEntry_MedRem_1_1_PatientMedicationReminder"><text>"CRITICA"</text></inputEntry>
        <inputEntry id="InputEntry_MedRem_1_2_PatientMedicationReminder"><text>&lt; 0</text></inputEntry>
        <inputEntry id="InputEntry_MedRem_1_3_PatientMedicationReminder"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_MedRem_1_resultado_PatientMedicationReminder"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MedRem_1_acao_PatientMedicationReminder"><text>"URGENTE: Medicação crítica atrasada. Notificar paciente e equipe médica imediatamente."</text></outputEntry>
        <outputEntry id="OutputEntry_MedRem_1_risco_PatientMedicationReminder"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_MedRem_2_PatientMedicationReminder">
        <description>Alerta: Alto risco de interação</description>
        <inputEntry id="InputEntry_MedRem_2_1_PatientMedicationReminder"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MedRem_2_2_PatientMedicationReminder"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MedRem_2_3_PatientMedicationReminder"><text>"ALTO"</text></inputEntry>
        <outputEntry id="OutputEntry_MedRem_2_resultado_PatientMedicationReminder"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MedRem_2_acao_PatientMedicationReminder"><text>"Lembrete com aviso sobre interações. Orientar intervalo adequado entre medicações."</text></outputEntry>
        <outputEntry id="OutputEntry_MedRem_2_risco_PatientMedicationReminder"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_MedRem_3_PatientMedicationReminder">
        <description>Alerta: Medicação de alta prioridade próxima</description>
        <inputEntry id="InputEntry_MedRem_3_1_PatientMedicationReminder"><text>"ALTA"</text></inputEntry>
        <inputEntry id="InputEntry_MedRem_3_2_PatientMedicationReminder"><text>&lt; 2</text></inputEntry>
        <inputEntry id="InputEntry_MedRem_3_3_PatientMedicationReminder"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_MedRem_3_resultado_PatientMedicationReminder"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MedRem_3_acao_PatientMedicationReminder"><text>"Lembrete urgente. Medicação de alta prioridade em menos de 2 horas."</text></outputEntry>
        <outputEntry id="OutputEntry_MedRem_3_risco_PatientMedicationReminder"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_MedRem_4_PatientMedicationReminder">
        <description>Aprovado: Lembrete de rotina</description>
        <inputEntry id="InputEntry_MedRem_4_1_PatientMedicationReminder"><text>"MEDIA","BAIXA"</text></inputEntry>
        <inputEntry id="InputEntry_MedRem_4_2_PatientMedicationReminder"><text>&gt;= 1</text></inputEntry>
        <inputEntry id="InputEntry_MedRem_4_3_PatientMedicationReminder"><text>"BAIXO"</text></inputEntry>
        <outputEntry id="OutputEntry_MedRem_4_resultado_PatientMedicationReminder"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_MedRem_4_acao_PatientMedicationReminder"><text>"Enviar lembrete de medicação conforme horário programado."</text></outputEntry>
        <outputEntry id="OutputEntry_MedRem_4_risco_PatientMedicationReminder"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_MedRem_Fallback_PatientMedicationReminder">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_MedRem_F_1_PatientMedicationReminder"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MedRem_F_2_PatientMedicationReminder"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MedRem_F_3_PatientMedicationReminder"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_MedRem_F_resultado_PatientMedicationReminder"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MedRem_F_acao_PatientMedicationReminder"><text>"Avaliar necessidade de lembrete."</text></outputEntry>
        <outputEntry id="OutputEntry_MedRem_F_risco_PatientMedicationReminder"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PatientMedicationReminder">
      <dmndi:DMNShape id="DMNShape_Decision_PatientMedicationReminder" dmnElementRef="Decision_PatientMedicationReminder">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
