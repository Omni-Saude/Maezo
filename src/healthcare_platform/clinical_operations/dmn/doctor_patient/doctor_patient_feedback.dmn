<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DOCTOR-PATIENT-FEEDBACK - Processamento de Feedback do Paciente
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DoctorPatientFeedback"
             name="Processamento de Feedback do Paciente"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DoctorPatientFeedback" name="[SP-CO-003 | doctor_patient] Decisao Patient Feedback" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DoctorPatientFeedback" hitPolicy="FIRST">

      <input id="Input_feedbackScore_DoctorPatientFeedback" label="Score do Feedback (0-10)">
        <inputExpression id="InputExpr_feedbackScore_DoctorPatientFeedback" typeRef="number">
          <text>feedbackScore</text>
        </inputExpression>
      </input>

      <input id="Input_feedbackCategory_DoctorPatientFeedback" label="Categoria do Feedback">
        <inputExpression id="InputExpr_feedbackCategory_DoctorPatientFeedback" typeRef="string">
          <text>feedbackCategory</text>
        </inputExpression>
        <inputValues><text>"ATENDIMENTO","COMUNICACAO","INSTALACOES","MEDICACAO","OUTROS"</text></inputValues>
      </input>

      <input id="Input_responseTime_DoctorPatientFeedback" label="Tempo para Resposta (horas)">
        <inputExpression id="InputExpr_responseTime_DoctorPatientFeedback" typeRef="number">
          <text>responseTime</text>
        </inputExpression>
      </input>

      <output id="Output_resultado_DoctorPatientFeedback" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_DoctorPatientFeedback" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco_DoctorPatientFeedback" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_PatFeed_1_DoctorPatientFeedback">
        <description>Bloqueio: Feedback crítico sem resposta</description>
        <inputEntry id="InputEntry_PatFeed_1_1_DoctorPatientFeedback"><text>&lt;= 3</text></inputEntry>
        <inputEntry id="InputEntry_PatFeed_1_2_DoctorPatientFeedback"><text>"ATENDIMENTO","MEDICACAO"</text></inputEntry>
        <inputEntry id="InputEntry_PatFeed_1_3_DoctorPatientFeedback"><text>&gt; 24</text></inputEntry>
        <outputEntry id="OutputEntry_PatFeed_1_resultado_DoctorPatientFeedback"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_PatFeed_1_acao_DoctorPatientFeedback"><text>"URGENTE: Feedback crítico sem resposta em 24h. Acionar gerência imediatamente."</text></outputEntry>
        <outputEntry id="OutputEntry_PatFeed_1_risco_DoctorPatientFeedback"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_PatFeed_2_DoctorPatientFeedback">
        <description>Alerta: Score baixo</description>
        <inputEntry id="InputEntry_PatFeed_2_1_DoctorPatientFeedback"><text>&lt;= 5</text></inputEntry>
        <inputEntry id="InputEntry_PatFeed_2_2_DoctorPatientFeedback"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PatFeed_2_3_DoctorPatientFeedback"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_PatFeed_2_resultado_DoctorPatientFeedback"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_PatFeed_2_acao_DoctorPatientFeedback"><text>"Feedback negativo. Contatar paciente em até 12h para entender queixa."</text></outputEntry>
        <outputEntry id="OutputEntry_PatFeed_2_risco_DoctorPatientFeedback"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_PatFeed_3_DoctorPatientFeedback">
        <description>Alerta: Resposta atrasada</description>
        <inputEntry id="InputEntry_PatFeed_3_1_DoctorPatientFeedback"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PatFeed_3_2_DoctorPatientFeedback"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PatFeed_3_3_DoctorPatientFeedback"><text>&gt; 48</text></inputEntry>
        <outputEntry id="OutputEntry_PatFeed_3_resultado_DoctorPatientFeedback"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_PatFeed_3_acao_DoctorPatientFeedback"><text>"Resposta atrasada. Priorizar contato com paciente."</text></outputEntry>
        <outputEntry id="OutputEntry_PatFeed_3_risco_DoctorPatientFeedback"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_PatFeed_4_DoctorPatientFeedback">
        <description>Aprovado: Feedback positivo</description>
        <inputEntry id="InputEntry_PatFeed_4_1_DoctorPatientFeedback"><text>&gt;= 8</text></inputEntry>
        <inputEntry id="InputEntry_PatFeed_4_2_DoctorPatientFeedback"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PatFeed_4_3_DoctorPatientFeedback"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_PatFeed_4_resultado_DoctorPatientFeedback"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_PatFeed_4_acao_DoctorPatientFeedback"><text>"Feedback positivo. Agradecer paciente e documentar."</text></outputEntry>
        <outputEntry id="OutputEntry_PatFeed_4_risco_DoctorPatientFeedback"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_PatFeed_Fallback_DoctorPatientFeedback">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_PatFeed_F_1_DoctorPatientFeedback"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PatFeed_F_2_DoctorPatientFeedback"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_PatFeed_F_3_DoctorPatientFeedback"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_PatFeed_F_resultado_DoctorPatientFeedback"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_PatFeed_F_acao_DoctorPatientFeedback"><text>"Registrar feedback e avaliar necessidade de resposta."</text></outputEntry>
        <outputEntry id="OutputEntry_PatFeed_F_risco_DoctorPatientFeedback"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorPatientFeedback">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorPatientFeedback" dmnElementRef="Decision_DoctorPatientFeedback">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
