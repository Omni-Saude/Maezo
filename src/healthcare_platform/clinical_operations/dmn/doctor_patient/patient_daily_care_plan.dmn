<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  PATIENT-DAILY-CARE-PLAN - Plano de Cuidados Diario do Paciente
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: PACIENTE (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_PatientDailyCarePlan"
             name="Plano de Cuidados Diario do Paciente"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_PatientDailyCarePlan" name="[SP-CO-003 | doctor_patient] Decisao Daily Care Plan" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_PatientDailyCarePlan" hitPolicy="FIRST">

      <input id="Input_planComplexity_PatientDailyCarePlan" label="Complexidade do Plano">
        <inputExpression id="InputExpr_planComplexity_PatientDailyCarePlan" typeRef="string">
          <text>planComplexity</text>
        </inputExpression>
        <inputValues><text>"ALTA","MEDIA","BAIXA"</text></inputValues>
      </input>

      <input id="Input_activeMedications_PatientDailyCarePlan" label="Medicacoes Ativas">
        <inputExpression id="InputExpr_activeMedications_PatientDailyCarePlan" typeRef="number">
          <text>activeMedications</text>
        </inputExpression>
      </input>

      <input id="Input_pendingTests_PatientDailyCarePlan" label="Exames Pendentes">
        <inputExpression id="InputExpr_pendingTests_PatientDailyCarePlan" typeRef="number">
          <text>pendingTests</text>
        </inputExpression>
      </input>

      <output id="Output_resultado_PatientDailyCarePlan" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_PatientDailyCarePlan" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco_PatientDailyCarePlan" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_DailyCare_1_PatientDailyCarePlan">
        <description>Bloqueio: Plano complexo com muitos pendentes</description>
        <inputEntry id="InputEntry_DailyCare_1_1_PatientDailyCarePlan"><text>"ALTA"</text></inputEntry>
        <inputEntry id="InputEntry_DailyCare_1_2_PatientDailyCarePlan"><text>&gt; 10</text></inputEntry>
        <inputEntry id="InputEntry_DailyCare_1_3_PatientDailyCarePlan"><text>&gt; 5</text></inputEntry>
        <outputEntry id="OutputEntry_DailyCare_1_resultado_PatientDailyCarePlan"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_DailyCare_1_acao_PatientDailyCarePlan"><text>"Plano de cuidados complexo. Revisar com equipe multiprofissional antes de compartilhar."</text></outputEntry>
        <outputEntry id="OutputEntry_DailyCare_1_risco_PatientDailyCarePlan"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_DailyCare_2_PatientDailyCarePlan">
        <description>Alerta: Muitas medicações</description>
        <inputEntry id="InputEntry_DailyCare_2_1_PatientDailyCarePlan"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DailyCare_2_2_PatientDailyCarePlan"><text>&gt; 8</text></inputEntry>
        <inputEntry id="InputEntry_DailyCare_2_3_PatientDailyCarePlan"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DailyCare_2_resultado_PatientDailyCarePlan"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_DailyCare_2_acao_PatientDailyCarePlan"><text>"Polifarmácia detectada. Revisar interações e simplificar plano se possível."</text></outputEntry>
        <outputEntry id="OutputEntry_DailyCare_2_risco_PatientDailyCarePlan"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_DailyCare_3_PatientDailyCarePlan">
        <description>Alerta: Muitos exames pendentes</description>
        <inputEntry id="InputEntry_DailyCare_3_1_PatientDailyCarePlan"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DailyCare_3_2_PatientDailyCarePlan"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DailyCare_3_3_PatientDailyCarePlan"><text>&gt; 4</text></inputEntry>
        <outputEntry id="OutputEntry_DailyCare_3_resultado_PatientDailyCarePlan"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_DailyCare_3_acao_PatientDailyCarePlan"><text>"Muitos exames pendentes. Priorizar e agendar conforme urgência."</text></outputEntry>
        <outputEntry id="OutputEntry_DailyCare_3_risco_PatientDailyCarePlan"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_DailyCare_4_PatientDailyCarePlan">
        <description>Aprovado: Plano simples</description>
        <inputEntry id="InputEntry_DailyCare_4_1_PatientDailyCarePlan"><text>"BAIXA","MEDIA"</text></inputEntry>
        <inputEntry id="InputEntry_DailyCare_4_2_PatientDailyCarePlan"><text>&lt;= 5</text></inputEntry>
        <inputEntry id="InputEntry_DailyCare_4_3_PatientDailyCarePlan"><text>&lt;= 2</text></inputEntry>
        <outputEntry id="OutputEntry_DailyCare_4_resultado_PatientDailyCarePlan"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_DailyCare_4_acao_PatientDailyCarePlan"><text>"Compartilhar plano de cuidados diário com paciente."</text></outputEntry>
        <outputEntry id="OutputEntry_DailyCare_4_risco_PatientDailyCarePlan"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_DailyCare_Fallback_PatientDailyCarePlan">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_DailyCare_F_1_PatientDailyCarePlan"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DailyCare_F_2_PatientDailyCarePlan"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DailyCare_F_3_PatientDailyCarePlan"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DailyCare_F_resultado_PatientDailyCarePlan"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_DailyCare_F_acao_PatientDailyCarePlan"><text>"Avaliar plano de cuidados antes de compartilhar."</text></outputEntry>
        <outputEntry id="OutputEntry_DailyCare_F_risco_PatientDailyCarePlan"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PatientDailyCarePlan">
      <dmndi:DMNShape id="DMNShape_Decision_PatientDailyCarePlan" dmnElementRef="Decision_PatientDailyCarePlan">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
