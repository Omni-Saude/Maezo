<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DOCTOR-CRITICAL-VALUE - Notificacao de Valor Critico Laboratorial
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DoctorCriticalValue"
             name="Notificacao de Valor Critico Laboratorial"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DoctorCriticalValue" name="[SP-CO-003 | doctor_patient] Decisao Valor Critico" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DoctorCriticalValue" hitPolicy="FIRST">

      <input id="Input_labValueType_DoctorCriticalValue" label="Tipo de Valor Laboratorial">
        <inputExpression id="InputExpr_labValueType_DoctorCriticalValue" typeRef="string">
          <text>labValueType</text>
        </inputExpression>
        <inputValues><text>"POTASSIO","GLICOSE","HEMOGLOBINA","TROPONINA","CREATININA","SODIO"</text></inputValues>
      </input>

      <input id="Input_deviationPercent_DoctorCriticalValue" label="Desvio do Normal (%)">
        <inputExpression id="InputExpr_deviationPercent_DoctorCriticalValue" typeRef="number">
          <text>deviationPercent</text>
        </inputExpression>
      </input>

      <input id="Input_patientAcuity_DoctorCriticalValue" label="Acuidade do Paciente">
        <inputExpression id="InputExpr_patientAcuity_DoctorCriticalValue" typeRef="string">
          <text>patientAcuity</text>
        </inputExpression>
        <inputValues><text>"CRITICO","GRAVE","MODERADO","ESTAVEL"</text></inputValues>
      </input>

      <output id="Output_resultado_DoctorCriticalValue" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_DoctorCriticalValue" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco_DoctorCriticalValue" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_CritVal_1_DoctorCriticalValue">
        <description>Bloqueio: Valor crítico em paciente crítico</description>
        <inputEntry id="InputEntry_CritVal_1_1_DoctorCriticalValue"><text>"POTASSIO","TROPONINA"</text></inputEntry>
        <inputEntry id="InputEntry_CritVal_1_2_DoctorCriticalValue"><text>&gt; 50</text></inputEntry>
        <inputEntry id="InputEntry_CritVal_1_3_DoctorCriticalValue"><text>"CRITICO"</text></inputEntry>
        <outputEntry id="OutputEntry_CritVal_1_resultado_DoctorCriticalValue"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CritVal_1_acao_DoctorCriticalValue"><text>"EMERGÊNCIA: Notificar médico IMEDIATAMENTE. Valor crítico em paciente crítico."</text></outputEntry>
        <outputEntry id="OutputEntry_CritVal_1_risco_DoctorCriticalValue"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_CritVal_2_DoctorCriticalValue">
        <description>Alerta: Desvio severo</description>
        <inputEntry id="InputEntry_CritVal_2_1_DoctorCriticalValue"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CritVal_2_2_DoctorCriticalValue"><text>&gt; 40</text></inputEntry>
        <inputEntry id="InputEntry_CritVal_2_3_DoctorCriticalValue"><text>"GRAVE","MODERADO"</text></inputEntry>
        <outputEntry id="OutputEntry_CritVal_2_resultado_DoctorCriticalValue"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CritVal_2_acao_DoctorCriticalValue"><text>"Notificar médico em até 30 minutos. Desvio significativo detectado."</text></outputEntry>
        <outputEntry id="OutputEntry_CritVal_2_risco_DoctorCriticalValue"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_CritVal_3_DoctorCriticalValue">
        <description>Alerta: Glicose ou sódio alterado</description>
        <inputEntry id="InputEntry_CritVal_3_1_DoctorCriticalValue"><text>"GLICOSE","SODIO"</text></inputEntry>
        <inputEntry id="InputEntry_CritVal_3_2_DoctorCriticalValue"><text>&gt; 30</text></inputEntry>
        <inputEntry id="InputEntry_CritVal_3_3_DoctorCriticalValue"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_CritVal_3_resultado_DoctorCriticalValue"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CritVal_3_acao_DoctorCriticalValue"><text>"Notificar médico. Avaliar necessidade de intervenção."</text></outputEntry>
        <outputEntry id="OutputEntry_CritVal_3_risco_DoctorCriticalValue"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_CritVal_4_DoctorCriticalValue">
        <description>Aprovado: Desvio leve em paciente estável</description>
        <inputEntry id="InputEntry_CritVal_4_1_DoctorCriticalValue"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CritVal_4_2_DoctorCriticalValue"><text>&lt;= 30</text></inputEntry>
        <inputEntry id="InputEntry_CritVal_4_3_DoctorCriticalValue"><text>"ESTAVEL"</text></inputEntry>
        <outputEntry id="OutputEntry_CritVal_4_resultado_DoctorCriticalValue"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_CritVal_4_acao_DoctorCriticalValue"><text>"Registrar resultado. Notificação de rotina ao médico."</text></outputEntry>
        <outputEntry id="OutputEntry_CritVal_4_risco_DoctorCriticalValue"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_CritVal_Fallback_DoctorCriticalValue">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_CritVal_F_1_DoctorCriticalValue"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CritVal_F_2_DoctorCriticalValue"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CritVal_F_3_DoctorCriticalValue"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_CritVal_F_resultado_DoctorCriticalValue"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CritVal_F_acao_DoctorCriticalValue"><text>"Avaliar resultado manualmente."</text></outputEntry>
        <outputEntry id="OutputEntry_CritVal_F_risco_DoctorCriticalValue"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorCriticalValue">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorCriticalValue" dmnElementRef="Decision_DoctorCriticalValue">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
