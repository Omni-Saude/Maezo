<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DOCTOR-ROUNDS-SUMMARY - Resumo de Visitas Medicas
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DoctorRoundsSummary"
             name="Resumo de Visitas Medicas"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DoctorRoundsSummary" name="[SP-CO-003 | doctor_patient] Decisao Rounds Summary" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DoctorRoundsSummary" hitPolicy="FIRST">

      <input id="Input_patientCount_DoctorRoundsSummary" label="Total de Pacientes">
        <inputExpression id="InputExpr_patientCount_DoctorRoundsSummary" typeRef="number">
          <text>patientCount</text>
        </inputExpression>
      </input>

      <input id="Input_criticalPatients_DoctorRoundsSummary" label="Pacientes Criticos">
        <inputExpression id="InputExpr_criticalPatients_DoctorRoundsSummary" typeRef="number">
          <text>criticalPatients</text>
        </inputExpression>
      </input>

      <input id="Input_pendingDecisions_DoctorRoundsSummary" label="Decisoes Pendentes">
        <inputExpression id="InputExpr_pendingDecisions_DoctorRoundsSummary" typeRef="number">
          <text>pendingDecisions</text>
        </inputExpression>
      </input>

      <output id="Output_resultado_DoctorRoundsSummary" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_DoctorRoundsSummary" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco_DoctorRoundsSummary" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_Rounds_1_DoctorRoundsSummary">
        <description>Bloqueio: Muitos críticos com decisões pendentes</description>
        <inputEntry id="InputEntry_Rounds_1_1_DoctorRoundsSummary"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Rounds_1_2_DoctorRoundsSummary"><text>&gt; 5</text></inputEntry>
        <inputEntry id="InputEntry_Rounds_1_3_DoctorRoundsSummary"><text>&gt; 10</text></inputEntry>
        <outputEntry id="OutputEntry_Rounds_1_resultado_DoctorRoundsSummary"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Rounds_1_acao_DoctorRoundsSummary"><text>"CRÍTICO: Múltiplos pacientes críticos com decisões pendentes. Priorizar rounds urgentes."</text></outputEntry>
        <outputEntry id="OutputEntry_Rounds_1_risco_DoctorRoundsSummary"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Rounds_2_DoctorRoundsSummary">
        <description>Alerta: Volume alto de pacientes</description>
        <inputEntry id="InputEntry_Rounds_2_1_DoctorRoundsSummary"><text>&gt; 30</text></inputEntry>
        <inputEntry id="InputEntry_Rounds_2_2_DoctorRoundsSummary"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Rounds_2_3_DoctorRoundsSummary"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_Rounds_2_resultado_DoctorRoundsSummary"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Rounds_2_acao_DoctorRoundsSummary"><text>"Volume alto de pacientes. Considerar redistribuição ou suporte adicional."</text></outputEntry>
        <outputEntry id="OutputEntry_Rounds_2_risco_DoctorRoundsSummary"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Rounds_3_DoctorRoundsSummary">
        <description>Alerta: Decisões pendentes acumuladas</description>
        <inputEntry id="InputEntry_Rounds_3_1_DoctorRoundsSummary"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Rounds_3_2_DoctorRoundsSummary"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Rounds_3_3_DoctorRoundsSummary"><text>&gt; 15</text></inputEntry>
        <outputEntry id="OutputEntry_Rounds_3_resultado_DoctorRoundsSummary"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Rounds_3_acao_DoctorRoundsSummary"><text>"Muitas decisões pendentes. Revisar casos e priorizar ações."</text></outputEntry>
        <outputEntry id="OutputEntry_Rounds_3_risco_DoctorRoundsSummary"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Rounds_4_DoctorRoundsSummary">
        <description>Aprovado: Rounds em dia</description>
        <inputEntry id="InputEntry_Rounds_4_1_DoctorRoundsSummary"><text>&lt;= 20</text></inputEntry>
        <inputEntry id="InputEntry_Rounds_4_2_DoctorRoundsSummary"><text>&lt;= 3</text></inputEntry>
        <inputEntry id="InputEntry_Rounds_4_3_DoctorRoundsSummary"><text>&lt;= 5</text></inputEntry>
        <outputEntry id="OutputEntry_Rounds_4_resultado_DoctorRoundsSummary"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_Rounds_4_acao_DoctorRoundsSummary"><text>"Rounds em dia. Volume gerenciável de pacientes e decisões."</text></outputEntry>
        <outputEntry id="OutputEntry_Rounds_4_risco_DoctorRoundsSummary"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Rounds_Fallback_DoctorRoundsSummary">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_Rounds_F_1_DoctorRoundsSummary"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Rounds_F_2_DoctorRoundsSummary"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Rounds_F_3_DoctorRoundsSummary"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_Rounds_F_resultado_DoctorRoundsSummary"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Rounds_F_acao_DoctorRoundsSummary"><text>"Avaliar status de rounds manualmente."</text></outputEntry>
        <outputEntry id="OutputEntry_Rounds_F_risco_DoctorRoundsSummary"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorRoundsSummary">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorRoundsSummary" dmnElementRef="Decision_DoctorRoundsSummary">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
