<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DOCTOR-SPECIALIST-CONSULT - Solicitacao de Parecer de Especialista
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DoctorSpecialistConsult"
             name="Solicitacao de Parecer de Especialista"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DoctorSpecialistConsult" name="[SP-CO-003 | doctor_patient] Decisao Specialist Consult" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DoctorSpecialistConsult" hitPolicy="FIRST">

      <input id="Input_consultUrgency_DoctorSpecialistConsult" label="Urgencia do Parecer">
        <inputExpression id="InputExpr_consultUrgency_DoctorSpecialistConsult" typeRef="string">
          <text>consultUrgency</text>
        </inputExpression>
        <inputValues><text>"EMERGENCIA","URGENTE","PROGRAMADO"</text></inputValues>
      </input>

      <input id="Input_specialtyType_DoctorSpecialistConsult" label="Tipo de Especialidade">
        <inputExpression id="InputExpr_specialtyType_DoctorSpecialistConsult" typeRef="string">
          <text>specialtyType</text>
        </inputExpression>
        <inputValues><text>"CARDIO","NEURO","ONCO","CIRURGIA","OUTROS"</text></inputValues>
      </input>

      <input id="Input_waitDays_DoctorSpecialistConsult" label="Dias de Espera">
        <inputExpression id="InputExpr_waitDays_DoctorSpecialistConsult" typeRef="number">
          <text>waitDays</text>
        </inputExpression>
      </input>

      <output id="Output_resultado_DoctorSpecialistConsult" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_DoctorSpecialistConsult" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco_DoctorSpecialistConsult" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_SpecConsult_1_DoctorSpecialistConsult">
        <description>Bloqueio: Emergência sem resposta</description>
        <inputEntry id="InputEntry_SpecConsult_1_1_DoctorSpecialistConsult"><text>"EMERGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_SpecConsult_1_2_DoctorSpecialistConsult"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_SpecConsult_1_3_DoctorSpecialistConsult"><text>&gt; 0.5</text></inputEntry>
        <outputEntry id="OutputEntry_SpecConsult_1_resultado_DoctorSpecialistConsult"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_SpecConsult_1_acao_DoctorSpecialistConsult"><text>"EMERGÊNCIA: Parecer urgente sem resposta. Acionar especialista de plantão imediatamente."</text></outputEntry>
        <outputEntry id="OutputEntry_SpecConsult_1_risco_DoctorSpecialistConsult"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_SpecConsult_2_DoctorSpecialistConsult">
        <description>Alerta: Urgente com espera prolongada</description>
        <inputEntry id="InputEntry_SpecConsult_2_1_DoctorSpecialistConsult"><text>"URGENTE"</text></inputEntry>
        <inputEntry id="InputEntry_SpecConsult_2_2_DoctorSpecialistConsult"><text>"CARDIO","NEURO","ONCO"</text></inputEntry>
        <inputEntry id="InputEntry_SpecConsult_2_3_DoctorSpecialistConsult"><text>&gt; 2</text></inputEntry>
        <outputEntry id="OutputEntry_SpecConsult_2_resultado_DoctorSpecialistConsult"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_SpecConsult_2_acao_DoctorSpecialistConsult"><text>"Parecer urgente aguardando &gt;2 dias. Acionar coordenação médica."</text></outputEntry>
        <outputEntry id="OutputEntry_SpecConsult_2_risco_DoctorSpecialistConsult"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_SpecConsult_3_DoctorSpecialistConsult">
        <description>Alerta: Programado atrasado</description>
        <inputEntry id="InputEntry_SpecConsult_3_1_DoctorSpecialistConsult"><text>"PROGRAMADO"</text></inputEntry>
        <inputEntry id="InputEntry_SpecConsult_3_2_DoctorSpecialistConsult"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_SpecConsult_3_3_DoctorSpecialistConsult"><text>&gt; 7</text></inputEntry>
        <outputEntry id="OutputEntry_SpecConsult_3_resultado_DoctorSpecialistConsult"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_SpecConsult_3_acao_DoctorSpecialistConsult"><text>"Parecer programado atrasado. Verificar disponibilidade de especialista."</text></outputEntry>
        <outputEntry id="OutputEntry_SpecConsult_3_risco_DoctorSpecialistConsult"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_SpecConsult_4_DoctorSpecialistConsult">
        <description>Aprovado: Solicitação no prazo</description>
        <inputEntry id="InputEntry_SpecConsult_4_1_DoctorSpecialistConsult"><text>"PROGRAMADO","URGENTE"</text></inputEntry>
        <inputEntry id="InputEntry_SpecConsult_4_2_DoctorSpecialistConsult"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_SpecConsult_4_3_DoctorSpecialistConsult"><text>&lt;= 2</text></inputEntry>
        <outputEntry id="OutputEntry_SpecConsult_4_resultado_DoctorSpecialistConsult"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_SpecConsult_4_acao_DoctorSpecialistConsult"><text>"Solicitação de parecer em andamento. Aguardar resposta do especialista."</text></outputEntry>
        <outputEntry id="OutputEntry_SpecConsult_4_risco_DoctorSpecialistConsult"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_SpecConsult_Fallback_DoctorSpecialistConsult">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_SpecConsult_F_1_DoctorSpecialistConsult"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_SpecConsult_F_2_DoctorSpecialistConsult"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_SpecConsult_F_3_DoctorSpecialistConsult"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_SpecConsult_F_resultado_DoctorSpecialistConsult"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_SpecConsult_F_acao_DoctorSpecialistConsult"><text>"Verificar status da solicitação de parecer."</text></outputEntry>
        <outputEntry id="OutputEntry_SpecConsult_F_risco_DoctorSpecialistConsult"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorSpecialistConsult">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorSpecialistConsult" dmnElementRef="Decision_DoctorSpecialistConsult">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
