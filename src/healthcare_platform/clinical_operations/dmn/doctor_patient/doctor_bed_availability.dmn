<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DOCTOR-BED-AVAILABILITY - Notificacao de Disponibilidade de Leito
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DoctorBedAvailability"
             name="Notificacao de Disponibilidade de Leito"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DoctorBedAvailability" name="[SP-CO-003 | doctor_patient] Decisao Disponibilidade Leito" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DoctorBedAvailability" hitPolicy="FIRST">

      <input id="Input_bedType_DoctorBedAvailability" label="Tipo de Leito">
        <inputExpression id="InputExpr_bedType_DoctorBedAvailability" typeRef="string">
          <text>bedType</text>
        </inputExpression>
        <inputValues><text>"UTI","SEMI_UTI","ENFERMARIA","ISOLAMENTO"</text></inputValues>
      </input>

      <input id="Input_unitOccupancy_DoctorBedAvailability" label="Ocupacao da Unidade (%)">
        <inputExpression id="InputExpr_unitOccupancy_DoctorBedAvailability" typeRef="number">
          <text>unitOccupancy</text>
        </inputExpression>
      </input>

      <input id="Input_waitHours_DoctorBedAvailability" label="Horas de Espera">
        <inputExpression id="InputExpr_waitHours_DoctorBedAvailability" typeRef="number">
          <text>waitHours</text>
        </inputExpression>
      </input>

      <output id="Output_resultado_DoctorBedAvailability" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_DoctorBedAvailability" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco_DoctorBedAvailability" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_BedAvail_1_DoctorBedAvailability">
        <description>Bloqueio: UTI lotada com espera crítica</description>
        <inputEntry id="InputEntry_BedAvail_1_1_DoctorBedAvailability"><text>"UTI"</text></inputEntry>
        <inputEntry id="InputEntry_BedAvail_1_2_DoctorBedAvailability"><text>&gt;= 95</text></inputEntry>
        <inputEntry id="InputEntry_BedAvail_1_3_DoctorBedAvailability"><text>&gt; 6</text></inputEntry>
        <outputEntry id="OutputEntry_BedAvail_1_resultado_DoctorBedAvailability"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_BedAvail_1_acao_DoctorBedAvailability"><text>"Acionar coordenação médica urgente. UTI em capacidade crítica."</text></outputEntry>
        <outputEntry id="OutputEntry_BedAvail_1_risco_DoctorBedAvailability"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_BedAvail_2_DoctorBedAvailability">
        <description>Alerta: Isolamento com ocupação elevada</description>
        <inputEntry id="InputEntry_BedAvail_2_1_DoctorBedAvailability"><text>"ISOLAMENTO"</text></inputEntry>
        <inputEntry id="InputEntry_BedAvail_2_2_DoctorBedAvailability"><text>&gt;= 80</text></inputEntry>
        <inputEntry id="InputEntry_BedAvail_2_3_DoctorBedAvailability"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_BedAvail_2_resultado_DoctorBedAvailability"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_BedAvail_2_acao_DoctorBedAvailability"><text>"Revisar protocolos de isolamento. Considerar leitos alternativos."</text></outputEntry>
        <outputEntry id="OutputEntry_BedAvail_2_risco_DoctorBedAvailability"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_BedAvail_3_DoctorBedAvailability">
        <description>Alerta: Espera prolongada em qualquer unidade</description>
        <inputEntry id="InputEntry_BedAvail_3_1_DoctorBedAvailability"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_BedAvail_3_2_DoctorBedAvailability"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_BedAvail_3_3_DoctorBedAvailability"><text>&gt; 12</text></inputEntry>
        <outputEntry id="OutputEntry_BedAvail_3_resultado_DoctorBedAvailability"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_BedAvail_3_acao_DoctorBedAvailability"><text>"Notificar médico assistente. Avaliar transferência para outra unidade."</text></outputEntry>
        <outputEntry id="OutputEntry_BedAvail_3_risco_DoctorBedAvailability"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_BedAvail_4_DoctorBedAvailability">
        <description>Aprovado: Disponibilidade normal</description>
        <inputEntry id="InputEntry_BedAvail_4_1_DoctorBedAvailability"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_BedAvail_4_2_DoctorBedAvailability"><text>&lt; 80</text></inputEntry>
        <inputEntry id="InputEntry_BedAvail_4_3_DoctorBedAvailability"><text>&lt;= 6</text></inputEntry>
        <outputEntry id="OutputEntry_BedAvail_4_resultado_DoctorBedAvailability"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_BedAvail_4_acao_DoctorBedAvailability"><text>"Notificar médico sobre disponibilidade de leito."</text></outputEntry>
        <outputEntry id="OutputEntry_BedAvail_4_risco_DoctorBedAvailability"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_BedAvail_Fallback_DoctorBedAvailability">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_BedAvail_F_1_DoctorBedAvailability"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_BedAvail_F_2_DoctorBedAvailability"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_BedAvail_F_3_DoctorBedAvailability"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_BedAvail_F_resultado_DoctorBedAvailability"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_BedAvail_F_acao_DoctorBedAvailability"><text>"Avaliar disponibilidade manualmente."</text></outputEntry>
        <outputEntry id="OutputEntry_BedAvail_F_risco_DoctorBedAvailability"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorBedAvailability">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorBedAvailability" dmnElementRef="Decision_DoctorBedAvailability">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
