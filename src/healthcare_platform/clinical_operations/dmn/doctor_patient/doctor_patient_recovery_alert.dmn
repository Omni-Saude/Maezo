<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DOCTOR-PATIENT-RECOVERY-ALERT - Alerta de Recuperacao do Paciente
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DoctorPatientRecoveryAlert"
             name="Alerta de Recuperacao do Paciente"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DoctorPatientRecoveryAlert" name="[SP-CO-003 | doctor_patient] Decisao Recovery Alert" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DoctorPatientRecoveryAlert" hitPolicy="FIRST">

      <input id="Input_recoveryScore_DoctorPatientRecoveryAlert" label="Score de Recuperacao (0-100)">
        <inputExpression id="InputExpr_recoveryScore_DoctorPatientRecoveryAlert" typeRef="number">
          <text>recoveryScore</text>
        </inputExpression>
      </input>

      <input id="Input_daysPostOp_DoctorPatientRecoveryAlert" label="Dias Pos-Operatorio">
        <inputExpression id="InputExpr_daysPostOp_DoctorPatientRecoveryAlert" typeRef="number">
          <text>daysPostOp</text>
        </inputExpression>
      </input>

      <input id="Input_complicationRisk_DoctorPatientRecoveryAlert" label="Risco de Complicacao">
        <inputExpression id="InputExpr_complicationRisk_DoctorPatientRecoveryAlert" typeRef="string">
          <text>complicationRisk</text>
        </inputExpression>
        <inputValues><text>"ALTO","MEDIO","BAIXO"</text></inputValues>
      </input>

      <output id="Output_resultado_DoctorPatientRecoveryAlert" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_DoctorPatientRecoveryAlert" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco_DoctorPatientRecoveryAlert" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_RecovAlert_1_DoctorPatientRecoveryAlert">
        <description>Bloqueio: Recuperação crítica em paciente de alto risco</description>
        <inputEntry id="InputEntry_RecovAlert_1_1_DoctorPatientRecoveryAlert"><text>&lt; 40</text></inputEntry>
        <inputEntry id="InputEntry_RecovAlert_1_2_DoctorPatientRecoveryAlert"><text>&gt; 3</text></inputEntry>
        <inputEntry id="InputEntry_RecovAlert_1_3_DoctorPatientRecoveryAlert"><text>"ALTO"</text></inputEntry>
        <outputEntry id="OutputEntry_RecovAlert_1_resultado_DoctorPatientRecoveryAlert"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_RecovAlert_1_acao_DoctorPatientRecoveryAlert"><text>"CRÍTICO: Recuperação insatisfatória em paciente alto risco. Avaliar intercorrências."</text></outputEntry>
        <outputEntry id="OutputEntry_RecovAlert_1_risco_DoctorPatientRecoveryAlert"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_RecovAlert_2_DoctorPatientRecoveryAlert">
        <description>Alerta: Recuperação lenta</description>
        <inputEntry id="InputEntry_RecovAlert_2_1_DoctorPatientRecoveryAlert"><text>&lt; 60</text></inputEntry>
        <inputEntry id="InputEntry_RecovAlert_2_2_DoctorPatientRecoveryAlert"><text>&gt; 7</text></inputEntry>
        <inputEntry id="InputEntry_RecovAlert_2_3_DoctorPatientRecoveryAlert"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RecovAlert_2_resultado_DoctorPatientRecoveryAlert"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_RecovAlert_2_acao_DoctorPatientRecoveryAlert"><text>"Recuperação abaixo do esperado. Revisar plano terapêutico."</text></outputEntry>
        <outputEntry id="OutputEntry_RecovAlert_2_risco_DoctorPatientRecoveryAlert"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_RecovAlert_3_DoctorPatientRecoveryAlert">
        <description>Alerta: Período crítico pós-op</description>
        <inputEntry id="InputEntry_RecovAlert_3_1_DoctorPatientRecoveryAlert"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RecovAlert_3_2_DoctorPatientRecoveryAlert"><text>&lt;= 3</text></inputEntry>
        <inputEntry id="InputEntry_RecovAlert_3_3_DoctorPatientRecoveryAlert"><text>"ALTO","MEDIO"</text></inputEntry>
        <outputEntry id="OutputEntry_RecovAlert_3_resultado_DoctorPatientRecoveryAlert"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_RecovAlert_3_acao_DoctorPatientRecoveryAlert"><text>"Período crítico pós-operatório. Monitorar sinais vitais de perto."</text></outputEntry>
        <outputEntry id="OutputEntry_RecovAlert_3_risco_DoctorPatientRecoveryAlert"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_RecovAlert_4_DoctorPatientRecoveryAlert">
        <description>Aprovado: Recuperação adequada</description>
        <inputEntry id="InputEntry_RecovAlert_4_1_DoctorPatientRecoveryAlert"><text>&gt;= 70</text></inputEntry>
        <inputEntry id="InputEntry_RecovAlert_4_2_DoctorPatientRecoveryAlert"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RecovAlert_4_3_DoctorPatientRecoveryAlert"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RecovAlert_4_resultado_DoctorPatientRecoveryAlert"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_RecovAlert_4_acao_DoctorPatientRecoveryAlert"><text>"Recuperação dentro do esperado. Manter acompanhamento de rotina."</text></outputEntry>
        <outputEntry id="OutputEntry_RecovAlert_4_risco_DoctorPatientRecoveryAlert"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_RecovAlert_Fallback_DoctorPatientRecoveryAlert">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_RecovAlert_F_1_DoctorPatientRecoveryAlert"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RecovAlert_F_2_DoctorPatientRecoveryAlert"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RecovAlert_F_3_DoctorPatientRecoveryAlert"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RecovAlert_F_resultado_DoctorPatientRecoveryAlert"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_RecovAlert_F_acao_DoctorPatientRecoveryAlert"><text>"Avaliar status de recuperação manualmente."</text></outputEntry>
        <outputEntry id="OutputEntry_RecovAlert_F_risco_DoctorPatientRecoveryAlert"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorPatientRecoveryAlert">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorPatientRecoveryAlert" dmnElementRef="Decision_DoctorPatientRecoveryAlert">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
