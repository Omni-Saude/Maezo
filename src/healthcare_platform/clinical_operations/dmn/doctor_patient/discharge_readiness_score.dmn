<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DischargeReadinessScore"
             name="Discharge Readiness Score"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_DischargeReadinessScore" name="[SP-CO-003 | doctor_patient] Discharge Readiness Score" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DischargeReadinessScore" hitPolicy="FIRST">
      <input id="Input_readiness_1_DischargeReadinessScore" label="Readiness Score (%)">
        <inputExpression id="InputExpr_readiness_1_DischargeReadinessScore" typeRef="number"><text>readinessScore</text></inputExpression>
      </input>
      <input id="Input_readiness_2_DischargeReadinessScore" label="Pending Tasks">
        <inputExpression id="InputExpr_readiness_2_DischargeReadinessScore" typeRef="number"><text>pendingTasks</text></inputExpression>
      </input>
      <input id="Input_readiness_3_DischargeReadinessScore" label="Follow-up Scheduled">
        <inputExpression id="InputExpr_readiness_3_DischargeReadinessScore" typeRef="boolean"><text>followupScheduled</text></inputExpression>
      </input>
      <output id="Output_readiness_resultado_DischargeReadinessScore" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_readiness_acao_DischargeReadinessScore" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_readiness_risco_DischargeReadinessScore" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>
      <rule id="Rule_readiness_1_DischargeReadinessScore">
        <inputEntry id="IE_readiness_1_1_DischargeReadinessScore"><text>&lt; 70</text></inputEntry>
        <inputEntry id="IE_readiness_1_2_DischargeReadinessScore"><text>&gt; 3</text></inputEntry>
        <inputEntry id="IE_readiness_1_3_DischargeReadinessScore"><text>false</text></inputEntry>
        <outputEntry id="OE_readiness_1_r_DischargeReadinessScore"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_readiness_1_a_DischargeReadinessScore"><text>"Prontidão insuficiente - completar pendências antes da alta"</text></outputEntry>
        <outputEntry id="OE_readiness_1_ri_DischargeReadinessScore"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_readiness_2_DischargeReadinessScore">
        <inputEntry id="IE_readiness_2_1_DischargeReadinessScore"><text>[70..90]</text></inputEntry>
        <inputEntry id="IE_readiness_2_2_DischargeReadinessScore"><text>[1..3]</text></inputEntry>
        <inputEntry id="IE_readiness_2_3_DischargeReadinessScore"><text></text></inputEntry>
        <outputEntry id="OE_readiness_2_r_DischargeReadinessScore"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_readiness_2_a_DischargeReadinessScore"><text>"Prontidão parcial - finalizar tarefas e agendar acompanhamento"</text></outputEntry>
        <outputEntry id="OE_readiness_2_ri_DischargeReadinessScore"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_readiness_3_DischargeReadinessScore">
        <inputEntry id="IE_readiness_3_1_DischargeReadinessScore"><text>&gt; 90</text></inputEntry>
        <inputEntry id="IE_readiness_3_2_DischargeReadinessScore"><text>0</text></inputEntry>
        <inputEntry id="IE_readiness_3_3_DischargeReadinessScore"><text>true</text></inputEntry>
        <outputEntry id="OE_readiness_3_r_DischargeReadinessScore"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_readiness_3_a_DischargeReadinessScore"><text>"Paciente pronto para alta - processar documentação"</text></outputEntry>
        <outputEntry id="OE_readiness_3_ri_DischargeReadinessScore"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_DischargeReadinessScore">
      <dmndi:DMNShape id="DMNShape_Decision_DischargeReadinessScore" dmnElementRef="Decision_DischargeReadinessScore">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
