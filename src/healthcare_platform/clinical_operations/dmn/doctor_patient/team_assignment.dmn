<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_TeamAssignment"
             name="Team Assignment"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_TeamAssignment" name="[SP-CO-003 | doctor_patient] Team Assignment" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_TeamAssignment" hitPolicy="FIRST">
      <input id="Input_team_1_TeamAssignment" label="Patient Acuity">
        <inputExpression id="InputExpr_team_1_TeamAssignment" typeRef="string"><text>patientAcuity</text></inputExpression>
        <inputValues><text>"CRITICO","GRAVE","MODERADO","ESTAVEL"</text></inputValues>
      </input>
      <input id="Input_team_2_TeamAssignment" label="Specialty Needed">
        <inputExpression id="InputExpr_team_2_TeamAssignment" typeRef="string"><text>specialtyNeeded</text></inputExpression>
      </input>
      <input id="Input_team_3_TeamAssignment" label="Staff Availability">
        <inputExpression id="InputExpr_team_3_TeamAssignment" typeRef="boolean"><text>staffAvailability</text></inputExpression>
      </input>
      <output id="Output_team_resultado_TeamAssignment" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_team_acao_TeamAssignment" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_team_risco_TeamAssignment" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>
      <rule id="Rule_team_1_TeamAssignment">
        <inputEntry id="IE_team_1_1_TeamAssignment"><text>"CRITICO"</text></inputEntry>
        <inputEntry id="IE_team_1_2_TeamAssignment"><text></text></inputEntry>
        <inputEntry id="IE_team_1_3_TeamAssignment"><text>false</text></inputEntry>
        <outputEntry id="OE_team_1_r_TeamAssignment"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_team_1_a_TeamAssignment"><text>"Paciente crítico sem equipe - acionar plantão urgente"</text></outputEntry>
        <outputEntry id="OE_team_1_ri_TeamAssignment"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_team_2_TeamAssignment">
        <inputEntry id="IE_team_2_1_TeamAssignment"><text>"GRAVE"</text></inputEntry>
        <inputEntry id="IE_team_2_2_TeamAssignment"><text>"CARDIO","NEURO","TRAUMA"</text></inputEntry>
        <inputEntry id="IE_team_2_3_TeamAssignment"><text>true</text></inputEntry>
        <outputEntry id="OE_team_2_r_TeamAssignment"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_team_2_a_TeamAssignment"><text>"Alocar equipe especializada com intensivista"</text></outputEntry>
        <outputEntry id="OE_team_2_ri_TeamAssignment"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_team_3_TeamAssignment">
        <inputEntry id="IE_team_3_1_TeamAssignment"><text>"MODERADO","ESTAVEL"</text></inputEntry>
        <inputEntry id="IE_team_3_2_TeamAssignment"><text></text></inputEntry>
        <inputEntry id="IE_team_3_3_TeamAssignment"><text>true</text></inputEntry>
        <outputEntry id="OE_team_3_r_TeamAssignment"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_team_3_a_TeamAssignment"><text>"Alocar equipe clínica padrão"</text></outputEntry>
        <outputEntry id="OE_team_3_ri_TeamAssignment"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_TeamAssignment">
      <dmndi:DMNShape id="DMNShape_Decision_TeamAssignment" dmnElementRef="Decision_TeamAssignment">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
