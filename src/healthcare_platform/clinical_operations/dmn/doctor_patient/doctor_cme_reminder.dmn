<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DOCTOR-CME-REMINDER - Lembrete de Educacao Medica Continuada
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DoctorCMEReminder"
             name="Lembrete de Educacao Medica Continuada"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DoctorCMEReminder" name="[SP-CO-003 | doctor_patient] Decisao CME Reminder" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DoctorCMEReminder" hitPolicy="FIRST">

      <input id="Input_daysSinceLastCME_DoctorCMEReminder" label="Dias Desde Ultimo CME">
        <inputExpression id="InputExpr_daysSinceLastCME_DoctorCMEReminder" typeRef="number">
          <text>daysSinceLastCME</text>
        </inputExpression>
      </input>

      <input id="Input_credentialExpiry_DoctorCMEReminder" label="Dias para Vencimento Credencial">
        <inputExpression id="InputExpr_credentialExpiry_DoctorCMEReminder" typeRef="number">
          <text>credentialExpiry</text>
        </inputExpression>
      </input>

      <input id="Input_specialtyReq_DoctorCMEReminder" label="Requisito Especialidade Atendido">
        <inputExpression id="InputExpr_specialtyReq_DoctorCMEReminder" typeRef="boolean">
          <text>specialtyReq</text>
        </inputExpression>
      </input>

      <output id="Output_resultado_DoctorCMEReminder" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_DoctorCMEReminder" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco_DoctorCMEReminder" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_CME_1_DoctorCMEReminder">
        <description>Bloqueio: Credencial vencendo sem requisitos</description>
        <inputEntry id="InputEntry_CME_1_1_DoctorCMEReminder"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CME_1_2_DoctorCMEReminder"><text>&lt; 30</text></inputEntry>
        <inputEntry id="InputEntry_CME_1_3_DoctorCMEReminder"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_CME_1_resultado_DoctorCMEReminder"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CME_1_acao_DoctorCMEReminder"><text>"URGENTE: Credencial vence em menos de 30 dias. Completar CME obrigatório."</text></outputEntry>
        <outputEntry id="OutputEntry_CME_1_risco_DoctorCMEReminder"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_CME_2_DoctorCMEReminder">
        <description>Alerta: CME atrasado</description>
        <inputEntry id="InputEntry_CME_2_1_DoctorCMEReminder"><text>&gt; 365</text></inputEntry>
        <inputEntry id="InputEntry_CME_2_2_DoctorCMEReminder"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CME_2_3_DoctorCMEReminder"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_CME_2_resultado_DoctorCMEReminder"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CME_2_acao_DoctorCMEReminder"><text>"Lembrete: Último CME há mais de 1 ano. Agendar treinamento."</text></outputEntry>
        <outputEntry id="OutputEntry_CME_2_risco_DoctorCMEReminder"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_CME_3_DoctorCMEReminder">
        <description>Alerta: Credencial próxima do vencimento</description>
        <inputEntry id="InputEntry_CME_3_1_DoctorCMEReminder"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CME_3_2_DoctorCMEReminder"><text>&lt; 60</text></inputEntry>
        <inputEntry id="InputEntry_CME_3_3_DoctorCMEReminder"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_CME_3_resultado_DoctorCMEReminder"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CME_3_acao_DoctorCMEReminder"><text>"Lembrete: Credencial vence em menos de 60 dias. Iniciar renovação."</text></outputEntry>
        <outputEntry id="OutputEntry_CME_3_risco_DoctorCMEReminder"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_CME_4_DoctorCMEReminder">
        <description>Aprovado: CME em dia</description>
        <inputEntry id="InputEntry_CME_4_1_DoctorCMEReminder"><text>&lt;= 365</text></inputEntry>
        <inputEntry id="InputEntry_CME_4_2_DoctorCMEReminder"><text>&gt;= 60</text></inputEntry>
        <inputEntry id="InputEntry_CME_4_3_DoctorCMEReminder"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_CME_4_resultado_DoctorCMEReminder"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_CME_4_acao_DoctorCMEReminder"><text>"CME e credenciais em dia. Nenhuma ação necessária."</text></outputEntry>
        <outputEntry id="OutputEntry_CME_4_risco_DoctorCMEReminder"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_CME_Fallback_DoctorCMEReminder">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_CME_F_1_DoctorCMEReminder"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CME_F_2_DoctorCMEReminder"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_CME_F_3_DoctorCMEReminder"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_CME_F_resultado_DoctorCMEReminder"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_CME_F_acao_DoctorCMEReminder"><text>"Verificar status de CME manualmente."</text></outputEntry>
        <outputEntry id="OutputEntry_CME_F_risco_DoctorCMEReminder"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorCMEReminder">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorCMEReminder" dmnElementRef="Decision_DoctorCMEReminder">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
