<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  PATIENT-MEDICATION-ADHERENCE - Aderencia a Medicacao do Paciente
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: PACIENTE (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_PatientMedicationAdherence"
             name="Aderencia a Medicacao do Paciente"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_PatientMedicationAdherence" name="[SP-CO-003 | doctor_patient] Decisao Medication Adherence" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_PatientMedicationAdherence" hitPolicy="FIRST">

      <input id="Input_adherenceScore_PatientMedicationAdherence" label="Score de Aderencia (%)">
        <inputExpression id="InputExpr_adherenceScore_PatientMedicationAdherence" typeRef="number">
          <text>adherenceScore</text>
        </inputExpression>
      </input>

      <input id="Input_missedDoses_PatientMedicationAdherence" label="Doses Perdidas (ultimos 7 dias)">
        <inputExpression id="InputExpr_missedDoses_PatientMedicationAdherence" typeRef="number">
          <text>missedDoses</text>
        </inputExpression>
      </input>

      <input id="Input_medicationCount_PatientMedicationAdherence" label="Numero de Medicacoes">
        <inputExpression id="InputExpr_medicationCount_PatientMedicationAdherence" typeRef="number">
          <text>medicationCount</text>
        </inputExpression>
      </input>

      <output id="Output_resultado_PatientMedicationAdherence" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_PatientMedicationAdherence" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco_PatientMedicationAdherence" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_MedAdher_1_PatientMedicationAdherence">
        <description>Bloqueio: Baixa aderência crítica</description>
        <inputEntry id="InputEntry_MedAdher_1_1_PatientMedicationAdherence"><text>&lt; 50</text></inputEntry>
        <inputEntry id="InputEntry_MedAdher_1_2_PatientMedicationAdherence"><text>&gt; 5</text></inputEntry>
        <inputEntry id="InputEntry_MedAdher_1_3_PatientMedicationAdherence"><text>&gt; 5</text></inputEntry>
        <outputEntry id="OutputEntry_MedAdher_1_resultado_PatientMedicationAdherence"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MedAdher_1_acao_PatientMedicationAdherence"><text>"CRÍTICO: Baixa aderência com múltiplas medicações. Contatar paciente e revisar esquema terapêutico."</text></outputEntry>
        <outputEntry id="OutputEntry_MedAdher_1_risco_PatientMedicationAdherence"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_MedAdher_2_PatientMedicationAdherence">
        <description>Alerta: Aderência moderada</description>
        <inputEntry id="InputEntry_MedAdher_2_1_PatientMedicationAdherence"><text>&lt; 70</text></inputEntry>
        <inputEntry id="InputEntry_MedAdher_2_2_PatientMedicationAdherence"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MedAdher_2_3_PatientMedicationAdherence"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_MedAdher_2_resultado_PatientMedicationAdherence"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MedAdher_2_acao_PatientMedicationAdherence"><text>"Aderência abaixo do ideal. Oferecer suporte educacional e estratégias de adesão."</text></outputEntry>
        <outputEntry id="OutputEntry_MedAdher_2_risco_PatientMedicationAdherence"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_MedAdher_3_PatientMedicationAdherence">
        <description>Alerta: Polifarmácia</description>
        <inputEntry id="InputEntry_MedAdher_3_1_PatientMedicationAdherence"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MedAdher_3_2_PatientMedicationAdherence"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MedAdher_3_3_PatientMedicationAdherence"><text>&gt; 8</text></inputEntry>
        <outputEntry id="OutputEntry_MedAdher_3_resultado_PatientMedicationAdherence"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MedAdher_3_acao_PatientMedicationAdherence"><text>"Polifarmácia identificada. Avaliar simplificação de esquema para melhorar aderência."</text></outputEntry>
        <outputEntry id="OutputEntry_MedAdher_3_risco_PatientMedicationAdherence"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_MedAdher_4_PatientMedicationAdherence">
        <description>Aprovado: Boa aderência</description>
        <inputEntry id="InputEntry_MedAdher_4_1_PatientMedicationAdherence"><text>&gt;= 80</text></inputEntry>
        <inputEntry id="InputEntry_MedAdher_4_2_PatientMedicationAdherence"><text>&lt;= 2</text></inputEntry>
        <inputEntry id="InputEntry_MedAdher_4_3_PatientMedicationAdherence"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_MedAdher_4_resultado_PatientMedicationAdherence"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_MedAdher_4_acao_PatientMedicationAdherence"><text>"Boa aderência medicamentosa. Reforçar positivamente comportamento."</text></outputEntry>
        <outputEntry id="OutputEntry_MedAdher_4_risco_PatientMedicationAdherence"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_MedAdher_Fallback_PatientMedicationAdherence">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_MedAdher_F_1_PatientMedicationAdherence"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MedAdher_F_2_PatientMedicationAdherence"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_MedAdher_F_3_PatientMedicationAdherence"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_MedAdher_F_resultado_PatientMedicationAdherence"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_MedAdher_F_acao_PatientMedicationAdherence"><text>"Monitorar aderência medicamentosa."</text></outputEntry>
        <outputEntry id="OutputEntry_MedAdher_F_risco_PatientMedicationAdherence"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PatientMedicationAdherence">
      <dmndi:DMNShape id="DMNShape_Decision_PatientMedicationAdherence" dmnElementRef="Decision_PatientMedicationAdherence">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
