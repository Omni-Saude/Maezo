<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DOCTOR-REFERRAL-STATUS - Status de Encaminhamento para Especialista
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DoctorReferralStatus"
             name="Status de Encaminhamento para Especialista"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DoctorReferralStatus" name="[SP-CO-003 | doctor_patient] Decisao Referral Status" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DoctorReferralStatus" hitPolicy="FIRST">

      <input id="Input_referralAge_DoctorReferralStatus" label="Idade do Encaminhamento (dias)">
        <inputExpression id="InputExpr_referralAge_DoctorReferralStatus" typeRef="number">
          <text>referralAge</text>
        </inputExpression>
      </input>

      <input id="Input_urgencyLevel_DoctorReferralStatus" label="Nivel de Urgencia">
        <inputExpression id="InputExpr_urgencyLevel_DoctorReferralStatus" typeRef="string">
          <text>urgencyLevel</text>
        </inputExpression>
        <inputValues><text>"EMERGENCIA","URGENTE","PROGRAMADO","ELETIVO"</text></inputValues>
      </input>

      <input id="Input_specialtyAvailability_DoctorReferralStatus" label="Disponibilidade Especialista (dias)">
        <inputExpression id="InputExpr_specialtyAvailability_DoctorReferralStatus" typeRef="number">
          <text>specialtyAvailability</text>
        </inputExpression>
      </input>

      <output id="Output_resultado_DoctorReferralStatus" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_DoctorReferralStatus" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco_DoctorReferralStatus" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_Referral_1_DoctorReferralStatus">
        <description>Bloqueio: Emergência sem atendimento</description>
        <inputEntry id="InputEntry_Referral_1_1_DoctorReferralStatus"><text>&gt; 1</text></inputEntry>
        <inputEntry id="InputEntry_Referral_1_2_DoctorReferralStatus"><text>"EMERGENCIA"</text></inputEntry>
        <inputEntry id="InputEntry_Referral_1_3_DoctorReferralStatus"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_Referral_1_resultado_DoctorReferralStatus"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Referral_1_acao_DoctorReferralStatus"><text>"EMERGÊNCIA: Encaminhamento urgente sem resposta. Acionar plantão de especialidade."</text></outputEntry>
        <outputEntry id="OutputEntry_Referral_1_risco_DoctorReferralStatus"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Referral_2_DoctorReferralStatus">
        <description>Alerta: Urgente com espera longa</description>
        <inputEntry id="InputEntry_Referral_2_1_DoctorReferralStatus"><text>&gt; 7</text></inputEntry>
        <inputEntry id="InputEntry_Referral_2_2_DoctorReferralStatus"><text>"URGENTE"</text></inputEntry>
        <inputEntry id="InputEntry_Referral_2_3_DoctorReferralStatus"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_Referral_2_resultado_DoctorReferralStatus"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Referral_2_acao_DoctorReferralStatus"><text>"Encaminhamento urgente com espera &gt;7 dias. Contatar especialista ou buscar alternativa."</text></outputEntry>
        <outputEntry id="OutputEntry_Referral_2_risco_DoctorReferralStatus"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Referral_3_DoctorReferralStatus">
        <description>Alerta: Disponibilidade limitada</description>
        <inputEntry id="InputEntry_Referral_3_1_DoctorReferralStatus"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Referral_3_2_DoctorReferralStatus"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Referral_3_3_DoctorReferralStatus"><text>&gt; 30</text></inputEntry>
        <outputEntry id="OutputEntry_Referral_3_resultado_DoctorReferralStatus"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Referral_3_acao_DoctorReferralStatus"><text>"Disponibilidade de especialista limitada (&gt;30 dias). Avaliar alternativas."</text></outputEntry>
        <outputEntry id="OutputEntry_Referral_3_risco_DoctorReferralStatus"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Referral_4_DoctorReferralStatus">
        <description>Aprovado: Encaminhamento em andamento</description>
        <inputEntry id="InputEntry_Referral_4_1_DoctorReferralStatus"><text>&lt;= 7</text></inputEntry>
        <inputEntry id="InputEntry_Referral_4_2_DoctorReferralStatus"><text>"PROGRAMADO","ELETIVO"</text></inputEntry>
        <inputEntry id="InputEntry_Referral_4_3_DoctorReferralStatus"><text>&lt;= 30</text></inputEntry>
        <outputEntry id="OutputEntry_Referral_4_resultado_DoctorReferralStatus"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_Referral_4_acao_DoctorReferralStatus"><text>"Encaminhamento em andamento. Aguardar agendamento."</text></outputEntry>
        <outputEntry id="OutputEntry_Referral_4_risco_DoctorReferralStatus"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Referral_Fallback_DoctorReferralStatus">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_Referral_F_1_DoctorReferralStatus"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Referral_F_2_DoctorReferralStatus"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_Referral_F_3_DoctorReferralStatus"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_Referral_F_resultado_DoctorReferralStatus"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_Referral_F_acao_DoctorReferralStatus"><text>"Verificar status do encaminhamento."</text></outputEntry>
        <outputEntry id="OutputEntry_Referral_F_risco_DoctorReferralStatus"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorReferralStatus">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorReferralStatus" dmnElementRef="Decision_DoctorReferralStatus">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
