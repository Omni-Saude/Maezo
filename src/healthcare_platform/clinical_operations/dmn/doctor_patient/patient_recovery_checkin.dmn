<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  PATIENT-RECOVERY-CHECKIN - Checkin de Recuperacao do Paciente
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: PACIENTE (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_PatientRecoveryCheckin"
             name="Checkin de Recuperacao do Paciente"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_PatientRecoveryCheckin" name="[SP-CO-003 | doctor_patient] Decisao Recovery Checkin" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_PatientRecoveryCheckin" hitPolicy="FIRST">

      <input id="Input_painScore_PatientRecoveryCheckin" label="Score de Dor (0-10)">
        <inputExpression id="InputExpr_painScore_PatientRecoveryCheckin" typeRef="number">
          <text>painScore</text>
        </inputExpression>
      </input>

      <input id="Input_mobilityScore_PatientRecoveryCheckin" label="Score de Mobilidade (0-100)">
        <inputExpression id="InputExpr_mobilityScore_PatientRecoveryCheckin" typeRef="number">
          <text>mobilityScore</text>
        </inputExpression>
      </input>

      <input id="Input_daysSinceSurgery_PatientRecoveryCheckin" label="Dias Desde Cirurgia">
        <inputExpression id="InputExpr_daysSinceSurgery_PatientRecoveryCheckin" typeRef="number">
          <text>daysSinceSurgery</text>
        </inputExpression>
      </input>

      <output id="Output_resultado_PatientRecoveryCheckin" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_PatientRecoveryCheckin" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco_PatientRecoveryCheckin" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_RecovCheck_1_PatientRecoveryCheckin">
        <description>Bloqueio: Dor severa pós-operatória</description>
        <inputEntry id="InputEntry_RecovCheck_1_1_PatientRecoveryCheckin"><text>&gt; 7</text></inputEntry>
        <inputEntry id="InputEntry_RecovCheck_1_2_PatientRecoveryCheckin"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RecovCheck_1_3_PatientRecoveryCheckin"><text>&lt; 7</text></inputEntry>
        <outputEntry id="OutputEntry_RecovCheck_1_resultado_PatientRecoveryCheckin"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_RecovCheck_1_acao_PatientRecoveryCheckin"><text>"URGENTE: Dor severa pós-operatória. Contatar equipe médica para ajuste de analgesia."</text></outputEntry>
        <outputEntry id="OutputEntry_RecovCheck_1_risco_PatientRecoveryCheckin"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_RecovCheck_2_PatientRecoveryCheckin">
        <description>Alerta: Mobilidade reduzida</description>
        <inputEntry id="InputEntry_RecovCheck_2_1_PatientRecoveryCheckin"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RecovCheck_2_2_PatientRecoveryCheckin"><text>&lt; 40</text></inputEntry>
        <inputEntry id="InputEntry_RecovCheck_2_3_PatientRecoveryCheckin"><text>&gt; 5</text></inputEntry>
        <outputEntry id="OutputEntry_RecovCheck_2_resultado_PatientRecoveryCheckin"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_RecovCheck_2_acao_PatientRecoveryCheckin"><text>"Mobilidade abaixo do esperado. Avaliar necessidade de fisioterapia intensificada."</text></outputEntry>
        <outputEntry id="OutputEntry_RecovCheck_2_risco_PatientRecoveryCheckin"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_RecovCheck_3_PatientRecoveryCheckin">
        <description>Alerta: Dor moderada persistente</description>
        <inputEntry id="InputEntry_RecovCheck_3_1_PatientRecoveryCheckin"><text>&gt; 4</text></inputEntry>
        <inputEntry id="InputEntry_RecovCheck_3_2_PatientRecoveryCheckin"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RecovCheck_3_3_PatientRecoveryCheckin"><text>&gt; 3</text></inputEntry>
        <outputEntry id="OutputEntry_RecovCheck_3_resultado_PatientRecoveryCheckin"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_RecovCheck_3_acao_PatientRecoveryCheckin"><text>"Dor moderada persistente. Verificar adesão a analgésicos e considerar ajuste."</text></outputEntry>
        <outputEntry id="OutputEntry_RecovCheck_3_risco_PatientRecoveryCheckin"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_RecovCheck_4_PatientRecoveryCheckin">
        <description>Aprovado: Recuperação adequada</description>
        <inputEntry id="InputEntry_RecovCheck_4_1_PatientRecoveryCheckin"><text>&lt;= 3</text></inputEntry>
        <inputEntry id="InputEntry_RecovCheck_4_2_PatientRecoveryCheckin"><text>&gt;= 60</text></inputEntry>
        <inputEntry id="InputEntry_RecovCheck_4_3_PatientRecoveryCheckin"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RecovCheck_4_resultado_PatientRecoveryCheckin"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_RecovCheck_4_acao_PatientRecoveryCheckin"><text>"Recuperação dentro do esperado. Encorajar paciente a continuar."</text></outputEntry>
        <outputEntry id="OutputEntry_RecovCheck_4_risco_PatientRecoveryCheckin"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_RecovCheck_Fallback_PatientRecoveryCheckin">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_RecovCheck_F_1_PatientRecoveryCheckin"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RecovCheck_F_2_PatientRecoveryCheckin"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_RecovCheck_F_3_PatientRecoveryCheckin"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_RecovCheck_F_resultado_PatientRecoveryCheckin"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_RecovCheck_F_acao_PatientRecoveryCheckin"><text>"Monitorar evolução da recuperação."</text></outputEntry>
        <outputEntry id="OutputEntry_RecovCheck_F_risco_PatientRecoveryCheckin"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PatientRecoveryCheckin">
      <dmndi:DMNShape id="DMNShape_Decision_PatientRecoveryCheckin" dmnElementRef="Decision_PatientRecoveryCheckin">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
