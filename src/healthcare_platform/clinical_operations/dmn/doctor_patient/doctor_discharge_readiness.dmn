<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DOCTOR-DISCHARGE-READINESS - Avaliacao de Prontidao para Alta
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: DOCTOR-PATIENT
  Perspectiva: MEDICO (Operacional)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DoctorDischargeReadiness"
             name="Avaliacao de Prontidao para Alta"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DoctorDischargeReadiness" name="[SP-CO-003 | doctor_patient] Decisao Prontidao Alta" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DoctorDischargeReadiness" hitPolicy="FIRST">

      <input id="Input_clinicalScore_DoctorDischargeReadiness" label="Score Clinico">
        <inputExpression id="InputExpr_clinicalScore_DoctorDischargeReadiness" typeRef="number">
          <text>clinicalScore</text>
        </inputExpression>
      </input>

      <input id="Input_pendingOrders_DoctorDischargeReadiness" label="Pedidos Pendentes">
        <inputExpression id="InputExpr_pendingOrders_DoctorDischargeReadiness" typeRef="number">
          <text>pendingOrders</text>
        </inputExpression>
      </input>

      <input id="Input_daysAdmitted_DoctorDischargeReadiness" label="Dias Internado">
        <inputExpression id="InputExpr_daysAdmitted_DoctorDischargeReadiness" typeRef="number">
          <text>daysAdmitted</text>
        </inputExpression>
      </input>

      <output id="Output_resultado_DoctorDischargeReadiness" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_DoctorDischargeReadiness" label="Ação" name="acao" typeRef="string"/>
      <output id="Output_risco_DoctorDischargeReadiness" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"BAIXO","MEDIO","ALTO"</text></outputValues>
      </output>

      <rule id="Rule_DischReady_1_DoctorDischargeReadiness">
        <description>Bloqueio: Score baixo com pedidos pendentes</description>
        <inputEntry id="InputEntry_DischReady_1_1_DoctorDischargeReadiness"><text>&lt; 70</text></inputEntry>
        <inputEntry id="InputEntry_DischReady_1_2_DoctorDischargeReadiness"><text>&gt; 3</text></inputEntry>
        <inputEntry id="InputEntry_DischReady_1_3_DoctorDischargeReadiness"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DischReady_1_resultado_DoctorDischargeReadiness"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OutputEntry_DischReady_1_acao_DoctorDischargeReadiness"><text>"Paciente não está pronto para alta. Aguardar melhora clínica e conclusão de pedidos."</text></outputEntry>
        <outputEntry id="OutputEntry_DischReady_1_risco_DoctorDischargeReadiness"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_DischReady_2_DoctorDischargeReadiness">
        <description>Alerta: Internação prolongada</description>
        <inputEntry id="InputEntry_DischReady_2_1_DoctorDischargeReadiness"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DischReady_2_2_DoctorDischargeReadiness"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DischReady_2_3_DoctorDischargeReadiness"><text>&gt; 14</text></inputEntry>
        <outputEntry id="OutputEntry_DischReady_2_resultado_DoctorDischargeReadiness"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_DischReady_2_acao_DoctorDischargeReadiness"><text>"Revisar plano de alta. Internação prolongada (&gt;14 dias). Avaliar barreiras."</text></outputEntry>
        <outputEntry id="OutputEntry_DischReady_2_risco_DoctorDischargeReadiness"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_DischReady_3_DoctorDischargeReadiness">
        <description>Alerta: Pedidos pendentes</description>
        <inputEntry id="InputEntry_DischReady_3_1_DoctorDischargeReadiness"><text>&gt;= 70</text></inputEntry>
        <inputEntry id="InputEntry_DischReady_3_2_DoctorDischargeReadiness"><text>&gt; 0</text></inputEntry>
        <inputEntry id="InputEntry_DischReady_3_3_DoctorDischargeReadiness"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DischReady_3_resultado_DoctorDischargeReadiness"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_DischReady_3_acao_DoctorDischargeReadiness"><text>"Condição clínica adequada. Aguardar conclusão de pedidos pendentes."</text></outputEntry>
        <outputEntry id="OutputEntry_DischReady_3_risco_DoctorDischargeReadiness"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_DischReady_4_DoctorDischargeReadiness">
        <description>Aprovado: Pronto para alta</description>
        <inputEntry id="InputEntry_DischReady_4_1_DoctorDischargeReadiness"><text>&gt;= 80</text></inputEntry>
        <inputEntry id="InputEntry_DischReady_4_2_DoctorDischargeReadiness"><text>= 0</text></inputEntry>
        <inputEntry id="InputEntry_DischReady_4_3_DoctorDischargeReadiness"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DischReady_4_resultado_DoctorDischargeReadiness"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OutputEntry_DischReady_4_acao_DoctorDischargeReadiness"><text>"Paciente pronto para alta. Iniciar processo de alta hospitalar."</text></outputEntry>
        <outputEntry id="OutputEntry_DischReady_4_risco_DoctorDischargeReadiness"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_DischReady_Fallback_DoctorDischargeReadiness">
        <description>Regra padrão</description>
        <inputEntry id="InputEntry_DischReady_F_1_DoctorDischargeReadiness"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DischReady_F_2_DoctorDischargeReadiness"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_DischReady_F_3_DoctorDischargeReadiness"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_DischReady_F_resultado_DoctorDischargeReadiness"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OutputEntry_DischReady_F_acao_DoctorDischargeReadiness"><text>"Avaliar prontidão para alta manualmente."</text></outputEntry>
        <outputEntry id="OutputEntry_DischReady_F_risco_DoctorDischargeReadiness"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DoctorDischargeReadiness">
      <dmndi:DMNShape id="DMNShape_Decision_DoctorDischargeReadiness" dmnElementRef="Decision_DoctorDischargeReadiness">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
