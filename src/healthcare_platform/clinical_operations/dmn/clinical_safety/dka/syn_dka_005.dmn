<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  SYN-DKA-005 - Clinical Syndromes
  ============================================================================
  Versao: 1.0.0 (2026-02-09)
  Categoria: syn/dka
  Perspectiva: HOSPITAL (Administrativo/Clinico)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_SYN_DKA_005" name="Clinical Syndromes" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_SYN_DKA_005" name="[SP-CO-004 | clinical_safety/dka] Clinical Syndromes" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_SYN_DKA_005" hitPolicy="FIRST">

      <input id="Input_1_SYN_DKA_005" label="Parametro Principal">
        <inputExpression id="InputExpression_1_SYN_DKA_005" typeRef="string">
          <text>parametroPrincipal</text>
        </inputExpression>
      </input>

      <output id="Output_1_SYN_DKA_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_SYN_DKA_005" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_SYN_DKA_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />
      <output id="Output_4_SYN_DKA_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>
      <output id="Output_5_SYN_DKA_005" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <rule id="Rule_Aprovado_1_SYN_DKA_005">
        <description>Regra de aprovacao padrao</description>
        <inputEntry id="InputEntry_A1_1_SYN_DKA_005"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_A1_1_SYN_DKA_005"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_2_SYN_DKA_005"><text>"Processamento aprovado conforme parametros."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_3_SYN_DKA_005"><text>"Prosseguir com processamento."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_4_SYN_DKA_005"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_5_SYN_DKA_005"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_SYN_DKA_005">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_SYN_DKA_005"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_SYN_DKA_005"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_SYN_DKA_005"><text>"Situacao requer avaliacao manual."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_SYN_DKA_005"><text>"Revisar caso manualmente."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_SYN_DKA_005"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_SYN_DKA_005"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_SYN_DKA_005">
      <dmndi:DMNShape id="DMNShape_Decision_SYN_DKA_005" dmnElementRef="Decision_SYN_DKA_005">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>