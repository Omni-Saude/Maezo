<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="clinical_safety_recovery_trajectory" name="Recovery Trajectory"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="decision_recovery_trajectory" name="[SP-CO-004 | clinical_safety] Trajetória de Recuperação" camunda:historyTimeToLive="180">
    <decisionTable id="dt_recovery_trajectory" hitPolicy="FIRST">
      <input id="rt_in1_recovery_trajectory" label="Tendência">
        <inputExpression typeRef="string"><text>improvementTrend</text></inputExpression>
      </input>
      <input id="rt_in2_recovery_trajectory" label="Significância Estatística">
        <inputExpression typeRef="boolean"><text>statisticallySignificant</text></inputExpression>
      </input>
      <output id="rt_out1_recovery_trajectory" label="action" name="action" typeRef="string"/>
      <output id="rt_out2_recovery_trajectory" label="trajectory" name="trajectory" typeRef="string"/>
      <output id="rt_out3_recovery_trajectory" label="justificativa" name="justificativa" typeRef="string"/>

      <rule id="rt_r1_recovery_trajectory">
        <inputEntry><text>"improving"</text></inputEntry>
        <inputEntry><text>true</text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"on_track"</text></outputEntry>
        <outputEntry><text>"Recuperação no ritmo esperado"</text></outputEntry>
      </rule>
      <rule id="rt_r2_recovery_trajectory">
        <inputEntry><text>"improving"</text></inputEntry>
        <inputEntry><text>false</text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"early_improvement"</text></outputEntry>
        <outputEntry><text>"Melhora inicial detectada, aguardar confirmação"</text></outputEntry>
      </rule>
      <rule id="rt_r3_recovery_trajectory">
        <inputEntry><text>"stable"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"plateau"</text></outputEntry>
        <outputEntry><text>"Platô atingido - avaliar necessidade de ajuste"</text></outputEntry>
      </rule>
      <rule id="rt_r4_recovery_trajectory">
        <inputEntry><text>"declining"</text></inputEntry>
        <inputEntry><text>true</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"deteriorating"</text></outputEntry>
        <outputEntry><text>"Deterioração significativa - intervenção imediata"</text></outputEntry>
      </rule>
      <rule id="rt_r5_recovery_trajectory">
        <inputEntry><text>"declining"</text></inputEntry>
        <inputEntry><text>false</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"possible_decline"</text></outputEntry>
        <outputEntry><text>"Possível declínio - monitorar de perto"</text></outputEntry>
      </rule>
      <rule id="rt_r6_recovery_trajectory">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"unknown"</text></outputEntry>
        <outputEntry><text>"Trajetória indeterminada"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_recovery_trajectory">
      <dmndi:DMNShape id="DMNShape_decision_recovery_trajectory" dmnElementRef="decision_recovery_trajectory">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
