<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  EWS-MEWS-002: MEWS Medium Risk (Score 3-4) - ENHANCED MONITORING
  ============================================================================

  Modified Early Warning Score medium risk alert for increased surveillance.
  This rule triggers enhanced monitoring protocol.

  Evidence Base: Subbe et al. (2001), QJM
  Response Level: Score 3-4 indicates need for increased observation frequency

  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_EWS_MEWS_002"
             name="MEWS Medium Risk Alert"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!--
    ═══════════════════════════════════════════════════════════════════════════
    EWS-MEWS-002: MEWS Medium Risk Score Alert (3-4)
    Version: 1.0.0 (2026-02-06)
    Clinical Domain: General Medicine / Ward Care
    ═══════════════════════════════════════════════════════════════════════════

    TRIGGER CONDITIONS:
    - MEWS total score 3-4 points (medium risk)
    - May indicate early deterioration

    CLINICAL ACTIONS REQUIRED:
    - Increase monitoring frequency to every 2 hours
    - Notify nurse in charge
    - Consider medical review within 4 hours

    EVIDENCE BASE:
    - MEWS 3-4: 2.1x increased mortality risk
    - Early intervention at this stage prevents escalation
    ═══════════════════════════════════════════════════════════════════════════
  -->

  <decision id="Decision_EWS_MEWS_002" name="[SP-CO-004 | clinical_safety/mews] MEWS Medium Risk Evaluation" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_EWS_MEWS_002" hitPolicy="FIRST">

      <!-- INPUT 1: MEWS Total Score -->
      <input id="Input_1_EWS_MEWS_002" label="MEWS Score Total">
        <inputExpression id="InputExpression_1_EWS_MEWS_002" typeRef="number">
          <text>mewsScoreTotal</text>
        </inputExpression>
      </input>

      <!-- INPUT 2: Trend Direction (worsening/stable/improving) -->
      <input id="Input_2_EWS_MEWS_002" label="Tendencia Score">
        <inputExpression id="InputExpression_2_EWS_MEWS_002" typeRef="string">
          <text>tendenciaScore</text>
        </inputExpression>
      </input>

      <!-- INPUT 3: Has Comorbidities -->
      <input id="Input_3_EWS_MEWS_002" label="Comorbidades">
        <inputExpression id="InputExpression_3_EWS_MEWS_002" typeRef="boolean">
          <text>temComorbidades</text>
        </inputExpression>
      </input>

      <!-- INPUT 4: Hours Since Admission -->
      <input id="Input_4_EWS_MEWS_002" label="Horas Desde Admissao">
        <inputExpression id="InputExpression_4_EWS_MEWS_002" typeRef="number">
          <text>horasDesdeAdmissao</text>
        </inputExpression>
      </input>

      <!-- OUTPUT 1: Alert Level -->
      <output id="Output_1_EWS_MEWS_002" label="Nivel Alerta" name="nivelAlerta" typeRef="string">
        <outputValues id="OutputValues_1_EWS_MEWS_002">
          <text>"Alerta", "Atencao", "Informativo", "OK", "Revisar"</text>
        </outputValues>
      </output>

      <!-- OUTPUT 2: Urgency -->
      <output id="Output_2_EWS_MEWS_002" label="Urgencia" name="urgencia" typeRef="string">
        <outputValues id="OutputValues_2_EWS_MEWS_002">
          <text>"IMEDIATA", "URGENTE", "ROTINA", "INFORMATIVA"</text>
        </outputValues>
      </output>

      <!-- OUTPUT 3: Required Action -->
      <output id="Output_3_EWS_MEWS_002" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>

      <!-- OUTPUT 4: Clinical Justification -->
      <output id="Output_4_EWS_MEWS_002" label="Justificativa Cientifica" name="justificativaCientifica" typeRef="string"/>

      <!-- RULE 1: Medium Risk + Worsening Trend -->
      <rule id="Rule_MediumRisk_Worsening_EWS_MEWS_002">
        <description>MEWS 3-4 with worsening trend requires urgent attention</description>
        <inputEntry id="InputEntry_1_1_EWS_MEWS_002">
          <text>[3..4]</text>
        </inputEntry>
        <inputEntry id="InputEntry_1_2_EWS_MEWS_002">
          <text>"piorando"</text>
        </inputEntry>
        <inputEntry id="InputEntry_1_3_EWS_MEWS_002">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_1_4_EWS_MEWS_002">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_1_1_EWS_MEWS_002">
          <text>"Atencao"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_1_2_EWS_MEWS_002">
          <text>"URGENTE"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_1_3_EWS_MEWS_002">
          <text>"Score em tendencia de piora. Solicitar avaliacao medica dentro de 2 horas. Aumentar frequencia de sinais vitais para cada 1 hora. Revisar prescricao e intervencoes. Preparar para possivel escalonamento."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_1_4_EWS_MEWS_002">
          <text>"MEWS 3-4 com tendencia de piora indica deterioracao ativa. Taxa de progressao para score critico: 35% em 6 horas se nao tratado. Intervencao precoce reduz mortalidade em 20%."</text>
        </outputEntry>
      </rule>

      <!-- RULE 2: Medium Risk + Comorbidities -->
      <rule id="Rule_MediumRisk_Comorbid_EWS_MEWS_002">
        <description>MEWS 3-4 with comorbidities needs enhanced monitoring</description>
        <inputEntry id="InputEntry_2_1_EWS_MEWS_002">
          <text>[3..4]</text>
        </inputEntry>
        <inputEntry id="InputEntry_2_2_EWS_MEWS_002">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_2_3_EWS_MEWS_002">
          <text>true</text>
        </inputEntry>
        <inputEntry id="InputEntry_2_4_EWS_MEWS_002">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_2_1_EWS_MEWS_002">
          <text>"Atencao"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_2_2_EWS_MEWS_002">
          <text>"URGENTE"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_2_3_EWS_MEWS_002">
          <text>"Paciente com comorbidades e MEWS moderado. Comunicar enfermeiro responsavel. Avaliacao medica em ate 4 horas. Revisar manejo de doencas de base. Monitorar cada 2 horas."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_2_4_EWS_MEWS_002">
          <text>"Comorbidades (diabetes, DPOC, ICC, DRC) reduzem reserva fisiologica. MEWS 3-4 nestes pacientes equivale a risco similar de MEWS 5 em pacientes sem comorbidades."</text>
        </outputEntry>
      </rule>

      <!-- RULE 3: Medium Risk + Early Admission (<24h) -->
      <rule id="Rule_MediumRisk_EarlyAdmission_EWS_MEWS_002">
        <description>MEWS 3-4 within first 24h of admission requires attention</description>
        <inputEntry id="InputEntry_3_1_EWS_MEWS_002">
          <text>[3..4]</text>
        </inputEntry>
        <inputEntry id="InputEntry_3_2_EWS_MEWS_002">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_3_3_EWS_MEWS_002">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_3_4_EWS_MEWS_002">
          <text>&lt;= 24</text>
        </inputEntry>
        <outputEntry id="OutputEntry_3_1_EWS_MEWS_002">
          <text>"Atencao"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_3_2_EWS_MEWS_002">
          <text>"URGENTE"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_3_3_EWS_MEWS_002">
          <text>"MEWS elevado nas primeiras 24h de admissao. Confirmar diagnostico de entrada adequado. Revisar plano terapeutico. Considerar necessidade de exames adicionais. Monitorar resposta ao tratamento."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_3_4_EWS_MEWS_002">
          <text>"Deterioracao precoce (primeiras 24h) frequentemente indica diagnostico incompleto ou tratamento inadequado. Reavaliacao clinica obrigatoria para ajuste de conduta."</text>
        </outputEntry>
      </rule>

      <!-- RULE 4: Medium Risk Stable -->
      <rule id="Rule_MediumRisk_Stable_EWS_MEWS_002">
        <description>MEWS 3-4 stable requires enhanced monitoring</description>
        <inputEntry id="InputEntry_4_1_EWS_MEWS_002">
          <text>[3..4]</text>
        </inputEntry>
        <inputEntry id="InputEntry_4_2_EWS_MEWS_002">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_4_3_EWS_MEWS_002">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_4_4_EWS_MEWS_002">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_4_1_EWS_MEWS_002">
          <text>"Atencao"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_4_2_EWS_MEWS_002">
          <text>"ROTINA"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_4_3_EWS_MEWS_002">
          <text>"Aumentar frequencia de sinais vitais para cada 2 horas. Comunicar enfermeiro responsavel pelo setor. Documentar em prontuario. Reavaliar em 4 horas ou se houver piora."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_4_4_EWS_MEWS_002">
          <text>"MEWS 3-4 indica risco aumentado mas ainda nao critico. Monitoramento intensificado permite detectar deterioracao precoce. 85% dos pacientes nao progridem se monitorados adequadamente."</text>
        </outputEntry>
      </rule>

      <!-- RULE 5: FALLBACK -->
      <rule id="Rule_Fallback_EWS_MEWS_002">
        <description>Dados incompletos ou fora do escopo desta regra</description>
        <inputEntry id="InputEntry_F_1_EWS_MEWS_002">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_F_2_EWS_MEWS_002">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_F_3_EWS_MEWS_002">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_F_4_EWS_MEWS_002">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_F_1_EWS_MEWS_002">
          <text>"Revisar"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_F_2_EWS_MEWS_002">
          <text>"ROTINA"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_F_3_EWS_MEWS_002">
          <text>"Score fora da faixa 3-4 ou dados incompletos. Verificar outras regras MEWS (001 para critico, 003 para baixo risco). Confirmar calculo correto."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_F_4_EWS_MEWS_002">
          <text>"Esta regra avalia especificamente MEWS 3-4. Valores diferentes devem ser avaliados por regras apropriadas ao nivel de risco."</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_EWS_MEWS_002">
      <dmndi:DMNShape id="DMNShape_Decision_EWS_MEWS_002" dmnElementRef="Decision_EWS_MEWS_002">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
