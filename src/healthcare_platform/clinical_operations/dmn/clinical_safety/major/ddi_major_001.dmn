<?xml version="1.0" encoding="UTF-8"?>
<!-- ============================================================================
     DDI-MAJOR-001: Varfarina + Antibioticos/Antifungicos - Hemorragia

     EVIDENCIA CLINICA:
     - Holbrook AM et al. Chest. 2012;141:e52S-88S (ACCP Guidelines)
     - Schelleman H et al. Arch Intern Med. 2010;170:1513-9
     - Lane MA et al. Am J Med. 2014;127:657-63

     MECANISMO: Antibioticos/antifungicos inibem CYP2C9 (metaboliza S-varfarina) ou
     destroem flora intestinal produtora de vitamina K. Metronidazol, fluconazol,
     sulfametoxazol sao os mais potentes. Aumento INR 2-5x em dias.

     INCIDENCIA: Sangramento maior em 3-5% em 30 dias de uso concomitante
     ============================================================================ -->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="DDI_MAJOR_001" name="DDI-MAJOR-001: Varfarina + Antibioticos" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="ddi_major_001_decision" name="[SP-CO-004 | clinical_safety/major] Varfarina + Antibioticos/Antifungicos - Hemorragia" camunda:historyTimeToLive="180">
    <decisionTable id="ddi_major_001_table" hitPolicy="FIRST">
      <input id="input_medicamentos_ativos_ddi_major_001_decision" label="Medicamentos Ativos">
        <inputExpression id="input_expr_medicamentos_ddi_major_001_decision" typeRef="string">
          <text>medicamentosAtivos</text>
        </inputExpression>
      </input>
      <input id="input_medicamento_novo_ddi_major_001_decision" label="Medicamento Novo">
        <inputExpression id="input_expr_novo_ddi_major_001_decision" typeRef="string">
          <text>medicamentoNovo</text>
        </inputExpression>
      </input>
      <input id="input_inr_atual_ddi_major_001_decision" label="INR Atual">
        <inputExpression id="input_expr_inr_ddi_major_001_decision" typeRef="number">
          <text>inrAtual</text>
        </inputExpression>
      </input>

      <output id="output_nivel_alerta_ddi_major_001_decision" name="nivelAlerta" typeRef="string">
        <outputValues><text>"Alerta","Atencao","Informativo","OK"</text></outputValues>
      </output>
      <output id="output_acao_requerida_ddi_major_001_decision" name="acaoRequerida" typeRef="string" />
      <output id="output_justificativa_ddi_major_001_decision" name="justificativaCientifica" typeRef="string" />

      <!-- Rule 1: Varfarina + Inibidor CYP2C9 potente + INR alto -->
      <rule id="rule_varfarina_cyp2c9_alto_ddi_major_001_decision">
        <inputEntry id="ie_varfarina_ativa_ddi_major_001_decision">
          <text>list contains(medicamentosAtivos, "VARFARINA") or list contains(medicamentosAtivos, "MAREVAN")</text>
        </inputEntry>
        <inputEntry id="ie_inibidor_potente_ddi_major_001_decision">
          <text>"METRONIDAZOL" or "FLUCONAZOL" or "SULFAMETOXAZOL" or "MICONAZOL" or "VORICONAZOL"</text>
        </inputEntry>
        <inputEntry id="ie_inr_alto_ddi_major_001_decision">
          <text>&gt; 3.0</text>
        </inputEntry>
        <outputEntry id="oe_alerta_alto_ddi_major_001_decision"><text>"Alerta"</text></outputEntry>
        <outputEntry id="oe_acao_alto_ddi_major_001_decision"><text>"RISCO HEMORRAGICO IMINENTE. INR >3 + inibidor CYP2C9. REDUZIR varfarina 25-50% empiricamente. Medir INR em 3-5 dias. Vigiar sinais sangramento (hematuria, melena, epistaxe). Considerar alternativa ao antibiotico se possivel."</text></outputEntry>
        <outputEntry id="oe_just_alto_ddi_major_001_decision"><text>"Metronidazol/fluconazol aumentam INR 2-3x em 5-7 dias. Alto risco hemorragia maior. Holbrook AM, Chest 2012."</text></outputEntry>
      </rule>

      <!-- Rule 2: Varfarina + Inibidor CYP2C9 potente + INR normal -->
      <rule id="rule_varfarina_cyp2c9_normal_ddi_major_001_decision">
        <inputEntry id="ie_varfarina_ativa2_ddi_major_001_decision">
          <text>list contains(medicamentosAtivos, "VARFARINA") or list contains(medicamentosAtivos, "MAREVAN")</text>
        </inputEntry>
        <inputEntry id="ie_inibidor_potente2_ddi_major_001_decision">
          <text>"METRONIDAZOL" or "FLUCONAZOL" or "SULFAMETOXAZOL" or "VORICONAZOL"</text>
        </inputEntry>
        <inputEntry id="ie_inr_normal_ddi_major_001_decision">
          <text>[2.0..3.0]</text>
        </inputEntry>
        <outputEntry id="oe_atencao_normal_ddi_major_001_decision"><text>"Atencao"</text></outputEntry>
        <outputEntry id="oe_acao_normal_ddi_major_001_decision"><text>"Considerar reducao profilatica de varfarina 10-25%. Medir INR em 5-7 dias obrigatoriamente. Orientar sinais de sangramento. Se antibiotico por >7 dias, monitorar INR semanalmente."</text></outputEntry>
        <outputEntry id="oe_just_normal_ddi_major_001_decision"><text>"Interacao previsivel. Ajuste proativo previne supraterapia. Lane MA, Am J Med 2014."</text></outputEntry>
      </rule>

      <!-- Rule 3: Varfarina + Antibiotico de menor risco -->
      <rule id="rule_varfarina_antibiotico_menor_ddi_major_001_decision">
        <inputEntry id="ie_varfarina_ativa3_ddi_major_001_decision">
          <text>list contains(medicamentosAtivos, "VARFARINA") or list contains(medicamentosAtivos, "MAREVAN")</text>
        </inputEntry>
        <inputEntry id="ie_antibiotico_menor_ddi_major_001_decision">
          <text>"AMOXICILINA" or "AZITROMICINA" or "CIPROFLOXACINO" or "CLARITROMICINA" or "LEVOFLOXACINO"</text>
        </inputEntry>
        <inputEntry id="ie_inr_any_ddi_major_001_decision">
          <text>-</text>
        </inputEntry>
        <outputEntry id="oe_atencao_menor_ddi_major_001_decision"><text>"Atencao"</text></outputEntry>
        <outputEntry id="oe_acao_menor_ddi_major_001_decision"><text>"Risco moderado de aumento INR (flora intestinal). Manter dose varfarina, monitorar INR em 7-10 dias se uso prolongado. Orientar sinais de sangramento."</text></outputEntry>
        <outputEntry id="oe_just_menor_ddi_major_001_decision"><text>"Antibioticos de espectro amplo reduzem flora produtora de vitamina K. Risco menor que inibidores CYP."</text></outputEntry>
      </rule>

      <!-- Fallback Rule -->
      <rule id="Rule_Fallback_ddi_major_001_decision">
        <inputEntry id="ie_fallback1_ddi_major_001_decision"><text>-</text></inputEntry>
        <inputEntry id="ie_fallback2_ddi_major_001_decision"><text>-</text></inputEntry>
        <inputEntry id="ie_fallback3_ddi_major_001_decision"><text>-</text></inputEntry>
        <outputEntry id="oe_fallback1_ddi_major_001_decision"><text>"OK"</text></outputEntry>
        <outputEntry id="oe_fallback2_ddi_major_001_decision"><text>""</text></outputEntry>
        <outputEntry id="oe_fallback3_ddi_major_001_decision"><text>""</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ddi_major_001_decision">
      <dmndi:DMNShape id="DMNShape_ddi_major_001_decision" dmnElementRef="ddi_major_001_decision">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
