             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_RSK_FALL_003" name="DRD" namespace="http://camunda.org/schema/1.0/dmn" exporter="Camunda Modeler" exporterVersion="5.32.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.7.0">
  <decision id="Decision_RSK_FALL_003" name="[SP-CO-004 | clinical_safety/fall] RSK_FALL_003: Baixo Risco de Queda" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_RSK_FALL_003" hitPolicy="FIRST">
      <input id="Input_scoreMorse_RSK_FALL_003" label="Scoremorse">
        <inputExpression id="InputExpression_scoreMorse_RSK_FALL_003" typeRef="number">
          <text>scoreMorse</text>
        </inputExpression>
      </input>

      <output id="Output_nivelAlerta_RSK_FALL_003" label="Nível de Alerta" name="nivelAlerta" typeRef="string">
        <outputValues id="UnaryTests_nivelAlerta_RSK_FALL_003">
          <text>"Alerta","Atencao","Informativo","OK"</text>
        </outputValues>
      </output>
      <output id="Output_nivelRisco_RSK_FALL_003" label="Nível de Risco" name="nivelRisco" typeRef="string">
        <outputValues id="UnaryTests_nivelRisco_RSK_FALL_003">
          <text>"MUITO_ALTO","ALTO","MODERADO","BAIXO"</text>
        </outputValues>
      </output>
      <output id="Output_intervencaoRequerida_RSK_FALL_003" label="Intervenção Requerida" name="intervencaoRequerida" typeRef="string" />
      <output id="Output_frequenciaMonitoramento_RSK_FALL_003" label="Frequência de Monitoramento" name="frequenciaMonitoramento" typeRef="string" />
      <rule id="DecisionRule_001_RSK_FALL_003">
        <inputEntry id="UnaryTests_001_01_RSK_FALL_003">
          <text></text>
        </inputEntry>

        <outputEntry id="LiteralExpression_001_01_RSK_FALL_003">
          <text>"Informativo"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_001_02_RSK_FALL_003">
          <text>"MODERADO"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_001_03_RSK_FALL_003">
          <text>"Baixo risco de queda. Orientações gerais de segurança."</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_001_04_RSK_FALL_003">
          <text>"Q8H"</text>
        </outputEntry>
