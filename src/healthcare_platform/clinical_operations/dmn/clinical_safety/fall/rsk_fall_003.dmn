        </inputEntry>

        <outputEntry id="LiteralExpression_999_01_RSK_FALL_003">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_999_02_RSK_FALL_003">
          <text>"BAIXO"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_999_03_RSK_FALL_003">
          <text>"Condição não atende critérios de alerta."</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_999_04_RSK_FALL_003">
          <text>"Q4H"</text>
