<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  EWS-qSOFA-006 - Early Warning Scores - qSOFA Rule 6
  ============================================================================
  Versao: 1.0.0 (2026-02-09)
  Categoria: CLINICAL_SAFETY
  Perspectiva: HOSPITAL (Clinico)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_EWS_qSOFA_006" name="Early Warning Scores - qSOFA Rule 6" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_EWS_qSOFA_006" name="[SP-CO-004 | clinical_safety/qsofa] Early Warning Scores - qSOFA Rule 6" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_EWS_qSOFA_006" hitPolicy="FIRST">

      <input id="Input_1_EWS_qSOFA_006" label="Frequencia Respiratoria">
        <inputExpression id="InputExpression_1_EWS_qSOFA_006" typeRef="number">
          <text>frequenciaRespiratoria</text>
        </inputExpression>
      </input>

      <input id="Input_2_EWS_qSOFA_006" label="Pressao Sistolica">
        <inputExpression id="InputExpression_2_EWS_qSOFA_006" typeRef="number">
          <text>pressaoSistolica</text>
        </inputExpression>
      </input>

      <input id="Input_3_EWS_qSOFA_006" label="Alteracao Mental">
        <inputExpression id="InputExpression_3_EWS_qSOFA_006" typeRef="boolean">
          <text>alteracaoMental</text>
        </inputExpression>
      </input>

      <output id="Output_1_EWS_qSOFA_006" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_EWS_qSOFA_006" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_EWS_qSOFA_006" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />
      <output id="Output_4_EWS_qSOFA_006" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>
      <output id="Output_5_EWS_qSOFA_006" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <rule id="Rule_Critico_1_EWS_qSOFA_006">
        <description>qSOFA >= 2 pontos - Alto risco de sepse</description>
        <inputEntry id="InputEntry_C1_1_EWS_qSOFA_006"><text>>= 22</text></inputEntry>
        <inputEntry id="InputEntry_C1_2_EWS_qSOFA_006"><text>&lt;= 100</text></inputEntry>
        <inputEntry id="InputEntry_C1_3_EWS_qSOFA_006"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_C1_1_EWS_qSOFA_006"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_C1_2_EWS_qSOFA_006"><text>"qSOFA >= 2: Alto risco de sepse. Avaliacao medica urgente necessaria."</text></outputEntry>
        <outputEntry id="OutputEntry_C1_3_EWS_qSOFA_006"><text>"Ativar protocolo de sepse, avaliar imediatamente."</text></outputEntry>
        <outputEntry id="OutputEntry_C1_4_EWS_qSOFA_006"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_C1_5_EWS_qSOFA_006"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_Alerta_1_EWS_qSOFA_006">
        <description>qSOFA = 1 ponto - Monitoramento</description>
        <inputEntry id="InputEntry_A1_1_EWS_qSOFA_006"><text>>= 22</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_EWS_qSOFA_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_EWS_qSOFA_006"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_A1_1_EWS_qSOFA_006"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_2_EWS_qSOFA_006"><text>"qSOFA = 1: Monitoramento necessario."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_3_EWS_qSOFA_006"><text>"Monitorar sinais vitais, reavaliar em 1-2h."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_4_EWS_qSOFA_006"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_5_EWS_qSOFA_006"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Normal_1_EWS_qSOFA_006">
        <description>qSOFA = 0 - Normal</description>
        <inputEntry id="InputEntry_N1_1_EWS_qSOFA_006"><text>&lt; 22</text></inputEntry>
        <inputEntry id="InputEntry_N1_2_EWS_qSOFA_006"><text>> 100</text></inputEntry>
        <inputEntry id="InputEntry_N1_3_EWS_qSOFA_006"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_N1_1_EWS_qSOFA_006"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_N1_2_EWS_qSOFA_006"><text>"qSOFA = 0: Parametros normais."</text></outputEntry>
        <outputEntry id="OutputEntry_N1_3_EWS_qSOFA_006"><text>"Continuar cuidados de rotina."</text></outputEntry>
        <outputEntry id="OutputEntry_N1_4_EWS_qSOFA_006"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_N1_5_EWS_qSOFA_006"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_EWS_qSOFA_006">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_EWS_qSOFA_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_EWS_qSOFA_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_EWS_qSOFA_006"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_EWS_qSOFA_006"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_EWS_qSOFA_006"><text>"Avaliar criterios qSOFA manualmente."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_EWS_qSOFA_006"><text>"Revisar sinais vitais e estado mental."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_EWS_qSOFA_006"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_EWS_qSOFA_006"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_EWS_qSOFA_006">
      <dmndi:DMNShape id="DMNShape_Decision_EWS_qSOFA_006" dmnElementRef="Decision_EWS_qSOFA_006">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>