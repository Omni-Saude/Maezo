<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_EWS_NEWS_003"
             name="NEWS2 Medium Risk (5-6)"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_EWS_NEWS_003" name="[SP-CO-004 | clinical_safety/news] NEWS2 Medium Risk Evaluation" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_EWS_NEWS_003" hitPolicy="FIRST">

      <input id="Input_1_EWS_NEWS_003" label="NEWS2 Score Total">
        <inputExpression id="InputExpression_1_EWS_NEWS_003" typeRef="number">
          <text>news2ScoreTotal</text>
        </inputExpression>
      </input>

      <input id="Input_2_EWS_NEWS_003" label="Trending Up">
        <inputExpression id="InputExpression_2_EWS_NEWS_003" typeRef="boolean">
          <text>scoreTrendingUp</text>
        </inputExpression>
      </input>

      <output id="Output_1_EWS_NEWS_003" label="Nivel Alerta" name="nivelAlerta" typeRef="string">
        <outputValues id="OutputValues_1_EWS_NEWS_003">
          <text>"Alerta", "Atencao", "Informativo", "OK", "Revisar"</text>
        </outputValues>
      </output>

      <output id="Output_2_EWS_NEWS_003" label="Urgencia" name="urgencia" typeRef="string">
        <outputValues id="OutputValues_2_EWS_NEWS_003">
          <text>"IMEDIATA", "URGENTE", "ROTINA", "INFORMATIVA"</text>
        </outputValues>
      </output>

      <output id="Output_3_EWS_NEWS_003" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4_EWS_NEWS_003" label="Justificativa Cientifica" name="justificativaCientifica" typeRef="string"/>

      <rule id="Rule_MediumRisk_Trending_EWS_NEWS_003">
        <description>Medium risk score trending upward - urgent review needed</description>
        <inputEntry id="InputEntry_1_1_EWS_NEWS_003">
          <text>[5..6]</text>
        </inputEntry>
        <inputEntry id="InputEntry_1_2_EWS_NEWS_003">
          <text>true</text>
        </inputEntry>
        <outputEntry id="OutputEntry_1_1_EWS_NEWS_003">
          <text>"Atencao"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_1_2_EWS_NEWS_003">
          <text>"URGENTE"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_1_3_EWS_NEWS_003">
          <text>"Score medio-elevado (5-6) com tendencia de piora. Avaliacao por medico clinico dentro de 1 hora. Aumentar frequencia de monitorizacao para cada 1 hora. Revisar plano terapeutico."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_1_4_EWS_NEWS_003">
          <text>"NEWS2 5-6 indica risco medio (mortalidade 3.1%). Tendencia ascendente sugere deterioracao progressiva requerendo intensificacao de cuidados antes de atingir risco alto."</text>
        </outputEntry>
      </rule>

      <rule id="Rule_MediumRisk_Stable_EWS_NEWS_003">
        <description>Medium risk score stable - enhanced monitoring</description>
        <inputEntry id="InputEntry_2_1_EWS_NEWS_003">
          <text>[5..6]</text>
        </inputEntry>
        <inputEntry id="InputEntry_2_2_EWS_NEWS_003">
          <text>false</text>
        </inputEntry>
        <outputEntry id="OutputEntry_2_1_EWS_NEWS_003">
          <text>"Atencao"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_2_2_EWS_NEWS_003">
          <text>"URGENTE"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_2_3_EWS_NEWS_003">
          <text>"Score medio (5-6) estavel. Avaliacao clinica urgente. Monitoramento a cada 1-2 horas. Identificar causa do score elevado e otimizar tratamento."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_2_4_EWS_NEWS_003">
          <text>"Score medio requer atencao medica urgente para prevenir deterioracao. Risco intermediario entre baixo (1-4) e alto (≥7)."</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Fallback_EWS_NEWS_003">
        <description>Score outside medium range</description>
        <inputEntry id="InputEntry_F_1_EWS_NEWS_003">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_F_2_EWS_NEWS_003">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_F_1_EWS_NEWS_003">
          <text>"Revisar"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_F_2_EWS_NEWS_003">
          <text>"INFORMATIVA"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_F_3_EWS_NEWS_003">
          <text>"Score fora da faixa medio-risco. Consultar outras regras NEWS2."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_F_4_EWS_NEWS_003">
          <text>"Score nao se enquadra nos criterios de risco medio (5-6)."</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_EWS_NEWS_003">
      <dmndi:DMNShape id="DMNShape_Decision_EWS_NEWS_003" dmnElementRef="Decision_EWS_NEWS_003">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
