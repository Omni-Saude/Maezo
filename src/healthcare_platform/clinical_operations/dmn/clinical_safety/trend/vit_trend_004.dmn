             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_VIT_TREND_004" name="DRD" namespace="http://camunda.org/schema/1.0/dmn" exporter="Camunda Modeler" exporterVersion="5.32.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.7.0">
  <decision id="Decision_VIT_TREND_004" name="[SP-CO-004 | clinical_safety/trend] VIT_TREND_004: Tríade de Cushing" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_VIT_TREND_004" hitPolicy="FIRST">
      <input id="Input_pressaoSistolica_VIT_TREND_004" label="Pressaosistolica">
        <inputExpression id="InputExpression_pressaoSistolica_VIT_TREND_004" typeRef="number">
          <text>pressaoSistolica</text>
        </inputExpression>
      </input>
      <input id="Input_frequenciaCardiaca_VIT_TREND_004" label="Frequenciacardiaca">
        <inputExpression id="InputExpression_frequenciaCardiaca_VIT_TREND_004" typeRef="number">
          <text>frequenciaCardiaca</text>
        </inputExpression>
      </input>
      <input id="Input_frequenciaRespiratoria_VIT_TREND_004" label="Frequenciarespiratoria">
        <inputExpression id="InputExpression_frequenciaRespiratoria_VIT_TREND_004" typeRef="number">
          <text>frequenciaRespiratoria</text>
        </inputExpression>
      </input>

      <output id="Output_nivelAlerta_VIT_TREND_004" label="Nível de Alerta" name="nivelAlerta" typeRef="string">
        <outputValues id="UnaryTests_nivelAlerta_VIT_TREND_004">
          <text>"Alerta","Atencao","Informativo","OK"</text>
        </outputValues>
      </output>
      <output id="Output_nivelRisco_VIT_TREND_004" label="Nível de Risco" name="nivelRisco" typeRef="string">
        <outputValues id="UnaryTests_nivelRisco_VIT_TREND_004">
          <text>"MUITO_ALTO","ALTO","MODERADO","BAIXO"</text>
        </outputValues>
      </output>
      <output id="Output_intervencaoRequerida_VIT_TREND_004" label="Intervenção Requerida" name="intervencaoRequerida" typeRef="string" />
      <output id="Output_frequenciaMonitoramento_VIT_TREND_004" label="Frequência de Monitoramento" name="frequenciaMonitoramento" typeRef="string" />
      <rule id="DecisionRule_001_VIT_TREND_004">
        <inputEntry id="UnaryTests_001_01_VIT_TREND_004">
          <text></text>
        </inputEntry>
        <inputEntry id="UnaryTests_001_02_VIT_TREND_004">
          <text></text>
        </inputEntry>
        <inputEntry id="UnaryTests_001_03_VIT_TREND_004">
          <text></text>
        </inputEntry>

        <outputEntry id="LiteralExpression_001_01_VIT_TREND_004">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_001_02_VIT_TREND_004">
          <text>"MUITO_ALTO"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_001_03_VIT_TREND_004">
          <text>"TRÍADE DE CUSHING - Suspeita de hipertensão intracraniana. TC crânio urgente. Acionar neurocirurgia."</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_001_04_VIT_TREND_004">
          <text>"CONTINUO"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_999_VIT_TREND_004">
        <inputEntry id="UnaryTests_999_01_VIT_TREND_004">
          <text></text>
        </inputEntry>
        <inputEntry id="UnaryTests_999_02_VIT_TREND_004">
          <text></text>
        </inputEntry>
        <inputEntry id="UnaryTests_999_03_VIT_TREND_004">
          <text></text>
        </inputEntry>

        <outputEntry id="LiteralExpression_999_01_VIT_TREND_004">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_999_02_VIT_TREND_004">
          <text>"BAIXO"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_999_03_VIT_TREND_004">
          <text>"Condição não atende critérios de alerta."</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_999_04_VIT_TREND_004">
          <text>"Q4H"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

