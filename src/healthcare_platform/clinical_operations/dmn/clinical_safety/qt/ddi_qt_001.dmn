<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="DDI_QT_001" name="DDI-QT-001: Amiodarona + Fluoroquinolonas" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="ddi_qt_001_decision" name="[SP-CO-004 | clinical_safety/qt] Amiodarona + Fluoroquinolonas QT Prolongation" camunda:historyTimeToLive="180">
    <decisionTable id="ddi_qt_001_table" hitPolicy="FIRST">
      <input id="input_medicamentos_ativos_ddi_qt_001_decision" label="Medicamentos Ativos">
        <inputExpression id="input_expr_medicamentos_ativos_ddi_qt_001_decision" typeRef="string">
          <text>medicamentosAtivos</text>
        </inputExpression>
      </input>
      <input id="input_medicamento_novo_ddi_qt_001_decision" label="Medicamento Novo">
        <inputExpression id="input_expr_medicamento_novo_ddi_qt_001_decision" typeRef="string">
          <text>medicamentoNovo</text>
        </inputExpression>
      </input>
      <input id="input_potassio_ddi_qt_001_decision" label="Potássio (mmol/L)">
        <inputExpression id="input_expr_potassio_ddi_qt_001_decision" typeRef="number">
          <text>potassio</text>
        </inputExpression>
      </input>
      <input id="input_historico_qt_ddi_qt_001_decision" label="Histórico QT Longo">
        <inputExpression id="input_expr_historico_ddi_qt_001_decision" typeRef="boolean">
          <text>historicoQTLongo</text>
        </inputExpression>
      </input>

      <output id="output_nivel_alerta_ddi_qt_001_decision" name="nivelAlerta" typeRef="string">
        <outputValues>
          <text>"Alerta","Atencao","Informativo"</text>
        </outputValues>
      </output>
      <output id="output_urgencia_ddi_qt_001_decision" name="urgencia" typeRef="string">
        <outputValues>
          <text>"IMEDIATA","URGENTE","ROTINA"</text>
        </outputValues>
      </output>
      <output id="output_medicamentos_conflitantes_ddi_qt_001_decision" name="medicamentosConflitantes" typeRef="string" />
      <output id="output_mecanismo_interacao_ddi_qt_001_decision" name="mecanismoInteracao" typeRef="string" />
      <output id="output_acao_requerida_ddi_qt_001_decision" name="acaoRequerida" typeRef="string" />

      <!-- Rule 1: Amiodarona + Fluoroquinolonas com hipocalemia ou QT prévio -->
      <rule id="rule_amio_fluoro_alto_risco_ddi_qt_001_decision">
        <inputEntry id="input_medicamentos_amio_ddi_qt_001_decision">
          <text>list contains(medicamentosAtivos, "AMIODARONA")</text>
        </inputEntry>
        <inputEntry id="input_novo_fluoro_ddi_qt_001_decision">
          <text>"MOXIFLOXACINO" or "LEVOFLOXACINO" or "CIPROFLOXACINO"</text>
        </inputEntry>
        <inputEntry id="input_k_baixo_ddi_qt_001_decision">
          <text>&lt; 3.5</text>
        </inputEntry>
        <inputEntry id="input_qt_sim_ddi_qt_001_decision">
          <text>true</text>
        </inputEntry>
        <outputEntry id="output_alerta_alto_ddi_qt_001_decision">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_alto_ddi_qt_001_decision">
          <text>"IMEDIATA"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_alto_ddi_qt_001_decision">
          <text>"Amiodarona + Fluoroquinolona (K+&lt;3.5 + QT previo)"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_alto_ddi_qt_001_decision">
          <text>"Duplo bloqueio canais K+ (IKr) = prolongamento QTc aditivo. Risco Torsades de pointes CRITICO com hipocalemia."</text>
        </outputEntry>
        <outputEntry id="output_acao_alto_ddi_qt_001_decision">
          <text>"URGENTE: (1) Corrigir K+ &gt;4.0 mmol/L ANTES antibiotico, (2) Mg &gt;2.0, (3) ECG baseline + 48h + 7 dias, (4) Considerar antibiotico alternativo (doxiciclina, ceftriaxona). Se QTc&gt;500ms, SUSPENDER quinolona."</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: Amiodarona + Moxifloxacino (maior risco) -->
      <rule id="rule_amio_moxi_ddi_qt_001_decision">
        <inputEntry id="input_medicamentos_amio_moxi_ddi_qt_001_decision">
          <text>list contains(medicamentosAtivos, "AMIODARONA")</text>
        </inputEntry>
        <inputEntry id="input_novo_moxi_ddi_qt_001_decision">
          <text>"MOXIFLOXACINO"</text>
        </inputEntry>
        <inputEntry id="input_k_normal_ddi_qt_001_decision">
          <text>&gt;= 3.5</text>
        </inputEntry>
        <inputEntry id="input_qt_nao_ddi_qt_001_decision">
          <text>false</text>
        </inputEntry>
        <outputEntry id="output_alerta_moxi_ddi_qt_001_decision">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_moxi_ddi_qt_001_decision">
          <text>"URGENTE"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_moxi_ddi_qt_001_decision">
          <text>"Amiodarona + Moxifloxacino"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_moxi_ddi_qt_001_decision">
          <text>"Moxifloxacino possui MAIOR efeito QT entre fluoroquinolonas. Risco Torsades documentado."</text>
        </outputEntry>
        <outputEntry id="output_acao_moxi_ddi_qt_001_decision">
          <text>"EVITAR: Usar levofloxacino (menor efeito QT) ou ceftriaxona. Se ESSENCIAL: ECG baseline, K+/Mg normais, ECG 72h. Suspender se QTc&gt;500ms ou aumento &gt;60ms."</text>
        </outputEntry>
      </rule>

      <!-- Rule 3: Amiodarona + Levo/Cipro (menor risco mas monitorar) -->
      <rule id="rule_amio_levo_cipro_ddi_qt_001_decision">
        <inputEntry id="input_medicamentos_amio_lc_ddi_qt_001_decision">
          <text>list contains(medicamentosAtivos, "AMIODARONA")</text>
        </inputEntry>
        <inputEntry id="input_novo_lc_ddi_qt_001_decision">
          <text>"LEVOFLOXACINO" or "CIPROFLOXACINO"</text>
        </inputEntry>
        <inputEntry id="input_k_ok_ddi_qt_001_decision">
          <text>&gt;= 3.5</text>
        </inputEntry>
        <inputEntry id="input_qt_nao_lc_ddi_qt_001_decision">
          <text>-</text>
        </inputEntry>
        <outputEntry id="output_alerta_lc_ddi_qt_001_decision">
          <text>"Atencao"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_lc_ddi_qt_001_decision">
          <text>"URGENTE"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_lc_ddi_qt_001_decision">
          <text>"Amiodarona + Levofloxacino/Ciprofloxacino"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_lc_ddi_qt_001_decision">
          <text>"Prolongamento QT moderado. Risco menor que moxifloxacino."</text>
        </outputEntry>
        <outputEntry id="output_acao_lc_ddi_qt_001_decision">
          <text>"ECG baseline recomendado. K+ e Mg normais. Monitorar sintomas (palpitacoes, sincope). ECG 72h se historia cardiaca."</text>
        </outputEntry>
      </rule>

      <!-- Fallback Rule -->
      <rule id="rule_fallback_ddi_qt_001_decision">
        <inputEntry id="input_fallback_1_ddi_qt_001_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_fallback_2_ddi_qt_001_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_fallback_3_ddi_qt_001_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_fallback_4_ddi_qt_001_decision">
          <text>-</text>
        </inputEntry>
        <outputEntry id="output_fallback_1_ddi_qt_001_decision">
          <text>"Informativo"</text>
        </outputEntry>
        <outputEntry id="output_fallback_2_ddi_qt_001_decision">
          <text>"ROTINA"</text>
        </outputEntry>
        <outputEntry id="output_fallback_3_ddi_qt_001_decision">
          <text>""</text>
        </outputEntry>
        <outputEntry id="output_fallback_4_ddi_qt_001_decision">
          <text>""</text>
        </outputEntry>
        <outputEntry id="output_fallback_5_ddi_qt_001_decision">
          <text>""</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ddi_qt_001_decision">
      <dmndi:DMNShape id="DMNShape_ddi_qt_001_decision" dmnElementRef="ddi_qt_001_decision">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
