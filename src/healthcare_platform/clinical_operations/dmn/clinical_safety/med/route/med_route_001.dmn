<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
  id="clinical_safety_med_route_001" name="Administration Route Validation"
  namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="decision_med_route_001" name="[SP-CO-004 | clinical_safety/med] Administration Route Validation" camunda:historyTimeToLive="180">
    <decisionTable id="dt_med_route_001" hitPolicy="FIRST">
      <input id="input_1_med_route_001" label="medicationForm">
        <inputExpression typeRef="string"><text>medicationForm</text></inputExpression>
      </input>
      <input id="input_2_med_route_001" label="prescribedRoute">
        <inputExpression typeRef="string"><text>prescribedRoute</text></inputExpression>
      </input>
      <output id="output_1_med_route_001" label="action" name="action" typeRef="string"/>
      <output id="output_2_med_route_001" label="reason" name="reason" typeRef="string"/>
      <!-- Oral medication via IV = block -->
      <rule id="rule_1_med_route_001">
        <inputEntry><text>"ORAL_TABLET"</text></inputEntry>
        <inputEntry><text>"IV"</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"Via incompativel - comprimido oral nao pode ser IV"</text></outputEntry>
      </rule>
      <!-- IV medication via oral = block -->
      <rule id="rule_2_med_route_001">
        <inputEntry><text>"IV_SOLUTION"</text></inputEntry>
        <inputEntry><text>"ORAL"</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"Via incompativel - solucao IV nao pode ser oral"</text></outputEntry>
      </rule>
      <!-- Topical via IV = block -->
      <rule id="rule_3_med_route_001">
        <inputEntry><text>"TOPICAL"</text></inputEntry>
        <inputEntry><text>"IV"</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"Via incompativel - topico nao pode ser IV"</text></outputEntry>
      </rule>
      <!-- Default pass -->
      <rule id="rule_99_med_route_001">
        <inputEntry><text></text></inputEntry>
        <inputEntry><text></text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"Via compativel"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_med_route_001">
      <dmndi:DMNShape id="DMNShape_decision_med_route_001" dmnElementRef="decision_med_route_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
