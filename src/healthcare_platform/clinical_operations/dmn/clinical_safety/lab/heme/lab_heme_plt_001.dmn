<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:biodi="http://bpmn.io/schema/dmn/biodi/2.0"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="definitions_LAB-HEME-PLT-001" name="LAB-HEME-PLT-001" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="decision_LAB_HEME_PLT_001" name="[SP-CO-004 | clinical_safety/lab] Trombocitopenia Critica" camunda:historyTimeToLive="180">
    <decisionTable id="decisionTable_LAB_HEME_PLT_001" hitPolicy="FIRST">
      <input id="input_plaquetas_LAB_HEME_PLT_001" label="Plaquetas (/uL)">
        <inputExpression id="inputExpression_plaquetas_LAB_HEME_PLT_001" typeRef="number">
          <text>plaquetas</text>
        </inputExpression>
      </input>
      <input id="input_sangramento_ativo_LAB_HEME_PLT_001" label="Sangramento Ativo">
        <inputExpression id="inputExpression_sangramento_LAB_HEME_PLT_001" typeRef="boolean">
          <text>sangramentoAtivo</text>
        </inputExpression>
      </input>

      <output id="output_nivelAlerta_LAB_HEME_PLT_001" label="Nivel de Alerta" name="nivelAlerta" typeRef="string">
        <outputValues id="outputValues_nivelAlerta_LAB_HEME_PLT_001">
          <text>"Alerta","Atencao","OK"</text>
        </outputValues>
      </output>
      <output id="output_urgencia_LAB_HEME_PLT_001" label="Urgencia" name="urgencia" typeRef="string">
        <outputValues id="outputValues_urgencia_LAB_HEME_PLT_001">
          <text>"IMEDIATA","ALTA","MEDIA","BAIXA"</text>
        </outputValues>
      </output>
      <output id="output_classificacao_LAB_HEME_PLT_001" label="Classificacao" name="classificacao" typeRef="string" />
      <output id="output_tendencia_LAB_HEME_PLT_001" label="Tendencia" name="tendencia" typeRef="string" />
      <output id="output_acaoRequerida_LAB_HEME_PLT_001" label="Acao Requerida" name="acaoRequerida" typeRef="string" />
      <output id="output_justificativa_LAB_HEME_PLT_001" label="Justificativa Cientifica" name="justificativaCientifica" typeRef="string" />

      <!-- Critical thrombocytopenia with bleeding: Emergency transfusion -->
      <rule id="rule_001_LAB_HEME_PLT_001">
        <inputEntry id="inputEntry_001_1_LAB_HEME_PLT_001">
          <text>&lt; 10000</text>
        </inputEntry>
        <inputEntry id="inputEntry_001_2_LAB_HEME_PLT_001">
          <text>true</text>
        </inputEntry>
        <outputEntry id="outputEntry_001_1_LAB_HEME_PLT_001">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_2_LAB_HEME_PLT_001">
          <text>"IMEDIATA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_3_LAB_HEME_PLT_001">
          <text>"CRITICO_SANGRANDO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_4_LAB_HEME_PLT_001">
          <text>"HEMORRAGICO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_5_LAB_HEME_PLT_001">
          <text>"EMERGENCIA: Trombocitopenia severa com sangramento. Transfusao de plaquetas IMEDIATA. Alvo &gt;50.000 se sangramento grave ou SNC. Investigar causa: PTI, PTT/SHU, HIT, CIVD, falencia medular. Se suspeita de PTT (esquizocitos, LDH alto), NAO transfundir ate avaliacao - plasmaferese pode ser necessaria. Suspender anticoagulantes/antiagregantes."</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_6_LAB_HEME_PLT_001">
          <text>"Trombocitopenia &lt;10.000/uL com sangramento e emergencia hematologica. Risco de hemorragia intracraniana espontanea. Transfusao imediata exceto se PTT/HIT (investigar antes). Meta de plaquetas varia: &gt;10.000 profilaxia, &gt;50.000 sangramento, &gt;100.000 para neurocirugia."</text>
        </outputEntry>
      </rule>

      <!-- Critical thrombocytopenia without bleeding: Prophylactic transfusion threshold -->
      <rule id="rule_002_LAB_HEME_PLT_001">
        <inputEntry id="inputEntry_002_1_LAB_HEME_PLT_001">
          <text>&lt; 10000</text>
        </inputEntry>
        <inputEntry id="inputEntry_002_2_LAB_HEME_PLT_001">
          <text>false</text>
        </inputEntry>
        <outputEntry id="outputEntry_002_1_LAB_HEME_PLT_001">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_2_LAB_HEME_PLT_001">
          <text>"ALTA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_3_LAB_HEME_PLT_001">
          <text>"CRITICO_BAIXO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_4_LAB_HEME_PLT_001">
          <text>"RISCO_ESPONTANEO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_5_LAB_HEME_PLT_001">
          <text>"Trombocitopenia critica sem sangramento. Transfusao profilatica geralmente indicada com PLT &lt;10.000. Investigar etiologia: esfregaco, reticulocitos, LDH, haptoglobina, Coombs, coagulacao. Excluir PTT/HIT antes de transfundir. Evitar procedimentos invasivos. Precaucoes para sangramento."</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_6_LAB_HEME_PLT_001">
          <text>"Plaquetas &lt;10.000/uL conferem risco de sangramento espontaneo incluindo hemorragia intracraniana. Transfusao profilatica indicada na maioria dos casos, exceto PTT e HIT onde pode ser contraindicada."</text>
        </outputEntry>
      </rule>

      <!-- Severe thrombocytopenia: 10-20k -->
      <rule id="rule_003_LAB_HEME_PLT_001">
        <inputEntry id="inputEntry_003_1_LAB_HEME_PLT_001">
          <text>[10000..20000]</text>
        </inputEntry>
        <inputEntry id="inputEntry_003_2_LAB_HEME_PLT_001">
          <text>-</text>
        </inputEntry>
        <outputEntry id="outputEntry_003_1_LAB_HEME_PLT_001">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="outputEntry_003_2_LAB_HEME_PLT_001">
          <text>"ALTA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_003_3_LAB_HEME_PLT_001">
          <text>"SEVERO_BAIXO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_003_4_LAB_HEME_PLT_001">
          <text>"MUITO_BAIXO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_003_5_LAB_HEME_PLT_001">
          <text>"Trombocitopenia severa. Transfusao profilatica se febre, infeccao, mucosites ou uso de anticoagulantes. Investigar causa. Precaucoes para sangramento: evitar AINEs, injecoes IM, procedimentos invasivos. Monitorar para sangramento."</text>
        </outputEntry>
        <outputEntry id="outputEntry_003_6_LAB_HEME_PLT_001">
          <text>"Plaquetas 10.000-20.000/uL - risco de sangramento espontaneo menor, mas aumentado por fatores de risco (febre, mucosites, coagulopatia). Transfusao profilatica em situacoes de risco."</text>
        </outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="rule_fallback_LAB_HEME_PLT_001">
        <inputEntry id="inputEntry_fallback_1_LAB_HEME_PLT_001">
          <text>-</text>
        </inputEntry>
        <inputEntry id="inputEntry_fallback_2_LAB_HEME_PLT_001">
          <text>-</text>
        </inputEntry>
        <outputEntry id="outputEntry_fallback_1_LAB_HEME_PLT_001">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_2_LAB_HEME_PLT_001">
          <text>"BAIXA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_3_LAB_HEME_PLT_001">
          <text>"FORA_CRITERIO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_4_LAB_HEME_PLT_001">
          <text>"NAO_APLICAVEL"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_5_LAB_HEME_PLT_001">
          <text>"Plaquetas nao atendem criterio de trombocitopenia critica desta regra."</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_6_LAB_HEME_PLT_001">
          <text>"Esta regra monitora trombocitopenia critica com plaquetas &lt;20.000/uL."</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_LAB_HEME_PLT_001">
      <dmndi:DMNShape id="DMNShape_decision_LAB_HEME_PLT_001" dmnElementRef="decision_LAB_HEME_PLT_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
