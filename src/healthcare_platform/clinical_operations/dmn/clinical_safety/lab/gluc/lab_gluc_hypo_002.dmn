<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:biodi="http://bpmn.io/schema/dmn/biodi/2.0"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="definitions_LAB-GLUC-HYPO-002" name="LAB-GLUC-HYPO-002" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="decision_LAB_GLUC_HYPO_002" name="[SP-CO-004 | clinical_safety/lab] Hipoglicemia Moderada" camunda:historyTimeToLive="180">
    <decisionTable id="decisionTable_LAB_GLUC_HYPO_002" hitPolicy="FIRST">
      <input id="input_glicemia_LAB_GLUC_HYPO_002" label="Glicemia (mg/dL)">
        <inputExpression id="inputExpression_glicemia_LAB_GLUC_HYPO_002" typeRef="number">
          <text>glicemia</text>
        </inputExpression>
      </input>

      <output id="output_nivelAlerta_LAB_GLUC_HYPO_002" label="Nível de Alerta" name="nivelAlerta" typeRef="string">
        <outputValues id="outputValues_nivelAlerta_LAB_GLUC_HYPO_002">
          <text>"Alerta","Atencao","OK"</text>
        </outputValues>
      </output>
      <output id="output_urgencia_LAB_GLUC_HYPO_002" label="Urgência" name="urgencia" typeRef="string">
        <outputValues id="outputValues_urgencia_LAB_GLUC_HYPO_002">
          <text>"URGENTE","ROTINA"</text>
        </outputValues>
      </output>
      <output id="output_classificacao_LAB_GLUC_HYPO_002" label="Classificação" name="classificacao" typeRef="string" />
      <output id="output_tendencia_LAB_GLUC_HYPO_002" label="Tendência" name="tendencia" typeRef="string" />
      <output id="output_acaoRequerida_LAB_GLUC_HYPO_002" label="Ação Requerida" name="acaoRequerida" typeRef="string" />
      <output id="output_justificativa_LAB_GLUC_HYPO_002" label="Justificativa Científica" name="justificativaCientifica" typeRef="string" />

      <!-- Moderate hypoglycemia: glucose 40-53 mg/dL -->
      <rule id="rule_001_LAB_GLUC_HYPO_002">
        <inputEntry id="inputEntry_001_1_LAB_GLUC_HYPO_002">
          <text>[40..54)</text>
        </inputEntry>
        <outputEntry id="outputEntry_001_1_LAB_GLUC_HYPO_002">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_2_LAB_GLUC_HYPO_002">
          <text>"URGENTE"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_3_LAB_GLUC_HYPO_002">
          <text>"MODERADA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_4_LAB_GLUC_HYPO_002">
          <text>"MUITO_BAIXO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_5_LAB_GLUC_HYPO_002">
          <text>"Administrar 15-20g de carboidrato de ação rápida via oral (ex: 150-200ml suco de laranja, 3-4 tabletes de glicose). Verificar glicemia após 15 minutos. Se ainda abaixo de 70 mg/dL, repetir tratamento. Notificar equipe médica."</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_6_LAB_GLUC_HYPO_002">
          <text>"Hipoglicemia moderada (40-53 mg/dL) causa sintomas neurogênicos e neuroglicopênicos significativos. ADA 2024 recomenda regra dos 15-15: 15g de carboidrato, verificar após 15 minutos. Risco de progressão para hipoglicemia grave se não tratada."</text>
        </outputEntry>
      </rule>

      <!-- Fallback: Outside moderate range -->
      <rule id="rule_fallback_LAB_GLUC_HYPO_002">
        <inputEntry id="inputEntry_fallback_1_LAB_GLUC_HYPO_002">
          <text>-</text>
        </inputEntry>
        <outputEntry id="outputEntry_fallback_1_LAB_GLUC_HYPO_002">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_2_LAB_GLUC_HYPO_002">
          <text>"ROTINA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_3_LAB_GLUC_HYPO_002">
          <text>"FORA_CRITERIO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_4_LAB_GLUC_HYPO_002">
          <text>"NAO_APLICAVEL"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_5_LAB_GLUC_HYPO_002">
          <text>"Glicemia não atende critério de hipoglicemia moderada desta regra. Ver outras regras de glicemia."</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_6_LAB_GLUC_HYPO_002">
          <text>"Esta regra monitora especificamente hipoglicemia moderada 40-53 mg/dL. Valores fora desta faixa devem ser avaliados por outras regras específicas."</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_LAB_GLUC_HYPO_002">
      <dmndi:DMNShape id="DMNShape_decision_LAB_GLUC_HYPO_002" dmnElementRef="decision_LAB_GLUC_HYPO_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
