<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:biodi="http://bpmn.io/schema/dmn/biodi/2.0"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="definitions_LAB-ELECTRO-K-002" name="LAB-ELECTRO-K-002" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="decision_LAB_ELECTRO_K_002" name="[SP-CO-004 | clinical_safety/lab] Hipercalemia Crítica" camunda:historyTimeToLive="180">
    <decisionTable id="decisionTable_LAB_ELECTRO_K_002" hitPolicy="FIRST">
      <input id="input_potassio_LAB_ELECTRO_K_002" label="Potássio (mEq/L)">
        <inputExpression id="inputExpression_potassio_LAB_ELECTRO_K_002" typeRef="number">
          <text>potassio</text>
        </inputExpression>
      </input>

      <output id="output_nivelAlerta_LAB_ELECTRO_K_002" label="Nível de Alerta" name="nivelAlerta" typeRef="string">
        <outputValues id="outputValues_nivelAlerta_LAB_ELECTRO_K_002">
          <text>"Alerta","Atencao","OK"</text>
        </outputValues>
      </output>
      <output id="output_urgencia_LAB_ELECTRO_K_002" label="Urgência" name="urgencia" typeRef="string">
        <outputValues id="outputValues_urgencia_LAB_ELECTRO_K_002">
          <text>"IMEDIATA","ALTA","MEDIA","BAIXA"</text>
        </outputValues>
      </output>
      <output id="output_classificacao_LAB_ELECTRO_K_002" label="Classificação" name="classificacao" typeRef="string" />
      <output id="output_tendencia_LAB_ELECTRO_K_002" label="Tendência" name="tendencia" typeRef="string" />
      <output id="output_acaoRequerida_LAB_ELECTRO_K_002" label="Ação Requerida" name="acaoRequerida" typeRef="string" />
      <output id="output_justificativa_LAB_ELECTRO_K_002" label="Justificativa Científica" name="justificativaCientifica" typeRef="string" />

      <!-- Critical hyperkalemia: K+ >6.5 mEq/L -->
      <rule id="rule_001_LAB_ELECTRO_K_002">
        <inputEntry id="inputEntry_001_1_LAB_ELECTRO_K_002">
          <text>&gt; 6.5</text>
        </inputEntry>
        <outputEntry id="outputEntry_001_1_LAB_ELECTRO_K_002">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_2_LAB_ELECTRO_K_002">
          <text>"IMEDIATA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_3_LAB_ELECTRO_K_002">
          <text>"CRITICO_ALTO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_4_LAB_ELECTRO_K_002">
          <text>"PERIGOSAMENTE_ALTO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_5_LAB_ELECTRO_K_002">
          <text>"EMERGÊNCIA: ECG STAT. Monitoramento cardíaco contínuo. Protocolo hipercalemia: Gluconato de cálcio IV (estabilização membrana), Insulina+Glicose, Salbutamol nebulizado, Resina trocadora, considerar diálise urgente. Notificar nefrologista/intensivista IMEDIATAMENTE."</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_6_LAB_ELECTRO_K_002">
          <text>"Hipercalemia severa (&gt;6.5 mEq/L) causa bloqueios de condução cardíaca progressivos (alargamento QRS, ondas T apiculadas), bradicardia, fibrilação ventricular e assistolia. Risco de morte súbita. Tratamento emergencial visa estabilizar membrana cardíaca e remover potássio."</text>
        </outputEntry>
      </rule>

      <!-- Severe hyperkalemia: K+ 6.0-6.5 mEq/L -->
      <rule id="rule_002_LAB_ELECTRO_K_002">
        <inputEntry id="inputEntry_002_1_LAB_ELECTRO_K_002">
          <text>[6.0..6.5]</text>
        </inputEntry>
        <outputEntry id="outputEntry_002_1_LAB_ELECTRO_K_002">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_2_LAB_ELECTRO_K_002">
          <text>"IMEDIATA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_3_LAB_ELECTRO_K_002">
          <text>"SEVERO_ALTO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_4_LAB_ELECTRO_K_002">
          <text>"MUITO_ALTO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_5_LAB_ELECTRO_K_002">
          <text>"ECG urgente. Monitoramento cardíaco. Iniciar protocolo hipercalemia se alterações ECG. Suspender suplementos de K+, IECAs, diuréticos poupadores. Verificar função renal. Repetir dosagem em 1-2 horas."</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_6_LAB_ELECTRO_K_002">
          <text>"Hipercalemia severa (6.0-6.5 mEq/L) representa alto risco de arritmias fatais, especialmente se alterações ECG presentes. Alterações típicas: ondas T apiculadas, alargamento QRS, prolongamento PR. Requer intervenção urgente."</text>
        </outputEntry>
      </rule>

      <!-- Fallback: Outside critical range -->
      <rule id="rule_fallback_LAB_ELECTRO_K_002">
        <inputEntry id="inputEntry_fallback_1_LAB_ELECTRO_K_002">
          <text>-</text>
        </inputEntry>
        <outputEntry id="outputEntry_fallback_1_LAB_ELECTRO_K_002">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_2_LAB_ELECTRO_K_002">
          <text>"BAIXA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_3_LAB_ELECTRO_K_002">
          <text>"FORA_CRITERIO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_4_LAB_ELECTRO_K_002">
          <text>"NAO_APLICAVEL"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_5_LAB_ELECTRO_K_002">
          <text>"Potássio não atende critério de hipercalemia crítica desta regra. Ver outras regras de eletrólitos."</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_6_LAB_ELECTRO_K_002">
          <text>"Esta regra monitora especificamente hipercalemia crítica &gt;6.5 mEq/L. Valores fora desta faixa devem ser avaliados por outras regras específicas."</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_LAB_ELECTRO_K_002">
      <dmndi:DMNShape id="DMNShape_decision_LAB_ELECTRO_K_002" dmnElementRef="decision_LAB_ELECTRO_K_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
