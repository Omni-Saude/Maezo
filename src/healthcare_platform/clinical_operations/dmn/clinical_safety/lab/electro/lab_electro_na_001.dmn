<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:biodi="http://bpmn.io/schema/dmn/biodi/2.0"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="definitions_LAB-ELECTRO-NA-001" name="LAB-ELECTRO-NA-001" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="decision_LAB_ELECTRO_NA_001" name="[SP-CO-004 | clinical_safety/lab] Hiponatremia Crítica" camunda:historyTimeToLive="180">
    <decisionTable id="decisionTable_LAB_ELECTRO_NA_001" hitPolicy="FIRST">
      <input id="input_sodio_LAB_ELECTRO_NA_001" label="Sódio (mEq/L)">
        <inputExpression id="inputExpression_sodio_LAB_ELECTRO_NA_001" typeRef="number">
          <text>sodio</text>
        </inputExpression>
      </input>

      <output id="output_nivelAlerta_LAB_ELECTRO_NA_001" label="Nível de Alerta" name="nivelAlerta" typeRef="string">
        <outputValues id="outputValues_nivelAlerta_LAB_ELECTRO_NA_001">
          <text>"Alerta","Atencao","OK"</text>
        </outputValues>
      </output>
      <output id="output_urgencia_LAB_ELECTRO_NA_001" label="Urgência" name="urgencia" typeRef="string">
        <outputValues id="outputValues_urgencia_LAB_ELECTRO_NA_001">
          <text>"IMEDIATA","ALTA","MEDIA","BAIXA"</text>
        </outputValues>
      </output>
      <output id="output_classificacao_LAB_ELECTRO_NA_001" label="Classificação" name="classificacao" typeRef="string" />
      <output id="output_tendencia_LAB_ELECTRO_NA_001" label="Tendência" name="tendencia" typeRef="string" />
      <output id="output_acaoRequerida_LAB_ELECTRO_NA_001" label="Ação Requerida" name="acaoRequerida" typeRef="string" />
      <output id="output_justificativa_LAB_ELECTRO_NA_001" label="Justificativa Científica" name="justificativaCientifica" typeRef="string" />

      <!-- Critical hyponatremia: Na <120 mEq/L -->
      <rule id="rule_001_LAB_ELECTRO_NA_001">
        <inputEntry id="inputEntry_001_1_LAB_ELECTRO_NA_001">
          <text>&lt; 120</text>
        </inputEntry>
        <outputEntry id="outputEntry_001_1_LAB_ELECTRO_NA_001">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_2_LAB_ELECTRO_NA_001">
          <text>"IMEDIATA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_3_LAB_ELECTRO_NA_001">
          <text>"CRITICO_BAIXO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_4_LAB_ELECTRO_NA_001">
          <text>"PERIGOSAMENTE_BAIXO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_5_LAB_ELECTRO_NA_001">
          <text>"EMERGÊNCIA: Risco de convulsões e edema cerebral. Avaliar sintomas neurológicos urgentemente. Determinar causa e cronicidade. Se hiponatremia aguda sintomática: NaCl 3% IV bolus 100-150ml em 10-20min, pode repetir até melhora sintomas. CUIDADO: correção gradual (8-10 mEq/L/24h) para evitar mielinólise pontina. Notificar neurologista/intensivista IMEDIATAMENTE."</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_6_LAB_ELECTRO_NA_001">
          <text>"Hiponatremia severa (&lt;120 mEq/L) causa edema cerebral, confusão, convulsões, coma e herniação cerebral potencialmente fatal. Requer tratamento emergencial, mas correção deve ser gradual (máx 8-10 mEq/L em 24h) para prevenir síndrome de desmielinização osmótica (mielinólise pontina central)."</text>
        </outputEntry>
      </rule>

      <!-- Severe hyponatremia: 120-124 mEq/L -->
      <rule id="rule_002_LAB_ELECTRO_NA_001">
        <inputEntry id="inputEntry_002_1_LAB_ELECTRO_NA_001">
          <text>[120..124]</text>
        </inputEntry>
        <outputEntry id="outputEntry_002_1_LAB_ELECTRO_NA_001">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_2_LAB_ELECTRO_NA_001">
          <text>"ALTA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_3_LAB_ELECTRO_NA_001">
          <text>"SEVERO_BAIXO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_4_LAB_ELECTRO_NA_001">
          <text>"MUITO_BAIXO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_5_LAB_ELECTRO_NA_001">
          <text>"Avaliar sintomas neurológicos (confusão, náuseas, letargia). Investigar causa: SIADH, polidipsia, diuréticos, insuficiência cardíaca/hepática. Determinar cronicidade. Correção cautelosa conforme protocolo (máx 8-10 mEq/L/24h). Considerar restrição hídrica ou NaCl 3% se sintomático."</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_6_LAB_ELECTRO_NA_001">
          <text>"Hiponatremia severa (120-124 mEq/L) aumenta risco de sintomas neurológicos. Correção rápida demais pode causar mielinólise pontina (sequelas neurológicas irreversíveis). Taxa de correção máxima: 8-10 mEq/L em 24 horas."</text>
        </outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="rule_fallback_LAB_ELECTRO_NA_001">
        <inputEntry id="inputEntry_fallback_1_LAB_ELECTRO_NA_001">
          <text>-</text>
        </inputEntry>
        <outputEntry id="outputEntry_fallback_1_LAB_ELECTRO_NA_001">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_2_LAB_ELECTRO_NA_001">
          <text>"BAIXA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_3_LAB_ELECTRO_NA_001">
          <text>"FORA_CRITERIO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_4_LAB_ELECTRO_NA_001">
          <text>"NAO_APLICAVEL"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_5_LAB_ELECTRO_NA_001">
          <text>"Sódio não atende critério de hiponatremia crítica desta regra."</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_6_LAB_ELECTRO_NA_001">
          <text>"Esta regra monitora hiponatremia crítica &lt;120 mEq/L."</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_LAB_ELECTRO_NA_001">
      <dmndi:DMNShape id="DMNShape_decision_LAB_ELECTRO_NA_001" dmnElementRef="decision_LAB_ELECTRO_NA_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
