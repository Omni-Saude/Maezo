<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:biodi="http://bpmn.io/schema/dmn/biodi/2.0"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="definitions_LAB-ELECTRO-K-004" name="LAB-ELECTRO-K-004" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="decision_LAB_ELECTRO_K_004" name="[SP-CO-004 | clinical_safety/lab] Potássio Normal" camunda:historyTimeToLive="180">
    <decisionTable id="decisionTable_LAB_ELECTRO_K_004" hitPolicy="FIRST">
      <input id="input_potassio_LAB_ELECTRO_K_004" label="Potássio (mEq/L)">
        <inputExpression id="inputExpression_potassio_LAB_ELECTRO_K_004" typeRef="number">
          <text>potassio</text>
        </inputExpression>
      </input>

      <output id="output_nivelAlerta_LAB_ELECTRO_K_004" label="Nível de Alerta" name="nivelAlerta" typeRef="string">
        <outputValues id="outputValues_nivelAlerta_LAB_ELECTRO_K_004">
          <text>"Alerta","Atencao","OK"</text>
        </outputValues>
      </output>
      <output id="output_urgencia_LAB_ELECTRO_K_004" label="Urgência" name="urgencia" typeRef="string">
        <outputValues id="outputValues_urgencia_LAB_ELECTRO_K_004">
          <text>"IMEDIATA","ALTA","MEDIA","BAIXA"</text>
        </outputValues>
      </output>
      <output id="output_classificacao_LAB_ELECTRO_K_004" label="Classificação" name="classificacao" typeRef="string" />
      <output id="output_tendencia_LAB_ELECTRO_K_004" label="Tendência" name="tendencia" typeRef="string" />
      <output id="output_acaoRequerida_LAB_ELECTRO_K_004" label="Ação Requerida" name="acaoRequerida" typeRef="string" />
      <output id="output_justificativa_LAB_ELECTRO_K_004" label="Justificativa Científica" name="justificativaCientifica" typeRef="string" />

      <!-- Normal potassium: 3.5-5.0 mEq/L -->
      <rule id="rule_001_LAB_ELECTRO_K_004">
        <inputEntry id="inputEntry_001_1_LAB_ELECTRO_K_004">
          <text>[3.5..5.0]</text>
        </inputEntry>
        <outputEntry id="outputEntry_001_1_LAB_ELECTRO_K_004">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_2_LAB_ELECTRO_K_004">
          <text>"BAIXA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_3_LAB_ELECTRO_K_004">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_4_LAB_ELECTRO_K_004">
          <text>"ESTAVEL"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_5_LAB_ELECTRO_K_004">
          <text>"Potássio dentro da faixa normal. Manter monitoramento de rotina conforme protocolo institucional."</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_6_LAB_ELECTRO_K_004">
          <text>"Potássio normal (3.5-5.0 mEq/L) mantém função neuromuscular e cardíaca adequadas. Monitoramento periódico é adequado para pacientes em uso de diuréticos, IECAs ou com doenças renais."</text>
        </outputEntry>
      </rule>

      <!-- Borderline low: 3.5-3.6 mEq/L -->
      <rule id="rule_002_LAB_ELECTRO_K_004">
        <inputEntry id="inputEntry_002_1_LAB_ELECTRO_K_004">
          <text>[3.5..3.6]</text>
        </inputEntry>
        <outputEntry id="outputEntry_002_1_LAB_ELECTRO_K_004">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_2_LAB_ELECTRO_K_004">
          <text>"MEDIA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_3_LAB_ELECTRO_K_004">
          <text>"LIMINAR_BAIXO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_4_LAB_ELECTRO_K_004">
          <text>"ESTAVEL"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_5_LAB_ELECTRO_K_004">
          <text>"Potássio no limite inferior da normalidade. Atenção se paciente em uso de diuréticos ou com perdas GI. Considerar repetir em 48-72h se fatores de risco presentes."</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_6_LAB_ELECTRO_K_004">
          <text>"Potássio liminar inferior requer vigilância em pacientes com fatores de risco para hipocalemia (diuréticos, diarreia, vômitos) para prevenir progressão."</text>
        </outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="rule_fallback_LAB_ELECTRO_K_004">
        <inputEntry id="inputEntry_fallback_1_LAB_ELECTRO_K_004">
          <text>-</text>
        </inputEntry>
        <outputEntry id="outputEntry_fallback_1_LAB_ELECTRO_K_004">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_2_LAB_ELECTRO_K_004">
          <text>"BAIXA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_3_LAB_ELECTRO_K_004">
          <text>"FORA_CRITERIO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_4_LAB_ELECTRO_K_004">
          <text>"NAO_APLICAVEL"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_5_LAB_ELECTRO_K_004">
          <text>"Valor não atende critério de normalidade desta regra."</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_6_LAB_ELECTRO_K_004">
          <text>"Esta regra monitora potássio na faixa normal (3.5-5.0 mEq/L)."</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_LAB_ELECTRO_K_004">
      <dmndi:DMNShape id="DMNShape_decision_LAB_ELECTRO_K_004" dmnElementRef="decision_LAB_ELECTRO_K_004">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
