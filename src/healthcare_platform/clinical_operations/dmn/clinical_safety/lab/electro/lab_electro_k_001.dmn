<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:biodi="http://bpmn.io/schema/dmn/biodi/2.0"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="definitions_LAB-ELECTRO-K-001" name="LAB-ELECTRO-K-001" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="decision_LAB_ELECTRO_K_001" name="[SP-CO-004 | clinical_safety/lab] Hipocalemia Crítica" camunda:historyTimeToLive="180">
    <decisionTable id="decisionTable_LAB_ELECTRO_K_001" hitPolicy="FIRST">
      <input id="input_potassio_LAB_ELECTRO_K_001" label="Potássio (mEq/L)">
        <inputExpression id="inputExpression_potassio_LAB_ELECTRO_K_001" typeRef="number">
          <text>potassio</text>
        </inputExpression>
      </input>

      <output id="output_nivelAlerta_LAB_ELECTRO_K_001" label="Nível de Alerta" name="nivelAlerta" typeRef="string">
        <outputValues id="outputValues_nivelAlerta_LAB_ELECTRO_K_001">
          <text>"Alerta","Atencao","OK"</text>
        </outputValues>
      </output>
      <output id="output_urgencia_LAB_ELECTRO_K_001" label="Urgência" name="urgencia" typeRef="string">
        <outputValues id="outputValues_urgencia_LAB_ELECTRO_K_001">
          <text>"IMEDIATA","ALTA","MEDIA","BAIXA"</text>
        </outputValues>
      </output>
      <output id="output_classificacao_LAB_ELECTRO_K_001" label="Classificação" name="classificacao" typeRef="string" />
      <output id="output_tendencia_LAB_ELECTRO_K_001" label="Tendência" name="tendencia" typeRef="string" />
      <output id="output_acaoRequerida_LAB_ELECTRO_K_001" label="Ação Requerida" name="acaoRequerida" typeRef="string" />
      <output id="output_justificativa_LAB_ELECTRO_K_001" label="Justificativa Científica" name="justificativaCientifica" typeRef="string" />

      <!-- Critical hypokalemia: K+ <2.5 mEq/L -->
      <rule id="rule_001_LAB_ELECTRO_K_001">
        <inputEntry id="inputEntry_001_1_LAB_ELECTRO_K_001">
          <text>&lt; 2.5</text>
        </inputEntry>
        <outputEntry id="outputEntry_001_1_LAB_ELECTRO_K_001">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_2_LAB_ELECTRO_K_001">
          <text>"IMEDIATA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_3_LAB_ELECTRO_K_001">
          <text>"CRITICO_BAIXO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_4_LAB_ELECTRO_K_001">
          <text>"PERIGOSAMENTE_BAIXO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_5_LAB_ELECTRO_K_001">
          <text>"Reposição imediata de potássio. ECG urgente. Monitoramento cardíaco contínuo. Avaliar causas: diuréticos, diarreia, vômitos. Notificar intensivista/cardiologista IMEDIATAMENTE."</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_6_LAB_ELECTRO_K_001">
          <text>"Hipocalemia severa (&lt;2.5 mEq/L) causa arritmias ventriculares potencialmente fatais (torsades de pointes), fraqueza muscular grave, e pode levar a parada cardíaca. Reposição urgente é mandatória com monitoramento ECG contínuo."</text>
        </outputEntry>
      </rule>

      <!-- Severe hypokalemia: K+ 2.0-2.4 mEq/L -->
      <rule id="rule_002_LAB_ELECTRO_K_001">
        <inputEntry id="inputEntry_002_1_LAB_ELECTRO_K_001">
          <text>[2.0..2.4]</text>
        </inputEntry>
        <outputEntry id="outputEntry_002_1_LAB_ELECTRO_K_001">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_2_LAB_ELECTRO_K_001">
          <text>"IMEDIATA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_3_LAB_ELECTRO_K_001">
          <text>"SEVERO_BAIXO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_4_LAB_ELECTRO_K_001">
          <text>"MUITO_BAIXO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_5_LAB_ELECTRO_K_001">
          <text>"Reposição urgente de potássio IV. ECG de controle. Monitorar função renal. Verificar magnésio sérico. Reavaliação em 2-4 horas."</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_6_LAB_ELECTRO_K_001">
          <text>"Hipocalemia severa aumenta significativamente o risco de arritmias, especialmente em pacientes com cardiopatia ou em uso de digitálicos. Reposição deve ser cautelosa para evitar hipercalemia de rebote."</text>
        </outputEntry>
      </rule>

      <!-- Fallback: Outside critical range -->
      <rule id="rule_fallback_LAB_ELECTRO_K_001">
        <inputEntry id="inputEntry_fallback_1_LAB_ELECTRO_K_001">
          <text>-</text>
        </inputEntry>
        <outputEntry id="outputEntry_fallback_1_LAB_ELECTRO_K_001">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_2_LAB_ELECTRO_K_001">
          <text>"BAIXA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_3_LAB_ELECTRO_K_001">
          <text>"FORA_CRITERIO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_4_LAB_ELECTRO_K_001">
          <text>"NAO_APLICAVEL"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_5_LAB_ELECTRO_K_001">
          <text>"Potássio não atende critério de hipocalemia crítica desta regra. Ver outras regras de eletrólitos."</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_6_LAB_ELECTRO_K_001">
          <text>"Esta regra monitora especificamente hipocalemia crítica &lt;2.5 mEq/L. Valores fora desta faixa devem ser avaliados por outras regras específicas."</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_LAB_ELECTRO_K_001">
      <dmndi:DMNShape id="DMNShape_decision_LAB_ELECTRO_K_001" dmnElementRef="decision_LAB_ELECTRO_K_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
