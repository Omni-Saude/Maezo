<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:biodi="http://bpmn.io/schema/dmn/biodi/2.0"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="definitions_LAB-ELECTRO-PHOS-002" name="LAB-ELECTRO-PHOS-002" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="decision_LAB_ELECTRO_PHOS_002" name="[SP-CO-004 | clinical_safety/lab] Hiperfosfatemia Critica" camunda:historyTimeToLive="180">
    <decisionTable id="decisionTable_LAB_ELECTRO_PHOS_002" hitPolicy="FIRST">
      <input id="input_fosforo_LAB_ELECTRO_PHOS_002" label="Fosforo (mg/dL)">
        <inputExpression id="inputExpression_fosforo_LAB_ELECTRO_PHOS_002" typeRef="number">
          <text>fosforo</text>
        </inputExpression>
      </input>
      <input id="input_calcio_LAB_ELECTRO_PHOS_002" label="Calcio Serico (mg/dL)">
        <inputExpression id="inputExpression_calcio_LAB_ELECTRO_PHOS_002" typeRef="number">
          <text>calcioSerico</text>
        </inputExpression>
      </input>

      <output id="output_nivelAlerta_LAB_ELECTRO_PHOS_002" label="Nivel de Alerta" name="nivelAlerta" typeRef="string">
        <outputValues id="outputValues_nivelAlerta_LAB_ELECTRO_PHOS_002">
          <text>"Alerta","Atencao","OK"</text>
        </outputValues>
      </output>
      <output id="output_urgencia_LAB_ELECTRO_PHOS_002" label="Urgencia" name="urgencia" typeRef="string">
        <outputValues id="outputValues_urgencia_LAB_ELECTRO_PHOS_002">
          <text>"IMEDIATA","ALTA","MEDIA","BAIXA"</text>
        </outputValues>
      </output>
      <output id="output_classificacao_LAB_ELECTRO_PHOS_002" label="Classificacao" name="classificacao" typeRef="string" />
      <output id="output_tendencia_LAB_ELECTRO_PHOS_002" label="Tendencia" name="tendencia" typeRef="string" />
      <output id="output_acaoRequerida_LAB_ELECTRO_PHOS_002" label="Acao Requerida" name="acaoRequerida" typeRef="string" />
      <output id="output_justificativa_LAB_ELECTRO_PHOS_002" label="Justificativa Cientifica" name="justificativaCientifica" typeRef="string" />

      <!-- Critical hyperphosphatemia with high Ca-P product: Risk of metastatic calcification -->
      <rule id="rule_001_LAB_ELECTRO_PHOS_002">
        <inputEntry id="inputEntry_001_1_LAB_ELECTRO_PHOS_002">
          <text>&gt; 8.0</text>
        </inputEntry>
        <inputEntry id="inputEntry_001_2_LAB_ELECTRO_PHOS_002">
          <text>&gt; 9.0</text>
        </inputEntry>
        <outputEntry id="outputEntry_001_1_LAB_ELECTRO_PHOS_002">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_2_LAB_ELECTRO_PHOS_002">
          <text>"IMEDIATA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_3_LAB_ELECTRO_PHOS_002">
          <text>"CRITICO_PRODUTO_ALTO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_4_LAB_ELECTRO_PHOS_002">
          <text>"PERIGOSAMENTE_ALTO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_5_LAB_ELECTRO_PHOS_002">
          <text>"EMERGENCIA: Hiperfosfatemia severa com produto Ca x P elevado. RISCO de calcificacao metastatica (vascular, tecidos moles). Dialise URGENTE se DRC. Quelantes de fosforo em altas doses. EVITAR calcio IV. Dieta restrita em fosforo. Investigar causa: rabdomiolise, sindrome de lise tumoral, IRA."</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_6_LAB_ELECTRO_PHOS_002">
          <text>"Produto calcio-fosforo &gt;70 mg2/dL2 causa precipitacao de fosfato de calcio em tecidos moles, vasos e orgaos. Calcificacao vascular aumenta mortalidade cardiovascular. Dialise e tratamento mais eficaz em casos agudos severos."</text>
        </outputEntry>
      </rule>

      <!-- Severe hyperphosphatemia: >8.0 mg/dL -->
      <rule id="rule_002_LAB_ELECTRO_PHOS_002">
        <inputEntry id="inputEntry_002_1_LAB_ELECTRO_PHOS_002">
          <text>&gt; 8.0</text>
        </inputEntry>
        <inputEntry id="inputEntry_002_2_LAB_ELECTRO_PHOS_002">
          <text>-</text>
        </inputEntry>
        <outputEntry id="outputEntry_002_1_LAB_ELECTRO_PHOS_002">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_2_LAB_ELECTRO_PHOS_002">
          <text>"ALTA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_3_LAB_ELECTRO_PHOS_002">
          <text>"SEVERO_ALTO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_4_LAB_ELECTRO_PHOS_002">
          <text>"MUITO_ALTO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_5_LAB_ELECTRO_PHOS_002">
          <text>"Hiperfosfatemia severa. Quelantes de fosforo (sevelamer, carbonato de lantanio). Dieta restrita em fosforo. Avaliar funcao renal - se DRC, considerar dialise. Verificar calcio e PTH. Investigar sindrome de lise tumoral ou rabdomiolise."</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_6_LAB_ELECTRO_PHOS_002">
          <text>"Hiperfosfatemia &gt;8 mg/dL geralmente indica DRC avancada, sindrome de lise tumoral, ou rabdomiolise. Causa hipocalcemia secundaria por quelacao. Tratamento depende da etiologia e funcao renal."</text>
        </outputEntry>
      </rule>

      <!-- Moderate hyperphosphatemia with hypocalcemia: 6.0-8.0 with low calcium -->
      <rule id="rule_003_LAB_ELECTRO_PHOS_002">
        <inputEntry id="inputEntry_003_1_LAB_ELECTRO_PHOS_002">
          <text>[6.0..8.0]</text>
        </inputEntry>
        <inputEntry id="inputEntry_003_2_LAB_ELECTRO_PHOS_002">
          <text>&lt; 8.0</text>
        </inputEntry>
        <outputEntry id="outputEntry_003_1_LAB_ELECTRO_PHOS_002">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="outputEntry_003_2_LAB_ELECTRO_PHOS_002">
          <text>"ALTA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_003_3_LAB_ELECTRO_PHOS_002">
          <text>"MODERADO_COM_HIPOCALCEMIA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_003_4_LAB_ELECTRO_PHOS_002">
          <text>"ALTO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_003_5_LAB_ELECTRO_PHOS_002">
          <text>"Hiperfosfatemia com hipocalcemia secundaria. CUIDADO ao repor calcio (pode precipitar). Tratar hiperfosfatemia primeiro. Quelantes de fosforo. Monitorar sintomas de hipocalcemia (tetania)."</text>
        </outputEntry>
        <outputEntry id="outputEntry_003_6_LAB_ELECTRO_PHOS_002">
          <text>"Hiperfosfatemia causa hipocalcemia por quelacao e deposicao tecidual. Reposicao de calcio deve ser cautelosa para evitar precipitacao de CaPO4. Priorizar reducao do fosforo."</text>
        </outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="rule_fallback_LAB_ELECTRO_PHOS_002">
        <inputEntry id="inputEntry_fallback_1_LAB_ELECTRO_PHOS_002">
          <text>-</text>
        </inputEntry>
        <inputEntry id="inputEntry_fallback_2_LAB_ELECTRO_PHOS_002">
          <text>-</text>
        </inputEntry>
        <outputEntry id="outputEntry_fallback_1_LAB_ELECTRO_PHOS_002">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_2_LAB_ELECTRO_PHOS_002">
          <text>"BAIXA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_3_LAB_ELECTRO_PHOS_002">
          <text>"FORA_CRITERIO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_4_LAB_ELECTRO_PHOS_002">
          <text>"NAO_APLICAVEL"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_5_LAB_ELECTRO_PHOS_002">
          <text>"Fosforo nao atende criterio de hiperfosfatemia critica desta regra."</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_6_LAB_ELECTRO_PHOS_002">
          <text>"Esta regra monitora hiperfosfatemia critica com fosforo &gt;6.0 mg/dL."</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_LAB_ELECTRO_PHOS_002">
      <dmndi:DMNShape id="DMNShape_decision_LAB_ELECTRO_PHOS_002" dmnElementRef="decision_LAB_ELECTRO_PHOS_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
