<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:biodi="http://bpmn.io/schema/dmn/biodi/2.0"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="definitions_LAB-ELECTRO-PHOS-001" name="LAB-ELECTRO-PHOS-001" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="decision_LAB_ELECTRO_PHOS_001" name="[SP-CO-004 | clinical_safety/lab] Hipofosfatemia Critica" camunda:historyTimeToLive="180">
    <decisionTable id="decisionTable_LAB_ELECTRO_PHOS_001" hitPolicy="FIRST">
      <input id="input_fosforo_LAB_ELECTRO_PHOS_001" label="Fosforo (mg/dL)">
        <inputExpression id="inputExpression_fosforo_LAB_ELECTRO_PHOS_001" typeRef="number">
          <text>fosforo</text>
        </inputExpression>
      </input>
      <input id="input_ventilacao_mecanica_LAB_ELECTRO_PHOS_001" label="Em Ventilacao Mecanica">
        <inputExpression id="inputExpression_vm_LAB_ELECTRO_PHOS_001" typeRef="boolean">
          <text>emVentilacaoMecanica</text>
        </inputExpression>
      </input>

      <output id="output_nivelAlerta_LAB_ELECTRO_PHOS_001" label="Nivel de Alerta" name="nivelAlerta" typeRef="string">
        <outputValues id="outputValues_nivelAlerta_LAB_ELECTRO_PHOS_001">
          <text>"Alerta","Atencao","OK"</text>
        </outputValues>
      </output>
      <output id="output_urgencia_LAB_ELECTRO_PHOS_001" label="Urgencia" name="urgencia" typeRef="string">
        <outputValues id="outputValues_urgencia_LAB_ELECTRO_PHOS_001">
          <text>"IMEDIATA","ALTA","MEDIA","BAIXA"</text>
        </outputValues>
      </output>
      <output id="output_classificacao_LAB_ELECTRO_PHOS_001" label="Classificacao" name="classificacao" typeRef="string" />
      <output id="output_tendencia_LAB_ELECTRO_PHOS_001" label="Tendencia" name="tendencia" typeRef="string" />
      <output id="output_acaoRequerida_LAB_ELECTRO_PHOS_001" label="Acao Requerida" name="acaoRequerida" typeRef="string" />
      <output id="output_justificativa_LAB_ELECTRO_PHOS_001" label="Justificativa Cientifica" name="justificativaCientifica" typeRef="string" />

      <!-- Critical hypophosphatemia: P <1.0 mg/dL - High risk of respiratory failure -->
      <rule id="rule_001_LAB_ELECTRO_PHOS_001">
        <inputEntry id="inputEntry_001_1_LAB_ELECTRO_PHOS_001">
          <text>&lt; 1.0</text>
        </inputEntry>
        <inputEntry id="inputEntry_001_2_LAB_ELECTRO_PHOS_001">
          <text>-</text>
        </inputEntry>
        <outputEntry id="outputEntry_001_1_LAB_ELECTRO_PHOS_001">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_2_LAB_ELECTRO_PHOS_001">
          <text>"IMEDIATA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_3_LAB_ELECTRO_PHOS_001">
          <text>"CRITICO_BAIXO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_4_LAB_ELECTRO_PHOS_001">
          <text>"PERIGOSAMENTE_BAIXO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_5_LAB_ELECTRO_PHOS_001">
          <text>"EMERGENCIA: Hipofosfatemia severa. Fosfato de potassio ou sodio IV: 0.08-0.16 mmol/kg em 6h. RISCO de fraqueza muscular respiratoria, insuficiencia cardiaca, hemolise e rabdomiolise. Se em VM, desmame impossivel sem correcao. Monitorar calcio (pode precipitar). Avaliar causas: realimentacao, alcoolismo, cetoacidose diabetica em tratamento."</text>
        </outputEntry>
        <outputEntry id="outputEntry_001_6_LAB_ELECTRO_PHOS_001">
          <text>"Hipofosfatemia severa (&lt;1.0 mg/dL) causa fraqueza muscular grave incluindo diafragma (falha de desmame VM), cardiomiopatia, hemolise, rabdomiolise. ATP intracelular depletado. Sindrome de realimentacao e causa classica. Reposicao IV mandatoria."</text>
        </outputEntry>
      </rule>

      <!-- Severe hypophosphatemia on mechanical ventilation: 1.0-1.5 mg/dL on MV -->
      <rule id="rule_002_LAB_ELECTRO_PHOS_001">
        <inputEntry id="inputEntry_002_1_LAB_ELECTRO_PHOS_001">
          <text>[1.0..1.5]</text>
        </inputEntry>
        <inputEntry id="inputEntry_002_2_LAB_ELECTRO_PHOS_001">
          <text>true</text>
        </inputEntry>
        <outputEntry id="outputEntry_002_1_LAB_ELECTRO_PHOS_001">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_2_LAB_ELECTRO_PHOS_001">
          <text>"IMEDIATA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_3_LAB_ELECTRO_PHOS_001">
          <text>"SEVERO_EM_VM"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_4_LAB_ELECTRO_PHOS_001">
          <text>"MUITO_BAIXO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_5_LAB_ELECTRO_PHOS_001">
          <text>"Hipofosfatemia em paciente em VM. IMPEDE DESMAME. Reposicao IV necessaria antes de tentativa de extubacao. Fosfato IV conforme protocolo. Monitorar calcio durante reposicao. Avaliar necessidade de suplementacao continua na NPT/dieta enteral."</text>
        </outputEntry>
        <outputEntry id="outputEntry_002_6_LAB_ELECTRO_PHOS_001">
          <text>"Fosforo e essencial para contracao muscular (ATP). Hipofosfatemia em paciente ventilado causa fraqueza diafragmatica, impossibilitando desmame. Correcao antes de extubacao e mandatoria."</text>
        </outputEntry>
      </rule>

      <!-- Moderate hypophosphatemia: 1.0-1.5 mg/dL not on MV -->
      <rule id="rule_003_LAB_ELECTRO_PHOS_001">
        <inputEntry id="inputEntry_003_1_LAB_ELECTRO_PHOS_001">
          <text>[1.0..1.5]</text>
        </inputEntry>
        <inputEntry id="inputEntry_003_2_LAB_ELECTRO_PHOS_001">
          <text>false</text>
        </inputEntry>
        <outputEntry id="outputEntry_003_1_LAB_ELECTRO_PHOS_001">
          <text>"Atencao"</text>
        </outputEntry>
        <outputEntry id="outputEntry_003_2_LAB_ELECTRO_PHOS_001">
          <text>"ALTA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_003_3_LAB_ELECTRO_PHOS_001">
          <text>"MODERADO_BAIXO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_003_4_LAB_ELECTRO_PHOS_001">
          <text>"BAIXO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_003_5_LAB_ELECTRO_PHOS_001">
          <text>"Hipofosfatemia moderada. Reposicao oral preferencial se tolerando VO. IV se sintomatico ou incapaz de VO. Investigar causa: realimentacao, alcoolismo, uso de antiacidos, cetoacidose. Suplementar dieta."</text>
        </outputEntry>
        <outputEntry id="outputEntry_003_6_LAB_ELECTRO_PHOS_001">
          <text>"Hipofosfatemia moderada pode ser assintomatica ou causar fraqueza leve. Reposicao oral geralmente suficiente. Risco de progressao se causa nao corrigida, especialmente em realimentacao."</text>
        </outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="rule_fallback_LAB_ELECTRO_PHOS_001">
        <inputEntry id="inputEntry_fallback_1_LAB_ELECTRO_PHOS_001">
          <text>-</text>
        </inputEntry>
        <inputEntry id="inputEntry_fallback_2_LAB_ELECTRO_PHOS_001">
          <text>-</text>
        </inputEntry>
        <outputEntry id="outputEntry_fallback_1_LAB_ELECTRO_PHOS_001">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_2_LAB_ELECTRO_PHOS_001">
          <text>"BAIXA"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_3_LAB_ELECTRO_PHOS_001">
          <text>"FORA_CRITERIO"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_4_LAB_ELECTRO_PHOS_001">
          <text>"NAO_APLICAVEL"</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_5_LAB_ELECTRO_PHOS_001">
          <text>"Fosforo nao atende criterio de hipofosfatemia critica desta regra."</text>
        </outputEntry>
        <outputEntry id="outputEntry_fallback_6_LAB_ELECTRO_PHOS_001">
          <text>"Esta regra monitora hipofosfatemia critica com fosforo &lt;1.5 mg/dL."</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_LAB_ELECTRO_PHOS_001">
      <dmndi:DMNShape id="DMNShape_decision_LAB_ELECTRO_PHOS_001" dmnElementRef="decision_LAB_ELECTRO_PHOS_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
