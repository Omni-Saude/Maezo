<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DDX-RENAL-010"
             name="Espironolactona + K &gt; 5.5 + DRC"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_DDX-RENAL-010" name="[SP-CO-004 | clinical_safety/ddx] Espironolactona + K &gt; 5.5 + DRC" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DDX-RENAL-010" hitPolicy="FIRST">
      <input id="Input_1_DDX-RENAL-010" label="Medicamento Atual">
        <inputExpression id="InputExpression_1_DDX-RENAL-010" typeRef="string">
          <text>medicamentoAtual</text>
        </inputExpression>
      </input>
      <input id="Input_2_DDX-RENAL-010" label="Condicao Clinica">
        <inputExpression id="InputExpression_2_DDX-RENAL-010" typeRef="string">
          <text>condicaoClinica</text>
        </inputExpression>
      </input>
      <output id="Output_1_DDX-RENAL-010" label="Nivel Alerta" name="nivelAlerta" typeRef="string">
        <outputValues id="OutputValues_1_DDX-RENAL-010">
          <text>"Alerta", "Atencao", "Informativo", "Sem_Alerta"</text>
        </outputValues>
      </output>
      <output id="Output_2_DDX-RENAL-010" label="Contraindicacao" name="contraindicacao" typeRef="string">
      </output>
      <output id="Output_3_DDX-RENAL-010" label="Medicamento Alternativo" name="medicamentoAlternativo" typeRef="string">
      </output>
      <output id="Output_4_DDX-RENAL-010" label="Acao Requerida" name="acaoRequerida" typeRef="string">
      </output>
      <rule id="Rule_1_DDX-RENAL-010">
        <description>Espironolactona com hipercalemia e DRC: risco hipercalemia severa (>6.5) e arritmia.</description>
        <inputEntry id="InputEntry_R1_1_DDX-RENAL-010">
          <text>"ESPIRONOLACTONA"</text>
        </inputEntry>
        <inputEntry id="InputEntry_R1_2_DDX-RENAL-010">
          <text>"HYPERKALEMIA_AND_CKD"</text>
        </inputEntry>
        <outputEntry id="OutputEntry_R1_1_DDX-RENAL-010">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_R1_2_DDX-RENAL-010">
          <text>"Espironolactona com hipercalemia e DRC: risco hipercalemia severa (>6.5) e arritmia."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_R1_3_DDX-RENAL-010">
          <text>"Suspender, corrigir K+, considerar furosemida"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_R1_4_DDX-RENAL-010">
          <text>"SUSPENDER_MEDICAMENTO"</text>
        </outputEntry>
      </rule>
      <rule id="Rule_2_DDX-RENAL-010">
        <description>Sem alerta</description>
        <inputEntry id="InputEntry_R2_1_DDX-RENAL-010">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_R2_2_DDX-RENAL-010">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_R2_1_DDX-RENAL-010">
          <text>"Sem_Alerta"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_R2_2_DDX-RENAL-010">
          <text>"Sem contraindicacao identificada."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_R2_3_DDX-RENAL-010">
          <text>"-"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_R2_4_DDX-RENAL-010">
          <text>"NENHUMA_ACAO"</text>
        </outputEntry>
      </rule>
      <rule id="DecisionRule_fallback_DDX-RENAL-010">
        <description>FALLBACK: Condição padrão - sem alerta específico</description>
        <inputEntry id="UnaryTests_fallback_01_DDX-RENAL-010">
          <text></text>
        </inputEntry>
        <inputEntry id="UnaryTests_fallback_02_DDX-RENAL-010">
          <text></text>
        </inputEntry>
        <outputEntry id="LiteralExpression_fallback_01_DDX-RENAL-010">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_fallback_02_DDX-RENAL-010">
          <text>"BAIXO"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_fallback_03_DDX-RENAL-010">
          <text>"Nenhuma intervenção necessária"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_fallback_04_DDX-RENAL-010">
          <text>"Rotina"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DDX-RENAL-010">
      <dmndi:DMNShape id="DMNShape_Decision_DDX-RENAL-010" dmnElementRef="Decision_DDX-RENAL-010">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
