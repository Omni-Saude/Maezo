<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DDX_CARDIAC_003"
             name="AINE em Insuficiencia Cardiaca"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!--
    DDX-CARDIAC-003: AINE + ICC
    Versão: 1.0.0 (2026-02-06)

    CONTRAINDICAÇÃO:
    - AINEs aumentam retenção hídrica e Na+
    - Antagonizam efeito de diuréticos e IECA
    - Pioram descompensação em ICC
  -->

  <decision id="Decision_DDX_CARDIAC_003" name="[SP-CO-004 | clinical_safety/cardiac] Alerta AINE em ICC" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DDX_CARDIAC_003" hitPolicy="FIRST">

      <input id="Input_1_DDX_CARDIAC_003" label="Medicamento Atual">
        <inputExpression id="InputExpression_1_DDX_CARDIAC_003" typeRef="string">
          <text>medicamentoAtual</text>
        </inputExpression>
      </input>

      <input id="Input_2_DDX_CARDIAC_003" label="Funcao Cardiaca">
        <inputExpression id="InputExpression_2_DDX_CARDIAC_003" typeRef="string">
          <text>funcaoCardiaca</text>
        </inputExpression>
      </input>

      <output id="Output_1_DDX_CARDIAC_003" label="Nivel Alerta" name="nivelAlerta" typeRef="string">
        <outputValues id="OutputValues_1_DDX_CARDIAC_003">
          <text>"Alerta", "Atencao", "Informativo", "Sem_Alerta"</text>
        </outputValues>
      </output>

      <output id="Output_2_DDX_CARDIAC_003" label="Contraindicacao" name="contraindicacao" typeRef="string"/>
      <output id="Output_3_DDX_CARDIAC_003" label="Medicamento Alternativo" name="medicamentoAlternativo" typeRef="string"/>
      <output id="Output_4_DDX_CARDIAC_003" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>

      <!-- ATENÇÃO: AINE em qualquer ICC -->
      <rule id="Rule_Atencao_1_DDX_CARDIAC_003">
        <description>AINE em insuficiencia cardiaca</description>
        <inputEntry id="InputEntry_AT1_1_DDX_CARDIAC_003">
          <text>"IBUPROFENO", "NAPROXENO", "DICLOFENACO", "CETOPROFENO", "INDOMETACINA", "PIROXICAM", "CELECOXIBE"</text>
        </inputEntry>
        <inputEntry id="InputEntry_AT1_2_DDX_CARDIAC_003">
          <text>"HFrEF", "HFpEF", "DESCOMPENSADA"</text>
        </inputEntry>
        <outputEntry id="OutputEntry_AT1_1_DDX_CARDIAC_003">
          <text>"Atencao"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_AT1_2_DDX_CARDIAC_003">
          <text>"AINE em ICC: risco de retencao hidrica, antagonismo de diureticos/IECA e descompensacao."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_AT1_3_DDX_CARDIAC_003">
          <text>"Preferir Paracetamol ou opioide fraco. Limitar duracao se AINE necessario. Monitorar peso e edema."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_AT1_4_DDX_CARDIAC_003">
          <text>"MONITORAR_PESO_EDEMA"</text>
        </outputEntry>
      </rule>

      <!-- FALLBACK -->
      <rule id="Rule_Fallback_DDX_CARDIAC_003">
        <description>Sem alerta</description>
        <inputEntry id="InputEntry_F_1_DDX_CARDIAC_003">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_F_2_DDX_CARDIAC_003">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_F_1_DDX_CARDIAC_003">
          <text>"Sem_Alerta"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_F_2_DDX_CARDIAC_003">
          <text>"Sem contraindicacao identificada."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_F_3_DDX_CARDIAC_003">
          <text>"-"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_F_4_DDX_CARDIAC_003">
          <text>"NENHUMA_ACAO"</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DDX_CARDIAC_003">
      <dmndi:DMNShape id="DMNShape_Decision_DDX_CARDIAC_003" dmnElementRef="Decision_DDX_CARDIAC_003">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
