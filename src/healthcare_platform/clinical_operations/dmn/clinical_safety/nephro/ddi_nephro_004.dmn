<?xml version="1.0" encoding="UTF-8"?>
<!-- ============================================================================
     DDI-NEPHRO-004: Cisplatina + Aminoglicosideos - Nefrotoxicidade Aditiva

     EVIDENCIA CLINICA:
     - NCCN Guidelines - Supportive Care
     - Lameire N et al. Lancet. 2005;365:417-30
     - Filipski KK et al. Clin Cancer Res. 2009;15:4200-6

     MECANISMO: Cisplatina causa necrose tubular proximal dose-cumulativa via
     geracao de especies reativas de oxigenio. Aminoglicosideos tem mesmo
     mecanismo. Efeito aditivo/sinergico com IRA em ate 50% dos pacientes.

     INCIDENCIA: IRA em 25-35% com cisplatina isolada; ate 50% com combinacao
     ============================================================================ -->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="DDI_NEPHRO_004" name="DDI-NEPHRO-004: Cisplatina + Aminoglicosideos" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="ddi_nephro_004_decision" name="[SP-CO-004 | clinical_safety/nephro] Cisplatina + Aminoglicosideos - Nefrotoxicidade Aditiva" camunda:historyTimeToLive="180">
    <decisionTable id="ddi_nephro_004_table" hitPolicy="FIRST">
      <input id="input_medicamentos_ativos_ddi_nephro_004_decision" label="Medicamentos Ativos">
        <inputExpression id="input_expr_medicamentos_ddi_nephro_004_decision" typeRef="string">
          <text>medicamentosAtivos</text>
        </inputExpression>
      </input>
      <input id="input_medicamento_novo_ddi_nephro_004_decision" label="Medicamento Novo">
        <inputExpression id="input_expr_novo_ddi_nephro_004_decision" typeRef="string">
          <text>medicamentoNovo</text>
        </inputExpression>
      </input>
      <input id="input_dose_cisplatina_ddi_nephro_004_decision" label="Dose Cumulativa Cisplatina (mg/m2)">
        <inputExpression id="input_expr_dose_ddi_nephro_004_decision" typeRef="number">
          <text>doseCumulativaCisplatina</text>
        </inputExpression>
      </input>

      <output id="output_nivel_alerta_ddi_nephro_004_decision" name="nivelAlerta" typeRef="string">
        <outputValues><text>"Alerta","Atencao","Informativo","OK"</text></outputValues>
      </output>
      <output id="output_acao_requerida_ddi_nephro_004_decision" name="acaoRequerida" typeRef="string" />
      <output id="output_justificativa_ddi_nephro_004_decision" name="justificativaCientifica" typeRef="string" />

      <!-- Rule 1: Cisplatina em uso + Aminoglicosideo novo + dose cumulativa alta -->
      <rule id="rule_cisplatina_amino_dose_alta_ddi_nephro_004_decision">
        <inputEntry id="ie_cisplatina_ativa_ddi_nephro_004_decision">
          <text>list contains(medicamentosAtivos, "CISPLATINA")</text>
        </inputEntry>
        <inputEntry id="ie_amino_novo_ddi_nephro_004_decision">
          <text>"GENTAMICINA" or "AMICACINA" or "TOBRAMICINA" or "ESTREPTOMICINA"</text>
        </inputEntry>
        <inputEntry id="ie_dose_alta_ddi_nephro_004_decision">
          <text>&gt; 200</text>
        </inputEntry>
        <outputEntry id="oe_alerta_alta_ddi_nephro_004_decision"><text>"Alerta"</text></outputEntry>
        <outputEntry id="oe_acao_alta_ddi_nephro_004_decision"><text>"EVITAR COMBINACAO. Dose cumulativa cisplatina >200mg/m2 = alto risco nefrotoxicidade. Usar antibiotico alternativo (cefepime, piperacilina-tazobactam, fluoroquinolona). Se aminoglicosideo indispensavel, dose unica diaria com monitorizacao rigorosa."</text></outputEntry>
        <outputEntry id="oe_just_alta_ddi_nephro_004_decision"><text>"Nefrotoxicidade cisplatina dose-cumulativa. Acima 200mg/m2, aminoglicosideo aumenta IRA para 50%. NCCN Guidelines."</text></outputEntry>
      </rule>

      <!-- Rule 2: Cisplatina + Aminoglicosideo + dose cumulativa moderada -->
      <rule id="rule_cisplatina_amino_dose_moderada_ddi_nephro_004_decision">
        <inputEntry id="ie_cisplatina_ativa2_ddi_nephro_004_decision">
          <text>list contains(medicamentosAtivos, "CISPLATINA")</text>
        </inputEntry>
        <inputEntry id="ie_amino_novo2_ddi_nephro_004_decision">
          <text>"GENTAMICINA" or "AMICACINA" or "TOBRAMICINA"</text>
        </inputEntry>
        <inputEntry id="ie_dose_moderada_ddi_nephro_004_decision">
          <text>[100..200]</text>
        </inputEntry>
        <outputEntry id="oe_atencao_moderada_ddi_nephro_004_decision"><text>"Atencao"</text></outputEntry>
        <outputEntry id="oe_acao_moderada_ddi_nephro_004_decision"><text>"Preferir antibiotico alternativo. Se aminoglicosideo necessario: dose unica diaria, monitorar Mg/K, creatinina diaria, hidratar com SF 2-3L/dia. Considerar amifostina se disponivel."</text></outputEntry>
        <outputEntry id="oe_just_moderada_ddi_nephro_004_decision"><text>"Risco nefrotoxicidade moderado (30-40%). Hidratacao agressiva e monitorizacao intensiva obrigatorias."</text></outputEntry>
      </rule>

      <!-- Rule 3: Aminoglicosideo em uso + Cisplatina nova -->
      <rule id="rule_amino_cisplatina_ddi_nephro_004_decision">
        <inputEntry id="ie_amino_ativo_ddi_nephro_004_decision">
          <text>list contains(medicamentosAtivos, "GENTAMICINA") or list contains(medicamentosAtivos, "AMICACINA") or list contains(medicamentosAtivos, "TOBRAMICINA")</text>
        </inputEntry>
        <inputEntry id="ie_cisplatina_nova_ddi_nephro_004_decision">
          <text>"CISPLATINA"</text>
        </inputEntry>
        <inputEntry id="ie_dose_any_ddi_nephro_004_decision">
          <text>-</text>
        </inputEntry>
        <outputEntry id="oe_atencao_cisplatina_ddi_nephro_004_decision"><text>"Atencao"</text></outputEntry>
        <outputEntry id="oe_acao_cisplatina_ddi_nephro_004_decision"><text>"Aguardar clareamento aminoglicosideo (5 meias-vidas, ~24-48h) antes de cisplatina se possivel. Hidratar vigorosamente pre e pos-quimioterapia. Monitorar funcao renal diariamente."</text></outputEntry>
        <outputEntry id="oe_just_cisplatina_ddi_nephro_004_decision"><text>"Efeito nefrotoxicidade aditivo. Intervalo entre drogas reduz toxicidade cumulativa."</text></outputEntry>
      </rule>

      <!-- Fallback Rule -->
      <rule id="Rule_Fallback_ddi_nephro_004_decision">
        <inputEntry id="ie_fallback1_ddi_nephro_004_decision"><text>-</text></inputEntry>
        <inputEntry id="ie_fallback2_ddi_nephro_004_decision"><text>-</text></inputEntry>
        <inputEntry id="ie_fallback3_ddi_nephro_004_decision"><text>-</text></inputEntry>
        <outputEntry id="oe_fallback1_ddi_nephro_004_decision"><text>"OK"</text></outputEntry>
        <outputEntry id="oe_fallback2_ddi_nephro_004_decision"><text>""</text></outputEntry>
        <outputEntry id="oe_fallback3_ddi_nephro_004_decision"><text>""</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ddi_nephro_004_decision">
      <dmndi:DMNShape id="DMNShape_ddi_nephro_004_decision" dmnElementRef="ddi_nephro_004_decision">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
