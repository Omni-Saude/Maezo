<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_VIT_CRITICAL_TEMP_001" name="DRD" namespace="http://camunda.org/schema/1.0/dmn" exporter="Camunda Modeler" exporterVersion="5.32.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.7.0">
  <decision id="Decision_VIT_CRITICAL_TEMP_001" name="[SP-CO-004 | clinical_safety/vit] VIT-CRITICAL-TEMP-001: Temperatura Crítica" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_VIT_CRITICAL_TEMP_001" hitPolicy="FIRST">
      <input id="Input_temperatura_VIT_CRITICAL_TEMP_001" label="Temperatura (°C)">
        <inputExpression id="InputExpression_temperatura_VIT_CRITICAL_TEMP_001" typeRef="number">
          <text>temperatura</text>
        </inputExpression>
      </input>
      <output id="Output_nivelAlerta_VIT_CRITICAL_TEMP_001" label="Nível de Alerta" name="nivelAlerta" typeRef="string">
        <outputValues id="UnaryTests_nivelAlerta_VIT_CRITICAL_TEMP_001">
          <text>"Alerta","Atencao","Informativo","OK"</text>
        </outputValues>
      </output>
      <output id="Output_nivelRisco_VIT_CRITICAL_TEMP_001" label="Nível de Risco" name="nivelRisco" typeRef="string">
        <outputValues id="UnaryTests_nivelRisco_VIT_CRITICAL_TEMP_001">
          <text>"MUITO_ALTO","ALTO","MODERADO","BAIXO"</text>
        </outputValues>
      </output>
      <output id="Output_intervencaoRequerida_VIT_CRITICAL_TEMP_001" label="Intervenção Requerida" name="intervencaoRequerida" typeRef="string" />
      <output id="Output_frequenciaMonitoramento_VIT_CRITICAL_TEMP_001" label="Frequência de Monitoramento" name="frequenciaMonitoramento" typeRef="string" />
      <!-- Severe hypothermia: Temp < 35°C -->
      <rule id="DecisionRule_001_VIT_CRITICAL_TEMP_001">
        <inputEntry id="UnaryTests_001_01_VIT_CRITICAL_TEMP_001">
          <text>&lt; 35</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_001_01_VIT_CRITICAL_TEMP_001">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_001_02_VIT_CRITICAL_TEMP_001">
          <text>"MUITO_ALTO"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_001_03_VIT_CRITICAL_TEMP_001">
          <text>"HIPOTERMIA. Iniciar reaquecimento ativo (mantas térmicas, fluidos aquecidos). Monitorar arritmias cardíacas. Investigar causa (exposição, sepse, hipotireoidismo). Acionar MD."</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_001_04_VIT_CRITICAL_TEMP_001">
          <text>"Q30M"</text>
        </outputEntry>
      </rule>
      <!-- Severe hyperthermia: Temp > 40°C -->
      <rule id="DecisionRule_002_VIT_CRITICAL_TEMP_001">
        <inputEntry id="UnaryTests_002_01_VIT_CRITICAL_TEMP_001">
          <text>&gt; 40</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_002_01_VIT_CRITICAL_TEMP_001">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_002_02_VIT_CRITICAL_TEMP_001">
          <text>"MUITO_ALTO"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_002_03_VIT_CRITICAL_TEMP_001">
          <text>"HIPERTERMIA SEVERA. Risco de convulsão e lesão neurológica. Iniciar resfriamento ativo (compressas, ventilação). Antitérmico EV. Investigar causa (infecção, hipertermia maligna, golpe de calor). Acionar MD."</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_002_04_VIT_CRITICAL_TEMP_001">
          <text>"Q30M"</text>
        </outputEntry>
      </rule>
      <!-- High fever: 39-40°C -->
      <rule id="DecisionRule_003_VIT_CRITICAL_TEMP_001">
        <inputEntry id="UnaryTests_003_01_VIT_CRITICAL_TEMP_001">
          <text>[39..40]</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_003_01_VIT_CRITICAL_TEMP_001">
          <text>"Atencao"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_003_02_VIT_CRITICAL_TEMP_001">
          <text>"ALTO"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_003_03_VIT_CRITICAL_TEMP_001">
          <text>"Febre alta. Administrar antitérmico. Investigar foco infeccioso (culturas, exames de imagem). Considerar hemoculturas antes de antibiótico."</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_003_04_VIT_CRITICAL_TEMP_001">
          <text>"Q1H"</text>
        </outputEntry>
      </rule>
      <!-- Normal range -->
      <rule id="DecisionRule_999_VIT_CRITICAL_TEMP_001">
        <inputEntry id="UnaryTests_999_01_VIT_CRITICAL_TEMP_001">
          <text></text>
        </inputEntry>
        <outputEntry id="LiteralExpression_999_01_VIT_CRITICAL_TEMP_001">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_999_02_VIT_CRITICAL_TEMP_001">
          <text>"BAIXO"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_999_03_VIT_CRITICAL_TEMP_001">
          <text>"Temperatura dentro da normalidade."</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_999_04_VIT_CRITICAL_TEMP_001">
          <text>"Q4H"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_VIT_CRITICAL_TEMP_001">
      <dmndi:DMNShape id="DMNShape_Decision_VIT_CRITICAL_TEMP_001" dmnElementRef="Decision_VIT_CRITICAL_TEMP_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
