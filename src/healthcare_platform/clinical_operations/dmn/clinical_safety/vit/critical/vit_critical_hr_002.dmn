<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_VIT_CRITICAL_HR_002" name="DRD" namespace="http://camunda.org/schema/1.0/dmn" exporter="Camunda Modeler" exporterVersion="5.32.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.7.0">
  <decision id="Decision_VIT_CRITICAL_HR_002" name="[SP-CO-004 | clinical_safety/vit] VIT-CRITICAL-HR-002: Taquicardia Severa" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_VIT_CRITICAL_HR_002" hitPolicy="FIRST">
      <input id="Input_frequenciaCardiaca_VIT_CRITICAL_HR_002" label="Frequência Cardíaca (bpm)">
        <inputExpression id="InputExpression_frequenciaCardiaca_VIT_CRITICAL_HR_002" typeRef="number">
          <text>frequenciaCardiaca</text>
        </inputExpression>
      </input>
      <input id="Input_idadePaciente_VIT_CRITICAL_HR_002" label="Idade do Paciente">
        <inputExpression id="InputExpression_idadePaciente_VIT_CRITICAL_HR_002" typeRef="number">
          <text>idadePaciente</text>
        </inputExpression>
      </input>
      <output id="Output_nivelAlerta_VIT_CRITICAL_HR_002" label="Nível de Alerta" name="nivelAlerta" typeRef="string">
        <outputValues id="UnaryTests_nivelAlerta_VIT_CRITICAL_HR_002">
          <text>"Alerta","Atencao","Informativo","OK"</text>
        </outputValues>
      </output>
      <output id="Output_nivelRisco_VIT_CRITICAL_HR_002" label="Nível de Risco" name="nivelRisco" typeRef="string">
        <outputValues id="UnaryTests_nivelRisco_VIT_CRITICAL_HR_002">
          <text>"MUITO_ALTO","ALTO","MODERADO","BAIXO"</text>
        </outputValues>
      </output>
      <output id="Output_intervencaoRequerida_VIT_CRITICAL_HR_002" label="Intervenção Requerida" name="intervencaoRequerida" typeRef="string" />
      <output id="Output_frequenciaMonitoramento_VIT_CRITICAL_HR_002" label="Frequência de Monitoramento" name="frequenciaMonitoramento" typeRef="string" />
      <!-- Severe tachycardia: HR > 150 bpm in adults -->
      <rule id="DecisionRule_001_VIT_CRITICAL_HR_002">
        <inputEntry id="UnaryTests_001_01_VIT_CRITICAL_HR_002">
          <text>&gt; 150</text>
        </inputEntry>
        <inputEntry id="UnaryTests_001_02_VIT_CRITICAL_HR_002">
          <text>&gt;= 18</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_001_01_VIT_CRITICAL_HR_002">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_001_02_VIT_CRITICAL_HR_002">
          <text>"MUITO_ALTO"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_001_03_VIT_CRITICAL_HR_002">
          <text>"Taquicardia severa. Avaliar estabilidade hemodinâmica, ECG de 12 derivações. Investigar causas (sepse, hipovolemia, TEP, arritmia). Acionar MD."</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_001_04_VIT_CRITICAL_HR_002">
          <text>"Q15M"</text>
        </outputEntry>
      </rule>
      <!-- Pediatric severe tachycardia (age-adjusted) -->
      <rule id="DecisionRule_002_VIT_CRITICAL_HR_002">
        <inputEntry id="UnaryTests_002_01_VIT_CRITICAL_HR_002">
          <text>&gt; 180</text>
        </inputEntry>
        <inputEntry id="UnaryTests_002_02_VIT_CRITICAL_HR_002">
          <text>&lt; 1</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_002_01_VIT_CRITICAL_HR_002">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_002_02_VIT_CRITICAL_HR_002">
          <text>"MUITO_ALTO"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_002_03_VIT_CRITICAL_HR_002">
          <text>"Taquicardia severa pediátrica (&gt;180 bpm em neonato). Avaliar perfusão, hidratação, febre. Acionar pediatra."</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_002_04_VIT_CRITICAL_HR_002">
          <text>"Q15M"</text>
        </outputEntry>
      </rule>
      <!-- Pediatric severe tachycardia (1-5 years) -->
      <rule id="DecisionRule_003_VIT_CRITICAL_HR_002">
        <inputEntry id="UnaryTests_003_01_VIT_CRITICAL_HR_002">
          <text>&gt; 160</text>
        </inputEntry>
        <inputEntry id="UnaryTests_003_02_VIT_CRITICAL_HR_002">
          <text>[1..5]</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_003_01_VIT_CRITICAL_HR_002">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_003_02_VIT_CRITICAL_HR_002">
          <text>"MUITO_ALTO"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_003_03_VIT_CRITICAL_HR_002">
          <text>"Taquicardia severa pediátrica (&gt;160 bpm em 1-5 anos). Avaliar perfusão, hidratação, febre. Acionar pediatra."</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_003_04_VIT_CRITICAL_HR_002">
          <text>"Q15M"</text>
        </outputEntry>
      </rule>
      <!-- Normal range -->
      <rule id="DecisionRule_999_VIT_CRITICAL_HR_002">
        <inputEntry id="UnaryTests_999_01_VIT_CRITICAL_HR_002">
          <text></text>
        </inputEntry>
        <inputEntry id="UnaryTests_999_02_VIT_CRITICAL_HR_002">
          <text></text>
        </inputEntry>
        <outputEntry id="LiteralExpression_999_01_VIT_CRITICAL_HR_002">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_999_02_VIT_CRITICAL_HR_002">
          <text>"BAIXO"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_999_03_VIT_CRITICAL_HR_002">
          <text>"Frequência cardíaca dentro da normalidade para taquicardia severa."</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_999_04_VIT_CRITICAL_HR_002">
          <text>"Q4H"</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_VIT_CRITICAL_HR_002">
      <dmndi:DMNShape id="DMNShape_Decision_VIT_CRITICAL_HR_002" dmnElementRef="Decision_VIT_CRITICAL_HR_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
