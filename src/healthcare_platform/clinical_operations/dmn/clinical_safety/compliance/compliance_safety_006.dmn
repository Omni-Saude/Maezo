<?xml version="1.0" encoding="UTF-8"?>
<!--
  COMPLIANCE_SAFETY_006: Safety Protocol Compliance
  Clinical Compliance DMN - Extracted from clinical_compliance_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_compliance_safety_006"
             name="Safety Protocol Compliance"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_compliance_safety_006" name="[SP-CO-004 | clinical_safety/compliance] Safety Protocol Compliance" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_compliance_safety_006" hitPolicy="FIRST">

      <input id="Input_1_compliance_safety_006" label="safetyDomain">
        <inputExpression id="InputExpression_1_compliance_safety_006" typeRef="string">
          <text>safetyDomain</text>
        </inputExpression>
      </input>

      <input id="Input_2_compliance_safety_006" label="adherenceRate">
        <inputExpression id="InputExpression_2_compliance_safety_006" typeRef="string">
          <text>adherenceRate</text>
        </inputExpression>
      </input>

      <output id="Output_1_compliance_safety_006" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2_compliance_safety_006" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3_compliance_safety_006" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4_compliance_safety_006" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1_compliance_safety_006">
        <inputEntry id="IE_1_1_compliance_safety_006"><text>-</text></inputEntry>
        <inputEntry id="IE_1_2_compliance_safety_006"><text>&lt; 90.0</text></inputEntry>
        <outputEntry id="OE_1_1_compliance_safety_006"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_1_2_compliance_safety_006"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_1_3_compliance_safety_006"><text>"Adesao ao protocolo de seguranca critica (&lt; 90%). Acoes imediatas."</text></outputEntry>
        <outputEntry id="OE_1_4_compliance_safety_006"><text>"Adesao &lt; 90% aos protocolos de seguranca representa risco ao paciente."</text></outputEntry>
      </rule>

      <rule id="Rule_2_compliance_safety_006">
        <inputEntry id="IE_2_1_compliance_safety_006"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2_compliance_safety_006"><text>[90.0..95.0)</text></inputEntry>
        <outputEntry id="OE_2_1_compliance_safety_006"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_2_2_compliance_safety_006"><text>"URGENTE"</text></outputEntry>
        <outputEntry id="OE_2_3_compliance_safety_006"><text>"Adesao ao protocolo abaixo da meta. Reforcar treinamento."</text></outputEntry>
        <outputEntry id="OE_2_4_compliance_safety_006"><text>"Adesao entre 90-95% indica necessidade de reforco nas praticas."</text></outputEntry>
      </rule>

      <rule id="Rule_3_compliance_safety_006">
        <inputEntry id="IE_3_1_compliance_safety_006"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2_compliance_safety_006"><text>>= 95.0</text></inputEntry>
        <outputEntry id="OE_3_1_compliance_safety_006"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2_compliance_safety_006"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_3_3_compliance_safety_006"><text>"Adesao ao protocolo de seguranca adequada."</text></outputEntry>
        <outputEntry id="OE_3_4_compliance_safety_006"><text>"Adesao >= 95% atende as metas de seguranca do paciente."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_compliance_safety_006">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1_compliance_safety_006"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_compliance_safety_006"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_compliance_safety_006"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2_compliance_safety_006"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3_compliance_safety_006"><text>"Verificar dados de entrada e reavaliar conformidade."</text></outputEntry>
        <outputEntry id="OE_F_4_compliance_safety_006"><text>"Dados insuficientes para avaliacao automatica de conformidade."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_compliance_safety_006">
      <dmndi:DMNShape id="DMNShape_compliance_safety_006" dmnElementRef="Decision_compliance_safety_006">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
