<?xml version="1.0" encoding="UTF-8"?>
<!--
  COMPLIANCE_SCORING_009: Compliance Scoring Rules
  Clinical Compliance DMN - Extracted from clinical_compliance_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_compliance_scoring_009"
             name="Compliance Scoring Rules"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_compliance_scoring_009" name="[SP-CO-004 | clinical_safety/compliance] Compliance Scoring Rules" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_compliance_scoring_009" hitPolicy="FIRST">

      <input id="Input_1_compliance_scoring_009" label="violationsCount">
        <inputExpression id="InputExpression_1_compliance_scoring_009" typeRef="string">
          <text>violationsCount</text>
        </inputExpression>
      </input>

      <input id="Input_2_compliance_scoring_009" label="totalRules">
        <inputExpression id="InputExpression_2_compliance_scoring_009" typeRef="string">
          <text>totalRules</text>
        </inputExpression>
      </input>

      <output id="Output_1_compliance_scoring_009" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2_compliance_scoring_009" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3_compliance_scoring_009" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4_compliance_scoring_009" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1_compliance_scoring_009">
        <inputEntry id="IE_1_1_compliance_scoring_009"><text>">= 5"</text></inputEntry>
        <inputEntry id="IE_1_2_compliance_scoring_009"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1_compliance_scoring_009"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_1_2_compliance_scoring_009"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_1_3_compliance_scoring_009"><text>"Score de conformidade critico. Auditoria completa necessaria."</text></outputEntry>
        <outputEntry id="OE_1_4_compliance_scoring_009"><text>"Mais de 5 violacoes indica necessidade de revisao sistemica."</text></outputEntry>
      </rule>

      <rule id="Rule_2_compliance_scoring_009">
        <inputEntry id="IE_2_1_compliance_scoring_009"><text>"[2..5)"</text></inputEntry>
        <inputEntry id="IE_2_2_compliance_scoring_009"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1_compliance_scoring_009"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_2_2_compliance_scoring_009"><text>"URGENTE"</text></outputEntry>
        <outputEntry id="OE_2_3_compliance_scoring_009"><text>"Score de conformidade parcial. Plano de melhoria necessario."</text></outputEntry>
        <outputEntry id="OE_2_4_compliance_scoring_009"><text>"Entre 2-5 violacoes indica lacunas pontuais a serem corrigidas."</text></outputEntry>
      </rule>

      <rule id="Rule_3_compliance_scoring_009">
        <inputEntry id="IE_3_1_compliance_scoring_009"><text>"[0..2)"</text></inputEntry>
        <inputEntry id="IE_3_2_compliance_scoring_009"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1_compliance_scoring_009"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2_compliance_scoring_009"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_3_3_compliance_scoring_009"><text>"Score de conformidade adequado. Manter monitoramento."</text></outputEntry>
        <outputEntry id="OE_3_4_compliance_scoring_009"><text>"Menos de 2 violacoes indica boa aderencia aos requisitos."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_compliance_scoring_009">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1_compliance_scoring_009"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_compliance_scoring_009"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_compliance_scoring_009"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2_compliance_scoring_009"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3_compliance_scoring_009"><text>"Verificar dados de entrada e reavaliar conformidade."</text></outputEntry>
        <outputEntry id="OE_F_4_compliance_scoring_009"><text>"Dados insuficientes para avaliacao automatica de conformidade."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_compliance_scoring_009">
      <dmndi:DMNShape id="DMNShape_compliance_scoring_009" dmnElementRef="Decision_compliance_scoring_009">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
