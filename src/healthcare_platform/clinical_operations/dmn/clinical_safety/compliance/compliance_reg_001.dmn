<?xml version="1.0" encoding="UTF-8"?>
<!--
  COMPLIANCE_REG_001: Regulatory Compliance Rules
  Clinical Compliance DMN - Extracted from clinical_compliance_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_compliance_reg_001"
             name="Regulatory Compliance Rules"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_compliance_reg_001" name="[SP-CO-004 | clinical_safety/compliance] Regulatory Compliance Rules" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_compliance_reg_001" hitPolicy="FIRST">

      <input id="Input_1_compliance_reg_001" label="complianceDomain">
        <inputExpression id="InputExpression_1_compliance_reg_001" typeRef="string">
          <text>complianceDomain</text>
        </inputExpression>
      </input>

      <input id="Input_2_compliance_reg_001" label="ruleReference">
        <inputExpression id="InputExpression_2_compliance_reg_001" typeRef="string">
          <text>ruleReference</text>
        </inputExpression>
      </input>

      <output id="Output_1_compliance_reg_001" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2_compliance_reg_001" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3_compliance_reg_001" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4_compliance_reg_001" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1_compliance_reg_001">
        <inputEntry id="IE_1_1_compliance_reg_001"><text>"anvisa"</text></inputEntry>
        <inputEntry id="IE_1_2_compliance_reg_001"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1_compliance_reg_001"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_1_2_compliance_reg_001"><text>"URGENTE"</text></outputEntry>
        <outputEntry id="OE_1_3_compliance_reg_001"><text>"Verificar conformidade ANVISA. Revisar RDCs aplicaveis."</text></outputEntry>
        <outputEntry id="OE_1_4_compliance_reg_001"><text>"ANVISA regulamenta seguranca do paciente e produtos para saude."</text></outputEntry>
      </rule>

      <rule id="Rule_2_compliance_reg_001">
        <inputEntry id="IE_2_1_compliance_reg_001"><text>"ans"</text></inputEntry>
        <inputEntry id="IE_2_2_compliance_reg_001"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1_compliance_reg_001"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_2_2_compliance_reg_001"><text>"URGENTE"</text></outputEntry>
        <outputEntry id="OE_2_3_compliance_reg_001"><text>"Verificar conformidade ANS. Revisar resolucoes normativas."</text></outputEntry>
        <outputEntry id="OE_2_4_compliance_reg_001"><text>"ANS regulamenta qualidade assistencial e direitos dos beneficiarios."</text></outputEntry>
      </rule>

      <rule id="Rule_3_compliance_reg_001">
        <inputEntry id="IE_3_1_compliance_reg_001"><text>"cnes"</text></inputEntry>
        <inputEntry id="IE_3_2_compliance_reg_001"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1_compliance_reg_001"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2_compliance_reg_001"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_3_3_compliance_reg_001"><text>"Verificar cadastro CNES atualizado."</text></outputEntry>
        <outputEntry id="OE_3_4_compliance_reg_001"><text>"CNES exige atualizacao cadastral periodica dos estabelecimentos."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_compliance_reg_001">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1_compliance_reg_001"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_compliance_reg_001"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_compliance_reg_001"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2_compliance_reg_001"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3_compliance_reg_001"><text>"Verificar dados de entrada e reavaliar conformidade."</text></outputEntry>
        <outputEntry id="OE_F_4_compliance_reg_001"><text>"Dados insuficientes para avaliacao automatica de conformidade."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_compliance_reg_001">
      <dmndi:DMNShape id="DMNShape_compliance_reg_001" dmnElementRef="Decision_compliance_reg_001">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
