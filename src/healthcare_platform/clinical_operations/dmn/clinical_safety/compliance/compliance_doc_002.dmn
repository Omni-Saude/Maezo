<?xml version="1.0" encoding="UTF-8"?>
<!--
  COMPLIANCE_DOC_002: Documentation Requirements
  Clinical Compliance DMN - Extracted from clinical_compliance_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_compliance_doc_002"
             name="Documentation Requirements"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_compliance_doc_002" name="[SP-CO-004 | clinical_safety/compliance] Documentation Requirements" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_compliance_doc_002" hitPolicy="FIRST">

      <input id="Input_1_compliance_doc_002" label="documentType">
        <inputExpression id="InputExpression_1_compliance_doc_002" typeRef="string">
          <text>documentType</text>
        </inputExpression>
      </input>

      <input id="Input_2_compliance_doc_002" label="completeness">
        <inputExpression id="InputExpression_2_compliance_doc_002" typeRef="string">
          <text>completeness</text>
        </inputExpression>
      </input>

      <output id="Output_1_compliance_doc_002" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2_compliance_doc_002" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3_compliance_doc_002" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4_compliance_doc_002" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1_compliance_doc_002">
        <inputEntry id="IE_1_1_compliance_doc_002"><text>"clinical_record"</text></inputEntry>
        <inputEntry id="IE_1_2_compliance_doc_002"><text>"incomplete"</text></inputEntry>
        <outputEntry id="OE_1_1_compliance_doc_002"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_1_2_compliance_doc_002"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_1_3_compliance_doc_002"><text>"Prontuario incompleto. Completar documentacao clinica."</text></outputEntry>
        <outputEntry id="OE_1_4_compliance_doc_002"><text>"Prontuario incompleto viola CFM 1638/2002 e compromete seguranca."</text></outputEntry>
      </rule>

      <rule id="Rule_2_compliance_doc_002">
        <inputEntry id="IE_2_1_compliance_doc_002"><text>"consent_form"</text></inputEntry>
        <inputEntry id="IE_2_2_compliance_doc_002"><text>"missing"</text></inputEntry>
        <outputEntry id="OE_2_1_compliance_doc_002"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_2_2_compliance_doc_002"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_2_3_compliance_doc_002"><text>"Termo de consentimento ausente. Obter antes do procedimento."</text></outputEntry>
        <outputEntry id="OE_2_4_compliance_doc_002"><text>"Consentimento informado e obrigatorio (CFM 1931/2009, Art. 22)."</text></outputEntry>
      </rule>

      <rule id="Rule_3_compliance_doc_002">
        <inputEntry id="IE_3_1_compliance_doc_002"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2_compliance_doc_002"><text>"complete"</text></inputEntry>
        <outputEntry id="OE_3_1_compliance_doc_002"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2_compliance_doc_002"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_3_3_compliance_doc_002"><text>"Documentacao completa e adequada."</text></outputEntry>
        <outputEntry id="OE_3_4_compliance_doc_002"><text>"Documentacao atende aos requisitos regulatorios vigentes."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_compliance_doc_002">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1_compliance_doc_002"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_compliance_doc_002"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_compliance_doc_002"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2_compliance_doc_002"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3_compliance_doc_002"><text>"Verificar dados de entrada e reavaliar conformidade."</text></outputEntry>
        <outputEntry id="OE_F_4_compliance_doc_002"><text>"Dados insuficientes para avaliacao automatica de conformidade."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_compliance_doc_002">
      <dmndi:DMNShape id="DMNShape_compliance_doc_002" dmnElementRef="Decision_compliance_doc_002">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
