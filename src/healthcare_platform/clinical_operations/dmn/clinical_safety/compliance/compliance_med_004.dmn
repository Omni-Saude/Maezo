<?xml version="1.0" encoding="UTF-8"?>
<!--
  COMPLIANCE_MED_004: Medication Compliance Rules
  Clinical Compliance DMN - Extracted from clinical_compliance_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_compliance_med_004"
             name="Medication Compliance Rules"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_compliance_med_004" name="[SP-CO-004 | clinical_safety/compliance] Medication Compliance Rules" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_compliance_med_004" hitPolicy="FIRST">

      <input id="Input_1_compliance_med_004" label="medicationProcess">
        <inputExpression id="InputExpression_1_compliance_med_004" typeRef="string">
          <text>medicationProcess</text>
        </inputExpression>
      </input>

      <input id="Input_2_compliance_med_004" label="complianceStatus">
        <inputExpression id="InputExpression_2_compliance_med_004" typeRef="string">
          <text>complianceStatus</text>
        </inputExpression>
      </input>

      <output id="Output_1_compliance_med_004" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2_compliance_med_004" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3_compliance_med_004" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4_compliance_med_004" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1_compliance_med_004">
        <inputEntry id="IE_1_1_compliance_med_004"><text>-</text></inputEntry>
        <inputEntry id="IE_1_2_compliance_med_004"><text>"non_compliant"</text></inputEntry>
        <outputEntry id="OE_1_1_compliance_med_004"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_1_2_compliance_med_004"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_1_3_compliance_med_004"><text>"Processo de medicacao nao conforme. Corrigir imediatamente."</text></outputEntry>
        <outputEntry id="OE_1_4_compliance_med_004"><text>"Nao conformidade em medicacao pode causar eventos adversos graves."</text></outputEntry>
      </rule>

      <rule id="Rule_2_compliance_med_004">
        <inputEntry id="IE_2_1_compliance_med_004"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2_compliance_med_004"><text>"partial"</text></inputEntry>
        <outputEntry id="OE_2_1_compliance_med_004"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_2_2_compliance_med_004"><text>"URGENTE"</text></outputEntry>
        <outputEntry id="OE_2_3_compliance_med_004"><text>"Conformidade parcial em medicacao. Revisar processo."</text></outputEntry>
        <outputEntry id="OE_2_4_compliance_med_004"><text>"Lacunas no processo de medicacao devem ser corrigidas."</text></outputEntry>
      </rule>

      <rule id="Rule_3_compliance_med_004">
        <inputEntry id="IE_3_1_compliance_med_004"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2_compliance_med_004"><text>"compliant"</text></inputEntry>
        <outputEntry id="OE_3_1_compliance_med_004"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2_compliance_med_004"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_3_3_compliance_med_004"><text>"Processo de medicacao conforme. Manter padrao."</text></outputEntry>
        <outputEntry id="OE_3_4_compliance_med_004"><text>"Processo de medicacao atende aos protocolos de seguranca."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_compliance_med_004">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1_compliance_med_004"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_compliance_med_004"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_compliance_med_004"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2_compliance_med_004"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3_compliance_med_004"><text>"Verificar dados de entrada e reavaliar conformidade."</text></outputEntry>
        <outputEntry id="OE_F_4_compliance_med_004"><text>"Dados insuficientes para avaliacao automatica de conformidade."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_compliance_med_004">
      <dmndi:DMNShape id="DMNShape_compliance_med_004" dmnElementRef="Decision_compliance_med_004">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
