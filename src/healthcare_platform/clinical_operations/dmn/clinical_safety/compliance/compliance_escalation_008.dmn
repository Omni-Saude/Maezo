<?xml version="1.0" encoding="UTF-8"?>
<!--
  COMPLIANCE_ESCALATION_008: Escalation Rules
  Clinical Compliance DMN - Extracted from clinical_compliance_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_compliance_escalation_008"
             name="Escalation Rules"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_compliance_escalation_008" name="[SP-CO-004 | clinical_safety/compliance] Escalation Rules" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_compliance_escalation_008" hitPolicy="FIRST">

      <input id="Input_1_compliance_escalation_008" label="violationSeverity">
        <inputExpression id="InputExpression_1_compliance_escalation_008" typeRef="string">
          <text>violationSeverity</text>
        </inputExpression>
      </input>

      <input id="Input_2_compliance_escalation_008" label="criticalCount">
        <inputExpression id="InputExpression_2_compliance_escalation_008" typeRef="string">
          <text>criticalCount</text>
        </inputExpression>
      </input>

      <output id="Output_1_compliance_escalation_008" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2_compliance_escalation_008" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3_compliance_escalation_008" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4_compliance_escalation_008" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1_compliance_escalation_008">
        <inputEntry id="IE_1_1_compliance_escalation_008"><text>"critical"</text></inputEntry>
        <inputEntry id="IE_1_2_compliance_escalation_008"><text>>= 1</text></inputEntry>
        <outputEntry id="OE_1_1_compliance_escalation_008"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_1_2_compliance_escalation_008"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_1_3_compliance_escalation_008"><text>"Violacao critica. Escalar para diretoria medica imediatamente."</text></outputEntry>
        <outputEntry id="OE_1_4_compliance_escalation_008"><text>"Violacoes criticas requerem notificacao da alta direcao e plano de acao."</text></outputEntry>
      </rule>

      <rule id="Rule_2_compliance_escalation_008">
        <inputEntry id="IE_2_1_compliance_escalation_008"><text>"major"</text></inputEntry>
        <inputEntry id="IE_2_2_compliance_escalation_008"><text>>= 3</text></inputEntry>
        <outputEntry id="OE_2_1_compliance_escalation_008"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_2_2_compliance_escalation_008"><text>"URGENTE"</text></outputEntry>
        <outputEntry id="OE_2_3_compliance_escalation_008"><text>"Multiplas violacoes maiores. Escalar para gerencia."</text></outputEntry>
        <outputEntry id="OE_2_4_compliance_escalation_008"><text>"Acumulo de violacoes maiores indica falha sistemica."</text></outputEntry>
      </rule>

      <rule id="Rule_3_compliance_escalation_008">
        <inputEntry id="IE_3_1_compliance_escalation_008"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2_compliance_escalation_008"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1_compliance_escalation_008"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2_compliance_escalation_008"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_3_3_compliance_escalation_008"><text>"Sem necessidade de escalacao. Tratar via processo padrao."</text></outputEntry>
        <outputEntry id="OE_3_4_compliance_escalation_008"><text>"Violacoes menores tratadas pela equipe de qualidade local."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_compliance_escalation_008">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1_compliance_escalation_008"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_compliance_escalation_008"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_compliance_escalation_008"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2_compliance_escalation_008"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3_compliance_escalation_008"><text>"Verificar dados de entrada e reavaliar conformidade."</text></outputEntry>
        <outputEntry id="OE_F_4_compliance_escalation_008"><text>"Dados insuficientes para avaliacao automatica de conformidade."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_compliance_escalation_008">
      <dmndi:DMNShape id="DMNShape_compliance_escalation_008" dmnElementRef="Decision_compliance_escalation_008">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
