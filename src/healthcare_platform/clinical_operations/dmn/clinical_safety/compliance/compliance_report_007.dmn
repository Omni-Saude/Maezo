<?xml version="1.0" encoding="UTF-8"?>
<!--
  COMPLIANCE_REPORT_007: Reporting Requirements
  Clinical Compliance DMN - Extracted from clinical_compliance_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_compliance_report_007"
             name="Reporting Requirements"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_compliance_report_007" name="[SP-CO-004 | clinical_safety/compliance] Reporting Requirements" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_compliance_report_007" hitPolicy="FIRST">

      <input id="Input_1_compliance_report_007" label="reportType">
        <inputExpression id="InputExpression_1_compliance_report_007" typeRef="string">
          <text>reportType</text>
        </inputExpression>
      </input>

      <input id="Input_2_compliance_report_007" label="reportStatus">
        <inputExpression id="InputExpression_2_compliance_report_007" typeRef="string">
          <text>reportStatus</text>
        </inputExpression>
      </input>

      <output id="Output_1_compliance_report_007" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2_compliance_report_007" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3_compliance_report_007" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4_compliance_report_007" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1_compliance_report_007">
        <inputEntry id="IE_1_1_compliance_report_007"><text>-</text></inputEntry>
        <inputEntry id="IE_1_2_compliance_report_007"><text>"overdue"</text></inputEntry>
        <outputEntry id="OE_1_1_compliance_report_007"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_1_2_compliance_report_007"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_1_3_compliance_report_007"><text>"Relatorio obrigatorio em atraso. Enviar imediatamente."</text></outputEntry>
        <outputEntry id="OE_1_4_compliance_report_007"><text>"Atraso em relatorios regulatorios pode resultar em sancoes."</text></outputEntry>
      </rule>

      <rule id="Rule_2_compliance_report_007">
        <inputEntry id="IE_2_1_compliance_report_007"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2_compliance_report_007"><text>"pending"</text></inputEntry>
        <outputEntry id="OE_2_1_compliance_report_007"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_2_2_compliance_report_007"><text>"URGENTE"</text></outputEntry>
        <outputEntry id="OE_2_3_compliance_report_007"><text>"Relatorio regulatorio pendente. Priorizar envio."</text></outputEntry>
        <outputEntry id="OE_2_4_compliance_report_007"><text>"Relatorios pendentes devem ser enviados dentro do prazo legal."</text></outputEntry>
      </rule>

      <rule id="Rule_3_compliance_report_007">
        <inputEntry id="IE_3_1_compliance_report_007"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2_compliance_report_007"><text>"submitted"</text></inputEntry>
        <outputEntry id="OE_3_1_compliance_report_007"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2_compliance_report_007"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_3_3_compliance_report_007"><text>"Relatorio regulatorio enviado. Aguardar confirmacao."</text></outputEntry>
        <outputEntry id="OE_3_4_compliance_report_007"><text>"Relatorio enviado dentro do prazo regulatorio."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_compliance_report_007">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1_compliance_report_007"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_compliance_report_007"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_compliance_report_007"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2_compliance_report_007"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3_compliance_report_007"><text>"Verificar dados de entrada e reavaliar conformidade."</text></outputEntry>
        <outputEntry id="OE_F_4_compliance_report_007"><text>"Dados insuficientes para avaliacao automatica de conformidade."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_compliance_report_007">
      <dmndi:DMNShape id="DMNShape_compliance_report_007" dmnElementRef="Decision_compliance_report_007">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
