<?xml version="1.0" encoding="UTF-8"?>
<!--
  COMPLIANCE_INFECT_005: Infection Control Compliance
  Clinical Compliance DMN - Extracted from clinical_compliance_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_compliance_infect_005"
             name="Infection Control Compliance"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_compliance_infect_005" name="[SP-CO-004 | clinical_safety/compliance] Infection Control Compliance" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_compliance_infect_005" hitPolicy="FIRST">

      <input id="Input_1_compliance_infect_005" label="infectionMetric">
        <inputExpression id="InputExpression_1_compliance_infect_005" typeRef="string">
          <text>infectionMetric</text>
        </inputExpression>
      </input>

      <input id="Input_2_compliance_infect_005" label="metricValue">
        <inputExpression id="InputExpression_2_compliance_infect_005" typeRef="string">
          <text>metricValue</text>
        </inputExpression>
      </input>

      <output id="Output_1_compliance_infect_005" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2_compliance_infect_005" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3_compliance_infect_005" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4_compliance_infect_005" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1_compliance_infect_005">
        <inputEntry id="IE_1_1_compliance_infect_005"><text>"hand_hygiene"</text></inputEntry>
        <inputEntry id="IE_1_2_compliance_infect_005"><text>&lt; 80.0</text></inputEntry>
        <outputEntry id="OE_1_1_compliance_infect_005"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_1_2_compliance_infect_005"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_1_3_compliance_infect_005"><text>"Adesao a higiene de maos critica (&lt; 80%). Acionar CCIH."</text></outputEntry>
        <outputEntry id="OE_1_4_compliance_infect_005"><text>"Higiene de maos &lt; 80% aumenta significativamente risco de IRAS."</text></outputEntry>
      </rule>

      <rule id="Rule_2_compliance_infect_005">
        <inputEntry id="IE_2_1_compliance_infect_005"><text>"iras_rate"</text></inputEntry>
        <inputEntry id="IE_2_2_compliance_infect_005"><text>>= 5.0</text></inputEntry>
        <outputEntry id="OE_2_1_compliance_infect_005"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_2_2_compliance_infect_005"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_2_3_compliance_infect_005"><text>"Taxa de IRAS elevada (>= 5%). Investigacao epidemiologica."</text></outputEntry>
        <outputEntry id="OE_2_4_compliance_infect_005"><text>"IRAS >= 5% indica falhas nos protocolos de controle de infeccao."</text></outputEntry>
      </rule>

      <rule id="Rule_3_compliance_infect_005">
        <inputEntry id="IE_3_1_compliance_infect_005"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2_compliance_infect_005"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1_compliance_infect_005"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2_compliance_infect_005"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_3_3_compliance_infect_005"><text>"Indicadores de controle de infeccao adequados."</text></outputEntry>
        <outputEntry id="OE_3_4_compliance_infect_005"><text>"Metricas de infeccao dentro dos parametros aceitaveis."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_compliance_infect_005">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1_compliance_infect_005"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_compliance_infect_005"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_compliance_infect_005"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2_compliance_infect_005"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3_compliance_infect_005"><text>"Verificar dados de entrada e reavaliar conformidade."</text></outputEntry>
        <outputEntry id="OE_F_4_compliance_infect_005"><text>"Dados insuficientes para avaliacao automatica de conformidade."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_compliance_infect_005">
      <dmndi:DMNShape id="DMNShape_compliance_infect_005" dmnElementRef="Decision_compliance_infect_005">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
