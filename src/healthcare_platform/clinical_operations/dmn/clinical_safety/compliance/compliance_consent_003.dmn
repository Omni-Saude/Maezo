<?xml version="1.0" encoding="UTF-8"?>
<!--
  COMPLIANCE_CONSENT_003: Consent Compliance Rules
  Clinical Compliance DMN - Extracted from clinical_compliance_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_compliance_consent_003"
             name="Consent Compliance Rules"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_compliance_consent_003" name="[SP-CO-004 | clinical_safety/compliance] Consent Compliance Rules" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_compliance_consent_003" hitPolicy="FIRST">

      <input id="Input_1_compliance_consent_003" label="procedureRisk">
        <inputExpression id="InputExpression_1_compliance_consent_003" typeRef="string">
          <text>procedureRisk</text>
        </inputExpression>
      </input>

      <input id="Input_2_compliance_consent_003" label="consentStatus">
        <inputExpression id="InputExpression_2_compliance_consent_003" typeRef="string">
          <text>consentStatus</text>
        </inputExpression>
      </input>

      <output id="Output_1_compliance_consent_003" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2_compliance_consent_003" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3_compliance_consent_003" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4_compliance_consent_003" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1_compliance_consent_003">
        <inputEntry id="IE_1_1_compliance_consent_003"><text>"high"</text></inputEntry>
        <inputEntry id="IE_1_2_compliance_consent_003"><text>"absent"</text></inputEntry>
        <outputEntry id="OE_1_1_compliance_consent_003"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_1_2_compliance_consent_003"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_1_3_compliance_consent_003"><text>"BLOQUEAR: Procedimento de alto risco sem consentimento."</text></outputEntry>
        <outputEntry id="OE_1_4_compliance_consent_003"><text>"Consentimento obrigatorio para procedimentos de alto risco (CFM)."</text></outputEntry>
      </rule>

      <rule id="Rule_2_compliance_consent_003">
        <inputEntry id="IE_2_1_compliance_consent_003"><text>"medium"</text></inputEntry>
        <inputEntry id="IE_2_2_compliance_consent_003"><text>"absent"</text></inputEntry>
        <outputEntry id="OE_2_1_compliance_consent_003"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_2_2_compliance_consent_003"><text>"URGENTE"</text></outputEntry>
        <outputEntry id="OE_2_3_compliance_consent_003"><text>"Obter consentimento antes de prosseguir."</text></outputEntry>
        <outputEntry id="OE_2_4_compliance_consent_003"><text>"Procedimentos de risco moderado requerem consentimento documentado."</text></outputEntry>
      </rule>

      <rule id="Rule_3_compliance_consent_003">
        <inputEntry id="IE_3_1_compliance_consent_003"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2_compliance_consent_003"><text>"present"</text></inputEntry>
        <outputEntry id="OE_3_1_compliance_consent_003"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2_compliance_consent_003"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_3_3_compliance_consent_003"><text>"Consentimento adequado. Prosseguir com procedimento."</text></outputEntry>
        <outputEntry id="OE_3_4_compliance_consent_003"><text>"Consentimento informado presente e valido."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_compliance_consent_003">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1_compliance_consent_003"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_compliance_consent_003"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_compliance_consent_003"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2_compliance_consent_003"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3_compliance_consent_003"><text>"Verificar dados de entrada e reavaliar conformidade."</text></outputEntry>
        <outputEntry id="OE_F_4_compliance_consent_003"><text>"Dados insuficientes para avaliacao automatica de conformidade."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_compliance_consent_003">
      <dmndi:DMNShape id="DMNShape_compliance_consent_003" dmnElementRef="Decision_compliance_consent_003">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
