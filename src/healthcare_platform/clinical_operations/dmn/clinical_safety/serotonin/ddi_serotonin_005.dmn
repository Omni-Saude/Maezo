<?xml version="1.0" encoding="UTF-8"?>
<!-- DDI-SEROTONIN-005: Dextrometorfano + ISRS/IMAOs - Sindrome Serotoninergica -->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="DDI_SEROTONIN_005" name="DDI-SEROTONIN-005: DXM + Serotoninergicos" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="ddi_serotonin_005_decision" name="[SP-CO-004 | clinical_safety/serotonin] Dextrometorfano + ISRS/IMAOs - Sindrome Serotoninergica" camunda:historyTimeToLive="180">
    <decisionTable id="ddi_serotonin_005_table" hitPolicy="FIRST">
      <input id="input_medicamentos_ativos_ddi_serotonin_005_decision"><inputExpression typeRef="string"><text>medicamentosAtivos</text></inputExpression></input>
      <input id="input_medicamento_novo_ddi_serotonin_005_decision"><inputExpression typeRef="string"><text>medicamentoNovo</text></inputExpression></input>
      <output id="output_nivel_alerta_ddi_serotonin_005_decision" name="nivelAlerta" typeRef="string"><outputValues><text>"Alerta","Atencao","Informativo","OK"</text></outputValues></output>
      <output id="output_acao_requerida_ddi_serotonin_005_decision" name="acaoRequerida" typeRef="string" />
      <output id="output_justificativa_ddi_serotonin_005_decision" name="justificativaCientifica" typeRef="string" />

      <rule id="rule_dxm_imao_ddi_serotonin_005_decision">
        <inputEntry><text>list contains(medicamentosAtivos, "FENELZINA") or list contains(medicamentosAtivos, "TRANILCIPROMINA") or list contains(medicamentosAtivos, "SELEGILINA") or list contains(medicamentosAtivos, "LINEZOLIDA")</text></inputEntry>
        <inputEntry><text>"DEXTROMETORFANO" or "DXM"</text></inputEntry>
        <outputEntry><text>"Alerta"</text></outputEntry>
        <outputEntry><text>"CONTRAINDICADO. Dextrometorfano + IMAO = risco FATAL de sindrome serotoninergica. DXM inibe recaptacao de serotonina e tem efeito tipo sigma. Usar antitussigeno alternativo (codeina, benzonatato). Pacientes em IMAO devem evitar qualquer xarope com DXM."</text></outputEntry>
        <outputEntry><text>"Obitos descritos. Rivers N, Horner B. Am J Emerg Med. 1988;6:17-20."</text></outputEntry>
      </rule>
      <rule id="rule_dxm_isrs_ddi_serotonin_005_decision">
        <inputEntry><text>list contains(medicamentosAtivos, "FLUOXETINA") or list contains(medicamentosAtivos, "PAROXETINA") or list contains(medicamentosAtivos, "BUPROPIONA")</text></inputEntry>
        <inputEntry><text>"DEXTROMETORFANO" or "DXM"</text></inputEntry>
        <outputEntry><text>"Atencao"</text></outputEntry>
        <outputEntry><text>"DXM metabolizado por CYP2D6. Fluoxetina/paroxetina/bupropiona sao inibidores CYP2D6 potentes. Aumento nivel DXM + efeito serotoninergico aditivo. Evitar uso frequente ou doses altas de DXM. Monitorar sintomas serotoninergicos."</text></outputEntry>
        <outputEntry><text>"Interacao farmacocinetica (CYP2D6) + farmacodinamica (serotonina). Skinner MH, J Clin Pharmacol 2003."</text></outputEntry>
      </rule>
      <rule id="rule_isrs_dxm_ddi_serotonin_005_decision">
        <inputEntry><text>list contains(medicamentosAtivos, "DEXTROMETORFANO")</text></inputEntry>
        <inputEntry><text>"FLUOXETINA" or "PAROXETINA" or "FENELZINA" or "TRANILCIPROMINA" or "SELEGILINA" or "LINEZOLIDA"</text></inputEntry>
        <outputEntry><text>"Alerta"</text></outputEntry>
        <outputEntry><text>"Paciente em DXM (antitussigeno). NAO iniciar IMAO ate washout. Se iniciando ISRS inibidor CYP2D6, orientar a suspender medicamentos contendo DXM."</text></outputEntry>
        <outputEntry><text>"DXM presente em muitos xaropes OTC. Paciente pode nao relatar uso."</text></outputEntry>
      </rule>
      <rule id="Rule_Fallback_ddi_serotonin_005_decision">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"OK"</text></outputEntry>
        <outputEntry><text>""</text></outputEntry>
        <outputEntry><text>""</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ddi_serotonin_005_decision">
      <dmndi:DMNShape id="DMNShape_ddi_serotonin_005_decision" dmnElementRef="ddi_serotonin_005_decision">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
