<?xml version="1.0" encoding="UTF-8"?>
<!-- DDI-SEROTONIN-002: Fentanil + IMAOs - Sindrome Serotoninergica Grave -->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="DDI_SEROTONIN_002" name="DDI-SEROTONIN-002: Fentanil + IMAO" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="ddi_serotonin_002_decision" name="[SP-CO-004 | clinical_safety/serotonin] Fentanil + IMAO - Sindrome Serotoninergica Fatal" camunda:historyTimeToLive="180">
    <decisionTable id="ddi_serotonin_002_table" hitPolicy="FIRST">
      <input id="input_medicamentos_ativos_ddi_serotonin_002_decision"><inputExpression typeRef="string"><text>medicamentosAtivos</text></inputExpression></input>
      <input id="input_medicamento_novo_ddi_serotonin_002_decision"><inputExpression typeRef="string"><text>medicamentoNovo</text></inputExpression></input>
      <output id="output_nivel_alerta_ddi_serotonin_002_decision" name="nivelAlerta" typeRef="string"><outputValues><text>"Alerta","Atencao","Informativo","OK"</text></outputValues></output>
      <output id="output_acao_requerida_ddi_serotonin_002_decision" name="acaoRequerida" typeRef="string" />
      <output id="output_justificativa_ddi_serotonin_002_decision" name="justificativaCientifica" typeRef="string" />

      <rule id="rule_fentanil_imao_ddi_serotonin_002_decision">
        <inputEntry><text>list contains(medicamentosAtivos, "FENELZINA") or list contains(medicamentosAtivos, "TRANILCIPROMINA") or list contains(medicamentosAtivos, "SELEGILINA") or list contains(medicamentosAtivos, "RASAGILINA") or list contains(medicamentosAtivos, "ISOCARBOXAZIDA")</text></inputEntry>
        <inputEntry><text>"FENTANIL" or "FENTANILA"</text></inputEntry>
        <outputEntry><text>"Alerta"</text></outputEntry>
        <outputEntry><text>"CONTRAINDICADO. Fentanil + IMAO = risco FATAL de sindrome serotoninergica. IMAOs devem ser suspensos 14 dias antes de opioides serotoninergicos. Usar morfina como alternativa (menor risco serotoninergico). Se analgesia urgente, monitorar em UTI."</text></outputEntry>
        <outputEntry><text>"Fentanil inibe recaptacao serotonina. IMAOs impedem degradacao. Acumulo potencialmente letal. Gillman PK, Br J Anaesth 2005."</text></outputEntry>
      </rule>
      <rule id="rule_imao_fentanil_ddi_serotonin_002_decision">
        <inputEntry><text>list contains(medicamentosAtivos, "FENTANIL") or list contains(medicamentosAtivos, "FENTANILA")</text></inputEntry>
        <inputEntry><text>"FENELZINA" or "TRANILCIPROMINA" or "SELEGILINA" or "RASAGILINA"</text></inputEntry>
        <outputEntry><text>"Alerta"</text></outputEntry>
        <outputEntry><text>"CONTRAINDICADO iniciar IMAO em paciente usando fentanil. Aguardar eliminacao do opioide (5 meias-vidas) antes de IMAO. Considerar antidepressivos nao-IMAO."</text></outputEntry>
        <outputEntry><text>"Washout necessario para evitar sindrome serotoninergica."</text></outputEntry>
      </rule>
      <rule id="Rule_Fallback_ddi_serotonin_002_decision">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"OK"</text></outputEntry>
        <outputEntry><text>""</text></outputEntry>
        <outputEntry><text>""</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ddi_serotonin_002_decision">
      <dmndi:DMNShape id="DMNShape_ddi_serotonin_002_decision" dmnElementRef="ddi_serotonin_002_decision">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
