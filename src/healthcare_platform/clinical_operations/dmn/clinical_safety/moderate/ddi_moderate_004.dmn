<?xml version="1.0" encoding="UTF-8"?>
<!-- DDI-MODERATE-004: Metformina + IBP - Deficiencia B12 -->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="DDI_MODERATE_004" name="DDI-MODERATE-004: Metformina + IBP" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="ddi_moderate_004_decision" name="[SP-CO-004 | clinical_safety/moderate] Metformina + IBP - Deficiencia B12" camunda:historyTimeToLive="180">
    <decisionTable id="ddi_moderate_004_table" hitPolicy="FIRST">
      <input id="input_medicamentos_ativos_ddi_moderate_004_decision"><inputExpression typeRef="string"><text>medicamentosAtivos</text></inputExpression></input>
      <input id="input_medicamento_novo_ddi_moderate_004_decision"><inputExpression typeRef="string"><text>medicamentoNovo</text></inputExpression></input>
      <input id="input_duracao_uso_ddi_moderate_004_decision"><inputExpression typeRef="string"><text>duracaoUso</text></inputExpression></input>
      <output id="output_nivel_alerta_ddi_moderate_004_decision" name="nivelAlerta" typeRef="string"><outputValues><text>"Alerta","Atencao","Informativo","OK"</text></outputValues></output>
      <output id="output_acao_requerida_ddi_moderate_004_decision" name="acaoRequerida" typeRef="string" />
      <output id="output_justificativa_ddi_moderate_004_decision" name="justificativaCientifica" typeRef="string" />

      <rule id="rule_metformina_ibp_longo_ddi_moderate_004_decision">
        <inputEntry><text>list contains(medicamentosAtivos, "METFORMINA")</text></inputEntry>
        <inputEntry><text>"OMEPRAZOL" or "PANTOPRAZOL" or "LANSOPRAZOL" or "ESOMEPRAZOL"</text></inputEntry>
        <inputEntry><text>"CRONICO" or "LONGO_PRAZO"</text></inputEntry>
        <outputEntry><text>"Atencao"</text></outputEntry>
        <outputEntry><text>"Duplo risco deficiencia B12: metformina + IBP cronico. Dosar B12 anualmente. Se&lt; 200 pg/mL, suplementar. Considerar descontinuar IBP se indicacao fraca. Sintomas: neuropatia, anemia, fadiga."</text></outputEntry>
        <outputEntry><text>"Ambos reduzem absorcao B12 por mecanismos diferentes. Lam JR, JAMA 2013."</text></outputEntry>
      </rule>
      <rule id="Rule_Fallback_ddi_moderate_004_decision">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"OK"</text></outputEntry>
        <outputEntry><text>""</text></outputEntry>
        <outputEntry><text>""</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ddi_moderate_004_decision">
      <dmndi:DMNShape id="DMNShape_ddi_moderate_004_decision" dmnElementRef="ddi_moderate_004_decision">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
