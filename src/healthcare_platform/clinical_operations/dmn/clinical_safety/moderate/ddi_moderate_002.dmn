<?xml version="1.0" encoding="UTF-8"?>
<!-- DDI-MODERATE-002: IBP + Ferro Oral - Reducao Absorcao -->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="DDI_MODERATE_002" name="DDI-MODERATE-002: IBP + Ferro" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="ddi_moderate_002_decision" name="[SP-CO-004 | clinical_safety/moderate] IBP + Ferro Oral - Absorcao Reduzida" camunda:historyTimeToLive="180">
    <decisionTable id="ddi_moderate_002_table" hitPolicy="FIRST">
      <input id="input_medicamentos_ativos_ddi_moderate_002_decision"><inputExpression typeRef="string"><text>medicamentosAtivos</text></inputExpression></input>
      <input id="input_medicamento_novo_ddi_moderate_002_decision"><inputExpression typeRef="string"><text>medicamentoNovo</text></inputExpression></input>
      <output id="output_nivel_alerta_ddi_moderate_002_decision" name="nivelAlerta" typeRef="string"><outputValues><text>"Alerta","Atencao","Informativo","OK"</text></outputValues></output>
      <output id="output_acao_requerida_ddi_moderate_002_decision" name="acaoRequerida" typeRef="string" />
      <output id="output_justificativa_ddi_moderate_002_decision" name="justificativaCientifica" typeRef="string" />

      <rule id="rule_ibp_ferro_ddi_moderate_002_decision">
        <inputEntry><text>list contains(medicamentosAtivos, "OMEPRAZOL") or list contains(medicamentosAtivos, "PANTOPRAZOL") or list contains(medicamentosAtivos, "LANSOPRAZOL") or list contains(medicamentosAtivos, "ESOMEPRAZOL")</text></inputEntry>
        <inputEntry><text>"SULFATO_FERROSO" or "FERRO_ORAL" or "NORIPURUM_ORAL"</text></inputEntry>
        <outputEntry><text>"Atencao"</text></outputEntry>
        <outputEntry><text>"IBP reduz absorcao de ferro (necessita meio acido). Administrar ferro 2h antes do IBP ou usar sais de ferro mais absorviveis (ferro polimaltosado). Monitorar hemoglobina e ferritina. Se anemia refrataria, considerar ferro IV."</text></outputEntry>
        <outputEntry><text>"pH gastrico elevado reduz conversao Fe3+ para Fe2+ (forma absorvivel). Sharma VR, J Clin Gastroenterol 2004."</text></outputEntry>
      </rule>
      <rule id="Rule_Fallback_ddi_moderate_002_decision">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"OK"</text></outputEntry>
        <outputEntry><text>""</text></outputEntry>
        <outputEntry><text>""</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ddi_moderate_002_decision">
      <dmndi:DMNShape id="DMNShape_ddi_moderate_002_decision" dmnElementRef="ddi_moderate_002_decision">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
