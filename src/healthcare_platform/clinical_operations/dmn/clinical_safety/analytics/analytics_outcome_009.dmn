<?xml version="1.0" encoding="UTF-8"?>
<!--
  ANALYTICS_OUTCOME_009: Outcome Correlation Rules
  Clinical Analytics DMN - Extracted from clinical_analytics_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_analytics_outcome_009"
             name="Outcome Correlation Rules"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_analytics_outcome_009" name="[SP-CO-004 | clinical_safety/analytics] Outcome Correlation Rules" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_analytics_outcome_009" hitPolicy="FIRST">

      <input id="Input_1_analytics_outcome_009" label="outcomeType">
        <inputExpression id="InputExpression_1_analytics_outcome_009" typeRef="string">
          <text>outcomeType</text>
        </inputExpression>
      </input>

      <input id="Input_2_analytics_outcome_009" label="correlationStrength">
        <inputExpression id="InputExpression_2_analytics_outcome_009" typeRef="number">
          <text>correlationStrength</text>
        </inputExpression>
      </input>

      <output id="Output_1_analytics_outcome_009" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2_analytics_outcome_009" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3_analytics_outcome_009" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4_analytics_outcome_009" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1_analytics_outcome_009">
        <inputEntry id="IE_1_1_analytics_outcome_009"><text>"-"</text></inputEntry>
        <inputEntry id="IE_1_2_analytics_outcome_009"><text>>= 0.7</text></inputEntry>
        <outputEntry id="OE_1_1_analytics_outcome_009"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_1_2_analytics_outcome_009"><text>"URGENTE"</text></outputEntry>
        <outputEntry id="OE_1_3_analytics_outcome_009"><text>"Correlacao forte detectada. Investigar causalidade."</text></outputEntry>
        <outputEntry id="OE_1_4_analytics_outcome_009"><text>"Correlacao >= 0.7 sugere relacao significativa entre variaveis clinicas."</text></outputEntry>
      </rule>

      <rule id="Rule_2_analytics_outcome_009">
        <inputEntry id="IE_2_1_analytics_outcome_009"><text>"-"</text></inputEntry>
        <inputEntry id="IE_2_2_analytics_outcome_009"><text>[0.4..0.7)</text></inputEntry>
        <outputEntry id="OE_2_1_analytics_outcome_009"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_2_2_analytics_outcome_009"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_2_3_analytics_outcome_009"><text>"Correlacao moderada. Incluir em analise de tendencias."</text></outputEntry>
        <outputEntry id="OE_2_4_analytics_outcome_009"><text>"Correlacao entre 0.4-0.7 merece acompanhamento mas nao acao imediata."</text></outputEntry>
      </rule>

      <rule id="Rule_3_analytics_outcome_009">
        <inputEntry id="IE_3_1_analytics_outcome_009"><text>"-"</text></inputEntry>
        <inputEntry id="IE_3_2_analytics_outcome_009"><text>&lt; 0.4</text></inputEntry>
        <outputEntry id="OE_3_1_analytics_outcome_009"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2_analytics_outcome_009"><text>"INFORMATIVA"</text></outputEntry>
        <outputEntry id="OE_3_3_analytics_outcome_009"><text>"Correlacao fraca. Sem significancia clinica aparente."</text></outputEntry>
        <outputEntry id="OE_3_4_analytics_outcome_009"><text>"Correlacao &lt; 0.4 nao indica relacao clinica relevante."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_analytics_outcome_009">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1_analytics_outcome_009"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_analytics_outcome_009"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_analytics_outcome_009"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2_analytics_outcome_009"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3_analytics_outcome_009"><text>"Verificar dados de entrada e recalcular metricas."</text></outputEntry>
        <outputEntry id="OE_F_4_analytics_outcome_009"><text>"Dados insuficientes para avaliacao automatica. Revisao manual necessaria."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_analytics_outcome_009">
      <dmndi:DMNShape id="DMNShape_analytics_outcome_009" dmnElementRef="Decision_analytics_outcome_009">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
