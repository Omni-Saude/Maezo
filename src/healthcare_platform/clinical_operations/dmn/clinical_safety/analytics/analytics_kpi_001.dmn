<?xml version="1.0" encoding="UTF-8"?>
<!--
  ANALYTICS_KPI_001: KPI Threshold Rules
  Clinical Analytics DMN - Extracted from clinical_analytics_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_analytics_kpi_001"
             name="KPI Threshold Rules"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_analytics_kpi_001" name="[SP-CO-004 | clinical_safety/analytics] KPI Threshold Rules" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_analytics_kpi_001" hitPolicy="FIRST">

      <input id="Input_1_analytics_kpi_001" label="analyticsType">
        <inputExpression id="InputExpression_1_analytics_kpi_001" typeRef="string">
          <text>analyticsType</text>
        </inputExpression>
      </input>

      <input id="Input_2_analytics_kpi_001" label="metricValue">
        <inputExpression id="InputExpression_2_analytics_kpi_001" typeRef="number">
          <text>metricValue</text>
        </inputExpression>
      </input>

      <output id="Output_1_analytics_kpi_001" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2_analytics_kpi_001" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3_analytics_kpi_001" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4_analytics_kpi_001" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1_analytics_kpi_001">
        <inputEntry id="IE_1_1_analytics_kpi_001"><text>"los"</text></inputEntry>
        <inputEntry id="IE_1_2_analytics_kpi_001"><text>>= 5.0</text></inputEntry>
        <outputEntry id="OE_1_1_analytics_kpi_001"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_1_2_analytics_kpi_001"><text>"URGENTE"</text></outputEntry>
        <outputEntry id="OE_1_3_analytics_kpi_001"><text>"Tempo de permanencia acima do limiar. Revisar processo de alta."</text></outputEntry>
        <outputEntry id="OE_1_4_analytics_kpi_001"><text>"LOS > 5 dias indica ineficiencia operacional. Meta nacional: 4.8 dias."</text></outputEntry>
      </rule>

      <rule id="Rule_2_analytics_kpi_001">
        <inputEntry id="IE_2_1_analytics_kpi_001"><text>"occupancy"</text></inputEntry>
        <inputEntry id="IE_2_2_analytics_kpi_001"><text>>= 95.0</text></inputEntry>
        <outputEntry id="OE_2_1_analytics_kpi_001"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_2_2_analytics_kpi_001"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_2_3_analytics_kpi_001"><text>"Taxa de ocupacao critica. Ativar plano de contingencia."</text></outputEntry>
        <outputEntry id="OE_2_4_analytics_kpi_001"><text>"Ocupacao >= 95% indica risco de recusa de admissoes e queda de qualidade."</text></outputEntry>
      </rule>

      <rule id="Rule_3_analytics_kpi_001">
        <inputEntry id="IE_3_1_analytics_kpi_001"><text>"throughput"</text></inputEntry>
        <inputEntry id="IE_3_2_analytics_kpi_001"><text>&lt; 10.0</text></inputEntry>
        <outputEntry id="OE_3_1_analytics_kpi_001"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_3_2_analytics_kpi_001"><text>"URGENTE"</text></outputEntry>
        <outputEntry id="OE_3_3_analytics_kpi_001"><text>"Throughput abaixo da meta. Avaliar gargalos operacionais."</text></outputEntry>
        <outputEntry id="OE_3_4_analytics_kpi_001"><text>"Admissoes diarias &lt; 10 pode indicar problemas de acesso ou agendamento."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_analytics_kpi_001">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1_analytics_kpi_001"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_analytics_kpi_001"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_analytics_kpi_001"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2_analytics_kpi_001"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3_analytics_kpi_001"><text>"Verificar dados de entrada e recalcular metricas."</text></outputEntry>
        <outputEntry id="OE_F_4_analytics_kpi_001"><text>"Dados insuficientes para avaliacao automatica. Revisao manual necessaria."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_analytics_kpi_001">
      <dmndi:DMNShape id="DMNShape_analytics_kpi_001" dmnElementRef="Decision_analytics_kpi_001">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
