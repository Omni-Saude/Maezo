<?xml version="1.0" encoding="UTF-8"?>
<!--
  ANALYTICS_PROVIDER_006: Provider Performance Scoring
  Clinical Analytics DMN - Extracted from clinical_analytics_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_analytics_provider_006"
             name="Provider Performance Scoring"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_analytics_provider_006" name="[SP-CO-004 | clinical_safety/analytics] Provider Performance Scoring" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_analytics_provider_006" hitPolicy="FIRST">

      <input id="Input_1_analytics_provider_006" label="providerType">
        <inputExpression id="InputExpression_1_analytics_provider_006" typeRef="string">
          <text>providerType</text>
        </inputExpression>
      </input>

      <input id="Input_2_analytics_provider_006" label="performanceScore">
        <inputExpression id="InputExpression_2_analytics_provider_006" typeRef="number">
          <text>performanceScore</text>
        </inputExpression>
      </input>

      <output id="Output_1_analytics_provider_006" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2_analytics_provider_006" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3_analytics_provider_006" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4_analytics_provider_006" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1_analytics_provider_006">
        <inputEntry id="IE_1_1_analytics_provider_006"><text>"-"</text></inputEntry>
        <inputEntry id="IE_1_2_analytics_provider_006"><text>&lt; 70.0</text></inputEntry>
        <outputEntry id="OE_1_1_analytics_provider_006"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_1_2_analytics_provider_006"><text>"URGENTE"</text></outputEntry>
        <outputEntry id="OE_1_3_analytics_provider_006"><text>"Profissional com performance abaixo do esperado. Feedback necessario."</text></outputEntry>
        <outputEntry id="OE_1_4_analytics_provider_006"><text>"Score &lt; 70 indica necessidade de capacitacao ou revisao de praticas."</text></outputEntry>
      </rule>

      <rule id="Rule_2_analytics_provider_006">
        <inputEntry id="IE_2_1_analytics_provider_006"><text>"-"</text></inputEntry>
        <inputEntry id="IE_2_2_analytics_provider_006"><text>[70.0..90.0)</text></inputEntry>
        <outputEntry id="OE_2_1_analytics_provider_006"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_2_2_analytics_provider_006"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_2_3_analytics_provider_006"><text>"Performance profissional dentro do esperado. Continuar acompanhamento."</text></outputEntry>
        <outputEntry id="OE_2_4_analytics_provider_006"><text>"Score entre 70-90 indica praticas clinicas adequadas."</text></outputEntry>
      </rule>

      <rule id="Rule_3_analytics_provider_006">
        <inputEntry id="IE_3_1_analytics_provider_006"><text>"-"</text></inputEntry>
        <inputEntry id="IE_3_2_analytics_provider_006"><text>>= 90.0</text></inputEntry>
        <outputEntry id="OE_3_1_analytics_provider_006"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2_analytics_provider_006"><text>"INFORMATIVA"</text></outputEntry>
        <outputEntry id="OE_3_3_analytics_provider_006"><text>"Performance profissional exemplar. Reconhecimento recomendado."</text></outputEntry>
        <outputEntry id="OE_3_4_analytics_provider_006"><text>"Score >= 90 indica excelencia clinica. Modelo para boas praticas."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_analytics_provider_006">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1_analytics_provider_006"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_analytics_provider_006"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_analytics_provider_006"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2_analytics_provider_006"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3_analytics_provider_006"><text>"Verificar dados de entrada e recalcular metricas."</text></outputEntry>
        <outputEntry id="OE_F_4_analytics_provider_006"><text>"Dados insuficientes para avaliacao automatica. Revisao manual necessaria."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_analytics_provider_006">
      <dmndi:DMNShape id="DMNShape_analytics_provider_006" dmnElementRef="Decision_analytics_provider_006">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
