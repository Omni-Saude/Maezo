<?xml version="1.0" encoding="UTF-8"?>
<!--
  ANALYTICS_ANOMALY_003: Anomaly Detection Thresholds
  Clinical Analytics DMN - Extracted from clinical_analytics_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_analytics_anomaly_003"
             name="Anomaly Detection Thresholds"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_analytics_anomaly_003" name="[SP-CO-004 | clinical_safety/analytics] Anomaly Detection Thresholds" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_analytics_anomaly_003" hitPolicy="FIRST">

      <input id="Input_1_analytics_anomaly_003" label="deviationSigma">
        <inputExpression id="InputExpression_1_analytics_anomaly_003" typeRef="number">
          <text>deviationSigma</text>
        </inputExpression>
      </input>

      <input id="Input_2_analytics_anomaly_003" label="anomalyType">
        <inputExpression id="InputExpression_2_analytics_anomaly_003" typeRef="string">
          <text>anomalyType</text>
        </inputExpression>
      </input>

      <output id="Output_1_analytics_anomaly_003" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2_analytics_anomaly_003" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3_analytics_anomaly_003" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4_analytics_anomaly_003" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1_analytics_anomaly_003">
        <inputEntry id="IE_1_1_analytics_anomaly_003"><text>">= 3.0"</text></inputEntry>
        <inputEntry id="IE_1_2_analytics_anomaly_003"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1_analytics_anomaly_003"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_1_2_analytics_anomaly_003"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_1_3_analytics_anomaly_003"><text>"Anomalia estatistica grave (>= 3 sigma). Investigacao imediata."</text></outputEntry>
        <outputEntry id="OE_1_4_analytics_anomaly_003"><text>"Desvio >= 3 sigma tem probabilidade &lt; 0.3% de ser aleatorio."</text></outputEntry>
      </rule>

      <rule id="Rule_2_analytics_anomaly_003">
        <inputEntry id="IE_2_1_analytics_anomaly_003"><text>"[2.0..3.0)"</text></inputEntry>
        <inputEntry id="IE_2_2_analytics_anomaly_003"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1_analytics_anomaly_003"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_2_2_analytics_anomaly_003"><text>"URGENTE"</text></outputEntry>
        <outputEntry id="OE_2_3_analytics_anomaly_003"><text>"Anomalia moderada detectada. Avaliar em 24 horas."</text></outputEntry>
        <outputEntry id="OE_2_4_analytics_anomaly_003"><text>"Desvio entre 2-3 sigma requer atencao mas pode ser variacao natural."</text></outputEntry>
      </rule>

      <rule id="Rule_3_analytics_anomaly_003">
        <inputEntry id="IE_3_1_analytics_anomaly_003"><text>"&lt; 2.0"</text></inputEntry>
        <inputEntry id="IE_3_2_analytics_anomaly_003"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1_analytics_anomaly_003"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2_analytics_anomaly_003"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_3_3_analytics_anomaly_003"><text>"Valores dentro da faixa esperada. Sem anomalias."</text></outputEntry>
        <outputEntry id="OE_3_4_analytics_anomaly_003"><text>"Desvio &lt; 2 sigma esta dentro da variacao estatistica normal."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_analytics_anomaly_003">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1_analytics_anomaly_003"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_analytics_anomaly_003"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_analytics_anomaly_003"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2_analytics_anomaly_003"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3_analytics_anomaly_003"><text>"Verificar dados de entrada e recalcular metricas."</text></outputEntry>
        <outputEntry id="OE_F_4_analytics_anomaly_003"><text>"Dados insuficientes para avaliacao automatica. Revisao manual necessaria."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_analytics_anomaly_003">
      <dmndi:DMNShape id="DMNShape_analytics_anomaly_003" dmnElementRef="Decision_analytics_anomaly_003">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
