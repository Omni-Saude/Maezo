<?xml version="1.0" encoding="UTF-8"?>
<!--
  ANALYTICS_QI_011: Quality Indicator Scoring
  Clinical Analytics DMN - Extracted from clinical_analytics_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_analytics_qi_011"
             name="Quality Indicator Scoring"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_analytics_qi_011" name="[SP-CO-004 | clinical_safety/analytics] Quality Indicator Scoring" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_analytics_qi_011" hitPolicy="FIRST">

      <input id="Input_1_analytics_qi_011" label="indicatorType">
        <inputExpression id="InputExpression_1_analytics_qi_011" typeRef="string">
          <text>indicatorType</text>
        </inputExpression>
      </input>

      <input id="Input_2_analytics_qi_011" label="indicatorValue">
        <inputExpression id="InputExpression_2_analytics_qi_011" typeRef="number">
          <text>indicatorValue</text>
        </inputExpression>
      </input>

      <output id="Output_1_analytics_qi_011" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2_analytics_qi_011" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3_analytics_qi_011" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4_analytics_qi_011" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1_analytics_qi_011">
        <inputEntry id="IE_1_1_analytics_qi_011"><text>"readmission_rate"</text></inputEntry>
        <inputEntry id="IE_1_2_analytics_qi_011"><text>>= 15.0</text></inputEntry>
        <outputEntry id="OE_1_1_analytics_qi_011"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_1_2_analytics_qi_011"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_1_3_analytics_qi_011"><text>"Taxa de readmissao critica (>= 15%). Revisar processo de alta."</text></outputEntry>
        <outputEntry id="OE_1_4_analytics_qi_011"><text>"Readmissao >= 15% indica falhas no planejamento de alta e follow-up."</text></outputEntry>
      </rule>

      <rule id="Rule_2_analytics_qi_011">
        <inputEntry id="IE_2_1_analytics_qi_011"><text>"infection_rate"</text></inputEntry>
        <inputEntry id="IE_2_2_analytics_qi_011"><text>>= 5.0</text></inputEntry>
        <outputEntry id="OE_2_1_analytics_qi_011"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_2_2_analytics_qi_011"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_2_3_analytics_qi_011"><text>"Taxa de infeccao acima do aceitavel (>= 5%). Acionar CCIH."</text></outputEntry>
        <outputEntry id="OE_2_4_analytics_qi_011"><text>"Taxa de IRAS >= 5% requer intervencao imediata da CCIH."</text></outputEntry>
      </rule>

      <rule id="Rule_3_analytics_qi_011">
        <inputEntry id="IE_3_1_analytics_qi_011"><text>"mortality_rate"</text></inputEntry>
        <inputEntry id="IE_3_2_analytics_qi_011"><text>>= 3.0</text></inputEntry>
        <outputEntry id="OE_3_1_analytics_qi_011"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_3_2_analytics_qi_011"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_3_3_analytics_qi_011"><text>"Taxa de mortalidade elevada. Comite de obitos imediato."</text></outputEntry>
        <outputEntry id="OE_3_4_analytics_qi_011"><text>"Mortalidade >= 3% requer analise detalhada pelo comite de obitos."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_analytics_qi_011">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1_analytics_qi_011"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_analytics_qi_011"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_analytics_qi_011"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2_analytics_qi_011"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3_analytics_qi_011"><text>"Verificar dados de entrada e recalcular metricas."</text></outputEntry>
        <outputEntry id="OE_F_4_analytics_qi_011"><text>"Dados insuficientes para avaliacao automatica. Revisao manual necessaria."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_analytics_qi_011">
      <dmndi:DMNShape id="DMNShape_analytics_qi_011" dmnElementRef="Decision_analytics_qi_011">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
