<?xml version="1.0" encoding="UTF-8"?>
<!--
  ANALYTICS_DEPT_005: Department Performance Scoring
  Clinical Analytics DMN - Extracted from clinical_analytics_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_analytics_dept_005"
             name="Department Performance Scoring"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_analytics_dept_005" name="[SP-CO-004 | clinical_safety/analytics] Department Performance Scoring" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_analytics_dept_005" hitPolicy="FIRST">

      <input id="Input_1_analytics_dept_005" label="department">
        <inputExpression id="InputExpression_1_analytics_dept_005" typeRef="string">
          <text>department</text>
        </inputExpression>
      </input>

      <input id="Input_2_analytics_dept_005" label="performanceScore">
        <inputExpression id="InputExpression_2_analytics_dept_005" typeRef="number">
          <text>performanceScore</text>
        </inputExpression>
      </input>

      <output id="Output_1_analytics_dept_005" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2_analytics_dept_005" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3_analytics_dept_005" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4_analytics_dept_005" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1_analytics_dept_005">
        <inputEntry id="IE_1_1_analytics_dept_005"><text>"-"</text></inputEntry>
        <inputEntry id="IE_1_2_analytics_dept_005"><text>&lt; 60.0</text></inputEntry>
        <outputEntry id="OE_1_1_analytics_dept_005"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_1_2_analytics_dept_005"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_1_3_analytics_dept_005"><text>"Departamento com performance critica. Intervencao gerencial."</text></outputEntry>
        <outputEntry id="OE_1_4_analytics_dept_005"><text>"Score &lt; 60 indica deficiencias operacionais graves no departamento."</text></outputEntry>
      </rule>

      <rule id="Rule_2_analytics_dept_005">
        <inputEntry id="IE_2_1_analytics_dept_005"><text>"-"</text></inputEntry>
        <inputEntry id="IE_2_2_analytics_dept_005"><text>[60.0..80.0)</text></inputEntry>
        <outputEntry id="OE_2_1_analytics_dept_005"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_2_2_analytics_dept_005"><text>"URGENTE"</text></outputEntry>
        <outputEntry id="OE_2_3_analytics_dept_005"><text>"Performance departamental abaixo da meta. Plano de melhoria."</text></outputEntry>
        <outputEntry id="OE_2_4_analytics_dept_005"><text>"Score entre 60-80 indica necessidade de acoes corretivas especificas."</text></outputEntry>
      </rule>

      <rule id="Rule_3_analytics_dept_005">
        <inputEntry id="IE_3_1_analytics_dept_005"><text>"-"</text></inputEntry>
        <inputEntry id="IE_3_2_analytics_dept_005"><text>>= 80.0</text></inputEntry>
        <outputEntry id="OE_3_1_analytics_dept_005"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2_analytics_dept_005"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_3_3_analytics_dept_005"><text>"Departamento com performance adequada. Manter monitoramento."</text></outputEntry>
        <outputEntry id="OE_3_4_analytics_dept_005"><text>"Score >= 80 indica operacao dentro dos parametros de qualidade."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_analytics_dept_005">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1_analytics_dept_005"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_analytics_dept_005"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_analytics_dept_005"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2_analytics_dept_005"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3_analytics_dept_005"><text>"Verificar dados de entrada e recalcular metricas."</text></outputEntry>
        <outputEntry id="OE_F_4_analytics_dept_005"><text>"Dados insuficientes para avaliacao automatica. Revisao manual necessaria."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_analytics_dept_005">
      <dmndi:DMNShape id="DMNShape_analytics_dept_005" dmnElementRef="Decision_analytics_dept_005">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
