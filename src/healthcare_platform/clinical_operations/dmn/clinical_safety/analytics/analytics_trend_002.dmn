<?xml version="1.0" encoding="UTF-8"?>
<!--
  ANALYTICS_TREND_002: Trend Analysis Rules
  Clinical Analytics DMN - Extracted from clinical_analytics_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_analytics_trend_002"
             name="Trend Analysis Rules"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_analytics_trend_002" name="[SP-CO-004 | clinical_safety/analytics] Trend Analysis Rules" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_analytics_trend_002" hitPolicy="FIRST">

      <input id="Input_1_analytics_trend_002" label="trendDirection">
        <inputExpression id="InputExpression_1_analytics_trend_002" typeRef="string">
          <text>trendDirection</text>
        </inputExpression>
      </input>

      <input id="Input_2_analytics_trend_002" label="trendMagnitude">
        <inputExpression id="InputExpression_2_analytics_trend_002" typeRef="number">
          <text>trendMagnitude</text>
        </inputExpression>
      </input>

      <output id="Output_1_analytics_trend_002" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2_analytics_trend_002" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3_analytics_trend_002" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4_analytics_trend_002" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1_analytics_trend_002">
        <inputEntry id="IE_1_1_analytics_trend_002"><text>"deteriorating"</text></inputEntry>
        <inputEntry id="IE_1_2_analytics_trend_002"><text>>= 10.0</text></inputEntry>
        <outputEntry id="OE_1_1_analytics_trend_002"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_1_2_analytics_trend_002"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_1_3_analytics_trend_002"><text>"Tendencia de deterioracao significativa detectada. Investigar causas."</text></outputEntry>
        <outputEntry id="OE_1_4_analytics_trend_002"><text>"Variacao >= 10% em direcao desfavoravel requer intervencao imediata."</text></outputEntry>
      </rule>

      <rule id="Rule_2_analytics_trend_002">
        <inputEntry id="IE_2_1_analytics_trend_002"><text>"improving"</text></inputEntry>
        <inputEntry id="IE_2_2_analytics_trend_002"><text>>= 5.0</text></inputEntry>
        <outputEntry id="OE_2_1_analytics_trend_002"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_2_2_analytics_trend_002"><text>"INFORMATIVA"</text></outputEntry>
        <outputEntry id="OE_2_3_analytics_trend_002"><text>"Tendencia positiva identificada. Manter monitoramento."</text></outputEntry>
        <outputEntry id="OE_2_4_analytics_trend_002"><text>"Melhoria >= 5% indica efetividade das acoes implementadas."</text></outputEntry>
      </rule>

      <rule id="Rule_3_analytics_trend_002">
        <inputEntry id="IE_3_1_analytics_trend_002"><text>"stable"</text></inputEntry>
        <inputEntry id="IE_3_2_analytics_trend_002"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1_analytics_trend_002"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2_analytics_trend_002"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_3_3_analytics_trend_002"><text>"Indicadores estaveis. Manter rotina de monitoramento."</text></outputEntry>
        <outputEntry id="OE_3_4_analytics_trend_002"><text>"Estabilidade nos indicadores dentro dos limites aceitaveis."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_analytics_trend_002">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1_analytics_trend_002"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_analytics_trend_002"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_analytics_trend_002"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2_analytics_trend_002"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3_analytics_trend_002"><text>"Verificar dados de entrada e recalcular metricas."</text></outputEntry>
        <outputEntry id="OE_F_4_analytics_trend_002"><text>"Dados insuficientes para avaliacao automatica. Revisao manual necessaria."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_analytics_trend_002">
      <dmndi:DMNShape id="DMNShape_analytics_trend_002" dmnElementRef="Decision_analytics_trend_002">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
