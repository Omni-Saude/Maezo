<?xml version="1.0" encoding="UTF-8"?>
<!--
  ANALYTICS_RESOURCE_008: Resource Utilization Rules
  Clinical Analytics DMN - Extracted from clinical_analytics_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_analytics_resource_008"
             name="Resource Utilization Rules"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_analytics_resource_008" name="[SP-CO-004 | clinical_safety/analytics] Resource Utilization Rules" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_analytics_resource_008" hitPolicy="FIRST">

      <input id="Input_1_analytics_resource_008" label="resourceType">
        <inputExpression id="InputExpression_1_analytics_resource_008" typeRef="string">
          <text>resourceType</text>
        </inputExpression>
      </input>

      <input id="Input_2_analytics_resource_008" label="utilizationRate">
        <inputExpression id="InputExpression_2_analytics_resource_008" typeRef="number">
          <text>utilizationRate</text>
        </inputExpression>
      </input>

      <output id="Output_1_analytics_resource_008" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2_analytics_resource_008" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3_analytics_resource_008" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4_analytics_resource_008" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1_analytics_resource_008">
        <inputEntry id="IE_1_1_analytics_resource_008"><text>"-"</text></inputEntry>
        <inputEntry id="IE_1_2_analytics_resource_008"><text>>= 95.0</text></inputEntry>
        <outputEntry id="OE_1_1_analytics_resource_008"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_1_2_analytics_resource_008"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_1_3_analytics_resource_008"><text>"Recurso em capacidade critica (>= 95%). Plano de contingencia."</text></outputEntry>
        <outputEntry id="OE_1_4_analytics_resource_008"><text>"Utilizacao >= 95% indica risco de indisponibilidade e atrasos."</text></outputEntry>
      </rule>

      <rule id="Rule_2_analytics_resource_008">
        <inputEntry id="IE_2_1_analytics_resource_008"><text>"-"</text></inputEntry>
        <inputEntry id="IE_2_2_analytics_resource_008"><text>[85.0..95.0)</text></inputEntry>
        <outputEntry id="OE_2_1_analytics_resource_008"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_2_2_analytics_resource_008"><text>"URGENTE"</text></outputEntry>
        <outputEntry id="OE_2_3_analytics_resource_008"><text>"Recurso com alta utilizacao. Monitorar e planejar expansao."</text></outputEntry>
        <outputEntry id="OE_2_4_analytics_resource_008"><text>"Utilizacao entre 85-95% requer planejamento proativo de capacidade."</text></outputEntry>
      </rule>

      <rule id="Rule_3_analytics_resource_008">
        <inputEntry id="IE_3_1_analytics_resource_008"><text>"-"</text></inputEntry>
        <inputEntry id="IE_3_2_analytics_resource_008"><text>&lt; 85.0</text></inputEntry>
        <outputEntry id="OE_3_1_analytics_resource_008"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2_analytics_resource_008"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_3_3_analytics_resource_008"><text>"Utilizacao de recursos dentro da faixa adequada."</text></outputEntry>
        <outputEntry id="OE_3_4_analytics_resource_008"><text>"Utilizacao &lt; 85% permite margem para variacao de demanda."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_analytics_resource_008">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1_analytics_resource_008"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_analytics_resource_008"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_analytics_resource_008"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2_analytics_resource_008"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3_analytics_resource_008"><text>"Verificar dados de entrada e recalcular metricas."</text></outputEntry>
        <outputEntry id="OE_F_4_analytics_resource_008"><text>"Dados insuficientes para avaliacao automatica. Revisao manual necessaria."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_analytics_resource_008">
      <dmndi:DMNShape id="DMNShape_analytics_resource_008" dmnElementRef="Decision_analytics_resource_008">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
