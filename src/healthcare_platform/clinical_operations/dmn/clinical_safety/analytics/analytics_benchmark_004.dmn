<?xml version="1.0" encoding="UTF-8"?>
<!--
  ANALYTICS_BENCHMARK_004: Benchmark Comparison Rules
  Clinical Analytics DMN - Extracted from clinical_analytics_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_analytics_benchmark_004"
             name="Benchmark Comparison Rules"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_analytics_benchmark_004" name="[SP-CO-004 | clinical_safety/analytics] Benchmark Comparison Rules" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_analytics_benchmark_004" hitPolicy="FIRST">

      <input id="Input_1_analytics_benchmark_004" label="benchmarkType">
        <inputExpression id="InputExpression_1_analytics_benchmark_004" typeRef="string">
          <text>benchmarkType</text>
        </inputExpression>
      </input>

      <input id="Input_2_analytics_benchmark_004" label="variancePercent">
        <inputExpression id="InputExpression_2_analytics_benchmark_004" typeRef="number">
          <text>variancePercent</text>
        </inputExpression>
      </input>

      <output id="Output_1_analytics_benchmark_004" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2_analytics_benchmark_004" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3_analytics_benchmark_004" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4_analytics_benchmark_004" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1_analytics_benchmark_004">
        <inputEntry id="IE_1_1_analytics_benchmark_004"><text>"-"</text></inputEntry>
        <inputEntry id="IE_1_2_analytics_benchmark_004"><text>> 20.0</text></inputEntry>
        <outputEntry id="OE_1_1_analytics_benchmark_004"><text>"Alerta"</text></outputEntry>
        <outputEntry id="OE_1_2_analytics_benchmark_004"><text>"IMEDIATA"</text></outputEntry>
        <outputEntry id="OE_1_3_analytics_benchmark_004"><text>"Variancia > 20% do benchmark. Plano de acao imediato."</text></outputEntry>
        <outputEntry id="OE_1_4_analytics_benchmark_004"><text>"Desvio significativo do benchmark indica necessidade de revisao de processos."</text></outputEntry>
      </rule>

      <rule id="Rule_2_analytics_benchmark_004">
        <inputEntry id="IE_2_1_analytics_benchmark_004"><text>"-"</text></inputEntry>
        <inputEntry id="IE_2_2_analytics_benchmark_004"><text>[10.0..20.0]</text></inputEntry>
        <outputEntry id="OE_2_1_analytics_benchmark_004"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_2_2_analytics_benchmark_004"><text>"URGENTE"</text></outputEntry>
        <outputEntry id="OE_2_3_analytics_benchmark_004"><text>"Variancia moderada do benchmark. Avaliar oportunidades de melhoria."</text></outputEntry>
        <outputEntry id="OE_2_4_analytics_benchmark_004"><text>"Variancia entre 10-20% sugere espaco para otimizacao operacional."</text></outputEntry>
      </rule>

      <rule id="Rule_3_analytics_benchmark_004">
        <inputEntry id="IE_3_1_analytics_benchmark_004"><text>"-"</text></inputEntry>
        <inputEntry id="IE_3_2_analytics_benchmark_004"><text>&lt; 10.0</text></inputEntry>
        <outputEntry id="OE_3_1_analytics_benchmark_004"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2_analytics_benchmark_004"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_3_3_analytics_benchmark_004"><text>"Performance dentro do benchmark esperado."</text></outputEntry>
        <outputEntry id="OE_3_4_analytics_benchmark_004"><text>"Variancia &lt; 10% indica alinhamento adequado com referencias do setor."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_analytics_benchmark_004">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1_analytics_benchmark_004"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_analytics_benchmark_004"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_analytics_benchmark_004"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2_analytics_benchmark_004"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3_analytics_benchmark_004"><text>"Verificar dados de entrada e recalcular metricas."</text></outputEntry>
        <outputEntry id="OE_F_4_analytics_benchmark_004"><text>"Dados insuficientes para avaliacao automatica. Revisao manual necessaria."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_analytics_benchmark_004">
      <dmndi:DMNShape id="DMNShape_analytics_benchmark_004" dmnElementRef="Decision_analytics_benchmark_004">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
