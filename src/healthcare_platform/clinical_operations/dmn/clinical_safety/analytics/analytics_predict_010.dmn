<?xml version="1.0" encoding="UTF-8"?>
<!--
  ANALYTICS_PREDICT_010: Predictive Model Thresholds
  Clinical Analytics DMN - Extracted from clinical_analytics_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_analytics_predict_010"
             name="Predictive Model Thresholds"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_analytics_predict_010" name="[SP-CO-004 | clinical_safety/analytics] Predictive Model Thresholds" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_analytics_predict_010" hitPolicy="FIRST">

      <input id="Input_1_analytics_predict_010" label="predictionType">
        <inputExpression id="InputExpression_1_analytics_predict_010" typeRef="string">
          <text>predictionType</text>
        </inputExpression>
      </input>

      <input id="Input_2_analytics_predict_010" label="confidenceLevel">
        <inputExpression id="InputExpression_2_analytics_predict_010" typeRef="number">
          <text>confidenceLevel</text>
        </inputExpression>
      </input>

      <output id="Output_1_analytics_predict_010" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2_analytics_predict_010" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3_analytics_predict_010" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4_analytics_predict_010" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1_analytics_predict_010">
        <inputEntry id="IE_1_1_analytics_predict_010"><text>"-"</text></inputEntry>
        <inputEntry id="IE_1_2_analytics_predict_010"><text>>= 0.85</text></inputEntry>
        <outputEntry id="OE_1_1_analytics_predict_010"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_1_2_analytics_predict_010"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_1_3_analytics_predict_010"><text>"Predicao com alta confianca. Utilizar para planejamento."</text></outputEntry>
        <outputEntry id="OE_1_4_analytics_predict_010"><text>"Confianca >= 85% indica modelo preditivo confiavel para decisoes."</text></outputEntry>
      </rule>

      <rule id="Rule_2_analytics_predict_010">
        <inputEntry id="IE_2_1_analytics_predict_010"><text>"-"</text></inputEntry>
        <inputEntry id="IE_2_2_analytics_predict_010"><text>[0.7..0.85)</text></inputEntry>
        <outputEntry id="OE_2_1_analytics_predict_010"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_2_2_analytics_predict_010"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_2_3_analytics_predict_010"><text>"Predicao com confianca moderada. Validar com dados adicionais."</text></outputEntry>
        <outputEntry id="OE_2_4_analytics_predict_010"><text>"Confianca entre 70-85% requer validacao cruzada antes de acao."</text></outputEntry>
      </rule>

      <rule id="Rule_3_analytics_predict_010">
        <inputEntry id="IE_3_1_analytics_predict_010"><text>"-"</text></inputEntry>
        <inputEntry id="IE_3_2_analytics_predict_010"><text>&lt; 0.7</text></inputEntry>
        <outputEntry id="OE_3_1_analytics_predict_010"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_3_2_analytics_predict_010"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_3_3_analytics_predict_010"><text>"Predicao com baixa confianca. Nao utilizar para decisoes."</text></outputEntry>
        <outputEntry id="OE_3_4_analytics_predict_010"><text>"Confianca &lt; 70% indica modelo impreciso. Recalibrar algoritmo."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_analytics_predict_010">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1_analytics_predict_010"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_analytics_predict_010"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_analytics_predict_010"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2_analytics_predict_010"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3_analytics_predict_010"><text>"Verificar dados de entrada e recalcular metricas."</text></outputEntry>
        <outputEntry id="OE_F_4_analytics_predict_010"><text>"Dados insuficientes para avaliacao automatica. Revisao manual necessaria."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_analytics_predict_010">
      <dmndi:DMNShape id="DMNShape_analytics_predict_010" dmnElementRef="Decision_analytics_predict_010">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
