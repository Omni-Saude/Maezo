<?xml version="1.0" encoding="UTF-8"?>
<!--
  ANALYTICS_COST_013: Cost Efficiency Rules
  Clinical Analytics DMN - Extracted from clinical_analytics_worker.py V1
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_analytics_cost_013"
             name="Cost Efficiency Rules"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_analytics_cost_013" name="[SP-CO-004 | clinical_safety/analytics] Cost Efficiency Rules" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_analytics_cost_013" hitPolicy="FIRST">

      <input id="Input_1_analytics_cost_013" label="costCategory">
        <inputExpression id="InputExpression_1_analytics_cost_013" typeRef="string">
          <text>costCategory</text>
        </inputExpression>
      </input>

      <input id="Input_2_analytics_cost_013" label="costVariance">
        <inputExpression id="InputExpression_2_analytics_cost_013" typeRef="number">
          <text>costVariance</text>
        </inputExpression>
      </input>

      <output id="Output_1_analytics_cost_013" label="Nivel Alerta" name="nivelAlerta" typeRef="string"/>
      <output id="Output_2_analytics_cost_013" label="Urgencia" name="urgencia" typeRef="string"/>
      <output id="Output_3_analytics_cost_013" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>
      <output id="Output_4_analytics_cost_013" label="Justificativa" name="justificativa" typeRef="string"/>

      <rule id="Rule_1_analytics_cost_013">
        <inputEntry id="IE_1_1_analytics_cost_013"><text>"-"</text></inputEntry>
        <inputEntry id="IE_1_2_analytics_cost_013"><text>> 15.0</text></inputEntry>
        <outputEntry id="OE_1_1_analytics_cost_013"><text>"Atencao"</text></outputEntry>
        <outputEntry id="OE_1_2_analytics_cost_013"><text>"URGENTE"</text></outputEntry>
        <outputEntry id="OE_1_3_analytics_cost_013"><text>"Variacao de custo > 15%. Revisar utilizacao de recursos."</text></outputEntry>
        <outputEntry id="OE_1_4_analytics_cost_013"><text>"Variacao > 15% do orcamento indica ineficiencia ou desperdicio."</text></outputEntry>
      </rule>

      <rule id="Rule_2_analytics_cost_013">
        <inputEntry id="IE_2_1_analytics_cost_013"><text>"-"</text></inputEntry>
        <inputEntry id="IE_2_2_analytics_cost_013"><text>[5.0..15.0]</text></inputEntry>
        <outputEntry id="OE_2_1_analytics_cost_013"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_2_2_analytics_cost_013"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_2_3_analytics_cost_013"><text>"Variacao de custo dentro do aceitavel. Monitorar tendencia."</text></outputEntry>
        <outputEntry id="OE_2_4_analytics_cost_013"><text>"Variacao entre 5-15% esta dentro da tolerancia operacional."</text></outputEntry>
      </rule>

      <rule id="Rule_3_analytics_cost_013">
        <inputEntry id="IE_3_1_analytics_cost_013"><text>"-"</text></inputEntry>
        <inputEntry id="IE_3_2_analytics_cost_013"><text>&lt; 5.0</text></inputEntry>
        <outputEntry id="OE_3_1_analytics_cost_013"><text>"OK"</text></outputEntry>
        <outputEntry id="OE_3_2_analytics_cost_013"><text>"INFORMATIVA"</text></outputEntry>
        <outputEntry id="OE_3_3_analytics_cost_013"><text>"Custos alinhados com orcamento. Performance financeira adequada."</text></outputEntry>
        <outputEntry id="OE_3_4_analytics_cost_013"><text>"Variacao &lt; 5% indica controle efetivo de custos operacionais."</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_analytics_cost_013">
        <description>Dados incompletos - requer revisao manual</description>
        <inputEntry id="IE_F_1_analytics_cost_013"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_analytics_cost_013"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_analytics_cost_013"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OE_F_2_analytics_cost_013"><text>"ROTINA"</text></outputEntry>
        <outputEntry id="OE_F_3_analytics_cost_013"><text>"Verificar dados de entrada e recalcular metricas."</text></outputEntry>
        <outputEntry id="OE_F_4_analytics_cost_013"><text>"Dados insuficientes para avaliacao automatica. Revisao manual necessaria."</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_analytics_cost_013">
      <dmndi:DMNShape id="DMNShape_analytics_cost_013" dmnElementRef="Decision_analytics_cost_013">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
