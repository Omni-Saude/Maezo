<?xml version="1.0" encoding="UTF-8"?>
<!-- ============================================================================
     DDI-NEPHRO-008: Litio + AINEs/Diureticos - Toxicidade por Acumulo

     EVIDENCIA CLINICA:
     - Micromedex: Major Interaction (Litio + AINEs)
     - Finley PR et al. Clin Pharmacokinet. 1995;29:172-91
     - Timmer RT, Sands JM. Am J Physiol. 1999;276:F952-9

     MECANISMO: AINEs reduzem TFG e excrecao renal de litio (aumento nivel 25-60%).
     Tiazidicos aumentam reabsorcao proximal de litio. Ambos causam toxicidade litica
     (tremor, ataxia, convulsoes, coma).

     INCIDENCIA: Toxicidade em 15-20% dos pacientes em uso combinado
     ============================================================================ -->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="DDI_NEPHRO_008" name="DDI-NEPHRO-008: Litio + AINEs/Diureticos" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="ddi_nephro_008_decision" name="[SP-CO-004 | clinical_safety/ddi] Litio + AINEs/Diureticos - Toxicidade Litica" camunda:historyTimeToLive="180">
    <decisionTable id="ddi_nephro_008_table" hitPolicy="FIRST">
      <input id="input_medicamentos_ativos_ddi_nephro_008_decision" label="Medicamentos Ativos">
        <inputExpression id="input_expr_medicamentos_ddi_nephro_008_decision" typeRef="string">
          <text>medicamentosAtivos</text>
        </inputExpression>
      </input>
      <input id="input_medicamento_novo_ddi_nephro_008_decision" label="Medicamento Novo">
        <inputExpression id="input_expr_novo_ddi_nephro_008_decision" typeRef="string">
          <text>medicamentoNovo</text>
        </inputExpression>
      </input>
      <input id="input_nivel_litio_ddi_nephro_008_decision" label="Litemia (mEq/L)">
        <inputExpression id="input_expr_litemia_ddi_nephro_008_decision" typeRef="number">
          <text>nivelLitio</text>
        </inputExpression>
      </input>

      <output id="output_nivel_alerta_ddi_nephro_008_decision" name="nivelAlerta" typeRef="string">
        <outputValues><text>"Alerta","Atencao","Informativo","OK"</text></outputValues>
      </output>
      <output id="output_acao_requerida_ddi_nephro_008_decision" name="acaoRequerida" typeRef="string" />
      <output id="output_justificativa_ddi_nephro_008_decision" name="justificativaCientifica" typeRef="string" />

      <!-- Rule 1: Litio + AINE + litemia limite -->
      <rule id="rule_litio_aine_alto_ddi_nephro_008_decision">
        <inputEntry id="ie_litio_ativo_ddi_nephro_008_decision">
          <text>list contains(medicamentosAtivos, "LITIO") or list contains(medicamentosAtivos, "CARBONATO_DE_LITIO")</text>
        </inputEntry>
        <inputEntry id="ie_aine_novo_ddi_nephro_008_decision">
          <text>"IBUPROFENO" or "DICLOFENACO" or "NAPROXENO" or "INDOMETACINA" or "PIROXICAM" or "MELOXICAM"</text>
        </inputEntry>
        <inputEntry id="ie_litemia_alta_ddi_nephro_008_decision">
          <text>&gt;= 1.0</text>
        </inputEntry>
        <outputEntry id="oe_alerta_alto_ddi_nephro_008_decision"><text>"Alerta"</text></outputEntry>
        <outputEntry id="oe_acao_alto_ddi_nephro_008_decision"><text>"EVITAR AINE. Litemia&gt; =1.0 com AINE = alto risco toxicidade (aumento 25-60% nivel). Usar paracetamol. Se AINE indispensavel, reduzir dose litio 25-50% e monitorar litemia em 5-7 dias. Vigiar: tremor, ataxia, confusao."</text></outputEntry>
        <outputEntry id="oe_just_alto_ddi_nephro_008_decision"><text>"AINEs reduzem excrecao renal de litio. Aumento nivel 25-60%. Finley PR, Clin Pharmacokinet 1995."</text></outputEntry>
      </rule>

      <!-- Rule 2: Litio + Tiazidico -->
      <rule id="rule_litio_tiazidico_ddi_nephro_008_decision">
        <inputEntry id="ie_litio_ativo2_ddi_nephro_008_decision">
          <text>list contains(medicamentosAtivos, "LITIO") or list contains(medicamentosAtivos, "CARBONATO_DE_LITIO")</text>
        </inputEntry>
        <inputEntry id="ie_tiazidico_novo_ddi_nephro_008_decision">
          <text>"HIDROCLOROTIAZIDA" or "CLORTALIDONA" or "INDAPAMIDA"</text>
        </inputEntry>
        <inputEntry id="ie_litemia_any_ddi_nephro_008_decision">
          <text>-</text>
        </inputEntry>
        <outputEntry id="oe_alerta_tiaz_ddi_nephro_008_decision"><text>"Alerta"</text></outputEntry>
        <outputEntry id="oe_acao_tiaz_ddi_nephro_008_decision"><text>"EVITAR TIAZIDICO se possivel. Tiazidicos aumentam reabsorcao proximal de litio (aumento nivel 20-40%). Se necessario para HAS, reduzir dose litio 25% e monitorar litemia semanalmente por 4 semanas. Preferir furosemida (menor interacao)."</text></outputEntry>
        <outputEntry id="oe_just_tiaz_ddi_nephro_008_decision"><text>"Tiazidicos causam deplecao sodio, aumentando reabsorcao tubular proximal de litio. Timmer RT, Am J Physiol 1999."</text></outputEntry>
      </rule>

      <!-- Rule 3: Litio + AINE + litemia normal-baixa -->
      <rule id="rule_litio_aine_normal_ddi_nephro_008_decision">
        <inputEntry id="ie_litio_ativo3_ddi_nephro_008_decision">
          <text>list contains(medicamentosAtivos, "LITIO") or list contains(medicamentosAtivos, "CARBONATO_DE_LITIO")</text>
        </inputEntry>
        <inputEntry id="ie_aine_novo2_ddi_nephro_008_decision">
          <text>"IBUPROFENO" or "DICLOFENACO" or "NAPROXENO" or "MELOXICAM" or "NIMESULIDA"</text>
        </inputEntry>
        <inputEntry id="ie_litemia_normal_ddi_nephro_008_decision">
          <text>&lt; 1.0</text>
        </inputEntry>
        <outputEntry id="oe_atencao_normal_ddi_nephro_008_decision"><text>"Atencao"</text></outputEntry>
        <outputEntry id="oe_acao_normal_ddi_nephro_008_decision"><text>"Preferir paracetamol. Se AINE necessario por curto periodo (&lt; 7 dias), monitorar litemia em 5-7 dias. Orientar sinais de intoxicacao (tremor, nausea, diarreia). Manter hidratacao adequada."</text></outputEntry>
        <outputEntry id="oe_just_normal_ddi_nephro_008_decision"><text>"Risco menor com litemia baixa, mas monitorizacao ainda necessaria. AINEs COX-2 seletivos podem ter menor interacao."</text></outputEntry>
      </rule>

      <!-- Fallback Rule -->
      <rule id="Rule_Fallback_ddi_nephro_008_decision">
        <inputEntry id="ie_fallback1_ddi_nephro_008_decision"><text>-</text></inputEntry>
        <inputEntry id="ie_fallback2_ddi_nephro_008_decision"><text>-</text></inputEntry>
        <inputEntry id="ie_fallback3_ddi_nephro_008_decision"><text>-</text></inputEntry>
        <outputEntry id="oe_fallback1_ddi_nephro_008_decision"><text>"OK"</text></outputEntry>
        <outputEntry id="oe_fallback2_ddi_nephro_008_decision"><text>""</text></outputEntry>
        <outputEntry id="oe_fallback3_ddi_nephro_008_decision"><text>""</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ddi_nephro_008_decision">
      <dmndi:DMNShape id="DMNShape_ddi_nephro_008_decision" dmnElementRef="ddi_nephro_008_decision">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
