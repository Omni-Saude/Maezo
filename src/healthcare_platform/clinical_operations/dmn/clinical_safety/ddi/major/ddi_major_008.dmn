<?xml version="1.0" encoding="UTF-8"?>
<!-- DDI-MAJOR-008: Metotrexato + Trimetoprim - Mielossupressao -->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="DDI_MAJOR_008" name="DDI-MAJOR-008: MTX + TMP" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="ddi_major_008_decision" name="[SP-CO-004 | clinical_safety/ddi] Metotrexato + Trimetoprim - Pancitopenia" camunda:historyTimeToLive="180">
    <decisionTable id="ddi_major_008_table" hitPolicy="FIRST">
      <input id="input_medicamentos_ativos_ddi_major_008_decision"><inputExpression typeRef="string"><text>medicamentosAtivos</text></inputExpression></input>
      <input id="input_medicamento_novo_ddi_major_008_decision"><inputExpression typeRef="string"><text>medicamentoNovo</text></inputExpression></input>
      <output id="output_nivel_alerta_ddi_major_008_decision" name="nivelAlerta" typeRef="string"><outputValues><text>"Alerta","Atencao","Informativo","OK"</text></outputValues></output>
      <output id="output_acao_requerida_ddi_major_008_decision" name="acaoRequerida" typeRef="string" />
      <output id="output_justificativa_ddi_major_008_decision" name="justificativaCientifica" typeRef="string" />

      <rule id="rule_mtx_tmp_ddi_major_008_decision">
        <inputEntry><text>list contains(medicamentosAtivos, "METOTREXATO") or list contains(medicamentosAtivos, "MTX")</text></inputEntry>
        <inputEntry><text>"SULFAMETOXAZOL_TRIMETOPRIM" or "BACTRIM" or "TRIMETOPRIM"</text></inputEntry>
        <outputEntry><text>"Alerta"</text></outputEntry>
        <outputEntry><text>"MIELOSSUPRESSAO SEVERA. TMP inibe DHFR como MTX - efeito aditivo antifolato. EVITAR combinacao. Se infeccao urinaria, usar cefalexina ou nitrofurantoina. Monitorar hemograma em 5-7 dias se uso inadvertido. Suplementar acido folinico."</text></outputEntry>
        <outputEntry><text>"Ambos antifolatos. Pancitopenia grave descrita. Thomas RJ, Pharmacotherapy 1998."</text></outputEntry>
      </rule>
      <rule id="rule_tmp_mtx_ddi_major_008_decision">
        <inputEntry><text>list contains(medicamentosAtivos, "SULFAMETOXAZOL_TRIMETOPRIM") or list contains(medicamentosAtivos, "BACTRIM")</text></inputEntry>
        <inputEntry><text>"METOTREXATO" or "MTX"</text></inputEntry>
        <outputEntry><text>"Alerta"</text></outputEntry>
        <outputEntry><text>"Paciente em TMP-SMX. Iniciar MTX CONTRAINDICADO ate suspensao de TMP. Se MTX urgente, aguardar clareamento TMP (3-5 dias) e repor acido folinico."</text></outputEntry>
        <outputEntry><text>"Antagonismo de folato duplo. Alto risco mielotoxicidade."</text></outputEntry>
      </rule>
      <rule id="Rule_Fallback_ddi_major_008_decision">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"OK"</text></outputEntry>
        <outputEntry><text>""</text></outputEntry>
        <outputEntry><text>""</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ddi_major_008_decision">
      <dmndi:DMNShape id="DMNShape_ddi_major_008_decision" dmnElementRef="ddi_major_008_decision">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
