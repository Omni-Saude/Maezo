<?xml version="1.0" encoding="UTF-8"?>
<!-- DDI-MAJOR-009: Carbamazepina + Macrolideos/Azolicos - Toxicidade Neurologica -->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="DDI_MAJOR_009" name="DDI-MAJOR-009: CBZ + CYP3A4 Inibidores" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="ddi_major_009_decision" name="[SP-CO-004 | clinical_safety/ddi] Carbamazepina + Inibidores CYP3A4" camunda:historyTimeToLive="180">
    <decisionTable id="ddi_major_009_table" hitPolicy="FIRST">
      <input id="input_medicamentos_ativos_ddi_major_009_decision"><inputExpression typeRef="string"><text>medicamentosAtivos</text></inputExpression></input>
      <input id="input_medicamento_novo_ddi_major_009_decision"><inputExpression typeRef="string"><text>medicamentoNovo</text></inputExpression></input>
      <output id="output_nivel_alerta_ddi_major_009_decision" name="nivelAlerta" typeRef="string"><outputValues><text>"Alerta","Atencao","Informativo","OK"</text></outputValues></output>
      <output id="output_acao_requerida_ddi_major_009_decision" name="acaoRequerida" typeRef="string" />
      <output id="output_justificativa_ddi_major_009_decision" name="justificativaCientifica" typeRef="string" />

      <rule id="rule_cbz_macrolideo_ddi_major_009_decision">
        <inputEntry><text>list contains(medicamentosAtivos, "CARBAMAZEPINA")</text></inputEntry>
        <inputEntry><text>"ERITROMICINA" or "CLARITROMICINA" or "FLUCONAZOL" or "ITRACONAZOL" or "CETOCONAZOL" or "VORICONAZOL"</text></inputEntry>
        <outputEntry><text>"Alerta"</text></outputEntry>
        <outputEntry><text>"NEUROTOXICIDADE IMINENTE. Inibidores CYP3A4 aumentam carbamazepina 2-4x. Sintomas: diplopia, ataxia, nistagmo, letargia, convulsoes. EVITAR: usar azitromicina (menor interacao) ou fluconazol dose baixa. Se indispensavel, reduzir CBZ 50% e dosar nivel."</text></outputEntry>
        <outputEntry><text>"Carbamazepina tem indice terapeutico estreito. Aumento nivel causa toxicidade previsível. Spina E, CNS Drugs 1996."</text></outputEntry>
      </rule>
      <rule id="rule_cbz_verapamil_ddi_major_009_decision">
        <inputEntry><text>list contains(medicamentosAtivos, "CARBAMAZEPINA")</text></inputEntry>
        <inputEntry><text>"VERAPAMIL" or "DILTIAZEM"</text></inputEntry>
        <outputEntry><text>"Atencao"</text></outputEntry>
        <outputEntry><text>"BCC inibem CYP3A4 - aumento CBZ possivel. Monitorar sinais toxicidade. Dosar nivel carbamazepina em 5-7 dias. CBZ tambem pode reduzir nivel do BCC (indutor)."</text></outputEntry>
        <outputEntry><text>"Interacao bidirecional. CBZ induz CYP3A4, BCC inibem."</text></outputEntry>
      </rule>
      <rule id="Rule_Fallback_ddi_major_009_decision">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"OK"</text></outputEntry>
        <outputEntry><text>""</text></outputEntry>
        <outputEntry><text>""</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ddi_major_009_decision">
      <dmndi:DMNShape id="DMNShape_ddi_major_009_decision" dmnElementRef="ddi_major_009_decision">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
