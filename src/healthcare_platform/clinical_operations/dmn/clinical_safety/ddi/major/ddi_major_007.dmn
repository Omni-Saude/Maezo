<?xml version="1.0" encoding="UTF-8"?>
<!-- DDI-MAJOR-007: Sildenafil + Nitratos - Hipotensao Severa -->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="DDI_MAJOR_007" name="DDI-MAJOR-007: Sildenafil + Nitratos" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="ddi_major_007_decision" name="[SP-CO-004 | clinical_safety/ddi] IPDE5 + Nitratos - Hipotensao Fatal" camunda:historyTimeToLive="180">
    <decisionTable id="ddi_major_007_table" hitPolicy="FIRST">
      <input id="input_medicamentos_ativos_ddi_major_007_decision"><inputExpression typeRef="string"><text>medicamentosAtivos</text></inputExpression></input>
      <input id="input_medicamento_novo_ddi_major_007_decision"><inputExpression typeRef="string"><text>medicamentoNovo</text></inputExpression></input>
      <output id="output_nivel_alerta_ddi_major_007_decision" name="nivelAlerta" typeRef="string"><outputValues><text>"Alerta","Atencao","Informativo","OK"</text></outputValues></output>
      <output id="output_acao_requerida_ddi_major_007_decision" name="acaoRequerida" typeRef="string" />
      <output id="output_justificativa_ddi_major_007_decision" name="justificativaCientifica" typeRef="string" />

      <rule id="rule_ipde5_nitrato_ddi_major_007_decision">
        <inputEntry><text>list contains(medicamentosAtivos, "SILDENAFIL") or list contains(medicamentosAtivos, "TADALAFIL") or list contains(medicamentosAtivos, "VARDENAFIL")</text></inputEntry>
        <inputEntry><text>"ISOSSORBIDA" or "NITROGLICERINA" or "MONONITRATO" or "DINITRATO" or "NITRATO"</text></inputEntry>
        <outputEntry><text>"Alerta"</text></outputEntry>
        <outputEntry><text>"CONTRAINDICACAO ABSOLUTA. IPDE5 + nitrato = hipotensao severa potencialmente fatal. NAO ADMINISTRAR. Se paciente usou sildenafil nas ultimas 24h (ou tadalafil 48h), NAO dar nitrato. Em caso de SCA, usar outras terapias (betabloqueador, morfina)."</text></outputEntry>
        <outputEntry><text>"Contraindicacao bem estabelecida. Ambos causam vasodilatacao via GMPc. Webb DJ et al. J Am Coll Cardiol 1999."</text></outputEntry>
      </rule>
      <rule id="rule_nitrato_ipde5_ddi_major_007_decision">
        <inputEntry><text>list contains(medicamentosAtivos, "ISOSSORBIDA") or list contains(medicamentosAtivos, "NITROGLICERINA") or list contains(medicamentosAtivos, "MONONITRATO")</text></inputEntry>
        <inputEntry><text>"SILDENAFIL" or "TADALAFIL" or "VARDENAFIL"</text></inputEntry>
        <outputEntry><text>"Alerta"</text></outputEntry>
        <outputEntry><text>"CONTRAINDICACAO ABSOLUTA. Paciente em uso de nitrato NAO pode usar IPDE5. Intervalo minimo: 24h apos ultimo nitrato (48h se tadalafil planejado). Orientar paciente sobre risco fatal."</text></outputEntry>
        <outputEntry><text>"ACC/AHA: contraindicado uso concomitante ou em intervalo inadequado."</text></outputEntry>
      </rule>
      <rule id="Rule_Fallback_ddi_major_007_decision">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"OK"</text></outputEntry>
        <outputEntry><text>""</text></outputEntry>
        <outputEntry><text>""</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ddi_major_007_decision">
      <dmndi:DMNShape id="DMNShape_ddi_major_007_decision" dmnElementRef="ddi_major_007_decision">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
