<?xml version="1.0" encoding="UTF-8"?>
<!-- DDI-MAJOR-010: Teofilina + Quinolonas - Convulsoes -->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="DDI_MAJOR_010" name="DDI-MAJOR-010: Teofilina + Quinolonas" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="ddi_major_010_decision" name="[SP-CO-004 | clinical_safety/ddi] Teofilina + Quinolonas - Neurotoxicidade" camunda:historyTimeToLive="180">
    <decisionTable id="ddi_major_010_table" hitPolicy="FIRST">
      <input id="input_medicamentos_ativos_ddi_major_010_decision"><inputExpression typeRef="string"><text>medicamentosAtivos</text></inputExpression></input>
      <input id="input_medicamento_novo_ddi_major_010_decision"><inputExpression typeRef="string"><text>medicamentoNovo</text></inputExpression></input>
      <input id="input_nivel_teofilina_ddi_major_010_decision"><inputExpression typeRef="number"><text>nivelTeofilina</text></inputExpression></input>
      <output id="output_nivel_alerta_ddi_major_010_decision" name="nivelAlerta" typeRef="string"><outputValues><text>"Alerta","Atencao","Informativo","OK"</text></outputValues></output>
      <output id="output_acao_requerida_ddi_major_010_decision" name="acaoRequerida" typeRef="string" />
      <output id="output_justificativa_ddi_major_010_decision" name="justificativaCientifica" typeRef="string" />

      <rule id="rule_teofilina_ciprofloxacino_ddi_major_010_decision">
        <inputEntry><text>list contains(medicamentosAtivos, "TEOFILINA") or list contains(medicamentosAtivos, "AMINOFILINA")</text></inputEntry>
        <inputEntry><text>"CIPROFLOXACINO" or "ENOXACINO" or "NORFLOXACINO"</text></inputEntry>
        <inputEntry><text>&gt; 15</text></inputEntry>
        <outputEntry><text>"Alerta"</text></outputEntry>
        <outputEntry><text>"ALTO RISCO convulsoes. Teofilina >15 + ciprofloxacino = neurotoxicidade. Ciprofloxacino aumenta teofilina 30-80% (inibe CYP1A2). Usar levofloxacino ou moxifloxacino (menor interacao). Se cipro necessario, reduzir teofilina 30-50%."</text></outputEntry>
        <outputEntry><text>"Ciprofloxacino potente inibidor CYP1A2. Nivel toxico teofilina >20. Batty KT, Clin Pharmacokinet 1992."</text></outputEntry>
      </rule>
      <rule id="rule_teofilina_levofloxacino_ddi_major_010_decision">
        <inputEntry><text>list contains(medicamentosAtivos, "TEOFILINA") or list contains(medicamentosAtivos, "AMINOFILINA")</text></inputEntry>
        <inputEntry><text>"LEVOFLOXACINO" or "MOXIFLOXACINO"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"Atencao"</text></outputEntry>
        <outputEntry><text>"Interacao menor que ciprofloxacino, mas quinolonas tem potencial convulsivante proprio. Monitorar nivel teofilina se uso prolongado. Vigiar sinais toxicidade (nausea, tremor, taquicardia)."</text></outputEntry>
        <outputEntry><text>"Levofloxacino/moxifloxacino tem menor efeito em CYP1A2, mas prudencia necessaria."</text></outputEntry>
      </rule>
      <rule id="Rule_Fallback_ddi_major_010_decision">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"OK"</text></outputEntry>
        <outputEntry><text>""</text></outputEntry>
        <outputEntry><text>""</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ddi_major_010_decision">
      <dmndi:DMNShape id="DMNShape_ddi_major_010_decision" dmnElementRef="ddi_major_010_decision">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
