<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="DDI_BLEED_015" name="DDI-BLEED-015: Ticagrelor + Aspirina  &gt; 100mg" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="ddi_bleed_015_decision" name="[SP-CO-004 | clinical_safety/ddi] Ticagrelor + High-Dose Aspirin" camunda:historyTimeToLive="180">
    <decisionTable id="ddi_bleed_015_table" hitPolicy="FIRST">
      <input id="input_medicamentos_ativos_ddi_bleed_015_decision" label="Medicamentos Ativos">
        <inputExpression id="input_expr_medicamentos_ativos_ddi_bleed_015_decision" typeRef="string">
          <text>medicamentosAtivos</text>
        </inputExpression>
      </input>
      <input id="input_medicamento_novo_ddi_bleed_015_decision" label="Medicamento Novo">
        <inputExpression id="input_expr_medicamento_novo_ddi_bleed_015_decision" typeRef="string">
          <text>medicamentoNovo</text>
        </inputExpression>
      </input>
      <input id="input_dose_aspirina_ddi_bleed_015_decision" label="Dose Aspirina (mg)">
        <inputExpression id="input_expr_dose_ddi_bleed_015_decision" typeRef="number">
          <text>doseAspirina</text>
        </inputExpression>
      </input>

      <output id="output_nivel_alerta_ddi_bleed_015_decision" name="nivelAlerta" typeRef="string">
        <outputValues>
          <text>"Alerta","Atencao","Informativo","OK"</text>
        </outputValues>
      </output>
      <output id="output_urgencia_ddi_bleed_015_decision" name="urgencia" typeRef="string">
        <outputValues>
          <text>"IMEDIATA","URGENTE","ROTINA"</text>
        </outputValues>
      </output>
      <output id="output_medicamentos_conflitantes_ddi_bleed_015_decision" name="medicamentosConflitantes" typeRef="string" />
      <output id="output_mecanismo_interacao_ddi_bleed_015_decision" name="mecanismoInteracao" typeRef="string" />
      <output id="output_acao_requerida_ddi_bleed_015_decision" name="acaoRequerida" typeRef="string" />

      <!-- Rule 1: Ticagrelor + Aspirina >100mg -->
      <rule id="rule_ticag_asa_alta_ddi_bleed_015_decision">
        <inputEntry id="input_medicamentos_ticag_ddi_bleed_015_decision">
          <text>list contains(medicamentosAtivos, "TICAGRELOR")</text>
        </inputEntry>
        <inputEntry id="input_novo_asa_ddi_bleed_015_decision">
          <text>"ASPIRINA" or "AAS" or "ACIDO ACETILSALICILICO"</text>
        </inputEntry>
        <inputEntry id="input_dose_alta_ddi_bleed_015_decision">
          <text>&gt; 100</text>
        </inputEntry>
        <outputEntry id="output_alerta_alta_ddi_bleed_015_decision">
          <text>"Atencao"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_alta_ddi_bleed_015_decision">
          <text>"ROTINA"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_alta_ddi_bleed_015_decision">
          <text>"Ticagrelor + Aspirina &gt;100mg"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_alta_ddi_bleed_015_decision">
          <text>"DOSE SUBÓTIMA: PLATO trial demonstrou ticagrelor + aspirina 75-100mg SUPERIOR a doses maiores (>300mg). Aspirina alta dose (>100mg) AUMENTA sangramento SEM benefício isquêmico adicional. Mecanismo: aspirina >100mg não aumenta inibição COX-1 plaquetária mas aumenta efeitos sistêmicos pró-hemorrágicos (lesão mucosa GI, inibição COX-2 renal)."</text>
        </outputEntry>
        <outputEntry id="output_acao_alta_ddi_bleed_015_decision">
          <text>"REDUZIR aspirina para 75-100mg/dia: (1) Dose ideal: 81-100mg/dia (eficácia MÁXIMA, menos sangramento), (2) NUNCA >100mg com ticagrelor (sem benefício, mais sangramento), (3) IBP se fatores risco GI (idade >65, úlcera prévia): omeprazol 20mg/dia, (4) Monitorar sinais sangramento (melena, hematomas). Nota: ticagrelor já MUITO potente (inibição P2Y12 90%), aspirina baixa dose suficiente."</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: Ticagrelor + Aspirina dose adequada (≤100mg) -->
      <rule id="rule_ticag_asa_ok_ddi_bleed_015_decision">
        <inputEntry id="input_medicamentos_ticag_ok_ddi_bleed_015_decision">
          <text>list contains(medicamentosAtivos, "TICAGRELOR")</text>
        </inputEntry>
        <inputEntry id="input_novo_asa_ok_ddi_bleed_015_decision">
          <text>"ASPIRINA" or "AAS" or "ACIDO ACETILSALICILICO"</text>
        </inputEntry>
        <inputEntry id="input_dose_ok_ddi_bleed_015_decision">
          <text>&lt;= 100</text>
        </inputEntry>
        <outputEntry id="output_alerta_ok_ddi_bleed_015_decision">
          <text>"Informativo"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_ok_ddi_bleed_015_decision">
          <text>"ROTINA"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_ok_ddi_bleed_015_decision">
          <text>"Ticagrelor + Aspirina dose adequada"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_ok_ddi_bleed_015_decision">
          <text>"DOSE ADEQUADA: Ticagrelor 90mg 12/12h + aspirina 75-100mg/dia = esquema PLATO (redução mortalidade CV 16% vs clopidogrel). Risco sangramento MAIOR aumentado (~12% vs 11.2% clopidogrel) mas aceitável dado benefício."</text>
        </outputEntry>
        <outputEntry id="output_acao_ok_ddi_bleed_015_decision">
          <text>"MANTER esquema atual: (1) Ticagrelor 90mg 12/12h + aspirina 75-100mg/dia, (2) IBP se fatores risco GI (omeprazol 20mg/dia - sem interação ticagrelor), (3) Monitorar efeitos colaterais ticagrelor: dispneia (10-15% - geralmente autolimitada, raramente requer suspensão), bradicardia (pausas >3s em 5-10%), (4) Duração: 12 meses pós-SCA (PLATO protocolo), (5) Advertir paciente: ticagrelor REVERSÍVEL (suspender 5 dias antes cirurgia eletiva)."</text>
        </outputEntry>
      </rule>

      <!-- Fallback Rule -->
      <rule id="rule_fallback_ddi_bleed_015_decision">
        <inputEntry id="input_fallback_1_ddi_bleed_015_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_fallback_2_ddi_bleed_015_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_fallback_3_ddi_bleed_015_decision">
          <text>-</text>
        </inputEntry>
        <outputEntry id="output_fallback_1_ddi_bleed_015_decision">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="output_fallback_2_ddi_bleed_015_decision">
          <text>"ROTINA"</text>
        </outputEntry>
        <outputEntry id="output_fallback_3_ddi_bleed_015_decision">
          <text>""</text>
        </outputEntry>
        <outputEntry id="output_fallback_4_ddi_bleed_015_decision">
          <text>""</text>
        </outputEntry>
        <outputEntry id="output_fallback_5_ddi_bleed_015_decision">
          <text>""</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ddi_bleed_015_decision">
      <dmndi:DMNShape id="DMNShape_ddi_bleed_015_decision" dmnElementRef="ddi_bleed_015_decision">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
