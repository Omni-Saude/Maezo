<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="DDI_QT_017" name="DDI-QT-017: Domperidona + Antiarrítmicos" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="ddi_qt_017_decision" name="[SP-CO-004 | clinical_safety/ddi] Domperidona + Antiarrítmicos QT Prolongation" camunda:historyTimeToLive="180">
    <decisionTable id="ddi_qt_017_table" hitPolicy="FIRST">
      <input id="input_medicamentos_ativos_ddi_qt_017_decision" label="Medicamentos Ativos">
        <inputExpression id="input_expr_medicamentos_ativos_ddi_qt_017_decision" typeRef="string">
          <text>medicamentosAtivos</text>
        </inputExpression>
      </input>
      <input id="input_medicamento_novo_ddi_qt_017_decision" label="Medicamento Novo">
        <inputExpression id="input_expr_medicamento_novo_ddi_qt_017_decision" typeRef="string">
          <text>medicamentoNovo</text>
        </inputExpression>
      </input>
      <input id="input_dose_domperidona_ddi_qt_017_decision" label="Dose Domperidona (mg/dia)">
        <inputExpression id="input_expr_dose_ddi_qt_017_decision" typeRef="number">
          <text>doseDomperidona</text>
        </inputExpression>
      </input>
      <input id="input_idade_ddi_qt_017_decision" label="Idade (anos)">
        <inputExpression id="input_expr_idade_ddi_qt_017_decision" typeRef="number">
          <text>idade</text>
        </inputExpression>
      </input>

      <output id="output_nivel_alerta_ddi_qt_017_decision" name="nivelAlerta" typeRef="string">
        <outputValues>
          <text>"Alerta","Atencao","OK"</text>
        </outputValues>
      </output>
      <output id="output_urgencia_ddi_qt_017_decision" name="urgencia" typeRef="string">
        <outputValues>
          <text>"IMEDIATA","URGENTE","ROTINA"</text>
        </outputValues>
      </output>
      <output id="output_medicamentos_conflitantes_ddi_qt_017_decision" name="medicamentosConflitantes" typeRef="string" />
      <output id="output_mecanismo_interacao_ddi_qt_017_decision" name="mecanismoInteracao" typeRef="string" />
      <output id="output_acao_requerida_ddi_qt_017_decision" name="acaoRequerida" typeRef="string" />

      <!-- Rule 1: CONTRAINDICATED - Domperidone + Class III antiarrhythmics -->
      <rule id="rule_domperidona_classe_iii_ddi_qt_017_decision">
        <inputEntry id="input_medicamentos_dompe_ddi_qt_017_decision">
          <text>list contains(medicamentosAtivos, "DOMPERIDONA")</text>
        </inputEntry>
        <inputEntry id="input_novo_antiarr_classe3_ddi_qt_017_decision">
          <text>"AMIODARONA" or "SOTALOL" or "DOFETILIDA" or "IBUTILIDA"</text>
        </inputEntry>
        <inputEntry id="input_dose_qualquer_ddi_qt_017_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_idade_qualquer_ddi_qt_017_decision">
          <text>-</text>
        </inputEntry>
        <outputEntry id="output_alerta_contraindicado_ddi_qt_017_decision">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_contraindicado_ddi_qt_017_decision">
          <text>"IMEDIATA"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_contraindicado_ddi_qt_017_decision">
          <text>"Domperidona + Antiarrítmico Classe III (CONTRAINDICADO)"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_contraindicado_ddi_qt_017_decision">
          <text>"CONTRAINDICAÇÃO ABSOLUTA. Domperidona QT +10-20ms + Antiarrítmicos classe III (amiodarona +40-60ms, sotalol +20-40ms). EMA RESTRINGIU domperidona (2014) por Torsades. Risco morte súbita INACEITÁVEL."</text>
        </outputEntry>
        <outputEntry id="output_acao_contraindicado_ddi_qt_017_decision">
          <text>"BLOQUEAR prescrição: (1) NÃO usar domperidona com antiarrítmicos classe III, (2) Antiemético alternativo: metoclopramida 10mg 8/8h, bromoprida 10mg 8/8h, ondansetron 4-8mg (cautela QT menor), (3) Procinético alternativo: metoclopramida, cisaprida (retirada maioria países), (4) Se AMBOS essenciais: internação, ECG diário, monitorização cardíaca."</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: Domperidone + Class I antiarrhythmics (moderate risk) -->
      <rule id="rule_domperidona_classe_i_ddi_qt_017_decision">
        <inputEntry id="input_medicamentos_dompe2_ddi_qt_017_decision">
          <text>list contains(medicamentosAtivos, "DOMPERIDONA")</text>
        </inputEntry>
        <inputEntry id="input_novo_antiarr_classe1_ddi_qt_017_decision">
          <text>"QUINIDINA" or "PROCAINAMIDA" or "DISOPIRAMIDA" or "FLECAINIDA" or "PROPAFENONA"</text>
        </inputEntry>
        <inputEntry id="input_dose_qualquer2_ddi_qt_017_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_idade_qualquer2_ddi_qt_017_decision">
          <text>-</text>
        </inputEntry>
        <outputEntry id="output_alerta_classe1_ddi_qt_017_decision">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_classe1_ddi_qt_017_decision">
          <text>"URGENTE"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_classe1_ddi_qt_017_decision">
          <text>"Domperidona + Antiarrítmico Classe I"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_classe1_ddi_qt_017_decision">
          <text>"QT aditivo moderado. Quinidina +20-30ms (MAIOR classe I), Disopiramida +10-20ms. Flecainida/Propafenona QT mínimo mas risco arritmia. Domperidona +10-20ms."</text>
        </outputEntry>
        <outputEntry id="output_acao_classe1_ddi_qt_017_decision">
          <text>"EVITAR associação: (1) Preferir metoclopramida, bromoprida antiemético (SEM QT), (2) Se ESSENCIAL: ECG baseline + 48h + 7 dias, K+&gt;4.5, Mg&gt;2.0, dose domperidona MAX 10mg 8/8h (30mg/dia), (3) Suspender domperidona se QTc&gt;500ms."</text>
        </outputEntry>
      </rule>

      <!-- Rule 3: High dose domperidone (>30mg/day) + any cardiac condition -->
      <rule id="rule_domperidona_alta_dose_ddi_qt_017_decision">
        <inputEntry id="input_medicamentos_dompe3_ddi_qt_017_decision">
          <text>list contains(medicamentosAtivos, "DOMPERIDONA")</text>
        </inputEntry>
        <inputEntry id="input_novo_qualquer_ddi_qt_017_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_dose_alta_ddi_qt_017_decision">
          <text>&gt; 30</text>
        </inputEntry>
        <inputEntry id="input_idade_qualquer3_ddi_qt_017_decision">
          <text>-</text>
        </inputEntry>
        <outputEntry id="output_alerta_alta_dose_ddi_qt_017_decision">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_alta_dose_ddi_qt_017_decision">
          <text>"URGENTE"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_alta_dose_ddi_qt_017_decision">
          <text>"Domperidona &gt;30mg/dia (EXCEDE limite EMA)"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_alta_dose_ddi_qt_017_decision">
          <text>"EMA LIMITOU domperidona MAX 30mg/dia (2014) por risco Torsades dose-dependente. Doses &gt;30mg aumentam risco 3-5x."</text>
        </outputEntry>
        <outputEntry id="output_acao_alta_dose_ddi_qt_017_decision">
          <text>"REDUZIR dose domperidona: MAX 10mg 8/8h (30mg/dia - LIMITE EMA). Duração MAX 7 dias (EMA). ECG se uso prolongado. Considerar trocar por metoclopramida ou bromoprida (SEM limite dose QT)."</text>
        </outputEntry>
      </rule>

      <!-- Rule 4: Domperidone age >60 -->
      <rule id="rule_domperidona_idoso_ddi_qt_017_decision">
        <inputEntry id="input_medicamentos_dompe4_ddi_qt_017_decision">
          <text>list contains(medicamentosAtivos, "DOMPERIDONA")</text>
        </inputEntry>
        <inputEntry id="input_novo_qualquer2_ddi_qt_017_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_dose_qualquer3_ddi_qt_017_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_idade_idoso_ddi_qt_017_decision">
          <text>&gt; 60</text>
        </inputEntry>
        <outputEntry id="output_alerta_idoso_ddi_qt_017_decision">
          <text>"Atencao"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_idoso_ddi_qt_017_decision">
          <text>"URGENTE"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_idoso_ddi_qt_017_decision">
          <text>"Domperidona idade &gt;60 anos"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_idoso_ddi_qt_017_decision">
          <text>"EMA recomenda EVITAR domperidona &gt;60 anos (metabolismo reduzido, QT basal mais longo, maior risco cardíaco)."</text>
        </outputEntry>
        <outputEntry id="output_acao_idoso_ddi_qt_017_decision">
          <text>"CONSIDERAR alternativa: Metoclopramida 10mg 8/8h (preferida &gt;60 anos), Bromoprida 10mg 8/8h. Se domperidona ESSENCIAL: dose MAX 10mg 8/8h, duração MAX 7 dias, ECG baseline, K+/Mg normais."</text>
        </outputEntry>
      </rule>

      <!-- Fallback Rule -->
      <rule id="rule_fallback_ddi_qt_017_decision">
        <inputEntry id="input_fallback_1_ddi_qt_017_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_fallback_2_ddi_qt_017_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_fallback_3_ddi_qt_017_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_fallback_4_ddi_qt_017_decision">
          <text>-</text>
        </inputEntry>
        <outputEntry id="output_fallback_1_ddi_qt_017_decision">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="output_fallback_2_ddi_qt_017_decision">
          <text>"ROTINA"</text>
        </outputEntry>
        <outputEntry id="output_fallback_3_ddi_qt_017_decision">
          <text>""</text>
        </outputEntry>
        <outputEntry id="output_fallback_4_ddi_qt_017_decision">
          <text>""</text>
        </outputEntry>
        <outputEntry id="output_fallback_5_ddi_qt_017_decision">
          <text>""</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ddi_qt_017_decision">
      <dmndi:DMNShape id="DMNShape_ddi_qt_017_decision" dmnElementRef="ddi_qt_017_decision">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
