<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="DDI_QT_014" name="DDI-QT-014: Metadona + Azólicos" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="ddi_qt_014_decision" name="[SP-CO-004 | clinical_safety/ddi] Metadona + Azólicos QT Prolongation + CYP3A4" camunda:historyTimeToLive="180">
    <decisionTable id="ddi_qt_014_table" hitPolicy="FIRST">
      <input id="input_medicamentos_ativos_ddi_qt_014_decision" label="Medicamentos Ativos">
        <inputExpression id="input_expr_medicamentos_ativos_ddi_qt_014_decision" typeRef="string">
          <text>medicamentosAtivos</text>
        </inputExpression>
      </input>
      <input id="input_medicamento_novo_ddi_qt_014_decision" label="Medicamento Novo">
        <inputExpression id="input_expr_medicamento_novo_ddi_qt_014_decision" typeRef="string">
          <text>medicamentoNovo</text>
        </inputExpression>
      </input>
      <input id="input_dose_metadona_ddi_qt_014_decision" label="Dose Metadona (mg/dia)">
        <inputExpression id="input_expr_dose_ddi_qt_014_decision" typeRef="number">
          <text>doseMetadona</text>
        </inputExpression>
      </input>
      <input id="input_duracao_azol_ddi_qt_014_decision" label="Duração Azólico (dias)">
        <inputExpression id="input_expr_duracao_ddi_qt_014_decision" typeRef="number">
          <text>duracaoAzolico</text>
        </inputExpression>
      </input>

      <output id="output_nivel_alerta_ddi_qt_014_decision" name="nivelAlerta" typeRef="string">
        <outputValues>
          <text>"Alerta","Atencao","OK"</text>
        </outputValues>
      </output>
      <output id="output_urgencia_ddi_qt_014_decision" name="urgencia" typeRef="string">
        <outputValues>
          <text>"IMEDIATA","URGENTE","ROTINA"</text>
        </outputValues>
      </output>
      <output id="output_medicamentos_conflitantes_ddi_qt_014_decision" name="medicamentosConflitantes" typeRef="string" />
      <output id="output_mecanismo_interacao_ddi_qt_014_decision" name="mecanismoInteracao" typeRef="string" />
      <output id="output_acao_requerida_ddi_qt_014_decision" name="acaoRequerida" typeRef="string" />

      <!-- Rule 1: High dose methadone + systemic azole (MAJOR interaction) -->
      <rule id="rule_metadona_alta_azol_sistemico_ddi_qt_014_decision">
        <inputEntry id="input_medicamentos_metadona_ddi_qt_014_decision">
          <text>list contains(medicamentosAtivos, "METADONA")</text>
        </inputEntry>
        <inputEntry id="input_novo_azol_sistemico_ddi_qt_014_decision">
          <text>"FLUCONAZOL" or "ITRACONAZOL" or "VORICONAZOL" or "POSACONAZOL"</text>
        </inputEntry>
        <inputEntry id="input_dose_alta_ddi_qt_014_decision">
          <text>&gt; 100</text>
        </inputEntry>
        <inputEntry id="input_duracao_qualquer_ddi_qt_014_decision">
          <text>-</text>
        </inputEntry>
        <outputEntry id="output_alerta_alta_sistemico_ddi_qt_014_decision">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_alta_sistemico_ddi_qt_014_decision">
          <text>"URGENTE"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_alta_sistemico_ddi_qt_014_decision">
          <text>"Metadona &gt;100mg/dia + Azólico Sistêmico"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_alta_sistemico_ddi_qt_014_decision">
          <text>"DUPLO MECANISMO: (1) QT aditivo - Metadona QT +20-40ms DOSE-DEPENDENTE (&gt;100mg maior risco) + Fluconazol +5-10ms, (2) CYP3A4 - Azólicos inibem metabolismo metadona → níveis DOBRAM → QT adicional +20-30ms. Risco Torsades ALTO."</text>
        </outputEntry>
        <outputEntry id="output_acao_alta_sistemico_ddi_qt_014_decision">
          <text>"MAJOR: (1) REDUZIR metadona 30-50% ao iniciar azólico, (2) ECG baseline + 48h + 7 dias obrigatório, (3) K+&gt;4.5, Mg&gt;2.0, (4) Monitorar sedação excessiva (toxicidade opioid), (5) Considerar antifúngico alternativo: terbinafina (dor ungueal), anfotericina (infecção grave), (6) Suspender azólico se QTc&gt;500ms."</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: Standard dose methadone + systemic azole -->
      <rule id="rule_metadona_padrao_azol_sistemico_ddi_qt_014_decision">
        <inputEntry id="input_medicamentos_metadona2_ddi_qt_014_decision">
          <text>list contains(medicamentosAtivos, "METADONA")</text>
        </inputEntry>
        <inputEntry id="input_novo_azol_sistemico2_ddi_qt_014_decision">
          <text>"FLUCONAZOL" or "ITRACONAZOL" or "VORICONAZOL" or "POSACONAZOL"</text>
        </inputEntry>
        <inputEntry id="input_dose_padrao_ddi_qt_014_decision">
          <text>&gt;= 30, &lt;= 100</text>
        </inputEntry>
        <inputEntry id="input_duracao_qualquer2_ddi_qt_014_decision">
          <text>-</text>
        </inputEntry>
        <outputEntry id="output_alerta_padrao_sistemico_ddi_qt_014_decision">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_padrao_sistemico_ddi_qt_014_decision">
          <text>"URGENTE"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_padrao_sistemico_ddi_qt_014_decision">
          <text>"Metadona 30-100mg/dia + Azólico Sistêmico"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_padrao_sistemico_ddi_qt_014_decision">
          <text>"Inibição CYP3A4 → níveis metadona aumentam 50-100%. QT aditivo moderado. Risco Torsades + sedação excessiva."</text>
        </outputEntry>
        <outputEntry id="output_acao_padrao_sistemico_ddi_qt_014_decision">
          <text>"REDUZIR metadona 20-30% profilático ao iniciar azólico, ECG baseline + 7 dias, K+/Mg normais, Monitorar sedação (náusea, sonolência = toxicidade), Considerar fluconazol dose única 150mg (menor interação que doses prolongadas), Naloxona disponível se sedação severa."</text>
        </outputEntry>
      </rule>

      <!-- Rule 3: Methadone + prolonged azole therapy (>7 days) -->
      <rule id="rule_metadona_azol_prolongado_ddi_qt_014_decision">
        <inputEntry id="input_medicamentos_metadona3_ddi_qt_014_decision">
          <text>list contains(medicamentosAtivos, "METADONA")</text>
        </inputEntry>
        <inputEntry id="input_novo_azol_sistemico3_ddi_qt_014_decision">
          <text>"FLUCONAZOL" or "ITRACONAZOL" or "VORICONAZOL"</text>
        </inputEntry>
        <inputEntry id="input_dose_qualquer_ddi_qt_014_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_duracao_longa_ddi_qt_014_decision">
          <text>&gt; 7</text>
        </inputEntry>
        <outputEntry id="output_alerta_prolongado_ddi_qt_014_decision">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_prolongado_ddi_qt_014_decision">
          <text>"URGENTE"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_prolongado_ddi_qt_014_decision">
          <text>"Metadona + Azólico &gt;7 dias"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_prolongado_ddi_qt_014_decision">
          <text>"Terapia prolongada azólico → acúmulo metadona gradual (meia-vida 24-36h) → níveis DOBRAM após 5-7 dias. QT piora progressivamente."</text>
        </outputEntry>
        <outputEntry id="output_acao_prolongado_ddi_qt_014_decision">
          <text>"MONITORAMENTO RIGOROSO: (1) ECG semanal durante terapia azólico, (2) Reduzir metadona 30-50%, (3) Avaliar necessidade terapia prolongada azólico (considerar anfotericina alternativa), (4) Sintomas toxicidade: miose, sonolência, náusea = reduzir metadona adicional, (5) QTc &gt;500ms: suspender azólico."</text>
        </outputEntry>
      </rule>

      <!-- Rule 4: Methadone + topical/low-dose azole -->
      <rule id="rule_metadona_azol_topico_ddi_qt_014_decision">
        <inputEntry id="input_medicamentos_metadona4_ddi_qt_014_decision">
          <text>list contains(medicamentosAtivos, "METADONA")</text>
        </inputEntry>
        <inputEntry id="input_novo_azol_topico_ddi_qt_014_decision">
          <text>"CLOTRIMAZOL_TOPICO" or "MICONAZOL_TOPICO" or "FLUCONAZOL" and duracaoAzolico &lt;= 3</text>
        </inputEntry>
        <inputEntry id="input_dose_qualquer2_ddi_qt_014_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_duracao_curta_ddi_qt_014_decision">
          <text>&lt;= 3</text>
        </inputEntry>
        <outputEntry id="output_alerta_topico_ddi_qt_014_decision">
          <text>"Atencao"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_topico_ddi_qt_014_decision">
          <text>"URGENTE"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_topico_ddi_qt_014_decision">
          <text>"Metadona + Azólico Tópico/Dose Única"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_topico_ddi_qt_014_decision">
          <text>"Azólicos tópicos absorção mínima sistêmica. Fluconazol dose única 150mg inibição CYP3A4 transitória (48-72h)."</text>
        </outputEntry>
        <outputEntry id="output_acao_topico_ddi_qt_014_decision">
          <text>"BAIXO RISCO: (1) Azólico tópico (creme, óvulo) absorção mínima - OK usar, (2) Fluconazol 150mg dose única - ECG opcional, monitorar sintomas 48-72h, (3) K+/Mg normais, (4) Não reduzir dose metadona profilaticamente."</text>
        </outputEntry>
      </rule>

      <!-- Fallback Rule -->
      <rule id="rule_fallback_ddi_qt_014_decision">
        <inputEntry id="input_fallback_1_ddi_qt_014_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_fallback_2_ddi_qt_014_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_fallback_3_ddi_qt_014_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_fallback_4_ddi_qt_014_decision">
          <text>-</text>
        </inputEntry>
        <outputEntry id="output_fallback_1_ddi_qt_014_decision">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="output_fallback_2_ddi_qt_014_decision">
          <text>"ROTINA"</text>
        </outputEntry>
        <outputEntry id="output_fallback_3_ddi_qt_014_decision">
          <text>""</text>
        </outputEntry>
        <outputEntry id="output_fallback_4_ddi_qt_014_decision">
          <text>""</text>
        </outputEntry>
        <outputEntry id="output_fallback_5_ddi_qt_014_decision">
          <text>""</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ddi_qt_014_decision">
      <dmndi:DMNShape id="DMNShape_ddi_qt_014_decision" dmnElementRef="ddi_qt_014_decision">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
