<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="DDI_QT_010" name="DDI-QT-010: Amiodarona + Haloperidol" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="ddi_qt_010_decision" name="[SP-CO-004 | clinical_safety/ddi] Amiodarona + Haloperidol QT Prolongation" camunda:historyTimeToLive="180">
    <decisionTable id="ddi_qt_010_table" hitPolicy="FIRST">
      <input id="input_medicamentos_ativos_ddi_qt_010_decision" label="Medicamentos Ativos">
        <inputExpression id="input_expr_medicamentos_ativos_ddi_qt_010_decision" typeRef="string">
          <text>medicamentosAtivos</text>
        </inputExpression>
      </input>
      <input id="input_medicamento_novo_ddi_qt_010_decision" label="Medicamento Novo">
        <inputExpression id="input_expr_medicamento_novo_ddi_qt_010_decision" typeRef="string">
          <text>medicamentoNovo</text>
        </inputExpression>
      </input>
      <input id="input_potassio_ddi_qt_010_decision" label="Potássio (mmol/L)">
        <inputExpression id="input_expr_potassio_ddi_qt_010_decision" typeRef="number">
          <text>potassio</text>
        </inputExpression>
      </input>
      <input id="input_historico_qt_ddi_qt_010_decision" label="Histórico QT Longo">
        <inputExpression id="input_expr_historico_ddi_qt_010_decision" typeRef="boolean">
          <text>historicoQTLongo</text>
        </inputExpression>
      </input>

      <output id="output_nivel_alerta_ddi_qt_010_decision" name="nivelAlerta" typeRef="string">
        <outputValues>
          <text>"Alerta","Atencao","OK"</text>
        </outputValues>
      </output>
      <output id="output_urgencia_ddi_qt_010_decision" name="urgencia" typeRef="string">
        <outputValues>
          <text>"IMEDIATA","URGENTE","ROTINA"</text>
        </outputValues>
      </output>
      <output id="output_medicamentos_conflitantes_ddi_qt_010_decision" name="medicamentosConflitantes" typeRef="string" />
      <output id="output_mecanismo_interacao_ddi_qt_010_decision" name="mecanismoInteracao" typeRef="string" />
      <output id="output_acao_requerida_ddi_qt_010_decision" name="acaoRequerida" typeRef="string" />

      <!-- Rule 1: CONTRAINDICATED - Both drugs together -->
      <rule id="rule_amio_halo_contraindicado_ddi_qt_010_decision">
        <inputEntry id="input_medicamentos_amio_ddi_qt_010_decision">
          <text>list contains(medicamentosAtivos, "AMIODARONA")</text>
        </inputEntry>
        <inputEntry id="input_novo_halo_ddi_qt_010_decision">
          <text>"HALOPERIDOL"</text>
        </inputEntry>
        <inputEntry id="input_k_qualquer_ddi_qt_010_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_qt_qualquer_ddi_qt_010_decision">
          <text>-</text>
        </inputEntry>
        <outputEntry id="output_alerta_contraindicado_ddi_qt_010_decision">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_contraindicado_ddi_qt_010_decision">
          <text>"IMEDIATA"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_contraindicado_ddi_qt_010_decision">
          <text>"Amiodarona + Haloperidol (CONTRAINDICADO)"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_contraindicado_ddi_qt_010_decision">
          <text>"Bloqueio aditivo severo canais K+ (IKr/hERG). Amiodarona prolonga QTc 40-60ms + Haloperidol 20-35ms (dose IV &gt;2mg). Risco Torsades de pointes CRITICO, morte súbita documentada."</text>
        </outputEntry>
        <outputEntry id="output_acao_contraindicado_ddi_qt_010_decision">
          <text>"CONTRAINDICAÇÃO ABSOLUTA: (1) NÃO iniciar haloperidol se amiodarona ativa, (2) Alternativas: olanzapina, quetiapina (menor QT), risperidona baixa dose, (3) Se ESSENCIAL: descontinuar amiodarona 30+ dias antes (meia-vida longa), ECG diário, K+&gt;4.5, Mg&gt;2.0, monitorização cardíaca contínua."</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: Haloperidol já ativo, tentativa adicionar amiodarona -->
      <rule id="rule_halo_amio_reverso_ddi_qt_010_decision">
        <inputEntry id="input_medicamentos_halo_ddi_qt_010_decision">
          <text>list contains(medicamentosAtivos, "HALOPERIDOL")</text>
        </inputEntry>
        <inputEntry id="input_novo_amio_ddi_qt_010_decision">
          <text>"AMIODARONA"</text>
        </inputEntry>
        <inputEntry id="input_k_qualquer2_ddi_qt_010_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_qt_qualquer2_ddi_qt_010_decision">
          <text>-</text>
        </inputEntry>
        <outputEntry id="output_alerta_reverso_ddi_qt_010_decision">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_reverso_ddi_qt_010_decision">
          <text>"IMEDIATA"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_reverso_ddi_qt_010_decision">
          <text>"Haloperidol + Amiodarona (CONTRAINDICADO)"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_reverso_ddi_qt_010_decision">
          <text>"Associação contraindicada independente da ordem. Risco morte súbita documentado em literatura (FDA black box warning haloperidol IV)."</text>
        </outputEntry>
        <outputEntry id="output_acao_reverso_ddi_qt_010_decision">
          <text>"BLOQUEAR prescrição: (1) Descontinuar haloperidol antes amiodarona, (2) Antiarrítmico alternativo: sotalol evitar (também QT), considerar flecainida/propafenona (sem QT) se apropriado, (3) Antipsicótico alternativo: olanzapina, quetiapina."</text>
        </outputEntry>
      </rule>

      <!-- Fallback Rule -->
      <rule id="rule_fallback_ddi_qt_010_decision">
        <inputEntry id="input_fallback_1_ddi_qt_010_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_fallback_2_ddi_qt_010_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_fallback_3_ddi_qt_010_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_fallback_4_ddi_qt_010_decision">
          <text>-</text>
        </inputEntry>
        <outputEntry id="output_fallback_1_ddi_qt_010_decision">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="output_fallback_2_ddi_qt_010_decision">
          <text>"ROTINA"</text>
        </outputEntry>
        <outputEntry id="output_fallback_3_ddi_qt_010_decision">
          <text>""</text>
        </outputEntry>
        <outputEntry id="output_fallback_4_ddi_qt_010_decision">
          <text>""</text>
        </outputEntry>
        <outputEntry id="output_fallback_5_ddi_qt_010_decision">
          <text>""</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ddi_qt_010_decision">
      <dmndi:DMNShape id="DMNShape_ddi_qt_010_decision" dmnElementRef="ddi_qt_010_decision">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
