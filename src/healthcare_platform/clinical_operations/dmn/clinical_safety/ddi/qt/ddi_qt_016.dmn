<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="DDI_QT_016" name="DDI-QT-016: Escitalopram + Claritromicina" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="ddi_qt_016_decision" name="[SP-CO-004 | clinical_safety/ddi] Escitalopram + Claritromicina QT Prolongation" camunda:historyTimeToLive="180">
    <decisionTable id="ddi_qt_016_table" hitPolicy="FIRST">
      <input id="input_medicamentos_ativos_ddi_qt_016_decision" label="Medicamentos Ativos">
        <inputExpression id="input_expr_medicamentos_ativos_ddi_qt_016_decision" typeRef="string">
          <text>medicamentosAtivos</text>
        </inputExpression>
      </input>
      <input id="input_medicamento_novo_ddi_qt_016_decision" label="Medicamento Novo">
        <inputExpression id="input_expr_medicamento_novo_ddi_qt_016_decision" typeRef="string">
          <text>medicamentoNovo</text>
        </inputExpression>
      </input>
      <input id="input_dose_escitalopram_ddi_qt_016_decision" label="Dose Escitalopram (mg/dia)">
        <inputExpression id="input_expr_dose_ddi_qt_016_decision" typeRef="number">
          <text>doseEscitalopram</text>
        </inputExpression>
      </input>
      <input id="input_idade_ddi_qt_016_decision" label="Idade (anos)">
        <inputExpression id="input_expr_idade_ddi_qt_016_decision" typeRef="number">
          <text>idade</text>
        </inputExpression>
      </input>

      <output id="output_nivel_alerta_ddi_qt_016_decision" name="nivelAlerta" typeRef="string">
        <outputValues>
          <text>"Alerta","Atencao","OK"</text>
        </outputValues>
      </output>
      <output id="output_urgencia_ddi_qt_016_decision" name="urgencia" typeRef="string">
        <outputValues>
          <text>"IMEDIATA","URGENTE","ROTINA"</text>
        </outputValues>
      </output>
      <output id="output_medicamentos_conflitantes_ddi_qt_016_decision" name="medicamentosConflitantes" typeRef="string" />
      <output id="output_mecanismo_interacao_ddi_qt_016_decision" name="mecanismoInteracao" typeRef="string" />
      <output id="output_acao_requerida_ddi_qt_016_decision" name="acaoRequerida" typeRef="string" />

      <!-- Rule 1: High dose escitalopram (>10mg) + clarithromycin, age >65 -->
      <rule id="rule_escit_alta_claritro_idoso_ddi_qt_016_decision">
        <inputEntry id="input_medicamentos_escit_ddi_qt_016_decision">
          <text>list contains(medicamentosAtivos, "ESCITALOPRAM")</text>
        </inputEntry>
        <inputEntry id="input_novo_claritro_ddi_qt_016_decision">
          <text>"CLARITROMICINA"</text>
        </inputEntry>
        <inputEntry id="input_dose_alta_ddi_qt_016_decision">
          <text>&gt; 10</text>
        </inputEntry>
        <inputEntry id="input_idade_idoso_ddi_qt_016_decision">
          <text>&gt; 65</text>
        </inputEntry>
        <outputEntry id="output_alerta_alta_idoso_ddi_qt_016_decision">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_alta_idoso_ddi_qt_016_decision">
          <text>"URGENTE"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_alta_idoso_ddi_qt_016_decision">
          <text>"Escitalopram &gt;10mg + Claritromicina (idade &gt;65)"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_alta_idoso_ddi_qt_016_decision">
          <text>"QT aditivo CRÍTICO idade &gt;65. Escitalopram 20mg +10ms, Claritromicina +15-20ms (MAIOR QT entre macrolídeos). FDA recomenda MAX 10mg/dia escitalopram &gt;65 anos."</text>
        </outputEntry>
        <outputEntry id="output_acao_alta_idoso_ddi_qt_016_decision">
          <text>"REDUZIR escitalopram MAX 10mg/dia (recomendação FDA &gt;65 anos). ECG baseline + 48h obrigatório. Alternativa antibiótico: azitromicina 5 dias, doxiciclina, amoxicilina-clavulanato. K+&gt;4.0, Mg&gt;2.0. Suspender claritromicina se QTc&gt;500ms."</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: Standard dose escitalopram (≤10mg) + clarithromycin, age >65 -->
      <rule id="rule_escit_padrao_claritro_idoso_ddi_qt_016_decision">
        <inputEntry id="input_medicamentos_escit2_ddi_qt_016_decision">
          <text>list contains(medicamentosAtivos, "ESCITALOPRAM")</text>
        </inputEntry>
        <inputEntry id="input_novo_claritro2_ddi_qt_016_decision">
          <text>"CLARITROMICINA"</text>
        </inputEntry>
        <inputEntry id="input_dose_padrao_ddi_qt_016_decision">
          <text>&lt;= 10</text>
        </inputEntry>
        <inputEntry id="input_idade_idoso2_ddi_qt_016_decision">
          <text>&gt; 65</text>
        </inputEntry>
        <outputEntry id="output_alerta_padrao_idoso_ddi_qt_016_decision">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_padrao_idoso_ddi_qt_016_decision">
          <text>"URGENTE"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_padrao_idoso_ddi_qt_016_decision">
          <text>"Escitalopram ≤10mg + Claritromicina (idade &gt;65)"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_padrao_idoso_ddi_qt_016_decision">
          <text>"QT aditivo moderado. Claritromicina MAIOR QT entre macrolídeos (+15-20ms). Risco aumentado idade &gt;65."</text>
        </outputEntry>
        <outputEntry id="output_acao_padrao_idoso_ddi_qt_016_decision">
          <text>"ECG baseline obrigatório. Curso claritromicina CURTO (5-7 dias). Preferir azitromicina 5 dias ou doxiciclina. K+&gt;4.0, Mg&gt;2.0. Monitorar sintomas (tontura, palpitações). Considerar trocar escitalopram por sertralina se antibiótico prolongado."</text>
        </outputEntry>
      </rule>

      <!-- Rule 3: High dose escitalopram (>10mg) + clarithromycin, age ≤65 -->
      <rule id="rule_escit_alta_claritro_jovem_ddi_qt_016_decision">
        <inputEntry id="input_medicamentos_escit3_ddi_qt_016_decision">
          <text>list contains(medicamentosAtivos, "ESCITALOPRAM")</text>
        </inputEntry>
        <inputEntry id="input_novo_claritro3_ddi_qt_016_decision">
          <text>"CLARITROMICINA"</text>
        </inputEntry>
        <inputEntry id="input_dose_alta2_ddi_qt_016_decision">
          <text>&gt; 10</text>
        </inputEntry>
        <inputEntry id="input_idade_jovem_ddi_qt_016_decision">
          <text>&lt;= 65</text>
        </inputEntry>
        <outputEntry id="output_alerta_alta_jovem_ddi_qt_016_decision">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_alta_jovem_ddi_qt_016_decision">
          <text>"URGENTE"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_alta_jovem_ddi_qt_016_decision">
          <text>"Escitalopram &gt;10mg + Claritromicina"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_alta_jovem_ddi_qt_016_decision">
          <text>"QT aditivo significativo. Escitalopram 20mg +10ms, Claritromicina +15-20ms. Claritromicina possui MAIOR QT entre macrolídeos."</text>
        </outputEntry>
        <outputEntry id="output_acao_alta_jovem_ddi_qt_016_decision">
          <text>"CONSIDERAR reduzir escitalopram para 10mg/dia. ECG baseline + 48h. Alternativa antibiótico: azitromicina 5 dias (menor QT que claritro), doxiciclina. K+/Mg normais. Suspender claritro se QTc&gt;500ms."</text>
        </outputEntry>
      </rule>

      <!-- Rule 4: Standard dose escitalopram (≤10mg) + clarithromycin, age ≤65 -->
      <rule id="rule_escit_padrao_claritro_jovem_ddi_qt_016_decision">
        <inputEntry id="input_medicamentos_escit4_ddi_qt_016_decision">
          <text>list contains(medicamentosAtivos, "ESCITALOPRAM")</text>
        </inputEntry>
        <inputEntry id="input_novo_claritro4_ddi_qt_016_decision">
          <text>"CLARITROMICINA"</text>
        </inputEntry>
        <inputEntry id="input_dose_padrao2_ddi_qt_016_decision">
          <text>&lt;= 10</text>
        </inputEntry>
        <inputEntry id="input_idade_jovem2_ddi_qt_016_decision">
          <text>&lt;= 65</text>
        </inputEntry>
        <outputEntry id="output_alerta_padrao_jovem_ddi_qt_016_decision">
          <text>"Atencao"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_padrao_jovem_ddi_qt_016_decision">
          <text>"URGENTE"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_padrao_jovem_ddi_qt_016_decision">
          <text>"Escitalopram ≤10mg + Claritromicina"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_padrao_jovem_ddi_qt_016_decision">
          <text>"QT aditivo moderado. Escitalopram 10mg +5ms, Claritromicina +15-20ms. Risco baixo a moderado."</text>
        </outputEntry>
        <outputEntry id="output_acao_padrao_jovem_ddi_qt_016_decision">
          <text>"ACEITÁVEL com precauções: ECG baseline recomendado. Curso claritromicina curto (5-7 dias). Preferir azitromicina 5 dias ou doxiciclina. K+/Mg normais. Monitorar sintomas. Suspender claritro se sintomas."</text>
        </outputEntry>
      </rule>

      <!-- Fallback Rule -->
      <rule id="rule_fallback_ddi_qt_016_decision">
        <inputEntry id="input_fallback_1_ddi_qt_016_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_fallback_2_ddi_qt_016_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_fallback_3_ddi_qt_016_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_fallback_4_ddi_qt_016_decision">
          <text>-</text>
        </inputEntry>
        <outputEntry id="output_fallback_1_ddi_qt_016_decision">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="output_fallback_2_ddi_qt_016_decision">
          <text>"ROTINA"</text>
        </outputEntry>
        <outputEntry id="output_fallback_3_ddi_qt_016_decision">
          <text>""</text>
        </outputEntry>
        <outputEntry id="output_fallback_4_ddi_qt_016_decision">
          <text>""</text>
        </outputEntry>
        <outputEntry id="output_fallback_5_ddi_qt_016_decision">
          <text>""</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ddi_qt_016_decision">
      <dmndi:DMNShape id="DMNShape_ddi_qt_016_decision" dmnElementRef="ddi_qt_016_decision">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
