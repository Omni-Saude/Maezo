<?xml version="1.0" encoding="UTF-8"?>
<!-- DDI-MODERATE-007: Corticoides + AINEs - Ulcera Peptica -->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="DDI_MODERATE_007" name="DDI-MODERATE-007: Corticoide + AINE" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="ddi_moderate_007_decision" name="[SP-CO-004 | clinical_safety/ddi] Corticoide + AINE - Ulcera" camunda:historyTimeToLive="180">
    <decisionTable id="ddi_moderate_007_table" hitPolicy="FIRST">
      <input id="input_medicamentos_ativos_ddi_moderate_007_decision"><inputExpression typeRef="string"><text>medicamentosAtivos</text></inputExpression></input>
      <input id="input_medicamento_novo_ddi_moderate_007_decision"><inputExpression typeRef="string"><text>medicamentoNovo</text></inputExpression></input>
      <output id="output_nivel_alerta_ddi_moderate_007_decision" name="nivelAlerta" typeRef="string"><outputValues><text>"Alerta","Atencao","Informativo","OK"</text></outputValues></output>
      <output id="output_acao_requerida_ddi_moderate_007_decision" name="acaoRequerida" typeRef="string" />
      <output id="output_justificativa_ddi_moderate_007_decision" name="justificativaCientifica" typeRef="string" />

      <rule id="rule_corticoide_aine_ddi_moderate_007_decision">
        <inputEntry><text>list contains(medicamentosAtivos, "PREDNISONA") or list contains(medicamentosAtivos, "PREDNISOLONA") or list contains(medicamentosAtivos, "DEXAMETASONA") or list contains(medicamentosAtivos, "HIDROCORTISONA")</text></inputEntry>
        <inputEntry><text>"IBUPROFENO" or "DICLOFENACO" or "NAPROXENO" or "PIROXICAM" or "MELOXICAM" or "NIMESULIDA" or "CETOPROFENO"</text></inputEntry>
        <outputEntry><text>"Atencao"</text></outputEntry>
        <outputEntry><text>"Risco ulcera peptica 15x maior com combinacao corticoide + AINE. Associar IBP como gastroprotecao. Considerar paracetamol para dor. Se ambos necessarios por doenca reumatica, usar IBP dose plena e monitorar sintomas GI."</text></outputEntry>
        <outputEntry><text>"Piper JM, Ann Intern Med 1991: risco ulcera 15x com combinacao vs nenhum."</text></outputEntry>
      </rule>
      <rule id="Rule_Fallback_ddi_moderate_007_decision">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"OK"</text></outputEntry>
        <outputEntry><text>""</text></outputEntry>
        <outputEntry><text>""</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ddi_moderate_007_decision">
      <dmndi:DMNShape id="DMNShape_ddi_moderate_007_decision" dmnElementRef="ddi_moderate_007_decision">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
