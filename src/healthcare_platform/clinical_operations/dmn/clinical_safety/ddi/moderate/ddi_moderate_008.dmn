<?xml version="1.0" encoding="UTF-8"?>
<!-- DDI-MODERATE-008: Metoclopramida + Antipsicoticos - Distonia/Acatisia -->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="DDI_MODERATE_008" name="DDI-MODERATE-008: Metoclopramida + Antipsicotico" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="ddi_moderate_008_decision" name="[SP-CO-004 | clinical_safety/ddi] Metoclopramida + Antipsicotico - SEP" camunda:historyTimeToLive="180">
    <decisionTable id="ddi_moderate_008_table" hitPolicy="FIRST">
      <input id="input_medicamentos_ativos_ddi_moderate_008_decision"><inputExpression typeRef="string"><text>medicamentosAtivos</text></inputExpression></input>
      <input id="input_medicamento_novo_ddi_moderate_008_decision"><inputExpression typeRef="string"><text>medicamentoNovo</text></inputExpression></input>
      <output id="output_nivel_alerta_ddi_moderate_008_decision" name="nivelAlerta" typeRef="string"><outputValues><text>"Alerta","Atencao","Informativo","OK"</text></outputValues></output>
      <output id="output_acao_requerida_ddi_moderate_008_decision" name="acaoRequerida" typeRef="string" />
      <output id="output_justificativa_ddi_moderate_008_decision" name="justificativaCientifica" typeRef="string" />

      <rule id="rule_metoclo_antipsicotico_ddi_moderate_008_decision">
        <inputEntry><text>list contains(medicamentosAtivos, "HALOPERIDOL") or list contains(medicamentosAtivos, "RISPERIDONA") or list contains(medicamentosAtivos, "OLANZAPINA") or list contains(medicamentosAtivos, "QUETIAPINA") or list contains(medicamentosAtivos, "CLORPROMAZINA")</text></inputEntry>
        <inputEntry><text>"METOCLOPRAMIDA" or "BROMOPRIDA"</text></inputEntry>
        <outputEntry><text>"Atencao"</text></outputEntry>
        <outputEntry><text>"Bloqueio dopaminergico aditivo. Alto risco sintomas extrapiramidais (distonia, acatisia, parkinsonismo). Evitar combinacao se possivel. Usar ondansetrona como antiemetico alternativo. Se necessario, monitorar SEP de perto."</text></outputEntry>
        <outputEntry><text>"Ambos bloqueiam D2. Metoclopramida tem FDA Black Box para discinesia tardia. Evitar uso prolongado."</text></outputEntry>
      </rule>
      <rule id="Rule_Fallback_ddi_moderate_008_decision">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"OK"</text></outputEntry>
        <outputEntry><text>""</text></outputEntry>
        <outputEntry><text>""</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ddi_moderate_008_decision">
      <dmndi:DMNShape id="DMNShape_ddi_moderate_008_decision" dmnElementRef="ddi_moderate_008_decision">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
