<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="DDI_CONTRAIND_001" name="DDI-CONTRAIND-001: Linezolid + SSRIs/SNRIs" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="ddi_contraind_001_decision" name="[SP-CO-004 | clinical_safety/contraind] Linezolid + SSRIs/SNRIs Interaction" camunda:historyTimeToLive="180">
    <decisionTable id="ddi_contraind_001_table" hitPolicy="FIRST">
      <input id="input_medicamentos_ativos_ddi_contraind_001_decision" label="Medicamentos Ativos">
        <inputExpression id="input_expr_medicamentos_ativos_ddi_contraind_001_decision" typeRef="string">
          <text>medicamentosAtivos</text>
        </inputExpression>
      </input>
      <input id="input_medicamento_novo_ddi_contraind_001_decision" label="Medicamento Novo">
        <inputExpression id="input_expr_medicamento_novo_ddi_contraind_001_decision" typeRef="string">
          <text>medicamentoNovo</text>
        </inputExpression>
      </input>

      <output id="output_nivel_alerta_ddi_contraind_001_decision" name="nivelAlerta" typeRef="string">
        <outputValues>
          <text>"Alerta","Atencao","Informativo"</text>
        </outputValues>
      </output>
      <output id="output_urgencia_ddi_contraind_001_decision" name="urgencia" typeRef="string">
        <outputValues>
          <text>"IMEDIATA","URGENTE","ROTINA"</text>
        </outputValues>
      </output>
      <output id="output_medicamentos_conflitantes_ddi_contraind_001_decision" name="medicamentosConflitantes" typeRef="string" />
      <output id="output_mecanismo_interacao_ddi_contraind_001_decision" name="mecanismoInteracao" typeRef="string" />
      <output id="output_acao_requerida_ddi_contraind_001_decision" name="acaoRequerida" typeRef="string" />

      <!-- Rule 1: Linezolid + SSRIs (Fluoxetina, Paroxetina, Sertralina, Citalopram, Escitalopram) -->
      <rule id="rule_linezolid_ssri_ddi_contraind_001_decision">
        <inputEntry id="input_medicamentos_ssri_ddi_contraind_001_decision">
          <text>list contains(medicamentosAtivos, "FLUOXETINA") or list contains(medicamentosAtivos, "PAROXETINA") or list contains(medicamentosAtivos, "SERTRALINA") or list contains(medicamentosAtivos, "CITALOPRAM") or list contains(medicamentosAtivos, "ESCITALOPRAM")</text>
        </inputEntry>
        <inputEntry id="input_novo_linezolid_ddi_contraind_001_decision">
          <text>"LINEZOLIDA"</text>
        </inputEntry>
        <outputEntry id="output_alerta_ssri_ddi_contraind_001_decision">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_ssri_ddi_contraind_001_decision">
          <text>"IMEDIATA"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_ssri_ddi_contraind_001_decision">
          <text>"Linezolida + ISRS"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_ssri_ddi_contraind_001_decision">
          <text>"Inibicao MAO reversivel (linezolida) + aumento serotonina (ISRS) = SINDROME SEROTONINERGICA FATAL"</text>
        </outputEntry>
        <outputEntry id="output_acao_ssri_ddi_contraind_001_decision">
          <text>"CONTRAINDICADO: Suspender ISRS 14 dias antes linezolida OU escolher antibiotico alternativo. Monitorar: agitacao, tremor, hipertermia, rigidez, convulsoes."</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: Linezolid + SNRIs (Venlafaxina, Duloxetina, Desvenlafaxina) -->
      <rule id="rule_linezolid_snri_ddi_contraind_001_decision">
        <inputEntry id="input_medicamentos_snri_ddi_contraind_001_decision">
          <text>list contains(medicamentosAtivos, "VENLAFAXINA") or list contains(medicamentosAtivos, "DULOXETINA") or list contains(medicamentosAtivos, "DESVENLAFAXINA")</text>
        </inputEntry>
        <inputEntry id="input_novo_linezolid_snri_ddi_contraind_001_decision">
          <text>"LINEZOLIDA"</text>
        </inputEntry>
        <outputEntry id="output_alerta_snri_ddi_contraind_001_decision">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_snri_ddi_contraind_001_decision">
          <text>"IMEDIATA"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_snri_ddi_contraind_001_decision">
          <text>"Linezolida + ISRSN"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_snri_ddi_contraind_001_decision">
          <text>"Inibicao MAO reversivel + aumento serotonina/noradrenalina = SINDROME SEROTONINERGICA"</text>
        </outputEntry>
        <outputEntry id="output_acao_snri_ddi_contraind_001_decision">
          <text>"CONTRAINDICADO: Suspender ISRSN 7 dias antes linezolida. Se emergencia, usar antibiotico alternativo (vancomicina, daptomicina)."</text>
        </outputEntry>
      </rule>

      <!-- Fallback Rule -->
      <rule id="rule_fallback_ddi_contraind_001_decision">
        <inputEntry id="input_fallback_1_ddi_contraind_001_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_fallback_2_ddi_contraind_001_decision">
          <text>-</text>
        </inputEntry>
        <outputEntry id="output_fallback_1_ddi_contraind_001_decision">
          <text>"Informativo"</text>
        </outputEntry>
        <outputEntry id="output_fallback_2_ddi_contraind_001_decision">
          <text>"ROTINA"</text>
        </outputEntry>
        <outputEntry id="output_fallback_3_ddi_contraind_001_decision">
          <text>""</text>
        </outputEntry>
        <outputEntry id="output_fallback_4_ddi_contraind_001_decision">
          <text>""</text>
        </outputEntry>
        <outputEntry id="output_fallback_5_ddi_contraind_001_decision">
          <text>""</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ddi_contraind_001_decision">
      <dmndi:DMNShape id="DMNShape_ddi_contraind_001_decision" dmnElementRef="ddi_contraind_001_decision">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
