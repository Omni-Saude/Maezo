<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="DDI_CONTRAIND_002" name="DDI-CONTRAIND-002: IMAOs + Meperidina" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="ddi_contraind_002_decision" name="[SP-CO-004 | clinical_safety/contraind] IMAOs + Meperidina Interaction" camunda:historyTimeToLive="180">
    <decisionTable id="ddi_contraind_002_table" hitPolicy="FIRST">
      <input id="input_medicamentos_ativos_ddi_contraind_002_decision" label="Medicamentos Ativos">
        <inputExpression id="input_expr_medicamentos_ativos_ddi_contraind_002_decision" typeRef="string">
          <text>medicamentosAtivos</text>
        </inputExpression>
      </input>
      <input id="input_medicamento_novo_ddi_contraind_002_decision" label="Medicamento Novo">
        <inputExpression id="input_expr_medicamento_novo_ddi_contraind_002_decision" typeRef="string">
          <text>medicamentoNovo</text>
        </inputExpression>
      </input>

      <output id="output_nivel_alerta_ddi_contraind_002_decision" name="nivelAlerta" typeRef="string">
        <outputValues>
          <text>"Alerta","Atencao","Informativo"</text>
        </outputValues>
      </output>
      <output id="output_urgencia_ddi_contraind_002_decision" name="urgencia" typeRef="string">
        <outputValues>
          <text>"IMEDIATA","URGENTE","ROTINA"</text>
        </outputValues>
      </output>
      <output id="output_medicamentos_conflitantes_ddi_contraind_002_decision" name="medicamentosConflitantes" typeRef="string" />
      <output id="output_mecanismo_interacao_ddi_contraind_002_decision" name="mecanismoInteracao" typeRef="string" />
      <output id="output_acao_requerida_ddi_contraind_002_decision" name="acaoRequerida" typeRef="string" />

      <!-- Rule 1: IMAOs irreversíveis + Meperidina -->
      <rule id="rule_imao_meperidina_ddi_contraind_002_decision">
        <inputEntry id="input_medicamentos_imao_ddi_contraind_002_decision">
          <text>list contains(medicamentosAtivos, "FENELZINA") or list contains(medicamentosAtivos, "TRANILCIPROMINA") or list contains(medicamentosAtivos, "ISOCARBOXAZIDA") or list contains(medicamentosAtivos, "SELEGILINA")</text>
        </inputEntry>
        <inputEntry id="input_novo_meperidina_ddi_contraind_002_decision">
          <text>"MEPERIDINA" or "PETIDINA"</text>
        </inputEntry>
        <outputEntry id="output_alerta_imao_ddi_contraind_002_decision">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_imao_ddi_contraind_002_decision">
          <text>"IMEDIATA"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_imao_ddi_contraind_002_decision">
          <text>"IMAO + Meperidina"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_imao_ddi_contraind_002_decision">
          <text>"Meperidina metabolito (normeperidina) + inibicao MAO = acumulo MASSIVO serotonina + catecolaminas = sindrome serotoninergica GRAVE + crises hipertensivas + depressao respiratoria"</text>
        </outputEntry>
        <outputEntry id="output_acao_imao_ddi_contraind_002_decision">
          <text>"CONTRAINDICADO ABSOLUTO: Nunca associar. Se IMAO ativo, aguardar washout 14 dias. Alternativas analgesia: morfina, fentanil, hidromorfona (com cautela). Mortalidade reportada."</text>
        </outputEntry>
      </rule>

      <!-- Rule 2: Meperidina em uso + prescrição IMAO -->
      <rule id="rule_meperidina_imao_ddi_contraind_002_decision">
        <inputEntry id="input_medicamentos_meperidina_ddi_contraind_002_decision">
          <text>list contains(medicamentosAtivos, "MEPERIDINA") or list contains(medicamentosAtivos, "PETIDINA")</text>
        </inputEntry>
        <inputEntry id="input_novo_imao_ddi_contraind_002_decision">
          <text>"FENELZINA" or "TRANILCIPROMINA" or "ISOCARBOXAZIDA" or "SELEGILINA"</text>
        </inputEntry>
        <outputEntry id="output_alerta_meperidina_ddi_contraind_002_decision">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="output_urgencia_meperidina_ddi_contraind_002_decision">
          <text>"IMEDIATA"</text>
        </outputEntry>
        <outputEntry id="output_conflitantes_meperidina_ddi_contraind_002_decision">
          <text>"Meperidina ativa + IMAO prescrito"</text>
        </outputEntry>
        <outputEntry id="output_mecanismo_meperidina_ddi_contraind_002_decision">
          <text>"Mesmo mecanismo - metabolito normeperidina + inibicao MAO = FATAL"</text>
        </outputEntry>
        <outputEntry id="output_acao_meperidina_ddi_contraind_002_decision">
          <text>"CONTRAINDICADO: Suspender meperidina 24h antes de iniciar IMAO. Interacao pode ocorrer ate 48h apos ultima dose meperidina. Risco mortalidade alto."</text>
        </outputEntry>
      </rule>

      <!-- Fallback Rule -->
      <rule id="rule_fallback_ddi_contraind_002_decision">
        <inputEntry id="input_fallback_1_ddi_contraind_002_decision">
          <text>-</text>
        </inputEntry>
        <inputEntry id="input_fallback_2_ddi_contraind_002_decision">
          <text>-</text>
        </inputEntry>
        <outputEntry id="output_fallback_1_ddi_contraind_002_decision">
          <text>"Informativo"</text>
        </outputEntry>
        <outputEntry id="output_fallback_2_ddi_contraind_002_decision">
          <text>"ROTINA"</text>
        </outputEntry>
        <outputEntry id="output_fallback_3_ddi_contraind_002_decision">
          <text>""</text>
        </outputEntry>
        <outputEntry id="output_fallback_4_ddi_contraind_002_decision">
          <text>""</text>
        </outputEntry>
        <outputEntry id="output_fallback_5_ddi_contraind_002_decision">
          <text>""</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ddi_contraind_002_decision">
      <dmndi:DMNShape id="DMNShape_ddi_contraind_002_decision" dmnElementRef="ddi_contraind_002_decision">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
