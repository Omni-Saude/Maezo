<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DLI_RENAL_016"
             name="Alerta: Colchicina CrCl  &lt; 30"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DLI_RENAL_016" name="[SP-CO-004 | clinical_safety/dli] Colchicina CrCl  &lt; 30" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DLI_RENAL_016" hitPolicy="FIRST">

      <input id="Input_1_DLI_RENAL_016" label="Medicamento Atual">
        <inputExpression id="InputExpression_1_DLI_RENAL_016" typeRef="string">
          <text>medicamentoAtual</text>
        </inputExpression>
      </input>

      <input id="Input_2_DLI_RENAL_016" label="Clearance Creatinina (mL/min)">
        <inputExpression id="InputExpression_2_DLI_RENAL_016" typeRef="number">
          <text>clearanceCreatinina</text>
        </inputExpression>
      </input>

      <output id="Output_1_DLI_RENAL_016" label="Nivel de Alerta" name="nivelAlerta" typeRef="string">
        <outputValues id="OutputValues_1_DLI_RENAL_016">
          <text>"Informativo", "Atencao", "Alerta", "Alerta"</text>
        </outputValues>
      </output>

      <output id="Output_2_DLI_RENAL_016" label="Ajuste Recomendado" name="ajusteDoseRecomendado" typeRef="string"/>
      <output id="Output_3_DLI_RENAL_016" label="Frequencia Recomendada" name="frequenciaRecomendada" typeRef="string"/>
      <output id="Output_4_DLI_RENAL_016" label="Monitoramento Requerido" name="monitoramentoRequerido" typeRef="string"/>

      <rule id="Rule_Alerta_1_DLI_RENAL_016">
        <description>Colchicina CrCl  &lt; 30 - 0.3 mg/dia</description>
        <inputEntry id="InputEntry_A1_1_DLI_RENAL_016">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_A1_2_DLI_RENAL_016">
          <text>&lt; 30</text>
        </inputEntry>
        <outputEntry id="OutputEntry_A1_1_DLI_RENAL_016">
          <text>"Alerta"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_A1_2_DLI_RENAL_016">
          <text>"0.3 mg/dia - Hemograma, miopatia"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_A1_3_DLI_RENAL_016">
          <text>"0.3 mg/dia"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_A1_4_DLI_RENAL_016">
          <text>"Hemograma, miopatia"</text>
        </outputEntry>
      </rule>

      <rule id="Rule_Fallback_DLI_RENAL_016">
        <description>Sem ajuste necessario</description>
        <inputEntry id="InputEntry_F_1_DLI_RENAL_016">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_F_2_DLI_RENAL_016">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_F_1_DLI_RENAL_016">
          <text>"Informativo"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_F_2_DLI_RENAL_016">
          <text>"Sem ajuste necessario."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_F_3_DLI_RENAL_016">
          <text>"Conforme prescricao"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_F_4_DLI_RENAL_016">
          <text>"Rotina"</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DLI_RENAL_016">
      <dmndi:DMNShape id="DMNShape_Decision_DLI_RENAL_016" dmnElementRef="Decision_DLI_RENAL_016">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
