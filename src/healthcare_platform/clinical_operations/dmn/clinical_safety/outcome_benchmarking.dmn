<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="clinical_safety_outcome_benchmarking" name="Outcome Benchmarking"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="decision_outcome_benchmarking" name="[SP-CO-004 | clinical_safety] Benchmarking de Desfechos" camunda:historyTimeToLive="180">
    <decisionTable id="dt_outcome_benchmarking" hitPolicy="FIRST">
      <input id="ob_in1_outcome_benchmarking" label="Performance vs Benchmark">
        <inputExpression typeRef="string"><text>benchmarkPerformance</text></inputExpression>
      </input>
      <input id="ob_in2_outcome_benchmarking" label="Variação Percentual">
        <inputExpression typeRef="double"><text>variancePercent</text></inputExpression>
      </input>
      <output id="ob_out1_outcome_benchmarking" label="action" name="action" typeRef="string"/>
      <output id="ob_out2_outcome_benchmarking" label="benchmarkAction" name="benchmarkAction" typeRef="string"/>
      <output id="ob_out3_outcome_benchmarking" label="justificativa" name="justificativa" typeRef="string"/>

      <rule id="ob_r1_outcome_benchmarking">
        <inputEntry><text>"below_average"</text></inputEntry>
        <inputEntry><text>&lt; -20</text></inputEntry>
        <outputEntry><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry><text>"investigate_barriers"</text></outputEntry>
        <outputEntry><text>"Desfecho muito abaixo do benchmark - investigar barreiras"</text></outputEntry>
      </rule>
      <rule id="ob_r2_outcome_benchmarking">
        <inputEntry><text>"below_average"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"review_protocol"</text></outputEntry>
        <outputEntry><text>"Abaixo da média - revisar protocolo terapêutico"</text></outputEntry>
      </rule>
      <rule id="ob_r3_outcome_benchmarking">
        <inputEntry><text>"average"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"maintain"</text></outputEntry>
        <outputEntry><text>"Dentro da média - manter abordagem atual"</text></outputEntry>
      </rule>
      <rule id="ob_r4_outcome_benchmarking">
        <inputEntry><text>"above_average"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry><text>"best_practice"</text></outputEntry>
        <outputEntry><text>"Acima da média - candidato a boas práticas"</text></outputEntry>
      </rule>
      <rule id="ob_r5_outcome_benchmarking">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"REVISAR"</text></outputEntry>
        <outputEntry><text>"insufficient_data"</text></outputEntry>
        <outputEntry><text>"Dados insuficientes para comparação"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_decision_outcome_benchmarking">
      <dmndi:DMNShape id="DMNShape_decision_outcome_benchmarking" dmnElementRef="decision_outcome_benchmarking">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
