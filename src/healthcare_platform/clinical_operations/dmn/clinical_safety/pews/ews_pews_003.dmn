<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  EWS-PEWS-003: PEWS Low Risk (Score 0-2) - ROUTINE MONITORING
  ============================================================================

  Pediatric Early Warning Score low risk - routine monitoring.
  This rule confirms stable pediatric patients requiring standard observation.

  Evidence Base: Monaghan (2005), Brighton PEWS
  Response Level: Score 0-2 indicates stable condition

  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_EWS_PEWS_003"
             name="PEWS Low Risk Alert"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!--
    ═══════════════════════════════════════════════════════════════════════════
    EWS-PEWS-003: PEWS Low Risk Score (0-2)
    Version: 1.0.0 (2026-02-06)
    Clinical Domain: Pediatric Medicine / Ward Care
    ═══════════════════════════════════════════════════════════════════════════

    TRIGGER CONDITIONS:
    - PEWS total score 0-2 points
    - Vital signs and behavior within acceptable ranges

    CLINICAL ACTIONS:
    - Continue routine monitoring every 4-6 hours
    - Document in clinical record
    - No escalation needed unless change
    - Reassure parents
    ═══════════════════════════════════════════════════════════════════════════
  -->

  <decision id="Decision_EWS_PEWS_003" name="[SP-CO-004 | clinical_safety/pews] PEWS Low Risk Evaluation" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_EWS_PEWS_003" hitPolicy="FIRST">

      <!-- INPUT 1: PEWS Total Score -->
      <input id="Input_1_EWS_PEWS_003" label="PEWS Score Total">
        <inputExpression id="InputExpression_1_EWS_PEWS_003" typeRef="number">
          <text>pewsScoreTotal</text>
        </inputExpression>
      </input>

      <!-- INPUT 2: Recent Score Increase -->
      <input id="Input_2_EWS_PEWS_003" label="Aumento Recente">
        <inputExpression id="InputExpression_2_EWS_PEWS_003" typeRef="boolean">
          <text>aumentoRecente</text>
        </inputExpression>
      </input>

      <!-- INPUT 3: First Assessment -->
      <input id="Input_3_EWS_PEWS_003" label="Primeira Avaliacao">
        <inputExpression id="InputExpression_3_EWS_PEWS_003" typeRef="boolean">
          <text>primeiraAvaliacao</text>
        </inputExpression>
      </input>

      <!-- OUTPUT 1: Alert Level -->
      <output id="Output_1_EWS_PEWS_003" label="Nivel Alerta" name="nivelAlerta" typeRef="string">
        <outputValues id="OutputValues_1_EWS_PEWS_003">
          <text>"Alerta", "Atencao", "Informativo", "OK", "Revisar"</text>
        </outputValues>
      </output>

      <!-- OUTPUT 2: Urgency -->
      <output id="Output_2_EWS_PEWS_003" label="Urgencia" name="urgencia" typeRef="string">
        <outputValues id="OutputValues_2_EWS_PEWS_003">
          <text>"IMEDIATA", "URGENTE", "ROTINA", "INFORMATIVA"</text>
        </outputValues>
      </output>

      <!-- OUTPUT 3: Required Action -->
      <output id="Output_3_EWS_PEWS_003" label="Acao Requerida" name="acaoRequerida" typeRef="string"/>

      <!-- OUTPUT 4: Clinical Justification -->
      <output id="Output_4_EWS_PEWS_003" label="Justificativa Cientifica" name="justificativaCientifica" typeRef="string"/>

      <!-- RULE 1: Low Risk but Recent Increase -->
      <rule id="Rule_LowRisk_RecentIncrease_EWS_PEWS_003">
        <description>PEWS 0-2 but recently increased - monitor trend</description>
        <inputEntry id="InputEntry_1_1_EWS_PEWS_003">
          <text>[1..2]</text>
        </inputEntry>
        <inputEntry id="InputEntry_1_2_EWS_PEWS_003">
          <text>true</text>
        </inputEntry>
        <inputEntry id="InputEntry_1_3_EWS_PEWS_003">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_1_1_EWS_PEWS_003">
          <text>"Informativo"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_1_2_EWS_PEWS_003">
          <text>"INFORMATIVA"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_1_3_EWS_PEWS_003">
          <text>"PEWS aumentou de 0 para 1-2. Ainda em faixa baixa mas monitorar tendencia. Repetir avaliacao em 4 horas. Documentar mudanca. Orientar pais sobre sinais de alerta. Investigar causa se persistir."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_1_4_EWS_PEWS_003">
          <text>"Aumento de score mesmo dentro da faixa baixa pode indicar inicio de deterioracao. Criancas podem mudar rapidamente. Deteccao precoce de tendencias e essencial em pediatria."</text>
        </outputEntry>
      </rule>

      <!-- RULE 2: First Assessment (Admission) -->
      <rule id="Rule_LowRisk_FirstAssessment_EWS_PEWS_003">
        <description>First PEWS assessment on admission - baseline documentation</description>
        <inputEntry id="InputEntry_2_1_EWS_PEWS_003">
          <text>[0..2]</text>
        </inputEntry>
        <inputEntry id="InputEntry_2_2_EWS_PEWS_003">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_2_3_EWS_PEWS_003">
          <text>true</text>
        </inputEntry>
        <outputEntry id="OutputEntry_2_1_EWS_PEWS_003">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_2_2_EWS_PEWS_003">
          <text>"INFORMATIVA"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_2_3_EWS_PEWS_003">
          <text>"PEWS inicial de admissao registrado. Estabelecer baseline para comparacoes futuras. Orientar pais sobre PEWS e sinais de alerta. Proxima avaliacao em 4-6 horas conforme protocolo. Documentar condicao de admissao."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_2_4_EWS_PEWS_003">
          <text>"Primeira avaliacao estabelece baseline individual. Criancas com doencas cronicas podem ter baseline diferente. Comparacoes subsequentes devem considerar este baseline."</text>
        </outputEntry>
      </rule>

      <!-- RULE 3: Low Risk Stable (Score 0) -->
      <rule id="Rule_LowRisk_Zero_EWS_PEWS_003">
        <description>PEWS 0 - child stable, routine monitoring</description>
        <inputEntry id="InputEntry_3_1_EWS_PEWS_003">
          <text>0</text>
        </inputEntry>
        <inputEntry id="InputEntry_3_2_EWS_PEWS_003">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_3_3_EWS_PEWS_003">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_3_1_EWS_PEWS_003">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_3_2_EWS_PEWS_003">
          <text>"INFORMATIVA"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_3_3_EWS_PEWS_003">
          <text>"Crianca estavel, PEWS otimo. Manter sinais vitais de rotina cada 4-6 horas. Encorajar presenca dos pais. Orientar sobre sinais de piora. Estimular aceitacao oral se indicado. Preparar para alta se indicada."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_3_4_EWS_PEWS_003">
          <text>"PEWS 0 indica todos os componentes normais: comportamento adequado, boa perfusao, respiracao tranquila. Risco baixissimo de deterioracao. Monitoramento de rotina apropriado."</text>
        </outputEntry>
      </rule>

      <!-- RULE 4: Low Risk (Score 1-2) -->
      <rule id="Rule_LowRisk_Stable_EWS_PEWS_003">
        <description>PEWS 1-2 - minor deviations, routine monitoring</description>
        <inputEntry id="InputEntry_4_1_EWS_PEWS_003">
          <text>[1..2]</text>
        </inputEntry>
        <inputEntry id="InputEntry_4_2_EWS_PEWS_003">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_4_3_EWS_PEWS_003">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_4_1_EWS_PEWS_003">
          <text>"OK"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_4_2_EWS_PEWS_003">
          <text>"INFORMATIVA"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_4_3_EWS_PEWS_003">
          <text>"Desvios menores detectados. Manter monitoramento cada 4-6 horas. Documentar achados. Sem necessidade de escalonamento neste momento. Orientar pais para chamar se notarem mudanca."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_4_4_EWS_PEWS_003">
          <text>"PEWS 1-2 representa desvios leves (ex: levemente irritavel, discreto aumento FR). Comum em criancas hospitalizadas. Maioria mantem-se estavel com monitoramento de rotina."</text>
        </outputEntry>
      </rule>

      <!-- RULE 5: FALLBACK -->
      <rule id="Rule_Fallback_EWS_PEWS_003">
        <description>Score fora da faixa 0-2 ou dados incompletos</description>
        <inputEntry id="InputEntry_F_1_EWS_PEWS_003">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_F_2_EWS_PEWS_003">
          <text>-</text>
        </inputEntry>
        <inputEntry id="InputEntry_F_3_EWS_PEWS_003">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OutputEntry_F_1_EWS_PEWS_003">
          <text>"Revisar"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_F_2_EWS_PEWS_003">
          <text>"ROTINA"</text>
        </outputEntry>
        <outputEntry id="OutputEntry_F_3_EWS_PEWS_003">
          <text>"PEWS fora da faixa 0-2 ou dados incompletos. Verificar regras PEWS-001 (critico) ou PEWS-002 (medio risco). Confirmar calculo correto dos tres componentes."</text>
        </outputEntry>
        <outputEntry id="OutputEntry_F_4_EWS_PEWS_003">
          <text>"Esta regra avalia especificamente PEWS 0-2. Valores maiores indicam risco aumentado e devem ser avaliados pelas regras apropriadas."</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_EWS_PEWS_003">
      <dmndi:DMNShape id="DMNShape_Decision_EWS_PEWS_003" dmnElementRef="Decision_EWS_PEWS_003">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
