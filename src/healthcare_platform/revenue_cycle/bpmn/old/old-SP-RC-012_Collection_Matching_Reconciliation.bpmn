<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_RC008A" targetNamespace="http://cib7.healthcare/revenue-cycle" exporter="Camunda Modeler" exporterVersion="5.35.0">
  <bpmn:process id="SP_RC_012_Collection_Matching_Reconciliation" name="Conciliação de Pagamentos e Reconciliação" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="start_matching_reconciliation" name="Início Conciliação">
      <bpmn:outgoing>flow_to_parse_payment_file</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="gateway_matching_strategy" name="Estratégia de Conciliação" default="flow_to_match_patient">
      <bpmn:incoming>flow_to_matching_strategy</bpmn:incoming>
      <bpmn:outgoing>flow_to_match_protocol</bpmn:outgoing>
      <bpmn:outgoing>flow_to_match_invoice</bpmn:outgoing>
      <bpmn:outgoing>flow_to_match_patient</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="gateway_matching_join">
      <bpmn:incoming>flow_protocol_to_join</bpmn:incoming>
      <bpmn:incoming>flow_invoice_to_join</bpmn:incoming>
      <bpmn:incoming>flow_patient_to_join</bpmn:incoming>
      <bpmn:outgoing>flow_to_auto_matching</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:boundaryEvent id="error_duplicate_detected" name="Duplicado Detectado" attachedToRef="task_detect_duplicate_payment">
      <bpmn:outgoing>flow_to_end_error</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_DuplicatePayment" />
    </bpmn:boundaryEvent>
    <bpmn:exclusiveGateway id="gateway_payment_value" name="Valor do Pagamento" default="flow_to_exact_match">
      <bpmn:incoming>flow_to_payment_value_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_to_overpayment</bpmn:outgoing>
      <bpmn:outgoing>flow_to_underpayment</bpmn:outgoing>
      <bpmn:outgoing>flow_to_exact_match</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="gateway_payment_value_join">
      <bpmn:incoming>flow_overpayment_to_join</bpmn:incoming>
      <bpmn:incoming>flow_underpayment_to_join</bpmn:incoming>
      <bpmn:incoming>flow_to_exact_match</bpmn:incoming>
      <bpmn:outgoing>flow_to_persist_payment</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="gateway_reconciliation_frequency" name="Frequência de Reconciliação" default="flow_to_archive_direct">
      <bpmn:incoming>flow_to_reconciliation_frequency</bpmn:incoming>
      <bpmn:outgoing>flow_to_weekly</bpmn:outgoing>
      <bpmn:outgoing>flow_to_monthly</bpmn:outgoing>
      <bpmn:outgoing>flow_to_archive_direct</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="gateway_reconciliation_join">
      <bpmn:incoming>flow_weekly_to_join</bpmn:incoming>
      <bpmn:incoming>flow_monthly_to_join</bpmn:incoming>
      <bpmn:incoming>flow_to_archive_direct</bpmn:incoming>
      <bpmn:outgoing>flow_to_flag_discrepancies</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="end_success" name="Reconciliação Concluída">
      <bpmn:incoming>flow_to_end_success</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="end_error" name="Erro Duplicado">
      <bpmn:incoming>flow_to_end_error</bpmn:incoming>
      <bpmn:errorEventDefinition errorRef="Error_DuplicatePayment" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_to_parse_payment_file" sourceRef="start_matching_reconciliation" targetRef="task_parse_payment_file" />
    <bpmn:sequenceFlow id="flow_to_validate_payment_data" sourceRef="task_parse_payment_file" targetRef="task_validate_payment_data" />
    <bpmn:sequenceFlow id="flow_to_classify_payment_type" sourceRef="task_validate_payment_data" targetRef="task_classify_payment_type" />
    <bpmn:sequenceFlow id="flow_to_matching_strategy" sourceRef="task_classify_payment_type" targetRef="gateway_matching_strategy" />
    <bpmn:sequenceFlow id="flow_to_match_protocol" name="Por Protocolo" sourceRef="gateway_matching_strategy" targetRef="task_match_by_protocol">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${matchingStrategy == 'PROTOCOL'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_to_match_invoice" name="Por Fatura" sourceRef="gateway_matching_strategy" targetRef="task_match_by_invoice">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${matchingStrategy == 'INVOICE'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_to_match_patient" name="Por Paciente" sourceRef="gateway_matching_strategy" targetRef="task_match_by_patient" />
    <bpmn:sequenceFlow id="flow_protocol_to_join" sourceRef="task_match_by_protocol" targetRef="gateway_matching_join" />
    <bpmn:sequenceFlow id="flow_invoice_to_join" sourceRef="task_match_by_invoice" targetRef="gateway_matching_join" />
    <bpmn:sequenceFlow id="flow_patient_to_join" sourceRef="task_match_by_patient" targetRef="gateway_matching_join" />
    <bpmn:sequenceFlow id="flow_to_auto_matching" sourceRef="gateway_matching_join" targetRef="task_auto_matching" />
    <bpmn:sequenceFlow id="flow_to_detect_duplicate" sourceRef="task_auto_matching" targetRef="task_detect_duplicate_payment" />
    <bpmn:sequenceFlow id="flow_to_convert_currency" sourceRef="task_detect_duplicate_payment" targetRef="task_convert_currency" />
    <bpmn:sequenceFlow id="flow_to_apply_adjustments" sourceRef="task_convert_currency" targetRef="task_apply_contractual_adjustments" />
    <bpmn:sequenceFlow id="flow_to_calculate_net" sourceRef="task_apply_contractual_adjustments" targetRef="task_calculate_net_payment" />
    <bpmn:sequenceFlow id="flow_to_payment_value_gateway" sourceRef="task_calculate_net_payment" targetRef="gateway_payment_value" />
    <bpmn:sequenceFlow id="flow_to_overpayment" name="Pagamento a Maior" sourceRef="gateway_payment_value" targetRef="task_handle_overpayment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${paymentVariance &gt; 0}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_to_underpayment" name="Pagamento a Menor" sourceRef="gateway_payment_value" targetRef="task_handle_underpayment">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${paymentVariance &lt; 0}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_to_exact_match" name="Pagamento Exato" sourceRef="gateway_payment_value" targetRef="gateway_payment_value_join" />
    <bpmn:sequenceFlow id="flow_overpayment_to_join" sourceRef="task_handle_overpayment" targetRef="gateway_payment_value_join" />
    <bpmn:sequenceFlow id="flow_underpayment_to_join" sourceRef="task_handle_underpayment" targetRef="gateway_payment_value_join" />
    <bpmn:sequenceFlow id="flow_to_persist_payment" sourceRef="gateway_payment_value_join" targetRef="task_persist_payment" />
    <bpmn:sequenceFlow id="flow_to_reconciliation_frequency" sourceRef="task_persist_payment" targetRef="gateway_reconciliation_frequency" />
    <bpmn:sequenceFlow id="flow_to_weekly" name="Semanal" sourceRef="gateway_reconciliation_frequency" targetRef="task_reconcile_weekly">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${reconciliationFrequency == 'WEEKLY'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_to_monthly" name="Mensal" sourceRef="gateway_reconciliation_frequency" targetRef="task_reconcile_monthly">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${reconciliationFrequency == 'MONTHLY'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_to_archive_direct" name="Arquivar Direto" sourceRef="gateway_reconciliation_frequency" targetRef="gateway_reconciliation_join" />
    <bpmn:sequenceFlow id="flow_weekly_to_join" sourceRef="task_reconcile_weekly" targetRef="gateway_reconciliation_join" />
    <bpmn:sequenceFlow id="flow_monthly_to_join" sourceRef="task_reconcile_monthly" targetRef="gateway_reconciliation_join" />
    <bpmn:sequenceFlow id="flow_to_flag_discrepancies" sourceRef="gateway_reconciliation_join" targetRef="task_flag_discrepancies" />
    <bpmn:sequenceFlow id="flow_to_archive_reconciliation" sourceRef="task_flag_discrepancies" targetRef="task_archive_reconciliation" />
    <bpmn:sequenceFlow id="flow_to_end_success" sourceRef="task_archive_reconciliation" targetRef="end_success" />
    <bpmn:sequenceFlow id="flow_to_end_error" sourceRef="error_duplicate_detected" targetRef="end_error" />
    <bpmn:serviceTask id="task_parse_payment_file" name="Processar Arquivo de Pagamento" camunda:type="external" camunda:topic="collection.parse_payment_file">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="parsedPayments">${payments}</camunda:outputParameter>
          <camunda:outputParameter name="recordCount">${paymentCount}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_parse_payment_file</bpmn:incoming>
      <bpmn:outgoing>flow_to_validate_payment_data</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_validate_payment_data" name="Validar Dados de Pagamento" camunda:type="external" camunda:topic="collection.validate_payment_data">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="validPayments">${validatedPayments}</camunda:outputParameter>
          <camunda:outputParameter name="validationErrors">${errors}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_validate_payment_data</bpmn:incoming>
      <bpmn:outgoing>flow_to_classify_payment_type</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_classify_payment_type" name="Classificar Tipo de Pagamento" camunda:type="external" camunda:topic="collection.classify_payment_type">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="classifiedPayments">${classifiedPayments}</camunda:outputParameter>
          <camunda:outputParameter name="paymentTypes">${paymentTypeBreakdown}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_classify_payment_type</bpmn:incoming>
      <bpmn:outgoing>flow_to_matching_strategy</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_match_by_protocol" name="Conciliar por Protocolo" camunda:type="external" camunda:topic="collection.match_by_protocol">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="matchedPayments">${protocolMatches}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_match_protocol</bpmn:incoming>
      <bpmn:outgoing>flow_protocol_to_join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_match_by_invoice" name="Conciliar por Fatura" camunda:type="external" camunda:topic="collection.match_by_invoice">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="matchedPayments">${invoiceMatches}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_match_invoice</bpmn:incoming>
      <bpmn:outgoing>flow_invoice_to_join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_match_by_patient" name="Conciliar por Paciente" camunda:type="external" camunda:topic="collection.match_by_patient">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="matchedPayments">${patientMatches}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_match_patient</bpmn:incoming>
      <bpmn:outgoing>flow_patient_to_join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_auto_matching" name="Conciliação Automática" camunda:type="external" camunda:topic="revenue_cycle.auto_matching">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="reconciledPayments">${autoMatched}</camunda:outputParameter>
          <camunda:outputParameter name="unmatchedPayments">${pendingMatching}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_auto_matching</bpmn:incoming>
      <bpmn:outgoing>flow_to_detect_duplicate</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_detect_duplicate_payment" name="Detectar Pagamento Duplicado" camunda:type="external" camunda:topic="collection.detect_duplicate_payment">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="uniquePayments">${uniquePayments}</camunda:outputParameter>
          <camunda:outputParameter name="duplicates">${duplicatePayments}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_detect_duplicate</bpmn:incoming>
      <bpmn:outgoing>flow_to_convert_currency</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_convert_currency" name="Converter Moeda" camunda:type="external" camunda:topic="collection.convert_currency">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="convertedPayments">${currencyConverted}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_convert_currency</bpmn:incoming>
      <bpmn:outgoing>flow_to_apply_adjustments</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_apply_contractual_adjustments" name="Aplicar Ajustes Contratuais" camunda:type="external" camunda:topic="collection.apply_contractual_adjustments">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="adjustedPayments">${contractualAdjusted}</camunda:outputParameter>
          <camunda:outputParameter name="adjustmentTotal">${totalAdjustments}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_apply_adjustments</bpmn:incoming>
      <bpmn:outgoing>flow_to_calculate_net</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_calculate_net_payment" name="Calcular Pagamento Líquido" camunda:type="external" camunda:topic="collection.calculate_net_payment">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="netPayments">${netPaymentAmounts}</camunda:outputParameter>
          <camunda:outputParameter name="variance">${paymentVariance}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_calculate_net</bpmn:incoming>
      <bpmn:outgoing>flow_to_payment_value_gateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_handle_overpayment" name="Tratar Pagamento a Maior" camunda:type="external" camunda:topic="collection.handle_overpayment">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="processedPayments">${overpaymentProcessed}</camunda:outputParameter>
          <camunda:outputParameter name="creditBalance">${creditAmount}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_overpayment</bpmn:incoming>
      <bpmn:outgoing>flow_overpayment_to_join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_handle_underpayment" name="Tratar Pagamento a Menor" camunda:type="external" camunda:topic="collection.handle_underpayment">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="processedPayments">${underpaymentProcessed}</camunda:outputParameter>
          <camunda:outputParameter name="debitBalance">${outstandingAmount}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_underpayment</bpmn:incoming>
      <bpmn:outgoing>flow_underpayment_to_join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_persist_payment" name="Persistir Pagamento" camunda:type="external" camunda:topic="collection.persist_payment">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="persistedPayments">${savedPayments}</camunda:outputParameter>
          <camunda:outputParameter name="paymentIds">${paymentIdentifiers}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_persist_payment</bpmn:incoming>
      <bpmn:outgoing>flow_to_reconciliation_frequency</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_reconcile_weekly" name="Reconciliar Semanalmente" camunda:type="external" camunda:topic="collection.reconcile_weekly">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="weeklyReport">${weeklyReconciliation}</camunda:outputParameter>
          <camunda:outputParameter name="weeklyTotal">${weeklyTotalAmount}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_weekly</bpmn:incoming>
      <bpmn:outgoing>flow_weekly_to_join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_reconcile_monthly" name="Reconciliar Mensalmente" camunda:type="external" camunda:topic="collection.reconcile_monthly">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="monthlyReport">${monthlyReconciliation}</camunda:outputParameter>
          <camunda:outputParameter name="monthlyTotal">${monthlyTotalAmount}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_monthly</bpmn:incoming>
      <bpmn:outgoing>flow_monthly_to_join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_flag_discrepancies" name="Sinalizar Divergências" camunda:type="external" camunda:topic="collection.flag_discrepancies">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="discrepancies">${flaggedDiscrepancies}</camunda:outputParameter>
          <camunda:outputParameter name="discrepancyCount">${totalDiscrepancies}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_flag_discrepancies</bpmn:incoming>
      <bpmn:outgoing>flow_to_archive_reconciliation</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_archive_reconciliation" name="Arquivar Reconciliação" camunda:type="external" camunda:topic="collection.archive_reconciliation">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="archiveId">${reconciliationArchiveId}</camunda:outputParameter>
          <camunda:outputParameter name="archiveStatus">archived</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_archive_reconciliation</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_success</bpmn:outgoing>
    </bpmn:serviceTask>
  </bpmn:process>
  <bpmn:error id="Error_DuplicatePayment" name="DuplicatePayment" errorCode="ERR_DUPLICATE_PAYMENT_001" />
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="SP_RC_012_Collection_Matching_Reconciliation">
      <bpmndi:BPMNShape id="start_matching_reconciliation_di" bpmnElement="start_matching_reconciliation">
        <dc:Bounds x="162" y="232" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="137" y="275" width="87" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_matching_strategy_di" bpmnElement="gateway_matching_strategy" isMarkerVisible="true">
        <dc:Bounds x="665" y="225" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="657" y="282" width="66" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_matching_join_di" bpmnElement="gateway_matching_join" isMarkerVisible="true">
        <dc:Bounds x="950" y="225" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_payment_value_di" bpmnElement="gateway_payment_value" isMarkerVisible="true">
        <dc:Bounds x="1800" y="225" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1797" y="282" width="57" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_payment_value_join_di" bpmnElement="gateway_payment_value_join" isMarkerVisible="true">
        <dc:Bounds x="2050" y="225" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_reconciliation_frequency_di" bpmnElement="gateway_reconciliation_frequency" isMarkerVisible="true">
        <dc:Bounds x="2300" y="225" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2290" y="282" width="71" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gateway_reconciliation_join_di" bpmnElement="gateway_reconciliation_join" isMarkerVisible="true">
        <dc:Bounds x="2550" y="225" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_success_di" bpmnElement="end_success">
        <dc:Bounds x="2950" y="232" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2934" y="275" width="69" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_error_di" bpmnElement="end_error">
        <dc:Bounds x="1232" y="382" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1213" y="425" width="74" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1e78glm_di" bpmnElement="task_parse_payment_file">
        <dc:Bounds x="230" y="210" width="100" height="80" />
