      <bpmndi:BPMNShape id="Shape_gateway_auth_status" bpmnElement="gateway_auth_status" isMarkerVisible="true" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="1175" y="435" width="50" height="50" />
