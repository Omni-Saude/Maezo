      <bpmndi:BPMNShape id="Shape_end_approved" bpmnElement="end_approved" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="1502" y="242" width="36" height="36" />
