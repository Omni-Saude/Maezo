        <di:waypoint x="198" y="460" />
        <di:waypoint x="260" y="460" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_check_to_dmn_di" bpmnElement="Flow_check_to_dmn" bioc:stroke="#0d4372" color:border-color="#0d4372">
        <di:waypoint x="360" y="460" />
        <di:waypoint x="450" y="460" />
