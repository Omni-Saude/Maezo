<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_RC008" targetNamespace="http://cib7.healthcare/revenue-cycle" exporter="Camunda Modeler" exporterVersion="5.42.0">
  <bpmn:process id="SP_RC_008_Revenue_Collection" name="Cobrança e Recebimento" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="start_collection" name="Início Cobrança">
      <bpmn:outgoing>flow_to_identify_overdue</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="task_prioritize_collection" name="Priorizar Cobrança" camunda:type="external" camunda:topic="collection.prioritize_collection">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="accounts">${accountsOverdue}</camunda:inputParameter>
          <camunda:outputParameter name="accountsByPriority">${prioritizedAccounts}</camunda:outputParameter>
          <camunda:outputParameter name="urgentCount">${highPriorityCount}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_prioritize</bpmn:incoming>
      <bpmn:outgoing>flow_to_dmn_payment</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:businessRuleTask id="dmn_payment_method" name="Método de Pagamento" camunda:resultVariable="paymentMethodRules" camunda:decisionRef="cash_operations_payment_method" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>flow_to_dmn_payment</bpmn:incoming>
      <bpmn:outgoing>flow_to_dmn_discount</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:businessRuleTask id="dmn_discount_rules" name="Regras de Desconto" camunda:resultVariable="discountRules" camunda:decisionRef="cash_operations_discount" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>flow_to_dmn_discount</bpmn:incoming>
      <bpmn:outgoing>flow_to_receive_payment</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:serviceTask id="task_receive_payment_notification" name="Receber Notificação de Pagamento" camunda:type="external" camunda:topic="revenue_cycle.receive_payment_notification">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="accounts">${accountsByPriority}</camunda:inputParameter>
          <camunda:outputParameter name="receivedPayments">${payments}</camunda:outputParameter>
          <camunda:outputParameter name="receiptDate">${paymentDate}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1wa311o</bpmn:incoming>
      <bpmn:outgoing>Flow_074gphk</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="timer_payment_followup" name="após 7d" attachedToRef="task_receive_payment_notification">
      <bpmn:outgoing>flow_to_followup</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P7D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:userTask id="task_manual_matching" name="Notificar&#10;pendência">
      <bpmn:incoming>Flow_0cwti5n</bpmn:incoming>
      <bpmn:outgoing>Flow_14scllb</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="end_success" name="Recebimento Concluído">
      <bpmn:incoming>flow_to_end_success</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="end_followup" name="Seguimento Necessário">
      <bpmn:incoming>flow_to_end_followup</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_to_identify_overdue" sourceRef="start_collection" targetRef="task_identify_overdue" />
    <bpmn:sequenceFlow id="flow_to_prioritize" sourceRef="task_identify_overdue" targetRef="task_prioritize_collection" />
    <bpmn:sequenceFlow id="flow_to_dmn_payment" sourceRef="task_prioritize_collection" targetRef="dmn_payment_method" />
    <bpmn:sequenceFlow id="flow_to_dmn_discount" sourceRef="dmn_payment_method" targetRef="dmn_discount_rules" />
    <bpmn:sequenceFlow id="flow_to_receive_payment" sourceRef="dmn_discount_rules" targetRef="Activity_1xuuwke" />
    <bpmn:sequenceFlow id="flow_to_matching_gateway" sourceRef="task_auto_matching" targetRef="Gateway_0crumd0" />
    <bpmn:sequenceFlow id="flow_to_followup" sourceRef="timer_payment_followup" targetRef="task_payment_followup" />
    <bpmn:sequenceFlow id="flow_to_end_success" sourceRef="task_update_ar" targetRef="end_success" />
    <bpmn:sequenceFlow id="flow_to_end_followup" sourceRef="task_payment_followup" targetRef="end_followup" />
    <bpmn:task id="task_identify_overdue" name="Identificar Contas Vencidas">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="accountsOverdue">${overdueAccounts}</camunda:outputParameter>
          <camunda:outputParameter name="overdueAmount">${totalOverdue}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_identify_overdue</bpmn:incoming>
      <bpmn:outgoing>flow_to_prioritize</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_update_ar" name="Atualizar&#10;CR">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="currentAR">${updatedAR}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0s44vy5</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_success</bpmn:outgoing>
    </bpmn:task>
    <bpmn:businessRuleTask id="Activity_1xuuwke" name="Estimar Recebimento" camunda:resultVariable="paymentEstimate" camunda:decisionRef="cash_operations_estimate" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>flow_to_receive_payment</bpmn:incoming>
      <bpmn:outgoing>Flow_1wa311o</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:sequenceFlow id="Flow_1wa311o" sourceRef="Activity_1xuuwke" targetRef="task_receive_payment_notification" />
    <bpmn:boundaryEvent id="Event_1i38a2s" attachedToRef="task_auto_matching">
      <bpmn:outgoing>Flow_0cwti5n</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_1dampiy" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_0cwti5n" name="erro na&#10;conciliação" sourceRef="Event_1i38a2s" targetRef="task_manual_matching" />
    <bpmn:intermediateThrowEvent id="Event_0910zjh" name="concliação&#10;manual">
      <bpmn:incoming>Flow_14scllb</bpmn:incoming>
      <bpmn:outgoing>Flow_1t6ezni</bpmn:outgoing>
    </bpmn:intermediateThrowEvent>
    <bpmn:sequenceFlow id="Flow_14scllb" sourceRef="task_manual_matching" targetRef="Event_0910zjh" />
    <bpmn:sequenceFlow id="Flow_074gphk" sourceRef="task_receive_payment_notification" targetRef="task_auto_matching" />
    <bpmn:exclusiveGateway id="Gateway_0crumd0">
      <bpmn:incoming>flow_to_matching_gateway</bpmn:incoming>
      <bpmn:incoming>Flow_1t6ezni</bpmn:incoming>
      <bpmn:outgoing>Flow_0s44vy5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0s44vy5" sourceRef="Gateway_0crumd0" targetRef="task_update_ar" />
    <bpmn:sequenceFlow id="Flow_1t6ezni" sourceRef="Event_0910zjh" targetRef="Gateway_0crumd0" />
    <bpmn:task id="task_payment_followup" name="Seguimento de Pagamento">
      <bpmn:incoming>flow_to_followup</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_followup</bpmn:outgoing>
    </bpmn:task>
    <bpmn:callActivity id="task_auto_matching" name="Conciliação Automática" calledElement="SP_RC_008B_Payment_Reconciliation">
      <bpmn:extensionElements>
        <camunda:in source="receivedPayments" target="payments" />
        <camunda:in source="accountsOverdue" target="openAccounts" />
        <camunda:out source="matchedPayments" target="reconciledPayments" />
        <camunda:out source="unmatchedPayments" target="pendingReconciliation" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_074gphk</bpmn:incoming>
      <bpmn:outgoing>flow_to_matching_gateway</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:textAnnotation id="TextAnnotation_1wenlx5">
      <bpmn:text>SP-RC-008B</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0oax7jp" associationDirection="None" sourceRef="task_auto_matching" targetRef="TextAnnotation_1wenlx5" />
  </bpmn:process>
  <bpmn:error id="Error_MatchingFailed" name="MatchingFailed" errorCode="ERR_MATCHING_001" />
  <bpmndi:BPMNDiagram id="BPMNDiagram_RC008">
    <bpmndi:BPMNPlane id="BPMNPlane_RC008" bpmnElement="SP_RC_008_Revenue_Collection">
