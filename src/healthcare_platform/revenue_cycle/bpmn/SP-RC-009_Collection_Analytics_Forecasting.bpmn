<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_RC009A" targetNamespace="http://cib7.healthcare/revenue-cycle" exporter="Camunda Modeler" exporterVersion="5.42.0">
  <bpmn:process id="SP_RC_009_Collection_Analytics_Forecasting" name="Análise e Previsão de Cobrança" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:parallelGateway id="Gateway_AnalyticsSplit">
      <bpmn:incoming>Flow_ToParallelSplit</bpmn:incoming>
      <bpmn:outgoing>Flow_ToDSO</bpmn:outgoing>
      <bpmn:outgoing>Flow_ToCollectionRate</bpmn:outgoing>
      <bpmn:outgoing>Flow_ToVariance</bpmn:outgoing>
      <bpmn:outgoing>Flow_ToRevenueCycleTime</bpmn:outgoing>
      <bpmn:outgoing>Flow_ToPayerPerformance</bpmn:outgoing>
      <bpmn:outgoing>Flow_ToRevenueLeakage</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:serviceTask id="Task_CalculateDSO" name="Calcular DSO" camunda:type="external" camunda:topic="collection.calculate_dso">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="periodStart">${periodStart}</camunda:inputParameter>
          <camunda:inputParameter name="periodEnd">${periodEnd}</camunda:inputParameter>
          <camunda:inputParameter name="tenantId">${tenantId}</camunda:inputParameter>
          <camunda:outputParameter name="dsoValue">${dsoValue}</camunda:outputParameter>
          <camunda:outputParameter name="dsoTrend">${dsoTrend}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToDSO</bpmn:incoming>
      <bpmn:outgoing>Flow_FromDSO</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_CalculateCollectionRate" name="Calcular Taxa de Cobrança" camunda:type="external" camunda:topic="collection.calculate_collection_rate">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="periodStart">${periodStart}</camunda:inputParameter>
          <camunda:inputParameter name="periodEnd">${periodEnd}</camunda:inputParameter>
          <camunda:inputParameter name="tenantId">${tenantId}</camunda:inputParameter>
          <camunda:outputParameter name="collectionRate">${collectionRate}</camunda:outputParameter>
          <camunda:outputParameter name="collectionTrend">${collectionTrend}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToCollectionRate</bpmn:incoming>
      <bpmn:outgoing>Flow_FromCollectionRate</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_CalculateVariance" name="Calcular Variância" camunda:type="external" camunda:topic="collection.calculate_variance">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="periodStart">${periodStart}</camunda:inputParameter>
          <camunda:inputParameter name="periodEnd">${periodEnd}</camunda:inputParameter>
          <camunda:inputParameter name="tenantId">${tenantId}</camunda:inputParameter>
          <camunda:outputParameter name="varianceAmount">${varianceAmount}</camunda:outputParameter>
          <camunda:outputParameter name="variancePercentage">${variancePercentage}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToVariance</bpmn:incoming>
      <bpmn:outgoing>Flow_FromVariance</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_CalculateRevenueCycleTime" name="Calcular Tempo do Ciclo de Receita" camunda:type="external" camunda:topic="collection.calculate_revenue_cycle_time">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="periodStart">${periodStart}</camunda:inputParameter>
          <camunda:inputParameter name="periodEnd">${periodEnd}</camunda:inputParameter>
          <camunda:inputParameter name="tenantId">${tenantId}</camunda:inputParameter>
          <camunda:outputParameter name="avgCycleTimeDays">${avgCycleTimeDays}</camunda:outputParameter>
          <camunda:outputParameter name="cycleTimeByStage">${cycleTimeByStage}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToRevenueCycleTime</bpmn:incoming>
      <bpmn:outgoing>Flow_FromRevenueCycleTime</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_AnalyzePayerPerformance" name="Analisar Desempenho de Operadoras" camunda:type="external" camunda:topic="collection.analyze_payer_performance">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="periodStart">${periodStart}</camunda:inputParameter>
          <camunda:inputParameter name="periodEnd">${periodEnd}</camunda:inputParameter>
          <camunda:inputParameter name="tenantId">${tenantId}</camunda:inputParameter>
          <camunda:outputParameter name="payerMetrics">${payerMetrics}</camunda:outputParameter>
          <camunda:outputParameter name="slowPayersList">${slowPayersList}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToPayerPerformance</bpmn:incoming>
      <bpmn:outgoing>Flow_FromPayerPerformance</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_DetectRevenueLeakage" name="Detectar Vazamento de Receita" camunda:type="external" camunda:topic="collection.detect_revenue_leakage">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="periodStart">${periodStart}</camunda:inputParameter>
          <camunda:inputParameter name="periodEnd">${periodEnd}</camunda:inputParameter>
          <camunda:inputParameter name="tenantId">${tenantId}</camunda:inputParameter>
          <camunda:outputParameter name="leakageAmount">${leakageAmount}</camunda:outputParameter>
          <camunda:outputParameter name="leakageSources">${leakageSources}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToRevenueLeakage</bpmn:incoming>
      <bpmn:outgoing>Flow_FromRevenueLeakage</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:parallelGateway id="Gateway_AnalyticsJoin">
      <bpmn:incoming>Flow_FromDSO</bpmn:incoming>
      <bpmn:incoming>Flow_FromCollectionRate</bpmn:incoming>
      <bpmn:incoming>Flow_FromVariance</bpmn:incoming>
      <bpmn:incoming>Flow_FromRevenueCycleTime</bpmn:incoming>
      <bpmn:incoming>Flow_FromPayerPerformance</bpmn:incoming>
      <bpmn:incoming>Flow_FromRevenueLeakage</bpmn:incoming>
      <bpmn:outgoing>Flow_17eajta</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:serviceTask id="Task_GenerateExecutiveDashboard" name="Gerar Dashboard Executivo" camunda:type="external" camunda:topic="collection.generate_executive_dashboard">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="dsoValue">${dsoValue}</camunda:inputParameter>
          <camunda:inputParameter name="collectionRate">${collectionRate}</camunda:inputParameter>
          <camunda:inputParameter name="varianceAmount">${varianceAmount}</camunda:inputParameter>
          <camunda:inputParameter name="avgCycleTimeDays">${avgCycleTimeDays}</camunda:inputParameter>
          <camunda:inputParameter name="payerMetrics">${payerMetrics}</camunda:inputParameter>
          <camunda:inputParameter name="leakageAmount">${leakageAmount}</camunda:inputParameter>
          <camunda:inputParameter name="tenantId">${tenantId}</camunda:inputParameter>
          <camunda:outputParameter name="dashboardUrl">${dashboardUrl}</camunda:outputParameter>
          <camunda:outputParameter name="reportGenerated">${reportGenerated}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_041os34</bpmn:incoming>
      <bpmn:outgoing>Flow_1aic46q</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_PredictCollectionDate" name="Prever Data de Cobrança" camunda:type="external" camunda:topic="collection.predict_collection_date">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="accounts">${accounts}</camunda:inputParameter>
          <camunda:inputParameter name="payerMetrics">${payerMetrics}</camunda:inputParameter>
          <camunda:inputParameter name="tenantId">${tenantId}</camunda:inputParameter>
          <camunda:outputParameter name="predictedDates">${predictedDates}</camunda:outputParameter>
          <camunda:outputParameter name="confidenceScores">${confidenceScores}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0bp5htv</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSlowPayers</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_IdentifySlowPayers" name="Identificar Pagadores Lentos" camunda:type="external" camunda:topic="collection.identify_slow_payers">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="accounts">${accounts}</camunda:inputParameter>
          <camunda:inputParameter name="predictedDates">${predictedDates}</camunda:inputParameter>
          <camunda:inputParameter name="slowPayerThresholdDays">60</camunda:inputParameter>
          <camunda:inputParameter name="tenantId">${tenantId}</camunda:inputParameter>
          <camunda:outputParameter name="slowPayersDetected">${slowPayersDetected}</camunda:outputParameter>
          <camunda:outputParameter name="slowPayerAccounts">${slowPayerAccounts}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToSlowPayers</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSlowPayerGateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_SlowPayerCheck" name="Pagador Lento?" default="Flow_NoSlowPayer">
      <bpmn:incoming>Flow_ToSlowPayerGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_YesSlowPayer</bpmn:outgoing>
      <bpmn:outgoing>Flow_NoSlowPayer</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_NegotiatePaymentPlan" name="Negociar Plano de Pagamento" camunda:type="external" camunda:topic="collection.negotiate_payment_plan">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="slowPayerAccounts">${slowPayerAccounts}</camunda:inputParameter>
          <camunda:inputParameter name="tenantId">${tenantId}</camunda:inputParameter>
          <camunda:outputParameter name="paymentPlansCreated">${paymentPlansCreated}</camunda:outputParameter>
          <camunda:outputParameter name="negotiationResults">${negotiationResults}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_YesSlowPayer</bpmn:incoming>
      <bpmn:outgoing>Flow_ToPenalties</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_ApplyPenalties" name="Aplicar Penalidades" camunda:type="external" camunda:topic="collection.apply_penalties">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="accounts">${slowPayerAccounts}</camunda:inputParameter>
          <camunda:inputParameter name="negotiationResults">${negotiationResults}</camunda:inputParameter>
          <camunda:inputParameter name="penaltyRate">0.02</camunda:inputParameter>
          <camunda:inputParameter name="tenantId">${tenantId}</camunda:inputParameter>
          <camunda:outputParameter name="penaltiesApplied">${penaltiesApplied}</camunda:outputParameter>
          <camunda:outputParameter name="penaltyAmount">${penaltyAmount}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToPenalties</bpmn:incoming>
      <bpmn:outgoing>Flow_FromSlowPayerPath</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_ApplyContractualAdjustments" name="Aplicar Ajustes Contratuais" camunda:type="external" camunda:topic="collection.apply_contractual_adjustments">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="accounts">${accounts}</camunda:inputParameter>
          <camunda:inputParameter name="payerMetrics">${payerMetrics}</camunda:inputParameter>
          <camunda:inputParameter name="tenantId">${tenantId}</camunda:inputParameter>
          <camunda:outputParameter name="adjustmentsApplied">${adjustmentsApplied}</camunda:outputParameter>
          <camunda:outputParameter name="adjustmentAmount">${adjustmentAmount}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_NoSlowPayer</bpmn:incoming>
      <bpmn:outgoing>Flow_FromNormalPath</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_PathMerge">
      <bpmn:incoming>Flow_FromSlowPayerPath</bpmn:incoming>
      <bpmn:incoming>Flow_FromNormalPath</bpmn:incoming>
      <bpmn:outgoing>Flow_ToUpdateForecasts</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_UpdateForecasts" name="Atualizar Projeções" camunda:type="external" camunda:topic="collection.update_forecasts">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="predictedDates">${predictedDates}</camunda:inputParameter>
          <camunda:inputParameter name="paymentPlansCreated">${paymentPlansCreated}</camunda:inputParameter>
          <camunda:inputParameter name="adjustmentsApplied">${adjustmentsApplied}</camunda:inputParameter>
          <camunda:inputParameter name="penaltiesApplied">${penaltiesApplied}</camunda:inputParameter>
          <camunda:inputParameter name="tenantId">${tenantId}</camunda:inputParameter>
          <camunda:outputParameter name="forecastsUpdated">${forecastsUpdated}</camunda:outputParameter>
          <camunda:outputParameter name="projectedRevenue">${projectedRevenue}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToUpdateForecasts</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEnd</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_CollectionAnalyticsComplete" name="Análise Completa">
      <bpmn:incoming>Flow_ToEnd</bpmn:incoming>
      <bpmn:messageEventDefinition id="MessageEventDefinition_1" messageRef="Message_CollectionAnalyticsComplete" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_ToParallelSplit" sourceRef="StartEvent_CollectionAnalytics" targetRef="Gateway_AnalyticsSplit" />
    <bpmn:sequenceFlow id="Flow_ToDSO" sourceRef="Gateway_AnalyticsSplit" targetRef="Task_CalculateDSO" />
    <bpmn:sequenceFlow id="Flow_ToCollectionRate" sourceRef="Gateway_AnalyticsSplit" targetRef="Task_CalculateCollectionRate" />
    <bpmn:sequenceFlow id="Flow_ToVariance" sourceRef="Gateway_AnalyticsSplit" targetRef="Task_CalculateVariance" />
    <bpmn:sequenceFlow id="Flow_ToRevenueCycleTime" sourceRef="Gateway_AnalyticsSplit" targetRef="Task_CalculateRevenueCycleTime" />
    <bpmn:sequenceFlow id="Flow_ToPayerPerformance" sourceRef="Gateway_AnalyticsSplit" targetRef="Task_AnalyzePayerPerformance" />
    <bpmn:sequenceFlow id="Flow_ToRevenueLeakage" sourceRef="Gateway_AnalyticsSplit" targetRef="Task_DetectRevenueLeakage" />
    <bpmn:sequenceFlow id="Flow_FromDSO" sourceRef="Task_CalculateDSO" targetRef="Gateway_AnalyticsJoin" />
    <bpmn:sequenceFlow id="Flow_FromCollectionRate" sourceRef="Task_CalculateCollectionRate" targetRef="Gateway_AnalyticsJoin" />
    <bpmn:sequenceFlow id="Flow_FromVariance" sourceRef="Task_CalculateVariance" targetRef="Gateway_AnalyticsJoin" />
    <bpmn:sequenceFlow id="Flow_FromRevenueCycleTime" sourceRef="Task_CalculateRevenueCycleTime" targetRef="Gateway_AnalyticsJoin" />
    <bpmn:sequenceFlow id="Flow_FromPayerPerformance" sourceRef="Task_AnalyzePayerPerformance" targetRef="Gateway_AnalyticsJoin" />
    <bpmn:sequenceFlow id="Flow_FromRevenueLeakage" sourceRef="Task_DetectRevenueLeakage" targetRef="Gateway_AnalyticsJoin" />
    <bpmn:sequenceFlow id="Flow_ToSlowPayers" sourceRef="Task_PredictCollectionDate" targetRef="Task_IdentifySlowPayers" />
    <bpmn:sequenceFlow id="Flow_ToSlowPayerGateway" sourceRef="Task_IdentifySlowPayers" targetRef="Gateway_SlowPayerCheck" />
    <bpmn:sequenceFlow id="Flow_YesSlowPayer" name="Sim" sourceRef="Gateway_SlowPayerCheck" targetRef="Task_NegotiatePaymentPlan">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${slowPayersDetected == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NoSlowPayer" name="Não" sourceRef="Gateway_SlowPayerCheck" targetRef="Task_ApplyContractualAdjustments" />
    <bpmn:sequenceFlow id="Flow_ToPenalties" sourceRef="Task_NegotiatePaymentPlan" targetRef="Task_ApplyPenalties" />
    <bpmn:sequenceFlow id="Flow_FromSlowPayerPath" sourceRef="Task_ApplyPenalties" targetRef="Gateway_PathMerge" />
    <bpmn:sequenceFlow id="Flow_FromNormalPath" sourceRef="Task_ApplyContractualAdjustments" targetRef="Gateway_PathMerge" />
    <bpmn:sequenceFlow id="Flow_ToUpdateForecasts" sourceRef="Gateway_PathMerge" targetRef="Task_UpdateForecasts" />
    <bpmn:sequenceFlow id="Flow_ToEnd" sourceRef="Task_UpdateForecasts" targetRef="EndEvent_CollectionAnalyticsComplete" />
    <bpmn:startEvent id="StartEvent_CollectionAnalytics" name="Iniciar Análise&#10;(ciclo diário)">
      <bpmn:outgoing>Flow_ToParallelSplit</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_15efmrv">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">0 0 6 * * ?</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:startEvent>
    <bpmn:parallelGateway id="parallel_dashboard_start" name="Gerar Dashboards">
      <bpmn:incoming>Flow_17eajta</bpmn:incoming>
      <bpmn:outgoing>flow_to_operational_metrics</bpmn:outgoing>
      <bpmn:outgoing>Flow_041os34</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:serviceTask id="task_generate_operational_metrics" name="Gerar Métricas Operacionais" camunda:type="external" camunda:topic="analytics.generate_operational_metrics">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="dsoTrend">${dsoTrendData}</camunda:inputParameter>
          <camunda:inputParameter name="payerMetrics">${collectionByPayer}</camunda:inputParameter>
          <camunda:outputParameter name="metricsData">${operationalMetrics}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_operational_metrics</bpmn:incoming>
      <bpmn:outgoing>flow_operational_to_join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:parallelGateway id="parallel_dashboard_join" name="Combinar Dashboards">
      <bpmn:incoming>flow_operational_to_join</bpmn:incoming>
      <bpmn:incoming>Flow_1aic46q</bpmn:incoming>
      <bpmn:outgoing>Flow_0bp5htv</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:sequenceFlow id="flow_to_operational_metrics" sourceRef="parallel_dashboard_start" targetRef="task_generate_operational_metrics" />
    <bpmn:sequenceFlow id="flow_operational_to_join" sourceRef="task_generate_operational_metrics" targetRef="parallel_dashboard_join" />
    <bpmn:sequenceFlow id="Flow_17eajta" sourceRef="Gateway_AnalyticsJoin" targetRef="parallel_dashboard_start" />
    <bpmn:sequenceFlow id="Flow_1aic46q" sourceRef="Task_GenerateExecutiveDashboard" targetRef="parallel_dashboard_join" />
    <bpmn:sequenceFlow id="Flow_041os34" sourceRef="parallel_dashboard_start" targetRef="Task_GenerateExecutiveDashboard" />
    <bpmn:sequenceFlow id="Flow_0bp5htv" sourceRef="parallel_dashboard_join" targetRef="Task_PredictCollectionDate" />
  </bpmn:process>
  <bpmn:message id="Message_CollectionAnalyticsComplete" name="Message_CollectionAnalyticsComplete" />
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="SP_RC_009_Collection_Analytics_Forecasting">
      <bpmndi:BPMNShape id="Gateway_AnalyticsSplit_di" bpmnElement="Gateway_AnalyticsSplit" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="255" y="505" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="169.5" y="473" width="75" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CalculateDSO_di" bpmnElement="Task_CalculateDSO" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="360" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CalculateCollectionRate_di" bpmnElement="Task_CalculateCollectionRate" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="360" y="230" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CalculateVariance_di" bpmnElement="Task_CalculateVariance" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="360" y="340" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CalculateRevenueCycleTime_di" bpmnElement="Task_CalculateRevenueCycleTime" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="360" y="490" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AnalyzePayerPerformance_di" bpmnElement="Task_AnalyzePayerPerformance" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="360" y="630" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DetectRevenueLeakage_di" bpmnElement="Task_DetectRevenueLeakage" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="360" y="740" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AnalyticsJoin_di" bpmnElement="Gateway_AnalyticsJoin" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="515" y="505" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="575" y="473" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GenerateExecutiveDashboard_di" bpmnElement="Task_GenerateExecutiveDashboard" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="740" y="390" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PredictCollectionDate_di" bpmnElement="Task_PredictCollectionDate" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="1040" y="490" width="100" height="80" />
