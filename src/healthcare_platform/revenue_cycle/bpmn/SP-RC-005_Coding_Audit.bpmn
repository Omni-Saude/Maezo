<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_RC005" targetNamespace="http://cib7.healthcare/revenue-cycle" exporter="Camunda Modeler" exporterVersion="5.42.0">
  <bpmn:process id="SP_RC_005_Coding_Audit" name="Codificação e Auditoria" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="start_coding_audit" name="Início Codificação">
      <bpmn:outgoing>flow_to_extract_clinical</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="gateway_fraud_risk" name="Alto Risco?" default="flow_high_risk">
      <bpmn:incoming>flow_to_fraud_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_low_risk</bpmn:outgoing>
      <bpmn:outgoing>flow_high_risk</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="end_success" name="Codificação Auditada">
      <bpmn:incoming>flow_to_end_success</bpmn:incoming>
      <bpmn:incoming>Flow_0gb3434</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_to_extract_clinical" sourceRef="start_coding_audit" targetRef="task_extract_clinical_data" />
    <bpmn:sequenceFlow id="flow_to_suggest_cid10" sourceRef="task_extract_clinical_data" targetRef="task_suggest_cid10" />
    <bpmn:sequenceFlow id="flow_to_suggest_tuss" sourceRef="task_suggest_cid10" targetRef="Activity_0fz3rg1" />
    <bpmn:sequenceFlow id="flow_to_dmn_frequency" sourceRef="dmn_duplicate_detection" targetRef="dmn_unbundling" />
    <bpmn:sequenceFlow id="flow_to_detect_fraud" sourceRef="dmn_unbundling" targetRef="Gateway_13arf5h" />
    <bpmn:sequenceFlow id="flow_to_fraud_gateway" sourceRef="task_detect_fraud" targetRef="gateway_fraud_risk" />
    <bpmn:sequenceFlow id="flow_low_risk" name="Não" sourceRef="gateway_fraud_risk" targetRef="task_audit_coding">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${fraudRiskScore &lt; 0.7}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_high_risk" name="Sim" sourceRef="gateway_fraud_risk" targetRef="task_fraud_review" />
    <bpmn:sequenceFlow id="flow_to_end_success" sourceRef="task_audit_coding" targetRef="end_success" />
    <bpmn:sequenceFlow id="Flow_1pdp8cx" sourceRef="Activity_0fz3rg1" targetRef="task_suggest_tuss" />
    <bpmn:sequenceFlow id="Flow_1e5a90e" sourceRef="task_suggest_tuss" targetRef="task_check_compatibility" />
    <bpmn:sequenceFlow id="Flow_0vhhwa0" sourceRef="task_check_compatibility" targetRef="dmn_duplicate_detection" />
    <bpmn:exclusiveGateway id="Gateway_13arf5h">
      <bpmn:incoming>flow_to_detect_fraud</bpmn:incoming>
      <bpmn:incoming>Flow_16c20wx</bpmn:incoming>
      <bpmn:outgoing>Flow_1n95mlg</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1n95mlg" sourceRef="Gateway_13arf5h" targetRef="task_detect_fraud" />
    <bpmn:sequenceFlow id="Flow_10l1ts9" sourceRef="task_fraud_review" targetRef="Event_0p756nf" />
    <bpmn:sequenceFlow id="Flow_16c20wx" sourceRef="Event_0p756nf" targetRef="Gateway_13arf5h" />
    <bpmn:intermediateCatchEvent id="Event_0p756nf" name="após 24 horas">
      <bpmn:incoming>Flow_10l1ts9</bpmn:incoming>
      <bpmn:outgoing>Flow_16c20wx</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1yc5s8t">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT24H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="task_extract_clinical_data" name="Extrair Dados Clínicos" camunda:type="external" camunda:topic="revenue_cycle.coding.extract_clinical_data">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="clinicalExtract">${extractedData}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_extract_clinical</bpmn:incoming>
      <bpmn:outgoing>flow_to_suggest_cid10</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_suggest_cid10" name="Sugerir Códigos CID-10" camunda:type="external" camunda:topic="revenue_cycle.coding.suggest_cid10">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="icd10Suggestions">${suggestedCodes}</camunda:outputParameter>
          <camunda:outputParameter name="icd10Confidence">${confidence}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_suggest_cid10</bpmn:incoming>
      <bpmn:outgoing>flow_to_suggest_tuss</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_0fz3rg1" name="Verificar&#10;contrato" camunda:type="external" camunda:topic="revenue_cycle.coding.verify_contract">
      <bpmn:incoming>flow_to_suggest_tuss</bpmn:incoming>
      <bpmn:outgoing>Flow_1pdp8cx</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_suggest_tuss" name="Sugerir Códigos TUSS" camunda:type="external" camunda:topic="revenue_cycle.coding.suggest_tuss">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="tussSuggestions">${suggestedProcedures}</camunda:outputParameter>
          <camunda:outputParameter name="tussConfidence">${confidence}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1pdp8cx</bpmn:incoming>
      <bpmn:outgoing>Flow_1e5a90e</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_check_compatibility" name="Verificar&#10;Compatibilidade" camunda:type="external" camunda:topic="revenue_cycle.coding.check_compatibility">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="isCompatible">${compatibilityResult}</camunda:outputParameter>
          <camunda:outputParameter name="incompatiblePairs">${incompatibilities}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1e5a90e</bpmn:incoming>
      <bpmn:outgoing>Flow_0vhhwa0</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_detect_fraud" name="Detectar Padrões de Fraude" camunda:type="external" camunda:topic="revenue_cycle.coding.detect_fraud">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="fraudRiskScore">${fraudScore}</camunda:outputParameter>
          <camunda:outputParameter name="indicators">${fraudIndicators}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1n95mlg</bpmn:incoming>
      <bpmn:outgoing>flow_to_fraud_gateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="task_fraud_review" name="Notificar&#10;pendência">
      <bpmn:incoming>flow_high_risk</bpmn:incoming>
      <bpmn:outgoing>Flow_10l1ts9</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="task_audit_coding" name="Validar Codificação">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="auditStatus">${auditResult}</camunda:outputParameter>
          <camunda:outputParameter name="findings">${auditFindings}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_low_risk</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_success</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="Event_1anl41e" attachedToRef="task_audit_coding">
      <bpmn:outgoing>Flow_0gb3434</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1wioeu3" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_0gb3434" sourceRef="Event_1anl41e" targetRef="end_success" />
    <bpmn:serviceTask id="dmn_duplicate_detection" name="Detectar Duplicatas" camunda:resultVariable="duplicateCheck">
      <bpmn:incoming>Flow_0vhhwa0</bpmn:incoming>
      <bpmn:outgoing>flow_to_dmn_frequency</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="dmn_unbundling" name="Detectar Unbundling" camunda:resultVariable="unbundlingCheck">
      <bpmn:incoming>flow_to_dmn_frequency</bpmn:incoming>
      <bpmn:outgoing>flow_to_detect_fraud</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:textAnnotation id="TextAnnotation_19gz2zh">
      <bpmn:text>detectar itens fora do pacote</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0mwi1mo" associationDirection="None" sourceRef="dmn_unbundling" targetRef="TextAnnotation_19gz2zh" />
    <bpmn:textAnnotation id="TextAnnotation_1e5zz2u">
      <bpmn:text>sugerir codificação</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0mekvzl" associationDirection="None" sourceRef="task_suggest_tuss" targetRef="TextAnnotation_1e5zz2u" />
    <bpmn:textAnnotation id="TextAnnotation_1dv7wkn">
      <bpmn:text>cobertura contratual</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1gse8n1" associationDirection="None" sourceRef="Activity_0fz3rg1" targetRef="TextAnnotation_1dv7wkn" />
    <bpmn:textAnnotation id="TextAnnotation_06wlbnl">
      <bpmn:text>revisar lançamento</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1nsm4l8" associationDirection="None" sourceRef="task_fraud_review" targetRef="TextAnnotation_06wlbnl" />
    <bpmn:group id="Group_0e45kfp" />
    <bpmn:textAnnotation id="TextAnnotation_130zjvw">
      <bpmn:text>Agente auditor com IA</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1nrsjh1" associationDirection="None" sourceRef="Group_0e45kfp" targetRef="TextAnnotation_130zjvw" />
    <bpmn:textAnnotation id="TextAnnotation_0gqqzs1">
      <bpmn:text>Algoritmo de ML p fraude</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0s8ek8d" associationDirection="None" sourceRef="task_detect_fraud" targetRef="TextAnnotation_0gqqzs1" />
    <bpmn:textAnnotation id="TextAnnotation_1e6skuq">
      <bpmn:text>Timer para não travar o processo</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1j2urr0" associationDirection="None" sourceRef="Event_1anl41e" targetRef="TextAnnotation_1e6skuq" />
    <bpmn:textAnnotation id="TextAnnotation_0aatcms">
      <bpmn:text>Rodrigo acha desnecessario</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0y6dxtz" associationDirection="None" sourceRef="task_suggest_cid10" targetRef="TextAnnotation_0aatcms" />
    <bpmn:textAnnotation id="TextAnnotation_1axa6b9">
      <bpmn:text>Rodrigo acha desnecessario</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0s0gg2b" associationDirection="None" sourceRef="Activity_0fz3rg1" targetRef="TextAnnotation_1axa6b9" />
  </bpmn:process>
