<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_RC010" targetNamespace="http://cib7.healthcare/revenue-cycle" exporter="Camunda Modeler" exporterVersion="5.35.0">
  <bpmn:process id="SP_RC_010_Maximization" name="Maximização de Receita" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="start_maximization" name="Início Maximização">
      <bpmn:outgoing>flow_to_predict_collection</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="task_predict_collection_date" name="Prever Data de Cobrança" camunda:type="external" camunda:topic="revenue_cycle.predict_collection_date">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="accounts">${accountIds}</camunda:inputParameter>
          <camunda:inputParameter name="history">${historicalData}</camunda:inputParameter>
          <camunda:outputParameter name="collectionDatePredictions">${predictedDates}</camunda:outputParameter>
          <camunda:outputParameter name="predictionConfidence">${confidenceScores}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_predict_collection</bpmn:incoming>
      <bpmn:outgoing>flow_to_identify_slow_payers</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_identify_slow_payers" name="Identificar Pagadores Lentos" camunda:type="external" camunda:topic="revenue_cycle.identify_slow_payers">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="predictions">${collectionDatePredictions}</camunda:inputParameter>
          <camunda:inputParameter name="payerHistory">${payerPerformanceData}</camunda:inputParameter>
          <camunda:outputParameter name="identifiedSlowPayers">${slowPayers}</camunda:outputParameter>
          <camunda:outputParameter name="payerRiskScores">${riskScores}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_identify_slow_payers</bpmn:incoming>
      <bpmn:outgoing>flow_to_risk_gateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gateway_risk_assessment" name="Alto Risco?" default="flow_high_risk">
      <bpmn:incoming>flow_to_risk_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_low_risk</bpmn:outgoing>
      <bpmn:outgoing>flow_high_risk</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:businessRuleTask id="dmn_optimization_strategy" name="Estratégia de Otimização" camunda:resultVariable="optimizationPlan" camunda:decisionRef="revenue_optimization_strategy" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>flow_low_risk</bpmn:incoming>
      <bpmn:outgoing>flow_to_update_forecasts</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:serviceTask id="task_update_forecasts" name="Atualizar Projeções" camunda:type="external" camunda:topic="revenue_cycle.update_forecasts">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="predictions">${collectionDatePredictions}</camunda:inputParameter>
          <camunda:inputParameter name="strategy">${optimizationPlan}</camunda:inputParameter>
          <camunda:outputParameter name="revenueForecasts">${updatedForecasts}</camunda:outputParameter>
          <camunda:outputParameter name="accuracyMetrics">${forecastAccuracy}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_update_forecasts</bpmn:incoming>
      <bpmn:outgoing>flow_to_analyze_opportunities</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_analyze_opportunities" name="Analisar Oportunidades" camunda:type="external" camunda:topic="revenue_cycle.analyze_revenue_opportunities">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="forecasts">${revenueForecasts}</camunda:inputParameter>
          <camunda:inputParameter name="slowPayers">${identifiedSlowPayers}</camunda:inputParameter>
          <camunda:outputParameter name="revenueOpportunities">${opportunities}</camunda:outputParameter>
          <camunda:outputParameter name="opportunityValue">${potentialValue}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_analyze_opportunities</bpmn:incoming>
      <bpmn:outgoing>flow_to_opportunity_gateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gateway_opportunities" name="Oportunidades Identificadas?" default="flow_no_opportunities">
      <bpmn:incoming>flow_to_opportunity_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_has_opportunities</bpmn:outgoing>
      <bpmn:outgoing>flow_no_opportunities</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:parallelGateway id="parallel_optimization_start" name="Executar Otimizações">
      <bpmn:incoming>flow_has_opportunities</bpmn:incoming>
      <bpmn:outgoing>flow_to_optimize_pricing</bpmn:outgoing>
      <bpmn:outgoing>flow_to_optimize_contracts</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:serviceTask id="task_optimize_pricing" name="Otimizar Precificação" camunda:type="external" camunda:topic="revenue_cycle.optimize_pricing_strategy">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="opportunities">${revenueOpportunities}</camunda:inputParameter>
          <camunda:outputParameter name="optimizedPricing">${pricingRecommendations}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_optimize_pricing</bpmn:incoming>
      <bpmn:outgoing>flow_to_parallel_join</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_optimize_contracts" name="Otimizar Contratos" camunda:type="external" camunda:topic="revenue_cycle.optimize_contract_terms">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="slowPayers">${identifiedSlowPayers}</camunda:inputParameter>
          <camunda:inputParameter name="opportunities">${revenueOpportunities}</camunda:inputParameter>
          <camunda:outputParameter name="optimizedContracts">${contractRecommendations}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_optimize_contracts</bpmn:incoming>
      <bpmn:outgoing>flow_to_parallel_join</bpmn:outgoing>
      <bpmn:outgoing>Flow_010q9xi</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:parallelGateway id="parallel_optimization_join" name="Combinar Otimizações">
      <bpmn:incoming>flow_to_parallel_join</bpmn:incoming>
      <bpmn:incoming>flow_to_parallel_join</bpmn:incoming>
      <bpmn:incoming>Flow_010q9xi</bpmn:incoming>
      <bpmn:outgoing>flow_to_generate_action_plan</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:serviceTask id="task_generate_action_plan" name="Gerar Plano de Ação" camunda:type="external" camunda:topic="revenue_cycle.generate_maximization_action_plan">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="pricingPlan">${optimizedPricing}</camunda:inputParameter>
          <camunda:inputParameter name="contractPlan">${optimizedContracts}</camunda:inputParameter>
          <camunda:inputParameter name="expectedValue">${opportunityValue}</camunda:inputParameter>
          <camunda:outputParameter name="implementationPlan">${actionPlan}</camunda:outputParameter>
          <camunda:outputParameter name="projectedImpact">${estimatedImpact}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_generate_action_plan</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_success</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_negotiate_payment_plan" name="Negociar Plano de Pagamento" camunda:type="external" camunda:topic="revenue_cycle.negotiate_payment_plan">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="slowPayers">${identifiedSlowPayers}</camunda:inputParameter>
          <camunda:inputParameter name="riskScores">${payerRiskScores}</camunda:inputParameter>
          <camunda:outputParameter name="paymentPlans">${negotiationOutcomes}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_high_risk</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_negotiated</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="timer_forecast_cycle" name="Atualização Semanal" attachedToRef="task_update_forecasts">
      <bpmn:timerEventDefinition>
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/P7D</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:userTask id="task_review_opportunities" name="Revisar Oportunidades">
      <bpmn:incoming>flow_no_opportunities</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_review</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="end_success" name="Plano de Maximização Gerado">
      <bpmn:incoming>flow_to_end_success</bpmn:incoming>
      <bpmn:messageEventDefinition messageRef="Message_MaximizationComplete" />
    </bpmn:endEvent>
    <bpmn:endEvent id="end_negotiated" name="Planos Negociados">
      <bpmn:incoming>flow_to_end_negotiated</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="end_review" name="Revisão Manual">
      <bpmn:incoming>flow_to_end_review</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_to_predict_collection" sourceRef="start_maximization" targetRef="task_predict_collection_date" />
    <bpmn:sequenceFlow id="flow_to_identify_slow_payers" sourceRef="task_predict_collection_date" targetRef="task_identify_slow_payers" />
    <bpmn:sequenceFlow id="flow_to_risk_gateway" sourceRef="task_identify_slow_payers" targetRef="gateway_risk_assessment" />
    <bpmn:sequenceFlow id="flow_low_risk" name="Não" sourceRef="gateway_risk_assessment" targetRef="dmn_optimization_strategy">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=avg(payerRiskScores) &lt; 0.7</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_high_risk" name="Sim" sourceRef="gateway_risk_assessment" targetRef="task_negotiate_payment_plan" />
    <bpmn:sequenceFlow id="flow_to_update_forecasts" sourceRef="dmn_optimization_strategy" targetRef="task_update_forecasts" />
    <bpmn:sequenceFlow id="flow_to_analyze_opportunities" sourceRef="task_update_forecasts" targetRef="task_analyze_opportunities" />
    <bpmn:sequenceFlow id="flow_to_opportunity_gateway" sourceRef="task_analyze_opportunities" targetRef="gateway_opportunities" />
    <bpmn:sequenceFlow id="flow_has_opportunities" name="Sim" sourceRef="gateway_opportunities" targetRef="parallel_optimization_start">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=size(revenueOpportunities) &gt; 0</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_no_opportunities" name="Não" sourceRef="gateway_opportunities" targetRef="task_review_opportunities" />
    <bpmn:sequenceFlow id="flow_to_optimize_pricing" sourceRef="parallel_optimization_start" targetRef="task_optimize_pricing" />
    <bpmn:sequenceFlow id="flow_to_optimize_contracts" sourceRef="parallel_optimization_start" targetRef="task_optimize_contracts" />
    <bpmn:sequenceFlow id="flow_to_parallel_join" sourceRef="task_optimize_pricing" targetRef="parallel_optimization_join" />
    <bpmn:sequenceFlow id="flow_to_generate_action_plan" sourceRef="parallel_optimization_join" targetRef="task_generate_action_plan" />
    <bpmn:sequenceFlow id="flow_to_end_success" sourceRef="task_generate_action_plan" targetRef="end_success" />
    <bpmn:sequenceFlow id="flow_to_end_negotiated" sourceRef="task_negotiate_payment_plan" targetRef="end_negotiated" />
    <bpmn:sequenceFlow id="flow_to_end_review" sourceRef="task_review_opportunities" targetRef="end_review" />
    <bpmn:sequenceFlow id="Flow_010q9xi" sourceRef="task_optimize_contracts" targetRef="parallel_optimization_join" />
  </bpmn:process>
  <bpmn:message id="Message_MaximizationComplete" name="MaximizationCompleteMessage" />
  <bpmndi:BPMNDiagram id="BPMNDiagram_RC010">
    <bpmndi:BPMNPlane id="BPMNPlane_RC010" bpmnElement="SP_RC_010_Maximization">
      <bpmndi:BPMNShape id="shape_start_maximization" bpmnElement="start_maximization" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="180" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel color:color="#0d4372">
          <dc:Bounds x="166" y="265" width="65" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_predict_collection_date" bpmnElement="task_predict_collection_date" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="280" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_identify_slow_payers" bpmnElement="task_identify_slow_payers" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="440" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gateway_risk_assessment" bpmnElement="gateway_risk_assessment" isMarkerVisible="true" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="605" y="215" width="50" height="50" />
        <bpmndi:BPMNLabel color:color="#0d4372">
          <dc:Bounds x="602" y="191" width="56" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_dmn_optimization_strategy" bpmnElement="dmn_optimization_strategy" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="720" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_update_forecasts" bpmnElement="task_update_forecasts" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="880" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_analyze_opportunities" bpmnElement="task_analyze_opportunities" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="1040" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_gateway_opportunities" bpmnElement="gateway_opportunities" isMarkerVisible="true" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="1205" y="215" width="50" height="50" />
        <bpmndi:BPMNLabel color:color="#0d4372">
          <dc:Bounds x="1193" y="178" width="73" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_parallel_optimization_start" bpmnElement="parallel_optimization_start" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="1325" y="215" width="50" height="50" />
        <bpmndi:BPMNLabel color:color="#0d4372">
          <dc:Bounds x="1320" y="272" width="61" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_optimize_pricing" bpmnElement="task_optimize_pricing" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="1440" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_optimize_contracts" bpmnElement="task_optimize_contracts" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="1440" y="320" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_parallel_optimization_join" bpmnElement="parallel_optimization_join" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="1605" y="215" width="50" height="50" />
        <bpmndi:BPMNLabel color:color="#0d4372">
          <dc:Bounds x="1600" y="286" width="61" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_generate_action_plan" bpmnElement="task_generate_action_plan" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="1720" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_negotiate_payment_plan" bpmnElement="task_negotiate_payment_plan" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="580" y="380" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_task_review_opportunities" bpmnElement="task_review_opportunities" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="1180" y="380" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_end_success" bpmnElement="end_success" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="1882" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel color:color="#0d4372">
          <dc:Bounds x="1868" y="265" width="65" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_end_negotiated" bpmnElement="end_negotiated" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="612" y="522" width="36" height="36" />
        <bpmndi:BPMNLabel color:color="#0d4372">
          <dc:Bounds x="601" y="565" width="59" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_end_review" bpmnElement="end_review" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="1212" y="522" width="36" height="36" />
        <bpmndi:BPMNLabel color:color="#0d4372">
          <dc:Bounds x="1191" y="565" width="79" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="shape_timer_forecast_cycle" bpmnElement="timer_forecast_cycle" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="912" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel color:color="#0d4372">
          <dc:Bounds x="901" y="306" width="57" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="edge_flow_to_predict_collection" bpmnElement="flow_to_predict_collection" bioc:stroke="#0d4372" color:border-color="#0d4372">
        <di:waypoint x="216" y="240" />
        <di:waypoint x="280" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_to_identify_slow_payers" bpmnElement="flow_to_identify_slow_payers" bioc:stroke="#0d4372" color:border-color="#0d4372">
        <di:waypoint x="380" y="240" />
        <di:waypoint x="440" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_to_risk_gateway" bpmnElement="flow_to_risk_gateway" bioc:stroke="#0d4372" color:border-color="#0d4372">
        <di:waypoint x="540" y="240" />
        <di:waypoint x="605" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_low_risk" bpmnElement="flow_low_risk" bioc:stroke="#0d4372" color:border-color="#0d4372">
        <di:waypoint x="655" y="240" />
        <di:waypoint x="720" y="240" />
        <bpmndi:BPMNLabel color:color="#0d4372">
          <dc:Bounds x="679" y="222" width="21" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_high_risk" bpmnElement="flow_high_risk" bioc:stroke="#0d4372" color:border-color="#0d4372">
        <di:waypoint x="630" y="265" />
        <di:waypoint x="630" y="380" />
        <bpmndi:BPMNLabel color:color="#0d4372">
          <dc:Bounds x="648" y="319" width="20" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_to_update_forecasts" bpmnElement="flow_to_update_forecasts" bioc:stroke="#0d4372" color:border-color="#0d4372">
        <di:waypoint x="820" y="240" />
        <di:waypoint x="880" y="240" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="edge_flow_to_analyze_opportunities" bpmnElement="flow_to_analyze_opportunities" bioc:stroke="#0d4372" color:border-color="#0d4372">
        <di:waypoint x="980" y="240" />
        <di:waypoint x="1040" y="240" />
      </bpmndi:BPMNEdge>
