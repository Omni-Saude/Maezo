<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_RC003" targetNamespace="http://cib7.healthcare/revenue-cycle" exporter="Camunda Modeler" exporterVersion="5.35.0">
  <bpmn:process id="SP_RC_003_Clinical_Service" name="Atendimento Clínico e Documentação" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="start_clinical_service" name="Início Atendimento">
      <bpmn:outgoing>flow_to_capture_procedure</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:boundaryEvent id="timer_capture_timeout" name="Timeout 4h" attachedToRef="task_capture_procedure">
      <bpmn:outgoing>flow_to_escalate_capture</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT4H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:boundaryEvent id="error_capture_failed" name="Erro Captura" attachedToRef="task_capture_procedure">
      <bpmn:outgoing>flow_to_manual_capture</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_CaptureFailed" />
    </bpmn:boundaryEvent>
    <bpmn:exclusiveGateway id="gateway_completeness" name="Documentação Completa?" default="flow_doc_complete">
      <bpmn:incoming>Flow_06f4ezo</bpmn:incoming>
      <bpmn:outgoing>flow_doc_complete</bpmn:outgoing>
      <bpmn:outgoing>flow_doc_incomplete</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="gateway_validation" name="Dados Válidos?" default="flow_valid">
      <bpmn:incoming>flow_to_validation_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_valid</bpmn:outgoing>
      <bpmn:outgoing>flow_invalid</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="end_success" name="Documentação Completa">
      <bpmn:incoming>flow_valid</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="end_manual_capture" name="Captura Manual">
      <bpmn:incoming>flow_to_end_manual_capture</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="end_escalated" name="Escalado">
      <bpmn:incoming>flow_to_end_escalated</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_to_capture_procedure" sourceRef="start_clinical_service" targetRef="task_capture_procedure" />
    <bpmn:sequenceFlow id="flow_to_enrich_procedure" sourceRef="task_capture_procedure" targetRef="Gateway_0o1p7c9" />
    <bpmn:sequenceFlow id="flow_doc_complete" name="Sim" sourceRef="gateway_completeness" targetRef="task_calculate_quantity" />
    <bpmn:sequenceFlow id="flow_doc_incomplete" name="Não" sourceRef="gateway_completeness" targetRef="Gateway_1c91mw2">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${completeData == null}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_to_validate_data" sourceRef="task_calculate_quantity" targetRef="task_validate_data" />
    <bpmn:sequenceFlow id="flow_to_validation_gateway" sourceRef="task_validate_data" targetRef="gateway_validation" />
    <bpmn:sequenceFlow id="flow_valid" name="Sim" sourceRef="gateway_validation" targetRef="end_success" />
    <bpmn:sequenceFlow id="flow_invalid" name="Não" sourceRef="gateway_validation" targetRef="Gateway_1c91mw2">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${dataValidated == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_to_manual_capture" sourceRef="error_capture_failed" targetRef="task_manual_capture" />
    <bpmn:sequenceFlow id="flow_to_escalate_capture" sourceRef="timer_capture_timeout" targetRef="task_escalate_capture" />
    <bpmn:sequenceFlow id="flow_to_end_manual_capture" sourceRef="task_manual_capture" targetRef="end_manual_capture" />
    <bpmn:sequenceFlow id="flow_to_end_escalated" sourceRef="task_escalate_capture" targetRef="end_escalated" />
    <bpmn:task id="task_manual_capture" name="Captura Manual">
      <bpmn:incoming>flow_to_manual_capture</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_manual_capture</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_escalate_capture" name="Escalar Captura">
      <bpmn:incoming>flow_to_escalate_capture</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_escalated</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_0tpcq79" sourceRef="Activity_1geah6w" targetRef="Event_12dvors" />
    <bpmn:intermediateCatchEvent id="Event_12dvors" name="após 24 horas">
      <bpmn:incoming>Flow_0tpcq79</bpmn:incoming>
      <bpmn:outgoing>Flow_0g5ipxq</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_00urhen">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT24H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="Gateway_0o1p7c9">
      <bpmn:incoming>Flow_0g5ipxq</bpmn:incoming>
      <bpmn:incoming>flow_to_enrich_procedure</bpmn:incoming>
      <bpmn:outgoing>Flow_06z1p0z</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0g5ipxq" sourceRef="Event_12dvors" targetRef="Gateway_0o1p7c9" />
    <bpmn:sequenceFlow id="Flow_06z1p0z" sourceRef="Gateway_0o1p7c9" targetRef="task_enrich_procedure" />
    <bpmn:sequenceFlow id="Flow_06f4ezo" sourceRef="task_enrich_procedure" targetRef="gateway_completeness" />
    <bpmn:exclusiveGateway id="Gateway_1c91mw2">
      <bpmn:incoming>flow_invalid</bpmn:incoming>
      <bpmn:incoming>flow_doc_incomplete</bpmn:incoming>
      <bpmn:outgoing>Flow_1anglbu</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1anglbu" sourceRef="Gateway_1c91mw2" targetRef="Activity_1geah6w" />
    <bpmn:serviceTask id="task_calculate_quantity" name="Calcular Quantidade e Unidades" camunda:type="external" camunda:topic="revenue_cycle.production.calculate_value">
      <bpmn:incoming>flow_doc_complete</bpmn:incoming>
      <bpmn:outgoing>flow_to_validate_data</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_validate_data" name="Validar Dados Clínicos" camunda:type="external" camunda:topic="revenue_cycle.validate_procedure">
      <bpmn:incoming>flow_to_validate_data</bpmn:incoming>
      <bpmn:outgoing>flow_to_validation_gateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_enrich_procedure" name="Enriquecer Dados Clínicos" camunda:type="external" camunda:topic="revenue_cycle.enrich_procedure">
      <bpmn:incoming>Flow_06z1p0z</bpmn:incoming>
      <bpmn:outgoing>Flow_06f4ezo</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_1geah6w" name="Notificar&#10;pendências" camunda:type="external" camunda:topic="NotificarPendenciaTasy">
      <bpmn:incoming>Flow_1anglbu</bpmn:incoming>
      <bpmn:outgoing>Flow_0tpcq79</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_capture_procedure" name="Capturar Dados do Procedimento" camunda:type="external" camunda:topic="revenue_cycle.capture_procedure">
      <bpmn:incoming>flow_to_capture_procedure</bpmn:incoming>
      <bpmn:outgoing>flow_to_enrich_procedure</bpmn:outgoing>
    </bpmn:serviceTask>
  </bpmn:process>
  <bpmn:error id="Error_CaptureFailed" name="CaptureFailed" errorCode="ERR_CAPTURE_001" />
