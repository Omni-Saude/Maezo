<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_RC007" targetNamespace="http://cib7.healthcare/revenue-cycle" exporter="Camunda Modeler" exporterVersion="5.35.0">
  <bpmn:process id="SP_RC_007_Denial_Management" name="Gestão de Glosas" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="start_denial_mgmt" name="Início Gestão de Glosas">
      <bpmn:outgoing>flow_to_identify_glosa</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="task_identify_glosa" name="Identificar Glosa" camunda:type="external" camunda:topic="glosa.identify">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="billingBatch">${batchId}</camunda:inputParameter>
          <camunda:inputParameter name="response">${payerResponse}</camunda:inputParameter>
          <camunda:outputParameter name="identifiedGlosas">${glosaItems}</camunda:outputParameter>
          <camunda:outputParameter name="totalGlosas">${glosaCount}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_identify_glosa</bpmn:incoming>
      <bpmn:outgoing>flow_to_classify_type</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="timer_appeal_deadline" name="Prazo 30d" attachedToRef="task_check_appeal_eligibility">
      <bpmn:outgoing>flow_to_expired</bpmn:outgoing>
      <bpmn:timerEventDefinition>
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P30D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:exclusiveGateway id="gateway_eligibility" name="Elegível para Recurso?" default="flow_not_eligible">
      <bpmn:incoming>flow_to_eligibility_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_eligible</bpmn:outgoing>
      <bpmn:outgoing>flow_not_eligible</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:businessRuleTask id="dmn_recovery_strategy" name="Estratégia de Recuperação" camunda:resultVariable="recoveryPlan" camunda:decisionRef="revenue_recovery_strategy" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>Flow_1xob87u</bpmn:incoming>
      <bpmn:outgoing>flow_to_dmn_recovery_elig</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:businessRuleTask id="dmn_recovery_eligibility" name="Elegibilidade de Recuperação" camunda:resultVariable="recoveryEligibility" camunda:decisionRef="revenue_recovery_eligibility" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>flow_to_dmn_recovery_elig</bpmn:incoming>
      <bpmn:outgoing>flow_to_generate_appeal</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:serviceTask id="task_submit_appeal" name="Submeter Recurso" camunda:type="external" camunda:topic="denial.submit_appeal">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="appealPackage">${completePackage}</camunda:inputParameter>
          <camunda:inputParameter name="payer">${payerId}</camunda:inputParameter>
          <camunda:outputParameter name="submittedAppealId">${appealId}</camunda:outputParameter>
          <camunda:outputParameter name="appealSubmissionDate">${submissionDate}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_submit_appeal</bpmn:incoming>
      <bpmn:outgoing>flow_to_track_appeal</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_track_appeal_status" name="Acompanhar Status do Recurso" camunda:type="external" camunda:topic="denial.track_appeal_status">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="appealId">${submittedAppealId}</camunda:inputParameter>
          <camunda:outputParameter name="appealStatus">${currentStatus}</camunda:outputParameter>
          <camunda:outputParameter name="response">${payerResponse}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_track_appeal</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_success</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_success" name="Recurso Submetido">
      <bpmn:incoming>flow_to_end_success</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="end_not_eligible" name="Não Elegível">
      <bpmn:incoming>flow_to_end_not_eligible</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="end_expired" name="Prazo Expirado">
      <bpmn:incoming>flow_to_end_expired</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_to_identify_glosa" sourceRef="start_denial_mgmt" targetRef="task_identify_glosa" />
    <bpmn:sequenceFlow id="flow_to_classify_type" sourceRef="task_identify_glosa" targetRef="task_classify_glosa_type" />
    <bpmn:sequenceFlow id="flow_to_analyze_reason" sourceRef="task_classify_glosa_type" targetRef="task_analyze_glosa_reason" />
    <bpmn:sequenceFlow id="flow_to_dmn_predict" sourceRef="task_analyze_glosa_reason" targetRef="dmn_predict_risk" />
    <bpmn:sequenceFlow id="flow_to_dmn_prevent" sourceRef="dmn_predict_risk" targetRef="dmn_prevention_strategy" />
    <bpmn:sequenceFlow id="flow_to_check_eligibility" sourceRef="dmn_prevention_strategy" targetRef="task_check_appeal_eligibility" />
    <bpmn:sequenceFlow id="flow_to_eligibility_gateway" sourceRef="task_check_appeal_eligibility" targetRef="gateway_eligibility" />
    <bpmn:sequenceFlow id="flow_eligible" name="Sim" sourceRef="gateway_eligibility" targetRef="Activity_1s4ckeb">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=appealEligible = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_not_eligible" name="Não" sourceRef="gateway_eligibility" targetRef="task_review_not_eligible" />
    <bpmn:sequenceFlow id="flow_to_dmn_recovery_elig" sourceRef="dmn_recovery_strategy" targetRef="dmn_recovery_eligibility" />
    <bpmn:sequenceFlow id="flow_to_generate_appeal" sourceRef="dmn_recovery_eligibility" targetRef="task_generate_appeal_documentation" />
    <bpmn:sequenceFlow id="flow_to_submit_appeal" sourceRef="task_generate_appeal_documentation" targetRef="task_submit_appeal" />
    <bpmn:sequenceFlow id="flow_to_track_appeal" sourceRef="task_submit_appeal" targetRef="task_track_appeal_status" />
    <bpmn:sequenceFlow id="flow_to_expired" sourceRef="timer_appeal_deadline" targetRef="task_handle_expired" />
    <bpmn:sequenceFlow id="flow_to_end_success" sourceRef="task_track_appeal_status" targetRef="end_success" />
    <bpmn:sequenceFlow id="flow_to_end_not_eligible" sourceRef="task_review_not_eligible" targetRef="end_not_eligible" />
    <bpmn:sequenceFlow id="flow_to_end_expired" sourceRef="task_handle_expired" targetRef="end_expired" />
    <bpmn:task id="task_classify_glosa_type" name="Classificar Tipo de Glosa">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="glosasByType">${classifiedGlosas}</camunda:outputParameter>
          <camunda:outputParameter name="mainGlosaType">${primaryType}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_classify_type</bpmn:incoming>
      <bpmn:outgoing>flow_to_analyze_reason</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_analyze_glosa_reason" name="Analisar Razão da Glosa">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="glosaRootCause">${rootCause}</camunda:outputParameter>
          <camunda:outputParameter name="causeAnalysis">${analysisDetails}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_analyze_reason</bpmn:incoming>
      <bpmn:outgoing>flow_to_dmn_predict</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="dmn_predict_risk" name="Prever Risco de Glosa">
      <bpmn:incoming>flow_to_dmn_predict</bpmn:incoming>
      <bpmn:outgoing>flow_to_dmn_prevent</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="dmn_prevention_strategy" name="Estratégia de Prevenção">
      <bpmn:incoming>flow_to_dmn_prevent</bpmn:incoming>
      <bpmn:outgoing>flow_to_check_eligibility</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_generate_appeal_documentation" name="Gerar Documentação de Recurso">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="generatedAppealDocs">${appealDocuments}</camunda:outputParameter>
          <camunda:outputParameter name="completePackage">${appealPackage}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_generate_appeal</bpmn:incoming>
      <bpmn:outgoing>flow_to_submit_appeal</bpmn:outgoing>
    </bpmn:task>
    <bpmn:serviceTask id="task_check_appeal_eligibility" name="Verificar Elegibilidade para Recurso" camunda:type="external" camunda:topic="VerificarElegibilidade">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="glosas">${glosasByType}</camunda:inputParameter>
          <camunda:inputParameter name="rootCause">${glosaRootCause}</camunda:inputParameter>
          <camunda:outputParameter name="appealEligible">${isEligible}</camunda:outputParameter>
          <camunda:outputParameter name="eligibilityDetails">${eligibilityReason}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_check_eligibility</bpmn:incoming>
      <bpmn:outgoing>flow_to_eligibility_gateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1xob87u" sourceRef="Activity_1s4ckeb" targetRef="dmn_recovery_strategy" />
    <bpmn:serviceTask id="Activity_1s4ckeb" name="Coletar&#10;dados" camunda:type="external" camunda:topic="ColetarDados">
      <bpmn:incoming>flow_eligible</bpmn:incoming>
      <bpmn:outgoing>Flow_1xob87u</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:task id="task_handle_expired" name="Tratar Recurso Expirado">
      <bpmn:incoming>flow_to_expired</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_expired</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_review_not_eligible" name="Revisar Glosa Não Elegível">
      <bpmn:incoming>flow_not_eligible</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_not_eligible</bpmn:outgoing>
    </bpmn:task>
    <bpmn:textAnnotation id="TextAnnotation_0j74rl0">
      <bpmn:text>RPA</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0a05jsr" associationDirection="None" sourceRef="task_submit_appeal" targetRef="TextAnnotation_0j74rl0" />
    <bpmn:association id="Association_1uvjtmj" associationDirection="None" sourceRef="TextAnnotation_0j74rl0" targetRef="task_track_appeal_status" />
  </bpmn:process>
