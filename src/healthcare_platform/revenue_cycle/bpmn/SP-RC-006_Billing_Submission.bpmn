<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_RC006" targetNamespace="http://cib7.healthcare/revenue-cycle" exporter="Camunda Modeler" exporterVersion="5.35.0">
  <bpmn:process id="SP_RC_006_Billing_Submission" name="Faturamento e Envio TISS" isExecutable="true" camunda:historyTimeToLive="30">
    <bpmn:startEvent id="start_billing" name="Início Faturamento">
      <bpmn:outgoing>flow_to_validate_claim</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="gateway_validation" name="Validação OK?" default="flow_invalid">
      <bpmn:incoming>flow_to_validation_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_valid</bpmn:outgoing>
      <bpmn:outgoing>flow_invalid</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:businessRuleTask id="dmn_quantity_validation" name="Validar Quantidades" camunda:resultVariable="quantityCheck" camunda:decisionRef="billing_quantity_validation" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>flow_valid</bpmn:incoming>
      <bpmn:outgoing>flow_to_calculate_charges</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:businessRuleTask id="dmn_modifier_rules" name="Aplicar Modificadores" camunda:resultVariable="modifiers" camunda:decisionRef="billing_modifier_rules" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>flow_to_dmn_modifier</bpmn:incoming>
      <bpmn:outgoing>flow_to_dmn_bundle</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:businessRuleTask id="dmn_bundle_rules" name="Regras de Pacotes" camunda:resultVariable="bundleRules" camunda:decisionRef="billing_bundle_rules" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>flow_to_dmn_bundle</bpmn:incoming>
      <bpmn:outgoing>flow_to_apply_contract</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:businessRuleTask id="dmn_tax_calculation" name="Calcular Taxas" camunda:resultVariable="taxes" camunda:decisionRef="billing_tax_calculation" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>flow_to_dmn_taxa</bpmn:incoming>
      <bpmn:outgoing>flow_to_dmn_opme</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:businessRuleTask id="dmn_opme_rules" name="Aplicar Regras OPME" camunda:resultVariable="opmeRules" camunda:decisionRef="billing_opme_rules" camunda:mapDecisionResult="singleResult">
      <bpmn:incoming>flow_to_dmn_opme</bpmn:incoming>
      <bpmn:outgoing>flow_to_generate_tiss</bpmn:outgoing>
    </bpmn:businessRuleTask>
    <bpmn:serviceTask id="task_generate_tiss_xml" name="Gerar XML TISS" camunda:type="external" camunda:topic="billing.generate_tiss_xml">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="charges">${finalCharges}</camunda:inputParameter>
          <camunda:inputParameter name="taxDetails">${taxes}</camunda:inputParameter>
          <camunda:inputParameter name="opme">${opmeRules}</camunda:inputParameter>
          <camunda:inputParameter name="encounter">${encounterId}</camunda:inputParameter>
          <camunda:outputParameter name="generatedXml">${tissXml}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_113i7r0</bpmn:incoming>
      <bpmn:outgoing>flow_to_validate_schema</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="error_tiss_generation" name="Erro TISS" attachedToRef="task_generate_tiss_xml">
      <bpmn:outgoing>flow_to_manual_tiss</bpmn:outgoing>
      <bpmn:errorEventDefinition errorRef="Error_TissGenerationFailed" />
    </bpmn:boundaryEvent>
    <bpmn:exclusiveGateway id="gateway_schema" name="Schema Válido?" default="flow_schema_valid">
      <bpmn:incoming>flow_to_schema_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_schema_valid</bpmn:outgoing>
      <bpmn:outgoing>flow_schema_invalid</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="task_submit_to_payer" name="Enviar para Operadora" camunda:type="external" camunda:topic="billing.submit_to_payer">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="tissXml">${generatedXml}</camunda:inputParameter>
          <camunda:inputParameter name="payer">${payerId}</camunda:inputParameter>
          <camunda:outputParameter name="batchId">${submissionId}</camunda:outputParameter>
          <camunda:outputParameter name="status">${submissionStatus}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_03vhw0f</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_success</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="end_success" name="Enviado com Sucesso">
      <bpmn:incoming>flow_to_end_success</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="end_corrections" name="Correções Necessárias">
      <bpmn:incoming>flow_to_end_corrections</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_to_validate_claim" sourceRef="start_billing" targetRef="task_validate_claim" />
    <bpmn:sequenceFlow id="flow_to_validation_gateway" sourceRef="task_validate_claim" targetRef="gateway_validation" />
    <bpmn:sequenceFlow id="flow_valid" name="Sim" sourceRef="gateway_validation" targetRef="dmn_quantity_validation">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=claimValidated = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_invalid" name="Não" sourceRef="gateway_validation" targetRef="task_correct_errors" />
    <bpmn:sequenceFlow id="flow_to_calculate_charges" sourceRef="dmn_quantity_validation" targetRef="task_calculate_charges" />
    <bpmn:sequenceFlow id="flow_to_dmn_modifier" sourceRef="task_calculate_charges" targetRef="dmn_modifier_rules" />
    <bpmn:sequenceFlow id="flow_to_dmn_bundle" sourceRef="dmn_modifier_rules" targetRef="dmn_bundle_rules" />
    <bpmn:sequenceFlow id="flow_to_apply_contract" sourceRef="dmn_bundle_rules" targetRef="task_apply_contract_rules" />
    <bpmn:sequenceFlow id="flow_to_dmn_taxa" sourceRef="task_apply_contract_rules" targetRef="dmn_tax_calculation" />
    <bpmn:sequenceFlow id="flow_to_dmn_opme" sourceRef="dmn_tax_calculation" targetRef="dmn_opme_rules" />
    <bpmn:sequenceFlow id="flow_to_generate_tiss" sourceRef="dmn_opme_rules" targetRef="Activity_0yeaydo" />
    <bpmn:sequenceFlow id="flow_to_validate_schema" sourceRef="task_generate_tiss_xml" targetRef="task_validate_tiss_schema" />
    <bpmn:sequenceFlow id="flow_to_schema_gateway" sourceRef="task_validate_tiss_schema" targetRef="gateway_schema" />
    <bpmn:sequenceFlow id="flow_schema_valid" name="Sim" sourceRef="gateway_schema" targetRef="Gateway_1g8qr0a" />
    <bpmn:sequenceFlow id="flow_schema_invalid" name="Não" sourceRef="gateway_schema" targetRef="task_fix_schema">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${schemaValid == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow_to_manual_tiss" sourceRef="error_tiss_generation" targetRef="task_manual_tiss" />
    <bpmn:sequenceFlow id="flow_to_escalate_submission" sourceRef="timer_submission_sla" targetRef="task_escalate_submission" />
    <bpmn:sequenceFlow id="flow_to_end_success" sourceRef="task_submit_to_payer" targetRef="end_success" />
    <bpmn:sequenceFlow id="flow_to_end_corrections" sourceRef="task_correct_errors" targetRef="end_corrections" />
    <bpmn:sequenceFlow id="Flow_0e1taz1" sourceRef="Activity_0yeaydo" targetRef="Activity_0fi22n9" />
    <bpmn:sequenceFlow id="Flow_0hu85jy" sourceRef="Activity_0fi22n9" targetRef="Activity_0lt08hn" />
    <bpmn:sequenceFlow id="Flow_1samn4d" sourceRef="Activity_0lt08hn" targetRef="Gateway_0q37jwx" />
    <bpmn:exclusiveGateway id="Gateway_0q37jwx">
      <bpmn:incoming>Flow_1samn4d</bpmn:incoming>
      <bpmn:incoming>Flow_0i3kylf</bpmn:incoming>
      <bpmn:outgoing>Flow_113i7r0</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_113i7r0" sourceRef="Gateway_0q37jwx" targetRef="task_generate_tiss_xml" />
    <bpmn:sequenceFlow id="Flow_1600s33" sourceRef="task_manual_tiss" targetRef="Event_1ropo18" />
    <bpmn:serviceTask id="Activity_0fi22n9" name="Fechar&#10;conta" camunda:type="external" camunda:topic="billing.close_account">
      <bpmn:incoming>Flow_0e1taz1</bpmn:incoming>
      <bpmn:outgoing>Flow_0hu85jy</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_0lt08hn" name="Incluir conta em Protocolo" camunda:type="external" camunda:topic="IncluirContaProtocolo">
      <bpmn:incoming>Flow_0hu85jy</bpmn:incoming>
      <bpmn:outgoing>Flow_1samn4d</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_manual_tiss" name="Notificar&#10;pendência" camunda:type="external" camunda:topic="NotificarPendencia">
      <bpmn:incoming>flow_to_manual_tiss</bpmn:incoming>
      <bpmn:outgoing>Flow_1600s33</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0i3kylf" sourceRef="Event_1ropo18" targetRef="Gateway_0q37jwx" />
    <bpmn:intermediateCatchEvent id="Event_1ropo18" name="após 24 horas">
      <bpmn:incoming>Flow_1600s33</bpmn:incoming>
      <bpmn:outgoing>Flow_0i3kylf</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_17nsog7">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT24H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="end_schema_fix" name="Correção de Schema">
      <bpmn:incoming>flow_to_end_schema_fix</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_to_end_schema_fix" sourceRef="task_fix_schema" targetRef="end_schema_fix" />
    <bpmn:sequenceFlow id="Flow_0qz6nw7" sourceRef="task_escalate_submission" targetRef="Event_1bx26xi" />
    <bpmn:intermediateCatchEvent id="Event_1bx26xi" name="após 24 horas">
      <bpmn:incoming>Flow_0qz6nw7</bpmn:incoming>
      <bpmn:outgoing>Flow_0qdhj6v</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_1bnek45">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT24H</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="Gateway_1g8qr0a">
      <bpmn:incoming>flow_schema_valid</bpmn:incoming>
      <bpmn:incoming>Flow_0qdhj6v</bpmn:incoming>
      <bpmn:outgoing>Flow_03vhw0f</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_03vhw0f" sourceRef="Gateway_1g8qr0a" targetRef="task_submit_to_payer" />
    <bpmn:sequenceFlow id="Flow_0qdhj6v" sourceRef="Event_1bx26xi" targetRef="Gateway_1g8qr0a" />
    <bpmn:serviceTask id="task_escalate_submission" name="Notificar&#10;pendência" camunda:type="external" camunda:topic="NotificarPendencia">
      <bpmn:incoming>flow_to_escalate_submission</bpmn:incoming>
      <bpmn:outgoing>Flow_0qz6nw7</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:boundaryEvent id="timer_submission_sla" name="Erro&#10;Operadora" attachedToRef="task_submit_to_payer">
      <bpmn:outgoing>flow_to_escalate_submission</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorEventDefinition_1sy6wve" errorRef="Error_1xp6ciu" />
    </bpmn:boundaryEvent>
    <bpmn:task id="Activity_0yeaydo" name="Verificar consistências das contas e TISS">
      <bpmn:incoming>flow_to_generate_tiss</bpmn:incoming>
      <bpmn:outgoing>Flow_0e1taz1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_apply_contract_rules" name="Aplicar Regras de Pacotes">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="finalCharges">${adjustedCharges}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_apply_contract</bpmn:incoming>
      <bpmn:outgoing>flow_to_dmn_taxa</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_calculate_charges" name="Calcular Valores">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="billingTotal">${totalCharges}</camunda:outputParameter>
          <camunda:outputParameter name="breakdown">${chargeBreakdown}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_calculate_charges</bpmn:incoming>
      <bpmn:outgoing>flow_to_dmn_modifier</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_correct_errors" name="Corrigir Erros de Validação">
      <bpmn:incoming>flow_invalid</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_corrections</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_validate_claim" name="Validar Dados da Conta">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="claimValidated">${validationResult}</camunda:outputParameter>
          <camunda:outputParameter name="errors">${validationErrors}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_validate_claim</bpmn:incoming>
      <bpmn:outgoing>flow_to_validation_gateway</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_validate_tiss_schema" name="Validar Schema TISS">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:outputParameter name="isSchemaValid">${schemaValid}</camunda:outputParameter>
          <camunda:outputParameter name="schemaValidationErrors">${schemaErrors}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>flow_to_validate_schema</bpmn:incoming>
      <bpmn:outgoing>flow_to_schema_gateway</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_fix_schema" name="Corrigir Erros de Schema">
      <bpmn:incoming>flow_schema_invalid</bpmn:incoming>
      <bpmn:outgoing>flow_to_end_schema_fix</bpmn:outgoing>
    </bpmn:task>
    <bpmn:textAnnotation id="TextAnnotation_1lnuurq">
      <bpmn:text>validar dados do atendimento</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0a0x0th" associationDirection="None" sourceRef="task_validate_claim" targetRef="TextAnnotation_1lnuurq" />
    <bpmn:textAnnotation id="TextAnnotation_1aswfkn">
      <bpmn:text>substituição de itens e codificação?</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0nir0nh" associationDirection="None" sourceRef="dmn_modifier_rules" targetRef="TextAnnotation_1aswfkn" />
    <bpmn:textAnnotation id="TextAnnotation_0zo15cg">
      <bpmn:text>diárias e taxas
itens</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1o8fjgv" associationDirection="None" sourceRef="dmn_bundle_rules" targetRef="TextAnnotation_0zo15cg" />
    <bpmn:textAnnotation id="TextAnnotation_0ihrjfu">
      <bpmn:text>quando não existir pacote</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0w6dx2j" associationDirection="None" sourceRef="dmn_tax_calculation" targetRef="TextAnnotation_0ihrjfu" />
    <bpmn:textAnnotation id="TextAnnotation_0iob7zm">
      <bpmn:text>Validar se os pcts fazem sentido</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_04x8aal" associationDirection="None" sourceRef="dmn_bundle_rules" targetRef="TextAnnotation_0iob7zm" />
    <bpmn:textAnnotation id="TextAnnotation_18kdhp7">
      <bpmn:text>RPA</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1h6gprz" associationDirection="None" sourceRef="Activity_0fi22n9" targetRef="TextAnnotation_18kdhp7" />
    <bpmn:textAnnotation id="TextAnnotation_1ewk36h">
      <bpmn:text>RPA</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0nm04yn" associationDirection="None" sourceRef="task_generate_tiss_xml" targetRef="TextAnnotation_1ewk36h" />
    <bpmn:textAnnotation id="TextAnnotation_1i41ify">
      <bpmn:text>RPA</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_13ve4ej" associationDirection="None" sourceRef="task_submit_to_payer" targetRef="TextAnnotation_1i41ify" />
  </bpmn:process>
  <bpmn:error id="Error_TissGenerationFailed" name="TissGenerationFailed" errorCode="ERR_TISS_001" />
  <bpmn:error id="Error_1jul0fk" name="Erro" />
  <bpmn:error id="Error_1xp6ciu" name="Error_3u9n6im" />
  <bpmndi:BPMNDiagram id="BPMNDiagram_RC006">
    <bpmndi:BPMNPlane id="BPMNPlane_RC006" bpmnElement="SP_RC_006_Billing_Submission">
      <bpmndi:BPMNShape id="Shape_start_billing" bpmnElement="start_billing" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
