      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_end_corrections" bpmnElement="end_corrections">
        <dc:Bounds x="390" y="612" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="378" y="655" width="61" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
