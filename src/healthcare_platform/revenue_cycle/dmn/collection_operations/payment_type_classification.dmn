<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  PAYMENT-TYPE-CLASSIFICATION - Classificacao de Tipo de Pagamento
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: classify_payment_type_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_PAYMENT_TYPE_CLASSIFICATION"
             name="Classificacao de Tipo de Pagamento"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_PAYMENT_TYPE_CLASSIFICATION" name="[SP-RC-013 | collection_operations] Classificacao de Tipo de Pagamento" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_PAYMENT_TYPE_CLASSIFICATION" hitPolicy="FIRST">

      <input id="Input_1_PAYMENT_TYPE_CLASSIFICATION" label="Metodo Pagamento">
        <inputExpression id="InputExpression_1_PAYMENT_TYPE_CLASSIFICATION" typeRef="string">
          <text>payment_method</text>
        </inputExpression>
        <inputValues id="InputValues_1_PAYMENT_TYPE_CLASSIFICATION">
          <text>"PIX","TED","BOLETO","CHEQUE","DEPOSITO","CARTAO"</text>
        </inputValues>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_category_PAYMENT_TYPE_CLASSIFICATION" label="Categoria" name="payment_category" typeRef="string">
        <outputValues><text>"electronic","slip","paper","manual","other"</text></outputValues>
      </output>
      <output id="Output_days_PAYMENT_TYPE_CLASSIFICATION" label="Dias Processamento" name="processing_days" typeRef="integer"/>
      <output id="Output_review_PAYMENT_TYPE_CLASSIFICATION" label="Requer Revisao Manual" name="requires_manual_review" typeRef="boolean"/>

      <rule id="Rule_PIX_PAYMENT_TYPE_CLASSIFICATION">
        <description>PIX - pagamento instantaneo</description>
        <inputEntry id="IE_1_1_PAYMENT_TYPE_CLASSIFICATION"><text>"PIX"</text></inputEntry>
        <outputEntry id="OE_1_1_PAYMENT_TYPE_CLASSIFICATION"><text>"electronic"</text></outputEntry>
        <outputEntry id="OE_1_2_PAYMENT_TYPE_CLASSIFICATION"><text>0</text></outputEntry>
        <outputEntry id="OE_1_3_PAYMENT_TYPE_CLASSIFICATION"><text>false</text></outputEntry>
      </rule>

      <rule id="Rule_TED_PAYMENT_TYPE_CLASSIFICATION">
        <description>TED - transferencia eletronica</description>
        <inputEntry id="IE_2_1_PAYMENT_TYPE_CLASSIFICATION"><text>"TED"</text></inputEntry>
        <outputEntry id="OE_2_1_PAYMENT_TYPE_CLASSIFICATION"><text>"electronic"</text></outputEntry>
        <outputEntry id="OE_2_2_PAYMENT_TYPE_CLASSIFICATION"><text>1</text></outputEntry>
        <outputEntry id="OE_2_3_PAYMENT_TYPE_CLASSIFICATION"><text>false</text></outputEntry>
      </rule>

      <rule id="Rule_Boleto_PAYMENT_TYPE_CLASSIFICATION">
        <description>Boleto bancario</description>
        <inputEntry id="IE_3_1_PAYMENT_TYPE_CLASSIFICATION"><text>"BOLETO"</text></inputEntry>
        <outputEntry id="OE_3_1_PAYMENT_TYPE_CLASSIFICATION"><text>"slip"</text></outputEntry>
        <outputEntry id="OE_3_2_PAYMENT_TYPE_CLASSIFICATION"><text>3</text></outputEntry>
        <outputEntry id="OE_3_3_PAYMENT_TYPE_CLASSIFICATION"><text>false</text></outputEntry>
      </rule>

      <rule id="Rule_Cheque_PAYMENT_TYPE_CLASSIFICATION">
        <description>Cheque - requer revisao</description>
        <inputEntry id="IE_4_1_PAYMENT_TYPE_CLASSIFICATION"><text>"CHEQUE"</text></inputEntry>
        <outputEntry id="OE_4_1_PAYMENT_TYPE_CLASSIFICATION"><text>"paper"</text></outputEntry>
        <outputEntry id="OE_4_2_PAYMENT_TYPE_CLASSIFICATION"><text>5</text></outputEntry>
        <outputEntry id="OE_4_3_PAYMENT_TYPE_CLASSIFICATION"><text>true</text></outputEntry>
      </rule>

      <rule id="Rule_Deposito_PAYMENT_TYPE_CLASSIFICATION">
        <description>Deposito bancario - revisao manual</description>
        <inputEntry id="IE_5_1_PAYMENT_TYPE_CLASSIFICATION"><text>"DEPOSITO"</text></inputEntry>
        <outputEntry id="OE_5_1_PAYMENT_TYPE_CLASSIFICATION"><text>"manual"</text></outputEntry>
        <outputEntry id="OE_5_2_PAYMENT_TYPE_CLASSIFICATION"><text>2</text></outputEntry>
        <outputEntry id="OE_5_3_PAYMENT_TYPE_CLASSIFICATION"><text>true</text></outputEntry>
      </rule>

      <rule id="Rule_Cartao_PAYMENT_TYPE_CLASSIFICATION">
        <description>Cartao de credito/debito</description>
        <inputEntry id="IE_6_1_PAYMENT_TYPE_CLASSIFICATION"><text>"CARTAO"</text></inputEntry>
        <outputEntry id="OE_6_1_PAYMENT_TYPE_CLASSIFICATION"><text>"electronic"</text></outputEntry>
        <outputEntry id="OE_6_2_PAYMENT_TYPE_CLASSIFICATION"><text>2</text></outputEntry>
        <outputEntry id="OE_6_3_PAYMENT_TYPE_CLASSIFICATION"><text>false</text></outputEntry>
      </rule>

      <rule id="Rule_Other_PAYMENT_TYPE_CLASSIFICATION">
        <description>Outros metodos - revisar</description>
        <inputEntry id="IE_F_1_PAYMENT_TYPE_CLASSIFICATION"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_PAYMENT_TYPE_CLASSIFICATION"><text>"other"</text></outputEntry>
        <outputEntry id="OE_F_2_PAYMENT_TYPE_CLASSIFICATION"><text>5</text></outputEntry>
        <outputEntry id="OE_F_3_PAYMENT_TYPE_CLASSIFICATION"><text>true</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PAYMENT_TYPE_CLASSIFICATION">
      <dmndi:DMNShape id="DMNShape_Decision_PAYMENT_TYPE_CLASSIFICATION" dmnElementRef="Decision_PAYMENT_TYPE_CLASSIFICATION">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
