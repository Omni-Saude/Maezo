<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  ARCHIVE-ROUTING - Roteamento de Arquivamento de Reconciliacao
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: archive_reconciliation_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_ARCHIVE_ROUTING"
             name="Roteamento de Arquivamento de Reconciliacao"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_ARCHIVE_ROUTING" name="[SP-RC-013 | collection_operations] Roteamento de Arquivamento de Reconciliacao" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_ARCHIVE_ROUTING" hitPolicy="FIRST">

      <input id="Input_1_ARCHIVE_ROUTING" label="Dias Retencao">
        <inputExpression id="InputExpression_1_ARCHIVE_ROUTING" typeRef="number">
          <text>retentionDays</text>
        </inputExpression>
      </input>

      <input id="Input_2_ARCHIVE_ROUTING" label="Quantidade Elegivel">
        <inputExpression id="InputExpression_2_ARCHIVE_ROUTING" typeRef="number">
          <text>eligibleCount</text>
        </inputExpression>
      </input>

      <input id="Input_3_ARCHIVE_ROUTING" label="Dry Run">
        <inputExpression id="InputExpression_3_ARCHIVE_ROUTING" typeRef="boolean">
          <text>dryRun</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado_ARCHIVE_ROUTING" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_ARCHIVE_ROUTING" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_ARCHIVE_ROUTING" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1_ARCHIVE_ROUTING">
        <description>Retencao muito curta - risco de perda de dados</description>
        <inputEntry id="IE_1_1_ARCHIVE_ROUTING"><text>&lt; 90</text></inputEntry>
        <inputEntry id="IE_1_2_ARCHIVE_ROUTING"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3_ARCHIVE_ROUTING"><text>false</text></inputEntry>
        <outputEntry id="OE_1_1_ARCHIVE_ROUTING"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2_ARCHIVE_ROUTING"><text>"Periodo de retencao inferior a 90 dias - risco de perda de dados fiscais"</text></outputEntry>
        <outputEntry id="OE_1_3_ARCHIVE_ROUTING"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2_ARCHIVE_ROUTING">
        <description>Arquivamento massivo sem dry run</description>
        <inputEntry id="IE_2_1_ARCHIVE_ROUTING"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2_ARCHIVE_ROUTING"><text>&gt; 500</text></inputEntry>
        <inputEntry id="IE_2_3_ARCHIVE_ROUTING"><text>false</text></inputEntry>
        <outputEntry id="OE_2_1_ARCHIVE_ROUTING"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_2_ARCHIVE_ROUTING"><text>"Mais de 500 registros para arquivar - executar dry run primeiro"</text></outputEntry>
        <outputEntry id="OE_2_3_ARCHIVE_ROUTING"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_3_ARCHIVE_ROUTING">
        <description>Dry run - sempre prosseguir</description>
        <inputEntry id="IE_3_1_ARCHIVE_ROUTING"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2_ARCHIVE_ROUTING"><text>-</text></inputEntry>
        <inputEntry id="IE_3_3_ARCHIVE_ROUTING"><text>true</text></inputEntry>
        <outputEntry id="OE_3_1_ARCHIVE_ROUTING"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_3_2_ARCHIVE_ROUTING"><text>"Modo simulacao - listar sem arquivar"</text></outputEntry>
        <outputEntry id="OE_3_3_ARCHIVE_ROUTING"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_4_ARCHIVE_ROUTING">
        <description>Arquivamento normal</description>
        <inputEntry id="IE_4_1_ARCHIVE_ROUTING"><text>&gt;= 365</text></inputEntry>
        <inputEntry id="IE_4_2_ARCHIVE_ROUTING"><text>&lt;= 500</text></inputEntry>
        <inputEntry id="IE_4_3_ARCHIVE_ROUTING"><text>false</text></inputEntry>
        <outputEntry id="OE_4_1_ARCHIVE_ROUTING"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2_ARCHIVE_ROUTING"><text>"Arquivamento padrao - retencao de 1+ ano atende requisitos legais"</text></outputEntry>
        <outputEntry id="OE_4_3_ARCHIVE_ROUTING"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_5_ARCHIVE_ROUTING">
        <description>Retencao entre 90-365 dias</description>
        <inputEntry id="IE_5_1_ARCHIVE_ROUTING"><text>[90..365]</text></inputEntry>
        <inputEntry id="IE_5_2_ARCHIVE_ROUTING"><text>-</text></inputEntry>
        <inputEntry id="IE_5_3_ARCHIVE_ROUTING"><text>false</text></inputEntry>
        <outputEntry id="OE_5_1_ARCHIVE_ROUTING"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_5_2_ARCHIVE_ROUTING"><text>"Retencao entre 90-365 dias - verificar requisitos regulatorios"</text></outputEntry>
        <outputEntry id="OE_5_3_ARCHIVE_ROUTING"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_ARCHIVE_ROUTING">
        <description>Fallback</description>
        <inputEntry id="IE_F_1_ARCHIVE_ROUTING"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_ARCHIVE_ROUTING"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3_ARCHIVE_ROUTING"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_ARCHIVE_ROUTING"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2_ARCHIVE_ROUTING"><text>"Avaliar politica de arquivamento manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3_ARCHIVE_ROUTING"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ARCHIVE_ROUTING">
      <dmndi:DMNShape id="DMNShape_Decision_ARCHIVE_ROUTING" dmnElementRef="Decision_ARCHIVE_ROUTING">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
