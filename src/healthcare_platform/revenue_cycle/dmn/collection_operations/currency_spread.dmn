<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  CURRENCY-SPREAD - Limites de Spread Cambial
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_OPERATIONS
  Archetype: THRESHOLD | Source: convert_currency_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_CURRENCY_SPREAD"
             name="Limites de Spread Cambial"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_CURRENCY_SPREAD" name="[SP-RC-013 | collection_operations] Limites de Spread Cambial" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_CURRENCY_SPREAD" hitPolicy="FIRST">

      <input id="Input_1_CURRENCY_SPREAD" label="Par Moeda">
        <inputExpression id="InputExpression_1_CURRENCY_SPREAD" typeRef="string">
          <text>currencyPair</text>
        </inputExpression>
      </input>

      <input id="Input_2_CURRENCY_SPREAD" label="Spread Percentual">
        <inputExpression id="InputExpression_2_CURRENCY_SPREAD" typeRef="number">
          <text>spreadPercent</text>
        </inputExpression>
      </input>

      <input id="Input_3_CURRENCY_SPREAD" label="Valor Operacao">
        <inputExpression id="InputExpression_3_CURRENCY_SPREAD" typeRef="number">
          <text>operationAmount</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado_CURRENCY_SPREAD" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_CURRENCY_SPREAD" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_CURRENCY_SPREAD" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1_CURRENCY_SPREAD">
        <description>Spread excessivo em operacao grande</description>
        <inputEntry id="IE_1_1_CURRENCY_SPREAD"><text>-</text></inputEntry>
        <inputEntry id="IE_1_2_CURRENCY_SPREAD"><text>&gt; 5.0</text></inputEntry>
        <inputEntry id="IE_1_3_CURRENCY_SPREAD"><text>&gt; 100000</text></inputEntry>
        <outputEntry id="OE_1_1_CURRENCY_SPREAD"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2_CURRENCY_SPREAD"><text>"Spread acima de 5% em operacao &gt;R$100k - renegociar taxa"</text></outputEntry>
        <outputEntry id="OE_1_3_CURRENCY_SPREAD"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2_CURRENCY_SPREAD">
        <description>USD/BRL com spread alto</description>
        <inputEntry id="IE_2_1_CURRENCY_SPREAD"><text>"USD_BRL"</text></inputEntry>
        <inputEntry id="IE_2_2_CURRENCY_SPREAD"><text>&gt; 3.0</text></inputEntry>
        <inputEntry id="IE_2_3_CURRENCY_SPREAD"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1_CURRENCY_SPREAD"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_2_CURRENCY_SPREAD"><text>"Spread USD/BRL acima do mercado - verificar cotacao atualizada"</text></outputEntry>
        <outputEntry id="OE_2_3_CURRENCY_SPREAD"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_3_CURRENCY_SPREAD">
        <description>EUR/BRL com spread alto</description>
        <inputEntry id="IE_3_1_CURRENCY_SPREAD"><text>"EUR_BRL"</text></inputEntry>
        <inputEntry id="IE_3_2_CURRENCY_SPREAD"><text>&gt; 3.5</text></inputEntry>
        <inputEntry id="IE_3_3_CURRENCY_SPREAD"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1_CURRENCY_SPREAD"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_3_2_CURRENCY_SPREAD"><text>"Spread EUR/BRL acima do mercado - verificar cotacao"</text></outputEntry>
        <outputEntry id="OE_3_3_CURRENCY_SPREAD"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_4_CURRENCY_SPREAD">
        <description>Spread dentro do aceitavel</description>
        <inputEntry id="IE_4_1_CURRENCY_SPREAD"><text>-</text></inputEntry>
        <inputEntry id="IE_4_2_CURRENCY_SPREAD"><text>&lt;= 2.0</text></inputEntry>
        <inputEntry id="IE_4_3_CURRENCY_SPREAD"><text>-</text></inputEntry>
        <outputEntry id="OE_4_1_CURRENCY_SPREAD"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2_CURRENCY_SPREAD"><text>"Spread dentro dos limites aceitaveis"</text></outputEntry>
        <outputEntry id="OE_4_3_CURRENCY_SPREAD"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_5_CURRENCY_SPREAD">
        <description>Operacao pequena - spread toleravel</description>
        <inputEntry id="IE_5_1_CURRENCY_SPREAD"><text>-</text></inputEntry>
        <inputEntry id="IE_5_2_CURRENCY_SPREAD"><text>[2.0..5.0]</text></inputEntry>
        <inputEntry id="IE_5_3_CURRENCY_SPREAD"><text>&lt; 10000</text></inputEntry>
        <outputEntry id="OE_5_1_CURRENCY_SPREAD"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_2_CURRENCY_SPREAD"><text>"Spread moderado em valor baixo - impacto aceitavel"</text></outputEntry>
        <outputEntry id="OE_5_3_CURRENCY_SPREAD"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_CURRENCY_SPREAD">
        <description>Fallback</description>
        <inputEntry id="IE_F_1_CURRENCY_SPREAD"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_CURRENCY_SPREAD"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3_CURRENCY_SPREAD"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_CURRENCY_SPREAD"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2_CURRENCY_SPREAD"><text>"Avaliar spread cambial manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3_CURRENCY_SPREAD"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_CURRENCY_SPREAD">
      <dmndi:DMNShape id="DMNShape_Decision_CURRENCY_SPREAD" dmnElementRef="Decision_CURRENCY_SPREAD">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
