<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  ARCHIVE-POLICY - Politica de Retencao e Arquivamento
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: archive_reconciliation_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_ARCHIVE_POLICY"
             name="Politica de Retencao e Arquivamento"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_ARCHIVE_POLICY" name="[SP-RC-013 | collection_operations] Politica de Retencao e Arquivamento" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_ARCHIVE_POLICY" hitPolicy="FIRST">

      <input id="Input_1_ARCHIVE_POLICY" label="Tipo Reconciliacao">
        <inputExpression id="InputExpression_1_ARCHIVE_POLICY" typeRef="string">
          <text>reconciliationType</text>
        </inputExpression>
        <inputValues id="InputValues_1_ARCHIVE_POLICY">
          <text>"daily","weekly","monthly"</text>
        </inputValues>
      </input>

      <input id="Input_2_ARCHIVE_POLICY" label="Status">
        <inputExpression id="InputExpression_2_ARCHIVE_POLICY" typeRef="string">
          <text>status</text>
        </inputExpression>
        <inputValues id="InputValues_2_ARCHIVE_POLICY">
          <text>"CLOSED","OPEN","PENDING"</text>
        </inputValues>
      </input>

      <input id="Input_3_ARCHIVE_POLICY" label="Dias desde Fechamento">
        <inputExpression id="InputExpression_3_ARCHIVE_POLICY" typeRef="number">
          <text>daysSinceClosed</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado_ARCHIVE_POLICY" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_ARCHIVE_POLICY" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_ARCHIVE_POLICY" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1_ARCHIVE_POLICY">
        <description>Reconciliacao aberta nao pode ser arquivada</description>
        <inputEntry id="IE_1_1_ARCHIVE_POLICY"><text>-</text></inputEntry>
        <inputEntry id="IE_1_2_ARCHIVE_POLICY"><text>"OPEN","PENDING"</text></inputEntry>
        <inputEntry id="IE_1_3_ARCHIVE_POLICY"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1_ARCHIVE_POLICY"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2_ARCHIVE_POLICY"><text>"Reconciliacao ainda aberta - fechar antes de arquivar"</text></outputEntry>
        <outputEntry id="OE_1_3_ARCHIVE_POLICY"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2_ARCHIVE_POLICY">
        <description>Mensal fechada recentemente - manter ativa</description>
        <inputEntry id="IE_2_1_ARCHIVE_POLICY"><text>"monthly"</text></inputEntry>
        <inputEntry id="IE_2_2_ARCHIVE_POLICY"><text>"CLOSED"</text></inputEntry>
        <inputEntry id="IE_2_3_ARCHIVE_POLICY"><text>&lt; 730</text></inputEntry>
        <outputEntry id="OE_2_1_ARCHIVE_POLICY"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_2_2_ARCHIVE_POLICY"><text>"Reconciliacao mensal requer retencao minima de 2 anos"</text></outputEntry>
        <outputEntry id="OE_2_3_ARCHIVE_POLICY"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_3_ARCHIVE_POLICY">
        <description>Diaria antiga - pode arquivar</description>
        <inputEntry id="IE_3_1_ARCHIVE_POLICY"><text>"daily"</text></inputEntry>
        <inputEntry id="IE_3_2_ARCHIVE_POLICY"><text>"CLOSED"</text></inputEntry>
        <inputEntry id="IE_3_3_ARCHIVE_POLICY"><text>&gt;= 365</text></inputEntry>
        <outputEntry id="OE_3_1_ARCHIVE_POLICY"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_3_2_ARCHIVE_POLICY"><text>"Reconciliacao diaria com mais de 1 ano - elegivel para arquivamento"</text></outputEntry>
        <outputEntry id="OE_3_3_ARCHIVE_POLICY"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_4_ARCHIVE_POLICY">
        <description>Semanal antiga - pode arquivar</description>
        <inputEntry id="IE_4_1_ARCHIVE_POLICY"><text>"weekly"</text></inputEntry>
        <inputEntry id="IE_4_2_ARCHIVE_POLICY"><text>"CLOSED"</text></inputEntry>
        <inputEntry id="IE_4_3_ARCHIVE_POLICY"><text>&gt;= 365</text></inputEntry>
        <outputEntry id="OE_4_1_ARCHIVE_POLICY"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2_ARCHIVE_POLICY"><text>"Reconciliacao semanal com mais de 1 ano - elegivel para arquivamento"</text></outputEntry>
        <outputEntry id="OE_4_3_ARCHIVE_POLICY"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_5_ARCHIVE_POLICY">
        <description>Mensal antiga - pode arquivar</description>
        <inputEntry id="IE_5_1_ARCHIVE_POLICY"><text>"monthly"</text></inputEntry>
        <inputEntry id="IE_5_2_ARCHIVE_POLICY"><text>"CLOSED"</text></inputEntry>
        <inputEntry id="IE_5_3_ARCHIVE_POLICY"><text>&gt;= 730</text></inputEntry>
        <outputEntry id="OE_5_1_ARCHIVE_POLICY"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_2_ARCHIVE_POLICY"><text>"Reconciliacao mensal com mais de 2 anos - elegivel para arquivamento"</text></outputEntry>
        <outputEntry id="OE_5_3_ARCHIVE_POLICY"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_ARCHIVE_POLICY">
        <description>Fallback</description>
        <inputEntry id="IE_F_1_ARCHIVE_POLICY"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_ARCHIVE_POLICY"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3_ARCHIVE_POLICY"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_ARCHIVE_POLICY"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2_ARCHIVE_POLICY"><text>"Avaliar politica de retencao manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3_ARCHIVE_POLICY"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ARCHIVE_POLICY">
      <dmndi:DMNShape id="DMNShape_Decision_ARCHIVE_POLICY" dmnElementRef="Decision_ARCHIVE_POLICY">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
