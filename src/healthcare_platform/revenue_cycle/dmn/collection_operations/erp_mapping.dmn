<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  ERP-MAPPING - Mapeamento de Campos para ERP
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_OPERATIONS
  Archetype: ROUTING | Source: export_to_erp_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_ERP_MAPPING"
             name="Mapeamento de Campos para ERP"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_ERP_MAPPING" name="[SP-RC-013 | collection_operations] Mapeamento de Campos para ERP" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_ERP_MAPPING" hitPolicy="FIRST">

      <input id="Input_1_ERP_MAPPING" label="Sistema ERP">
        <inputExpression id="InputExpression_1_ERP_MAPPING" typeRef="string">
          <text>erpSystem</text>
        </inputExpression>
      </input>

      <input id="Input_2_ERP_MAPPING" label="Tipo Registro">
        <inputExpression id="InputExpression_2_ERP_MAPPING" typeRef="string">
          <text>recordType</text>
        </inputExpression>
      </input>

      <input id="Input_3_ERP_MAPPING" label="Versao API">
        <inputExpression id="InputExpression_3_ERP_MAPPING" typeRef="string">
          <text>apiVersion</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado_ERP_MAPPING" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_ERP_MAPPING" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_ERP_MAPPING" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1_ERP_MAPPING">
        <description>Tasy - mapeamento padrao CDC</description>
        <inputEntry id="IE_1_1_ERP_MAPPING"><text>"TASY"</text></inputEntry>
        <inputEntry id="IE_1_2_ERP_MAPPING"><text>"PAYMENT"</text></inputEntry>
        <inputEntry id="IE_1_3_ERP_MAPPING"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1_ERP_MAPPING"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_1_2_ERP_MAPPING"><text>"Usar mapeamento Tasy CDC padrao - campos nr_titulo, vl_pagamento"</text></outputEntry>
        <outputEntry id="OE_1_3_ERP_MAPPING"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_2_ERP_MAPPING">
        <description>MV Soul - mapeamento legado</description>
        <inputEntry id="IE_2_1_ERP_MAPPING"><text>"MV_SOUL"</text></inputEntry>
        <inputEntry id="IE_2_2_ERP_MAPPING"><text>"PAYMENT"</text></inputEntry>
        <inputEntry id="IE_2_3_ERP_MAPPING"><text>"v1"</text></inputEntry>
        <outputEntry id="OE_2_1_ERP_MAPPING"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_2_ERP_MAPPING"><text>"API v1 MV Soul depreciada - migrar para v2 quando possivel"</text></outputEntry>
        <outputEntry id="OE_2_3_ERP_MAPPING"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_3_ERP_MAPPING">
        <description>Tipo registro desconhecido</description>
        <inputEntry id="IE_3_1_ERP_MAPPING"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2_ERP_MAPPING"><text>not("PAYMENT","ADJUSTMENT","GLOSA","CREDIT")</text></inputEntry>
        <inputEntry id="IE_3_3_ERP_MAPPING"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1_ERP_MAPPING"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_3_2_ERP_MAPPING"><text>"Tipo de registro nao mapeado para exportacao ERP"</text></outputEntry>
        <outputEntry id="OE_3_3_ERP_MAPPING"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_4_ERP_MAPPING">
        <description>Ajuste contabil - requer campos extras</description>
        <inputEntry id="IE_4_1_ERP_MAPPING"><text>-</text></inputEntry>
        <inputEntry id="IE_4_2_ERP_MAPPING"><text>"ADJUSTMENT"</text></inputEntry>
        <inputEntry id="IE_4_3_ERP_MAPPING"><text>-</text></inputEntry>
        <outputEntry id="OE_4_1_ERP_MAPPING"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2_ERP_MAPPING"><text>"Incluir centro de custo e conta contabil no mapeamento"</text></outputEntry>
        <outputEntry id="OE_4_3_ERP_MAPPING"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_5_ERP_MAPPING">
        <description>Credito/estorno - validacao adicional</description>
        <inputEntry id="IE_5_1_ERP_MAPPING"><text>-</text></inputEntry>
        <inputEntry id="IE_5_2_ERP_MAPPING"><text>"CREDIT"</text></inputEntry>
        <inputEntry id="IE_5_3_ERP_MAPPING"><text>-</text></inputEntry>
        <outputEntry id="OE_5_1_ERP_MAPPING"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_5_2_ERP_MAPPING"><text>"Credito requer aprovacao antes de exportar ao ERP"</text></outputEntry>
        <outputEntry id="OE_5_3_ERP_MAPPING"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_ERP_MAPPING">
        <description>Fallback</description>
        <inputEntry id="IE_F_1_ERP_MAPPING"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_ERP_MAPPING"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3_ERP_MAPPING"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_ERP_MAPPING"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2_ERP_MAPPING"><text>"Validar mapeamento ERP manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3_ERP_MAPPING"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ERP_MAPPING">
      <dmndi:DMNShape id="DMNShape_Decision_ERP_MAPPING" dmnElementRef="Decision_ERP_MAPPING">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
