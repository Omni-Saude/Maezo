<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  COLLECTION-STRATEGY - Estrategia de Cobranca
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: prioritize_collection_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_COLLECTION_STRATEGY"
             name="Estrategia de Cobranca"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_COLLECTION_STRATEGY" name="[SP-RC-013 | collection_operations] Estrategia de Cobranca" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_COLLECTION_STRATEGY" hitPolicy="FIRST">

      <input id="Input_1_COLLECTION_STRATEGY" label="Prioridade">
        <inputExpression id="InputExpression_1_COLLECTION_STRATEGY" typeRef="string">
          <text>priority</text>
        </inputExpression>
        <inputValues id="InputValues_1_COLLECTION_STRATEGY">
          <text>"critical","high","medium","low"</text>
        </inputValues>
      </input>

      <input id="Input_2_COLLECTION_STRATEGY" label="Dias em Atraso">
        <inputExpression id="InputExpression_2_COLLECTION_STRATEGY" typeRef="integer">
          <text>days_overdue</text>
        </inputExpression>
      </input>

      <input id="Input_3_COLLECTION_STRATEGY" label="Valor">
        <inputExpression id="InputExpression_3_COLLECTION_STRATEGY" typeRef="double">
          <text>amount</text>
        </inputExpression>
      </input>

      <input id="Input_4_COLLECTION_STRATEGY" label="Perfil Pagador">
        <inputExpression id="InputExpression_4_COLLECTION_STRATEGY" typeRef="string">
          <text>payer_profile</text>
        </inputExpression>
        <inputValues id="InputValues_4_COLLECTION_STRATEGY">
          <text>"reliable","standard","risky","defaulter"</text>
        </inputValues>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_strategy_COLLECTION_STRATEGY" label="Estrategia" name="strategy" typeRef="string">
        <outputValues><text>"LEGAL_ESCALATION","INTENSIVE_FOLLOW_UP","STANDARD_COLLECTION","REMINDER_ONLY"</text></outputValues>
      </output>
      <output id="Output_frequency_COLLECTION_STRATEGY" label="Frequencia Contato" name="contact_frequency" typeRef="string">
        <outputValues><text>"daily","weekly","biweekly","monthly"</text></outputValues>
      </output>
      <output id="Output_path_COLLECTION_STRATEGY" label="Caminho Escalacao" name="escalation_path" typeRef="string">
        <outputValues><text>"legal_team","senior_collector","collector","automated"</text></outputValues>
      </output>

      <rule id="Rule_Legal_COLLECTION_STRATEGY">
        <description>Estrategia juridica - casos criticos</description>
        <inputEntry id="IE_1_1_COLLECTION_STRATEGY"><text>"critical"</text></inputEntry>
        <inputEntry id="IE_1_2_COLLECTION_STRATEGY"><text>&gt; 90</text></inputEntry>
        <inputEntry id="IE_1_3_COLLECTION_STRATEGY"><text>-</text></inputEntry>
        <inputEntry id="IE_1_4_COLLECTION_STRATEGY"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1_COLLECTION_STRATEGY"><text>"LEGAL_ESCALATION"</text></outputEntry>
        <outputEntry id="OE_1_2_COLLECTION_STRATEGY"><text>"daily"</text></outputEntry>
        <outputEntry id="OE_1_3_COLLECTION_STRATEGY"><text>"legal_team"</text></outputEntry>
      </rule>

      <rule id="Rule_Intensive_COLLECTION_STRATEGY">
        <description>Cobranca intensiva - prioridade alta</description>
        <inputEntry id="IE_2_1_COLLECTION_STRATEGY"><text>"high"</text></inputEntry>
        <inputEntry id="IE_2_2_COLLECTION_STRATEGY"><text>&gt; 60</text></inputEntry>
        <inputEntry id="IE_2_3_COLLECTION_STRATEGY"><text>-</text></inputEntry>
        <inputEntry id="IE_2_4_COLLECTION_STRATEGY"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1_COLLECTION_STRATEGY"><text>"INTENSIVE_FOLLOW_UP"</text></outputEntry>
        <outputEntry id="OE_2_2_COLLECTION_STRATEGY"><text>"weekly"</text></outputEntry>
        <outputEntry id="OE_2_3_COLLECTION_STRATEGY"><text>"senior_collector"</text></outputEntry>
      </rule>

      <rule id="Rule_Standard_COLLECTION_STRATEGY">
        <description>Cobranca padrao - prioridade media</description>
        <inputEntry id="IE_3_1_COLLECTION_STRATEGY"><text>"medium"</text></inputEntry>
        <inputEntry id="IE_3_2_COLLECTION_STRATEGY"><text>&gt; 30</text></inputEntry>
        <inputEntry id="IE_3_3_COLLECTION_STRATEGY"><text>-</text></inputEntry>
        <inputEntry id="IE_3_4_COLLECTION_STRATEGY"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1_COLLECTION_STRATEGY"><text>"STANDARD_COLLECTION"</text></outputEntry>
        <outputEntry id="OE_3_2_COLLECTION_STRATEGY"><text>"biweekly"</text></outputEntry>
        <outputEntry id="OE_3_3_COLLECTION_STRATEGY"><text>"collector"</text></outputEntry>
      </rule>

      <rule id="Rule_Reminder_COLLECTION_STRATEGY">
        <description>Apenas lembretes - prioridade baixa</description>
        <inputEntry id="IE_F_1_COLLECTION_STRATEGY"><text>"low"</text></inputEntry>
        <inputEntry id="IE_F_2_COLLECTION_STRATEGY"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3_COLLECTION_STRATEGY"><text>-</text></inputEntry>
        <inputEntry id="IE_F_4_COLLECTION_STRATEGY"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_COLLECTION_STRATEGY"><text>"REMINDER_ONLY"</text></outputEntry>
        <outputEntry id="OE_F_2_COLLECTION_STRATEGY"><text>"monthly"</text></outputEntry>
        <outputEntry id="OE_F_3_COLLECTION_STRATEGY"><text>"automated"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_COLLECTION_STRATEGY">
      <dmndi:DMNShape id="DMNShape_Decision_COLLECTION_STRATEGY" dmnElementRef="Decision_COLLECTION_STRATEGY">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
