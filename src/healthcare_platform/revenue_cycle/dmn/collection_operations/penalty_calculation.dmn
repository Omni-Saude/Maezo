<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  PENALTY-CALCULATION - Calculo de Multas e Penalidades
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: apply_penalties_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_PENALTY_CALCULATION"
             name="Calculo de Multas e Penalidades"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_PENALTY_CALCULATION" name="[SP-RC-013 | collection_operations] Calculo de Multas e Penalidades" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_PENALTY_CALCULATION" hitPolicy="FIRST">

      <input id="Input_1_PENALTY_CALCULATION" label="Dias em Atraso">
        <inputExpression id="InputExpression_1_PENALTY_CALCULATION" typeRef="integer">
          <text>days_overdue</text>
        </inputExpression>
      </input>

      <input id="Input_2_PENALTY_CALCULATION" label="Valor Devido">
        <inputExpression id="InputExpression_2_PENALTY_CALCULATION" typeRef="double">
          <text>amount_due</text>
        </inputExpression>
      </input>

      <input id="Input_3_PENALTY_CALCULATION" label="Tipo Pagador">
        <inputExpression id="InputExpression_3_PENALTY_CALCULATION" typeRef="string">
          <text>payer_type</text>
        </inputExpression>
        <inputValues id="InputValues_3_PENALTY_CALCULATION">
          <text>"individual","institutional","government"</text>
        </inputValues>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_amount_PENALTY_CALCULATION" label="Valor Multa" name="penalty_amount" typeRef="double"/>
      <output id="Output_rate_PENALTY_CALCULATION" label="Taxa Multa" name="penalty_rate" typeRef="double"/>
      <output id="Output_type_PENALTY_CALCULATION" label="Tipo Multa" name="penalty_type" typeRef="string">
        <outputValues><text>"MORA","MULTA","JUROS","NONE"</text></outputValues>
      </output>

      <rule id="Rule_Mora_PENALTY_CALCULATION">
        <description>Mora - acima 90 dias institucional</description>
        <inputEntry id="IE_1_1_PENALTY_CALCULATION"><text>&gt; 90</text></inputEntry>
        <inputEntry id="IE_1_2_PENALTY_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3_PENALTY_CALCULATION"><text>"institutional"</text></inputEntry>
        <outputEntry id="OE_1_1_PENALTY_CALCULATION"><text>amount_due * 0.02</text></outputEntry>
        <outputEntry id="OE_1_2_PENALTY_CALCULATION"><text>0.02</text></outputEntry>
        <outputEntry id="OE_1_3_PENALTY_CALCULATION"><text>"MORA"</text></outputEntry>
      </rule>

      <rule id="Rule_Multa_PENALTY_CALCULATION">
        <description>Multa - acima 60 dias</description>
        <inputEntry id="IE_2_1_PENALTY_CALCULATION"><text>&gt; 60</text></inputEntry>
        <inputEntry id="IE_2_2_PENALTY_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_2_3_PENALTY_CALCULATION"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1_PENALTY_CALCULATION"><text>amount_due * 0.01</text></outputEntry>
        <outputEntry id="OE_2_2_PENALTY_CALCULATION"><text>0.01</text></outputEntry>
        <outputEntry id="OE_2_3_PENALTY_CALCULATION"><text>"MULTA"</text></outputEntry>
      </rule>

      <rule id="Rule_Juros_PENALTY_CALCULATION">
        <description>Juros - acima 30 dias</description>
        <inputEntry id="IE_3_1_PENALTY_CALCULATION"><text>&gt; 30</text></inputEntry>
        <inputEntry id="IE_3_2_PENALTY_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_3_3_PENALTY_CALCULATION"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1_PENALTY_CALCULATION"><text>amount_due * 0.005</text></outputEntry>
        <outputEntry id="OE_3_2_PENALTY_CALCULATION"><text>0.005</text></outputEntry>
        <outputEntry id="OE_3_3_PENALTY_CALCULATION"><text>"JUROS"</text></outputEntry>
      </rule>

      <rule id="Rule_NoPenalty_PENALTY_CALCULATION">
        <description>Sem penalidade</description>
        <inputEntry id="IE_F_1_PENALTY_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_PENALTY_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3_PENALTY_CALCULATION"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_PENALTY_CALCULATION"><text>0</text></outputEntry>
        <outputEntry id="OE_F_2_PENALTY_CALCULATION"><text>0</text></outputEntry>
        <outputEntry id="OE_F_3_PENALTY_CALCULATION"><text>"NONE"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PENALTY_CALCULATION">
      <dmndi:DMNShape id="DMNShape_Decision_PENALTY_CALCULATION" dmnElementRef="Decision_PENALTY_CALCULATION">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
