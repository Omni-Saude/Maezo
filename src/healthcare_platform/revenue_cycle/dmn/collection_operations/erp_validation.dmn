<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  ERP-VALIDATION - Validacao de Dados para Exportacao ERP
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: export_to_erp_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_ERP_VALIDATION"
             name="Validacao de Dados para Exportacao ERP"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_ERP_VALIDATION" name="[SP-RC-013 | collection_operations] Validacao de Dados para Exportacao ERP" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_ERP_VALIDATION" hitPolicy="FIRST">

      <input id="Input_1_ERP_VALIDATION" label="Account ID Presente">
        <inputExpression id="InputExpression_1_ERP_VALIDATION" typeRef="boolean">
          <text>hasAccountId</text>
        </inputExpression>
      </input>

      <input id="Input_2_ERP_VALIDATION" label="Dados Completos">
        <inputExpression id="InputExpression_2_ERP_VALIDATION" typeRef="boolean">
          <text>dataComplete</text>
        </inputExpression>
      </input>

      <input id="Input_3_ERP_VALIDATION" label="Sistema ERP">
        <inputExpression id="InputExpression_3_ERP_VALIDATION" typeRef="string">
          <text>erpSystem</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado_ERP_VALIDATION" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_ERP_VALIDATION" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_ERP_VALIDATION" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1_ERP_VALIDATION">
        <description>Sem account ID - bloqueio</description>
        <inputEntry id="IE_1_1_ERP_VALIDATION"><text>false</text></inputEntry>
        <inputEntry id="IE_1_2_ERP_VALIDATION"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3_ERP_VALIDATION"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1_ERP_VALIDATION"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2_ERP_VALIDATION"><text>"Account ID obrigatorio para sincronizacao com ERP"</text></outputEntry>
        <outputEntry id="OE_1_3_ERP_VALIDATION"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2_ERP_VALIDATION">
        <description>Dados incompletos</description>
        <inputEntry id="IE_2_1_ERP_VALIDATION"><text>true</text></inputEntry>
        <inputEntry id="IE_2_2_ERP_VALIDATION"><text>false</text></inputEntry>
        <inputEntry id="IE_2_3_ERP_VALIDATION"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1_ERP_VALIDATION"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_2_ERP_VALIDATION"><text>"Dados incompletos para exportacao - complementar antes de sincronizar"</text></outputEntry>
        <outputEntry id="OE_2_3_ERP_VALIDATION"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_3_ERP_VALIDATION">
        <description>ERP nao suportado</description>
        <inputEntry id="IE_3_1_ERP_VALIDATION"><text>true</text></inputEntry>
        <inputEntry id="IE_3_2_ERP_VALIDATION"><text>true</text></inputEntry>
        <inputEntry id="IE_3_3_ERP_VALIDATION"><text>not("tasy","mv_soul")</text></inputEntry>
        <outputEntry id="OE_3_1_ERP_VALIDATION"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_3_2_ERP_VALIDATION"><text>"Sistema ERP nao suportado pela integracao"</text></outputEntry>
        <outputEntry id="OE_3_3_ERP_VALIDATION"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_4_ERP_VALIDATION">
        <description>Dados validos para Tasy</description>
        <inputEntry id="IE_4_1_ERP_VALIDATION"><text>true</text></inputEntry>
        <inputEntry id="IE_4_2_ERP_VALIDATION"><text>true</text></inputEntry>
        <inputEntry id="IE_4_3_ERP_VALIDATION"><text>"tasy"</text></inputEntry>
        <outputEntry id="OE_4_1_ERP_VALIDATION"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2_ERP_VALIDATION"><text>"Dados validados para exportacao Tasy"</text></outputEntry>
        <outputEntry id="OE_4_3_ERP_VALIDATION"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_5_ERP_VALIDATION">
        <description>Dados validos para MV Soul</description>
        <inputEntry id="IE_5_1_ERP_VALIDATION"><text>true</text></inputEntry>
        <inputEntry id="IE_5_2_ERP_VALIDATION"><text>true</text></inputEntry>
        <inputEntry id="IE_5_3_ERP_VALIDATION"><text>"mv_soul"</text></inputEntry>
        <outputEntry id="OE_5_1_ERP_VALIDATION"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_2_ERP_VALIDATION"><text>"Dados validados para exportacao MV Soul"</text></outputEntry>
        <outputEntry id="OE_5_3_ERP_VALIDATION"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_ERP_VALIDATION">
        <description>Fallback</description>
        <inputEntry id="IE_F_1_ERP_VALIDATION"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_ERP_VALIDATION"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3_ERP_VALIDATION"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_ERP_VALIDATION"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2_ERP_VALIDATION"><text>"Validar dados de exportacao manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3_ERP_VALIDATION"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ERP_VALIDATION">
      <dmndi:DMNShape id="DMNShape_Decision_ERP_VALIDATION" dmnElementRef="Decision_ERP_VALIDATION">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
