<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  PRIORITY-SCORING - Calculo de Prioridade de Cobranca
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_SCORING | Source: prioritize_collection_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_PRIORITY_SCORING"
             name="Calculo de Prioridade de Cobranca"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_PRIORITY_SCORING" name="[SP-RC-013 | collection_operations] Calculo de Prioridade de Cobranca" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_PRIORITY_SCORING" hitPolicy="COLLECT" aggregation="SUM">

      <input id="Input_1_PRIORITY_SCORING" label="Valor">
        <inputExpression id="InputExpression_1_PRIORITY_SCORING" typeRef="double">
          <text>amount</text>
        </inputExpression>
      </input>

      <input id="Input_2_PRIORITY_SCORING" label="Dias em Atraso">
        <inputExpression id="InputExpression_2_PRIORITY_SCORING" typeRef="integer">
          <text>days_overdue</text>
        </inputExpression>
      </input>

      <input id="Input_3_PRIORITY_SCORING" label="Taxa Inadimplencia Pagador">
        <inputExpression id="InputExpression_3_PRIORITY_SCORING" typeRef="double">
          <text>payer_default_rate</text>
        </inputExpression>
      </input>

      <input id="Input_4_PRIORITY_SCORING" label="Tipo Conta">
        <inputExpression id="InputExpression_4_PRIORITY_SCORING" typeRef="string">
          <text>claim_type</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_score_PRIORITY_SCORING" label="Pontuacao" name="priority_score" typeRef="integer"/>
      <output id="Output_level_PRIORITY_SCORING" label="Nivel Prioridade" name="priority_level" typeRef="string">
        <outputValues><text>"critical","high","medium","low"</text></outputValues>
      </output>

      <rule id="Rule_Critical_1_PRIORITY_SCORING">
        <description>Critico: Alto valor e muito atrasado</description>
        <inputEntry id="IE_C1_1_PRIORITY_SCORING"><text>&gt; 50000</text></inputEntry>
        <inputEntry id="IE_C1_2_PRIORITY_SCORING"><text>&gt; 90</text></inputEntry>
        <inputEntry id="IE_C1_3_PRIORITY_SCORING"><text>-</text></inputEntry>
        <inputEntry id="IE_C1_4_PRIORITY_SCORING"><text>-</text></inputEntry>
        <outputEntry id="OE_C1_1_PRIORITY_SCORING"><text>100</text></outputEntry>
        <outputEntry id="OE_C1_2_PRIORITY_SCORING"><text>"critical"</text></outputEntry>
      </rule>

      <rule id="Rule_High_1_PRIORITY_SCORING">
        <description>Alto: Valor medio e atraso significativo</description>
        <inputEntry id="IE_H1_1_PRIORITY_SCORING"><text>&gt; 10000</text></inputEntry>
        <inputEntry id="IE_H1_2_PRIORITY_SCORING"><text>&gt; 60</text></inputEntry>
        <inputEntry id="IE_H1_3_PRIORITY_SCORING"><text>-</text></inputEntry>
        <inputEntry id="IE_H1_4_PRIORITY_SCORING"><text>-</text></inputEntry>
        <outputEntry id="OE_H1_1_PRIORITY_SCORING"><text>75</text></outputEntry>
        <outputEntry id="OE_H1_2_PRIORITY_SCORING"><text>"high"</text></outputEntry>
      </rule>

      <rule id="Rule_Medium_1_PRIORITY_SCORING">
        <description>Medio: Valor moderado com atraso</description>
        <inputEntry id="IE_M1_1_PRIORITY_SCORING"><text>&gt; 5000</text></inputEntry>
        <inputEntry id="IE_M1_2_PRIORITY_SCORING"><text>&gt; 30</text></inputEntry>
        <inputEntry id="IE_M1_3_PRIORITY_SCORING"><text>-</text></inputEntry>
        <inputEntry id="IE_M1_4_PRIORITY_SCORING"><text>-</text></inputEntry>
        <outputEntry id="OE_M1_1_PRIORITY_SCORING"><text>50</text></outputEntry>
        <outputEntry id="OE_M1_2_PRIORITY_SCORING"><text>"medium"</text></outputEntry>
      </rule>

      <rule id="Rule_Low_Fallback_PRIORITY_SCORING">
        <description>Baixo: Demais casos</description>
        <inputEntry id="IE_L1_1_PRIORITY_SCORING"><text>-</text></inputEntry>
        <inputEntry id="IE_L1_2_PRIORITY_SCORING"><text>-</text></inputEntry>
        <inputEntry id="IE_L1_3_PRIORITY_SCORING"><text>-</text></inputEntry>
        <inputEntry id="IE_L1_4_PRIORITY_SCORING"><text>-</text></inputEntry>
        <outputEntry id="OE_L1_1_PRIORITY_SCORING"><text>25</text></outputEntry>
        <outputEntry id="OE_L1_2_PRIORITY_SCORING"><text>"low"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PRIORITY_SCORING">
      <dmndi:DMNShape id="DMNShape_Decision_PRIORITY_SCORING" dmnElementRef="Decision_PRIORITY_SCORING">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
