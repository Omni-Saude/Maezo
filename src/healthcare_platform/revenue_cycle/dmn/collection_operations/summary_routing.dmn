<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  SUMMARY-ROUTING - Roteamento de Envio de Resumo Diario
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: send_daily_summary_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_SUMMARY_ROUTING"
             name="Roteamento de Envio de Resumo Diario"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_SUMMARY_ROUTING" name="[SP-RC-013 | collection_operations] Roteamento de Envio de Resumo Diario" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_SUMMARY_ROUTING" hitPolicy="FIRST">

      <input id="Input_1_SUMMARY_ROUTING" label="Taxa Cobranca (%)">
        <inputExpression id="InputExpression_1_SUMMARY_ROUTING" typeRef="number">
          <text>collectionRate</text>
        </inputExpression>
      </input>

      <input id="Input_2_SUMMARY_ROUTING" label="DSO (dias)">
        <inputExpression id="InputExpression_2_SUMMARY_ROUTING" typeRef="number">
          <text>dso</text>
        </inputExpression>
      </input>

      <input id="Input_3_SUMMARY_ROUTING" label="Quantidade Vencidos">
        <inputExpression id="InputExpression_3_SUMMARY_ROUTING" typeRef="number">
          <text>overdueCount</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado_SUMMARY_ROUTING" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_SUMMARY_ROUTING" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_SUMMARY_ROUTING" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1_SUMMARY_ROUTING">
        <description>Metricas criticas - alerta urgente</description>
        <inputEntry id="IE_1_1_SUMMARY_ROUTING"><text>&lt; 60</text></inputEntry>
        <inputEntry id="IE_1_2_SUMMARY_ROUTING"><text>&gt; 90</text></inputEntry>
        <inputEntry id="IE_1_3_SUMMARY_ROUTING"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1_SUMMARY_ROUTING"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2_SUMMARY_ROUTING"><text>"Metricas criticas - enviar alerta urgente para diretoria alem do resumo"</text></outputEntry>
        <outputEntry id="OE_1_3_SUMMARY_ROUTING"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2_SUMMARY_ROUTING">
        <description>Muitos vencidos - destaque no resumo</description>
        <inputEntry id="IE_2_1_SUMMARY_ROUTING"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2_SUMMARY_ROUTING"><text>-</text></inputEntry>
        <inputEntry id="IE_2_3_SUMMARY_ROUTING"><text>&gt; 50</text></inputEntry>
        <outputEntry id="OE_2_1_SUMMARY_ROUTING"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_2_SUMMARY_ROUTING"><text>"Alto volume de vencidos - destacar no resumo e notificar gestores"</text></outputEntry>
        <outputEntry id="OE_2_3_SUMMARY_ROUTING"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_3_SUMMARY_ROUTING">
        <description>Taxa baixa de cobranca</description>
        <inputEntry id="IE_3_1_SUMMARY_ROUTING"><text>[60..80]</text></inputEntry>
        <inputEntry id="IE_3_2_SUMMARY_ROUTING"><text>-</text></inputEntry>
        <inputEntry id="IE_3_3_SUMMARY_ROUTING"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1_SUMMARY_ROUTING"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_3_2_SUMMARY_ROUTING"><text>"Taxa de cobranca abaixo do ideal - incluir recomendacoes no resumo"</text></outputEntry>
        <outputEntry id="OE_3_3_SUMMARY_ROUTING"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_4_SUMMARY_ROUTING">
        <description>Metricas saudaveis</description>
        <inputEntry id="IE_4_1_SUMMARY_ROUTING"><text>&gt;= 80</text></inputEntry>
        <inputEntry id="IE_4_2_SUMMARY_ROUTING"><text>&lt;= 60</text></inputEntry>
        <inputEntry id="IE_4_3_SUMMARY_ROUTING"><text>&lt;= 20</text></inputEntry>
        <outputEntry id="OE_4_1_SUMMARY_ROUTING"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2_SUMMARY_ROUTING"><text>"Metricas saudaveis - enviar resumo padrao"</text></outputEntry>
        <outputEntry id="OE_4_3_SUMMARY_ROUTING"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_5_SUMMARY_ROUTING">
        <description>DSO elevado</description>
        <inputEntry id="IE_5_1_SUMMARY_ROUTING"><text>-</text></inputEntry>
        <inputEntry id="IE_5_2_SUMMARY_ROUTING"><text>[60..90]</text></inputEntry>
        <inputEntry id="IE_5_3_SUMMARY_ROUTING"><text>-</text></inputEntry>
        <outputEntry id="OE_5_1_SUMMARY_ROUTING"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_2_SUMMARY_ROUTING"><text>"DSO elevado - incluir analise de tendencia no resumo"</text></outputEntry>
        <outputEntry id="OE_5_3_SUMMARY_ROUTING"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_SUMMARY_ROUTING">
        <description>Fallback</description>
        <inputEntry id="IE_F_1_SUMMARY_ROUTING"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_SUMMARY_ROUTING"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3_SUMMARY_ROUTING"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_SUMMARY_ROUTING"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_F_2_SUMMARY_ROUTING"><text>"Enviar resumo padrao"</text></outputEntry>
        <outputEntry id="OE_F_3_SUMMARY_ROUTING"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_SUMMARY_ROUTING">
      <dmndi:DMNShape id="DMNShape_Decision_SUMMARY_ROUTING" dmnElementRef="Decision_SUMMARY_ROUTING">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
