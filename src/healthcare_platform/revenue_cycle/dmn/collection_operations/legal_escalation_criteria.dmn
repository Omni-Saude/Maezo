<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  LEGAL-ESCALATION-CRITERIA - Criterios para Escalacao Juridica
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: escalate_to_legal_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_LEGAL_ESCALATION_CRITERIA"
             name="Criterios para Escalacao Juridica"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_LEGAL_ESCALATION_CRITERIA" name="[SP-RC-013 | collection_operations] Criterios para Escalacao Juridica" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_LEGAL_ESCALATION_CRITERIA" hitPolicy="FIRST">

      <input id="Input_1_LEGAL_ESCALATION_CRITERIA" label="Valor Devido">
        <inputExpression id="InputExpression_1_LEGAL_ESCALATION_CRITERIA" typeRef="double">
          <text>amount_due</text>
        </inputExpression>
      </input>

      <input id="Input_2_LEGAL_ESCALATION_CRITERIA" label="Dias em Atraso">
        <inputExpression id="InputExpression_2_LEGAL_ESCALATION_CRITERIA" typeRef="integer">
          <text>days_overdue</text>
        </inputExpression>
      </input>

      <input id="Input_3_LEGAL_ESCALATION_CRITERIA" label="Tentativas Cobranca">
        <inputExpression id="InputExpression_3_LEGAL_ESCALATION_CRITERIA" typeRef="integer">
          <text>collection_attempts</text>
        </inputExpression>
      </input>

      <input id="Input_4_LEGAL_ESCALATION_CRITERIA" label="Tipo Pagador">
        <inputExpression id="InputExpression_4_LEGAL_ESCALATION_CRITERIA" typeRef="string">
          <text>payer_type</text>
        </inputExpression>
        <inputValues id="InputValues_4_LEGAL_ESCALATION_CRITERIA">
          <text>"individual","corporate","government"</text>
        </inputValues>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_escalate_LEGAL_ESCALATION_CRITERIA" label="Escalar para Juridico" name="escalate_to_legal" typeRef="boolean"/>
      <output id="Output_urgency_LEGAL_ESCALATION_CRITERIA" label="Nivel Urgencia" name="urgency_level" typeRef="string">
        <outputValues><text>"critical","high","medium","none"</text></outputValues>
      </output>
      <output id="Output_reason_LEGAL_ESCALATION_CRITERIA" label="Codigo Motivo" name="reason_code" typeRef="string">
        <outputValues><text>"CHRONIC_DEFAULT","EXHAUSTED_COLLECTION","INDIVIDUAL_DEFAULT","NOT_APPLICABLE"</text></outputValues>
      </output>

      <rule id="Rule_Critical_1_LEGAL_ESCALATION_CRITERIA">
        <description>Critico: Inadimplencia cronica com alto valor</description>
        <inputEntry id="IE_1_1_LEGAL_ESCALATION_CRITERIA"><text>&gt; 10000</text></inputEntry>
        <inputEntry id="IE_1_2_LEGAL_ESCALATION_CRITERIA"><text>&gt; 180</text></inputEntry>
        <inputEntry id="IE_1_3_LEGAL_ESCALATION_CRITERIA"><text>-</text></inputEntry>
        <inputEntry id="IE_1_4_LEGAL_ESCALATION_CRITERIA"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1_LEGAL_ESCALATION_CRITERIA"><text>true</text></outputEntry>
        <outputEntry id="OE_1_2_LEGAL_ESCALATION_CRITERIA"><text>"critical"</text></outputEntry>
        <outputEntry id="OE_1_3_LEGAL_ESCALATION_CRITERIA"><text>"CHRONIC_DEFAULT"</text></outputEntry>
      </rule>

      <rule id="Rule_High_1_LEGAL_ESCALATION_CRITERIA">
        <description>Alto: Esgotadas tentativas de cobranca</description>
        <inputEntry id="IE_2_1_LEGAL_ESCALATION_CRITERIA"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2_LEGAL_ESCALATION_CRITERIA"><text>&gt; 120</text></inputEntry>
        <inputEntry id="IE_2_3_LEGAL_ESCALATION_CRITERIA"><text>&gt; 5</text></inputEntry>
        <inputEntry id="IE_2_4_LEGAL_ESCALATION_CRITERIA"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1_LEGAL_ESCALATION_CRITERIA"><text>true</text></outputEntry>
        <outputEntry id="OE_2_2_LEGAL_ESCALATION_CRITERIA"><text>"high"</text></outputEntry>
        <outputEntry id="OE_2_3_LEGAL_ESCALATION_CRITERIA"><text>"EXHAUSTED_COLLECTION"</text></outputEntry>
      </rule>

      <rule id="Rule_Medium_1_LEGAL_ESCALATION_CRITERIA">
        <description>Medio: Pessoa fisica com valor significativo</description>
        <inputEntry id="IE_3_1_LEGAL_ESCALATION_CRITERIA"><text>&gt; 5000</text></inputEntry>
        <inputEntry id="IE_3_2_LEGAL_ESCALATION_CRITERIA"><text>&gt; 90</text></inputEntry>
        <inputEntry id="IE_3_3_LEGAL_ESCALATION_CRITERIA"><text>-</text></inputEntry>
        <inputEntry id="IE_3_4_LEGAL_ESCALATION_CRITERIA"><text>"individual"</text></inputEntry>
        <outputEntry id="OE_3_1_LEGAL_ESCALATION_CRITERIA"><text>true</text></outputEntry>
        <outputEntry id="OE_3_2_LEGAL_ESCALATION_CRITERIA"><text>"medium"</text></outputEntry>
        <outputEntry id="OE_3_3_LEGAL_ESCALATION_CRITERIA"><text>"INDIVIDUAL_DEFAULT"</text></outputEntry>
      </rule>

      <rule id="Rule_NoEscalation_LEGAL_ESCALATION_CRITERIA">
        <description>Nao escalar: Criterios nao atingidos</description>
        <inputEntry id="IE_F_1_LEGAL_ESCALATION_CRITERIA"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_LEGAL_ESCALATION_CRITERIA"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3_LEGAL_ESCALATION_CRITERIA"><text>-</text></inputEntry>
        <inputEntry id="IE_F_4_LEGAL_ESCALATION_CRITERIA"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_LEGAL_ESCALATION_CRITERIA"><text>false</text></outputEntry>
        <outputEntry id="OE_F_2_LEGAL_ESCALATION_CRITERIA"><text>"none"</text></outputEntry>
        <outputEntry id="OE_F_3_LEGAL_ESCALATION_CRITERIA"><text>"NOT_APPLICABLE"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_LEGAL_ESCALATION_CRITERIA">
      <dmndi:DMNShape id="DMNShape_Decision_LEGAL_ESCALATION_CRITERIA" dmnElementRef="Decision_LEGAL_ESCALATION_CRITERIA">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
