<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  WRITE-OFF-THRESHOLDS - Limiares para Write-off de Contas
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: write_off_bad_debt_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_WRITE_OFF_THRESHOLDS"
             name="Limiares para Write-off de Contas"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_WRITE_OFF_THRESHOLDS" name="[SP-RC-013 | collection_operations] Limiares para Write-off de Contas" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_WRITE_OFF_THRESHOLDS" hitPolicy="FIRST">

      <input id="Input_1_WRITE_OFF_THRESHOLDS" label="Valor">
        <inputExpression id="InputExpression_1_WRITE_OFF_THRESHOLDS" typeRef="double">
          <text>amount</text>
        </inputExpression>
      </input>

      <input id="Input_2_WRITE_OFF_THRESHOLDS" label="Dias em Atraso">
        <inputExpression id="InputExpression_2_WRITE_OFF_THRESHOLDS" typeRef="integer">
          <text>days_overdue</text>
        </inputExpression>
      </input>

      <input id="Input_3_WRITE_OFF_THRESHOLDS" label="Custo Cobranca">
        <inputExpression id="InputExpression_3_WRITE_OFF_THRESHOLDS" typeRef="double">
          <text>collection_cost</text>
        </inputExpression>
      </input>

      <input id="Input_4_WRITE_OFF_THRESHOLDS" label="Probabilidade Recuperacao">
        <inputExpression id="InputExpression_4_WRITE_OFF_THRESHOLDS" typeRef="double">
          <text>recovery_probability</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_approved_WRITE_OFF_THRESHOLDS" label="Aprovar Write-off" name="write_off_approved" typeRef="boolean"/>
      <output id="Output_reason_WRITE_OFF_THRESHOLDS" label="Codigo Motivo" name="reason_code" typeRef="string">
        <outputValues><text>"SMALL_BALANCE","LOW_RECOVERY","COST_EXCEEDS","NONE"</text></outputValues>
      </output>
      <output id="Output_manager_WRITE_OFF_THRESHOLDS" label="Requer Aprovacao Gerente" name="requires_manager_approval" typeRef="boolean"/>

      <rule id="Rule_SmallBalance_WRITE_OFF_THRESHOLDS">
        <description>Saldo pequeno com atraso longo</description>
        <inputEntry id="IE_1_1_WRITE_OFF_THRESHOLDS"><text>&lt; 100</text></inputEntry>
        <inputEntry id="IE_1_2_WRITE_OFF_THRESHOLDS"><text>&gt; 365</text></inputEntry>
        <inputEntry id="IE_1_3_WRITE_OFF_THRESHOLDS"><text>-</text></inputEntry>
        <inputEntry id="IE_1_4_WRITE_OFF_THRESHOLDS"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1_WRITE_OFF_THRESHOLDS"><text>true</text></outputEntry>
        <outputEntry id="OE_1_2_WRITE_OFF_THRESHOLDS"><text>"SMALL_BALANCE"</text></outputEntry>
        <outputEntry id="OE_1_3_WRITE_OFF_THRESHOLDS"><text>false</text></outputEntry>
      </rule>

      <rule id="Rule_LowRecovery_WRITE_OFF_THRESHOLDS">
        <description>Baixa probabilidade de recuperacao</description>
        <inputEntry id="IE_2_1_WRITE_OFF_THRESHOLDS"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2_WRITE_OFF_THRESHOLDS"><text>&gt; 180</text></inputEntry>
        <inputEntry id="IE_2_3_WRITE_OFF_THRESHOLDS"><text>-</text></inputEntry>
        <inputEntry id="IE_2_4_WRITE_OFF_THRESHOLDS"><text>&lt; 0.1</text></inputEntry>
        <outputEntry id="OE_2_1_WRITE_OFF_THRESHOLDS"><text>true</text></outputEntry>
        <outputEntry id="OE_2_2_WRITE_OFF_THRESHOLDS"><text>"LOW_RECOVERY"</text></outputEntry>
        <outputEntry id="OE_2_3_WRITE_OFF_THRESHOLDS"><text>true</text></outputEntry>
      </rule>

      <rule id="Rule_CostExceeds_WRITE_OFF_THRESHOLDS">
        <description>Custo cobranca excede valor recuperavel</description>
        <inputEntry id="IE_3_1_WRITE_OFF_THRESHOLDS"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2_WRITE_OFF_THRESHOLDS"><text>-</text></inputEntry>
        <inputEntry id="IE_3_3_WRITE_OFF_THRESHOLDS"><text>&gt; amount * 0.5</text></inputEntry>
        <inputEntry id="IE_3_4_WRITE_OFF_THRESHOLDS"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1_WRITE_OFF_THRESHOLDS"><text>true</text></outputEntry>
        <outputEntry id="OE_3_2_WRITE_OFF_THRESHOLDS"><text>"COST_EXCEEDS"</text></outputEntry>
        <outputEntry id="OE_3_3_WRITE_OFF_THRESHOLDS"><text>true</text></outputEntry>
      </rule>

      <rule id="Rule_NoWriteOff_WRITE_OFF_THRESHOLDS">
        <description>Nao aprovar write-off</description>
        <inputEntry id="IE_F_1_WRITE_OFF_THRESHOLDS"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_WRITE_OFF_THRESHOLDS"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3_WRITE_OFF_THRESHOLDS"><text>-</text></inputEntry>
        <inputEntry id="IE_F_4_WRITE_OFF_THRESHOLDS"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_WRITE_OFF_THRESHOLDS"><text>false</text></outputEntry>
        <outputEntry id="OE_F_2_WRITE_OFF_THRESHOLDS"><text>"NONE"</text></outputEntry>
        <outputEntry id="OE_F_3_WRITE_OFF_THRESHOLDS"><text>false</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_WRITE_OFF_THRESHOLDS">
      <dmndi:DMNShape id="DMNShape_Decision_WRITE_OFF_THRESHOLDS" dmnElementRef="Decision_WRITE_OFF_THRESHOLDS">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
