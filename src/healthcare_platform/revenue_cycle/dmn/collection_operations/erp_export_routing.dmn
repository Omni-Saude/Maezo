<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  ERP-EXPORT-ROUTING - Roteamento de Exportacao ERP
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: export_to_erp_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_ERP_EXPORT_ROUTING"
             name="Roteamento de Exportacao ERP"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_ERP_EXPORT_ROUTING" name="[SP-RC-013 | collection_operations] Roteamento de Exportacao ERP" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_ERP_EXPORT_ROUTING" hitPolicy="FIRST">

      <input id="Input_1_ERP_EXPORT_ROUTING" label="Sistema ERP">
        <inputExpression id="InputExpression_1_ERP_EXPORT_ROUTING" typeRef="string">
          <text>erpSystem</text>
        </inputExpression>
        <inputValues id="InputValues_1_ERP_EXPORT_ROUTING">
          <text>"tasy","mv_soul"</text>
        </inputValues>
      </input>

      <input id="Input_2_ERP_EXPORT_ROUTING" label="Tipo Entidade">
        <inputExpression id="InputExpression_2_ERP_EXPORT_ROUTING" typeRef="string">
          <text>entityType</text>
        </inputExpression>
        <inputValues id="InputValues_2_ERP_EXPORT_ROUTING">
          <text>"payment","reconciliation","adjustment","refund"</text>
        </inputValues>
      </input>

      <input id="Input_3_ERP_EXPORT_ROUTING" label="Operacao">
        <inputExpression id="InputExpression_3_ERP_EXPORT_ROUTING" typeRef="string">
          <text>operation</text>
        </inputExpression>
        <inputValues id="InputValues_3_ERP_EXPORT_ROUTING">
          <text>"insert","update","delete"</text>
        </inputValues>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado_ERP_EXPORT_ROUTING" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_ERP_EXPORT_ROUTING" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_ERP_EXPORT_ROUTING" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1_ERP_EXPORT_ROUTING">
        <description>Delecao em ERP requer aprovacao</description>
        <inputEntry id="IE_1_1_ERP_EXPORT_ROUTING"><text>-</text></inputEntry>
        <inputEntry id="IE_1_2_ERP_EXPORT_ROUTING"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3_ERP_EXPORT_ROUTING"><text>"delete"</text></inputEntry>
        <outputEntry id="OE_1_1_ERP_EXPORT_ROUTING"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2_ERP_EXPORT_ROUTING"><text>"Operacao de delecao requer aprovacao de supervisor antes da sincronizacao"</text></outputEntry>
        <outputEntry id="OE_1_3_ERP_EXPORT_ROUTING"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2_ERP_EXPORT_ROUTING">
        <description>Reembolso em qualquer ERP requer revisao</description>
        <inputEntry id="IE_2_1_ERP_EXPORT_ROUTING"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2_ERP_EXPORT_ROUTING"><text>"refund"</text></inputEntry>
        <inputEntry id="IE_2_3_ERP_EXPORT_ROUTING"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1_ERP_EXPORT_ROUTING"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_2_ERP_EXPORT_ROUTING"><text>"Exportacao de reembolso requer validacao antes da sincronizacao"</text></outputEntry>
        <outputEntry id="OE_2_3_ERP_EXPORT_ROUTING"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_3_ERP_EXPORT_ROUTING">
        <description>Pagamento via Tasy - rota padrao</description>
        <inputEntry id="IE_3_1_ERP_EXPORT_ROUTING"><text>"tasy"</text></inputEntry>
        <inputEntry id="IE_3_2_ERP_EXPORT_ROUTING"><text>"payment"</text></inputEntry>
        <inputEntry id="IE_3_3_ERP_EXPORT_ROUTING"><text>"insert"</text></inputEntry>
        <outputEntry id="OE_3_1_ERP_EXPORT_ROUTING"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_3_2_ERP_EXPORT_ROUTING"><text>"Sincronizar pagamento via Tasy API REST"</text></outputEntry>
        <outputEntry id="OE_3_3_ERP_EXPORT_ROUTING"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_4_ERP_EXPORT_ROUTING">
        <description>MV Soul - rota padrao</description>
        <inputEntry id="IE_4_1_ERP_EXPORT_ROUTING"><text>"mv_soul"</text></inputEntry>
        <inputEntry id="IE_4_2_ERP_EXPORT_ROUTING"><text>"payment"</text></inputEntry>
        <inputEntry id="IE_4_3_ERP_EXPORT_ROUTING"><text>"insert"</text></inputEntry>
        <outputEntry id="OE_4_1_ERP_EXPORT_ROUTING"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2_ERP_EXPORT_ROUTING"><text>"Sincronizar pagamento via MV Soul API"</text></outputEntry>
        <outputEntry id="OE_4_3_ERP_EXPORT_ROUTING"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_5_ERP_EXPORT_ROUTING">
        <description>Atualizacao de reconciliacao</description>
        <inputEntry id="IE_5_1_ERP_EXPORT_ROUTING"><text>-</text></inputEntry>
        <inputEntry id="IE_5_2_ERP_EXPORT_ROUTING"><text>"reconciliation"</text></inputEntry>
        <inputEntry id="IE_5_3_ERP_EXPORT_ROUTING"><text>"update"</text></inputEntry>
        <outputEntry id="OE_5_1_ERP_EXPORT_ROUTING"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_2_ERP_EXPORT_ROUTING"><text>"Atualizar reconciliacao no ERP"</text></outputEntry>
        <outputEntry id="OE_5_3_ERP_EXPORT_ROUTING"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_ERP_EXPORT_ROUTING">
        <description>Fallback</description>
        <inputEntry id="IE_F_1_ERP_EXPORT_ROUTING"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_ERP_EXPORT_ROUTING"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3_ERP_EXPORT_ROUTING"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_ERP_EXPORT_ROUTING"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2_ERP_EXPORT_ROUTING"><text>"Operacao ERP nao mapeada - avaliar manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3_ERP_EXPORT_ROUTING"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ERP_EXPORT_ROUTING">
      <dmndi:DMNShape id="DMNShape_Decision_ERP_EXPORT_ROUTING" dmnElementRef="Decision_ERP_EXPORT_ROUTING">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
