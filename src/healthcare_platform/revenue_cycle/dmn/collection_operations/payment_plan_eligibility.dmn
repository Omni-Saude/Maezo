<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  PAYMENT-PLAN-ELIGIBILITY - Elegibilidade para Plano de Pagamento
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: negotiate_payment_plan_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_PAYMENT_PLAN_ELIGIBILITY"
             name="Elegibilidade para Plano de Pagamento"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_PAYMENT_PLAN_ELIGIBILITY" name="[SP-RC-013 | collection_operations] Elegibilidade para Plano de Pagamento" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_PAYMENT_PLAN_ELIGIBILITY" hitPolicy="FIRST">

      <input id="Input_1_PAYMENT_PLAN_ELIGIBILITY" label="Valor Devido">
        <inputExpression id="InputExpression_1_PAYMENT_PLAN_ELIGIBILITY" typeRef="double">
          <text>amount_due</text>
        </inputExpression>
      </input>

      <input id="Input_2_PAYMENT_PLAN_ELIGIBILITY" label="Score Historico Pagador">
        <inputExpression id="InputExpression_2_PAYMENT_PLAN_ELIGIBILITY" typeRef="integer">
          <text>payer_history_score</text>
        </inputExpression>
      </input>

      <input id="Input_3_PAYMENT_PLAN_ELIGIBILITY" label="Dias em Atraso">
        <inputExpression id="InputExpression_3_PAYMENT_PLAN_ELIGIBILITY" typeRef="integer">
          <text>days_overdue</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_eligible_PAYMENT_PLAN_ELIGIBILITY" label="Elegivel" name="eligible" typeRef="boolean"/>
      <output id="Output_tier_PAYMENT_PLAN_ELIGIBILITY" label="Categoria Plano" name="plan_tier" typeRef="string">
        <outputValues><text>"premium","standard","basic","none"</text></outputValues>
      </output>
      <output id="Output_installments_PAYMENT_PLAN_ELIGIBILITY" label="Max Parcelas" name="max_installments" typeRef="integer"/>

      <rule id="Rule_Premium_PAYMENT_PLAN_ELIGIBILITY">
        <description>Plano premium: Score alto e valor significativo</description>
        <inputEntry id="IE_1_1_PAYMENT_PLAN_ELIGIBILITY"><text>&gt; 1000</text></inputEntry>
        <inputEntry id="IE_1_2_PAYMENT_PLAN_ELIGIBILITY"><text>&gt;= 80</text></inputEntry>
        <inputEntry id="IE_1_3_PAYMENT_PLAN_ELIGIBILITY"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1_PAYMENT_PLAN_ELIGIBILITY"><text>true</text></outputEntry>
        <outputEntry id="OE_1_2_PAYMENT_PLAN_ELIGIBILITY"><text>"premium"</text></outputEntry>
        <outputEntry id="OE_1_3_PAYMENT_PLAN_ELIGIBILITY"><text>12</text></outputEntry>
      </rule>

      <rule id="Rule_Standard_PAYMENT_PLAN_ELIGIBILITY">
        <description>Plano padrao: Score medio e valor moderado</description>
        <inputEntry id="IE_2_1_PAYMENT_PLAN_ELIGIBILITY"><text>&gt; 500</text></inputEntry>
        <inputEntry id="IE_2_2_PAYMENT_PLAN_ELIGIBILITY"><text>&gt;= 60</text></inputEntry>
        <inputEntry id="IE_2_3_PAYMENT_PLAN_ELIGIBILITY"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1_PAYMENT_PLAN_ELIGIBILITY"><text>true</text></outputEntry>
        <outputEntry id="OE_2_2_PAYMENT_PLAN_ELIGIBILITY"><text>"standard"</text></outputEntry>
        <outputEntry id="OE_2_3_PAYMENT_PLAN_ELIGIBILITY"><text>6</text></outputEntry>
      </rule>

      <rule id="Rule_Basic_PAYMENT_PLAN_ELIGIBILITY">
        <description>Plano basico: Score minimo aceitavel</description>
        <inputEntry id="IE_3_1_PAYMENT_PLAN_ELIGIBILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2_PAYMENT_PLAN_ELIGIBILITY"><text>&gt;= 40</text></inputEntry>
        <inputEntry id="IE_3_3_PAYMENT_PLAN_ELIGIBILITY"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1_PAYMENT_PLAN_ELIGIBILITY"><text>true</text></outputEntry>
        <outputEntry id="OE_3_2_PAYMENT_PLAN_ELIGIBILITY"><text>"basic"</text></outputEntry>
        <outputEntry id="OE_3_3_PAYMENT_PLAN_ELIGIBILITY"><text>3</text></outputEntry>
      </rule>

      <rule id="Rule_NotEligible_PAYMENT_PLAN_ELIGIBILITY">
        <description>Nao elegivel: Score baixo</description>
        <inputEntry id="IE_F_1_PAYMENT_PLAN_ELIGIBILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_PAYMENT_PLAN_ELIGIBILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3_PAYMENT_PLAN_ELIGIBILITY"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_PAYMENT_PLAN_ELIGIBILITY"><text>false</text></outputEntry>
        <outputEntry id="OE_F_2_PAYMENT_PLAN_ELIGIBILITY"><text>"none"</text></outputEntry>
        <outputEntry id="OE_F_3_PAYMENT_PLAN_ELIGIBILITY"><text>0</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PAYMENT_PLAN_ELIGIBILITY">
      <dmndi:DMNShape id="DMNShape_Decision_PAYMENT_PLAN_ELIGIBILITY" dmnElementRef="Decision_PAYMENT_PLAN_ELIGIBILITY">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
