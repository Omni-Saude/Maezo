<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  SUMMARY-THRESHOLD - Limiares para Alertas no Resumo Diario
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: send_daily_summary_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_SUMMARY_THRESHOLD"
             name="Limiares para Alertas no Resumo Diario"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_SUMMARY_THRESHOLD" name="[SP-RC-013 | collection_operations] Limiares para Alertas no Resumo Diario" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_SUMMARY_THRESHOLD" hitPolicy="FIRST">

      <input id="Input_1_SUMMARY_THRESHOLD" label="Valor Vencido (R$)">
        <inputExpression id="InputExpression_1_SUMMARY_THRESHOLD" typeRef="number">
          <text>overdueAmount</text>
        </inputExpression>
      </input>

      <input id="Input_2_SUMMARY_THRESHOLD" label="Valor Arrecadado Hoje (R$)">
        <inputExpression id="InputExpression_2_SUMMARY_THRESHOLD" typeRef="number">
          <text>amountCollectedToday</text>
        </inputExpression>
      </input>

      <input id="Input_3_SUMMARY_THRESHOLD" label="Destinatarios">
        <inputExpression id="InputExpression_3_SUMMARY_THRESHOLD" typeRef="number">
          <text>recipientCount</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado_SUMMARY_THRESHOLD" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_SUMMARY_THRESHOLD" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_SUMMARY_THRESHOLD" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1_SUMMARY_THRESHOLD">
        <description>Valor vencido critico</description>
        <inputEntry id="IE_1_1_SUMMARY_THRESHOLD"><text>&gt; 1000000</text></inputEntry>
        <inputEntry id="IE_1_2_SUMMARY_THRESHOLD"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3_SUMMARY_THRESHOLD"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1_SUMMARY_THRESHOLD"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2_SUMMARY_THRESHOLD"><text>"Valor vencido acima de R$1M - escalar para diretoria financeira"</text></outputEntry>
        <outputEntry id="OE_1_3_SUMMARY_THRESHOLD"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2_SUMMARY_THRESHOLD">
        <description>Sem destinatarios configurados</description>
        <inputEntry id="IE_2_1_SUMMARY_THRESHOLD"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2_SUMMARY_THRESHOLD"><text>-</text></inputEntry>
        <inputEntry id="IE_2_3_SUMMARY_THRESHOLD"><text>0</text></inputEntry>
        <outputEntry id="OE_2_1_SUMMARY_THRESHOLD"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_2_2_SUMMARY_THRESHOLD"><text>"Nenhum destinatario configurado para o resumo"</text></outputEntry>
        <outputEntry id="OE_2_3_SUMMARY_THRESHOLD"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_3_SUMMARY_THRESHOLD">
        <description>Nenhuma arrecadacao no dia</description>
        <inputEntry id="IE_3_1_SUMMARY_THRESHOLD"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2_SUMMARY_THRESHOLD"><text>0</text></inputEntry>
        <inputEntry id="IE_3_3_SUMMARY_THRESHOLD"><text>&gt; 0</text></inputEntry>
        <outputEntry id="OE_3_1_SUMMARY_THRESHOLD"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_3_2_SUMMARY_THRESHOLD"><text>"Nenhuma arrecadacao registrada hoje - verificar integracao de pagamentos"</text></outputEntry>
        <outputEntry id="OE_3_3_SUMMARY_THRESHOLD"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_4_SUMMARY_THRESHOLD">
        <description>Vencidos moderados</description>
        <inputEntry id="IE_4_1_SUMMARY_THRESHOLD"><text>[100000..1000000]</text></inputEntry>
        <inputEntry id="IE_4_2_SUMMARY_THRESHOLD"><text>&gt; 0</text></inputEntry>
        <inputEntry id="IE_4_3_SUMMARY_THRESHOLD"><text>&gt; 0</text></inputEntry>
        <outputEntry id="OE_4_1_SUMMARY_THRESHOLD"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2_SUMMARY_THRESHOLD"><text>"Incluir destaque de valores vencidos no resumo"</text></outputEntry>
        <outputEntry id="OE_4_3_SUMMARY_THRESHOLD"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_5_SUMMARY_THRESHOLD">
        <description>Operacao normal</description>
        <inputEntry id="IE_5_1_SUMMARY_THRESHOLD"><text>&lt; 100000</text></inputEntry>
        <inputEntry id="IE_5_2_SUMMARY_THRESHOLD"><text>&gt; 0</text></inputEntry>
        <inputEntry id="IE_5_3_SUMMARY_THRESHOLD"><text>&gt; 0</text></inputEntry>
        <outputEntry id="OE_5_1_SUMMARY_THRESHOLD"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_2_SUMMARY_THRESHOLD"><text>"Enviar resumo padrao sem alertas especiais"</text></outputEntry>
        <outputEntry id="OE_5_3_SUMMARY_THRESHOLD"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_SUMMARY_THRESHOLD">
        <description>Fallback</description>
        <inputEntry id="IE_F_1_SUMMARY_THRESHOLD"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_SUMMARY_THRESHOLD"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3_SUMMARY_THRESHOLD"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_SUMMARY_THRESHOLD"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_F_2_SUMMARY_THRESHOLD"><text>"Enviar resumo com configuracao padrao"</text></outputEntry>
        <outputEntry id="OE_F_3_SUMMARY_THRESHOLD"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_SUMMARY_THRESHOLD">
      <dmndi:DMNShape id="DMNShape_Decision_SUMMARY_THRESHOLD" dmnElementRef="Decision_SUMMARY_THRESHOLD">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
