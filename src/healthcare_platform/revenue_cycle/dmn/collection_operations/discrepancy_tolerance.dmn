<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DISCREPANCY-TOLERANCE - Tolerancia para Diferencas de Pagamento
  ============================================================================
  Versao: 1.0.0 (2026-02-16)
  Categoria: COLLECTION_OPERATIONS
  Archetype: OPERATIONAL_ROUTING | Source: flag_discrepancies_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DISCREPANCY_TOLERANCE"
             name="Tolerancia para Diferencas de Pagamento"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DISCREPANCY_TOLERANCE" name="[SP-RC-013 | collection_operations] Tolerancia para Diferencas de Pagamento" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DISCREPANCY_TOLERANCE" hitPolicy="FIRST">

      <input id="Input_1_DISCREPANCY_TOLERANCE" label="Valor Esperado">
        <inputExpression id="InputExpression_1_DISCREPANCY_TOLERANCE" typeRef="double">
          <text>expected_amount</text>
        </inputExpression>
      </input>

      <input id="Input_2_DISCREPANCY_TOLERANCE" label="Valor Recebido">
        <inputExpression id="InputExpression_2_DISCREPANCY_TOLERANCE" typeRef="double">
          <text>received_amount</text>
        </inputExpression>
      </input>

      <input id="Input_3_DISCREPANCY_TOLERANCE" label="Tipo Pagamento">
        <inputExpression id="InputExpression_3_DISCREPANCY_TOLERANCE" typeRef="string">
          <text>payment_type</text>
        </inputExpression>
        <inputValues id="InputValues_3_DISCREPANCY_TOLERANCE">
          <text>"transfer","check","cash","card"</text>
        </inputValues>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_within_DISCREPANCY_TOLERANCE" label="Dentro Tolerancia" name="within_tolerance" typeRef="boolean"/>
      <output id="Output_percentage_DISCREPANCY_TOLERANCE" label="Percentual Tolerancia" name="tolerance_percentage" typeRef="double"/>
      <output id="Output_action_DISCREPANCY_TOLERANCE" label="Acao" name="action" typeRef="string">
        <outputValues><text>"AUTO_ACCEPT","FLAG_REVIEW","MANUAL_REVIEW"</text></outputValues>
      </output>
      <output id="Output_variance_DISCREPANCY_TOLERANCE" label="Variancia" name="variance" typeRef="double"/>

      <rule id="Rule_MinimalVariance_DISCREPANCY_TOLERANCE">
        <description>Variancia minima - aceitar automaticamente</description>
        <inputEntry id="IE_1_1_DISCREPANCY_TOLERANCE"><text>-</text></inputEntry>
        <inputEntry id="IE_1_2_DISCREPANCY_TOLERANCE"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3_DISCREPANCY_TOLERANCE"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1_DISCREPANCY_TOLERANCE"><text>abs(received_amount - expected_amount) &lt; 0.01 * expected_amount</text></outputEntry>
        <outputEntry id="OE_1_2_DISCREPANCY_TOLERANCE"><text>1.0</text></outputEntry>
        <outputEntry id="OE_1_3_DISCREPANCY_TOLERANCE"><text>"AUTO_ACCEPT"</text></outputEntry>
        <outputEntry id="OE_1_4_DISCREPANCY_TOLERANCE"><text>received_amount - expected_amount</text></outputEntry>
      </rule>

      <rule id="Rule_SmallVariance_DISCREPANCY_TOLERANCE">
        <description>Variancia pequena - sinalizar para revisao</description>
        <inputEntry id="IE_2_1_DISCREPANCY_TOLERANCE"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2_DISCREPANCY_TOLERANCE"><text>-</text></inputEntry>
        <inputEntry id="IE_2_3_DISCREPANCY_TOLERANCE"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1_DISCREPANCY_TOLERANCE"><text>abs(received_amount - expected_amount) &lt; 0.05 * expected_amount</text></outputEntry>
        <outputEntry id="OE_2_2_DISCREPANCY_TOLERANCE"><text>5.0</text></outputEntry>
        <outputEntry id="OE_2_3_DISCREPANCY_TOLERANCE"><text>"FLAG_REVIEW"</text></outputEntry>
        <outputEntry id="OE_2_4_DISCREPANCY_TOLERANCE"><text>received_amount - expected_amount</text></outputEntry>
      </rule>

      <rule id="Rule_LargeVariance_DISCREPANCY_TOLERANCE">
        <description>Variancia grande - revisao manual necessaria</description>
        <inputEntry id="IE_F_1_DISCREPANCY_TOLERANCE"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_DISCREPANCY_TOLERANCE"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3_DISCREPANCY_TOLERANCE"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_DISCREPANCY_TOLERANCE"><text>false</text></outputEntry>
        <outputEntry id="OE_F_2_DISCREPANCY_TOLERANCE"><text>0</text></outputEntry>
        <outputEntry id="OE_F_3_DISCREPANCY_TOLERANCE"><text>"MANUAL_REVIEW"</text></outputEntry>
        <outputEntry id="OE_F_4_DISCREPANCY_TOLERANCE"><text>received_amount - expected_amount</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DISCREPANCY_TOLERANCE">
      <dmndi:DMNShape id="DMNShape_Decision_DISCREPANCY_TOLERANCE" dmnElementRef="Decision_DISCREPANCY_TOLERANCE">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
