<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             id="Definitions_quality_indicator_types_001"
             name="Clinical Quality Indicator Type Classification"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="quality_indicator_types_001" name="[SP-RC-003 | clinical_quality] Clinical Quality Indicator Type Classification" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_quality_indicator_types_001" hitPolicy="UNIQUE">
      <input id="input1_quality_indicator_types_001" label="Indicator Type">
        <inputExpression typeRef="string">
          <text>indicator_type</text>
        </inputExpression>
      </input>
      <output id="output1_quality_indicator_types_001" label="Category" name="category" typeRef="string"/>
      <output id="output2_quality_indicator_types_001" label="Measurement Frequency" name="measurement_frequency" typeRef="string"/>
      <output id="output3_quality_indicator_types_001" label="Target Threshold" name="target_threshold" typeRef="string"/>
      <output id="output4_quality_indicator_types_001" label="Reporting Level" name="reporting_level" typeRef="string"/>

      <!-- Mortality indicator -->
      <rule id="rule1_quality_indicator_types_001">
        <inputEntry><text>"mortality"</text></inputEntry>
        <outputEntry><text>"outcome"</text></outputEntry>
        <outputEntry><text>"monthly"</text></outputEntry>
        <outputEntry><text>"&lt; national benchmark"</text></outputEntry>
        <outputEntry><text>"executive"</text></outputEntry>
      </rule>

      <!-- Readmission indicator -->
      <rule id="rule2_quality_indicator_types_001">
        <inputEntry><text>"readmission"</text></inputEntry>
        <outputEntry><text>"outcome"</text></outputEntry>
        <outputEntry><text>"monthly"</text></outputEntry>
        <outputEntry><text>"&lt; 15% within 30 days"</text></outputEntry>
        <outputEntry><text>"departmental"</text></outputEntry>
      </rule>

      <!-- Infection rate indicator -->
      <rule id="rule3_quality_indicator_types_001">
        <inputEntry><text>"infection_rate"</text></inputEntry>
        <outputEntry><text>("process"</text></outputEntry>
        <outputEntry><text>"weekly"</text></outputEntry>
        <outputEntry><text>"&lt; 2% HAI rate"</text></outputEntry>
        <outputEntry><text>"unit"</text></outputEntry>
      </rule>

      <!-- Patient satisfaction indicator -->
      <rule id="rule4_quality_indicator_types_001">
        <inputEntry><text>"patient_satisfaction"</text></inputEntry>
        <outputEntry><text>"experience"</text></outputEntry>
        <outputEntry><text>"quarterly"</text></outputEntry>
        <outputEntry><text>"&gt; 85% satisfied"</text></outputEntry>
        <outputEntry><text>"departmental"</text></outputEntry>
      </rule>

      <!-- Medication error indicator -->
      <rule id="rule5_quality_indicator_types_001">
        <inputEntry><text>"medication_error"</text></inputEntry>
        <outputEntry><text>"safety"</text></outputEntry>
        <outputEntry><text>"weekly"</text></outputEntry>
        <outputEntry><text>"0 serious errors"</text></outputEntry>
        <outputEntry><text>"executive"</text></outputEntry>
      </rule>

      <!-- Length of stay indicator -->
      <rule id="rule6_quality_indicator_types_001">
        <inputEntry><text>"length_of_stay"</text></inputEntry>
        <outputEntry><text>"efficiency"</text></outputEntry>
        <outputEntry><text>"monthly"</text></outputEntry>
        <outputEntry><text>"within DRG benchmark"</text></outputEntry>
        <outputEntry><text>"departmental"</text></outputEntry>
      </rule>

      <!-- Falls indicator -->
      <rule id="rule7_quality_indicator_types_001">
        <inputEntry><text>"falls"</text></inputEntry>
        <outputEntry><text>"safety"</text></outputEntry>
        <outputEntry><text>"weekly"</text></outputEntry>
        <outputEntry><text>"&lt; 3 per 1000 patient days"</text></outputEntry>
        <outputEntry><text>"unit"</text></outputEntry>
      </rule>

      <!-- Pressure ulcer indicator -->
      <rule id="rule8_quality_indicator_types_001">
        <inputEntry><text>"pressure_ulcer"</text></inputEntry>
        <outputEntry><text>"process"</text></outputEntry>
        <outputEntry><text>"weekly"</text></outputEntry>
        <outputEntry><text>"0 hospital-acquired stage 3+"</text></outputEntry>
        <outputEntry><text>"unit"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_quality_indicator_types_001">
      <dmndi:DMNShape id="DMNShape_quality_indicator_types_001" dmnElementRef="quality_indicator_types_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
