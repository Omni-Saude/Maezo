<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/" xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_authorization_channel_001" name="Authorization Channel Routing" namespace="http://camunda.org/schema/1.0/dmn" exporter="Camunda Modeler" exporterVersion="5.45.0">
  <decision id="authorization_channel_001" name="[SP-RC-002 | authorization] Authorization Channel Routing" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_authorization_channel_001" hitPolicy="FIRST">
      <input id="input1_auth_channel" label="Convênio (payer_id)">
        <inputExpression typeRef="string">
          <text>payer_id</text>
        </inputExpression>
      </input>
      <input id="input2_auth_channel" label="Estabelecimento (cd_estabelecimento)">
        <inputExpression typeRef="integer">
          <text>cd_estabelecimento</text>
        </inputExpression>
      </input>
      <input id="input3_auth_channel" label="Tipo de Autorização (authorization_type)">
        <inputExpression typeRef="string">
          <text>authorization_type</text>
        </inputExpression>
      </input>
      <output id="output1_auth_channel" label="Canal de Autorização" name="authorization_channel" typeRef="string">
        <outputValues>
          <text>"rpa","dmn"</text>
        </outputValues>
      </output>
      <output id="output2_auth_channel" label="RPA" name="rpa_type" typeRef="string">
        <outputValues>
          <text>"autorizacao_pa","autorizacao_cirurgia","autorizacao_exames",""</text>
        </outputValues>
      </output>
      <rule id="rule1_auth_channel">
        <description>Unimed · Austa · Consulta → Autorização PA</description>
        <inputEntry id="ie1_r1">
          <text>contains(lower case(?), "unimed")</text>
        </inputEntry>
        <inputEntry id="ie2_r1">
          <text>4</text>
        </inputEntry>
        <inputEntry id="ie3_r1">
          <text>"consulta"</text>
        </inputEntry>
        <outputEntry id="oe1_r1">
          <text>"rpa"</text>
        </outputEntry>
        <outputEntry id="oe2_r1">
          <text>"autorizacao_pa"</text>
        </outputEntry>
      </rule>
      <rule id="rule2_auth_channel">
        <description>Unimed · Austa · Cirurgia → Autorização Cirurgia</description>
        <inputEntry id="ie1_r2">
          <text>contains(lower case(?), "unimed")</text>
        </inputEntry>
        <inputEntry id="ie2_r2">
          <text>4</text>
        </inputEntry>
        <inputEntry id="ie3_r2">
          <text>"cirurgia"</text>
        </inputEntry>
        <outputEntry id="oe1_r2">
          <text>"rpa"</text>
        </outputEntry>
        <outputEntry id="oe2_r2">
          <text>"autorizacao_cirurgia"</text>
        </outputEntry>
      </rule>
      <rule id="rule3_auth_channel">
        <description>Unimed · Austa · Exame → Autorização Exames</description>
        <inputEntry id="ie1_r3">
          <text>contains(lower case(?), "unimed")</text>
        </inputEntry>
        <inputEntry id="ie2_r3">
          <text>4</text>
        </inputEntry>
        <inputEntry id="ie3_r3">
          <text>"exame"</text>
        </inputEntry>
        <outputEntry id="oe1_r3">
          <text>"rpa"</text>
        </outputEntry>
        <outputEntry id="oe2_r3">
          <text>"autorizacao_exames"</text>
        </outputEntry>
      </rule>
      <rule id="rule4_auth_channel">
        <description>Unimed · AMH · Consulta → Autorização PA</description>
        <inputEntry id="ie1_r4">
          <text>contains(lower case(?), "unimed")</text>
        </inputEntry>
        <inputEntry id="ie2_r4">
          <text>5</text>
        </inputEntry>
        <inputEntry id="ie3_r4">
          <text>"consulta"</text>
        </inputEntry>
        <outputEntry id="oe1_r4">
          <text>"rpa"</text>
        </outputEntry>
        <outputEntry id="oe2_r4">
          <text>"autorizacao_pa"</text>
        </outputEntry>
      </rule>
      <rule id="rule5_auth_channel">
        <description>Unimed · AMH · Cirurgia → Autorização Cirurgia</description>
        <inputEntry id="ie1_r5">
          <text>contains(lower case(?), "unimed")</text>
        </inputEntry>
        <inputEntry id="ie2_r5">
          <text>5</text>
        </inputEntry>
        <inputEntry id="ie3_r5">
          <text>"cirurgia"</text>
        </inputEntry>
        <outputEntry id="oe1_r5">
          <text>"rpa"</text>
        </outputEntry>
        <outputEntry id="oe2_r5">
          <text>"autorizacao_cirurgia"</text>
        </outputEntry>
      </rule>
      <rule id="rule6_auth_channel">
        <description>Unimed · AMH · Exame → Autorização Exames</description>
        <inputEntry id="ie1_r6">
          <text>contains(lower case(?), "unimed")</text>
        </inputEntry>
        <inputEntry id="ie2_r6">
          <text>5</text>
        </inputEntry>
        <inputEntry id="ie3_r6">
          <text>"exame"</text>
        </inputEntry>
        <outputEntry id="oe1_r6">
          <text>"rpa"</text>
        </outputEntry>
        <outputEntry id="oe2_r6">
          <text>"autorizacao_exames"</text>
        </outputEntry>
      </rule>
      <rule id="rule_fallback_auth_channel">
        <description>Demais convênios (Bradesco, SulAmérica, Austa Clínicas...) → DMN interno</description>
        <inputEntry id="ie1_fb">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ie2_fb">
          <text>-</text>
        </inputEntry>
        <inputEntry id="ie3_fb">
          <text>-</text>
        </inputEntry>
        <outputEntry id="oe1_fb">
          <text>"dmn"</text>
        </outputEntry>
        <outputEntry id="oe2_fb">
          <text>""</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_authorization_channel_001">
      <dmndi:DMNShape id="DMNShape_authorization_channel_001" dmnElementRef="authorization_channel_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
