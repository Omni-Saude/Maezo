<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_PatientAuthNotificationRouting"
             name="Patient Auth Notification Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: patient_auth_notification_routing_worker.py -->

  <!-- Source: patient_authorization_update_worker.py
       Rules extracted from STATUS_LABELS and DEFAULT_NEXT_STEPS mappings.
  -->

  <decision id="Decision_PatientAuthNotifRouting" name="[SP-RC-008 | cash_operations/notifications] Patient Auth Notification Routing" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_PatientAuthNotifRouting" hitPolicy="FIRST">

      <input id="Input_authorizationStatus_PatientAuthNotifRouting" label="Authorization Status">
        <inputExpression id="InputExpr_authorizationStatus_PatientAuthNotifRouting" typeRef="string">
          <text>authorization_status</text>
        </inputExpression>
      </input>

      <output id="Output_destino_PatientAuthNotifRouting" label="Destino" name="destino" typeRef="string"/>

      <output id="Output_prioridade_PatientAuthNotifRouting" label="Prioridade" name="prioridade" typeRef="number"/>

      <output id="Output_restricao_PatientAuthNotifRouting" label="Restricao" name="restricao" typeRef="string"/>

      <!-- R1: Approved — schedule appointment -->
      <rule id="Rule_approved_PatientAuthNotifRouting">
        <description>Approved — notify patient to schedule</description>
        <inputEntry id="IE_a_1_PatientAuthNotifRouting"><text>"approved"</text></inputEntry>
        <outputEntry id="OE_a_dest_PatientAuthNotifRouting"><text>"whatsapp"</text></outputEntry>
        <outputEntry id="OE_a_prio_PatientAuthNotifRouting"><text>3</text></outputEntry>
        <outputEntry id="OE_a_restr_PatientAuthNotifRouting"><text>"Agende sua consulta"</text></outputEntry>
      </rule>

      <!-- R2: Denied — urgent, appeal instructions -->
      <rule id="Rule_denied_PatientAuthNotifRouting">
        <description>Denied — urgent notification with appeal instructions</description>
        <inputEntry id="IE_d_1_PatientAuthNotifRouting"><text>"denied"</text></inputEntry>
        <outputEntry id="OE_d_dest_PatientAuthNotifRouting"><text>"whatsapp"</text></outputEntry>
        <outputEntry id="OE_d_prio_PatientAuthNotifRouting"><text>1</text></outputEntry>
        <outputEntry id="OE_d_restr_PatientAuthNotifRouting"><text>"Ligue 0800 para recurso"</text></outputEntry>
      </rule>

      <!-- R3: Pending — wait notification -->
      <rule id="Rule_pending_PatientAuthNotifRouting">
        <description>Pending — notify patient to wait</description>
        <inputEntry id="IE_p_1_PatientAuthNotifRouting"><text>"pending"</text></inputEntry>
        <outputEntry id="OE_p_dest_PatientAuthNotifRouting"><text>"whatsapp"</text></outputEntry>
        <outputEntry id="OE_p_prio_PatientAuthNotifRouting"><text>2</text></outputEntry>
        <outputEntry id="OE_p_restr_PatientAuthNotifRouting"><text>"Aguarde 5 dias uteis"</text></outputEntry>
      </rule>

      <!-- R4: Cancelled — urgent notification -->
      <rule id="Rule_cancelled_PatientAuthNotifRouting">
        <description>Cancelled — urgent notification</description>
        <inputEntry id="IE_c_1_PatientAuthNotifRouting"><text>"cancelled"</text></inputEntry>
        <outputEntry id="OE_c_dest_PatientAuthNotifRouting"><text>"whatsapp"</text></outputEntry>
        <outputEntry id="OE_c_prio_PatientAuthNotifRouting"><text>1</text></outputEntry>
        <outputEntry id="OE_c_restr_PatientAuthNotifRouting"><text>"Autorizacao cancelada"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="Rule_fallback_PatientAuthNotifRouting">
        <description>Unknown status — default routing</description>
        <inputEntry id="IE_fb_1_PatientAuthNotifRouting"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_dest_PatientAuthNotifRouting"><text>"whatsapp"</text></outputEntry>
        <outputEntry id="OE_fb_prio_PatientAuthNotifRouting"><text>5</text></outputEntry>
        <outputEntry id="OE_fb_restr_PatientAuthNotifRouting"><text>"Entre em contato com a central"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1_PatientAuthNotifRouting">
      <dmndi:DMNShape id="DMNShape_Decision_PatientAuthNotifRouting" dmnElementRef="Decision_PatientAuthNotifRouting">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
