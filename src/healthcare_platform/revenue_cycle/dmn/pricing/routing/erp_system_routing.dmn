<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_ERPSystemRouting"
             name="ERP System Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: erp_system_routing_worker.py -->

  <!-- Source: capture_procedure_worker.py
       Rules extracted from _TASY_TENANTS and _MV_SOUL_TENANTS routing.
  -->

  <decision id="Decision_ERPRouting" name="[SP-RC-003 | pricing/routing] ERP System Routing" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_ERPRouting" hitPolicy="FIRST">

      <input id="Input_tenantCode_ERPRouting" label="Tenant Code">
        <inputExpression id="InputExpr_tenantCode_ERPRouting" typeRef="string">
          <text>tenantCode</text>
        </inputExpression>
      </input>

      <output id="Output_destino_ERPRouting" label="Destino" name="destino" typeRef="string"/>

      <output id="Output_prioridade_ERPRouting" label="Prioridade" name="prioridade" typeRef="number"/>

      <output id="Output_restricao_ERPRouting" label="Restricao" name="restricao" typeRef="string"/>

      <!-- R1: HOSPITAL_A → tasy -->
      <rule id="Rule_tasy_ERPRouting">
        <description>HOSPITAL_A routes to TASY ERP</description>
        <inputEntry id="IE_t_1_ERPRouting"><text>"HOSPITAL_A"</text></inputEntry>
        <outputEntry id="OE_t_dest_ERPRouting"><text>"tasy"</text></outputEntry>
        <outputEntry id="OE_t_prio_ERPRouting"><text>1</text></outputEntry>
        <outputEntry id="OE_t_restr_ERPRouting"><text>"none"</text></outputEntry>
      </rule>

      <!-- R2: AMH units → mv_soul -->
      <rule id="Rule_mv_soul_ERPRouting">
        <description>AMH units route to MV Soul ERP</description>
        <inputEntry id="IE_mv_1_ERPRouting"><text>"AMH_SP","AMH_RJ","AMH_MG"</text></inputEntry>
        <outputEntry id="OE_mv_dest_ERPRouting"><text>"mv_soul"</text></outputEntry>
        <outputEntry id="OE_mv_prio_ERPRouting"><text>1</text></outputEntry>
        <outputEntry id="OE_mv_restr_ERPRouting"><text>"none"</text></outputEntry>
      </rule>

      <!-- R3: HOSPITAL_B → tasy -->
      <rule id="Rule_tasy_b_ERPRouting">
        <description>HOSPITAL_B routes to TASY ERP</description>
        <inputEntry id="IE_tb_1_ERPRouting"><text>"HOSPITAL_B"</text></inputEntry>
        <outputEntry id="OE_tb_dest_ERPRouting"><text>"tasy"</text></outputEntry>
        <outputEntry id="OE_tb_prio_ERPRouting"><text>1</text></outputEntry>
        <outputEntry id="OE_tb_restr_ERPRouting"><text>"none"</text></outputEntry>
      </rule>

      <!-- R4: Legacy tenants → legacy_erp with migration notice -->
      <rule id="Rule_legacy_ERPRouting">
        <description>Legacy tenants route to legacy ERP with migration flag</description>
        <inputEntry id="IE_lg_1_ERPRouting"><text>"LEGACY_01","LEGACY_02"</text></inputEntry>
        <outputEntry id="OE_lg_dest_ERPRouting"><text>"legacy_erp"</text></outputEntry>
        <outputEntry id="OE_lg_prio_ERPRouting"><text>2</text></outputEntry>
        <outputEntry id="OE_lg_restr_ERPRouting"><text>"Migration pending to TASY"</text></outputEntry>
      </rule>

      <!-- R5: Unknown tenant — blocked -->
      <rule id="Rule_unknown_ERPRouting">
        <description>Unknown tenant code — blocked</description>
        <inputEntry id="IE_uk_1_ERPRouting"><text>-</text></inputEntry>
        <outputEntry id="OE_uk_dest_ERPRouting"><text>"blocked"</text></outputEntry>
        <outputEntry id="OE_uk_prio_ERPRouting"><text>5</text></outputEntry>
        <outputEntry id="OE_uk_restr_ERPRouting"><text>"Unknown tenant code"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1_ERPRouting">
      <dmndi:DMNShape id="DMNShape_Decision_ERPRouting" dmnElementRef="Decision_ERPRouting">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
