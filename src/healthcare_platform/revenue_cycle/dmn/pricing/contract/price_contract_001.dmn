<?xml version="1.0" encoding="UTF-8"?>
<!-- PRICE-CONTRACT-001 - Valor Cobrado vs Tabela Contratada | V1.0.0 (2026-02-08) -->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_PRICE_CONTRACT_001" name="Valor Cobrado vs Tabela Contratada" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_PRICE_CONTRACT_001" name="[SP-RC-003 | pricing/contract] Valor Cobrado vs Tabela Contratada" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_PRICE_CONTRACT_001" hitPolicy="FIRST">
      <input id="Input_1_PRICE_CONTRACT_001" label="Valor Cobrado"><inputExpression id="InputExpression_1_PRICE_CONTRACT_001" typeRef="double"><text>valorCobrado</text></inputExpression></input>
      <input id="Input_2_PRICE_CONTRACT_001" label="Valor Contratado"><inputExpression id="InputExpression_2_PRICE_CONTRACT_001" typeRef="double"><text>valorContratado</text></inputExpression></input>
      <input id="Input_3_PRICE_CONTRACT_001" label="Tipo Tabela"><inputExpression id="InputExpression_3_PRICE_CONTRACT_001" typeRef="string"><text>tipoTabela</text></inputExpression><inputValues><text>"CBHPM","AMB","BRASINDICE","SIMPRO","PROPRIA"</text></inputValues></input>
      <input id="Input_4_PRICE_CONTRACT_001" label="Tem Justificativa"><inputExpression id="InputExpression_4_PRICE_CONTRACT_001" typeRef="boolean"><text>temJustificativa</text></inputExpression></input>
      <output id="Output_1_PRICE_CONTRACT_001" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues></output>
      <output id="Output_2_PRICE_CONTRACT_001" label="Observacao" name="observacao" typeRef="string"/>
      <output id="Output_3_PRICE_CONTRACT_001" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>
      <output id="Output_4_PRICE_CONTRACT_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output>
      <output id="Output_5_PRICE_CONTRACT_001" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output>
      <rule id="Rule_Bloqueio_1_PRICE_CONTRACT_001"><description>Bloqueio: Valor 20%+ acima contratado sem justificativa</description><inputEntry id="InputEntry_B1_1_PRICE_CONTRACT_001"><text>&gt; 0</text></inputEntry><inputEntry id="InputEntry_B1_2_PRICE_CONTRACT_001"><text>&gt; 0</text></inputEntry><inputEntry id="InputEntry_B1_3_PRICE_CONTRACT_001"><text>-</text></inputEntry><inputEntry id="InputEntry_B1_4_PRICE_CONTRACT_001"><text>false</text></inputEntry><outputEntry id="OutputEntry_B1_1_PRICE_CONTRACT_001"><text>"Bloquear"</text></outputEntry><outputEntry id="OutputEntry_B1_2_PRICE_CONTRACT_001"><text>"BLOQUEADO - Valor cobrado 20%+ acima do contratado sem justificativa. RN 465/2021 exige aderencia a tabela contratada."</text></outputEntry><outputEntry id="OutputEntry_B1_3_PRICE_CONTRACT_001"><text>"Ajustar valor para tabela contratada ou apresentar justificativa com autorizacao previa."</text></outputEntry><outputEntry id="OutputEntry_B1_4_PRICE_CONTRACT_001"><text>"CONTRATO"</text></outputEntry><outputEntry id="OutputEntry_B1_5_PRICE_CONTRACT_001"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_Alerta_1_PRICE_CONTRACT_001"><description>Alerta: Variacao 10-20%</description><inputEntry id="InputEntry_A1_1_PRICE_CONTRACT_001"><text>&gt; 0</text></inputEntry><inputEntry id="InputEntry_A1_2_PRICE_CONTRACT_001"><text>&gt; 0</text></inputEntry><inputEntry id="InputEntry_A1_3_PRICE_CONTRACT_001"><text>-</text></inputEntry><inputEntry id="InputEntry_A1_4_PRICE_CONTRACT_001"><text>-</text></inputEntry><outputEntry id="OutputEntry_A1_1_PRICE_CONTRACT_001"><text>"Alertar"</text></outputEntry><outputEntry id="OutputEntry_A1_2_PRICE_CONTRACT_001"><text>"ALERTA - Valor cobrado 10-20% acima do contratado. Verificar aplicacao correta da tabela."</text></outputEntry><outputEntry id="OutputEntry_A1_3_PRICE_CONTRACT_001"><text>"Revisar calculo e documentar excedente se justificado."</text></outputEntry><outputEntry id="OutputEntry_A1_4_PRICE_CONTRACT_001"><text>"VALOR"</text></outputEntry><outputEntry id="OutputEntry_A1_5_PRICE_CONTRACT_001"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_Aprovado_1_PRICE_CONTRACT_001"><description>Aprovado: Valor compativel tabela</description><inputEntry id="InputEntry_P1_1_PRICE_CONTRACT_001"><text>&gt; 0</text></inputEntry><inputEntry id="InputEntry_P1_2_PRICE_CONTRACT_001"><text>&gt; 0</text></inputEntry><inputEntry id="InputEntry_P1_3_PRICE_CONTRACT_001"><text>-</text></inputEntry><inputEntry id="InputEntry_P1_4_PRICE_CONTRACT_001"><text>-</text></inputEntry><outputEntry id="OutputEntry_P1_1_PRICE_CONTRACT_001"><text>"Prosseguir"</text></outputEntry><outputEntry id="OutputEntry_P1_2_PRICE_CONTRACT_001"><text>"APROVADO - Valor cobrado compativel com tabela contratada (variacao ate 10%)."</text></outputEntry><outputEntry id="OutputEntry_P1_3_PRICE_CONTRACT_001"><text>"Prosseguir com faturamento conforme procedimento padrao."</text></outputEntry><outputEntry id="OutputEntry_P1_4_PRICE_CONTRACT_001"><text>"NENHUM"</text></outputEntry><outputEntry id="OutputEntry_P1_5_PRICE_CONTRACT_001"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_Fallback_PRICE_CONTRACT_001"><description>Regra padrao</description><inputEntry id="InputEntry_F_1_PRICE_CONTRACT_001"><text>-</text></inputEntry><inputEntry id="InputEntry_F_2_PRICE_CONTRACT_001"><text>-</text></inputEntry><inputEntry id="InputEntry_F_3_PRICE_CONTRACT_001"><text>-</text></inputEntry><inputEntry id="InputEntry_F_4_PRICE_CONTRACT_001"><text>-</text></inputEntry><outputEntry id="OutputEntry_F_1_PRICE_CONTRACT_001"><text>"Revisar"</text></outputEntry><outputEntry id="OutputEntry_F_2_PRICE_CONTRACT_001"><text>"Situacao requer analise manual por nao corresponder a nenhum criterio automatico."</text></outputEntry><outputEntry id="OutputEntry_F_3_PRICE_CONTRACT_001"><text>"Encaminhar para auditoria administrativa para avaliacao caso a caso."</text></outputEntry><outputEntry id="OutputEntry_F_4_PRICE_CONTRACT_001"><text>"NENHUM"</text></outputEntry><outputEntry id="OutputEntry_F_5_PRICE_CONTRACT_001"><text>"MEDIO"</text></outputEntry></rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI><dmndi:DMNDiagram id="DMNDiagram_PRICE_CONTRACT_001"><dmndi:DMNShape id="DMNShape_Decision_PRICE_CONTRACT_001" dmnElementRef="Decision_PRICE_CONTRACT_001"><dc:Bounds height="80" width="180" x="160" y="100"/></dmndi:DMNShape></dmndi:DMNDiagram></dmndi:DMNDI>
</definitions>
