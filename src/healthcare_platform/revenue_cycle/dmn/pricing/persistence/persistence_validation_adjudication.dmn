<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_PersistenceValidationAdjudication"
             name="Persistence Validation Adjudication"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: persistence_validation_adjudication_worker.py -->

  <!-- Source: persist_production_worker.py
       Rules extracted from empty procedures check and zero amount validation.
  -->

  <decision id="Decision_PersistValidAdj" name="[SP-RC-003 | pricing/persistence] Persistence Validation Adjudication" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_PersistValidAdj" hitPolicy="FIRST">

      <input id="Input_procedureCount_PersistValidAdj" label="Procedure Count">
        <inputExpression id="InputExpr_procedureCount_PersistValidAdj" typeRef="number">
          <text>procedureCount</text>
        </inputExpression>
      </input>

      <input id="Input_totalAmount_PersistValidAdj" label="Total Amount">
        <inputExpression id="InputExpr_totalAmount_PersistValidAdj" typeRef="number">
          <text>totalAmount</text>
        </inputExpression>
      </input>

      <output id="Output_resultado_PersistValidAdj" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_PersistValidAdj" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_PersistValidAdj" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- R1: No procedures — block -->
      <rule id="Rule_no_procs_PersistValidAdj">
        <description>No procedures to persist — hard block</description>
        <inputEntry id="IE_np_1_PersistValidAdj"><text>0</text></inputEntry>
        <inputEntry id="IE_np_2_PersistValidAdj"><text>-</text></inputEntry>
        <outputEntry id="OE_np_res_PersistValidAdj"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_np_acao_PersistValidAdj"><text>"No procedures to persist"</text></outputEntry>
        <outputEntry id="OE_np_risco_PersistValidAdj"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- R2: Zero amount — block -->
      <rule id="Rule_zero_amount_PersistValidAdj">
        <description>Zero amount billing — block</description>
        <inputEntry id="IE_za_1_PersistValidAdj"><text>&gt; 0</text></inputEntry>
        <inputEntry id="IE_za_2_PersistValidAdj"><text>0</text></inputEntry>
        <outputEntry id="OE_za_res_PersistValidAdj"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_za_acao_PersistValidAdj"><text>"Zero amount billing"</text></outputEntry>
        <outputEntry id="OE_za_risco_PersistValidAdj"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- R3: Valid — proceed -->
      <rule id="Rule_valid_PersistValidAdj">
        <description>Persistence validated — proceed</description>
        <inputEntry id="IE_v_1_PersistValidAdj"><text>&gt; 0</text></inputEntry>
        <inputEntry id="IE_v_2_PersistValidAdj"><text>&gt; 0</text></inputEntry>
        <outputEntry id="OE_v_res_PersistValidAdj"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_v_acao_PersistValidAdj"><text>"Persistence validated"</text></outputEntry>
        <outputEntry id="OE_v_risco_PersistValidAdj"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      
      <rule id="Rule_HighRisk_PersistValidAdj">
        <description>Risco alto detectado - revisao obrigatoria</description>
        <inputEntry id="IE_HighRisk_1_PersistValidAdj"><text>-</text></inputEntry>
        <inputEntry id="IE_HighRisk_2_PersistValidAdj"><text>-</text></inputEntry>
        <outputEntry id="OE_HighRisk_res_PersistValidAdj"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_HighRisk_acao_PersistValidAdj"><text>"Situacao de risco alto identificada - avaliacao detalhada necessaria"</text></outputEntry>
        <outputEntry id="OE_HighRisk_risco_PersistValidAdj"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_fallback_PersistValidAdj">
        <description>Caso nao enquadrado — revisao obrigatoria</description>
        <inputEntry id="IE_fb_1_PersistValidAdj"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2_PersistValidAdj"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res_PersistValidAdj"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao_PersistValidAdj"><text>"Caso requer avaliacao manual"</text></outputEntry>
        <outputEntry id="OE_fb_risco_PersistValidAdj"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1_PersistValidAdj">
      <dmndi:DMNShape id="DMNShape_Decision_PersistValidAdj" dmnElementRef="Decision_PersistValidAdj">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
