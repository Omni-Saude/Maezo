<?xml version="1.0" encoding="UTF-8"?>
<!-- PRICE-PACKAGE-005 - Intercorrencia Fora Pacote | V1.0.0 (2026-02-08) | HOSPITAL -->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_PRICE_PACKAGE_005" name="Intercorrencia Fora Pacote" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_PRICE_PACKAGE_005" name="[SP-RC-003 | pricing/package] Intercorrencia Fora Pacote" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_PRICE_PACKAGE_005" hitPolicy="FIRST">
      <input id="Input_1_PRICE_PACKAGE_005" label="Temintercorrencia"><inputExpression id="InputExpression_1_PRICE_PACKAGE_005" typeRef="boolean"><text>temIntercorrencia</text></inputExpression></input>
      <input id="Input_2_PRICE_PACKAGE_005" label="Intercorrenciadocumentada"><inputExpression id="InputExpression_2_PRICE_PACKAGE_005" typeRef="boolean"><text>intercorrenciaDocumentada</text></inputExpression></input>
      <input id="Input_3_PRICE_PACKAGE_005" label="Valorintercorrencia"><inputExpression id="InputExpression_3_PRICE_PACKAGE_005" typeRef="double"><text>valorIntercorrencia</text></inputExpression></input>
      <input id="Input_4_PRICE_PACKAGE_005" label="Dentroprazo"><inputExpression id="InputExpression_4_PRICE_PACKAGE_005" typeRef="boolean"><text>dentroPrazo</text></inputExpression></input>
      <output id="Output_1_PRICE_PACKAGE_005" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues></output>
      <output id="Output_2_PRICE_PACKAGE_005" label="Observacao" name="observacao" typeRef="string"/>
      <output id="Output_3_PRICE_PACKAGE_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>
      <output id="Output_4_PRICE_PACKAGE_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output>
      <output id="Output_5_PRICE_PACKAGE_005" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output>
      <rule id="Rule_Bloqueio_1_PRICE_PACKAGE_005"><description>Intercorrencia nao documentada ou fora prazo pacote</description>
        <inputEntry id="InputEntry_B1_1_PRICE_PACKAGE_005"><text>-</text></inputEntry><inputEntry id="InputEntry_B1_2_PRICE_PACKAGE_005"><text>-</text></inputEntry><inputEntry id="InputEntry_B1_3_PRICE_PACKAGE_005"><text>-</text></inputEntry><inputEntry id="InputEntry_B1_4_PRICE_PACKAGE_005"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_B1_1_PRICE_PACKAGE_005"><text>"Bloquear"</text></outputEntry><outputEntry id="OutputEntry_B1_2_PRICE_PACKAGE_005"><text>"BLOQUEADO - Intercorrencia nao documentada ou fora prazo pacote."</text></outputEntry><outputEntry id="OutputEntry_B1_3_PRICE_PACKAGE_005"><text>"Revisar criterios contratuais e solicitar documentacao adicional."</text></outputEntry><outputEntry id="OutputEntry_B1_4_PRICE_PACKAGE_005"><text>"CONTRATO"</text></outputEntry><outputEntry id="OutputEntry_B1_5_PRICE_PACKAGE_005"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_Alerta_1_PRICE_PACKAGE_005"><description>Intercorrencia documentada mas valor elevado</description>
        <inputEntry id="InputEntry_A1_1_PRICE_PACKAGE_005"><text>-</text></inputEntry><inputEntry id="InputEntry_A1_2_PRICE_PACKAGE_005"><text>-</text></inputEntry><inputEntry id="InputEntry_A1_3_PRICE_PACKAGE_005"><text>-</text></inputEntry><inputEntry id="InputEntry_A1_4_PRICE_PACKAGE_005"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_A1_1_PRICE_PACKAGE_005"><text>"Alertar"</text></outputEntry><outputEntry id="OutputEntry_A1_2_PRICE_PACKAGE_005"><text>"ALERTA - Intercorrencia documentada mas valor elevado."</text></outputEntry><outputEntry id="OutputEntry_A1_3_PRICE_PACKAGE_005"><text>"Revisar documentacao e validar conformidade contratual."</text></outputEntry><outputEntry id="OutputEntry_A1_4_PRICE_PACKAGE_005"><text>"VALOR"</text></outputEntry><outputEntry id="OutputEntry_A1_5_PRICE_PACKAGE_005"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_Aprovado_1_PRICE_PACKAGE_005"><description>Intercorrencia fora pacote devidamente caracterizada</description>
        <inputEntry id="InputEntry_P1_1_PRICE_PACKAGE_005"><text>-</text></inputEntry><inputEntry id="InputEntry_P1_2_PRICE_PACKAGE_005"><text>-</text></inputEntry><inputEntry id="InputEntry_P1_3_PRICE_PACKAGE_005"><text>-</text></inputEntry><inputEntry id="InputEntry_P1_4_PRICE_PACKAGE_005"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_PRICE_PACKAGE_005"><text>"Prosseguir"</text></outputEntry><outputEntry id="OutputEntry_P1_2_PRICE_PACKAGE_005"><text>"APROVADO - Intercorrencia fora pacote devidamente caracterizada."</text></outputEntry><outputEntry id="OutputEntry_P1_3_PRICE_PACKAGE_005"><text>"Prosseguir com faturamento conforme procedimento padrao."</text></outputEntry><outputEntry id="OutputEntry_P1_4_PRICE_PACKAGE_005"><text>"NENHUM"</text></outputEntry><outputEntry id="OutputEntry_P1_5_PRICE_PACKAGE_005"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_Fallback_PRICE_PACKAGE_005"><description>Regra padrao</description>
        <inputEntry id="InputEntry_F_1_PRICE_PACKAGE_005"><text>-</text></inputEntry><inputEntry id="InputEntry_F_2_PRICE_PACKAGE_005"><text>-</text></inputEntry><inputEntry id="InputEntry_F_3_PRICE_PACKAGE_005"><text>-</text></inputEntry><inputEntry id="InputEntry_F_4_PRICE_PACKAGE_005"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_PRICE_PACKAGE_005"><text>"Revisar"</text></outputEntry><outputEntry id="OutputEntry_F_2_PRICE_PACKAGE_005"><text>"Situacao requer analise manual por nao corresponder a nenhum criterio automatico."</text></outputEntry><outputEntry id="OutputEntry_F_3_PRICE_PACKAGE_005"><text>"Encaminhar para auditoria administrativa para avaliacao caso a caso."</text></outputEntry><outputEntry id="OutputEntry_F_4_PRICE_PACKAGE_005"><text>"NENHUM"</text></outputEntry><outputEntry id="OutputEntry_F_5_PRICE_PACKAGE_005"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI><dmndi:DMNDiagram id="DMNDiagram_PRICE_PACKAGE_005"><dmndi:DMNShape id="DMNShape_Decision_PRICE_PACKAGE_005" dmnElementRef="Decision_PRICE_PACKAGE_005"><dc:Bounds height="80" width="180" x="160" y="100"/></dmndi:DMNShape></dmndi:DMNDiagram></dmndi:DMNDI>
</definitions>
