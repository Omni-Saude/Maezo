<?xml version="1.0" encoding="UTF-8"?>
<!-- PRICE-PACKAGE-004 - Valor Excedente Pacote | V1.0.0 (2026-02-08) | HOSPITAL -->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_PRICE_PACKAGE_004" name="Valor Excedente Pacote" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_PRICE_PACKAGE_004" name="[SP-RC-003 | pricing/package] Valor Excedente Pacote" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_PRICE_PACKAGE_004" hitPolicy="FIRST">
      <input id="Input_1_PRICE_PACKAGE_004" label="Valorpacote"><inputExpression id="InputExpression_1_PRICE_PACKAGE_004" typeRef="double"><text>valorPacote</text></inputExpression></input>
      <input id="Input_2_PRICE_PACKAGE_004" label="Valorexcedente"><inputExpression id="InputExpression_2_PRICE_PACKAGE_004" typeRef="double"><text>valorExcedente</text></inputExpression></input>
      <input id="Input_3_PRICE_PACKAGE_004" label="Percentualexcedente"><inputExpression id="InputExpression_3_PRICE_PACKAGE_004" typeRef="double"><text>percentualExcedente</text></inputExpression></input>
      <input id="Input_4_PRICE_PACKAGE_004" label="Excedentjustificado"><inputExpression id="InputExpression_4_PRICE_PACKAGE_004" typeRef="boolean"><text>excedentJustificado</text></inputExpression></input>
      <output id="Output_1_PRICE_PACKAGE_004" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues></output>
      <output id="Output_2_PRICE_PACKAGE_004" label="Observacao" name="observacao" typeRef="string"/>
      <output id="Output_3_PRICE_PACKAGE_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>
      <output id="Output_4_PRICE_PACKAGE_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output>
      <output id="Output_5_PRICE_PACKAGE_004" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output>
      <rule id="Rule_Bloqueio_1_PRICE_PACKAGE_004"><description>Excedente 30%+ valor pacote sem justificativa</description>
        <inputEntry id="InputEntry_B1_1_PRICE_PACKAGE_004"><text>-</text></inputEntry><inputEntry id="InputEntry_B1_2_PRICE_PACKAGE_004"><text>-</text></inputEntry><inputEntry id="InputEntry_B1_3_PRICE_PACKAGE_004"><text>-</text></inputEntry><inputEntry id="InputEntry_B1_4_PRICE_PACKAGE_004"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_B1_1_PRICE_PACKAGE_004"><text>"Bloquear"</text></outputEntry><outputEntry id="OutputEntry_B1_2_PRICE_PACKAGE_004"><text>"BLOQUEADO - Excedente 30%+ valor pacote sem justificativa."</text></outputEntry><outputEntry id="OutputEntry_B1_3_PRICE_PACKAGE_004"><text>"Revisar criterios contratuais e solicitar documentacao adicional."</text></outputEntry><outputEntry id="OutputEntry_B1_4_PRICE_PACKAGE_004"><text>"CONTRATO"</text></outputEntry><outputEntry id="OutputEntry_B1_5_PRICE_PACKAGE_004"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_Alerta_1_PRICE_PACKAGE_004"><description>Excedente 15-30% valor pacote</description>
        <inputEntry id="InputEntry_A1_1_PRICE_PACKAGE_004"><text>-</text></inputEntry><inputEntry id="InputEntry_A1_2_PRICE_PACKAGE_004"><text>-</text></inputEntry><inputEntry id="InputEntry_A1_3_PRICE_PACKAGE_004"><text>-</text></inputEntry><inputEntry id="InputEntry_A1_4_PRICE_PACKAGE_004"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_A1_1_PRICE_PACKAGE_004"><text>"Alertar"</text></outputEntry><outputEntry id="OutputEntry_A1_2_PRICE_PACKAGE_004"><text>"ALERTA - Excedente 15-30% valor pacote."</text></outputEntry><outputEntry id="OutputEntry_A1_3_PRICE_PACKAGE_004"><text>"Revisar documentacao e validar conformidade contratual."</text></outputEntry><outputEntry id="OutputEntry_A1_4_PRICE_PACKAGE_004"><text>"VALOR"</text></outputEntry><outputEntry id="OutputEntry_A1_5_PRICE_PACKAGE_004"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_Aprovado_1_PRICE_PACKAGE_004"><description>Excedente dentro limite contratual ou justificado</description>
        <inputEntry id="InputEntry_P1_1_PRICE_PACKAGE_004"><text>-</text></inputEntry><inputEntry id="InputEntry_P1_2_PRICE_PACKAGE_004"><text>-</text></inputEntry><inputEntry id="InputEntry_P1_3_PRICE_PACKAGE_004"><text>-</text></inputEntry><inputEntry id="InputEntry_P1_4_PRICE_PACKAGE_004"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_PRICE_PACKAGE_004"><text>"Prosseguir"</text></outputEntry><outputEntry id="OutputEntry_P1_2_PRICE_PACKAGE_004"><text>"APROVADO - Excedente dentro limite contratual ou justificado."</text></outputEntry><outputEntry id="OutputEntry_P1_3_PRICE_PACKAGE_004"><text>"Prosseguir com faturamento conforme procedimento padrao."</text></outputEntry><outputEntry id="OutputEntry_P1_4_PRICE_PACKAGE_004"><text>"NENHUM"</text></outputEntry><outputEntry id="OutputEntry_P1_5_PRICE_PACKAGE_004"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_Fallback_PRICE_PACKAGE_004"><description>Regra padrao</description>
        <inputEntry id="InputEntry_F_1_PRICE_PACKAGE_004"><text>-</text></inputEntry><inputEntry id="InputEntry_F_2_PRICE_PACKAGE_004"><text>-</text></inputEntry><inputEntry id="InputEntry_F_3_PRICE_PACKAGE_004"><text>-</text></inputEntry><inputEntry id="InputEntry_F_4_PRICE_PACKAGE_004"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_PRICE_PACKAGE_004"><text>"Revisar"</text></outputEntry><outputEntry id="OutputEntry_F_2_PRICE_PACKAGE_004"><text>"Situacao requer analise manual por nao corresponder a nenhum criterio automatico."</text></outputEntry><outputEntry id="OutputEntry_F_3_PRICE_PACKAGE_004"><text>"Encaminhar para auditoria administrativa para avaliacao caso a caso."</text></outputEntry><outputEntry id="OutputEntry_F_4_PRICE_PACKAGE_004"><text>"NENHUM"</text></outputEntry><outputEntry id="OutputEntry_F_5_PRICE_PACKAGE_004"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI><dmndi:DMNDiagram id="DMNDiagram_PRICE_PACKAGE_004"><dmndi:DMNShape id="DMNShape_Decision_PRICE_PACKAGE_004" dmnElementRef="Decision_PRICE_PACKAGE_004"><dc:Bounds height="80" width="180" x="160" y="100"/></dmndi:DMNShape></dmndi:DMNDiagram></dmndi:DMNDI>
</definitions>
