<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_receive_notification_validation"
             name="Receive Payment Notification Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: receive_payment_notification_worker.py -->
  <decision id="Decision_receive_notification_validation" name="[SP-RC-012 | collection_matching] Receive Payment Notification Validation" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_receive_notification_validation" hitPolicy="FIRST">
      <input id="Input_has_payload_receive_notification_validation" label="Tem Payload">
        <inputExpression id="InputExpression_has_payload_receive_notification_validation" typeRef="boolean">
          <text>has_payload</text>
        </inputExpression>
      </input>
      <input id="Input_has_signature_receive_notification_validation" label="Tem Assinatura">
        <inputExpression id="InputExpression_has_signature_receive_notification_validation" typeRef="boolean">
          <text>has_signature</text>
        </inputExpression>
      </input>
      <input id="Input_payload_parseable_receive_notification_validation" label="Payload Parseavel">
        <inputExpression id="InputExpression_payload_parseable_receive_notification_validation" typeRef="boolean">
          <text>payload_parseable</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_receive_notification_validation" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_receive_notification_validation" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_receive_notification_validation" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1_receive_notification_validation">
        <inputEntry id="Input_1_1_receive_notification_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_1_2_receive_notification_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_1_3_receive_notification_validation"><text>true</text></inputEntry>
        <outputEntry id="Output_1_1_receive_notification_validation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2_receive_notification_validation"><text>"Webhook completo e valido"</text></outputEntry>
        <outputEntry id="Output_1_3_receive_notification_validation"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2_receive_notification_validation">
        <inputEntry id="Input_2_1_receive_notification_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_2_2_receive_notification_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_2_3_receive_notification_validation"><text>false</text></inputEntry>
        <outputEntry id="Output_2_1_receive_notification_validation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_2_2_receive_notification_validation"><text>"Payload malformado - nao parseavel"</text></outputEntry>
        <outputEntry id="Output_2_3_receive_notification_validation"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_3_receive_notification_validation">
        <inputEntry id="Input_3_1_receive_notification_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_3_2_receive_notification_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_3_3_receive_notification_validation"><text></text></inputEntry>
        <outputEntry id="Output_3_1_receive_notification_validation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_3_2_receive_notification_validation"><text>"Assinatura ausente - webhook rejeitado"</text></outputEntry>
        <outputEntry id="Output_3_3_receive_notification_validation"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_4_receive_notification_validation">
        <inputEntry id="Input_4_1_receive_notification_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_4_2_receive_notification_validation"><text></text></inputEntry>
        <inputEntry id="Input_4_3_receive_notification_validation"><text></text></inputEntry>
        <outputEntry id="Output_4_1_receive_notification_validation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_4_2_receive_notification_validation"><text>"Payload ausente - webhook vazio"</text></outputEntry>
        <outputEntry id="Output_4_3_receive_notification_validation"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_5_receive_notification_validation">
        <inputEntry id="Input_5_1_receive_notification_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_5_2_receive_notification_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_5_3_receive_notification_validation"><text>true</text></inputEntry>
        <outputEntry id="Output_5_1_receive_notification_validation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_5_2_receive_notification_validation"><text>"Validacao completa - encaminhar para processamento"</text></outputEntry>
        <outputEntry id="Output_5_3_receive_notification_validation"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_receive_notification_validation">
      <dmndi:DMNShape id="DMNShape_Decision_receive_notification_validation" dmnElementRef="Decision_receive_notification_validation">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
