<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_match_by_invoice_validation"
             name="Match By Invoice Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: match_by_invoice_worker.py -->
  <decision id="Decision_match_by_invoice_validation" name="[SP-RC-012 | collection_matching] Match By Invoice Validation" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_match_by_invoice_validation" hitPolicy="FIRST">
      <input id="Input_invoice_number_match_by_invoice_validation" label="Numero Fatura Presente">
        <inputExpression id="InputExpression_invoice_present_match_by_invoice_validation" typeRef="boolean">
          <text>invoice_present</text>
        </inputExpression>
      </input>
      <input id="Input_nosso_numero_match_by_invoice_validation" label="Nosso Numero Presente">
        <inputExpression id="InputExpression_nosso_numero_present_match_by_invoice_validation" typeRef="boolean">
          <text>nosso_numero_present</text>
        </inputExpression>
      </input>
      <input id="Input_payment_amount_match_by_invoice_validation" label="Valor Pagamento">
        <inputExpression id="InputExpression_payment_amount_match_by_invoice_validation" typeRef="double">
          <text>payment_amount</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_match_by_invoice_validation" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_match_by_invoice_validation" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_match_by_invoice_validation" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1_match_by_invoice_validation">
        <inputEntry id="Input_1_1_match_by_invoice_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_1_2_match_by_invoice_validation"><text></text></inputEntry>
        <inputEntry id="Input_1_3_match_by_invoice_validation"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_1_1_match_by_invoice_validation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2_match_by_invoice_validation"><text>"Fatura valida com valor positivo"</text></outputEntry>
        <outputEntry id="Output_1_3_match_by_invoice_validation"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2_match_by_invoice_validation">
        <inputEntry id="Input_2_1_match_by_invoice_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_2_2_match_by_invoice_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_2_3_match_by_invoice_validation"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_2_1_match_by_invoice_validation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_2_2_match_by_invoice_validation"><text>"Usar nosso_numero como alternativa"</text></outputEntry>
        <outputEntry id="Output_2_3_match_by_invoice_validation"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_3_match_by_invoice_validation">
        <inputEntry id="Input_3_1_match_by_invoice_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_3_2_match_by_invoice_validation"><text></text></inputEntry>
        <inputEntry id="Input_3_3_match_by_invoice_validation"><text>&lt;= 0</text></inputEntry>
        <outputEntry id="Output_3_1_match_by_invoice_validation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_3_2_match_by_invoice_validation"><text>"Valor do pagamento invalido"</text></outputEntry>
        <outputEntry id="Output_3_3_match_by_invoice_validation"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_4_match_by_invoice_validation">
        <inputEntry id="Input_4_1_match_by_invoice_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_4_2_match_by_invoice_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_4_3_match_by_invoice_validation"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_4_1_match_by_invoice_validation"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_4_2_match_by_invoice_validation"><text>"Sem identificador de fatura - revisar dados"</text></outputEntry>
        <outputEntry id="Output_4_3_match_by_invoice_validation"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_5_match_by_invoice_validation">
        <inputEntry id="Input_5_1_match_by_invoice_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_5_2_match_by_invoice_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_5_3_match_by_invoice_validation"><text>&lt;= 0</text></inputEntry>
        <outputEntry id="Output_5_1_match_by_invoice_validation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_5_2_match_by_invoice_validation"><text>"Sem identificador e valor invalido"</text></outputEntry>
        <outputEntry id="Output_5_3_match_by_invoice_validation"><text>"CRITICO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_match_by_invoice_validation">
      <dmndi:DMNShape id="DMNShape_Decision_match_by_invoice_validation" dmnElementRef="Decision_match_by_invoice_validation">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
