<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_detect_duplicate_validation"
             name="Detect Duplicate Payment Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: detect_duplicate_payment_worker.py -->
  <decision id="Decision_detect_duplicate_validation" name="[SP-RC-012 | collection_matching] Detect Duplicate Payment Validation" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_detect_duplicate_validation" hitPolicy="FIRST">
      <input id="Input_has_transaction_id_detect_duplicate_validation" label="Tem Transaction ID">
        <inputExpression id="InputExpression_has_transaction_id_detect_duplicate_validation" typeRef="boolean">
          <text>has_transaction_id</text>
        </inputExpression>
      </input>
      <input id="Input_has_nosso_numero_detect_duplicate_validation" label="Tem Nosso Numero">
        <inputExpression id="InputExpression_has_nosso_numero_detect_duplicate_validation" typeRef="boolean">
          <text>has_nosso_numero</text>
        </inputExpression>
      </input>
      <input id="Input_has_composite_fields_detect_duplicate_validation" label="Tem Campos Compostos">
        <inputExpression id="InputExpression_has_composite_fields_detect_duplicate_validation" typeRef="boolean">
          <text>has_composite_fields</text>
        </inputExpression>
      </input>
      <input id="Input_repository_available_detect_duplicate_validation" label="Repositorio Disponivel">
        <inputExpression id="InputExpression_repository_available_detect_duplicate_validation" typeRef="boolean">
          <text>repository_available</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_detect_duplicate_validation" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_detect_duplicate_validation" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_detect_duplicate_validation" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1_detect_duplicate_validation">
        <inputEntry id="Input_1_1_detect_duplicate_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_1_2_detect_duplicate_validation"><text></text></inputEntry>
        <inputEntry id="Input_1_3_detect_duplicate_validation"><text></text></inputEntry>
        <inputEntry id="Input_1_4_detect_duplicate_validation"><text>true</text></inputEntry>
        <outputEntry id="Output_1_1_detect_duplicate_validation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2_detect_duplicate_validation"><text>"Transaction ID disponivel - verificacao completa"</text></outputEntry>
        <outputEntry id="Output_1_3_detect_duplicate_validation"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2_detect_duplicate_validation">
        <inputEntry id="Input_2_1_detect_duplicate_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_2_2_detect_duplicate_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_2_3_detect_duplicate_validation"><text></text></inputEntry>
        <inputEntry id="Input_2_4_detect_duplicate_validation"><text>true</text></inputEntry>
        <outputEntry id="Output_2_1_detect_duplicate_validation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_2_2_detect_duplicate_validation"><text>"Nosso numero disponivel para verificacao"</text></outputEntry>
        <outputEntry id="Output_2_3_detect_duplicate_validation"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_3_detect_duplicate_validation">
        <inputEntry id="Input_3_1_detect_duplicate_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_3_2_detect_duplicate_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_3_3_detect_duplicate_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_3_4_detect_duplicate_validation"><text>true</text></inputEntry>
        <outputEntry id="Output_3_1_detect_duplicate_validation"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_3_2_detect_duplicate_validation"><text>"Apenas chave composta - deteccao menos confiavel"</text></outputEntry>
        <outputEntry id="Output_3_3_detect_duplicate_validation"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_4_detect_duplicate_validation">
        <inputEntry id="Input_4_1_detect_duplicate_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_4_2_detect_duplicate_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_4_3_detect_duplicate_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_4_4_detect_duplicate_validation"><text>true</text></inputEntry>
        <outputEntry id="Output_4_1_detect_duplicate_validation"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_4_2_detect_duplicate_validation"><text>"Sem campos para deteccao de duplicatas"</text></outputEntry>
        <outputEntry id="Output_4_3_detect_duplicate_validation"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_5_detect_duplicate_validation">
        <inputEntry id="Input_5_1_detect_duplicate_validation"><text></text></inputEntry>
        <inputEntry id="Input_5_2_detect_duplicate_validation"><text></text></inputEntry>
        <inputEntry id="Input_5_3_detect_duplicate_validation"><text></text></inputEntry>
        <inputEntry id="Input_5_4_detect_duplicate_validation"><text>false</text></inputEntry>
        <outputEntry id="Output_5_1_detect_duplicate_validation"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_5_2_detect_duplicate_validation"><text>"Repositorio indisponivel - verificacao de duplicatas ignorada"</text></outputEntry>
        <outputEntry id="Output_5_3_detect_duplicate_validation"><text>"ALTO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_detect_duplicate_validation">
      <dmndi:DMNShape id="DMNShape_Decision_detect_duplicate_validation" dmnElementRef="Decision_detect_duplicate_validation">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
