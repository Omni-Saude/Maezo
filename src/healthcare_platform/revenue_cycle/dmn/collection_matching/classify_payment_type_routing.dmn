<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_classify_payment_type_routing"
             name="Classify Payment Type Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: classify_payment_type_worker.py -->
  <decision id="Decision_classify_payment_type_routing" name="[SP-RC-012 | collection_matching] Classify Payment Type Routing" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_classify_payment_type_routing" hitPolicy="FIRST">
      <input id="Input_payment_ratio_classify_payment_type_routing" label="Ratio Pagamento">
        <inputExpression id="InputExpression_payment_ratio_classify_payment_type_routing" typeRef="double">
          <text>payment_ratio</text>
        </inputExpression>
      </input>
      <input id="Input_has_expected_classify_payment_type_routing" label="Tem Valor Esperado">
        <inputExpression id="InputExpression_has_expected_classify_payment_type_routing" typeRef="boolean">
          <text>has_expected_amount</text>
        </inputExpression>
      </input>
      <input id="Input_net_amount_classify_payment_type_routing" label="Valor Liquido">
        <inputExpression id="InputExpression_net_amount_classify_payment_type_routing" typeRef="double">
          <text>net_amount</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_classify_payment_type_routing" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_classify_payment_type_routing" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_classify_payment_type_routing" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1_classify_payment_type_routing">
        <inputEntry id="Input_1_1_classify_payment_type_routing"><text>&gt;= 0.95</text></inputEntry>
        <inputEntry id="Input_1_2_classify_payment_type_routing"><text>true</text></inputEntry>
        <inputEntry id="Input_1_3_classify_payment_type_routing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_1_1_classify_payment_type_routing"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2_classify_payment_type_routing"><text>"Pagamento integral - classificar como FULL"</text></outputEntry>
        <outputEntry id="Output_1_3_classify_payment_type_routing"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2_classify_payment_type_routing">
        <inputEntry id="Input_2_1_classify_payment_type_routing"><text>[0.10..0.95)</text></inputEntry>
        <inputEntry id="Input_2_2_classify_payment_type_routing"><text>true</text></inputEntry>
        <inputEntry id="Input_2_3_classify_payment_type_routing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_2_1_classify_payment_type_routing"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_2_2_classify_payment_type_routing"><text>"Pagamento parcial - classificar como PARTIAL"</text></outputEntry>
        <outputEntry id="Output_2_3_classify_payment_type_routing"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_3_classify_payment_type_routing">
        <inputEntry id="Input_3_1_classify_payment_type_routing"><text>&lt; 0.10</text></inputEntry>
        <inputEntry id="Input_3_2_classify_payment_type_routing"><text>true</text></inputEntry>
        <inputEntry id="Input_3_3_classify_payment_type_routing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_3_1_classify_payment_type_routing"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_3_2_classify_payment_type_routing"><text>"Pagamento minimo - verificar se parcial ou erro"</text></outputEntry>
        <outputEntry id="Output_3_3_classify_payment_type_routing"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_4_classify_payment_type_routing">
        <inputEntry id="Input_4_1_classify_payment_type_routing"><text>&gt; 1.05</text></inputEntry>
        <inputEntry id="Input_4_2_classify_payment_type_routing"><text>true</text></inputEntry>
        <inputEntry id="Input_4_3_classify_payment_type_routing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_4_1_classify_payment_type_routing"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_4_2_classify_payment_type_routing"><text>"Sobrepagamento detectado - verificar"</text></outputEntry>
        <outputEntry id="Output_4_3_classify_payment_type_routing"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_5_classify_payment_type_routing">
        <inputEntry id="Input_5_1_classify_payment_type_routing"><text></text></inputEntry>
        <inputEntry id="Input_5_2_classify_payment_type_routing"><text>false</text></inputEntry>
        <inputEntry id="Input_5_3_classify_payment_type_routing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_5_1_classify_payment_type_routing"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_5_2_classify_payment_type_routing"><text>"Sem valor esperado - classificar como ADVANCE"</text></outputEntry>
        <outputEntry id="Output_5_3_classify_payment_type_routing"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_6_classify_payment_type_routing">
        <inputEntry id="Input_6_1_classify_payment_type_routing"><text></text></inputEntry>
        <inputEntry id="Input_6_2_classify_payment_type_routing"><text></text></inputEntry>
        <inputEntry id="Input_6_3_classify_payment_type_routing"><text>&lt;= 0</text></inputEntry>
        <outputEntry id="Output_6_1_classify_payment_type_routing"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_6_2_classify_payment_type_routing"><text>"Valor liquido zerado ou negativo"</text></outputEntry>
        <outputEntry id="Output_6_3_classify_payment_type_routing"><text>"CRITICO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_classify_payment_type_routing">
      <dmndi:DMNShape id="DMNShape_Decision_classify_payment_type_routing" dmnElementRef="Decision_classify_payment_type_routing">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
