<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_auto_matching_routing"
             name="Auto Matching Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: auto_matching_worker.py -->
  <decision id="Decision_auto_matching_routing" name="[SP-RC-012 | collection_matching] Auto Matching Routing" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_auto_matching_routing" hitPolicy="FIRST">
      <input id="Input_match_method_auto_matching_routing" label="Metodo Correspondencia">
        <inputExpression id="InputExpression_match_method_auto_matching_routing" typeRef="string">
          <text>match_method</text>
        </inputExpression>
        <inputValues><text>"protocol","invoice","patient","none"</text></inputValues>
      </input>
      <input id="Input_confidence_score_auto_matching_routing" label="Score Confianca">
        <inputExpression id="InputExpression_confidence_score_auto_matching_routing" typeRef="double">
          <text>confidence_score</text>
        </inputExpression>
      </input>
      <input id="Input_claims_count_auto_matching_routing" label="Claims Disponiveis">
        <inputExpression id="InputExpression_claims_count_auto_matching_routing" typeRef="integer">
          <text>claims_count</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_auto_matching_routing" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_auto_matching_routing" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_auto_matching_routing" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <!-- Rule 1: Protocol match with high confidence -->
      <rule id="Rule_1_auto_matching_routing">
        <inputEntry id="Input_1_1_auto_matching_routing"><text>"protocol"</text></inputEntry>
        <inputEntry id="Input_1_2_auto_matching_routing"><text>&gt;= 0.90</text></inputEntry>
        <inputEntry id="Input_1_3_auto_matching_routing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_1_1_auto_matching_routing"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2_auto_matching_routing"><text>"Alocar automaticamente por protocolo TISS"</text></outputEntry>
        <outputEntry id="Output_1_3_auto_matching_routing"><text>"BAIXO"</text></outputEntry>
      </rule>
      <!-- Rule 2: Invoice match with high confidence -->
      <rule id="Rule_2_auto_matching_routing">
        <inputEntry id="Input_2_1_auto_matching_routing"><text>"invoice"</text></inputEntry>
        <inputEntry id="Input_2_2_auto_matching_routing"><text>&gt;= 0.80</text></inputEntry>
        <inputEntry id="Input_2_3_auto_matching_routing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_2_1_auto_matching_routing"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_2_2_auto_matching_routing"><text>"Alocar automaticamente por fatura"</text></outputEntry>
        <outputEntry id="Output_2_3_auto_matching_routing"><text>"BAIXO"</text></outputEntry>
      </rule>
      <!-- Rule 3: Patient match with good confidence -->
      <rule id="Rule_3_auto_matching_routing">
        <inputEntry id="Input_3_1_auto_matching_routing"><text>"patient"</text></inputEntry>
        <inputEntry id="Input_3_2_auto_matching_routing"><text>&gt;= 0.60</text></inputEntry>
        <inputEntry id="Input_3_3_auto_matching_routing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_3_1_auto_matching_routing"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_3_2_auto_matching_routing"><text>"Verificar correspondencia por paciente antes de alocar"</text></outputEntry>
        <outputEntry id="Output_3_3_auto_matching_routing"><text>"MEDIO"</text></outputEntry>
      </rule>
      <!-- Rule 4: Patient match with low confidence -->
      <rule id="Rule_4_auto_matching_routing">
        <inputEntry id="Input_4_1_auto_matching_routing"><text>"patient"</text></inputEntry>
        <inputEntry id="Input_4_2_auto_matching_routing"><text>&lt; 0.60</text></inputEntry>
        <inputEntry id="Input_4_3_auto_matching_routing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_4_1_auto_matching_routing"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_4_2_auto_matching_routing"><text>"Confianca baixa - revisao manual obrigatoria"</text></outputEntry>
        <outputEntry id="Output_4_3_auto_matching_routing"><text>"ALTO"</text></outputEntry>
      </rule>
      <!-- Rule 5: No match found with claims available -->
      <rule id="Rule_5_auto_matching_routing">
        <inputEntry id="Input_5_1_auto_matching_routing"><text>"none"</text></inputEntry>
        <inputEntry id="Input_5_2_auto_matching_routing"><text></text></inputEntry>
        <inputEntry id="Input_5_3_auto_matching_routing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_5_1_auto_matching_routing"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_5_2_auto_matching_routing"><text>"Nenhuma correspondencia automatica - encaminhar para matching manual"</text></outputEntry>
        <outputEntry id="Output_5_3_auto_matching_routing"><text>"ALTO"</text></outputEntry>
      </rule>
      <!-- Rule 6: No match and no claims -->
      <rule id="Rule_6_auto_matching_routing">
        <inputEntry id="Input_6_1_auto_matching_routing"><text>"none"</text></inputEntry>
        <inputEntry id="Input_6_2_auto_matching_routing"><text></text></inputEntry>
        <inputEntry id="Input_6_3_auto_matching_routing"><text>0</text></inputEntry>
        <outputEntry id="Output_6_1_auto_matching_routing"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_6_2_auto_matching_routing"><text>"Sem claims disponiveis para correspondencia"</text></outputEntry>
        <outputEntry id="Output_6_3_auto_matching_routing"><text>"CRITICO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_auto_matching_routing">
      <dmndi:DMNShape id="DMNShape_Decision_auto_matching_routing" dmnElementRef="Decision_auto_matching_routing">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
