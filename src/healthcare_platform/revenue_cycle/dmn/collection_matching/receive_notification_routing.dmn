<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_receive_notification_routing"
             name="Receive Payment Notification Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: receive_payment_notification_worker.py -->
  <decision id="Decision_receive_notification_routing" name="[SP-RC-012 | collection_matching] Receive Payment Notification Routing" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_receive_notification_routing" hitPolicy="FIRST">
      <input id="Input_signature_valid_receive_notification_routing" label="Assinatura Valida">
        <inputExpression id="InputExpression_signature_valid_receive_notification_routing" typeRef="boolean">
          <text>signature_valid</text>
        </inputExpression>
      </input>
      <input id="Input_payment_method_receive_notification_routing" label="Metodo Pagamento">
        <inputExpression id="InputExpression_payment_method_receive_notification_routing" typeRef="string">
          <text>payment_method</text>
        </inputExpression>
        <inputValues><text>"pix","boleto","bank_transfer"</text></inputValues>
      </input>
      <input id="Input_amount_receive_notification_routing" label="Valor">
        <inputExpression id="InputExpression_amount_receive_notification_routing" typeRef="double">
          <text>amount</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_receive_notification_routing" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_receive_notification_routing" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_receive_notification_routing" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1_receive_notification_routing">
        <inputEntry id="Input_1_1_receive_notification_routing"><text>true</text></inputEntry>
        <inputEntry id="Input_1_2_receive_notification_routing"><text>"pix"</text></inputEntry>
        <inputEntry id="Input_1_3_receive_notification_routing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_1_1_receive_notification_routing"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2_receive_notification_routing"><text>"Notificacao PIX valida - processar imediatamente"</text></outputEntry>
        <outputEntry id="Output_1_3_receive_notification_routing"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2_receive_notification_routing">
        <inputEntry id="Input_2_1_receive_notification_routing"><text>true</text></inputEntry>
        <inputEntry id="Input_2_2_receive_notification_routing"><text>"boleto"</text></inputEntry>
        <inputEntry id="Input_2_3_receive_notification_routing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_2_1_receive_notification_routing"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_2_2_receive_notification_routing"><text>"Notificacao boleto valida - processar"</text></outputEntry>
        <outputEntry id="Output_2_3_receive_notification_routing"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_3_receive_notification_routing">
        <inputEntry id="Input_3_1_receive_notification_routing"><text>true</text></inputEntry>
        <inputEntry id="Input_3_2_receive_notification_routing"><text>"bank_transfer"</text></inputEntry>
        <inputEntry id="Input_3_3_receive_notification_routing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_3_1_receive_notification_routing"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_3_2_receive_notification_routing"><text>"Transferencia bancaria valida - processar"</text></outputEntry>
        <outputEntry id="Output_3_3_receive_notification_routing"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_4_receive_notification_routing">
        <inputEntry id="Input_4_1_receive_notification_routing"><text>false</text></inputEntry>
        <inputEntry id="Input_4_2_receive_notification_routing"><text></text></inputEntry>
        <inputEntry id="Input_4_3_receive_notification_routing"><text></text></inputEntry>
        <outputEntry id="Output_4_1_receive_notification_routing"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_4_2_receive_notification_routing"><text>"Assinatura HMAC invalida - rejeitar webhook"</text></outputEntry>
        <outputEntry id="Output_4_3_receive_notification_routing"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_5_receive_notification_routing">
        <inputEntry id="Input_5_1_receive_notification_routing"><text>true</text></inputEntry>
        <inputEntry id="Input_5_2_receive_notification_routing"><text></text></inputEntry>
        <inputEntry id="Input_5_3_receive_notification_routing"><text>&lt;= 0</text></inputEntry>
        <outputEntry id="Output_5_1_receive_notification_routing"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_5_2_receive_notification_routing"><text>"Valor do pagamento zerado ou negativo"</text></outputEntry>
        <outputEntry id="Output_5_3_receive_notification_routing"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_6_receive_notification_routing">
        <inputEntry id="Input_6_1_receive_notification_routing"><text>true</text></inputEntry>
        <inputEntry id="Input_6_2_receive_notification_routing"><text></text></inputEntry>
        <inputEntry id="Input_6_3_receive_notification_routing"><text>&gt; 1000000</text></inputEntry>
        <outputEntry id="Output_6_1_receive_notification_routing"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_6_2_receive_notification_routing"><text>"Valor alto - revisao de seguranca obrigatoria"</text></outputEntry>
        <outputEntry id="Output_6_3_receive_notification_routing"><text>"ALTO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_receive_notification_routing">
      <dmndi:DMNShape id="DMNShape_Decision_receive_notification_routing" dmnElementRef="Decision_receive_notification_routing">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
