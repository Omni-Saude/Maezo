<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_persist_payment_validation"
             name="Persist Payment Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: persist_payment_worker.py -->
  <decision id="Decision_persist_payment_validation" name="[SP-RC-012 | collection_matching] Persist Payment Validation" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_persist_payment_validation" hitPolicy="FIRST">
      <input id="Input_has_transaction_id_persist_payment_validation" label="Tem Transaction ID">
        <inputExpression id="InputExpression_has_transaction_id_persist_payment_validation" typeRef="boolean">
          <text>has_transaction_id</text>
        </inputExpression>
      </input>
      <input id="Input_net_amount_persist_payment_validation" label="Valor Liquido">
        <inputExpression id="InputExpression_net_amount_persist_payment_validation" typeRef="double">
          <text>net_amount</text>
        </inputExpression>
      </input>
      <input id="Input_tenant_valid_persist_payment_validation" label="Tenant Valido">
        <inputExpression id="InputExpression_tenant_valid_persist_payment_validation" typeRef="boolean">
          <text>tenant_valid</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_persist_payment_validation" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_persist_payment_validation" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_persist_payment_validation" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1_persist_payment_validation">
        <inputEntry id="Input_1_1_persist_payment_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_1_2_persist_payment_validation"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_1_3_persist_payment_validation"><text>true</text></inputEntry>
        <outputEntry id="Output_1_1_persist_payment_validation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2_persist_payment_validation"><text>"Dados completos para persistencia"</text></outputEntry>
        <outputEntry id="Output_1_3_persist_payment_validation"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2_persist_payment_validation">
        <inputEntry id="Input_2_1_persist_payment_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_2_2_persist_payment_validation"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_2_3_persist_payment_validation"><text>true</text></inputEntry>
        <outputEntry id="Output_2_1_persist_payment_validation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_2_2_persist_payment_validation"><text>"Transaction ID obrigatorio para persistencia"</text></outputEntry>
        <outputEntry id="Output_2_3_persist_payment_validation"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_3_persist_payment_validation">
        <inputEntry id="Input_3_1_persist_payment_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_3_2_persist_payment_validation"><text>&lt;= 0</text></inputEntry>
        <inputEntry id="Input_3_3_persist_payment_validation"><text>true</text></inputEntry>
        <outputEntry id="Output_3_1_persist_payment_validation"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_3_2_persist_payment_validation"><text>"Valor liquido zerado - verificar taxas"</text></outputEntry>
        <outputEntry id="Output_3_3_persist_payment_validation"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_4_persist_payment_validation">
        <inputEntry id="Input_4_1_persist_payment_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_4_2_persist_payment_validation"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_4_3_persist_payment_validation"><text>false</text></inputEntry>
        <outputEntry id="Output_4_1_persist_payment_validation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_4_2_persist_payment_validation"><text>"Tenant invalido - nao pode persistir"</text></outputEntry>
        <outputEntry id="Output_4_3_persist_payment_validation"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_5_persist_payment_validation">
        <inputEntry id="Input_5_1_persist_payment_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_5_2_persist_payment_validation"><text>&lt;= 0</text></inputEntry>
        <inputEntry id="Input_5_3_persist_payment_validation"><text></text></inputEntry>
        <outputEntry id="Output_5_1_persist_payment_validation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_5_2_persist_payment_validation"><text>"Dados insuficientes para persistencia"</text></outputEntry>
        <outputEntry id="Output_5_3_persist_payment_validation"><text>"CRITICO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_persist_payment_validation">
      <dmndi:DMNShape id="DMNShape_Decision_persist_payment_validation" dmnElementRef="Decision_persist_payment_validation">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
