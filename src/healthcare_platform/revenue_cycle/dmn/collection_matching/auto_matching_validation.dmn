<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_auto_matching_validation"
             name="Auto Matching Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: auto_matching_worker.py -->
  <decision id="Decision_auto_matching_validation" name="[SP-RC-012 | collection_matching] Auto Matching Validation" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_auto_matching_validation" hitPolicy="FIRST">
      <input id="Input_has_protocol_auto_matching_validation" label="Tem Protocolo">
        <inputExpression id="InputExpression_has_protocol_auto_matching_validation" typeRef="boolean">
          <text>has_protocol</text>
        </inputExpression>
      </input>
      <input id="Input_has_invoice_auto_matching_validation" label="Tem Fatura">
        <inputExpression id="InputExpression_has_invoice_auto_matching_validation" typeRef="boolean">
          <text>has_invoice</text>
        </inputExpression>
      </input>
      <input id="Input_has_patient_auto_matching_validation" label="Tem Paciente">
        <inputExpression id="InputExpression_has_patient_auto_matching_validation" typeRef="boolean">
          <text>has_patient</text>
        </inputExpression>
      </input>
      <input id="Input_amount_diff_pct_auto_matching_validation" label="Diferenca Valor Pct">
        <inputExpression id="InputExpression_amount_diff_pct_auto_matching_validation" typeRef="double">
          <text>amount_diff_pct</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_auto_matching_validation" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_auto_matching_validation" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_auto_matching_validation" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1_auto_matching_validation">
        <inputEntry id="Input_1_1_auto_matching_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_1_2_auto_matching_validation"><text></text></inputEntry>
        <inputEntry id="Input_1_3_auto_matching_validation"><text></text></inputEntry>
        <inputEntry id="Input_1_4_auto_matching_validation"><text></text></inputEntry>
        <outputEntry id="Output_1_1_auto_matching_validation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2_auto_matching_validation"><text>"Protocolo disponivel - estrategia primaria"</text></outputEntry>
        <outputEntry id="Output_1_3_auto_matching_validation"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2_auto_matching_validation">
        <inputEntry id="Input_2_1_auto_matching_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_2_2_auto_matching_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_2_3_auto_matching_validation"><text></text></inputEntry>
        <inputEntry id="Input_2_4_auto_matching_validation"><text></text></inputEntry>
        <outputEntry id="Output_2_1_auto_matching_validation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_2_2_auto_matching_validation"><text>"Fatura disponivel - estrategia secundaria"</text></outputEntry>
        <outputEntry id="Output_2_3_auto_matching_validation"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_3_auto_matching_validation">
        <inputEntry id="Input_3_1_auto_matching_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_3_2_auto_matching_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_3_3_auto_matching_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_3_4_auto_matching_validation"><text>&lt; 5.0</text></inputEntry>
        <outputEntry id="Output_3_1_auto_matching_validation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_3_2_auto_matching_validation"><text>"Paciente com diferenca dentro da tolerancia 5%"</text></outputEntry>
        <outputEntry id="Output_3_3_auto_matching_validation"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_4_auto_matching_validation">
        <inputEntry id="Input_4_1_auto_matching_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_4_2_auto_matching_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_4_3_auto_matching_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_4_4_auto_matching_validation"><text>&gt;= 5.0</text></inputEntry>
        <outputEntry id="Output_4_1_auto_matching_validation"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_4_2_auto_matching_validation"><text>"Paciente com diferenca acima da tolerancia"</text></outputEntry>
        <outputEntry id="Output_4_3_auto_matching_validation"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_5_auto_matching_validation">
        <inputEntry id="Input_5_1_auto_matching_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_5_2_auto_matching_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_5_3_auto_matching_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_5_4_auto_matching_validation"><text></text></inputEntry>
        <outputEntry id="Output_5_1_auto_matching_validation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_5_2_auto_matching_validation"><text>"Nenhum identificador disponivel para correspondencia"</text></outputEntry>
        <outputEntry id="Output_5_3_auto_matching_validation"><text>"CRITICO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_auto_matching_validation">
      <dmndi:DMNShape id="DMNShape_Decision_auto_matching_validation" dmnElementRef="Decision_auto_matching_validation">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
