<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_bi_datawarehouse_scoring" name="BI Datawarehouse Scoring" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: update_bi_datawarehouse_worker.py -->
  <decision id="Decision_bi_datawarehouse_scoring" name="[SP-RC-011 | collection_analytics] BI Datawarehouse Scoring" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_bi_datawarehouse_scoring" hitPolicy="FIRST">
      <input id="Input_total_records_bi_datawarehouse_scoring" label="Total Registros">
        <inputExpression id="IE_rec_bi_datawarehouse_scoring" typeRef="integer"><text>total_records</text></inputExpression>
      </input>
      <input id="Input_avg_collection_rate_bi_datawarehouse_scoring" label="Taxa Media Cobranca">
        <inputExpression id="IE_acr_bi_datawarehouse_scoring" typeRef="double"><text>avg_collection_rate</text></inputExpression>
      </input>
      <output id="Output_resultado_bi_datawarehouse_scoring" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao_bi_datawarehouse_scoring" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_bi_datawarehouse_scoring" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1_bi_datawarehouse_scoring"><inputEntry id="U1a_bi_datawarehouse_scoring"><text>0</text></inputEntry><inputEntry id="U1b_bi_datawarehouse_scoring"><text></text></inputEntry><outputEntry id="L1_bi_datawarehouse_scoring"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L1a_bi_datawarehouse_scoring"><text>"Sem dados para exportar - verificar fonte"</text></outputEntry><outputEntry id="L1b_bi_datawarehouse_scoring"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2_bi_datawarehouse_scoring"><inputEntry id="U2a_bi_datawarehouse_scoring"><text>> 0</text></inputEntry><inputEntry id="U2b_bi_datawarehouse_scoring"><text>&lt; 50</text></inputEntry><outputEntry id="L2_bi_datawarehouse_scoring"><text>"REVISAR"</text></outputEntry><outputEntry id="L2a_bi_datawarehouse_scoring"><text>"Taxa cobranca baixa no lote exportado"</text></outputEntry><outputEntry id="L2b_bi_datawarehouse_scoring"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_3_bi_datawarehouse_scoring"><inputEntry id="U3a_bi_datawarehouse_scoring"><text>> 0</text></inputEntry><inputEntry id="U3b_bi_datawarehouse_scoring"><text>[50..80)</text></inputEntry><outputEntry id="L3_bi_datawarehouse_scoring"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L3a_bi_datawarehouse_scoring"><text>"Exportacao com metricas aceitaveis"</text></outputEntry><outputEntry id="L3b_bi_datawarehouse_scoring"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_4_bi_datawarehouse_scoring"><inputEntry id="U4a_bi_datawarehouse_scoring"><text>> 0</text></inputEntry><inputEntry id="U4b_bi_datawarehouse_scoring"><text>[80..95)</text></inputEntry><outputEntry id="L4_bi_datawarehouse_scoring"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a_bi_datawarehouse_scoring"><text>"Exportacao com boas metricas"</text></outputEntry><outputEntry id="L4b_bi_datawarehouse_scoring"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_5_bi_datawarehouse_scoring"><inputEntry id="U5a_bi_datawarehouse_scoring"><text>> 0</text></inputEntry><inputEntry id="U5b_bi_datawarehouse_scoring"><text>>= 95</text></inputEntry><outputEntry id="L5_bi_datawarehouse_scoring"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a_bi_datawarehouse_scoring"><text>"Exportacao com metricas excelentes"</text></outputEntry><outputEntry id="L5b_bi_datawarehouse_scoring"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_bi_datawarehouse_scoring">
      <dmndi:DMNShape id="DMNShape_Decision_bi_datawarehouse_scoring" dmnElementRef="Decision_bi_datawarehouse_scoring">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
