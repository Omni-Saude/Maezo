<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  LEAKAGE-PATTERN - Deteccao de Padroes de Vazamento de Receita
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_ANALYTICS
  Archetype: CLINICAL_SCORE | Source: detect_revenue_leakage_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_LEAKAGE_PATTERN"
             name="Deteccao de Padroes de Vazamento de Receita"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_LEAKAGE_PATTERN" name="[SP-RC-011 | collection_analytics] Deteccao de Padroes de Vazamento de Receita" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_LEAKAGE_PATTERN" hitPolicy="FIRST">

      <input id="Input_1_LEAKAGE_PATTERN" label="Taxa Vazamento Percentual">
        <inputExpression id="InputExpression_1_LEAKAGE_PATTERN" typeRef="number">
          <text>leakageRatePercent</text>
        </inputExpression>
      </input>

      <input id="Input_2_LEAKAGE_PATTERN" label="Origem Vazamento">
        <inputExpression id="InputExpression_2_LEAKAGE_PATTERN" typeRef="string">
          <text>leakageSource</text>
        </inputExpression>
      </input>

      <input id="Input_3_LEAKAGE_PATTERN" label="Valor Acumulado Perdido">
        <inputExpression id="InputExpression_3_LEAKAGE_PATTERN" typeRef="number">
          <text>accumulatedLoss</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado_LEAKAGE_PATTERN" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_LEAKAGE_PATTERN" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_LEAKAGE_PATTERN" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1_LEAKAGE_PATTERN">
        <description>Vazamento alto por subcobranca</description>
        <inputEntry id="IE_1_1_LEAKAGE_PATTERN"><text>&gt; 10</text></inputEntry>
        <inputEntry id="IE_1_2_LEAKAGE_PATTERN"><text>"UNDERBILLING"</text></inputEntry>
        <inputEntry id="IE_1_3_LEAKAGE_PATTERN"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1_LEAKAGE_PATTERN"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2_LEAKAGE_PATTERN"><text>"Vazamento &gt;10% por subcobranca - auditoria urgente de codificacao"</text></outputEntry>
        <outputEntry id="OE_1_3_LEAKAGE_PATTERN"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2_LEAKAGE_PATTERN">
        <description>Perda acumulada elevada por glosas nao contestadas</description>
        <inputEntry id="IE_2_1_LEAKAGE_PATTERN"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2_LEAKAGE_PATTERN"><text>"UNCONTESTED_DENIAL"</text></inputEntry>
        <inputEntry id="IE_2_3_LEAKAGE_PATTERN"><text>&gt; 50000</text></inputEntry>
        <outputEntry id="OE_2_1_LEAKAGE_PATTERN"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_2_2_LEAKAGE_PATTERN"><text>"Mais de R$50k em glosas nao contestadas - acionar equipe de recurso"</text></outputEntry>
        <outputEntry id="OE_2_3_LEAKAGE_PATTERN"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_3_LEAKAGE_PATTERN">
        <description>Vazamento moderado por contratos desatualizados</description>
        <inputEntry id="IE_3_1_LEAKAGE_PATTERN"><text>[5..10]</text></inputEntry>
        <inputEntry id="IE_3_2_LEAKAGE_PATTERN"><text>"CONTRACT_GAP"</text></inputEntry>
        <inputEntry id="IE_3_3_LEAKAGE_PATTERN"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1_LEAKAGE_PATTERN"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_3_2_LEAKAGE_PATTERN"><text>"Contratos com tabelas defasadas - agendar renegociacao"</text></outputEntry>
        <outputEntry id="OE_3_3_LEAKAGE_PATTERN"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_4_LEAKAGE_PATTERN">
        <description>Vazamento baixo - monitoramento padrao</description>
        <inputEntry id="IE_4_1_LEAKAGE_PATTERN"><text>[2..5]</text></inputEntry>
        <inputEntry id="IE_4_2_LEAKAGE_PATTERN"><text>-</text></inputEntry>
        <inputEntry id="IE_4_3_LEAKAGE_PATTERN"><text>&lt; 10000</text></inputEntry>
        <outputEntry id="OE_4_1_LEAKAGE_PATTERN"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2_LEAKAGE_PATTERN"><text>"Vazamento dentro da margem operacional - acompanhar mensalmente"</text></outputEntry>
        <outputEntry id="OE_4_3_LEAKAGE_PATTERN"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_5_LEAKAGE_PATTERN">
        <description>Vazamento residual - aceitavel</description>
        <inputEntry id="IE_5_1_LEAKAGE_PATTERN"><text>&lt; 2</text></inputEntry>
        <inputEntry id="IE_5_2_LEAKAGE_PATTERN"><text>-</text></inputEntry>
        <inputEntry id="IE_5_3_LEAKAGE_PATTERN"><text>-</text></inputEntry>
        <outputEntry id="OE_5_1_LEAKAGE_PATTERN"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_2_LEAKAGE_PATTERN"><text>"Taxa de vazamento residual dentro do benchmark"</text></outputEntry>
        <outputEntry id="OE_5_3_LEAKAGE_PATTERN"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_LEAKAGE_PATTERN">
        <description>Fallback</description>
        <inputEntry id="IE_F_1_LEAKAGE_PATTERN"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_LEAKAGE_PATTERN"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3_LEAKAGE_PATTERN"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_LEAKAGE_PATTERN"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2_LEAKAGE_PATTERN"><text>"Avaliar padrao de vazamento manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3_LEAKAGE_PATTERN"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_LEAKAGE_PATTERN">
      <dmndi:DMNShape id="DMNShape_Decision_LEAKAGE_PATTERN" dmnElementRef="Decision_LEAKAGE_PATTERN">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
