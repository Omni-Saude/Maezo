<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_anomalies_threshold"
             name="Anomalies Threshold"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: alert_anomalies_worker.py -->
  <decision id="Decision_anomalies_threshold" name="[SP-RC-011 | collection_analytics] Anomalies Threshold" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_anomalies_threshold" hitPolicy="FIRST">
      <input id="Input_critical_count_anomalies_threshold" label="Anomalias Criticas">
        <inputExpression id="IE_critical_count_anomalies_threshold" typeRef="integer"><text>critical_anomalies</text></inputExpression>
      </input>
      <input id="Input_total_count_anomalies_threshold" label="Total Anomalias">
        <inputExpression id="IE_total_count_anomalies_threshold" typeRef="integer"><text>total_anomalies</text></inputExpression>
      </input>
      <output id="Output_resultado_anomalies_threshold" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_anomalies_threshold" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_anomalies_threshold" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1_anomalies_threshold">
        <inputEntry id="U1a_anomalies_threshold"><text>>= 3</text></inputEntry>
        <inputEntry id="U1b_anomalies_threshold"><text></text></inputEntry>
        <outputEntry id="L1_anomalies_threshold"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="L1a_anomalies_threshold"><text>"Multiplas anomalias criticas - parar e investigar"</text></outputEntry>
        <outputEntry id="L1b_anomalies_threshold"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_2_anomalies_threshold">
        <inputEntry id="U2a_anomalies_threshold"><text>>= 1</text></inputEntry>
        <inputEntry id="U2b_anomalies_threshold"><text>>= 5</text></inputEntry>
        <outputEntry id="L2_anomalies_threshold"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="L2a_anomalies_threshold"><text>"Anomalia critica com muitas anomalias"</text></outputEntry>
        <outputEntry id="L2b_anomalies_threshold"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_3_anomalies_threshold">
        <inputEntry id="U3a_anomalies_threshold"><text>>= 1</text></inputEntry>
        <inputEntry id="U3b_anomalies_threshold"><text></text></inputEntry>
        <outputEntry id="L3_anomalies_threshold"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="L3a_anomalies_threshold"><text>"Anomalia critica isolada - analisar"</text></outputEntry>
        <outputEntry id="L3b_anomalies_threshold"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_4_anomalies_threshold">
        <inputEntry id="U4a_anomalies_threshold"><text>0</text></inputEntry>
        <inputEntry id="U4b_anomalies_threshold"><text>>= 3</text></inputEntry>
        <outputEntry id="L4_anomalies_threshold"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="L4a_anomalies_threshold"><text>"Volume alto de anomalias nao-criticas"</text></outputEntry>
        <outputEntry id="L4b_anomalies_threshold"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_5_anomalies_threshold">
        <inputEntry id="U5a_anomalies_threshold"><text>0</text></inputEntry>
        <inputEntry id="U5b_anomalies_threshold"><text>[1..3)</text></inputEntry>
        <outputEntry id="L5_anomalies_threshold"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="L5a_anomalies_threshold"><text>"Poucas anomalias leves"</text></outputEntry>
        <outputEntry id="L5b_anomalies_threshold"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_6_anomalies_threshold">
        <inputEntry id="U6a_anomalies_threshold"><text>0</text></inputEntry>
        <inputEntry id="U6b_anomalies_threshold"><text>0</text></inputEntry>
        <outputEntry id="L6_anomalies_threshold"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="L6a_anomalies_threshold"><text>"Sem anomalias detectadas"</text></outputEntry>
        <outputEntry id="L6b_anomalies_threshold"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_anomalies_threshold">
      <dmndi:DMNShape id="DMNShape_Decision_anomalies_threshold" dmnElementRef="Decision_anomalies_threshold">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
