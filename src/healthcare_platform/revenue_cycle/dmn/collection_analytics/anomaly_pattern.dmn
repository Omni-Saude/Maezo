<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  ANOMALY-PATTERN - Deteccao de Padroes Anomalos
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_ANALYTICS
  Archetype: CLINICAL_SCORE | Source: alert_anomalies_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_ANOMALY_PATTERN"
             name="Deteccao de Padroes Anomalos"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_ANOMALY_PATTERN" name="[SP-RC-011 | collection_analytics] Deteccao de Padroes Anomalos" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_ANOMALY_PATTERN" hitPolicy="FIRST">

      <input id="Input_1_ANOMALY_PATTERN" label="Desvio Padrao Score">
        <inputExpression id="InputExpression_1_ANOMALY_PATTERN" typeRef="number">
          <text>stdDevScore</text>
        </inputExpression>
      </input>

      <input id="Input_2_ANOMALY_PATTERN" label="Frequencia Anomalia">
        <inputExpression id="InputExpression_2_ANOMALY_PATTERN" typeRef="number">
          <text>anomalyFrequency</text>
        </inputExpression>
      </input>

      <input id="Input_3_ANOMALY_PATTERN" label="Tipo Anomalia">
        <inputExpression id="InputExpression_3_ANOMALY_PATTERN" typeRef="string">
          <text>anomalyType</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado_ANOMALY_PATTERN" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_ANOMALY_PATTERN" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_ANOMALY_PATTERN" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1_ANOMALY_PATTERN">
        <description>Anomalia critica - desvio extremo com alta frequencia</description>
        <inputEntry id="IE_1_1_ANOMALY_PATTERN"><text>&gt; 3.0</text></inputEntry>
        <inputEntry id="IE_1_2_ANOMALY_PATTERN"><text>&gt; 5</text></inputEntry>
        <inputEntry id="IE_1_3_ANOMALY_PATTERN"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1_ANOMALY_PATTERN"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2_ANOMALY_PATTERN"><text>"Anomalia sistematica detectada - suspender processamento e investigar"</text></outputEntry>
        <outputEntry id="OE_1_3_ANOMALY_PATTERN"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2_ANOMALY_PATTERN">
        <description>Pagamento duplicado detectado</description>
        <inputEntry id="IE_2_1_ANOMALY_PATTERN"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2_ANOMALY_PATTERN"><text>-</text></inputEntry>
        <inputEntry id="IE_2_3_ANOMALY_PATTERN"><text>"DUPLICATE_PAYMENT"</text></inputEntry>
        <outputEntry id="OE_2_1_ANOMALY_PATTERN"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_2_2_ANOMALY_PATTERN"><text>"Possivel pagamento duplicado - bloquear e verificar"</text></outputEntry>
        <outputEntry id="OE_2_3_ANOMALY_PATTERN"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_3_ANOMALY_PATTERN">
        <description>Desvio alto mas isolado</description>
        <inputEntry id="IE_3_1_ANOMALY_PATTERN"><text>[2.0..3.0]</text></inputEntry>
        <inputEntry id="IE_3_2_ANOMALY_PATTERN"><text>&lt;= 2</text></inputEntry>
        <inputEntry id="IE_3_3_ANOMALY_PATTERN"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1_ANOMALY_PATTERN"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_3_2_ANOMALY_PATTERN"><text>"Anomalia pontual - revisar caso individualmente"</text></outputEntry>
        <outputEntry id="OE_3_3_ANOMALY_PATTERN"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_4_ANOMALY_PATTERN">
        <description>Variacao de volume - padrao sazonal possivel</description>
        <inputEntry id="IE_4_1_ANOMALY_PATTERN"><text>[1.0..2.0]</text></inputEntry>
        <inputEntry id="IE_4_2_ANOMALY_PATTERN"><text>-</text></inputEntry>
        <inputEntry id="IE_4_3_ANOMALY_PATTERN"><text>"VOLUME_SPIKE"</text></inputEntry>
        <outputEntry id="OE_4_1_ANOMALY_PATTERN"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2_ANOMALY_PATTERN"><text>"Pico de volume dentro do esperado sazonal - monitorar"</text></outputEntry>
        <outputEntry id="OE_4_3_ANOMALY_PATTERN"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_5_ANOMALY_PATTERN">
        <description>Desvio baixo - operacao normal</description>
        <inputEntry id="IE_5_1_ANOMALY_PATTERN"><text>&lt; 1.0</text></inputEntry>
        <inputEntry id="IE_5_2_ANOMALY_PATTERN"><text>-</text></inputEntry>
        <inputEntry id="IE_5_3_ANOMALY_PATTERN"><text>-</text></inputEntry>
        <outputEntry id="OE_5_1_ANOMALY_PATTERN"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_2_ANOMALY_PATTERN"><text>"Valores dentro da faixa normal"</text></outputEntry>
        <outputEntry id="OE_5_3_ANOMALY_PATTERN"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_ANOMALY_PATTERN">
        <description>Fallback</description>
        <inputEntry id="IE_F_1_ANOMALY_PATTERN"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_ANOMALY_PATTERN"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3_ANOMALY_PATTERN"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_ANOMALY_PATTERN"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2_ANOMALY_PATTERN"><text>"Avaliar padrao anomalo manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3_ANOMALY_PATTERN"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ANOMALY_PATTERN">
      <dmndi:DMNShape id="DMNShape_Decision_ANOMALY_PATTERN" dmnElementRef="Decision_ANOMALY_PATTERN">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
