<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_reconcile_daily_validation"
             name="Reconcile Daily Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: reconcile_daily_worker.py -->
  <decision id="Decision_reconcile_daily_validation" name="[SP-RC-012 | collection_reconciliation] Reconcile Daily Validation" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_reconcile_daily_validation" hitPolicy="FIRST">
      <input id="Input_recon_date_valid_reconcile_daily_validation" label="Data Reconciliacao Valida">
        <inputExpression id="InputExpression_recon_date_valid_reconcile_daily_validation" typeRef="boolean">
          <text>recon_date_valid</text>
        </inputExpression>
      </input>
      <input id="Input_tasy_available_reconcile_daily_validation" label="TASY Disponivel">
        <inputExpression id="InputExpression_tasy_available_reconcile_daily_validation" typeRef="boolean">
          <text>tasy_available</text>
        </inputExpression>
      </input>
      <input id="Input_variance_threshold_reconcile_daily_validation" label="Threshold Variacao">
        <inputExpression id="InputExpression_variance_threshold_reconcile_daily_validation" typeRef="double">
          <text>variance_threshold</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_reconcile_daily_validation" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_reconcile_daily_validation" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_reconcile_daily_validation" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1_reconcile_daily_validation">
        <inputEntry id="Input_1_1_reconcile_daily_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_1_2_reconcile_daily_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_1_3_reconcile_daily_validation"><text>[0.001..0.05]</text></inputEntry>
        <outputEntry id="Output_1_1_reconcile_daily_validation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2_reconcile_daily_validation"><text>"Configuracao valida com TASY ativo"</text></outputEntry>
        <outputEntry id="Output_1_3_reconcile_daily_validation"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2_reconcile_daily_validation">
        <inputEntry id="Input_2_1_reconcile_daily_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_2_2_reconcile_daily_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_2_3_reconcile_daily_validation"><text></text></inputEntry>
        <outputEntry id="Output_2_1_reconcile_daily_validation"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_2_2_reconcile_daily_validation"><text>"TASY indisponivel - usar dados de fallback"</text></outputEntry>
        <outputEntry id="Output_2_3_reconcile_daily_validation"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_3_reconcile_daily_validation">
        <inputEntry id="Input_3_1_reconcile_daily_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_3_2_reconcile_daily_validation"><text></text></inputEntry>
        <inputEntry id="Input_3_3_reconcile_daily_validation"><text></text></inputEntry>
        <outputEntry id="Output_3_1_reconcile_daily_validation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_3_2_reconcile_daily_validation"><text>"Data de reconciliacao invalida"</text></outputEntry>
        <outputEntry id="Output_3_3_reconcile_daily_validation"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_4_reconcile_daily_validation">
        <inputEntry id="Input_4_1_reconcile_daily_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_4_2_reconcile_daily_validation"><text></text></inputEntry>
        <inputEntry id="Input_4_3_reconcile_daily_validation"><text>&gt; 0.05</text></inputEntry>
        <outputEntry id="Output_4_1_reconcile_daily_validation"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_4_2_reconcile_daily_validation"><text>"Threshold de variacao muito alto - verificar config"</text></outputEntry>
        <outputEntry id="Output_4_3_reconcile_daily_validation"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_5_reconcile_daily_validation">
        <inputEntry id="Input_5_1_reconcile_daily_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_5_2_reconcile_daily_validation"><text></text></inputEntry>
        <inputEntry id="Input_5_3_reconcile_daily_validation"><text>&lt;= 0</text></inputEntry>
        <outputEntry id="Output_5_1_reconcile_daily_validation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_5_2_reconcile_daily_validation"><text>"Threshold de variacao invalido"</text></outputEntry>
        <outputEntry id="Output_5_3_reconcile_daily_validation"><text>"ALTO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_reconcile_daily_validation">
      <dmndi:DMNShape id="DMNShape_Decision_reconcile_daily_validation" dmnElementRef="Decision_reconcile_daily_validation">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
