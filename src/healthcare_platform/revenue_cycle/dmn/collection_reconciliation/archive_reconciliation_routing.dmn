<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_archive_reconciliation_routing"
             name="Archive Reconciliation Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: archive_reconciliation_worker.py -->
  <decision id="Decision_archive_reconciliation_routing" name="[SP-RC-012 | collection_reconciliation] Archive Reconciliation Routing" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_archive_reconciliation_routing" hitPolicy="FIRST">
      <input id="Input_eligible_count_archive_reconciliation_routing" label="Elegiveis para Arquivo">
        <inputExpression id="InputExpression_eligible_count_archive_reconciliation_routing" typeRef="integer">
          <text>eligible_count</text>
        </inputExpression>
      </input>
      <input id="Input_retention_days_archive_reconciliation_routing" label="Dias Retencao">
        <inputExpression id="InputExpression_retention_days_archive_reconciliation_routing" typeRef="integer">
          <text>retention_days</text>
        </inputExpression>
      </input>
      <input id="Input_dry_run_archive_reconciliation_routing" label="Modo Simulacao">
        <inputExpression id="InputExpression_dry_run_archive_reconciliation_routing" typeRef="boolean">
          <text>dry_run</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_archive_reconciliation_routing" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_archive_reconciliation_routing" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_archive_reconciliation_routing" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1_archive_reconciliation_routing">
        <inputEntry id="Input_1_1_archive_reconciliation_routing"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_1_2_archive_reconciliation_routing"><text>&gt;= 365</text></inputEntry>
        <inputEntry id="Input_1_3_archive_reconciliation_routing"><text>false</text></inputEntry>
        <outputEntry id="Output_1_1_archive_reconciliation_routing"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2_archive_reconciliation_routing"><text>"Arquivar registros com retencao adequada"</text></outputEntry>
        <outputEntry id="Output_1_3_archive_reconciliation_routing"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2_archive_reconciliation_routing">
        <inputEntry id="Input_2_1_archive_reconciliation_routing"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_2_2_archive_reconciliation_routing"><text>&gt;= 365</text></inputEntry>
        <inputEntry id="Input_2_3_archive_reconciliation_routing"><text>true</text></inputEntry>
        <outputEntry id="Output_2_1_archive_reconciliation_routing"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_2_2_archive_reconciliation_routing"><text>"Simulacao - listar sem arquivar"</text></outputEntry>
        <outputEntry id="Output_2_3_archive_reconciliation_routing"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_3_archive_reconciliation_routing">
        <inputEntry id="Input_3_1_archive_reconciliation_routing"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_3_2_archive_reconciliation_routing"><text>[90..365)</text></inputEntry>
        <inputEntry id="Input_3_3_archive_reconciliation_routing"><text>false</text></inputEntry>
        <outputEntry id="Output_3_1_archive_reconciliation_routing"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_3_2_archive_reconciliation_routing"><text>"Retencao menor que 1 ano - verificar politica"</text></outputEntry>
        <outputEntry id="Output_3_3_archive_reconciliation_routing"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_4_archive_reconciliation_routing">
        <inputEntry id="Input_4_1_archive_reconciliation_routing"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_4_2_archive_reconciliation_routing"><text>&lt; 90</text></inputEntry>
        <inputEntry id="Input_4_3_archive_reconciliation_routing"><text></text></inputEntry>
        <outputEntry id="Output_4_1_archive_reconciliation_routing"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_4_2_archive_reconciliation_routing"><text>"Retencao muito curta - viola politica minima de 90 dias"</text></outputEntry>
        <outputEntry id="Output_4_3_archive_reconciliation_routing"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_5_archive_reconciliation_routing">
        <inputEntry id="Input_5_1_archive_reconciliation_routing"><text>0</text></inputEntry>
        <inputEntry id="Input_5_2_archive_reconciliation_routing"><text></text></inputEntry>
        <inputEntry id="Input_5_3_archive_reconciliation_routing"><text></text></inputEntry>
        <outputEntry id="Output_5_1_archive_reconciliation_routing"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_5_2_archive_reconciliation_routing"><text>"Nenhum registro elegivel para arquivamento"</text></outputEntry>
        <outputEntry id="Output_5_3_archive_reconciliation_routing"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_6_archive_reconciliation_routing">
        <inputEntry id="Input_6_1_archive_reconciliation_routing"><text>&gt; 1000</text></inputEntry>
        <inputEntry id="Input_6_2_archive_reconciliation_routing"><text></text></inputEntry>
        <inputEntry id="Input_6_3_archive_reconciliation_routing"><text>false</text></inputEntry>
        <outputEntry id="Output_6_1_archive_reconciliation_routing"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_6_2_archive_reconciliation_routing"><text>"Volume alto - executar em lotes com monitoramento"</text></outputEntry>
        <outputEntry id="Output_6_3_archive_reconciliation_routing"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_archive_reconciliation_routing">
      <dmndi:DMNShape id="DMNShape_Decision_archive_reconciliation_routing" dmnElementRef="Decision_archive_reconciliation_routing">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
