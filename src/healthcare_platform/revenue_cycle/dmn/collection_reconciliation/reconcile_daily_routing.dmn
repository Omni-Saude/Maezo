<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_reconcile_daily_routing"
             name="Reconcile Daily Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: reconcile_daily_worker.py -->
  <decision id="Decision_reconcile_daily_routing" name="[SP-RC-012 | collection_reconciliation] Reconcile Daily Routing" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_reconcile_daily_routing" hitPolicy="FIRST">
      <input id="Input_variance_pct_reconcile_daily_routing" label="Variacao Percentual">
        <inputExpression id="InputExpression_variance_pct_reconcile_daily_routing" typeRef="double">
          <text>variance_pct</text>
        </inputExpression>
      </input>
      <input id="Input_unmatched_count_reconcile_daily_routing" label="Nao Correspondidos">
        <inputExpression id="InputExpression_unmatched_count_reconcile_daily_routing" typeRef="integer">
          <text>unmatched_count</text>
        </inputExpression>
      </input>
      <input id="Input_payment_count_reconcile_daily_routing" label="Total Pagamentos">
        <inputExpression id="InputExpression_payment_count_reconcile_daily_routing" typeRef="integer">
          <text>payment_count</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_reconcile_daily_routing" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_reconcile_daily_routing" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_reconcile_daily_routing" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1_reconcile_daily_routing">
        <inputEntry id="Input_1_1_reconcile_daily_routing"><text>&lt;= 1.0</text></inputEntry>
        <inputEntry id="Input_1_2_reconcile_daily_routing"><text>0</text></inputEntry>
        <inputEntry id="Input_1_3_reconcile_daily_routing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_1_1_reconcile_daily_routing"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2_reconcile_daily_routing"><text>"Reconciliacao balanceada - variacao dentro do limite"</text></outputEntry>
        <outputEntry id="Output_1_3_reconcile_daily_routing"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2_reconcile_daily_routing">
        <inputEntry id="Input_2_1_reconcile_daily_routing"><text>&lt;= 1.0</text></inputEntry>
        <inputEntry id="Input_2_2_reconcile_daily_routing"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_2_3_reconcile_daily_routing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_2_1_reconcile_daily_routing"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_2_2_reconcile_daily_routing"><text>"Variacao aceitavel mas pagamentos nao correspondidos"</text></outputEntry>
        <outputEntry id="Output_2_3_reconcile_daily_routing"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_3_reconcile_daily_routing">
        <inputEntry id="Input_3_1_reconcile_daily_routing"><text>(1.0..5.0]</text></inputEntry>
        <inputEntry id="Input_3_2_reconcile_daily_routing"><text></text></inputEntry>
        <inputEntry id="Input_3_3_reconcile_daily_routing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_3_1_reconcile_daily_routing"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_3_2_reconcile_daily_routing"><text>"Variacao moderada - investigar discrepancias"</text></outputEntry>
        <outputEntry id="Output_3_3_reconcile_daily_routing"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_4_reconcile_daily_routing">
        <inputEntry id="Input_4_1_reconcile_daily_routing"><text>&gt; 5.0</text></inputEntry>
        <inputEntry id="Input_4_2_reconcile_daily_routing"><text></text></inputEntry>
        <inputEntry id="Input_4_3_reconcile_daily_routing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_4_1_reconcile_daily_routing"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_4_2_reconcile_daily_routing"><text>"Variacao critica - escalar para supervisao"</text></outputEntry>
        <outputEntry id="Output_4_3_reconcile_daily_routing"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_5_reconcile_daily_routing">
        <inputEntry id="Input_5_1_reconcile_daily_routing"><text></text></inputEntry>
        <inputEntry id="Input_5_2_reconcile_daily_routing"><text></text></inputEntry>
        <inputEntry id="Input_5_3_reconcile_daily_routing"><text>0</text></inputEntry>
        <outputEntry id="Output_5_1_reconcile_daily_routing"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_5_2_reconcile_daily_routing"><text>"Nenhum pagamento no periodo - verificar se esperado"</text></outputEntry>
        <outputEntry id="Output_5_3_reconcile_daily_routing"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_reconcile_daily_routing">
      <dmndi:DMNShape id="DMNShape_Decision_reconcile_daily_routing" dmnElementRef="Decision_reconcile_daily_routing">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
