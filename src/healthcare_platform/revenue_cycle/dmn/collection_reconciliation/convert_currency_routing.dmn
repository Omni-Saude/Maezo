<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_convert_currency_routing"
             name="Convert Currency Routing"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: convert_currency_worker.py -->
  <decision id="Decision_convert_currency_routing" name="[SP-RC-012 | collection_reconciliation] Convert Currency Routing" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_convert_currency_routing" hitPolicy="FIRST">
      <input id="Input_currency_convert_currency_routing" label="Moeda Origem">
        <inputExpression id="InputExpression_currency_convert_currency_routing" typeRef="string">
          <text>currency</text>
        </inputExpression>
        <inputValues><text>"BRL","USD","EUR","GBP"</text></inputValues>
      </input>
      <input id="Input_rate_available_convert_currency_routing" label="Taxa Disponivel">
        <inputExpression id="InputExpression_rate_available_convert_currency_routing" typeRef="boolean">
          <text>rate_available</text>
        </inputExpression>
      </input>
      <input id="Input_amount_convert_currency_routing" label="Valor">
        <inputExpression id="InputExpression_amount_convert_currency_routing" typeRef="double">
          <text>amount</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_convert_currency_routing" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_convert_currency_routing" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_convert_currency_routing" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1_convert_currency_routing">
        <inputEntry id="Input_1_1_convert_currency_routing"><text>"BRL"</text></inputEntry>
        <inputEntry id="Input_1_2_convert_currency_routing"><text></text></inputEntry>
        <inputEntry id="Input_1_3_convert_currency_routing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_1_1_convert_currency_routing"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2_convert_currency_routing"><text>"Ja em BRL - nenhuma conversao necessaria"</text></outputEntry>
        <outputEntry id="Output_1_3_convert_currency_routing"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2_convert_currency_routing">
        <inputEntry id="Input_2_1_convert_currency_routing"><text>"USD","EUR","GBP"</text></inputEntry>
        <inputEntry id="Input_2_2_convert_currency_routing"><text>true</text></inputEntry>
        <inputEntry id="Input_2_3_convert_currency_routing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_2_1_convert_currency_routing"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_2_2_convert_currency_routing"><text>"Moeda suportada com taxa - converter para BRL"</text></outputEntry>
        <outputEntry id="Output_2_3_convert_currency_routing"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_3_convert_currency_routing">
        <inputEntry id="Input_3_1_convert_currency_routing"><text>"USD","EUR","GBP"</text></inputEntry>
        <inputEntry id="Input_3_2_convert_currency_routing"><text>false</text></inputEntry>
        <inputEntry id="Input_3_3_convert_currency_routing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_3_1_convert_currency_routing"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_3_2_convert_currency_routing"><text>"Taxa de cambio indisponivel - usar taxa padrao com alerta"</text></outputEntry>
        <outputEntry id="Output_3_3_convert_currency_routing"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_4_convert_currency_routing">
        <inputEntry id="Input_4_1_convert_currency_routing"><text>not("BRL","USD","EUR","GBP")</text></inputEntry>
        <inputEntry id="Input_4_2_convert_currency_routing"><text></text></inputEntry>
        <inputEntry id="Input_4_3_convert_currency_routing"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_4_1_convert_currency_routing"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_4_2_convert_currency_routing"><text>"Moeda nao suportada - requer configuracao manual"</text></outputEntry>
        <outputEntry id="Output_4_3_convert_currency_routing"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_5_convert_currency_routing">
        <inputEntry id="Input_5_1_convert_currency_routing"><text></text></inputEntry>
        <inputEntry id="Input_5_2_convert_currency_routing"><text></text></inputEntry>
        <inputEntry id="Input_5_3_convert_currency_routing"><text>&lt;= 0</text></inputEntry>
        <outputEntry id="Output_5_1_convert_currency_routing"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_5_2_convert_currency_routing"><text>"Valor invalido para conversao"</text></outputEntry>
        <outputEntry id="Output_5_3_convert_currency_routing"><text>"CRITICO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_convert_currency_routing">
      <dmndi:DMNShape id="DMNShape_Decision_convert_currency_routing" dmnElementRef="Decision_convert_currency_routing">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
