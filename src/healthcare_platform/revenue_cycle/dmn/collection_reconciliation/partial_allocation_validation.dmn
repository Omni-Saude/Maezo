<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_partial_allocation_validation"
             name="Partial Allocation Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: partial_allocation_worker.py -->
  <decision id="Decision_partial_allocation_validation" name="[SP-RC-012 | collection_reconciliation] Partial Allocation Validation" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_partial_allocation_validation" hitPolicy="FIRST">
      <input id="Input_payment_amount_partial_allocation_validation" label="Valor Pagamento">
        <inputExpression id="InputExpression_payment_amount_partial_allocation_validation" typeRef="double">
          <text>payment_amount</text>
        </inputExpression>
      </input>
      <input id="Input_claims_sorted_partial_allocation_validation" label="Claims Ordenados">
        <inputExpression id="InputExpression_claims_sorted_partial_allocation_validation" typeRef="boolean">
          <text>claims_sorted_by_date</text>
        </inputExpression>
      </input>
      <input id="Input_total_outstanding_partial_allocation_validation" label="Total Pendente">
        <inputExpression id="InputExpression_total_outstanding_partial_allocation_validation" typeRef="double">
          <text>total_outstanding</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_partial_allocation_validation" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_partial_allocation_validation" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_partial_allocation_validation" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1_partial_allocation_validation">
        <inputEntry id="Input_1_1_partial_allocation_validation"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_1_2_partial_allocation_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_1_3_partial_allocation_validation"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_1_1_partial_allocation_validation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2_partial_allocation_validation"><text>"Dados validos para alocacao parcial"</text></outputEntry>
        <outputEntry id="Output_1_3_partial_allocation_validation"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2_partial_allocation_validation">
        <inputEntry id="Input_2_1_partial_allocation_validation"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_2_2_partial_allocation_validation"><text>false</text></inputEntry>
        <inputEntry id="Input_2_3_partial_allocation_validation"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_2_1_partial_allocation_validation"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_2_2_partial_allocation_validation"><text>"Claims nao ordenados por vencimento - pode afetar prioridade"</text></outputEntry>
        <outputEntry id="Output_2_3_partial_allocation_validation"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_3_partial_allocation_validation">
        <inputEntry id="Input_3_1_partial_allocation_validation"><text>&lt;= 0</text></inputEntry>
        <inputEntry id="Input_3_2_partial_allocation_validation"><text></text></inputEntry>
        <inputEntry id="Input_3_3_partial_allocation_validation"><text></text></inputEntry>
        <outputEntry id="Output_3_1_partial_allocation_validation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_3_2_partial_allocation_validation"><text>"Valor de pagamento invalido para alocacao"</text></outputEntry>
        <outputEntry id="Output_3_3_partial_allocation_validation"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_4_partial_allocation_validation">
        <inputEntry id="Input_4_1_partial_allocation_validation"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_4_2_partial_allocation_validation"><text></text></inputEntry>
        <inputEntry id="Input_4_3_partial_allocation_validation"><text>&lt;= 0</text></inputEntry>
        <outputEntry id="Output_4_1_partial_allocation_validation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_4_2_partial_allocation_validation"><text>"Nenhum valor pendente nos claims"</text></outputEntry>
        <outputEntry id="Output_4_3_partial_allocation_validation"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_5_partial_allocation_validation">
        <inputEntry id="Input_5_1_partial_allocation_validation"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_5_2_partial_allocation_validation"><text>true</text></inputEntry>
        <inputEntry id="Input_5_3_partial_allocation_validation"><text>&gt; 0</text></inputEntry>
        <outputEntry id="Output_5_1_partial_allocation_validation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_5_2_partial_allocation_validation"><text>"Iniciar alocacao por antiguidade (oldest first)"</text></outputEntry>
        <outputEntry id="Output_5_3_partial_allocation_validation"><text>"BAIXO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_partial_allocation_validation">
      <dmndi:DMNShape id="DMNShape_Decision_partial_allocation_validation" dmnElementRef="Decision_partial_allocation_validation">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
