<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_archive_reconciliation_validation"
             name="Archive Reconciliation Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: archive_reconciliation_worker.py -->
  <decision id="Decision_archive_reconciliation_validation" name="[SP-RC-012 | collection_reconciliation] Archive Reconciliation Validation" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_archive_reconciliation_validation" hitPolicy="FIRST">
      <input id="Input_status_archive_reconciliation_validation" label="Status Reconciliacao">
        <inputExpression id="InputExpression_status_archive_reconciliation_validation" typeRef="string">
          <text>reconciliation_status</text>
        </inputExpression>
        <inputValues><text>"closed","balanced","unbalanced"</text></inputValues>
      </input>
      <input id="Input_batch_size_archive_reconciliation_validation" label="Tamanho Lote">
        <inputExpression id="InputExpression_batch_size_archive_reconciliation_validation" typeRef="integer">
          <text>batch_size</text>
        </inputExpression>
      </input>
      <input id="Input_has_archived_at_archive_reconciliation_validation" label="Ja Arquivado">
        <inputExpression id="InputExpression_has_archived_at_archive_reconciliation_validation" typeRef="boolean">
          <text>already_archived</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_archive_reconciliation_validation" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_archive_reconciliation_validation" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_archive_reconciliation_validation" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1_archive_reconciliation_validation">
        <inputEntry id="Input_1_1_archive_reconciliation_validation"><text>"closed"</text></inputEntry>
        <inputEntry id="Input_1_2_archive_reconciliation_validation"><text>[1..500]</text></inputEntry>
        <inputEntry id="Input_1_3_archive_reconciliation_validation"><text>false</text></inputEntry>
        <outputEntry id="Output_1_1_archive_reconciliation_validation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2_archive_reconciliation_validation"><text>"Reconciliacao fechada pronta para arquivar"</text></outputEntry>
        <outputEntry id="Output_1_3_archive_reconciliation_validation"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2_archive_reconciliation_validation">
        <inputEntry id="Input_2_1_archive_reconciliation_validation"><text>"unbalanced"</text></inputEntry>
        <inputEntry id="Input_2_2_archive_reconciliation_validation"><text></text></inputEntry>
        <inputEntry id="Input_2_3_archive_reconciliation_validation"><text>false</text></inputEntry>
        <outputEntry id="Output_2_1_archive_reconciliation_validation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_2_2_archive_reconciliation_validation"><text>"Reconciliacao desbalanceada - nao arquivar"</text></outputEntry>
        <outputEntry id="Output_2_3_archive_reconciliation_validation"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_3_archive_reconciliation_validation">
        <inputEntry id="Input_3_1_archive_reconciliation_validation"><text></text></inputEntry>
        <inputEntry id="Input_3_2_archive_reconciliation_validation"><text></text></inputEntry>
        <inputEntry id="Input_3_3_archive_reconciliation_validation"><text>true</text></inputEntry>
        <outputEntry id="Output_3_1_archive_reconciliation_validation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_3_2_archive_reconciliation_validation"><text>"Ja arquivado - ignorar"</text></outputEntry>
        <outputEntry id="Output_3_3_archive_reconciliation_validation"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_4_archive_reconciliation_validation">
        <inputEntry id="Input_4_1_archive_reconciliation_validation"><text>"balanced"</text></inputEntry>
        <inputEntry id="Input_4_2_archive_reconciliation_validation"><text></text></inputEntry>
        <inputEntry id="Input_4_3_archive_reconciliation_validation"><text>false</text></inputEntry>
        <outputEntry id="Output_4_1_archive_reconciliation_validation"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_4_2_archive_reconciliation_validation"><text>"Reconciliacao balanceada mas nao fechada formalmente"</text></outputEntry>
        <outputEntry id="Output_4_3_archive_reconciliation_validation"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_5_archive_reconciliation_validation">
        <inputEntry id="Input_5_1_archive_reconciliation_validation"><text></text></inputEntry>
        <inputEntry id="Input_5_2_archive_reconciliation_validation"><text>&gt; 500</text></inputEntry>
        <inputEntry id="Input_5_3_archive_reconciliation_validation"><text></text></inputEntry>
        <outputEntry id="Output_5_1_archive_reconciliation_validation"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_5_2_archive_reconciliation_validation"><text>"Lote muito grande - reduzir para evitar timeout"</text></outputEntry>
        <outputEntry id="Output_5_3_archive_reconciliation_validation"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_archive_reconciliation_validation">
      <dmndi:DMNShape id="DMNShape_Decision_archive_reconciliation_validation" dmnElementRef="Decision_archive_reconciliation_validation">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
