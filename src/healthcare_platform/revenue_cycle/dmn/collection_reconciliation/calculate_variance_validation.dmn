<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_calculate_variance_validation"
             name="Calculate Variance Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: calculate_variance_worker.py -->
  <decision id="Decision_calculate_variance_validation" name="[SP-RC-012 | collection_reconciliation] Calculate Variance Validation" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_calculate_variance_validation" hitPolicy="FIRST">
      <input id="Input_expected_calculate_variance_validation" label="Valor Esperado">
        <inputExpression id="InputExpression_expected_calculate_variance_validation" typeRef="double">
          <text>expected_amount</text>
        </inputExpression>
      </input>
      <input id="Input_actual_calculate_variance_validation" label="Valor Real">
        <inputExpression id="InputExpression_actual_calculate_variance_validation" typeRef="double">
          <text>actual_amount</text>
        </inputExpression>
      </input>
      <input id="Input_currency_calculate_variance_validation" label="Moeda">
        <inputExpression id="InputExpression_currency_calculate_variance_validation" typeRef="string">
          <text>currency</text>
        </inputExpression>
      </input>
      <output id="Output_resultado_calculate_variance_validation" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_calculate_variance_validation" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_calculate_variance_validation" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>
      <rule id="Rule_1_calculate_variance_validation">
        <inputEntry id="Input_1_1_calculate_variance_validation"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_1_2_calculate_variance_validation"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_1_3_calculate_variance_validation"><text>"BRL"</text></inputEntry>
        <outputEntry id="Output_1_1_calculate_variance_validation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="Output_1_2_calculate_variance_validation"><text>"Dados validos para calculo de variacao"</text></outputEntry>
        <outputEntry id="Output_1_3_calculate_variance_validation"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_2_calculate_variance_validation">
        <inputEntry id="Input_2_1_calculate_variance_validation"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_2_2_calculate_variance_validation"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_2_3_calculate_variance_validation"><text>not("BRL")</text></inputEntry>
        <outputEntry id="Output_2_1_calculate_variance_validation"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="Output_2_2_calculate_variance_validation"><text>"Moeda nao BRL - converter antes de calcular"</text></outputEntry>
        <outputEntry id="Output_2_3_calculate_variance_validation"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_3_calculate_variance_validation">
        <inputEntry id="Input_3_1_calculate_variance_validation"><text>&lt;= 0</text></inputEntry>
        <inputEntry id="Input_3_2_calculate_variance_validation"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_3_3_calculate_variance_validation"><text></text></inputEntry>
        <outputEntry id="Output_3_1_calculate_variance_validation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_3_2_calculate_variance_validation"><text>"Valor esperado invalido - divisao por zero"</text></outputEntry>
        <outputEntry id="Output_3_3_calculate_variance_validation"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_4_calculate_variance_validation">
        <inputEntry id="Input_4_1_calculate_variance_validation"><text>&gt; 0</text></inputEntry>
        <inputEntry id="Input_4_2_calculate_variance_validation"><text>&lt;= 0</text></inputEntry>
        <inputEntry id="Input_4_3_calculate_variance_validation"><text></text></inputEntry>
        <outputEntry id="Output_4_1_calculate_variance_validation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_4_2_calculate_variance_validation"><text>"Valor real zerado ou negativo"</text></outputEntry>
        <outputEntry id="Output_4_3_calculate_variance_validation"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_5_calculate_variance_validation">
        <inputEntry id="Input_5_1_calculate_variance_validation"><text>&lt;= 0</text></inputEntry>
        <inputEntry id="Input_5_2_calculate_variance_validation"><text>&lt;= 0</text></inputEntry>
        <inputEntry id="Input_5_3_calculate_variance_validation"><text></text></inputEntry>
        <outputEntry id="Output_5_1_calculate_variance_validation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="Output_5_2_calculate_variance_validation"><text>"Ambos valores invalidos"</text></outputEntry>
        <outputEntry id="Output_5_3_calculate_variance_validation"><text>"CRITICO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_calculate_variance_validation">
      <dmndi:DMNShape id="DMNShape_Decision_calculate_variance_validation" dmnElementRef="Decision_calculate_variance_validation">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
