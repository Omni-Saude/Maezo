<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DENY-MEDICAL-002 - Falha Tratamento Conservador
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: DENY-MEDICAL
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_DENY_MEDICAL_002" name="Falha Tratamento Conservador" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_DENY_MEDICAL_002" name="[SP-RC-007 | glosa_prevention/medical] Verificar Falha Conservador" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_MEDICAL_002" hitPolicy="FIRST">
      <input id="Input_1_DENY_MEDICAL_002" label="Tem Falha Conservador">
        <inputExpression id="InputExpression_1_DENY_MEDICAL_002" typeRef="boolean"><text>temFalhaConservador</text></inputExpression>
      </input>
      <input id="Input_2_DENY_MEDICAL_002" label="Exige Tratamento Conservador">
        <inputExpression id="InputExpression_2_DENY_MEDICAL_002" typeRef="boolean"><text>exigeTratamentoConservador</text></inputExpression>
      </input>
      <input id="Input_3_DENY_MEDICAL_002" label="Tipo Procedimento">
        <inputExpression id="InputExpression_3_DENY_MEDICAL_002" typeRef="string"><text>tipoProcedimento</text></inputExpression>
      </input>
      <input id="Input_4_DENY_MEDICAL_002" label="Especialidade">
        <inputExpression id="InputExpression_4_DENY_MEDICAL_002" typeRef="string"><text>especialidade</text></inputExpression>
      </input>
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_DENY_MEDICAL_002" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_DENY_MEDICAL_002" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_DENY_MEDICAL_002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_DENY_MEDICAL_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_DENY_MEDICAL_002" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Block_1_DENY_MEDICAL_002">
        <description>Cirurgia de coluna sem comprovacao de falha conservador</description>
        <inputEntry id="InputEntry_B1_1_DENY_MEDICAL_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_DENY_MEDICAL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_DENY_MEDICAL_002"><text>"Cirurgia Coluna"</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_DENY_MEDICAL_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_DENY_MEDICAL_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_DENY_MEDICAL_002"><text>"GLOSA CERTA: Cirurgia de coluna exige comprovacao de falha de tratamento conservador (min 6 semanas fisioterapia)."</text></outputEntry>
        <outputEntry id="_DENY_MEDICAL_002"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_1_4_DENY_MEDICAL_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_DENY_MEDICAL_002"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_Block_2_DENY_MEDICAL_002">
        <inputEntry id="InputEntry_B2_1_DENY_MEDICAL_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_DENY_MEDICAL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_DENY_MEDICAL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_DENY_MEDICAL_002"><text>"Ortopedia"</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_DENY_MEDICAL_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_DENY_MEDICAL_002"><text>"GLOSA PROVAVEL: Procedimento ortopedico exige documentacao de falha de tratamento conservador."</text></outputEntry>
        <outputEntry id="_DENY_MEDICAL_002_2"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_2_4_DENY_MEDICAL_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_DENY_MEDICAL_002"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_Alert_1_DENY_MEDICAL_002">
        <inputEntry id="InputEntry_A1_1_DENY_MEDICAL_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_DENY_MEDICAL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_DENY_MEDICAL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_DENY_MEDICAL_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_DENY_MEDICAL_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_DENY_MEDICAL_002"><text>"RISCO ALTO: Procedimento pode exigir comprovacao de falha conservador."</text></outputEntry>
        <outputEntry id="_DENY_MEDICAL_002_3"><text></text></outputEntry>
<outputEntry id="OutputEntry_Alert_1_4_DENY_MEDICAL_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_DENY_MEDICAL_002"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_Proceed_1_DENY_MEDICAL_002">
        <inputEntry id="InputEntry_P1_1_DENY_MEDICAL_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_DENY_MEDICAL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_DENY_MEDICAL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_DENY_MEDICAL_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_DENY_MEDICAL_002"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_DENY_MEDICAL_002"><text>"Falha de tratamento conservador documentada."</text></outputEntry>
        <outputEntry id="_DENY_MEDICAL_002_4"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_1_4_DENY_MEDICAL_002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_DENY_MEDICAL_002"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_Proceed_2_DENY_MEDICAL_002">
        <inputEntry id="InputEntry_P2_1_DENY_MEDICAL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_DENY_MEDICAL_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_DENY_MEDICAL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_DENY_MEDICAL_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_DENY_MEDICAL_002"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_DENY_MEDICAL_002"><text>"Procedimento nao exige tratamento conservador previo."</text></outputEntry>
        <outputEntry id="_DENY_MEDICAL_002_5"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_2_4_DENY_MEDICAL_002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_DENY_MEDICAL_002"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_Fallback_DENY_MEDICAL_002">
        <inputEntry id="InputEntry_F_1_DENY_MEDICAL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_DENY_MEDICAL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_DENY_MEDICAL_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_DENY_MEDICAL_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_DENY_MEDICAL_002"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_DENY_MEDICAL_002"><text>"Verificar necessidade de tratamento conservador."</text></outputEntry>
        <outputEntry id="_DENY_MEDICAL_002_6"><text></text></outputEntry>
<outputEntry id="OutputEntry_Fallback_4_DENY_MEDICAL_002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_F_3_DENY_MEDICAL_002"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_DENY_MEDICAL_002">
      <dmndi:DMNShape id="DMNShape_Decision_DENY_MEDICAL_002" dmnElementRef="Decision_DENY_MEDICAL_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>