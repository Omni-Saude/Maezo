<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DENY-MEDICAL-004 - Risco Beneficio Documentacao
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: DENY-MEDICAL
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_DENY_MEDICAL_004" name="Risco Beneficio Documentacao" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_DENY_MEDICAL_004" name="[SP-RC-007 | glosa_prevention/medical] Verificar Risco Beneficio" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_MEDICAL_004" hitPolicy="FIRST">
      <input id="Input_1_DENY_MEDICAL_004" label="Tem Analise Risco Beneficio">
        <inputExpression id="InputExpression_1_DENY_MEDICAL_004" typeRef="boolean"><text>temAnaliseRiscoBeneficio</text></inputExpression>
      </input>
      <input id="Input_2_DENY_MEDICAL_004" label="Procedimento Alto Risco">
        <inputExpression id="InputExpression_2_DENY_MEDICAL_004" typeRef="boolean"><text>procedimentoAltoRisco</text></inputExpression>
      </input>
      <input id="Input_3_DENY_MEDICAL_004" label="Idade Paciente">
        <inputExpression id="InputExpression_3_DENY_MEDICAL_004" typeRef="number"><text>idadePaciente</text></inputExpression>
      </input>
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_DENY_MEDICAL_004" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_DENY_MEDICAL_004" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_DENY_MEDICAL_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_DENY_MEDICAL_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_DENY_MEDICAL_004" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Block_1_DENY_MEDICAL_004">
        <description>Procedimento alto risco sem analise risco-beneficio</description>
        <inputEntry id="InputEntry_B1_1_DENY_MEDICAL_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_DENY_MEDICAL_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_DENY_MEDICAL_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_DENY_MEDICAL_004"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_DENY_MEDICAL_004"><text>"GLOSA PROVAVEL: Procedimento de alto risco exige analise de risco-beneficio documentada."</text></outputEntry>
        <outputEntry id="_DENY_MEDICAL_004"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_1_4_DENY_MEDICAL_004"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_DENY_MEDICAL_004"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_Alert_1_DENY_MEDICAL_004">
        <inputEntry id="InputEntry_A1_1_DENY_MEDICAL_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_DENY_MEDICAL_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_DENY_MEDICAL_004"><text>&gt; 80</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_DENY_MEDICAL_004"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_DENY_MEDICAL_004"><text>"RISCO ALTO: Paciente idoso (&gt;80 anos) sem analise de risco-beneficio pode ser questionado."</text></outputEntry>
        <outputEntry id="_DENY_MEDICAL_004_2"><text></text></outputEntry>
<outputEntry id="OutputEntry_Alert_1_4_DENY_MEDICAL_004"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_DENY_MEDICAL_004"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_Proceed_1_DENY_MEDICAL_004">
        <inputEntry id="InputEntry_P1_1_DENY_MEDICAL_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_DENY_MEDICAL_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_DENY_MEDICAL_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_DENY_MEDICAL_004"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_DENY_MEDICAL_004"><text>"Analise de risco-beneficio documentada."</text></outputEntry>
        <outputEntry id="_DENY_MEDICAL_004_3"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_1_4_DENY_MEDICAL_004"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_DENY_MEDICAL_004"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_Fallback_DENY_MEDICAL_004">
        <inputEntry id="InputEntry_F_1_DENY_MEDICAL_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_DENY_MEDICAL_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_DENY_MEDICAL_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_DENY_MEDICAL_004"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_DENY_MEDICAL_004"><text>"Verificar necessidade de analise risco-beneficio."</text></outputEntry>
        <outputEntry id="_DENY_MEDICAL_004_4"><text></text></outputEntry>
<outputEntry id="OutputEntry_Fallback_4_DENY_MEDICAL_004"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_F_3_DENY_MEDICAL_004"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_DENY_MEDICAL_004">
      <dmndi:DMNShape id="DMNShape_Decision_DENY_MEDICAL_004" dmnElementRef="Decision_DENY_MEDICAL_004">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>