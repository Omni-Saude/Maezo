<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DENY-MEDICAL-007 - Urgencia Emergencia Justificativa
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: DENY-MEDICAL
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_DENY_MEDICAL_007" name="Urgencia Emergencia Justificativa" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_DENY_MEDICAL_007" name="[SP-RC-007 | glosa_prevention/medical] Verificar Urgencia Emergencia" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_MEDICAL_007" hitPolicy="FIRST">
      <input id="Input_1_DENY_MEDICAL_007" label="Caracterizado Urgencia/Emergencia">
        <inputExpression id="InputExpression_1_DENY_MEDICAL_007" typeRef="boolean"><text>caracterizadoUrgencia</text></inputExpression>
      </input>
      <input id="Input_2_DENY_MEDICAL_007" label="Tem Justificativa Medica">
        <inputExpression id="InputExpression_2_DENY_MEDICAL_007" typeRef="boolean"><text>temJustificativaMedica</text></inputExpression>
      </input>
      <input id="Input_3_DENY_MEDICAL_007" label="Tipo Atendimento">
        <inputExpression id="InputExpression_3_DENY_MEDICAL_007" typeRef="string"><text>tipoAtendimento</text></inputExpression>
      </input>
      <input id="Input_4_DENY_MEDICAL_007" label="CID Compativel">
        <inputExpression id="InputExpression_4_DENY_MEDICAL_007" typeRef="boolean"><text>cidCompativel</text></inputExpression>
      </input>
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_DENY_MEDICAL_007" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_DENY_MEDICAL_007" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_DENY_MEDICAL_007" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_DENY_MEDICAL_007" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_DENY_MEDICAL_007" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Block_1_DENY_MEDICAL_007">
        <description>Urgencia sem caracterizacao adequada</description>
        <inputEntry id="InputEntry_B1_1_DENY_MEDICAL_007"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_DENY_MEDICAL_007"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_DENY_MEDICAL_007"><text>"Urgencia", "Emergencia"</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_DENY_MEDICAL_007"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_DENY_MEDICAL_007"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_DENY_MEDICAL_007"><text>"GLOSA PROVAVEL: Urgencia/Emergencia nao caracterizada adequadamente. Pode ser contestado."</text></outputEntry>
        <outputEntry id="_DENY_MEDICAL_007"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_1_4_DENY_MEDICAL_007"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_DENY_MEDICAL_007"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_Alert_1_DENY_MEDICAL_007">
        <inputEntry id="InputEntry_A1_1_DENY_MEDICAL_007"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_DENY_MEDICAL_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_DENY_MEDICAL_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_DENY_MEDICAL_007"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_DENY_MEDICAL_007"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_DENY_MEDICAL_007"><text>"RISCO MEDIO: CID pode nao ser compativel com urgencia/emergencia."</text></outputEntry>
        <outputEntry id="_DENY_MEDICAL_007_2"><text></text></outputEntry>
<outputEntry id="OutputEntry_Alert_1_4_DENY_MEDICAL_007"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_DENY_MEDICAL_007"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_Proceed_1_DENY_MEDICAL_007">
        <inputEntry id="InputEntry_P1_1_DENY_MEDICAL_007"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_DENY_MEDICAL_007"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_DENY_MEDICAL_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_DENY_MEDICAL_007"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_DENY_MEDICAL_007"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_DENY_MEDICAL_007"><text>"Urgencia/Emergencia caracterizada adequadamente. CID compativel."</text></outputEntry>
        <outputEntry id="_DENY_MEDICAL_007_3"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_1_4_DENY_MEDICAL_007"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_DENY_MEDICAL_007"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_Proceed_2_DENY_MEDICAL_007">
        <inputEntry id="InputEntry_P2_1_DENY_MEDICAL_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_DENY_MEDICAL_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_DENY_MEDICAL_007"><text>"Eletivo"</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_DENY_MEDICAL_007"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_DENY_MEDICAL_007"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_DENY_MEDICAL_007"><text>"Atendimento eletivo. Nao exige caracterizacao de urgencia."</text></outputEntry>
        <outputEntry id="_DENY_MEDICAL_007_4"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_2_4_DENY_MEDICAL_007"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_DENY_MEDICAL_007"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_Fallback_DENY_MEDICAL_007">
        <inputEntry id="InputEntry_F_1_DENY_MEDICAL_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_DENY_MEDICAL_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_DENY_MEDICAL_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_DENY_MEDICAL_007"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_DENY_MEDICAL_007"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_DENY_MEDICAL_007"><text>"Verificar caracterizacao de urgencia/emergencia."</text></outputEntry>
        <outputEntry id="_DENY_MEDICAL_007_5"><text></text></outputEntry>
<outputEntry id="OutputEntry_Fallback_4_DENY_MEDICAL_007"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_F_3_DENY_MEDICAL_007"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_DENY_MEDICAL_007">
      <dmndi:DMNShape id="DMNShape_Decision_DENY_MEDICAL_007" dmnElementRef="Decision_DENY_MEDICAL_007">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>