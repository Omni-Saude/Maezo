<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DENY-MEDICAL-005 - Alternativa Tratamento Justificativa
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: DENY-MEDICAL
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_DENY_MEDICAL_005" name="Alternativa Tratamento Justificativa" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_DENY_MEDICAL_005" name="[SP-RC-007 | glosa_prevention/medical] Verificar Alternativa Tratamento" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_MEDICAL_005" hitPolicy="FIRST">
      <input id="Input_1_DENY_MEDICAL_005" label="Tem Justificativa Alternativa">
        <inputExpression id="InputExpression_1_DENY_MEDICAL_005" typeRef="boolean"><text>temJustificativaAlternativa</text></inputExpression>
      </input>
      <input id="Input_2_DENY_MEDICAL_005" label="Tratamento Nao Padrao">
        <inputExpression id="InputExpression_2_DENY_MEDICAL_005" typeRef="boolean"><text>tratamentoNaoPadrao</text></inputExpression>
      </input>
      <input id="Input_3_DENY_MEDICAL_005" label="Custo Acima Media">
        <inputExpression id="InputExpression_3_DENY_MEDICAL_005" typeRef="boolean"><text>custoAcimaMedia</text></inputExpression>
      </input>
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_DENY_MEDICAL_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_DENY_MEDICAL_005" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_DENY_MEDICAL_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_DENY_MEDICAL_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_DENY_MEDICAL_005" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Block_1_DENY_MEDICAL_005">
        <description>Tratamento nao padrao sem justificativa</description>
        <inputEntry id="InputEntry_B1_1_DENY_MEDICAL_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_DENY_MEDICAL_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_DENY_MEDICAL_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_DENY_MEDICAL_005"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_DENY_MEDICAL_005"><text>"GLOSA CERTA: Tratamento nao padrao exige justificativa para escolha da alternativa."</text></outputEntry>
        <outputEntry id="_DENY_MEDICAL_005"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_1_4_DENY_MEDICAL_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_DENY_MEDICAL_005"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_Alert_1_DENY_MEDICAL_005">
        <inputEntry id="InputEntry_A1_1_DENY_MEDICAL_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_DENY_MEDICAL_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_DENY_MEDICAL_005"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_DENY_MEDICAL_005"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_DENY_MEDICAL_005"><text>"RISCO ALTO: Custo acima da media sem justificativa de escolha."</text></outputEntry>
        <outputEntry id="_DENY_MEDICAL_005_2"><text></text></outputEntry>
<outputEntry id="OutputEntry_Alert_1_4_DENY_MEDICAL_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_DENY_MEDICAL_005"><text>"ALTO"</text></outputEntry>
      </rule>
      <rule id="Rule_Proceed_1_DENY_MEDICAL_005">
        <inputEntry id="InputEntry_P1_1_DENY_MEDICAL_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_DENY_MEDICAL_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_DENY_MEDICAL_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_DENY_MEDICAL_005"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_DENY_MEDICAL_005"><text>"Justificativa para alternativa de tratamento presente."</text></outputEntry>
        <outputEntry id="_DENY_MEDICAL_005_3"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_1_4_DENY_MEDICAL_005"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_DENY_MEDICAL_005"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_Proceed_2_DENY_MEDICAL_005">
        <inputEntry id="InputEntry_P2_1_DENY_MEDICAL_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_DENY_MEDICAL_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_DENY_MEDICAL_005"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_DENY_MEDICAL_005"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_DENY_MEDICAL_005"><text>"Tratamento padrao. Nao exige justificativa adicional."</text></outputEntry>
        <outputEntry id="_DENY_MEDICAL_005_4"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_2_4_DENY_MEDICAL_005"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_DENY_MEDICAL_005"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_Fallback_DENY_MEDICAL_005">
        <inputEntry id="InputEntry_F_1_DENY_MEDICAL_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_DENY_MEDICAL_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_DENY_MEDICAL_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_DENY_MEDICAL_005"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_DENY_MEDICAL_005"><text>"Verificar necessidade de justificativa."</text></outputEntry>
        <outputEntry id="_DENY_MEDICAL_005_5"><text></text></outputEntry>
<outputEntry id="OutputEntry_Fallback_4_DENY_MEDICAL_005"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_F_3_DENY_MEDICAL_005"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_DENY_MEDICAL_005">
      <dmndi:DMNShape id="DMNShape_Decision_DENY_MEDICAL_005" dmnElementRef="Decision_DENY_MEDICAL_005">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>