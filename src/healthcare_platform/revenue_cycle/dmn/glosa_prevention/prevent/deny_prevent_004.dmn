<?xml version="1.0" encoding="UTF-8"?>
<!--
  DENY-PREVENT-004 - Evolucao Medica Diaria Completa
  Versao: 1.0.0 (2026-02-08) | Categoria: DENY-PREVENT | Perspectiva: HOSPITAL (Auditoria Administrativa)
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_DENY_PREVENT_004" name="Evolucao Medica Diaria Completa" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_DENY_PREVENT_004" name="[SP-RC-007 | glosa_prevention/prevent] Evolucao Medica Diaria Completa" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_PREVENT_004" hitPolicy="FIRST">
      <input id="Input_1_DENY_PREVENT_004" label="Evolucao Diaria"><inputExpression id="InputExpression_1_DENY_PREVENT_004" typeRef="boolean"><text>evolucaoDiaria</text></inputExpression></input>
      
      <output id="Output_1_DENY_PREVENT_004" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues></output>
      <output id="Output_2_DENY_PREVENT_004" label="Observacao" name="observacao" typeRef="string"/>
      <output id="Output_3_DENY_PREVENT_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>
      <output id="Output_4_DENY_PREVENT_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output>
      <output id="Output_5_DENY_PREVENT_004" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output>
      <rule id="Rule_1_DENY_PREVENT_004"><description>Sem evolucao - bloqueio</description><inputEntry id="InputEntry_1_1_DENY_PREVENT_004"><text>false</text></inputEntry><outputEntry id="OutputEntry_1_1_DENY_PREVENT_004"><text>"Bloquear"</text></outputEntry><outputEntry id="OutputEntry_1_2_DENY_PREVENT_004"><text>"RISCO ALTO: Ausencia de evolucao medica diaria. Exigencia CFM 1.821/2007 para internacoes."</text></outputEntry><outputEntry id="OutputEntry_1_3_DENY_PREVENT_004"><text>"Solicitar evolucoes medicas diarias ao corpo clinico."</text></outputEntry><outputEntry id="OutputEntry_1_4_DENY_PREVENT_004"><text>"DOC"</text></outputEntry><outputEntry id="OutputEntry_1_5_DENY_PREVENT_004"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_2_DENY_PREVENT_004"><description>Com evolucao - prosseguir</description><inputEntry id="InputEntry_2_1_DENY_PREVENT_004"><text>true</text></inputEntry><outputEntry id="OutputEntry_2_1_DENY_PREVENT_004"><text>"Prosseguir"</text></outputEntry><outputEntry id="OutputEntry_2_2_DENY_PREVENT_004"><text>"Evolucoes medicas diarias presentes. Conformidade CFM."</text></outputEntry><outputEntry id="OutputEntry_2_3_DENY_PREVENT_004"><text>"Prosseguir com faturamento padrao."</text></outputEntry><outputEntry id="OutputEntry_2_4_DENY_PREVENT_004"><text>"NENHUM"</text></outputEntry><outputEntry id="OutputEntry_2_5_DENY_PREVENT_004"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_3_DENY_PREVENT_004"><description>Fallback</description><inputEntry id="InputEntry_3_1_DENY_PREVENT_004"><text>-</text></inputEntry><outputEntry id="OutputEntry_3_1_DENY_PREVENT_004"><text>"Revisar"</text></outputEntry><outputEntry id="OutputEntry_3_2_DENY_PREVENT_004"><text>"Situacao requer analise manual."</text></outputEntry><outputEntry id="OutputEntry_3_3_DENY_PREVENT_004"><text>"Encaminhar para auditoria."</text></outputEntry><outputEntry id="OutputEntry_3_4_DENY_PREVENT_004"><text>"NENHUM"</text></outputEntry><outputEntry id="OutputEntry_3_5_DENY_PREVENT_004"><text>"MEDIO"</text></outputEntry></rule>
      
    </decisionTable>
  </decision>
  <dmndi:DMNDI><dmndi:DMNDiagram id="DMNDiagram_DENY_PREVENT_004"><dmndi:DMNShape id="DMNShape_DENY_PREVENT_004" dmnElementRef="Decision_DENY_PREVENT_004"><dc:Bounds height="80" width="180" x="160" y="100"/></dmndi:DMNShape></dmndi:DMNDiagram></dmndi:DMNDI>
</definitions>
