<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_glosa_identify_adjudication"
             name="Glosa Identification Adjudication"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Glosa Identification Adjudication
       For: identify_glosa_worker
       Archetype: ADMIN_ADJUDICATION
       Purpose: Identify glosa type from payer response text
  -->

  <decision id="Decision_glosa_identify_adjudication" name="[SP-RC-007 | glosa_prevention/identification] Glosa Identification Adjudication" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_glosa_identify_adjudication" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_1_glosa_identify_adjudication" label="Reason Text">
        <inputExpression id="InputExpr_1_glosa_identify_adjudication" typeRef="string">
          <text>reasonText</text>
        </inputExpression>
      </input>

      <input id="Input_2_glosa_identify_adjudication" label="Adjudication Category">
        <inputExpression id="InputExpr_2_glosa_identify_adjudication" typeRef="string">
          <text>adjudicationCategory</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado_glosa_identify_adjudication" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_glosa_identify_adjudication" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_glosa_identify_adjudication" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Autorização expirada -->
      <rule id="Rule_1_glosa_identify_adjudication">
        <description>EXPIRED_AUTH identificada</description>
        <inputEntry id="IE_1_1_glosa_identify_adjudication"><text>contains(lower(reasonText), "autorização") and contains(lower(reasonText), "expirada")</text></inputEntry>
        <inputEntry id="IE_1_2_glosa_identify_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_1_res_glosa_identify_adjudication"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_acao_glosa_identify_adjudication"><text>"EXPIRED_AUTH identificada"</text></outputEntry>
        <outputEntry id="OE_1_risco_glosa_identify_adjudication"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Autorização/guia ausente -->
      <rule id="Rule_2_glosa_identify_adjudication">
        <description>MISSING_AUTH identificada</description>
        <inputEntry id="IE_2_1_glosa_identify_adjudication"><text>contains(lower(reasonText), "autorização") or contains(lower(reasonText), "guia")</text></inputEntry>
        <inputEntry id="IE_2_2_glosa_identify_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_2_res_glosa_identify_adjudication"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_2_acao_glosa_identify_adjudication"><text>"MISSING_AUTH identificada"</text></outputEntry>
        <outputEntry id="OE_2_risco_glosa_identify_adjudication"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Duplicidade -->
      <rule id="Rule_3_glosa_identify_adjudication">
        <description>DUPLICATE_CHARGE identificada</description>
        <inputEntry id="IE_3_1_glosa_identify_adjudication"><text>contains(lower(reasonText), "duplicad")</text></inputEntry>
        <inputEntry id="IE_3_2_glosa_identify_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_3_res_glosa_identify_adjudication"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_3_acao_glosa_identify_adjudication"><text>"DUPLICATE_CHARGE identificada"</text></outputEntry>
        <outputEntry id="OE_3_risco_glosa_identify_adjudication"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Não coberto -->
      <rule id="Rule_4_glosa_identify_adjudication">
        <description>NOT_COVERED identificada</description>
        <inputEntry id="IE_4_1_glosa_identify_adjudication"><text>contains(lower(reasonText), "não coberto")</text></inputEntry>
        <inputEntry id="IE_4_2_glosa_identify_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_4_res_glosa_identify_adjudication"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_4_acao_glosa_identify_adjudication"><text>"NOT_COVERED identificada"</text></outputEntry>
        <outputEntry id="OE_4_risco_glosa_identify_adjudication"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Quantidade excedida -->
      <rule id="Rule_5_glosa_identify_adjudication">
        <description>EXCEEDS_QUANTITY identificada</description>
        <inputEntry id="IE_5_1_glosa_identify_adjudication"><text>contains(lower(reasonText), "quantidade") or contains(lower(reasonText), "excede")</text></inputEntry>
        <inputEntry id="IE_5_2_glosa_identify_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_5_res_glosa_identify_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_5_acao_glosa_identify_adjudication"><text>"EXCEEDS_QUANTITY identificada"</text></outputEntry>
        <outputEntry id="OE_5_risco_glosa_identify_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 6: Código incorreto -->
      <rule id="Rule_6_glosa_identify_adjudication">
        <description>WRONG_CODE identificada</description>
        <inputEntry id="IE_6_1_glosa_identify_adjudication"><text>contains(lower(reasonText), "código") and contains(lower(reasonText), "incorreto")</text></inputEntry>
        <inputEntry id="IE_6_2_glosa_identify_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_6_res_glosa_identify_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_6_acao_glosa_identify_adjudication"><text>"WRONG_CODE identificada"</text></outputEntry>
        <outputEntry id="OE_6_risco_glosa_identify_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 7: Documentação incompleta -->
      <rule id="Rule_7_glosa_identify_adjudication">
        <description>MISSING_DOCUMENTATION identificada</description>
        <inputEntry id="IE_7_1_glosa_identify_adjudication"><text>contains(lower(reasonText), "documentação")</text></inputEntry>
        <inputEntry id="IE_7_2_glosa_identify_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_7_res_glosa_identify_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_7_acao_glosa_identify_adjudication"><text>"MISSING_DOCUMENTATION identificada"</text></outputEntry>
        <outputEntry id="OE_7_risco_glosa_identify_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 8: Procedimento incompatível -->
      <rule id="Rule_8_glosa_identify_adjudication">
        <description>INCOMPATIBLE_PROCEDURE identificada</description>
        <inputEntry id="IE_8_1_glosa_identify_adjudication"><text>contains(lower(reasonText), "incompatível")</text></inputEntry>
        <inputEntry id="IE_8_2_glosa_identify_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_8_res_glosa_identify_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_8_acao_glosa_identify_adjudication"><text>"INCOMPATIBLE_PROCEDURE identificada"</text></outputEntry>
        <outputEntry id="OE_8_risco_glosa_identify_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 9: Divergência de preço -->
      <rule id="Rule_9_glosa_identify_adjudication">
        <description>PRICE_DIVERGENCE identificada</description>
        <inputEntry id="IE_9_1_glosa_identify_adjudication"><text>contains(lower(reasonText), "valor") or contains(lower(reasonText), "preço")</text></inputEntry>
        <inputEntry id="IE_9_2_glosa_identify_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_9_res_glosa_identify_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_9_acao_glosa_identify_adjudication"><text>"PRICE_DIVERGENCE identificada"</text></outputEntry>
        <outputEntry id="OE_9_risco_glosa_identify_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="Rule_fallback_glosa_identify_adjudication">
        <description>Caso não enquadrado — revisão obrigatória</description>
        <inputEntry id="IE_fb_1_glosa_identify_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2_glosa_identify_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res_glosa_identify_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao_glosa_identify_adjudication"><text>"TISS_VALIDATION - avaliar manualmente"</text></outputEntry>
        <outputEntry id="OE_fb_risco_glosa_identify_adjudication"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1_glosa_identify_adjudication">
      <dmndi:DMNShape id="DMNShape_Decision_glosa_identify_adjudication" dmnElementRef="Decision_glosa_identify_adjudication">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
