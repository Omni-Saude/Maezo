<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_glosa_type_adjudication"
             name="Glosa Type Adjudication"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Glosa Type Classification Adjudication
       For: classify_glosa_type_worker
       Archetype: ADMIN_ADJUDICATION
       Purpose: Classify glosa as TOTAL, PARTIAL, LINEAR based on reason and denial ratio
  -->

  <decision id="Decision_glosa_type_adjudication" name="[SP-RC-007 | glosa_prevention/classification] Glosa Type Adjudication" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_glosa_type_adjudication" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_1_glosa_type_adjudication" label="Reason Code">
        <inputExpression id="InputExpr_1_glosa_type_adjudication" typeRef="string">
          <text>reasonCode</text>
        </inputExpression>
      </input>

      <input id="Input_2_glosa_type_adjudication" label="Denial Ratio">
        <inputExpression id="InputExpr_2_glosa_type_adjudication" typeRef="number">
          <text>denialRatio</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado_glosa_type_adjudication" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_glosa_type_adjudication" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_glosa_type_adjudication" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Price divergence - LINEAR -->
      <rule id="Rule_1_glosa_type_adjudication">
        <description>Classificar como LINEAR</description>
        <inputEntry id="IE_1_1_glosa_type_adjudication"><text>"PRICE_DIVERGENCE"</text></inputEntry>
        <inputEntry id="IE_1_2_glosa_type_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_1_res_glosa_type_adjudication"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_1_acao_glosa_type_adjudication"><text>"Classificar como LINEAR"</text></outputEntry>
        <outputEntry id="OE_1_risco_glosa_type_adjudication"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Administrative total (ratio >= 1.0) -->
      <rule id="Rule_2_glosa_type_adjudication">
        <description>ADMINISTRATIVE TOTAL</description>
        <inputEntry id="IE_2_1_glosa_type_adjudication"><text>"MISSING_AUTH","EXPIRED_AUTH","DUPLICATE_CHARGE"</text></inputEntry>
        <inputEntry id="IE_2_2_glosa_type_adjudication"><text>&gt;= 1.0</text></inputEntry>
        <outputEntry id="OE_2_res_glosa_type_adjudication"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_2_acao_glosa_type_adjudication"><text>"ADMINISTRATIVE TOTAL"</text></outputEntry>
        <outputEntry id="OE_2_risco_glosa_type_adjudication"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Administrative partial (ratio < 1.0) -->
      <rule id="Rule_3_glosa_type_adjudication">
        <description>ADMINISTRATIVE PARTIAL</description>
        <inputEntry id="IE_3_1_glosa_type_adjudication"><text>"MISSING_AUTH","EXPIRED_AUTH","DUPLICATE_CHARGE"</text></inputEntry>
        <inputEntry id="IE_3_2_glosa_type_adjudication"><text>&lt; 1.0</text></inputEntry>
        <outputEntry id="OE_3_res_glosa_type_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_3_acao_glosa_type_adjudication"><text>"ADMINISTRATIVE PARTIAL"</text></outputEntry>
        <outputEntry id="OE_3_risco_glosa_type_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Technical total (ratio >= 1.0) -->
      <rule id="Rule_4_glosa_type_adjudication">
        <description>TECHNICAL TOTAL</description>
        <inputEntry id="IE_4_1_glosa_type_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_4_2_glosa_type_adjudication"><text>&gt;= 1.0</text></inputEntry>
        <outputEntry id="OE_4_res_glosa_type_adjudication"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_4_acao_glosa_type_adjudication"><text>"TECHNICAL TOTAL"</text></outputEntry>
        <outputEntry id="OE_4_risco_glosa_type_adjudication"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Technical partial (ratio < 1.0) -->
      <rule id="Rule_5_glosa_type_adjudication">
        <description>TECHNICAL PARTIAL</description>
        <inputEntry id="IE_5_1_glosa_type_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_5_2_glosa_type_adjudication"><text>&lt; 1.0</text></inputEntry>
        <outputEntry id="OE_5_res_glosa_type_adjudication"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_acao_glosa_type_adjudication"><text>"TECHNICAL PARTIAL"</text></outputEntry>
        <outputEntry id="OE_5_risco_glosa_type_adjudication"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="Rule_fallback_glosa_type_adjudication">
        <description>Caso não enquadrado — revisão obrigatória</description>
        <inputEntry id="IE_fb_1_glosa_type_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2_glosa_type_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res_glosa_type_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao_glosa_type_adjudication"><text>"Classificação requer avaliação"</text></outputEntry>
        <outputEntry id="OE_fb_risco_glosa_type_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1_glosa_type_adjudication">
      <dmndi:DMNShape id="DMNShape_Decision_glosa_type_adjudication" dmnElementRef="Decision_glosa_type_adjudication">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
