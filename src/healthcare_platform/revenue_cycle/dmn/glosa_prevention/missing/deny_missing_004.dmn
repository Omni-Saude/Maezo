<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DENY-MISSING-004 - Dados Paciente Incompletos
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: DENY-MISSING
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_DENY_MISSING_004" name="Dados Paciente Incompletos" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DENY_MISSING_004" name="[SP-RC-007 | glosa_prevention/missing] Verificar Dados Paciente" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_MISSING_004" hitPolicy="FIRST">

      <input id="Input_1_DENY_MISSING_004" label="Dados Paciente Completos">
        <inputExpression id="InputExpression_1_DENY_MISSING_004" typeRef="boolean">
          <text>dadosPacienteCompletos</text>
        </inputExpression>
      </input>

      <input id="Input_2_DENY_MISSING_004" label="Tem Carteirinha">
        <inputExpression id="InputExpression_2_DENY_MISSING_004" typeRef="boolean">
          <text>temCarteirinha</text>
        </inputExpression>
      </input>

      <input id="Input_3_DENY_MISSING_004" label="Carteirinha Valida">
        <inputExpression id="InputExpression_3_DENY_MISSING_004" typeRef="boolean">
          <text>carteirinhaValida</text>
        </inputExpression>
      </input>

      <input id="Input_4_DENY_MISSING_004" label="Tem CPF">
        <inputExpression id="InputExpression_4_DENY_MISSING_004" typeRef="boolean">
          <text>temCPF</text>
        </inputExpression>
      </input>

      
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_DENY_MISSING_004" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_DENY_MISSING_004" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_DENY_MISSING_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_DENY_MISSING_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_DENY_MISSING_004" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Block_1_DENY_MISSING_004">
        <description>Numero de carteirinha do convenio faltante</description>
        <inputEntry id="InputEntry_B1_1_DENY_MISSING_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_DENY_MISSING_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_DENY_MISSING_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_DENY_MISSING_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_DENY_MISSING_004"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_DENY_MISSING_004"><text>"GLOSA CERTA: Numero da carteirinha do convenio nao informado. Campo obrigatorio para faturamento."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_004"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_1_4_DENY_MISSING_004"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_DENY_MISSING_004"><text>"CRITICO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Block_2_DENY_MISSING_004">
        <description>Carteirinha vencida ou cancelada</description>
        <inputEntry id="InputEntry_B2_1_DENY_MISSING_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_DENY_MISSING_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_DENY_MISSING_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_DENY_MISSING_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_DENY_MISSING_004"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_DENY_MISSING_004"><text>"GLOSA CERTA: Carteirinha vencida ou cancelada. Verificar elegibilidade do beneficiario."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_004_2"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_2_4_DENY_MISSING_004"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_DENY_MISSING_004"><text>"CRITICO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alert_1_DENY_MISSING_004">
        <description>Dados cadastrais do paciente incompletos</description>
        <inputEntry id="InputEntry_A1_1_DENY_MISSING_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_DENY_MISSING_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_DENY_MISSING_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_DENY_MISSING_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_DENY_MISSING_004"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_DENY_MISSING_004"><text>"RISCO MEDIO: Dados cadastrais incompletos podem causar rejeicao. Completar antes do envio."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_004_3"><text></text></outputEntry>
<outputEntry id="OutputEntry_Alert_1_4_DENY_MISSING_004"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_DENY_MISSING_004"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_1_DENY_MISSING_004">
        <description>Todos os dados do paciente presentes e validos</description>
        <inputEntry id="InputEntry_P1_1_DENY_MISSING_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_DENY_MISSING_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_DENY_MISSING_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_DENY_MISSING_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_DENY_MISSING_004"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_DENY_MISSING_004"><text>"Dados do paciente completos e validos. Elegibilidade confirmada."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_004_4"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_1_4_DENY_MISSING_004"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_DENY_MISSING_004"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_DENY_MISSING_004">
        <description>Caso padrao - verificar dados</description>
        <inputEntry id="InputEntry_F_1_DENY_MISSING_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_DENY_MISSING_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_DENY_MISSING_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_DENY_MISSING_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_DENY_MISSING_004"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_DENY_MISSING_004"><text>"Verificar completude dos dados do paciente."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_004_5"><text></text></outputEntry>
<outputEntry id="OutputEntry_Fallback_DENY_MISSING_004_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_F_3_DENY_MISSING_004"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DENY_MISSING_004">
      <dmndi:DMNShape id="DMNShape_Decision_DENY_MISSING_004" dmnElementRef="Decision_DENY_MISSING_004">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>