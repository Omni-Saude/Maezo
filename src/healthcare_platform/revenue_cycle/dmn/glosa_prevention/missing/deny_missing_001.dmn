<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DENY-MISSING-001 - Numero Autorizacao Faltante
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: DENY-MISSING
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_DENY_MISSING_001" name="Numero Autorizacao Faltante" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DENY_MISSING_001" name="[SP-RC-007 | glosa_prevention/missing] Verificar Numero Autorizacao" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_MISSING_001" hitPolicy="FIRST">

      <input id="Input_1_DENY_MISSING_001" label="Tem Numero Autorizacao">
        <inputExpression id="InputExpression_1_DENY_MISSING_001" typeRef="boolean">
          <text>temNumeroAutorizacao</text>
        </inputExpression>
      </input>

      <input id="Input_2_DENY_MISSING_001" label="Exige Pre-Autorizacao">
        <inputExpression id="InputExpression_2_DENY_MISSING_001" typeRef="boolean">
          <text>exigePreAutorizacao</text>
        </inputExpression>
      </input>

      <input id="Input_3_DENY_MISSING_001" label="Tipo Atendimento">
        <inputExpression id="InputExpression_3_DENY_MISSING_001" typeRef="string">
          <text>tipoAtendimento</text>
        </inputExpression>
      </input>

      <input id="Input_4_DENY_MISSING_001" label="Operadora">
        <inputExpression id="InputExpression_4_DENY_MISSING_001" typeRef="string">
          <text>operadora</text>
        </inputExpression>
      </input>

      
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_DENY_MISSING_001" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_DENY_MISSING_001" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_DENY_MISSING_001" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_DENY_MISSING_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_DENY_MISSING_001" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Block_1_DENY_MISSING_001">
        <description>Procedimento eletivo exige autorizacao mas nao tem</description>
        <inputEntry id="InputEntry_B1_1_DENY_MISSING_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_DENY_MISSING_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_DENY_MISSING_001"><text>"Eletivo"</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_DENY_MISSING_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_DENY_MISSING_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_DENY_MISSING_001"><text>"GLOSA CERTA: Procedimento eletivo exige numero de autorizacao previa. Nao faturar sem autorizacao."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_001"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_1_4_DENY_MISSING_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_DENY_MISSING_001"><text>"CRITICO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alert_1_DENY_MISSING_001">
        <description>Internacao sem numero de autorizacao</description>
        <inputEntry id="InputEntry_A1_1_DENY_MISSING_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_DENY_MISSING_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_DENY_MISSING_001"><text>"Internacao"</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_DENY_MISSING_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_DENY_MISSING_001"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_DENY_MISSING_001"><text>"RISCO ALTO: Internacao sem numero de autorizacao. Verificar com operadora prazo para regularizacao."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_001_2"><text></text></outputEntry>
<outputEntry id="OutputEntry_Alert_1_4_DENY_MISSING_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_DENY_MISSING_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_1_DENY_MISSING_001">
        <description>Emergencia com autorizacao posterior permitida</description>
        <inputEntry id="InputEntry_P1_1_DENY_MISSING_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_DENY_MISSING_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_DENY_MISSING_001"><text>"Emergencia", "Urgencia"</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_DENY_MISSING_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_DENY_MISSING_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_DENY_MISSING_001"><text>"Atendimento de emergencia/urgencia. Autorizacao posterior permitida conforme RN 395."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_001_3"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_1_4_DENY_MISSING_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_DENY_MISSING_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_2_DENY_MISSING_001">
        <description>Numero de autorizacao presente</description>
        <inputEntry id="InputEntry_P2_1_DENY_MISSING_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_DENY_MISSING_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_DENY_MISSING_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_DENY_MISSING_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_DENY_MISSING_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_DENY_MISSING_001"><text>"Numero de autorizacao presente. Documentacao adequada."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_001_4"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_2_4_DENY_MISSING_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_DENY_MISSING_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_3_DENY_MISSING_001">
        <description>Procedimento nao exige autorizacao</description>
        <inputEntry id="InputEntry_P3_1_DENY_MISSING_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P3_2_DENY_MISSING_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P3_3_DENY_MISSING_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P3_4_DENY_MISSING_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P3_1_DENY_MISSING_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P3_2_DENY_MISSING_001"><text>"Procedimento nao exige autorizacao previa. Pode ser faturado diretamente."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_001_5"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_3_4_DENY_MISSING_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P3_3_DENY_MISSING_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_DENY_MISSING_001">
        <description>Caso padrao - verificar necessidade de autorizacao</description>
        <inputEntry id="InputEntry_F_1_DENY_MISSING_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_DENY_MISSING_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_DENY_MISSING_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_DENY_MISSING_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_DENY_MISSING_001"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_DENY_MISSING_001"><text>"Verificar manualmente se procedimento exige autorizacao previa."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_001_6"><text></text></outputEntry>
<outputEntry id="OutputEntry_Fallback_DENY_MISSING_001_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_F_3_DENY_MISSING_001"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DENY_MISSING_001">
      <dmndi:DMNShape id="DMNShape_Decision_DENY_MISSING_001" dmnElementRef="Decision_DENY_MISSING_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>