<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DENY-MISSING-005 - Dados Prestador Incompletos
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: DENY-MISSING
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_DENY_MISSING_005" name="Dados Prestador Incompletos" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DENY_MISSING_005" name="[SP-RC-007 | glosa_prevention/missing] Verificar Dados Prestador" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_MISSING_005" hitPolicy="FIRST">

      <input id="Input_1_DENY_MISSING_005" label="Dados Prestador Completos">
        <inputExpression id="InputExpression_1_DENY_MISSING_005" typeRef="boolean">
          <text>dadosPrestadorCompletos</text>
        </inputExpression>
      </input>

      <input id="Input_2_DENY_MISSING_005" label="Tem CRM/CRO">
        <inputExpression id="InputExpression_2_DENY_MISSING_005" typeRef="boolean">
          <text>temCRM</text>
        </inputExpression>
      </input>

      <input id="Input_3_DENY_MISSING_005" label="Tem CNES">
        <inputExpression id="InputExpression_3_DENY_MISSING_005" typeRef="boolean">
          <text>temCNES</text>
        </inputExpression>
      </input>

      <input id="Input_4_DENY_MISSING_005" label="Prestador Credenciado">
        <inputExpression id="InputExpression_4_DENY_MISSING_005" typeRef="boolean">
          <text>prestadorCredenciado</text>
        </inputExpression>
      </input>

      
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_DENY_MISSING_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_DENY_MISSING_005" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_DENY_MISSING_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_DENY_MISSING_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_DENY_MISSING_005" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Block_1_DENY_MISSING_005">
        <description>CRM/CRO do medico executante nao informado</description>
        <inputEntry id="InputEntry_B1_1_DENY_MISSING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_DENY_MISSING_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_DENY_MISSING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_DENY_MISSING_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_DENY_MISSING_005"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_DENY_MISSING_005"><text>"GLOSA CERTA: CRM/CRO do medico executante nao informado. Campo obrigatorio."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_005"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_1_4_DENY_MISSING_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_DENY_MISSING_005"><text>"CRITICO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Block_2_DENY_MISSING_005">
        <description>CNES do estabelecimento nao informado</description>
        <inputEntry id="InputEntry_B2_1_DENY_MISSING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_DENY_MISSING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_DENY_MISSING_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_DENY_MISSING_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_DENY_MISSING_005"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_DENY_MISSING_005"><text>"GLOSA CERTA: CNES do estabelecimento nao informado. Obrigatorio para faturamento."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_005_2"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_2_4_DENY_MISSING_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_DENY_MISSING_005"><text>"CRITICO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Block_3_DENY_MISSING_005">
        <description>Prestador nao credenciado na operadora</description>
        <inputEntry id="InputEntry_B3_1_DENY_MISSING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_DENY_MISSING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_DENY_MISSING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_4_DENY_MISSING_005"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_B3_1_DENY_MISSING_005"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B3_2_DENY_MISSING_005"><text>"GLOSA CERTA: Prestador nao credenciado na operadora. Verificar rede credenciada."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_005_3"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_3_4_DENY_MISSING_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B3_3_DENY_MISSING_005"><text>"CRITICO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alert_1_DENY_MISSING_005">
        <description>Dados do prestador incompletos</description>
        <inputEntry id="InputEntry_A1_1_DENY_MISSING_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_DENY_MISSING_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_DENY_MISSING_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_DENY_MISSING_005"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_DENY_MISSING_005"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_DENY_MISSING_005"><text>"RISCO MEDIO: Dados complementares do prestador incompletos. Completar para evitar questionamentos."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_005_4"><text></text></outputEntry>
<outputEntry id="OutputEntry_Alert_1_4_DENY_MISSING_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_DENY_MISSING_005"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_1_DENY_MISSING_005">
        <description>Todos os dados do prestador presentes</description>
        <inputEntry id="InputEntry_P1_1_DENY_MISSING_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_DENY_MISSING_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_DENY_MISSING_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_DENY_MISSING_005"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_DENY_MISSING_005"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_DENY_MISSING_005"><text>"Dados do prestador completos. Credenciamento verificado."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_005_5"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_1_4_DENY_MISSING_005"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_DENY_MISSING_005"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_DENY_MISSING_005">
        <description>Caso padrao - verificar dados do prestador</description>
        <inputEntry id="InputEntry_F_1_DENY_MISSING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_DENY_MISSING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_DENY_MISSING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_DENY_MISSING_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_DENY_MISSING_005"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_DENY_MISSING_005"><text>"Verificar completude dos dados do prestador."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_005_6"><text></text></outputEntry>
<outputEntry id="OutputEntry_Fallback_DENY_MISSING_005_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_F_3_DENY_MISSING_005"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DENY_MISSING_005">
      <dmndi:DMNShape id="DMNShape_Decision_DENY_MISSING_005" dmnElementRef="Decision_DENY_MISSING_005">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>