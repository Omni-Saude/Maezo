<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DENY-MISSING-006 - Detalhes Procedimento Faltantes
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: DENY-MISSING
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_DENY_MISSING_006" name="Detalhes Procedimento Faltantes" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DENY_MISSING_006" name="[SP-RC-007 | glosa_prevention/missing] Verificar Detalhes Procedimento" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_MISSING_006" hitPolicy="FIRST">

      <input id="Input_1_DENY_MISSING_006" label="Tem Codigo TUSS">
        <inputExpression id="InputExpression_1_DENY_MISSING_006" typeRef="boolean">
          <text>temCodigoTUSS</text>
        </inputExpression>
      </input>

      <input id="Input_2_DENY_MISSING_006" label="Tem Quantidade">
        <inputExpression id="InputExpression_2_DENY_MISSING_006" typeRef="boolean">
          <text>temQuantidade</text>
        </inputExpression>
      </input>

      <input id="Input_3_DENY_MISSING_006" label="Tem Via de Acesso">
        <inputExpression id="InputExpression_3_DENY_MISSING_006" typeRef="boolean">
          <text>temViaAcesso</text>
        </inputExpression>
      </input>

      <input id="Input_4_DENY_MISSING_006" label="Tem Tecnica">
        <inputExpression id="InputExpression_4_DENY_MISSING_006" typeRef="boolean">
          <text>temTecnica</text>
        </inputExpression>
      </input>

      
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_DENY_MISSING_006" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_DENY_MISSING_006" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_DENY_MISSING_006" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_DENY_MISSING_006" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_DENY_MISSING_006" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Block_1_DENY_MISSING_006">
        <description>Codigo TUSS do procedimento nao informado</description>
        <inputEntry id="InputEntry_B1_1_DENY_MISSING_006"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_DENY_MISSING_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_DENY_MISSING_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_DENY_MISSING_006"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_DENY_MISSING_006"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_DENY_MISSING_006"><text>"GLOSA CERTA: Codigo TUSS do procedimento nao informado. Campo obrigatorio para faturamento."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_006"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_1_4_DENY_MISSING_006"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_DENY_MISSING_006"><text>"CRITICO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Block_2_DENY_MISSING_006">
        <description>Quantidade nao informada</description>
        <inputEntry id="InputEntry_B2_1_DENY_MISSING_006"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_DENY_MISSING_006"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_DENY_MISSING_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_DENY_MISSING_006"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_DENY_MISSING_006"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_DENY_MISSING_006"><text>"GLOSA CERTA: Quantidade do procedimento nao informada. Campo obrigatorio."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_006_2"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_2_4_DENY_MISSING_006"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_DENY_MISSING_006"><text>"CRITICO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alert_1_DENY_MISSING_006">
        <description>Via de acesso nao informada para procedimento cirurgico</description>
        <inputEntry id="InputEntry_A1_1_DENY_MISSING_006"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_DENY_MISSING_006"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_DENY_MISSING_006"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_DENY_MISSING_006"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_DENY_MISSING_006"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_DENY_MISSING_006"><text>"RISCO MEDIO: Via de acesso nao informada. Pode ser questionado para procedimentos cirurgicos."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_006_3"><text></text></outputEntry>
<outputEntry id="OutputEntry_Alert_1_4_DENY_MISSING_006"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_DENY_MISSING_006"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_1_DENY_MISSING_006">
        <description>Todos os detalhes do procedimento presentes</description>
        <inputEntry id="InputEntry_P1_1_DENY_MISSING_006"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_DENY_MISSING_006"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_DENY_MISSING_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_DENY_MISSING_006"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_DENY_MISSING_006"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_DENY_MISSING_006"><text>"Detalhes do procedimento completos. Pode ser faturado."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_006_4"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_1_4_DENY_MISSING_006"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_DENY_MISSING_006"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_DENY_MISSING_006">
        <description>Caso padrao - verificar detalhes</description>
        <inputEntry id="InputEntry_F_1_DENY_MISSING_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_DENY_MISSING_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_DENY_MISSING_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_DENY_MISSING_006"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_DENY_MISSING_006"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_DENY_MISSING_006"><text>"Verificar completude dos detalhes do procedimento."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_006_5"><text></text></outputEntry>
<outputEntry id="OutputEntry_Fallback_DENY_MISSING_006_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_F_3_DENY_MISSING_006"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DENY_MISSING_006">
      <dmndi:DMNShape id="DMNShape_Decision_DENY_MISSING_006" dmnElementRef="Decision_DENY_MISSING_006">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>