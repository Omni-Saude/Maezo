<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DENY-MISSING-002 - Laudo Medico Faltante
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: DENY-MISSING
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_DENY_MISSING_002" name="Laudo Medico Faltante" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DENY_MISSING_002" name="[SP-RC-007 | glosa_prevention/missing] Verificar Laudo Medico" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_MISSING_002" hitPolicy="FIRST">

      <input id="Input_1_DENY_MISSING_002" label="Tem Laudo Anexo">
        <inputExpression id="InputExpression_1_DENY_MISSING_002" typeRef="boolean">
          <text>temLaudoAnexo</text>
        </inputExpression>
      </input>

      <input id="Input_2_DENY_MISSING_002" label="Exige Laudo">
        <inputExpression id="InputExpression_2_DENY_MISSING_002" typeRef="boolean">
          <text>exigeLaudo</text>
        </inputExpression>
      </input>

      <input id="Input_3_DENY_MISSING_002" label="Tipo Procedimento">
        <inputExpression id="InputExpression_3_DENY_MISSING_002" typeRef="string">
          <text>tipoProcedimento</text>
        </inputExpression>
      </input>

      <input id="Input_4_DENY_MISSING_002" label="Complexidade">
        <inputExpression id="InputExpression_4_DENY_MISSING_002" typeRef="string">
          <text>complexidade</text>
        </inputExpression>
      </input>

      
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_DENY_MISSING_002" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_DENY_MISSING_002" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_DENY_MISSING_002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_DENY_MISSING_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_DENY_MISSING_002" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Block_1_DENY_MISSING_002">
        <description>Procedimento de alta complexidade sem laudo medico</description>
        <inputEntry id="InputEntry_B1_1_DENY_MISSING_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_DENY_MISSING_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_DENY_MISSING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_DENY_MISSING_002"><text>"Alta"</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_DENY_MISSING_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_DENY_MISSING_002"><text>"GLOSA CERTA: Procedimento de alta complexidade exige laudo medico conforme RN 465/2021 DUT. Operadoras glosam 100% sem justificativa clinica documentada."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_002"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_1_4_DENY_MISSING_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_DENY_MISSING_002"><text>"CRITICO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Block_2_DENY_MISSING_002">
        <description>Procedimento cirurgico exige laudo mas nao tem</description>
        <inputEntry id="InputEntry_B2_1_DENY_MISSING_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_DENY_MISSING_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_DENY_MISSING_002"><text>"Cirurgia"</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_DENY_MISSING_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_DENY_MISSING_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_DENY_MISSING_002"><text>"GLOSA CERTA: Procedimento cirurgico exige laudo medico com indicacao. Nao faturar sem documentacao."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_002_2"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_2_4_DENY_MISSING_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_DENY_MISSING_002"><text>"CRITICO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alert_1_DENY_MISSING_002">
        <description>Exame de imagem complexo sem laudo solicitante</description>
        <inputEntry id="InputEntry_A1_1_DENY_MISSING_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_DENY_MISSING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_DENY_MISSING_002"><text>"Exame Imagem"</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_DENY_MISSING_002"><text>"Media", "Alta"</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_DENY_MISSING_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_DENY_MISSING_002"><text>"RISCO ALTO: Exame de imagem complexo sem laudo solicitante pode ser questionado. Recomendado anexar justificativa."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_002_3"><text></text></outputEntry>
<outputEntry id="OutputEntry_Alert_1_4_DENY_MISSING_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_DENY_MISSING_002"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_1_DENY_MISSING_002">
        <description>Laudo medico presente</description>
        <inputEntry id="InputEntry_P1_1_DENY_MISSING_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_DENY_MISSING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_DENY_MISSING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_DENY_MISSING_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_DENY_MISSING_002"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_DENY_MISSING_002"><text>"Laudo medico anexado. Documentacao adequada."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_002_4"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_1_4_DENY_MISSING_002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_DENY_MISSING_002"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_2_DENY_MISSING_002">
        <description>Procedimento nao exige laudo</description>
        <inputEntry id="InputEntry_P2_1_DENY_MISSING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_DENY_MISSING_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_DENY_MISSING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_DENY_MISSING_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_DENY_MISSING_002"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_DENY_MISSING_002"><text>"Procedimento nao exige laudo medico. Pode ser faturado."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_002_5"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_2_4_DENY_MISSING_002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_DENY_MISSING_002"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_DENY_MISSING_002">
        <description>Caso padrao - verificar necessidade de laudo</description>
        <inputEntry id="InputEntry_F_1_DENY_MISSING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_DENY_MISSING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_DENY_MISSING_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_DENY_MISSING_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_DENY_MISSING_002"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_DENY_MISSING_002"><text>"Dados insuficientes para validacao automatica. Verificar DUT da operadora para requisitos de documentacao."</text></outputEntry>
        <outputEntry id="_DENY_MISSING_002_6"><text></text></outputEntry>
<outputEntry id="OutputEntry_Fallback_DENY_MISSING_002_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_F_3_DENY_MISSING_002"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DENY_MISSING_002">
      <dmndi:DMNShape id="DMNShape_Decision_DENY_MISSING_002" dmnElementRef="Decision_DENY_MISSING_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>