<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DENY-DUPLICATE-002 - Procedimento Similar Intervalo
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: DENY-DUPLICATE
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_DENY_DUPLICATE_002" name="Procedimento Similar Intervalo" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DENY_DUPLICATE_002" name="[SP-RC-007 | glosa_prevention/duplicate] Verificar Intervalo Minimo" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_DUPLICATE_002" hitPolicy="FIRST">

      <input id="Input_1_DENY_DUPLICATE_002" label="Dias Desde Ultimo">
        <inputExpression id="InputExpression_1_DENY_DUPLICATE_002" typeRef="number">
          <text>diasDesdeUltimo</text>
        </inputExpression>
      </input>

      <input id="Input_2_DENY_DUPLICATE_002" label="Intervalo Minimo Dias">
        <inputExpression id="InputExpression_2_DENY_DUPLICATE_002" typeRef="number">
          <text>intervaloMinimoDias</text>
        </inputExpression>
      </input>

      <input id="Input_3_DENY_DUPLICATE_002" label="Procedimento Anterior">
        <inputExpression id="InputExpression_3_DENY_DUPLICATE_002" typeRef="boolean">
          <text>procedimentoAnterior</text>
        </inputExpression>
      </input>

      <input id="Input_4_DENY_DUPLICATE_002" label="Tem Justificativa">
        <inputExpression id="InputExpression_4_DENY_DUPLICATE_002" typeRef="boolean">
          <text>temJustificativa</text>
        </inputExpression>
      </input>

      
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_DENY_DUPLICATE_002" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_DENY_DUPLICATE_002" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_DENY_DUPLICATE_002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_DENY_DUPLICATE_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_DENY_DUPLICATE_002" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Block_1_DENY_DUPLICATE_002">
        <description>Procedimento dentro do intervalo minimo sem justificativa</description>
        <inputEntry id="InputEntry_B1_1_DENY_DUPLICATE_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_DENY_DUPLICATE_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_DENY_DUPLICATE_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_DENY_DUPLICATE_002"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_DENY_DUPLICATE_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_DENY_DUPLICATE_002"><text>"GLOSA PROVAVEL: Procedimento realizado antes do intervalo minimo. Exige justificativa clinica para repeticao antecipada."</text></outputEntry>
        <outputEntry id="_DENY_DUPLICATE_002"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_1_4_DENY_DUPLICATE_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_DENY_DUPLICATE_002"><text>"CRITICO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alert_1_DENY_DUPLICATE_002">
        <description>Procedimento dentro do intervalo mas com justificativa</description>
        <inputEntry id="InputEntry_A1_1_DENY_DUPLICATE_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_DENY_DUPLICATE_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_DENY_DUPLICATE_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_DENY_DUPLICATE_002"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_DENY_DUPLICATE_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_DENY_DUPLICATE_002"><text>"RISCO MEDIO: Intervalo abaixo do padrao mas justificativa presente. Pode ser questionado."</text></outputEntry>
        <outputEntry id="_DENY_DUPLICATE_002_2"><text></text></outputEntry>
<outputEntry id="OutputEntry_Alert_1_4_DENY_DUPLICATE_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_DENY_DUPLICATE_002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_1_DENY_DUPLICATE_002">
        <description>Primeiro procedimento do tipo</description>
        <inputEntry id="InputEntry_P1_1_DENY_DUPLICATE_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_DENY_DUPLICATE_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_DENY_DUPLICATE_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_DENY_DUPLICATE_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_DENY_DUPLICATE_002"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_DENY_DUPLICATE_002"><text>"Primeiro procedimento do tipo. Sem restricao de intervalo."</text></outputEntry>
        <outputEntry id="_DENY_DUPLICATE_002_3"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_1_4_DENY_DUPLICATE_002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_DENY_DUPLICATE_002"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_DENY_DUPLICATE_002">
        <description>Caso padrao - verificar intervalo</description>
        <inputEntry id="InputEntry_F_1_DENY_DUPLICATE_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_DENY_DUPLICATE_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_DENY_DUPLICATE_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_DENY_DUPLICATE_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_DENY_DUPLICATE_002"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_DENY_DUPLICATE_002"><text>"Verificar intervalo minimo para este procedimento."</text></outputEntry>
        <outputEntry id="_DENY_DUPLICATE_002_4"><text></text></outputEntry>
<outputEntry id="OutputEntry_Fallback_DENY_DUPLICATE_002_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_F_3_DENY_DUPLICATE_002"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DENY_DUPLICATE_002">
      <dmndi:DMNShape id="DMNShape_Decision_DENY_DUPLICATE_002" dmnElementRef="Decision_DENY_DUPLICATE_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>