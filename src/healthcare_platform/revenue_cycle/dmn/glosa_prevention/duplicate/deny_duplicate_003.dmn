<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DENY-DUPLICATE-003 - Deteccao Reapresentacao
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: DENY-DUPLICATE
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_DENY_DUPLICATE_003" name="Deteccao Reapresentacao" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DENY_DUPLICATE_003" name="[SP-RC-007 | glosa_prevention/duplicate] Verificar Reapresentacao" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_DUPLICATE_003" hitPolicy="FIRST">

      <input id="Input_1_DENY_DUPLICATE_003" label="E Reapresentacao">
        <inputExpression id="InputExpression_1_DENY_DUPLICATE_003" typeRef="boolean">
          <text>reapresentacao</text>
        </inputExpression>
      </input>

      <input id="Input_2_DENY_DUPLICATE_003" label="Correcoes Realizadas">
        <inputExpression id="InputExpression_2_DENY_DUPLICATE_003" typeRef="boolean">
          <text>correcoesRealizadas</text>
        </inputExpression>
      </input>

      <input id="Input_3_DENY_DUPLICATE_003" label="Dias Desde Glosa">
        <inputExpression id="InputExpression_3_DENY_DUPLICATE_003" typeRef="number">
          <text>diasDesdeGlosa</text>
        </inputExpression>
      </input>

      <input id="Input_4_DENY_DUPLICATE_003" label="Motivo Glosa Anterior">
        <inputExpression id="InputExpression_4_DENY_DUPLICATE_003" typeRef="string">
          <text>motivoGlosaAnterior</text>
        </inputExpression>
      </input>

      
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_DENY_DUPLICATE_003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_DENY_DUPLICATE_003" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_DENY_DUPLICATE_003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_DENY_DUPLICATE_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_DENY_DUPLICATE_003" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Block_1_DENY_DUPLICATE_003">
        <description>Reapresentacao identica sem correcoes</description>
        <inputEntry id="InputEntry_B1_1_DENY_DUPLICATE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_DENY_DUPLICATE_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_DENY_DUPLICATE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_DENY_DUPLICATE_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_DENY_DUPLICATE_003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_DENY_DUPLICATE_003"><text>"GLOSA CERTA: Reapresentacao de guia sem as correcoes exigidas. Sera glosada novamente pelo mesmo motivo."</text></outputEntry>
        <outputEntry id="_DENY_DUPLICATE_003"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_1_4_DENY_DUPLICATE_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_DENY_DUPLICATE_003"><text>"CRITICO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Block_2_DENY_DUPLICATE_003">
        <description>Reapresentacao apos prazo de 30 dias</description>
        <inputEntry id="InputEntry_B2_1_DENY_DUPLICATE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_DENY_DUPLICATE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_DENY_DUPLICATE_003"><text>&gt; 30</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_DENY_DUPLICATE_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_DENY_DUPLICATE_003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_DENY_DUPLICATE_003"><text>"GLOSA CERTA: Reapresentacao fora do prazo de 30 dias. Conta perdida por intempestividade."</text></outputEntry>
        <outputEntry id="_DENY_DUPLICATE_003_2"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_2_4_DENY_DUPLICATE_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_DENY_DUPLICATE_003"><text>"CRITICO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alert_1_DENY_DUPLICATE_003">
        <description>Reapresentacao corrigida mas proximo do prazo</description>
        <inputEntry id="InputEntry_A1_1_DENY_DUPLICATE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_DENY_DUPLICATE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_DENY_DUPLICATE_003"><text>[25..30]</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_DENY_DUPLICATE_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_DENY_DUPLICATE_003"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_DENY_DUPLICATE_003"><text>"RISCO ALTO: Reapresentacao no limite do prazo. Enviar imediatamente."</text></outputEntry>
        <outputEntry id="_DENY_DUPLICATE_003_3"><text></text></outputEntry>
<outputEntry id="OutputEntry_Alert_1_4_DENY_DUPLICATE_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_DENY_DUPLICATE_003"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_1_DENY_DUPLICATE_003">
        <description>Reapresentacao corrigida dentro do prazo</description>
        <inputEntry id="InputEntry_P1_1_DENY_DUPLICATE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_DENY_DUPLICATE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_DENY_DUPLICATE_003"><text>&lt; 25</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_DENY_DUPLICATE_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_DENY_DUPLICATE_003"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_DENY_DUPLICATE_003"><text>"Reapresentacao com correcoes dentro do prazo. Pode ser enviada."</text></outputEntry>
        <outputEntry id="_DENY_DUPLICATE_003_4"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_1_4_DENY_DUPLICATE_003"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_DENY_DUPLICATE_003"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_2_DENY_DUPLICATE_003">
        <description>Nao e reapresentacao</description>
        <inputEntry id="InputEntry_P2_1_DENY_DUPLICATE_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_DENY_DUPLICATE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_DENY_DUPLICATE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_DENY_DUPLICATE_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_DENY_DUPLICATE_003"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_DENY_DUPLICATE_003"><text>"Primeira apresentacao da guia. Nao e reapresentacao."</text></outputEntry>
        <outputEntry id="_DENY_DUPLICATE_003_5"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_2_4_DENY_DUPLICATE_003"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_DENY_DUPLICATE_003"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_DENY_DUPLICATE_003">
        <description>Caso padrao - verificar status</description>
        <inputEntry id="InputEntry_F_1_DENY_DUPLICATE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_DENY_DUPLICATE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_DENY_DUPLICATE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_DENY_DUPLICATE_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_DENY_DUPLICATE_003"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_DENY_DUPLICATE_003"><text>"Verificar se guia e reapresentacao e status das correcoes."</text></outputEntry>
        <outputEntry id="_DENY_DUPLICATE_003_6"><text></text></outputEntry>
<outputEntry id="OutputEntry_Fallback_DENY_DUPLICATE_003_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_F_3_DENY_DUPLICATE_003"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DENY_DUPLICATE_003">
      <dmndi:DMNShape id="DMNShape_Decision_DENY_DUPLICATE_003" dmnElementRef="Decision_DENY_DUPLICATE_003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>