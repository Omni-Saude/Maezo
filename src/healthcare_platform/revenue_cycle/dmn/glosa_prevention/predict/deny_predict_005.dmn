<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DENY-PREDICT-005 - Bundle Billing Violation
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: DENY-PREDICT
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_DENY_PREDICT_005" name="Bundle Billing Violation" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DENY_PREDICT_005" name="[SP-RC-007 | glosa_prevention/predict] Detectar Violacao de Bundle" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_PREDICT_005" hitPolicy="FIRST">

      <input id="Input_1_DENY_PREDICT_005" label="Codigo TUSS Principal">
        <inputExpression id="InputExpression_1_DENY_PREDICT_005" typeRef="string">
          <text>codigoTUSSPrincipal</text>
        </inputExpression>
      </input>

      <input id="Input_2_DENY_PREDICT_005" label="Codigo TUSS Secundario">
        <inputExpression id="InputExpression_2_DENY_PREDICT_005" typeRef="string">
          <text>codigoTUSSSecundario</text>
        </inputExpression>
      </input>

      <input id="Input_3_DENY_PREDICT_005" label="Mesma Data">
        <inputExpression id="InputExpression_3_DENY_PREDICT_005" typeRef="boolean">
          <text>mesmaData</text>
        </inputExpression>
      </input>

      <input id="Input_4_DENY_PREDICT_005" label="Tipo Bundle">
        <inputExpression id="InputExpression_4_DENY_PREDICT_005" typeRef="string">
          <text>tipoBundle</text>
        </inputExpression>
      </input>

      
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_DENY_PREDICT_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_DENY_PREDICT_005" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_DENY_PREDICT_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_DENY_PREDICT_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_DENY_PREDICT_005" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Block_1_DENY_PREDICT_005">
        <description>Cobranca separada de anestesia inclusa no procedimento</description>
        <inputEntry id="InputEntry_B1_1_DENY_PREDICT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_DENY_PREDICT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_DENY_PREDICT_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_DENY_PREDICT_005"><text>"ANESTESIA_INCLUSA"</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_DENY_PREDICT_005"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_DENY_PREDICT_005"><text>"GLOSA CERTA: Anestesia ja esta inclusa no procedimento principal. Cobranca separada sera glosada."</text></outputEntry>
        <outputEntry id="_DENY_PREDICT_005"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_1_4_DENY_PREDICT_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_DENY_PREDICT_005"><text>"CRITICO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Block_2_DENY_PREDICT_005">
        <description>Cobranca separada de exames pre-op inclusos</description>
        <inputEntry id="InputEntry_B2_1_DENY_PREDICT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_DENY_PREDICT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_DENY_PREDICT_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_DENY_PREDICT_005"><text>"EXAMES_PRE_OP_INCLUSOS"</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_DENY_PREDICT_005"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_DENY_PREDICT_005"><text>"GLOSA CERTA: Exames pre-operatorios inclusos no pacote cirurgico. Nao cobrar separadamente."</text></outputEntry>
        <outputEntry id="_DENY_PREDICT_005_2"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_2_4_DENY_PREDICT_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_DENY_PREDICT_005"><text>"CRITICO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alert_1_DENY_PREDICT_005">
        <description>Procedimentos relacionados que podem ser bundle</description>
        <inputEntry id="InputEntry_A1_1_DENY_PREDICT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_DENY_PREDICT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_DENY_PREDICT_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_DENY_PREDICT_005"><text>"POSSIVEL_BUNDLE"</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_DENY_PREDICT_005"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_DENY_PREDICT_005"><text>"RISCO ALTO: Procedimentos podem constituir bundle. Verificar regras de cobranca antes de faturar."</text></outputEntry>
        <outputEntry id="_DENY_PREDICT_005_3"><text></text></outputEntry>
<outputEntry id="OutputEntry_Alert_1_4_DENY_PREDICT_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_DENY_PREDICT_005"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_1_DENY_PREDICT_005">
        <description>Procedimentos independentes</description>
        <inputEntry id="InputEntry_P1_1_DENY_PREDICT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_DENY_PREDICT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_DENY_PREDICT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_DENY_PREDICT_005"><text>"NAO_BUNDLE"</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_DENY_PREDICT_005"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_DENY_PREDICT_005"><text>"Procedimentos independentes. Podem ser cobrados separadamente."</text></outputEntry>
        <outputEntry id="_DENY_PREDICT_005_4"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_1_4_DENY_PREDICT_005"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_DENY_PREDICT_005"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_DENY_PREDICT_005">
        <description>Caso padrao - requer revisao</description>
        <inputEntry id="InputEntry_F_1_DENY_PREDICT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_DENY_PREDICT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_DENY_PREDICT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_DENY_PREDICT_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_DENY_PREDICT_005"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_DENY_PREDICT_005"><text>"Verificar manualmente se procedimentos constituem bundle ou podem ser cobrados separadamente."</text></outputEntry>
        <outputEntry id="_DENY_PREDICT_005_5"><text></text></outputEntry>
<outputEntry id="OutputEntry_Fallback_DENY_PREDICT_005_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_F_3_DENY_PREDICT_005"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DENY_PREDICT_005">
      <dmndi:DMNShape id="DMNShape_Decision_DENY_PREDICT_005" dmnElementRef="Decision_DENY_PREDICT_005">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>