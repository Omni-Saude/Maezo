<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DENY-PREDICT-007 - Tratamento Conservador Gap
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: DENY-PREDICT
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_DENY_PREDICT_007" name="Tratamento Conservador Gap" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DENY_PREDICT_007" name="[SP-RC-007 | glosa_prevention/predict] Verificar Tratamento Conservador" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_PREDICT_007" hitPolicy="FIRST">

      <input id="Input_1_DENY_PREDICT_007" label="Codigo TUSS">
        <inputExpression id="InputExpression_1_DENY_PREDICT_007" typeRef="string">
          <text>codigoTUSS</text>
        </inputExpression>
      </input>

      <input id="Input_2_DENY_PREDICT_007" label="Especialidade">
        <inputExpression id="InputExpression_2_DENY_PREDICT_007" typeRef="string">
          <text>especialidade</text>
        </inputExpression>
      </input>

      <input id="Input_3_DENY_PREDICT_007" label="Tem Tratamento Conservador">
        <inputExpression id="InputExpression_3_DENY_PREDICT_007" typeRef="boolean">
          <text>temTratamentoConservador</text>
        </inputExpression>
      </input>

      <input id="Input_4_DENY_PREDICT_007" label="Tipo Procedimento">
        <inputExpression id="InputExpression_4_DENY_PREDICT_007" typeRef="string">
          <text>tipoProcedimento</text>
        </inputExpression>
      </input>

      
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_DENY_PREDICT_007" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_DENY_PREDICT_007" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_DENY_PREDICT_007" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_DENY_PREDICT_007" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_DENY_PREDICT_007" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Block_1_DENY_PREDICT_007">
        <description>Cirurgia de coluna sem tratamento conservador documentado</description>
        <inputEntry id="InputEntry_B1_1_DENY_PREDICT_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_DENY_PREDICT_007"><text>"Ortopedia", "Neurocirurgia"</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_DENY_PREDICT_007"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_DENY_PREDICT_007"><text>"Cirurgia Coluna"</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_DENY_PREDICT_007"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_DENY_PREDICT_007"><text>"GLOSA CERTA: Cirurgia de coluna exige documentacao de tratamento conservador previo (fisioterapia minimo 6 semanas). Operadoras negam sem esta documentacao."</text></outputEntry>
        <outputEntry id="_DENY_PREDICT_007"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_1_4_DENY_PREDICT_007"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_DENY_PREDICT_007"><text>"CRITICO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Block_2_DENY_PREDICT_007">
        <description>Artroscopia sem tentativa de tratamento clinico</description>
        <inputEntry id="InputEntry_B2_1_DENY_PREDICT_007"><text>"31503082", "31503090"</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_DENY_PREDICT_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_DENY_PREDICT_007"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_DENY_PREDICT_007"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_DENY_PREDICT_007"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_DENY_PREDICT_007"><text>"GLOSA PROVAVEL: Artroscopia exige documentacao de falha de tratamento conservador. Anexar historico de fisioterapia/medicamentoso."</text></outputEntry>
        <outputEntry id="_DENY_PREDICT_007_2"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_2_4_DENY_PREDICT_007"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_DENY_PREDICT_007"><text>"CRITICO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alert_1_DENY_PREDICT_007">
        <description>Cirurgia eletiva sem documentacao de tratamento previo</description>
        <inputEntry id="InputEntry_A1_1_DENY_PREDICT_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_DENY_PREDICT_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_DENY_PREDICT_007"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_DENY_PREDICT_007"><text>"Cirurgia Eletiva"</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_DENY_PREDICT_007"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_DENY_PREDICT_007"><text>"RISCO ALTO: Cirurgia eletiva sem documentacao de tratamento conservador previo pode ser questionada. Recomendado anexar historico."</text></outputEntry>
        <outputEntry id="_DENY_PREDICT_007_3"><text></text></outputEntry>
<outputEntry id="OutputEntry_Alert_1_4_DENY_PREDICT_007"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_DENY_PREDICT_007"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_1_DENY_PREDICT_007">
        <description>Documentacao de tratamento conservador presente</description>
        <inputEntry id="InputEntry_P1_1_DENY_PREDICT_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_DENY_PREDICT_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_DENY_PREDICT_007"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_DENY_PREDICT_007"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_DENY_PREDICT_007"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_DENY_PREDICT_007"><text>"Tratamento conservador documentado. Falha terapeutica comprovada justifica procedimento cirurgico."</text></outputEntry>
        <outputEntry id="_DENY_PREDICT_007_4"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_1_4_DENY_PREDICT_007"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_DENY_PREDICT_007"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_2_DENY_PREDICT_007">
        <description>Procedimento de emergencia nao exige conservador</description>
        <inputEntry id="InputEntry_P2_1_DENY_PREDICT_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_DENY_PREDICT_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_DENY_PREDICT_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_DENY_PREDICT_007"><text>"Emergencia", "Urgencia"</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_DENY_PREDICT_007"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_DENY_PREDICT_007"><text>"Procedimento de emergencia/urgencia. Tratamento conservador previo nao e exigido."</text></outputEntry>
        <outputEntry id="_DENY_PREDICT_007_5"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_2_4_DENY_PREDICT_007"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_DENY_PREDICT_007"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_DENY_PREDICT_007">
        <description>Caso padrao - requer revisao</description>
        <inputEntry id="InputEntry_F_1_DENY_PREDICT_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_DENY_PREDICT_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_DENY_PREDICT_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_DENY_PREDICT_007"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_DENY_PREDICT_007"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_DENY_PREDICT_007"><text>"Verificar manualmente se procedimento exige documentacao de tratamento conservador previo."</text></outputEntry>
        <outputEntry id="_DENY_PREDICT_007_6"><text></text></outputEntry>
<outputEntry id="OutputEntry_Fallback_DENY_PREDICT_007_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_F_3_DENY_PREDICT_007"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DENY_PREDICT_007">
      <dmndi:DMNShape id="DMNShape_Decision_DENY_PREDICT_007" dmnElementRef="Decision_DENY_PREDICT_007">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>