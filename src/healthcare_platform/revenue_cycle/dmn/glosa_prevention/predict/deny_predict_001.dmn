<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DENY-PREDICT-001 - Mastologia Histopatologia Ausente
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: DENY-PREDICT
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_DENY_PREDICT_001" name="Mastologia Histopatologia Ausente" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DENY_PREDICT_001" name="[SP-RC-007 | glosa_prevention/predict] Verificar Histopatologia Mastologia" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_PREDICT_001" hitPolicy="FIRST">

      
      <input id="Input_1_DENY_PREDICT_001" label="Codigo TUSS">
        <inputExpression id="InputExpression_1_DENY_PREDICT_001" typeRef="string">
          <text>codigoTUSS</text>
        </inputExpression>
      </input>

      <input id="Input_2_DENY_PREDICT_001" label="Especialidade">
        <inputExpression id="InputExpression_2_DENY_PREDICT_001" typeRef="string">
          <text>especialidade</text>
        </inputExpression>
      </input>

      <input id="Input_3_DENY_PREDICT_001" label="Tem Laudo Histopatologico">
        <inputExpression id="InputExpression_3_DENY_PREDICT_001" typeRef="boolean">
          <text>temLaudoHistopatologico</text>
        </inputExpression>
      </input>

      
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_DENY_PREDICT_001" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_DENY_PREDICT_001" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_DENY_PREDICT_001" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_DENY_PREDICT_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_DENY_PREDICT_001" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Block_1_DENY_PREDICT_001">
        <description>Mastologia oncologica sem histopatologico - risco critico de glosa</description>
        <inputEntry id="InputEntry_B1_1_DENY_PREDICT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_DENY_PREDICT_001"><text>"Mastologia", "Oncologia Mamaria"</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_DENY_PREDICT_001"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_DENY_PREDICT_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_DENY_PREDICT_001"><text>"GLOSA CERTA: Procedimentos de mastologia oncologica requerem laudo histopatologico. Operadoras glosam 100% dos casos sem confirmacao diagnostica."</text></outputEntry>
        <outputEntry id="_DENY_PREDICT_001"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_1_4_DENY_PREDICT_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_DENY_PREDICT_001"><text>"CRITICO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alert_1_DENY_PREDICT_001">
        <description>Cirurgia mamaria sem histopatologico previo</description>
        <inputEntry id="InputEntry_A1_1_DENY_PREDICT_001"><text>"31401054", "31401062", "31401089", "31401097"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_DENY_PREDICT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_DENY_PREDICT_001"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_DENY_PREDICT_001"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_DENY_PREDICT_001"><text>"RISCO ALTO: Cirurgias de mama sem laudo histopatologico previo tem alta taxa de glosa. Verificar necessidade clinica."</text></outputEntry>
        <outputEntry id="_DENY_PREDICT_001_2"><text></text></outputEntry>
<outputEntry id="OutputEntry_Alert_1_4_DENY_PREDICT_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_DENY_PREDICT_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_1_DENY_PREDICT_001">
        <description>Documentacao completa - prosseguir com faturamento</description>
        <inputEntry id="InputEntry_P1_1_DENY_PREDICT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_DENY_PREDICT_001"><text>"Mastologia", "Oncologia Mamaria"</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_DENY_PREDICT_001"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_DENY_PREDICT_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_DENY_PREDICT_001"><text>"Documentacao de histopatologia presente. Baixo risco de glosa."</text></outputEntry>
        <outputEntry id="_DENY_PREDICT_001_3"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_1_4_DENY_PREDICT_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_DENY_PREDICT_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_DENY_PREDICT_001">
        <description>Caso padrao - requer revisao manual</description>
        <inputEntry id="InputEntry_F_1_DENY_PREDICT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_DENY_PREDICT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_DENY_PREDICT_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_DENY_PREDICT_001"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_DENY_PREDICT_001"><text>"Caso nao enquadrado nas regras automaticas. Verificar manualmente necessidade de histopatologico."</text></outputEntry>
        <outputEntry id="_DENY_PREDICT_001_4"><text></text></outputEntry>
<outputEntry id="OutputEntry_Fallback_DENY_PREDICT_001_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_F_3_DENY_PREDICT_001"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DENY_PREDICT_001">
      <dmndi:DMNShape id="DMNShape_Decision_DENY_PREDICT_001" dmnElementRef="Decision_DENY_PREDICT_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>