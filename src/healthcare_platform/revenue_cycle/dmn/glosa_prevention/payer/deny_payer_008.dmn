<?xml version="1.0" encoding="UTF-8"?>
<!--
  DENY-PAYER-008 - Regra Operadora Nao-Publicada (Glosa Indevida)
  Versao: 1.0.0 (2026-02-08)
  Categoria: DENY-PAYER | Perspectiva: HOSPITAL (Faturamento)
  Refs: Lei 9.656/1998 Art. 25, CDC Art. 46, RN ANS 465/2021
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DENY_PAYER_008"
             name="Regra Operadora Nao-Publicada"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_DENY_PAYER_008" name="[SP-RC-007 | glosa_prevention/payer] Regra Operadora Nao-Publicada" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_PAYER_008" hitPolicy="FIRST">
      <input id="Input_1_DENY_PAYER_008" label="Regra Publicada"><inputExpression id="InputExpression_1_DENY_PAYER_008" typeRef="boolean"><text>regraPublicada</text></inputExpression></input>
      <input id="Input_2_DENY_PAYER_008" label="Operadora"><inputExpression id="InputExpression_2_DENY_PAYER_008" typeRef="string"><text>operadora</text></inputExpression></input>
      <output id="Output_1_DENY_PAYER_008" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues></output>
      <output id="Output_2_DENY_PAYER_008" label="Observacao" name="observacao" typeRef="string"/>
      <output id="Output_3_DENY_PAYER_008" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>
      <output id="Output_4_DENY_PAYER_008" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output>
      <output id="Output_5_DENY_PAYER_008" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output>
      <rule id="Rule_Bloqueio_1_DENY_PAYER_008"><description>Regra nao publicada - glosa indevida</description><inputEntry id="InputEntry_B1_1_DENY_PAYER_008"><text>false</text></inputEntry><inputEntry id="InputEntry_B1_2_DENY_PAYER_008"><text>-</text></inputEntry><outputEntry id="OutputEntry_B1_1_DENY_PAYER_008"><text>"Bloquear"</text></outputEntry><outputEntry id="OutputEntry_B1_2_DENY_PAYER_008"><text>"GLOSA INDEVIDA: Regra invocada NAO ESTA PUBLICADA (CDC Art. 46). Operadora nao pode aplicar regra nao contratual. Acionar juridico imediatamente."</text></outputEntry><outputEntry id="OutputEntry_B1_3_DENY_PAYER_008"><text>"Acionar juridico para contestacao formal. Verificar contrato e manual vigente. Preparar recurso de glosa indevida. Considerar denuncia ANS."</text></outputEntry><outputEntry id="OutputEntry_B1_4_DENY_PAYER_008"><text>"CONTRATO"</text></outputEntry><outputEntry id="OutputEntry_B1_5_DENY_PAYER_008"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_Aprovado_1_DENY_PAYER_008"><description>Regra publicada oficialmente</description><inputEntry id="InputEntry_P1_1_DENY_PAYER_008"><text>true</text></inputEntry><inputEntry id="InputEntry_P1_2_DENY_PAYER_008"><text>-</text></inputEntry><outputEntry id="OutputEntry_P1_1_DENY_PAYER_008"><text>"Prosseguir"</text></outputEntry><outputEntry id="OutputEntry_P1_2_DENY_PAYER_008"><text>"Regra publicada oficialmente. Validade contratual confirmada. Prosseguir com analise de conformidade."</text></outputEntry><outputEntry id="OutputEntry_P1_3_DENY_PAYER_008"><text>"Prosseguir com analise de conformidade da regra publicada."</text></outputEntry><outputEntry id="OutputEntry_P1_4_DENY_PAYER_008"><text>"NENHUM"</text></outputEntry><outputEntry id="OutputEntry_P1_5_DENY_PAYER_008"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_Fallback_DENY_PAYER_008"><description>Regra padrao</description><inputEntry id="InputEntry_F_1_DENY_PAYER_008"><text>-</text></inputEntry><inputEntry id="InputEntry_F_2_DENY_PAYER_008"><text>-</text></inputEntry><outputEntry id="OutputEntry_F_1_DENY_PAYER_008"><text>"Revisar"</text></outputEntry><outputEntry id="OutputEntry_F_2_DENY_PAYER_008"><text>"Situacao requer analise manual. Verificar status de publicacao da regra."</text></outputEntry><outputEntry id="OutputEntry_F_3_DENY_PAYER_008"><text>"Encaminhar para auditoria administrativa para validar status de publicacao."</text></outputEntry><outputEntry id="OutputEntry_F_4_DENY_PAYER_008"><text>"NENHUM"</text></outputEntry><outputEntry id="OutputEntry_F_5_DENY_PAYER_008"><text>"MEDIO"</text></outputEntry></rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI><dmndi:DMNDiagram id="DMNDiagram_DENY_PAYER_008"><dmndi:DMNShape id="DMNShape_Decision_DENY_PAYER_008" dmnElementRef="Decision_DENY_PAYER_008"><dc:Bounds height="80" width="180" x="160" y="100"/></dmndi:DMNShape></dmndi:DMNDiagram></dmndi:DMNDI>
</definitions>
