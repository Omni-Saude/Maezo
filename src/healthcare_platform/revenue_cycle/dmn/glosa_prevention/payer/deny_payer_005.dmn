<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DENY-PAYER-005 - Padrao Glosa NotreDame Intermedica (GNDI)
  ============================================================================
  Versao: 1.0.0 (2026-02-06)
  Categoria: DENY-PAYER (Padrao Especifico de Operadora)

  OBJETIVO:
  Identificar padroes de glosa da NotreDame Intermedica relacionados a
  autorizacao de sistema e codigos de servico.

  REFERENCIAS:
  - RN 412/2016 ANS - Rol de Procedimentos
  - TISS 4.01.00 - Padrao de Comunicacao
  - Sistema de Autorizacao GNDI
  - Tabela de Servicos GNDI
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_DENY_PAYER_005" name="Padrao Glosa NotreDame Intermedica" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DENY_PAYER_005" name="[SP-RC-007 | glosa_prevention/payer] Detectar Padrao Glosa GNDI" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_PAYER_005" hitPolicy="FIRST">

      <input id="Input_1_DENY_PAYER_005" label="Codigo Operadora">
        <inputExpression id="InputExpression_1_DENY_PAYER_005" typeRef="string">
          <text>operadoraCodigo</text>
        </inputExpression>
      </input>

      <input id="Input_2_DENY_PAYER_005" label="Autorizacao Sistema Valida">
        <inputExpression id="InputExpression_2_DENY_PAYER_005" typeRef="boolean">
          <text>autorizacaoSistemaValida</text>
        </inputExpression>
      </input>

      <input id="Input_3_DENY_PAYER_005" label="Codigo Servico Mapeado">
        <inputExpression id="InputExpression_3_DENY_PAYER_005" typeRef="boolean">
          <text>codigoServicoMapeado</text>
        </inputExpression>
      </input>

      <input id="Input_4_DENY_PAYER_005" label="Status Autorizacao">
        <inputExpression id="InputExpression_4_DENY_PAYER_005" typeRef="string">
          <text>statusAutorizacao</text>
        </inputExpression>
      </input>

      <!-- OUTPUTS - Hospital Perspective -->
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_DENY_PAYER_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_DENY_PAYER_005" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_DENY_PAYER_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_DENY_PAYER_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_DENY_PAYER_005" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <rule id="Rule_Block_1_DENY_PAYER_005">
        <description>GNDI exige autorizacao no sistema proprio</description>
        <inputEntry id="InputEntry_B1_1_DENY_PAYER_005"><text>"GNDI", "NOTREDAME", "359017"</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_DENY_PAYER_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_DENY_PAYER_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_DENY_PAYER_005"><text>"Ausente", "Nao Encontrada"</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_DENY_PAYER_005"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_DENY_PAYER_005"><text>"GLOSA CERTA: GNDI sem autorizacao no sistema. Procedimento exige autorizacao previa no sistema proprio da operadora."</text></outputEntry>
        <outputEntry id="_DENY_PAYER_005"><text></text></outputEntry>
        <outputEntry id="_DENY_PAYER_005_2"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_DENY_PAYER_005"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA 2: BLOQUEIO - Codigo de servico nao mapeado -->
      <rule id="Rule_Block_2_DENY_PAYER_005">
        <description>GNDI com codigo de servico nao reconhecido</description>
        <inputEntry id="InputEntry_B2_1_DENY_PAYER_005"><text>"GNDI", "NOTREDAME", "359017"</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_DENY_PAYER_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_DENY_PAYER_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_DENY_PAYER_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_DENY_PAYER_005"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_DENY_PAYER_005"><text>"GLOSA CERTA: Codigo de servico nao mapeado na tabela GNDI. Verificar correspondencia TUSS-GNDI."</text></outputEntry>
        <outputEntry id="_DENY_PAYER_005_3"><text></text></outputEntry>
        <outputEntry id="_DENY_PAYER_005_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_DENY_PAYER_005"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA 3: ALERTA - Autorizacao parcial -->
      <rule id="Rule_Alert_1_DENY_PAYER_005">
        <description>GNDI com autorizacao parcialmente aprovada</description>
        <inputEntry id="InputEntry_A1_1_DENY_PAYER_005"><text>"GNDI", "NOTREDAME", "359017"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_DENY_PAYER_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_DENY_PAYER_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_DENY_PAYER_005"><text>"Parcial", "Em Analise"</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_DENY_PAYER_005"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_DENY_PAYER_005"><text>"ATENCAO: Autorizacao GNDI parcialmente aprovada ou em analise. Verificar itens aprovados antes de executar."</text></outputEntry>
        <outputEntry id="_DENY_PAYER_005_5"><text></text></outputEntry>
        <outputEntry id="_DENY_PAYER_005_6"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_DENY_PAYER_005"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA 4: ALERTA - Autorizacao proxima do vencimento -->
      <rule id="Rule_Alert_2_DENY_PAYER_005">
        <description>GNDI com autorizacao proxima da data de validade</description>
        <inputEntry id="InputEntry_A2_1_DENY_PAYER_005"><text>"GNDI", "NOTREDAME", "359017"</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_DENY_PAYER_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_DENY_PAYER_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_DENY_PAYER_005"><text>"Proximo Vencimento", "Ultimos 5 Dias"</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_DENY_PAYER_005"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_DENY_PAYER_005"><text>"RISCO: Autorizacao GNDI proxima do vencimento. Executar ou renovar antes da data limite."</text></outputEntry>
        <outputEntry id="_DENY_PAYER_005_7"><text></text></outputEntry>
        <outputEntry id="_DENY_PAYER_005_8"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_DENY_PAYER_005"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA 5: PROSSEGUIR - Autorizacao valida e codigo mapeado -->
      <rule id="Rule_Proceed_1_DENY_PAYER_005">
        <description>GNDI com autorizacao valida e codigo correto</description>
        <inputEntry id="InputEntry_P1_1_DENY_PAYER_005"><text>"GNDI", "NOTREDAME", "359017"</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_DENY_PAYER_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_DENY_PAYER_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_DENY_PAYER_005"><text>"Aprovada", "Vigente"</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_DENY_PAYER_005"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_DENY_PAYER_005"><text>"GNDI com autorizacao valida e codigo de servico correto. Faturar normalmente."</text></outputEntry>
        <outputEntry id="_DENY_PAYER_005_9"><text></text></outputEntry>
        <outputEntry id="_DENY_PAYER_005_10"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_DENY_PAYER_005"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA 6: PROSSEGUIR - Procedimento sem necessidade de autorizacao -->
      <rule id="Rule_Proceed_2_DENY_PAYER_005">
        <description>Procedimento GNDI livre de autorizacao</description>
        <inputEntry id="InputEntry_P2_1_DENY_PAYER_005"><text>"GNDI", "NOTREDAME", "359017"</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_DENY_PAYER_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_DENY_PAYER_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_DENY_PAYER_005"><text>"Livre", "Nao Requerida"</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_DENY_PAYER_005"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_DENY_PAYER_005"><text>"Procedimento GNDI livre de autorizacao previa."</text></outputEntry>
        <outputEntry id="_DENY_PAYER_005_11"><text></text></outputEntry>
        <outputEntry id="_DENY_PAYER_005_12"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_DENY_PAYER_005"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA 7: REVISAR - Outras operadoras -->
      <rule id="Rule_Review_1_DENY_PAYER_005">
        <description>Regra nao aplicavel - operadora nao e GNDI</description>
        <inputEntry id="InputEntry_R1_1_DENY_PAYER_005"><text>not("GNDI", "NOTREDAME", "359017")</text></inputEntry>
        <inputEntry id="InputEntry_R1_2_DENY_PAYER_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_R1_3_DENY_PAYER_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_R1_4_DENY_PAYER_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_R1_1_DENY_PAYER_005"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_R1_2_DENY_PAYER_005"><text>"Operadora nao e GNDI. Esta regra nao se aplica."</text></outputEntry>
        <outputEntry id="_DENY_PAYER_005_13"><text></text></outputEntry>
        <outputEntry id="_DENY_PAYER_005_14"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_R1_3_DENY_PAYER_005"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA FALLBACK -->
      <rule id="Rule_Fallback_DENY_PAYER_005">
        <description>Caso padrao GNDI - verificar autorizacao</description>
        <inputEntry id="InputEntry_F_1_DENY_PAYER_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_DENY_PAYER_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_DENY_PAYER_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_DENY_PAYER_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_DENY_PAYER_005"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_DENY_PAYER_005"><text>"Verificar status de autorizacao no sistema GNDI."</text></outputEntry>
        <outputEntry id="_DENY_PAYER_005_15"><text></text></outputEntry>
        <outputEntry id="_DENY_PAYER_005_16"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_F_3_DENY_PAYER_005"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DENY_PAYER_005">
      <dmndi:DMNShape id="DMNShape_Decision_DENY_PAYER_005" dmnElementRef="Decision_DENY_PAYER_005">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
