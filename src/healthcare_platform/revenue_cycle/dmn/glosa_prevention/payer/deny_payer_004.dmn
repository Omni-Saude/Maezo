<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DENY-PAYER-004 - Padrao Glosa Amil
  ============================================================================
  Versao: 1.0.0 (2026-02-06)
  Categoria: DENY-PAYER (Padrao Especifico de Operadora)

  OBJETIVO:
  Identificar padroes de glosa da Amil relacionados a rede credenciada
  e tabelas de contrato.

  REFERENCIAS:
  - RN 412/2016 ANS - Rol de Procedimentos
  - TISS 4.01.00 - Padrao de Comunicacao
  - Contrato Amil (UnitedHealth Group)
  - Tabela Amil vigente
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_DENY_PAYER_004" name="Padrao Glosa Amil" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DENY_PAYER_004" name="[SP-RC-007 | glosa_prevention/payer] Detectar Padrao Glosa Amil" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_PAYER_004" hitPolicy="FIRST">

      <input id="Input_1_DENY_PAYER_004" label="Codigo Operadora">
        <inputExpression id="InputExpression_1_DENY_PAYER_004" typeRef="string">
          <text>operadoraCodigo</text>
        </inputExpression>
      </input>

      <input id="Input_2_DENY_PAYER_004" label="Rede Credenciada">
        <inputExpression id="InputExpression_2_DENY_PAYER_004" typeRef="boolean">
          <text>redeCredenciada</text>
        </inputExpression>
      </input>

      <input id="Input_3_DENY_PAYER_004" label="Tabela Contrato Valida">
        <inputExpression id="InputExpression_3_DENY_PAYER_004" typeRef="boolean">
          <text>tabelaContratoValida</text>
        </inputExpression>
      </input>

      <input id="Input_4_DENY_PAYER_004" label="Tipo Rede">
        <inputExpression id="InputExpression_4_DENY_PAYER_004" typeRef="string">
          <text>tipoRede</text>
        </inputExpression>
      </input>

      <!-- OUTPUTS - Hospital Perspective -->
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_DENY_PAYER_004" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_DENY_PAYER_004" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_DENY_PAYER_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_DENY_PAYER_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_DENY_PAYER_004" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <rule id="Rule_Block_1_DENY_PAYER_004">
        <description>Amil glosa procedimentos fora da rede credenciada</description>
        <inputEntry id="InputEntry_B1_1_DENY_PAYER_004"><text>"AMIL", "326305"</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_DENY_PAYER_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_DENY_PAYER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_DENY_PAYER_004"><text>"Nao Credenciado", "Fora Rede"</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_DENY_PAYER_004"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_DENY_PAYER_004"><text>"GLOSA CERTA: Prestador fora da rede credenciada Amil. Procedimento nao sera reembolsado sem autorizacao previa de atendimento fora rede."</text></outputEntry>
        <outputEntry id="_DENY_PAYER_004"><text></text></outputEntry>
        <outputEntry id="_DENY_PAYER_004_2"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_DENY_PAYER_004"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA 2: BLOQUEIO - Tabela de contrato invalida -->
      <rule id="Rule_Block_2_DENY_PAYER_004">
        <description>Amil com tabela de contrato desatualizada ou invalida</description>
        <inputEntry id="InputEntry_B2_1_DENY_PAYER_004"><text>"AMIL", "326305"</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_DENY_PAYER_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_DENY_PAYER_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_DENY_PAYER_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_DENY_PAYER_004"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_DENY_PAYER_004"><text>"GLOSA CERTA: Tabela de contrato Amil invalida ou desatualizada. Verificar vigencia da tabela antes de faturar."</text></outputEntry>
        <outputEntry id="_DENY_PAYER_004_3"><text></text></outputEntry>
        <outputEntry id="_DENY_PAYER_004_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_DENY_PAYER_004"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA 3: ALERTA - Rede parcial -->
      <rule id="Rule_Alert_1_DENY_PAYER_004">
        <description>Amil com rede parcialmente credenciada</description>
        <inputEntry id="InputEntry_A1_1_DENY_PAYER_004"><text>"AMIL", "326305"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_DENY_PAYER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_DENY_PAYER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_DENY_PAYER_004"><text>"Parcial", "Restrita"</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_DENY_PAYER_004"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_DENY_PAYER_004"><text>"ATENCAO: Rede Amil parcialmente credenciada para este servico. Verificar se procedimento especifico esta coberto."</text></outputEntry>
        <outputEntry id="_DENY_PAYER_004_5"><text></text></outputEntry>
        <outputEntry id="_DENY_PAYER_004_6"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_DENY_PAYER_004"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA 4: ALERTA - Plano com restricao de rede -->
      <rule id="Rule_Alert_2_DENY_PAYER_004">
        <description>Amil com plano que restringe rede de atendimento</description>
        <inputEntry id="InputEntry_A2_1_DENY_PAYER_004"><text>"AMIL", "326305"</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_DENY_PAYER_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_DENY_PAYER_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_DENY_PAYER_004"><text>"Rede Essencial", "Rede Basica"</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_DENY_PAYER_004"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_DENY_PAYER_004"><text>"RISCO: Plano Amil com rede restrita (Essencial/Basica). Verificar se prestador esta na rede especifica do plano."</text></outputEntry>
        <outputEntry id="_DENY_PAYER_004_7"><text></text></outputEntry>
        <outputEntry id="_DENY_PAYER_004_8"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_DENY_PAYER_004"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA 5: PROSSEGUIR - Rede completa e tabela valida -->
      <rule id="Rule_Proceed_1_DENY_PAYER_004">
        <description>Amil credenciado com tabela valida</description>
        <inputEntry id="InputEntry_P1_1_DENY_PAYER_004"><text>"AMIL", "326305"</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_DENY_PAYER_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_DENY_PAYER_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_DENY_PAYER_004"><text>"Completa", "Total", "Premium"</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_DENY_PAYER_004"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_DENY_PAYER_004"><text>"Amil com rede completa e tabela valida. Faturar normalmente."</text></outputEntry>
        <outputEntry id="_DENY_PAYER_004_9"><text></text></outputEntry>
        <outputEntry id="_DENY_PAYER_004_10"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_DENY_PAYER_004"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA 6: PROSSEGUIR - Credenciado padrao -->
      <rule id="Rule_Proceed_2_DENY_PAYER_004">
        <description>Procedimento padrao Amil credenciado</description>
        <inputEntry id="InputEntry_P2_1_DENY_PAYER_004"><text>"AMIL", "326305"</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_DENY_PAYER_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_DENY_PAYER_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_DENY_PAYER_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_DENY_PAYER_004"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_DENY_PAYER_004"><text>"Prestador credenciado Amil com tabela valida."</text></outputEntry>
        <outputEntry id="_DENY_PAYER_004_11"><text></text></outputEntry>
        <outputEntry id="_DENY_PAYER_004_12"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_DENY_PAYER_004"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA 7: REVISAR - Outras operadoras -->
      <rule id="Rule_Review_1_DENY_PAYER_004">
        <description>Regra nao aplicavel - operadora nao e Amil</description>
        <inputEntry id="InputEntry_R1_1_DENY_PAYER_004"><text>not("AMIL", "326305")</text></inputEntry>
        <inputEntry id="InputEntry_R1_2_DENY_PAYER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_R1_3_DENY_PAYER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_R1_4_DENY_PAYER_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_R1_1_DENY_PAYER_004"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_R1_2_DENY_PAYER_004"><text>"Operadora nao e Amil. Esta regra nao se aplica."</text></outputEntry>
        <outputEntry id="_DENY_PAYER_004_13"><text></text></outputEntry>
        <outputEntry id="_DENY_PAYER_004_14"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_R1_3_DENY_PAYER_004"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA FALLBACK -->
      <rule id="Rule_Fallback_DENY_PAYER_004">
        <description>Caso padrao Amil - verificar credenciamento</description>
        <inputEntry id="InputEntry_F_1_DENY_PAYER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_DENY_PAYER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_DENY_PAYER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_DENY_PAYER_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_DENY_PAYER_004"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_DENY_PAYER_004"><text>"Verificar status de credenciamento e tabela de contrato Amil."</text></outputEntry>
        <outputEntry id="_DENY_PAYER_004_15"><text></text></outputEntry>
        <outputEntry id="_DENY_PAYER_004_16"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_F_3_DENY_PAYER_004"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DENY_PAYER_004">
      <dmndi:DMNShape id="DMNShape_Decision_DENY_PAYER_004" dmnElementRef="Decision_DENY_PAYER_004">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
