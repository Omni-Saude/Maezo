<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_glosa_reason_adjudication"
             name="Glosa Reason Adjudication"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Glosa Reason Analysis Adjudication
       For: analyze_glosa_reason_worker
       Archetype: ADMIN_ADJUDICATION
       Purpose: Map keyword patterns to reason codes
  -->

  <decision id="Decision_glosa_reason_adjudication" name="[SP-RC-007 | glosa_prevention/reason_analysis] Glosa Reason Adjudication" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_glosa_reason_adjudication" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_1_glosa_reason_adjudication" label="Description">
        <inputExpression id="InputExpr_1_glosa_reason_adjudication" typeRef="string">
          <text>description</text>
        </inputExpression>
      </input>

      <input id="Input_2_glosa_reason_adjudication" label="Glosa Type">
        <inputExpression id="InputExpr_2_glosa_reason_adjudication" typeRef="string">
          <text>glosaType</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado_glosa_reason_adjudication" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_glosa_reason_adjudication" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_glosa_reason_adjudication" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Autorização ausente -->
      <rule id="Rule_1_glosa_reason_adjudication">
        <description>Autorização ausente - MISSING_AUTH</description>
        <inputEntry id="IE_1_1_glosa_reason_adjudication"><text>contains(lower(description), "autorização") and contains(lower(description), "ausente")</text></inputEntry>
        <inputEntry id="IE_1_2_glosa_reason_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_1_res_glosa_reason_adjudication"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_acao_glosa_reason_adjudication"><text>"Glosa por autorização ausente - MISSING_AUTH"</text></outputEntry>
        <outputEntry id="OE_1_risco_glosa_reason_adjudication"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Autorização vencida -->
      <rule id="Rule_2_glosa_reason_adjudication">
        <description>Autorização vencida - EXPIRED_AUTH</description>
        <inputEntry id="IE_2_1_glosa_reason_adjudication"><text>contains(lower(description), "autorização") and contains(lower(description), "vencida")</text></inputEntry>
        <inputEntry id="IE_2_2_glosa_reason_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_2_res_glosa_reason_adjudication"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_2_acao_glosa_reason_adjudication"><text>"Glosa por autorização vencida - EXPIRED_AUTH"</text></outputEntry>
        <outputEntry id="OE_2_risco_glosa_reason_adjudication"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Cobrança duplicada -->
      <rule id="Rule_3_glosa_reason_adjudication">
        <description>Cobrança duplicada - DUPLICATE_CHARGE</description>
        <inputEntry id="IE_3_1_glosa_reason_adjudication"><text>contains(lower(description), "duplicad")</text></inputEntry>
        <inputEntry id="IE_3_2_glosa_reason_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_3_res_glosa_reason_adjudication"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_3_acao_glosa_reason_adjudication"><text>"Cobrança duplicada - DUPLICATE_CHARGE"</text></outputEntry>
        <outputEntry id="OE_3_risco_glosa_reason_adjudication"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Não coberto -->
      <rule id="Rule_4_glosa_reason_adjudication">
        <description>Não coberto - NOT_COVERED</description>
        <inputEntry id="IE_4_1_glosa_reason_adjudication"><text>contains(lower(description), "cobertura")</text></inputEntry>
        <inputEntry id="IE_4_2_glosa_reason_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_4_res_glosa_reason_adjudication"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_4_acao_glosa_reason_adjudication"><text>"Não coberto - NOT_COVERED"</text></outputEntry>
        <outputEntry id="OE_4_risco_glosa_reason_adjudication"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Código incompatível -->
      <rule id="Rule_5_glosa_reason_adjudication">
        <description>Procedimento incompatível - INCOMPATIBLE_PROCEDURE</description>
        <inputEntry id="IE_5_1_glosa_reason_adjudication"><text>contains(lower(description), "código") and contains(lower(description), "incompatível")</text></inputEntry>
        <inputEntry id="IE_5_2_glosa_reason_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_5_res_glosa_reason_adjudication"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_5_acao_glosa_reason_adjudication"><text>"Procedimento incompatível - INCOMPATIBLE_PROCEDURE"</text></outputEntry>
        <outputEntry id="OE_5_risco_glosa_reason_adjudication"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 6: Documentação incompleta -->
      <rule id="Rule_6_glosa_reason_adjudication">
        <description>Documentação incompleta - MISSING_DOCUMENTATION</description>
        <inputEntry id="IE_6_1_glosa_reason_adjudication"><text>contains(lower(description), "documentação")</text></inputEntry>
        <inputEntry id="IE_6_2_glosa_reason_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_6_res_glosa_reason_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_6_acao_glosa_reason_adjudication"><text>"Documentação incompleta - MISSING_DOCUMENTATION"</text></outputEntry>
        <outputEntry id="OE_6_risco_glosa_reason_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 7: Código incorreto -->
      <rule id="Rule_7_glosa_reason_adjudication">
        <description>Código incorreto - WRONG_CODE</description>
        <inputEntry id="IE_7_1_glosa_reason_adjudication"><text>contains(lower(description), "código")</text></inputEntry>
        <inputEntry id="IE_7_2_glosa_reason_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_7_res_glosa_reason_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_7_acao_glosa_reason_adjudication"><text>"Código incorreto - WRONG_CODE"</text></outputEntry>
        <outputEntry id="OE_7_risco_glosa_reason_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 8: Quantidade excedida -->
      <rule id="Rule_8_glosa_reason_adjudication">
        <description>Quantidade excedida - EXCEEDS_QUANTITY</description>
        <inputEntry id="IE_8_1_glosa_reason_adjudication"><text>contains(lower(description), "quantidade")</text></inputEntry>
        <inputEntry id="IE_8_2_glosa_reason_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_8_res_glosa_reason_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_8_acao_glosa_reason_adjudication"><text>"Quantidade excedida - EXCEEDS_QUANTITY"</text></outputEntry>
        <outputEntry id="OE_8_risco_glosa_reason_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 9: Divergência de preço -->
      <rule id="Rule_9_glosa_reason_adjudication">
        <description>Divergência de preço - PRICE_DIVERGENCE</description>
        <inputEntry id="IE_9_1_glosa_reason_adjudication"><text>contains(lower(description), "preço") or contains(lower(description), "valor")</text></inputEntry>
        <inputEntry id="IE_9_2_glosa_reason_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_9_res_glosa_reason_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_9_acao_glosa_reason_adjudication"><text>"Divergência de preço - PRICE_DIVERGENCE"</text></outputEntry>
        <outputEntry id="OE_9_risco_glosa_reason_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 10: Validação TISS -->
      <rule id="Rule_10_glosa_reason_adjudication">
        <description>Validação TISS - TISS_VALIDATION</description>
        <inputEntry id="IE_10_1_glosa_reason_adjudication"><text>contains(lower(description), "tiss")</text></inputEntry>
        <inputEntry id="IE_10_2_glosa_reason_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_10_res_glosa_reason_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_10_acao_glosa_reason_adjudication"><text>"Validação TISS - TISS_VALIDATION"</text></outputEntry>
        <outputEntry id="OE_10_risco_glosa_reason_adjudication"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="Rule_fallback_glosa_reason_adjudication">
        <description>Caso não enquadrado — revisão obrigatória</description>
        <inputEntry id="IE_fb_1_glosa_reason_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2_glosa_reason_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res_glosa_reason_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao_glosa_reason_adjudication"><text>"Caso requer avaliação manual"</text></outputEntry>
        <outputEntry id="OE_fb_risco_glosa_reason_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1_glosa_reason_adjudication">
      <dmndi:DMNShape id="DMNShape_Decision_glosa_reason_adjudication" dmnElementRef="Decision_glosa_reason_adjudication">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
