<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DENY-APPEAL-001 - Recurso Administrativo
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: DENY-APPEAL
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_DENY_APPEAL_001" name="Recurso Administrativo" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_DENY_APPEAL_001" name="[SP-RC-007 | glosa_prevention/appeal] Avaliacao Recurso Administrativo" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_APPEAL_001" hitPolicy="FIRST">

      
      <input id="Input_1_DENY_APPEAL_001" label="Prazo Recurso (dias restantes)">
        <inputExpression id="InputExpression_1_DENY_APPEAL_001" typeRef="number">
          <text>prazoRecurso</text>
        </inputExpression>
      </input>

      <input id="Input_2_DENY_APPEAL_001" label="Documentacao Anexada">
        <inputExpression id="InputExpression_2_DENY_APPEAL_001" typeRef="string">
          <text>documentacaoAnexada</text>
        </inputExpression>
        <inputValues id="InputValues_2_DENY_APPEAL_001">
          <text>"COMPLETA", "PARCIAL", "INSUFICIENTE"</text>
        </inputValues>
      </input>

      <input id="Input_3_DENY_APPEAL_001" label="Fundamentacao Legal">
        <inputExpression id="InputExpression_3_DENY_APPEAL_001" typeRef="string">
          <text>fundamentacaoLegal</text>
        </inputExpression>
        <inputValues id="InputValues_3_DENY_APPEAL_001">
          <text>"FORTE", "MODERADA", "FRACA", "INEXISTENTE"</text>
        </inputValues>
      </input>

      <input id="Input_4_DENY_APPEAL_001" label="Valor em Discussao">
        <inputExpression id="InputExpression_4_DENY_APPEAL_001" typeRef="number">
          <text>valorDiscussao</text>
        </inputExpression>
      </input>

      <input id="Input_5_DENY_APPEAL_001" label="Instancia">
        <inputExpression id="InputExpression_5_DENY_APPEAL_001" typeRef="string">
          <text>instancia</text>
        </inputExpression>
        <inputValues id="InputValues_5_DENY_APPEAL_001">
          <text>"PRIMEIRA", "SEGUNDA", "FINAL"</text>
        </inputValues>
      </input>

      
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_DENY_APPEAL_001" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_DENY_APPEAL_001" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_DENY_APPEAL_001" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_DENY_APPEAL_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_DENY_APPEAL_001" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Contraindicacao_1_DENY_APPEAL_001">
        <description>Prazo de recurso expirado</description>
        <inputEntry id="InputEntry_C1_1_DENY_APPEAL_001"><text>&lt;= 0</text></inputEntry>
        <inputEntry id="InputEntry_C1_2_DENY_APPEAL_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C1_3_DENY_APPEAL_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C1_4_DENY_APPEAL_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C1_5_DENY_APPEAL_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_C1_1_DENY_APPEAL_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_C1_2_DENY_APPEAL_001"><text>"Prazo de recurso administrativo expirado. ANS RN 395/2016 estabelece prazo peremptorio."</text></outputEntry>
<outputEntry id="OutputEntry_C1_3_DENY_APPEAL_001"><text>"DESISTIR"</text></outputEntry>
<outputEntry id="Rule_Contraindicacao_1_outputEntry_alertasConformidade_DENY_APPEAL_001"><text>"DOC"</text></outputEntry>
<outputEntry id="Rule_Contraindicacao_1_outputEntry_riscoDenial_DENY_APPEAL_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Contraindicacao_2_DENY_APPEAL_001">
        <description>Recurso em instancia final - via administrativa esgotada</description>
        <inputEntry id="InputEntry_C2_1_DENY_APPEAL_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C2_2_DENY_APPEAL_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C2_3_DENY_APPEAL_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C2_4_DENY_APPEAL_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C2_5_DENY_APPEAL_001"><text>"FINAL"</text></inputEntry>
<outputEntry id="OutputEntry_C2_1_DENY_APPEAL_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_C2_2_DENY_APPEAL_001"><text>"Via administrativa esgotada. Considerar reclamacao ANS ou acao judicial."</text></outputEntry>
<outputEntry id="OutputEntry_C2_3_DENY_APPEAL_001"><text>"ESCALAR_ANS"</text></outputEntry>
<outputEntry id="Rule_Contraindicacao_2_outputEntry_alertasConformidade_DENY_APPEAL_001"><text>"DOC"</text></outputEntry>
<outputEntry id="Rule_Contraindicacao_2_outputEntry_riscoDenial_DENY_APPEAL_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alerta_1_DENY_APPEAL_001">
        <description>Prazo de recurso em situacao critica</description>
        <inputEntry id="InputEntry_A1_1_DENY_APPEAL_001"><text>[1..3]</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_DENY_APPEAL_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_DENY_APPEAL_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_DENY_APPEAL_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_DENY_APPEAL_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_DENY_APPEAL_001"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_DENY_APPEAL_001"><text>"Prazo de recurso critico (menos de 3 dias). Priorizar protocolo imediato mesmo com documentacao parcial."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_DENY_APPEAL_001"><text>"INTERPOR_RECURSO"</text></outputEntry>
<outputEntry id="Rule_Alerta_1_outputEntry_alertasConformidade_DENY_APPEAL_001"><text>"DOC"</text></outputEntry>
<outputEntry id="Rule_Alerta_1_outputEntry_riscoDenial_DENY_APPEAL_001"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_1_DENY_APPEAL_001">
        <description>Recurso elegivel com documentacao completa</description>
        <inputEntry id="InputEntry_P1_1_DENY_APPEAL_001"><text>&gt; 3</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_DENY_APPEAL_001"><text>"COMPLETA"</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_DENY_APPEAL_001"><text>"FORTE", "MODERADA"</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_DENY_APPEAL_001"><text>&gt;= 100</text></inputEntry>
        <inputEntry id="InputEntry_P1_5_DENY_APPEAL_001"><text>"PRIMEIRA", "SEGUNDA"</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_DENY_APPEAL_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_DENY_APPEAL_001"><text>"Recurso administrativo elegivel. Documentacao completa e fundamentacao adequada."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_DENY_APPEAL_001"><text>"INTERPOR_RECURSO"</text></outputEntry>
<outputEntry id="Rule_Aprovado_1_outputEntry_alertasConformidade_DENY_APPEAL_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Aprovado_1_outputEntry_riscoDenial_DENY_APPEAL_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_2_DENY_APPEAL_001">
        <description>Recurso com documentacao parcial - tempo para complementar</description>
        <inputEntry id="InputEntry_P2_1_DENY_APPEAL_001"><text>&gt; 5</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_DENY_APPEAL_001"><text>"PARCIAL"</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_DENY_APPEAL_001"><text>"FORTE", "MODERADA"</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_DENY_APPEAL_001"><text>&gt;= 500</text></inputEntry>
        <inputEntry id="InputEntry_P2_5_DENY_APPEAL_001"><text>"PRIMEIRA"</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_DENY_APPEAL_001"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_DENY_APPEAL_001"><text>"Recurso elegivel mas documentacao incompleta. Completar documentacao antes do prazo."</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_DENY_APPEAL_001"><text>"COMPLEMENTAR_DOCS"</text></outputEntry>
<outputEntry id="Rule_Aprovado_2_outputEntry_alertasConformidade_DENY_APPEAL_001"><text>"DOC"</text></outputEntry>
<outputEntry id="Rule_Aprovado_2_outputEntry_riscoDenial_DENY_APPEAL_001"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_DENY_APPEAL_001">
        <description>Caso nao atenda criterios automaticos - Revisar</description>
        <inputEntry id="InputEntry_F_1_DENY_APPEAL_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_DENY_APPEAL_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_DENY_APPEAL_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_DENY_APPEAL_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_DENY_APPEAL_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_DENY_APPEAL_001"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_DENY_APPEAL_001"><text>"Recurso administrativo requer analise manual. Avaliar prazo, documentacao e fundamentacao."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_DENY_APPEAL_001"><text>"COMPLEMENTAR_DOCS"</text></outputEntry>
<outputEntry id="Rule_Fallback_DENY_APPEAL_001_outputEntry_alertasConformidade"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Fallback_DENY_APPEAL_001_outputEntry_riscoDenial"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DENY_APPEAL_001">
      <dmndi:DMNShape id="DMNShape_Decision_DENY_APPEAL_001" dmnElementRef="Decision_DENY_APPEAL_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>