<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DENY-TIMING-006 - Documentacao Deadline
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: DENY-TIMING
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_DENY_TIMING_006" name="Documentacao Deadline" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_DENY_TIMING_006" name="[SP-RC-007 | glosa_prevention/timing] Verificar Prazo Documentacao" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_TIMING_006" hitPolicy="FIRST">
      <input id="Input_1_DENY_TIMING_006" label="Dias Para Envio Documentacao">
        <inputExpression id="InputExpression_1_DENY_TIMING_006" typeRef="number"><text>diasParaEnvioDoc</text></inputExpression>
      </input>
      <input id="Input_2_DENY_TIMING_006" label="Documentacao Enviada">
        <inputExpression id="InputExpression_2_DENY_TIMING_006" typeRef="boolean"><text>documentacaoEnviada</text></inputExpression>
      </input>
      <input id="Input_3_DENY_TIMING_006" label="Prazo Convenio">
        <inputExpression id="InputExpression_3_DENY_TIMING_006" typeRef="number"><text>prazoConvenio</text></inputExpression>
      </input>
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_DENY_TIMING_006" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_DENY_TIMING_006" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_DENY_TIMING_006" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_DENY_TIMING_006" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_DENY_TIMING_006" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Block_1_DENY_TIMING_006">
        <description>Prazo de envio de documentacao expirado</description>
        <inputEntry id="InputEntry_B1_1_DENY_TIMING_006"><text>&lt; 0</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_DENY_TIMING_006"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_DENY_TIMING_006"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_DENY_TIMING_006"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_DENY_TIMING_006"><text>"GLOSA CERTA: Prazo para envio de documentacao expirado."</text></outputEntry>
        <outputEntry id="_DENY_TIMING_006"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_1_4_DENY_TIMING_006"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_DENY_TIMING_006"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_Alert_1_DENY_TIMING_006">
        <inputEntry id="InputEntry_A1_1_DENY_TIMING_006"><text>[0..3]</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_DENY_TIMING_006"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_DENY_TIMING_006"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_DENY_TIMING_006"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_DENY_TIMING_006"><text>"RISCO CRITICO: Prazo de documentacao expirando."</text></outputEntry>
        <outputEntry id="_DENY_TIMING_006_2"><text></text></outputEntry>
<outputEntry id="OutputEntry_Alert_1_4_DENY_TIMING_006"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_DENY_TIMING_006"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_Proceed_1_DENY_TIMING_006">
        <inputEntry id="InputEntry_P1_1_DENY_TIMING_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_DENY_TIMING_006"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_DENY_TIMING_006"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_DENY_TIMING_006"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_DENY_TIMING_006"><text>"Documentacao enviada dentro do prazo."</text></outputEntry>
        <outputEntry id="_DENY_TIMING_006_3"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_1_4_DENY_TIMING_006"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_DENY_TIMING_006"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_Fallback_DENY_TIMING_006">
        <inputEntry id="InputEntry_F_1_DENY_TIMING_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_DENY_TIMING_006"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_DENY_TIMING_006"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_DENY_TIMING_006"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_DENY_TIMING_006"><text>"Verificar prazo de documentacao."</text></outputEntry>
        <outputEntry id="_DENY_TIMING_006_4"><text></text></outputEntry>
<outputEntry id="OutputEntry_Fallback_4_DENY_TIMING_006"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_F_3_DENY_TIMING_006"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_DENY_TIMING_006">
      <dmndi:DMNShape id="DMNShape_Decision_DENY_TIMING_006" dmnElementRef="Decision_DENY_TIMING_006">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>