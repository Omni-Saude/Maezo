<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DENY-TIMING-007 - Resposta Deadline Tracking
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: DENY-TIMING
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_DENY_TIMING_007" name="Resposta Deadline Tracking" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_DENY_TIMING_007" name="[SP-RC-007 | glosa_prevention/timing] Verificar Prazo Resposta" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_TIMING_007" hitPolicy="FIRST">
      <input id="Input_1_DENY_TIMING_007" label="Dias Aguardando Resposta">
        <inputExpression id="InputExpression_1_DENY_TIMING_007" typeRef="number"><text>diasAguardandoResposta</text></inputExpression>
      </input>
      <input id="Input_2_DENY_TIMING_007" label="Prazo Resposta Operadora">
        <inputExpression id="InputExpression_2_DENY_TIMING_007" typeRef="number"><text>prazoRespostaOperadora</text></inputExpression>
      </input>
      <input id="Input_3_DENY_TIMING_007" label="Tipo Solicitacao">
        <inputExpression id="InputExpression_3_DENY_TIMING_007" typeRef="string"><text>tipoSolicitacao</text></inputExpression>
      </input>
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_DENY_TIMING_007" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_DENY_TIMING_007" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_DENY_TIMING_007" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_DENY_TIMING_007" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_DENY_TIMING_007" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Alert_1_DENY_TIMING_007">
        <description>Operadora nao respondeu no prazo - tacita aprovacao</description>
        <inputEntry id="InputEntry_A1_1_DENY_TIMING_007"><text>&gt; 21</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_DENY_TIMING_007"><text>21</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_DENY_TIMING_007"><text>"Autorizacao"</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_DENY_TIMING_007"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_DENY_TIMING_007"><text>"ACAO: Operadora excedeu prazo de 21 dias. Tacita aprovacao conforme RN 395."</text></outputEntry>
        <outputEntry id="_DENY_TIMING_007"><text></text></outputEntry>
<outputEntry id="OutputEntry_Alert_1_4_DENY_TIMING_007"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_DENY_TIMING_007"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_Alert_2_DENY_TIMING_007">
        <inputEntry id="InputEntry_A2_1_DENY_TIMING_007"><text>[18..21]</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_DENY_TIMING_007"><text>21</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_DENY_TIMING_007"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_DENY_TIMING_007"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_DENY_TIMING_007"><text>"ATENCAO: Prazo de resposta da operadora expirando."</text></outputEntry>
        <outputEntry id="_DENY_TIMING_007_2"><text></text></outputEntry>
<outputEntry id="OutputEntry_Alert_2_4_DENY_TIMING_007"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_DENY_TIMING_007"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_Proceed_1_DENY_TIMING_007">
        <inputEntry id="InputEntry_P1_1_DENY_TIMING_007"><text>&lt; 18</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_DENY_TIMING_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_DENY_TIMING_007"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_DENY_TIMING_007"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_DENY_TIMING_007"><text>"Aguardando resposta dentro do prazo."</text></outputEntry>
        <outputEntry id="_DENY_TIMING_007_3"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_1_4_DENY_TIMING_007"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_DENY_TIMING_007"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_Fallback_DENY_TIMING_007">
        <inputEntry id="InputEntry_F_1_DENY_TIMING_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_DENY_TIMING_007"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_DENY_TIMING_007"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_DENY_TIMING_007"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_DENY_TIMING_007"><text>"Verificar prazo de resposta."</text></outputEntry>
        <outputEntry id="_DENY_TIMING_007_4"><text></text></outputEntry>
<outputEntry id="OutputEntry_Fallback_4_DENY_TIMING_007"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_F_3_DENY_TIMING_007"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_DENY_TIMING_007">
      <dmndi:DMNShape id="DMNShape_Decision_DENY_TIMING_007" dmnElementRef="Decision_DENY_TIMING_007">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>