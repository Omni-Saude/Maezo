<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  DENY-TIMING-005 - Autorizacao Previa Timing
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: DENY-TIMING
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_DENY_TIMING_005" name="Autorizacao Previa Timing" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_DENY_TIMING_005" name="[SP-RC-007 | glosa_prevention/timing] Verificar Timing Autorizacao" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DENY_TIMING_005" hitPolicy="FIRST">
      <input id="Input_1_DENY_TIMING_005" label="Dias Antes Procedimento">
        <inputExpression id="InputExpression_1_DENY_TIMING_005" typeRef="number"><text>diasAntesAtendimento</text></inputExpression>
      </input>
      <input id="Input_2_DENY_TIMING_005" label="Autorizacao Obtida">
        <inputExpression id="InputExpression_2_DENY_TIMING_005" typeRef="boolean"><text>autorizacaoObtida</text></inputExpression>
      </input>
      <input id="Input_3_DENY_TIMING_005" label="Tipo Procedimento">
        <inputExpression id="InputExpression_3_DENY_TIMING_005" typeRef="string"><text>tipoProcedimento</text></inputExpression>
      </input>
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_DENY_TIMING_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_DENY_TIMING_005" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_DENY_TIMING_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_DENY_TIMING_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_DENY_TIMING_005" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Block_1_DENY_TIMING_005">
        <description>Procedimento eletivo sem autorizacao previa</description>
        <inputEntry id="InputEntry_B1_1_DENY_TIMING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_DENY_TIMING_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_DENY_TIMING_005"><text>"Eletivo"</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_DENY_TIMING_005"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_DENY_TIMING_005"><text>"GLOSA CERTA: Procedimento eletivo realizado sem autorizacao previa."</text></outputEntry>
        <outputEntry id="_DENY_TIMING_005"><text></text></outputEntry>
<outputEntry id="OutputEntry_Block_1_4_DENY_TIMING_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_DENY_TIMING_005"><text>"CRITICO"</text></outputEntry>
      </rule>
      <rule id="Rule_Alert_1_DENY_TIMING_005">
        <inputEntry id="InputEntry_A1_1_DENY_TIMING_005"><text>&lt; 3</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_DENY_TIMING_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_DENY_TIMING_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_DENY_TIMING_005"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_DENY_TIMING_005"><text>"RISCO MEDIO: Autorizacao obtida muito proxima do procedimento."</text></outputEntry>
        <outputEntry id="_DENY_TIMING_005_2"><text></text></outputEntry>
<outputEntry id="OutputEntry_Alert_1_4_DENY_TIMING_005"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_DENY_TIMING_005"><text>"MEDIO"</text></outputEntry>
      </rule>
      <rule id="Rule_Proceed_1_DENY_TIMING_005">
        <inputEntry id="InputEntry_P1_1_DENY_TIMING_005"><text>&gt;= 3</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_DENY_TIMING_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_DENY_TIMING_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_DENY_TIMING_005"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_DENY_TIMING_005"><text>"Autorizacao obtida com antecedencia adequada."</text></outputEntry>
        <outputEntry id="_DENY_TIMING_005_3"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_1_4_DENY_TIMING_005"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_DENY_TIMING_005"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_Proceed_2_DENY_TIMING_005">
        <inputEntry id="InputEntry_P2_1_DENY_TIMING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_DENY_TIMING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_DENY_TIMING_005"><text>"Emergencia", "Urgencia"</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_DENY_TIMING_005"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_DENY_TIMING_005"><text>"Emergencia/Urgencia - autorizacao posterior permitida."</text></outputEntry>
        <outputEntry id="_DENY_TIMING_005_4"><text></text></outputEntry>
<outputEntry id="OutputEntry_Proceed_2_4_DENY_TIMING_005"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_DENY_TIMING_005"><text>"BAIXO"</text></outputEntry>
      </rule>
      <rule id="Rule_Fallback_DENY_TIMING_005">
        <inputEntry id="InputEntry_F_1_DENY_TIMING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_DENY_TIMING_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_DENY_TIMING_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_DENY_TIMING_005"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_DENY_TIMING_005"><text>"Verificar timing da autorizacao."</text></outputEntry>
        <outputEntry id="_DENY_TIMING_005_5"><text></text></outputEntry>
<outputEntry id="OutputEntry_Fallback_4_DENY_TIMING_005"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_F_3_DENY_TIMING_005"><text>"MEDIO"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_DENY_TIMING_005">
      <dmndi:DMNShape id="DMNShape_Decision_DENY_TIMING_005" dmnElementRef="Decision_DENY_TIMING_005">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>