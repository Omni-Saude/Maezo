<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_legal_escalation_threshold" name="Legal Escalation Threshold" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: escalate_to_legal_worker.py -->
  <decision id="Decision_legal_escalation_threshold" name="[SP-RC-013 | collection_escalation] Legal Escalation Threshold" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_legal_escalation_threshold" hitPolicy="FIRST">
      <input id="Input_attempts_legal_escalation_threshold" label="Tentativas Cobranca"><inputExpression id="IE_att_legal_escalation_threshold" typeRef="integer"><text>collection_attempts</text></inputExpression></input>
      <input id="Input_has_reason_legal_escalation_threshold" label="Razao Explicita"><inputExpression id="IE_reason_legal_escalation_threshold" typeRef="boolean"><text>has_explicit_reason</text></inputExpression></input>
      <output id="Output_resultado_legal_escalation_threshold" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao_legal_escalation_threshold" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_legal_escalation_threshold" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1_legal_escalation_threshold"><inputEntry id="U1a_legal_escalation_threshold"><text></text></inputEntry><inputEntry id="U1b_legal_escalation_threshold"><text>true</text></inputEntry><outputEntry id="L1_legal_escalation_threshold"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L1a_legal_escalation_threshold"><text>"Escalacao por razao explicita - processar"</text></outputEntry><outputEntry id="L1b_legal_escalation_threshold"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2_legal_escalation_threshold"><inputEntry id="U2a_legal_escalation_threshold"><text>>= 10</text></inputEntry><inputEntry id="U2b_legal_escalation_threshold"><text></text></inputEntry><outputEntry id="L2_legal_escalation_threshold"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L2a_legal_escalation_threshold"><text>"Esgotadas tentativas de cobranca"</text></outputEntry><outputEntry id="L2b_legal_escalation_threshold"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_3_legal_escalation_threshold"><inputEntry id="U3a_legal_escalation_threshold"><text>[5..10)</text></inputEntry><inputEntry id="U3b_legal_escalation_threshold"><text></text></inputEntry><outputEntry id="L3_legal_escalation_threshold"><text>"REVISAR"</text></outputEntry><outputEntry id="L3a_legal_escalation_threshold"><text>"Muitas tentativas - considerar juridico"</text></outputEntry><outputEntry id="L3b_legal_escalation_threshold"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_4_legal_escalation_threshold"><inputEntry id="U4a_legal_escalation_threshold"><text>[3..5)</text></inputEntry><inputEntry id="U4b_legal_escalation_threshold"><text></text></inputEntry><outputEntry id="L4_legal_escalation_threshold"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a_legal_escalation_threshold"><text>"Continuar tentativas de cobranca"</text></outputEntry><outputEntry id="L4b_legal_escalation_threshold"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_5_legal_escalation_threshold"><inputEntry id="U5a_legal_escalation_threshold"><text>&lt; 3</text></inputEntry><inputEntry id="U5b_legal_escalation_threshold"><text></text></inputEntry><outputEntry id="L5_legal_escalation_threshold"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a_legal_escalation_threshold"><text>"Poucas tentativas - insistir"</text></outputEntry><outputEntry id="L5b_legal_escalation_threshold"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_legal_escalation_threshold">
      <dmndi:DMNShape id="DMNShape_Decision_legal_escalation_threshold" dmnElementRef="Decision_legal_escalation_threshold">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
