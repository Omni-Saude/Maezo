<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_collection_call_threshold" name="Collection Call Threshold" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: schedule_collection_call_worker.py -->
  <decision id="Decision_collection_call_threshold" name="[SP-RC-013 | collection_escalation] Collection Call Threshold" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_collection_call_threshold" hitPolicy="FIRST">
      <input id="Input_days_overdue_t_collection_call_threshold" label="Dias Vencidos"><inputExpression id="IE_days_overdue_t_collection_call_threshold" typeRef="integer"><text>days_overdue</text></inputExpression></input>
      <output id="Output_resultado_collection_call_threshold" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao_collection_call_threshold" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_collection_call_threshold" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1_collection_call_threshold"><inputEntry id="U1_collection_call_threshold"><text>> 90</text></inputEntry><outputEntry id="L1_collection_call_threshold"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L1a_collection_call_threshold"><text>"Ligacao com SLA minimo"</text></outputEntry><outputEntry id="L1b_collection_call_threshold"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2_collection_call_threshold"><inputEntry id="U2_collection_call_threshold"><text>(60..90]</text></inputEntry><outputEntry id="L2_collection_call_threshold"><text>"REVISAR"</text></outputEntry><outputEntry id="L2a_collection_call_threshold"><text>"Agendar ligacao prioritaria"</text></outputEntry><outputEntry id="L2b_collection_call_threshold"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_3_collection_call_threshold"><inputEntry id="U3_collection_call_threshold"><text>(30..60]</text></inputEntry><outputEntry id="L3_collection_call_threshold"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L3a_collection_call_threshold"><text>"Agendar ligacao normal"</text></outputEntry><outputEntry id="L3b_collection_call_threshold"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_4_collection_call_threshold"><inputEntry id="U4_collection_call_threshold"><text>(7..30]</text></inputEntry><outputEntry id="L4_collection_call_threshold"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a_collection_call_threshold"><text>"Fila normal de ligacoes"</text></outputEntry><outputEntry id="L4b_collection_call_threshold"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_5_collection_call_threshold"><inputEntry id="U5_collection_call_threshold"><text>&lt;= 7</text></inputEntry><outputEntry id="L5_collection_call_threshold"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a_collection_call_threshold"><text>"Enviar lembrete antes de ligar"</text></outputEntry><outputEntry id="L5b_collection_call_threshold"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_collection_call_threshold">
      <dmndi:DMNShape id="DMNShape_Decision_collection_call_threshold" dmnElementRef="Decision_collection_call_threshold">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
