<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_overdue_identification_scoring" name="Overdue Identification Scoring" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: identify_overdue_worker.py -->
  <decision id="Decision_overdue_identification_scoring" name="[SP-RC-013 | collection_escalation] Overdue Identification Scoring" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_overdue_identification_scoring" hitPolicy="FIRST">
      <input id="Input_days_overdue_overdue_identification_scoring" label="Dias Vencidos"><inputExpression id="IE_days_overdue_overdue_identification_scoring" typeRef="integer"><text>days_overdue</text></inputExpression></input>
      <input id="Input_amount_due_overdue_identification_scoring" label="Valor Devido"><inputExpression id="IE_amount_due_overdue_identification_scoring" typeRef="double"><text>amount_due</text></inputExpression></input>
      <output id="Output_resultado_overdue_identification_scoring" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao_overdue_identification_scoring" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_overdue_identification_scoring" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1_overdue_identification_scoring"><inputEntry id="U1a_overdue_identification_scoring"><text>>= 180</text></inputEntry><inputEntry id="U1b_overdue_identification_scoring"><text>>= 50000</text></inputEntry><outputEntry id="L1_overdue_identification_scoring"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L1a_overdue_identification_scoring"><text>"Vencimento critico com alto valor"</text></outputEntry><outputEntry id="L1b_overdue_identification_scoring"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2_overdue_identification_scoring"><inputEntry id="U2a_overdue_identification_scoring"><text>>= 120</text></inputEntry><inputEntry id="U2b_overdue_identification_scoring"><text></text></inputEntry><outputEntry id="L2_overdue_identification_scoring"><text>"REVISAR"</text></outputEntry><outputEntry id="L2a_overdue_identification_scoring"><text>"Vencido ha mais de 120 dias"</text></outputEntry><outputEntry id="L2b_overdue_identification_scoring"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_3_overdue_identification_scoring"><inputEntry id="U3a_overdue_identification_scoring"><text>[60..120)</text></inputEntry><inputEntry id="U3b_overdue_identification_scoring"><text></text></inputEntry><outputEntry id="L3_overdue_identification_scoring"><text>"REVISAR"</text></outputEntry><outputEntry id="L3a_overdue_identification_scoring"><text>"Cobranca ativa necessaria"</text></outputEntry><outputEntry id="L3b_overdue_identification_scoring"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_4_overdue_identification_scoring"><inputEntry id="U4a_overdue_identification_scoring"><text>[1..60)</text></inputEntry><inputEntry id="U4b_overdue_identification_scoring"><text></text></inputEntry><outputEntry id="L4_overdue_identification_scoring"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a_overdue_identification_scoring"><text>"Enviar lembrete de pagamento"</text></outputEntry><outputEntry id="L4b_overdue_identification_scoring"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_5_overdue_identification_scoring"><inputEntry id="U5a_overdue_identification_scoring"><text>&lt;= 0</text></inputEntry><inputEntry id="U5b_overdue_identification_scoring"><text></text></inputEntry><outputEntry id="L5_overdue_identification_scoring"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a_overdue_identification_scoring"><text>"Ainda nao vencido"</text></outputEntry><outputEntry id="L5b_overdue_identification_scoring"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_overdue_identification_scoring">
      <dmndi:DMNShape id="DMNShape_Decision_overdue_identification_scoring" dmnElementRef="Decision_overdue_identification_scoring">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
