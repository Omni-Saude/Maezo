<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  LEGAL-THRESHOLD - Limites para Escalacao Juridica
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_ESCALATION
  Archetype: THRESHOLD | Source: escalate_to_legal_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_LEGAL_THRESHOLD"
             name="Limites para Escalacao Juridica"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_LEGAL_THRESHOLD" name="[SP-RC-013 | collection_escalation] Limites para Escalacao Juridica" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_LEGAL_THRESHOLD" hitPolicy="FIRST">

      <input id="Input_1_LEGAL_THRESHOLD" label="Dias em Atraso">
        <inputExpression id="InputExpression_1_LEGAL_THRESHOLD" typeRef="number">
          <text>daysOverdue</text>
        </inputExpression>
      </input>

      <input id="Input_2_LEGAL_THRESHOLD" label="Valor Devedor">
        <inputExpression id="InputExpression_2_LEGAL_THRESHOLD" typeRef="number">
          <text>amountDue</text>
        </inputExpression>
      </input>

      <input id="Input_3_LEGAL_THRESHOLD" label="Tentativas Cobranca">
        <inputExpression id="InputExpression_3_LEGAL_THRESHOLD" typeRef="number">
          <text>collectionAttempts</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado_LEGAL_THRESHOLD" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_LEGAL_THRESHOLD" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_LEGAL_THRESHOLD" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1_LEGAL_THRESHOLD">
        <description>180+ dias e valor alto - escalacao juridica imediata</description>
        <inputEntry id="IE_1_1_LEGAL_THRESHOLD"><text>&gt;= 180</text></inputEntry>
        <inputEntry id="IE_1_2_LEGAL_THRESHOLD"><text>&gt;= 50000</text></inputEntry>
        <inputEntry id="IE_1_3_LEGAL_THRESHOLD"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1_LEGAL_THRESHOLD"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_1_2_LEGAL_THRESHOLD"><text>"Criterios de escalacao juridica atingidos - encaminhar ao departamento legal"</text></outputEntry>
        <outputEntry id="OE_1_3_LEGAL_THRESHOLD"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2_LEGAL_THRESHOLD">
        <description>360+ dias qualquer valor - prescricao iminente</description>
        <inputEntry id="IE_2_1_LEGAL_THRESHOLD"><text>&gt;= 360</text></inputEntry>
        <inputEntry id="IE_2_2_LEGAL_THRESHOLD"><text>-</text></inputEntry>
        <inputEntry id="IE_2_3_LEGAL_THRESHOLD"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1_LEGAL_THRESHOLD"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_2_2_LEGAL_THRESHOLD"><text>"Risco de prescricao - escalacao juridica urgente independente do valor"</text></outputEntry>
        <outputEntry id="OE_2_3_LEGAL_THRESHOLD"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_3_LEGAL_THRESHOLD">
        <description>Muitas tentativas sem sucesso</description>
        <inputEntry id="IE_3_1_LEGAL_THRESHOLD"><text>[90..180]</text></inputEntry>
        <inputEntry id="IE_3_2_LEGAL_THRESHOLD"><text>&gt;= 20000</text></inputEntry>
        <inputEntry id="IE_3_3_LEGAL_THRESHOLD"><text>&gt;= 5</text></inputEntry>
        <outputEntry id="OE_3_1_LEGAL_THRESHOLD"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_3_2_LEGAL_THRESHOLD"><text>"Esgotamento de tentativas administrativas - avaliar escalacao juridica"</text></outputEntry>
        <outputEntry id="OE_3_3_LEGAL_THRESHOLD"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_4_LEGAL_THRESHOLD">
        <description>Valor baixo - nao justifica custo juridico</description>
        <inputEntry id="IE_4_1_LEGAL_THRESHOLD"><text>-</text></inputEntry>
        <inputEntry id="IE_4_2_LEGAL_THRESHOLD"><text>&lt; 5000</text></inputEntry>
        <inputEntry id="IE_4_3_LEGAL_THRESHOLD"><text>-</text></inputEntry>
        <outputEntry id="OE_4_1_LEGAL_THRESHOLD"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_4_2_LEGAL_THRESHOLD"><text>"Valor abaixo de R$5k - custo juridico nao justifica a acao"</text></outputEntry>
        <outputEntry id="OE_4_3_LEGAL_THRESHOLD"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_5_LEGAL_THRESHOLD">
        <description>Atraso moderado - continuar cobranca administrativa</description>
        <inputEntry id="IE_5_1_LEGAL_THRESHOLD"><text>&lt; 90</text></inputEntry>
        <inputEntry id="IE_5_2_LEGAL_THRESHOLD"><text>-</text></inputEntry>
        <inputEntry id="IE_5_3_LEGAL_THRESHOLD"><text>&lt; 3</text></inputEntry>
        <outputEntry id="OE_5_1_LEGAL_THRESHOLD"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_5_2_LEGAL_THRESHOLD"><text>"Prazo e tentativas insuficientes - manter cobranca administrativa"</text></outputEntry>
        <outputEntry id="OE_5_3_LEGAL_THRESHOLD"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_LEGAL_THRESHOLD">
        <description>Fallback</description>
        <inputEntry id="IE_F_1_LEGAL_THRESHOLD"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_LEGAL_THRESHOLD"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3_LEGAL_THRESHOLD"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_LEGAL_THRESHOLD"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2_LEGAL_THRESHOLD"><text>"Avaliar necessidade de escalacao juridica"</text></outputEntry>
        <outputEntry id="OE_F_3_LEGAL_THRESHOLD"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_LEGAL_THRESHOLD">
      <dmndi:DMNShape id="DMNShape_Decision_LEGAL_THRESHOLD" dmnElementRef="Decision_LEGAL_THRESHOLD">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
