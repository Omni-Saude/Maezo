<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_whatsapp_reminder_scoring" name="Whatsapp Reminder Scoring" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: send_whatsapp_reminder_worker.py -->
  <decision id="Decision_whatsapp_reminder_scoring" name="[SP-RC-013 | collection_escalation] Whatsapp Reminder Scoring" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_whatsapp_reminder_scoring" hitPolicy="FIRST">
      <input id="Input_days_overdue_whatsapp_reminder_scoring" label="Dias Vencidos"><inputExpression id="IE_days_overdue_whatsapp_reminder_scoring" typeRef="integer"><text>days_overdue</text></inputExpression></input>
      <input id="Input_amount_due_whatsapp_reminder_scoring" label="Valor Devido"><inputExpression id="IE_amount_due_whatsapp_reminder_scoring" typeRef="double"><text>amount_due</text></inputExpression></input>
      <output id="Output_resultado_whatsapp_reminder_scoring" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao_whatsapp_reminder_scoring" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_whatsapp_reminder_scoring" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1_whatsapp_reminder_scoring"><inputEntry id="U1a_whatsapp_reminder_scoring"><text>> 60</text></inputEntry><inputEntry id="U1b_whatsapp_reminder_scoring"><text>>= 10000</text></inputEntry><outputEntry id="L1_whatsapp_reminder_scoring"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L1a_whatsapp_reminder_scoring"><text>"Template final - ultima tentativa via WhatsApp"</text></outputEntry><outputEntry id="L1b_whatsapp_reminder_scoring"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2_whatsapp_reminder_scoring"><inputEntry id="U2a_whatsapp_reminder_scoring"><text>(30..60]</text></inputEntry><inputEntry id="U2b_whatsapp_reminder_scoring"><text></text></inputEntry><outputEntry id="L2_whatsapp_reminder_scoring"><text>"REVISAR"</text></outputEntry><outputEntry id="L2a_whatsapp_reminder_scoring"><text>"Template urgente com link pagamento"</text></outputEntry><outputEntry id="L2b_whatsapp_reminder_scoring"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_3_whatsapp_reminder_scoring"><inputEntry id="U3a_whatsapp_reminder_scoring"><text>(7..30]</text></inputEntry><inputEntry id="U3b_whatsapp_reminder_scoring"><text></text></inputEntry><outputEntry id="L3_whatsapp_reminder_scoring"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L3a_whatsapp_reminder_scoring"><text>"Template urgente - lembrete"</text></outputEntry><outputEntry id="L3b_whatsapp_reminder_scoring"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_4_whatsapp_reminder_scoring"><inputEntry id="U4a_whatsapp_reminder_scoring"><text>[1..7]</text></inputEntry><inputEntry id="U4b_whatsapp_reminder_scoring"><text></text></inputEntry><outputEntry id="L4_whatsapp_reminder_scoring"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a_whatsapp_reminder_scoring"><text>"Template gentil - lembrete inicial"</text></outputEntry><outputEntry id="L4b_whatsapp_reminder_scoring"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_5_whatsapp_reminder_scoring"><inputEntry id="U5a_whatsapp_reminder_scoring"><text>&lt; 1</text></inputEntry><inputEntry id="U5b_whatsapp_reminder_scoring"><text></text></inputEntry><outputEntry id="L5_whatsapp_reminder_scoring"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a_whatsapp_reminder_scoring"><text>"Ainda nao vencido - nao enviar"</text></outputEntry><outputEntry id="L5b_whatsapp_reminder_scoring"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_whatsapp_reminder_scoring">
      <dmndi:DMNShape id="DMNShape_Decision_whatsapp_reminder_scoring" dmnElementRef="Decision_whatsapp_reminder_scoring">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
