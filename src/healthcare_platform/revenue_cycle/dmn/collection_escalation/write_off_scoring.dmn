<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_write_off_scoring" name="Write Off Scoring" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: write_off_bad_debt_worker.py -->
  <decision id="Decision_write_off_scoring" name="[SP-RC-013 | collection_escalation] Write Off Scoring" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_write_off_scoring" hitPolicy="FIRST">
      <input id="Input_amount_due_write_off_scoring" label="Valor Devido"><inputExpression id="IE_amount_due_write_off_scoring" typeRef="double"><text>amount_due</text></inputExpression></input>
      <input id="Input_days_overdue_write_off_scoring" label="Dias Vencidos"><inputExpression id="IE_days_overdue_write_off_scoring" typeRef="integer"><text>days_overdue</text></inputExpression></input>
      <output id="Output_resultado_write_off_scoring" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao_write_off_scoring" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_write_off_scoring" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1_write_off_scoring"><inputEntry id="U1a_write_off_scoring"><text>>= 10000</text></inputEntry><inputEntry id="U1b_write_off_scoring"><text>>= 360</text></inputEntry><outputEntry id="L1_write_off_scoring"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L1a_write_off_scoring"><text>"Write-off alto valor - requer aprovacao gerencial"</text></outputEntry><outputEntry id="L1b_write_off_scoring"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2_write_off_scoring"><inputEntry id="U2a_write_off_scoring"><text>>= 10000</text></inputEntry><inputEntry id="U2b_write_off_scoring"><text>[180..360)</text></inputEntry><outputEntry id="L2_write_off_scoring"><text>"REVISAR"</text></outputEntry><outputEntry id="L2a_write_off_scoring"><text>"Avaliar write-off vs juridico"</text></outputEntry><outputEntry id="L2b_write_off_scoring"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_3_write_off_scoring"><inputEntry id="U3a_write_off_scoring"><text>[1000..10000)</text></inputEntry><inputEntry id="U3b_write_off_scoring"><text>>= 180</text></inputEntry><outputEntry id="L3_write_off_scoring"><text>"REVISAR"</text></outputEntry><outputEntry id="L3a_write_off_scoring"><text>"Write-off medio valor - supervisor aprova"</text></outputEntry><outputEntry id="L3b_write_off_scoring"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_4_write_off_scoring"><inputEntry id="U4a_write_off_scoring"><text>&lt; 1000</text></inputEntry><inputEntry id="U4b_write_off_scoring"><text>>= 180</text></inputEntry><outputEntry id="L4_write_off_scoring"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a_write_off_scoring"><text>"Write-off baixo valor - auto-aprovacao"</text></outputEntry><outputEntry id="L4b_write_off_scoring"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_5_write_off_scoring"><inputEntry id="U5a_write_off_scoring"><text></text></inputEntry><inputEntry id="U5b_write_off_scoring"><text>&lt; 180</text></inputEntry><outputEntry id="L5_write_off_scoring"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a_write_off_scoring"><text>"Ainda nao elegivel para write-off"</text></outputEntry><outputEntry id="L5b_write_off_scoring"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_write_off_scoring">
      <dmndi:DMNShape id="DMNShape_Decision_write_off_scoring" dmnElementRef="Decision_write_off_scoring">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
