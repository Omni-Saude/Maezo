<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_collection_call_scoring" name="Collection Call Scoring" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: schedule_collection_call_worker.py -->
  <decision id="Decision_collection_call_scoring" name="[SP-RC-013 | collection_escalation] Collection Call Scoring" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_collection_call_scoring" hitPolicy="FIRST">
      <input id="Input_days_overdue_collection_call_scoring" label="Dias Vencidos"><inputExpression id="IE_days_overdue_collection_call_scoring" typeRef="integer"><text>days_overdue</text></inputExpression></input>
      <input id="Input_priority_collection_call_scoring" label="Prioridade"><inputExpression id="IE_priority_collection_call_scoring" typeRef="string"><text>priority</text></inputExpression></input>
      <output id="Output_resultado_collection_call_scoring" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao_collection_call_scoring" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_collection_call_scoring" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1_collection_call_scoring"><inputEntry id="U1a_collection_call_scoring"><text>> 90</text></inputEntry><inputEntry id="U1b_collection_call_scoring"><text>"CRITICAL"</text></inputEntry><outputEntry id="L1_collection_call_scoring"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L1a_collection_call_scoring"><text>"Ligacao urgente - SLA 4 horas"</text></outputEntry><outputEntry id="L1b_collection_call_scoring"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2_collection_call_scoring"><inputEntry id="U2a_collection_call_scoring"><text>> 60</text></inputEntry><inputEntry id="U2b_collection_call_scoring"><text>"HIGH"</text></inputEntry><outputEntry id="L2_collection_call_scoring"><text>"REVISAR"</text></outputEntry><outputEntry id="L2a_collection_call_scoring"><text>"Agendar ligacao prioritaria - SLA 24h"</text></outputEntry><outputEntry id="L2b_collection_call_scoring"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_3_collection_call_scoring"><inputEntry id="U3a_collection_call_scoring"><text>[30..60]</text></inputEntry><inputEntry id="U3b_collection_call_scoring"><text>"MEDIUM"</text></inputEntry><outputEntry id="L3_collection_call_scoring"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L3a_collection_call_scoring"><text>"Agendar ligacao - SLA 48h"</text></outputEntry><outputEntry id="L3b_collection_call_scoring"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_4_collection_call_scoring"><inputEntry id="U4a_collection_call_scoring"><text>[7..30)</text></inputEntry><inputEntry id="U4b_collection_call_scoring"><text></text></inputEntry><outputEntry id="L4_collection_call_scoring"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a_collection_call_scoring"><text>"Agendar ligacao - SLA 72h"</text></outputEntry><outputEntry id="L4b_collection_call_scoring"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_5_collection_call_scoring"><inputEntry id="U5a_collection_call_scoring"><text>&lt; 7</text></inputEntry><inputEntry id="U5b_collection_call_scoring"><text></text></inputEntry><outputEntry id="L5_collection_call_scoring"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a_collection_call_scoring"><text>"Recente - enviar lembrete antes"</text></outputEntry><outputEntry id="L5b_collection_call_scoring"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_collection_call_scoring">
      <dmndi:DMNShape id="DMNShape_Decision_collection_call_scoring" dmnElementRef="Decision_collection_call_scoring">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
