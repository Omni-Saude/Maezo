<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_penalties_scoring" name="Penalties Scoring" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: apply_penalties_worker.py -->
  <decision id="Decision_penalties_scoring" name="[SP-RC-013 | collection_escalation] Penalties Scoring" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_penalties_scoring" hitPolicy="FIRST">
      <input id="Input_days_overdue_penalties_scoring" label="Dias Vencidos"><inputExpression id="IE_days_overdue_penalties_scoring" typeRef="integer"><text>days_overdue</text></inputExpression></input>
      <input id="Input_principal_amount_penalties_scoring" label="Valor Principal"><inputExpression id="IE_principal_amount_penalties_scoring" typeRef="double"><text>principal_amount</text></inputExpression></input>
      <output id="Output_resultado_penalties_scoring" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao_penalties_scoring" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_penalties_scoring" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1_penalties_scoring"><inputEntry id="U1a_penalties_scoring"><text>>= 180</text></inputEntry><inputEntry id="U1b_penalties_scoring"><text>>= 50000</text></inputEntry><outputEntry id="L1_penalties_scoring"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L1a_penalties_scoring"><text>"Penalidades maximas aplicaveis - juridico"</text></outputEntry><outputEntry id="L1b_penalties_scoring"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2_penalties_scoring"><inputEntry id="U2a_penalties_scoring"><text>[90..180)</text></inputEntry><inputEntry id="U2b_penalties_scoring"><text>>= 10000</text></inputEntry><outputEntry id="L2_penalties_scoring"><text>"REVISAR"</text></outputEntry><outputEntry id="L2a_penalties_scoring"><text>"Aplicar multa 2% + juros SELIC"</text></outputEntry><outputEntry id="L2b_penalties_scoring"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_3_penalties_scoring"><inputEntry id="U3a_penalties_scoring"><text>[30..90)</text></inputEntry><inputEntry id="U3b_penalties_scoring"><text></text></inputEntry><outputEntry id="L3_penalties_scoring"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L3a_penalties_scoring"><text>"Aplicar juros pro-rata"</text></outputEntry><outputEntry id="L3b_penalties_scoring"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_4_penalties_scoring"><inputEntry id="U4a_penalties_scoring"><text>[1..30)</text></inputEntry><inputEntry id="U4b_penalties_scoring"><text></text></inputEntry><outputEntry id="L4_penalties_scoring"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a_penalties_scoring"><text>"Aplicar multa minima"</text></outputEntry><outputEntry id="L4b_penalties_scoring"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_5_penalties_scoring"><inputEntry id="U5a_penalties_scoring"><text>&lt; 1</text></inputEntry><inputEntry id="U5b_penalties_scoring"><text></text></inputEntry><outputEntry id="L5_penalties_scoring"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a_penalties_scoring"><text>"Sem penalidades - ainda no prazo"</text></outputEntry><outputEntry id="L5b_penalties_scoring"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_penalties_scoring">
      <dmndi:DMNShape id="DMNShape_Decision_penalties_scoring" dmnElementRef="Decision_penalties_scoring">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
