<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  PREDICTION-TREND - Analise de Tendencia de Cobranca
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_FORECASTING
  Archetype: CLINICAL_SCORE | Source: predict_collection_date_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_PRED_TREND"
             name="Analise de Tendencia de Cobranca"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_PRED_TREND" name="[SP-RC-011 | collection_forecasting] Analise de Tendencia de Cobranca" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_PRED_TREND" hitPolicy="FIRST">

      <input id="Input_1_PRED_TREND" label="Coeficiente Tendencia">
        <inputExpression id="InputExpression_1_PRED_TREND" typeRef="number">
          <text>trendCoefficient</text>
        </inputExpression>
      </input>

      <input id="Input_2_PRED_TREND" label="Variancia Residual">
        <inputExpression id="InputExpression_2_PRED_TREND" typeRef="number">
          <text>residualVariance</text>
        </inputExpression>
      </input>

      <input id="Input_3_PRED_TREND" label="Periodos Analisados">
        <inputExpression id="InputExpression_3_PRED_TREND" typeRef="number">
          <text>periodsAnalyzed</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado_PRED_TREND" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_PRED_TREND" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_PRED_TREND" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1_PRED_TREND">
        <description>Tendencia fortemente negativa - queda na arrecadacao</description>
        <inputEntry id="IE_1_1_PRED_TREND"><text>&lt; -0.3</text></inputEntry>
        <inputEntry id="IE_1_2_PRED_TREND"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3_PRED_TREND"><text>&gt;= 6</text></inputEntry>
        <outputEntry id="OE_1_1_PRED_TREND"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2_PRED_TREND"><text>"Tendencia de queda significativa - acionar plano de recuperacao"</text></outputEntry>
        <outputEntry id="OE_1_3_PRED_TREND"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2_PRED_TREND">
        <description>Tendencia negativa moderada com alta variancia</description>
        <inputEntry id="IE_2_1_PRED_TREND"><text>[-0.3..0]</text></inputEntry>
        <inputEntry id="IE_2_2_PRED_TREND"><text>&gt; 0.5</text></inputEntry>
        <inputEntry id="IE_2_3_PRED_TREND"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1_PRED_TREND"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_2_PRED_TREND"><text>"Tendencia instavel - investigar causas da variabilidade"</text></outputEntry>
        <outputEntry id="OE_2_3_PRED_TREND"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_3_PRED_TREND">
        <description>Tendencia estavel com baixa variancia</description>
        <inputEntry id="IE_3_1_PRED_TREND"><text>[-0.1..0.1]</text></inputEntry>
        <inputEntry id="IE_3_2_PRED_TREND"><text>&lt;= 0.2</text></inputEntry>
        <inputEntry id="IE_3_3_PRED_TREND"><text>&gt;= 3</text></inputEntry>
        <outputEntry id="OE_3_1_PRED_TREND"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_3_2_PRED_TREND"><text>"Tendencia estavel - previsoes confiaveis"</text></outputEntry>
        <outputEntry id="OE_3_3_PRED_TREND"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_4_PRED_TREND">
        <description>Tendencia positiva - melhoria na arrecadacao</description>
        <inputEntry id="IE_4_1_PRED_TREND"><text>&gt; 0.1</text></inputEntry>
        <inputEntry id="IE_4_2_PRED_TREND"><text>&lt;= 0.3</text></inputEntry>
        <inputEntry id="IE_4_3_PRED_TREND"><text>&gt;= 4</text></inputEntry>
        <outputEntry id="OE_4_1_PRED_TREND"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2_PRED_TREND"><text>"Tendencia positiva consistente - manter estrategia atual"</text></outputEntry>
        <outputEntry id="OE_4_3_PRED_TREND"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_5_PRED_TREND">
        <description>Poucos periodos para analise confiavel</description>
        <inputEntry id="IE_5_1_PRED_TREND"><text>-</text></inputEntry>
        <inputEntry id="IE_5_2_PRED_TREND"><text>-</text></inputEntry>
        <inputEntry id="IE_5_3_PRED_TREND"><text>&lt; 3</text></inputEntry>
        <outputEntry id="OE_5_1_PRED_TREND"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_5_2_PRED_TREND"><text>"Dados insuficientes para tendencia - aguardar mais periodos"</text></outputEntry>
        <outputEntry id="OE_5_3_PRED_TREND"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_PRED_TREND">
        <description>Fallback</description>
        <inputEntry id="IE_F_1_PRED_TREND"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_PRED_TREND"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3_PRED_TREND"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_PRED_TREND"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2_PRED_TREND"><text>"Avaliar tendencia manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3_PRED_TREND"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PRED_TREND">
      <dmndi:DMNShape id="DMNShape_Decision_PRED_TREND" dmnElementRef="Decision_PRED_TREND">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
