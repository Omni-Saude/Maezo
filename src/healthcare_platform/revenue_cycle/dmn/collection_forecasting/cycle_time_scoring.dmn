<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  CYCLE-TIME-SCORING - Scoring de Tempo de Ciclo de Receita
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_FORECASTING
  Archetype: CLINICAL_SCORE | Source: calculate_revenue_cycle_time_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_CYCLE_TIME_SCORING"
             name="Scoring de Tempo de Ciclo de Receita"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_CYCLE_TIME_SCORING" name="[SP-RC-011 | collection_forecasting] Scoring de Tempo de Ciclo de Receita" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_CYCLE_TIME_SCORING" hitPolicy="FIRST">

      <input id="Input_1_CYCLE_TIME_SCORING" label="Tempo Medio Ciclo (dias)">
        <inputExpression id="InputExpression_1_CYCLE_TIME_SCORING" typeRef="number">
          <text>avgCycleTimeDays</text>
        </inputExpression>
      </input>

      <input id="Input_2_CYCLE_TIME_SCORING" label="Tempo Maximo Ciclo (dias)">
        <inputExpression id="InputExpression_2_CYCLE_TIME_SCORING" typeRef="number">
          <text>maxCycleTimeDays</text>
        </inputExpression>
      </input>

      <input id="Input_3_CYCLE_TIME_SCORING" label="Total Encounters">
        <inputExpression id="InputExpression_3_CYCLE_TIME_SCORING" typeRef="number">
          <text>totalEncounters</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado_CYCLE_TIME_SCORING" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_CYCLE_TIME_SCORING" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_CYCLE_TIME_SCORING" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1_CYCLE_TIME_SCORING">
        <description>Ciclo excessivamente longo - problemas sistemicos</description>
        <inputEntry id="IE_1_1_CYCLE_TIME_SCORING"><text>&gt; 90</text></inputEntry>
        <inputEntry id="IE_1_2_CYCLE_TIME_SCORING"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3_CYCLE_TIME_SCORING"><text>&gt;= 10</text></inputEntry>
        <outputEntry id="OE_1_1_CYCLE_TIME_SCORING"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2_CYCLE_TIME_SCORING"><text>"Ciclo medio acima de 90 dias - investigar gargalos no processo"</text></outputEntry>
        <outputEntry id="OE_1_3_CYCLE_TIME_SCORING"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2_CYCLE_TIME_SCORING">
        <description>Ciclo longo com outliers extremos</description>
        <inputEntry id="IE_2_1_CYCLE_TIME_SCORING"><text>[60..90]</text></inputEntry>
        <inputEntry id="IE_2_2_CYCLE_TIME_SCORING"><text>&gt; 180</text></inputEntry>
        <inputEntry id="IE_2_3_CYCLE_TIME_SCORING"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1_CYCLE_TIME_SCORING"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_2_CYCLE_TIME_SCORING"><text>"Ciclo longo com outliers - analisar casos atipicos"</text></outputEntry>
        <outputEntry id="OE_2_3_CYCLE_TIME_SCORING"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_3_CYCLE_TIME_SCORING">
        <description>Ciclo moderado</description>
        <inputEntry id="IE_3_1_CYCLE_TIME_SCORING"><text>[45..60]</text></inputEntry>
        <inputEntry id="IE_3_2_CYCLE_TIME_SCORING"><text>-</text></inputEntry>
        <inputEntry id="IE_3_3_CYCLE_TIME_SCORING"><text>-</text></inputEntry>
        <outputEntry id="OE_3_1_CYCLE_TIME_SCORING"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_3_2_CYCLE_TIME_SCORING"><text>"Ciclo dentro do esperado para o mercado brasileiro"</text></outputEntry>
        <outputEntry id="OE_3_3_CYCLE_TIME_SCORING"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_4_CYCLE_TIME_SCORING">
        <description>Ciclo otimo</description>
        <inputEntry id="IE_4_1_CYCLE_TIME_SCORING"><text>[30..45]</text></inputEntry>
        <inputEntry id="IE_4_2_CYCLE_TIME_SCORING"><text>-</text></inputEntry>
        <inputEntry id="IE_4_3_CYCLE_TIME_SCORING"><text>-</text></inputEntry>
        <outputEntry id="OE_4_1_CYCLE_TIME_SCORING"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2_CYCLE_TIME_SCORING"><text>"Ciclo otimo - manter praticas atuais"</text></outputEntry>
        <outputEntry id="OE_4_3_CYCLE_TIME_SCORING"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_5_CYCLE_TIME_SCORING">
        <description>Ciclo excelente</description>
        <inputEntry id="IE_5_1_CYCLE_TIME_SCORING"><text>&lt; 30</text></inputEntry>
        <inputEntry id="IE_5_2_CYCLE_TIME_SCORING"><text>-</text></inputEntry>
        <inputEntry id="IE_5_3_CYCLE_TIME_SCORING"><text>&gt;= 5</text></inputEntry>
        <outputEntry id="OE_5_1_CYCLE_TIME_SCORING"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_2_CYCLE_TIME_SCORING"><text>"Ciclo excelente - benchmark positivo"</text></outputEntry>
        <outputEntry id="OE_5_3_CYCLE_TIME_SCORING"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_6_CYCLE_TIME_SCORING">
        <description>Amostra insuficiente</description>
        <inputEntry id="IE_6_1_CYCLE_TIME_SCORING"><text>-</text></inputEntry>
        <inputEntry id="IE_6_2_CYCLE_TIME_SCORING"><text>-</text></inputEntry>
        <inputEntry id="IE_6_3_CYCLE_TIME_SCORING"><text>&lt; 3</text></inputEntry>
        <outputEntry id="OE_6_1_CYCLE_TIME_SCORING"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_6_2_CYCLE_TIME_SCORING"><text>"Poucos encounters - resultado estatisticamente insignificante"</text></outputEntry>
        <outputEntry id="OE_6_3_CYCLE_TIME_SCORING"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_CYCLE_TIME_SCORING">
        <description>Fallback</description>
        <inputEntry id="IE_F_1_CYCLE_TIME_SCORING"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_CYCLE_TIME_SCORING"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3_CYCLE_TIME_SCORING"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_CYCLE_TIME_SCORING"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2_CYCLE_TIME_SCORING"><text>"Avaliar tempo de ciclo manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3_CYCLE_TIME_SCORING"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_CYCLE_TIME_SCORING">
      <dmndi:DMNShape id="DMNShape_Decision_CYCLE_TIME_SCORING" dmnElementRef="Decision_CYCLE_TIME_SCORING">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
