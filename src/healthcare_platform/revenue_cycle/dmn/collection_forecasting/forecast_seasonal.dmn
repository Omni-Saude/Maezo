<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  FORECAST-SEASONAL - Ajuste Sazonal de Previsao
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_FORECASTING
  Archetype: CLINICAL_SCORE | Source: update_forecasts_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_FORECAST_SEASONAL"
             name="Ajuste Sazonal de Previsao"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_FORECAST_SEASONAL" name="[SP-RC-011 | collection_forecasting] Ajuste Sazonal de Previsao" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_FORECAST_SEASONAL" hitPolicy="FIRST">

      <input id="Input_1_FORECAST_SEASONAL" label="Mes Referencia">
        <inputExpression id="InputExpression_1_FORECAST_SEASONAL" typeRef="number">
          <text>referenceMonth</text>
        </inputExpression>
      </input>

      <input id="Input_2_FORECAST_SEASONAL" label="Tipo Pagador">
        <inputExpression id="InputExpression_2_FORECAST_SEASONAL" typeRef="string">
          <text>payerType</text>
        </inputExpression>
      </input>

      <input id="Input_3_FORECAST_SEASONAL" label="Indice Sazonalidade">
        <inputExpression id="InputExpression_3_FORECAST_SEASONAL" typeRef="number">
          <text>seasonalityIndex</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado_FORECAST_SEASONAL" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_FORECAST_SEASONAL" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_FORECAST_SEASONAL" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1_FORECAST_SEASONAL">
        <description>Dezembro/Janeiro - alta sazonalidade SUS</description>
        <inputEntry id="IE_1_1_FORECAST_SEASONAL"><text>1,12</text></inputEntry>
        <inputEntry id="IE_1_2_FORECAST_SEASONAL"><text>"SUS"</text></inputEntry>
        <inputEntry id="IE_1_3_FORECAST_SEASONAL"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1_FORECAST_SEASONAL"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_1_2_FORECAST_SEASONAL"><text>"Periodo de alta sazonalidade SUS - ajustar previsao com fator 0.7"</text></outputEntry>
        <outputEntry id="OE_1_3_FORECAST_SEASONAL"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_2_FORECAST_SEASONAL">
        <description>Indice sazonalidade extremo - desvio significativo</description>
        <inputEntry id="IE_2_1_FORECAST_SEASONAL"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2_FORECAST_SEASONAL"><text>-</text></inputEntry>
        <inputEntry id="IE_2_3_FORECAST_SEASONAL"><text>&gt; 1.5</text></inputEntry>
        <outputEntry id="OE_2_1_FORECAST_SEASONAL"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_2_FORECAST_SEASONAL"><text>"Sazonalidade extrema - aplicar cap de ajuste em 1.5x"</text></outputEntry>
        <outputEntry id="OE_2_3_FORECAST_SEASONAL"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_3_FORECAST_SEASONAL">
        <description>Sazonalidade muito baixa - risco de subprevisao</description>
        <inputEntry id="IE_3_1_FORECAST_SEASONAL"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2_FORECAST_SEASONAL"><text>-</text></inputEntry>
        <inputEntry id="IE_3_3_FORECAST_SEASONAL"><text>&lt; 0.5</text></inputEntry>
        <outputEntry id="OE_3_1_FORECAST_SEASONAL"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_3_2_FORECAST_SEASONAL"><text>"Indice sazonal anomalo - verificar dados de entrada"</text></outputEntry>
        <outputEntry id="OE_3_3_FORECAST_SEASONAL"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_4_FORECAST_SEASONAL">
        <description>Operadora privada - sazonalidade moderada</description>
        <inputEntry id="IE_4_1_FORECAST_SEASONAL"><text>-</text></inputEntry>
        <inputEntry id="IE_4_2_FORECAST_SEASONAL"><text>"OPERADORA"</text></inputEntry>
        <inputEntry id="IE_4_3_FORECAST_SEASONAL"><text>[0.8..1.2]</text></inputEntry>
        <outputEntry id="OE_4_1_FORECAST_SEASONAL"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2_FORECAST_SEASONAL"><text>"Sazonalidade dentro do esperado para operadoras"</text></outputEntry>
        <outputEntry id="OE_4_3_FORECAST_SEASONAL"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_5_FORECAST_SEASONAL">
        <description>Particular - sem ajuste sazonal significativo</description>
        <inputEntry id="IE_5_1_FORECAST_SEASONAL"><text>-</text></inputEntry>
        <inputEntry id="IE_5_2_FORECAST_SEASONAL"><text>"PARTICULAR"</text></inputEntry>
        <inputEntry id="IE_5_3_FORECAST_SEASONAL"><text>[0.7..1.3]</text></inputEntry>
        <outputEntry id="OE_5_1_FORECAST_SEASONAL"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_2_FORECAST_SEASONAL"><text>"Particular com sazonalidade aceitavel"</text></outputEntry>
        <outputEntry id="OE_5_3_FORECAST_SEASONAL"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_FORECAST_SEASONAL">
        <description>Fallback</description>
        <inputEntry id="IE_F_1_FORECAST_SEASONAL"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_FORECAST_SEASONAL"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3_FORECAST_SEASONAL"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_FORECAST_SEASONAL"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2_FORECAST_SEASONAL"><text>"Avaliar ajuste sazonal manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3_FORECAST_SEASONAL"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_FORECAST_SEASONAL">
      <dmndi:DMNShape id="DMNShape_Decision_FORECAST_SEASONAL" dmnElementRef="Decision_FORECAST_SEASONAL">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
