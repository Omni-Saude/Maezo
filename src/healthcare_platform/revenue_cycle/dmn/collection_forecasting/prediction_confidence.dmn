<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  PREDICTION-CONFIDENCE - Avaliacao de Confianca da Predicao
  ============================================================================
  Versao: 1.0.0 (2026-02-14)
  Categoria: COLLECTION_FORECASTING
  Archetype: CLINICAL_SCORE | Source: predict_collection_date_worker.py
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_PRED_CONFIDENCE"
             name="Avaliacao de Confianca da Predicao"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_PRED_CONFIDENCE" name="[SP-RC-011 | collection_forecasting] Avaliacao de Confianca da Predicao" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_PRED_CONFIDENCE" hitPolicy="FIRST">

      <input id="Input_1_PRED_CONFIDENCE" label="Confianca Modelo">
        <inputExpression id="InputExpression_1_PRED_CONFIDENCE" typeRef="number">
          <text>confidence</text>
        </inputExpression>
      </input>

      <input id="Input_2_PRED_CONFIDENCE" label="Amostras Historicas">
        <inputExpression id="InputExpression_2_PRED_CONFIDENCE" typeRef="number">
          <text>historicalSamples</text>
        </inputExpression>
      </input>

      <input id="Input_3_PRED_CONFIDENCE" label="Tipo Modelo">
        <inputExpression id="InputExpression_3_PRED_CONFIDENCE" typeRef="string">
          <text>modelType</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS ========== -->
      <output id="Output_resultado_PRED_CONFIDENCE" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>
      <output id="Output_acao_PRED_CONFIDENCE" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_PRED_CONFIDENCE" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_1_PRED_CONFIDENCE">
        <description>Confianca muito baixa - modelo nao confiavel</description>
        <inputEntry id="IE_1_1_PRED_CONFIDENCE"><text>&lt; 0.3</text></inputEntry>
        <inputEntry id="IE_1_2_PRED_CONFIDENCE"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3_PRED_CONFIDENCE"><text>-</text></inputEntry>
        <outputEntry id="OE_1_1_PRED_CONFIDENCE"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_2_PRED_CONFIDENCE"><text>"Confianca abaixo de 30% - descartar predicao e usar estimativa manual"</text></outputEntry>
        <outputEntry id="OE_1_3_PRED_CONFIDENCE"><text>"CRITICO"</text></outputEntry>
      </rule>

      <rule id="Rule_2_PRED_CONFIDENCE">
        <description>Confianca baixa com poucas amostras</description>
        <inputEntry id="IE_2_1_PRED_CONFIDENCE"><text>[0.3..0.6]</text></inputEntry>
        <inputEntry id="IE_2_2_PRED_CONFIDENCE"><text>&lt; 5</text></inputEntry>
        <inputEntry id="IE_2_3_PRED_CONFIDENCE"><text>-</text></inputEntry>
        <outputEntry id="OE_2_1_PRED_CONFIDENCE"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_2_PRED_CONFIDENCE"><text>"Confianca moderada com poucos dados - validar com analista"</text></outputEntry>
        <outputEntry id="OE_2_3_PRED_CONFIDENCE"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_3_PRED_CONFIDENCE">
        <description>Confianca moderada com bom historico</description>
        <inputEntry id="IE_3_1_PRED_CONFIDENCE"><text>[0.6..0.8]</text></inputEntry>
        <inputEntry id="IE_3_2_PRED_CONFIDENCE"><text>&gt;= 5</text></inputEntry>
        <inputEntry id="IE_3_3_PRED_CONFIDENCE"><text>"linear_regression"</text></inputEntry>
        <outputEntry id="OE_3_1_PRED_CONFIDENCE"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_3_2_PRED_CONFIDENCE"><text>"Confianca aceitavel - usar predicao com monitoramento"</text></outputEntry>
        <outputEntry id="OE_3_3_PRED_CONFIDENCE"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_4_PRED_CONFIDENCE">
        <description>Confianca alta</description>
        <inputEntry id="IE_4_1_PRED_CONFIDENCE"><text>&gt;= 0.8</text></inputEntry>
        <inputEntry id="IE_4_2_PRED_CONFIDENCE"><text>&gt;= 8</text></inputEntry>
        <inputEntry id="IE_4_3_PRED_CONFIDENCE"><text>-</text></inputEntry>
        <outputEntry id="OE_4_1_PRED_CONFIDENCE"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_2_PRED_CONFIDENCE"><text>"Alta confianca - predicao confiavel para planejamento"</text></outputEntry>
        <outputEntry id="OE_4_3_PRED_CONFIDENCE"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_5_PRED_CONFIDENCE">
        <description>Modelo media simples - confianca limitada</description>
        <inputEntry id="IE_5_1_PRED_CONFIDENCE"><text>-</text></inputEntry>
        <inputEntry id="IE_5_2_PRED_CONFIDENCE"><text>-</text></inputEntry>
        <inputEntry id="IE_5_3_PRED_CONFIDENCE"><text>"average"</text></inputEntry>
        <outputEntry id="OE_5_1_PRED_CONFIDENCE"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_5_2_PRED_CONFIDENCE"><text>"Modelo media simples - confianca inerentemente limitada"</text></outputEntry>
        <outputEntry id="OE_5_3_PRED_CONFIDENCE"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_PRED_CONFIDENCE">
        <description>Fallback</description>
        <inputEntry id="IE_F_1_PRED_CONFIDENCE"><text>-</text></inputEntry>
        <inputEntry id="IE_F_2_PRED_CONFIDENCE"><text>-</text></inputEntry>
        <inputEntry id="IE_F_3_PRED_CONFIDENCE"><text>-</text></inputEntry>
        <outputEntry id="OE_F_1_PRED_CONFIDENCE"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F_2_PRED_CONFIDENCE"><text>"Avaliar confianca manualmente"</text></outputEntry>
        <outputEntry id="OE_F_3_PRED_CONFIDENCE"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_PRED_CONFIDENCE">
      <dmndi:DMNShape id="DMNShape_Decision_PRED_CONFIDENCE" dmnElementRef="Decision_PRED_CONFIDENCE">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
