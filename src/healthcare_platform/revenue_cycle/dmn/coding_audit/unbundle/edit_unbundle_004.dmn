<?xml version="1.0" encoding="UTF-8"?>
<!--
  EDIT-UNBUNDLE-004 - Honorario Ja Incluso no Pacote
  Versao: 1.0.0 (2026-02-08) | Categoria: EDIT-UNBUNDLE | Perspectiva: HOSPITAL (Auditoria Administrativa)
  Refs: RN ANS 465/2021, TISS 4.01.00, Lei 9.656/1998
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_EDIT_UNBUNDLE_004" name="Honorario Ja Incluso no Pacote" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_EDIT_UNBUNDLE_004" name="[SP-RC-005 | coding_audit/unbundle] Honorario Ja Incluso no Pacote" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_EDIT_UNBUNDLE_004" hitPolicy="FIRST">
      <input id="Input_1_EDIT_UNBUNDLE_004" label="Item Incluso"><inputExpression id="InputExpression_1_EDIT_UNBUNDLE_004" typeRef="boolean"><text>itemIncluso</text></inputExpression></input>
      <input id="Input_2_EDIT_UNBUNDLE_004" label="Tipo Pacote"><inputExpression id="InputExpression_2_EDIT_UNBUNDLE_004" typeRef="string"><text>tipoPacote</text></inputExpression><inputValues id="InputValues_2_EDIT_UNBUNDLE_004"><text>"DIARIA", "CIRURGIA", "PARTO", "EXAME"</text></inputValues></input>
      
      <output id="Output_1_EDIT_UNBUNDLE_004" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues></output>
      <output id="Output_2_EDIT_UNBUNDLE_004" label="Observacao" name="observacao" typeRef="string"/>
      <output id="Output_3_EDIT_UNBUNDLE_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>
      <output id="Output_4_EDIT_UNBUNDLE_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output>
      <output id="Output_5_EDIT_UNBUNDLE_004" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output>
      <rule id="Rule_1_EDIT_UNBUNDLE_004"><description>Honorario incluso - bloqueio</description><inputEntry id="InputEntry_1_1_EDIT_UNBUNDLE_004"><text>true</text></inputEntry><inputEntry id="InputEntry_1_2_EDIT_UNBUNDLE_004"><text>"CIRURGIA"</text></inputEntry><outputEntry id="OutputEntry_1_1_EDIT_UNBUNDLE_004"><text>"Bloquear"</text></outputEntry><outputEntry id="OutputEntry_1_2_EDIT_UNBUNDLE_004"><text>"GLOSA CERTA: Honorario JA INCLUSO no pacote cirurgico. Unbundling indevido."</text></outputEntry><outputEntry id="OutputEntry_1_3_EDIT_UNBUNDLE_004"><text>"Excluir honorario separado. Valor ja contemplado no pacote."</text></outputEntry><outputEntry id="OutputEntry_1_4_EDIT_UNBUNDLE_004"><text>"VALOR"</text></outputEntry><outputEntry id="OutputEntry_1_5_EDIT_UNBUNDLE_004"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2_EDIT_UNBUNDLE_004"><description>Honorario separado valido - prosseguir</description><inputEntry id="InputEntry_2_1_EDIT_UNBUNDLE_004"><text>false</text></inputEntry><inputEntry id="InputEntry_2_2_EDIT_UNBUNDLE_004"><text>-</text></inputEntry><outputEntry id="OutputEntry_2_1_EDIT_UNBUNDLE_004"><text>"Prosseguir"</text></outputEntry><outputEntry id="OutputEntry_2_2_EDIT_UNBUNDLE_004"><text>"Honorario nao incluso. Cobranca separada valida."</text></outputEntry><outputEntry id="OutputEntry_2_3_EDIT_UNBUNDLE_004"><text>"Prosseguir padrao."</text></outputEntry><outputEntry id="OutputEntry_2_4_EDIT_UNBUNDLE_004"><text>"NENHUM"</text></outputEntry><outputEntry id="OutputEntry_2_5_EDIT_UNBUNDLE_004"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_3_EDIT_UNBUNDLE_004"><description>Fallback</description><inputEntry id="InputEntry_3_1_EDIT_UNBUNDLE_004"><text>-</text></inputEntry><inputEntry id="InputEntry_3_2_EDIT_UNBUNDLE_004"><text>-</text></inputEntry><outputEntry id="OutputEntry_3_1_EDIT_UNBUNDLE_004"><text>"Revisar"</text></outputEntry><outputEntry id="OutputEntry_3_2_EDIT_UNBUNDLE_004"><text>"Analise manual necessaria."</text></outputEntry><outputEntry id="OutputEntry_3_3_EDIT_UNBUNDLE_004"><text>"Encaminhar auditoria."</text></outputEntry><outputEntry id="OutputEntry_3_4_EDIT_UNBUNDLE_004"><text>"NENHUM"</text></outputEntry><outputEntry id="OutputEntry_3_5_EDIT_UNBUNDLE_004"><text>"MEDIO"</text></outputEntry></rule>
      
    </decisionTable>
  </decision>
  <dmndi:DMNDI><dmndi:DMNDiagram id="DMNDiagram_EDIT_UNBUNDLE_004"><dmndi:DMNShape id="DMNShape_EDIT_UNBUNDLE_004" dmnElementRef="Decision_EDIT_UNBUNDLE_004"><dc:Bounds height="80" width="180" x="160" y="100"/></dmndi:DMNShape></dmndi:DMNDiagram></dmndi:DMNDI>
</definitions>
