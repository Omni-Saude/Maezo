<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_EncounterClassWeight"
             name="Encounter Class Weight"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: encounter_class_weight_worker.py -->

  <!-- DMN: Encounter Class Weight
       Based on: calculate_complexity_worker.py lines 102-107, 289-294
       Rule: Base weights by encounter class
  -->

  <decision id="Decision_EncounterClassWeight" name="[SP-RC-005 | coding_audit/complexity_scoring] Encounter Class Weight" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_EncounterClassWeight" hitPolicy="FIRST">

      <input id="Input_encounterClass_EncounterClassWeight" label="Encounter Class">
        <inputExpression id="InputExpr_encounterClass_EncounterClassWeight" typeRef="string">
          <text>encounter_class</text>
        </inputExpression>
      </input>

      <output id="Output_resultado_EncounterClassWeight" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_EncounterClassWeight" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_EncounterClassWeight" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_Ambulatorio_EncounterClassWeight">
        <description>Ambulatorio: peso 0.5</description>
        <inputEntry id="IE_Amb_1_EncounterClassWeight"><text>"ambulatorio"</text></inputEntry>
        <outputEntry id="OE_Amb_res_EncounterClassWeight"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Amb_acao_EncounterClassWeight"><text>"Classe ambulatorio: peso complexidade 0.5"</text></outputEntry>
        <outputEntry id="OE_Amb_risco_EncounterClassWeight"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Internacao_EncounterClassWeight">
        <description>Internacao: peso 2.0</description>
        <inputEntry id="IE_Int_1_EncounterClassWeight"><text>"internacao"</text></inputEntry>
        <outputEntry id="OE_Int_res_EncounterClassWeight"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Int_acao_EncounterClassWeight"><text>"Classe internacao: peso complexidade 2.0"</text></outputEntry>
        <outputEntry id="OE_Int_risco_EncounterClassWeight"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Urgencia_EncounterClassWeight">
        <description>Urgencia: peso 1.5</description>
        <inputEntry id="IE_Urg_1_EncounterClassWeight"><text>"urgencia"</text></inputEntry>
        <outputEntry id="OE_Urg_res_EncounterClassWeight"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Urg_acao_EncounterClassWeight"><text>"Classe urgencia: peso complexidade 1.5"</text></outputEntry>
        <outputEntry id="OE_Urg_risco_EncounterClassWeight"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_DayClinic_EncounterClassWeight">
        <description>Day Clinic: peso 1.0</description>
        <inputEntry id="IE_Day_1_EncounterClassWeight"><text>"day_clinic"</text></inputEntry>
        <outputEntry id="OE_Day_res_EncounterClassWeight"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Day_acao_EncounterClassWeight"><text>"Classe day_clinic: peso complexidade 1.0"</text></outputEntry>
        <outputEntry id="OE_Day_risco_EncounterClassWeight"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_EncounterClassWeight">
        <description>Caso nao enquadrado</description>
        <inputEntry id="IE_FB_1_EncounterClassWeight"><text>-</text></inputEntry>
        <outputEntry id="OE_FB_res_EncounterClassWeight"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_FB_acao_EncounterClassWeight"><text>"Classe de atendimento nao reconhecida"</text></outputEntry>
        <outputEntry id="OE_FB_risco_EncounterClassWeight"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_EncounterClassWeight">
      <dmndi:DMNShape id="DMNShape_Decision_EncounterClassWeight" dmnElementRef="Decision_EncounterClassWeight">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
