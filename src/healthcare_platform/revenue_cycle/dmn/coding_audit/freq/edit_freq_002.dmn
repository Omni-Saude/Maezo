<?xml version="1.0" encoding="UTF-8"?>
<!--
  EDIT-FREQ-002 - Intervalo Minimo Entre Exames Imagem
  Versao: 1.0.0 (2026-02-08) | Categoria: EDIT-FREQ | Perspectiva: HOSPITAL (Auditoria Administrativa)
  Refs: RN ANS 465/2021, TISS 4.01.00, Lei 9.656/1998
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_EDIT_FREQ_002" name="Intervalo Minimo Entre Exames Imagem" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_EDIT_FREQ_002" name="[SP-RC-005 | coding_audit/freq] Intervalo Minimo Entre Exames Imagem" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_EDIT_FREQ_002" hitPolicy="FIRST">
      <input id="Input_1_EDIT_FREQ_002" label="Dias Intervalo"><inputExpression id="InputExpression_1_EDIT_FREQ_002" typeRef="number"><text>diasIntervalo</text></inputExpression></input>
      <input id="Input_2_EDIT_FREQ_002" label="Intervalo Minimo"><inputExpression id="InputExpression_2_EDIT_FREQ_002" typeRef="number"><text>intervaloMinimo</text></inputExpression></input>
      
      <output id="Output_1_EDIT_FREQ_002" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues></output>
      <output id="Output_2_EDIT_FREQ_002" label="Observacao" name="observacao" typeRef="string"/>
      <output id="Output_3_EDIT_FREQ_002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>
      <output id="Output_4_EDIT_FREQ_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output>
      <output id="Output_5_EDIT_FREQ_002" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output>
      <rule id="Rule_1_EDIT_FREQ_002"><description>Intervalo insuficiente - bloqueio</description><inputEntry id="InputEntry_1_1_EDIT_FREQ_002"><text>&lt; intervaloMinimo</text></inputEntry><inputEntry id="InputEntry_1_2_EDIT_FREQ_002"><text>-</text></inputEntry><outputEntry id="OutputEntry_1_1_EDIT_FREQ_002"><text>"Bloquear"</text></outputEntry><outputEntry id="OutputEntry_1_2_EDIT_FREQ_002"><text>"GLOSA PROVAVEL: Exame realizado ANTES do intervalo minimo recomendado. Verificar justificativa clinica."</text></outputEntry><outputEntry id="OutputEntry_1_3_EDIT_FREQ_002"><text>"Solicitar justificativa medica fundamentada. Avaliar necessidade clinica do exame antecipado."</text></outputEntry><outputEntry id="OutputEntry_1_4_EDIT_FREQ_002"><text>"FREQ"</text></outputEntry><outputEntry id="OutputEntry_1_5_EDIT_FREQ_002"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_2_EDIT_FREQ_002"><description>Intervalo adequado - prosseguir</description><inputEntry id="InputEntry_2_1_EDIT_FREQ_002"><text>&gt;= intervaloMinimo</text></inputEntry><inputEntry id="InputEntry_2_2_EDIT_FREQ_002"><text>-</text></inputEntry><outputEntry id="OutputEntry_2_1_EDIT_FREQ_002"><text>"Prosseguir"</text></outputEntry><outputEntry id="OutputEntry_2_2_EDIT_FREQ_002"><text>"Intervalo entre exames adequado. Conformidade com protocolos."</text></outputEntry><outputEntry id="OutputEntry_2_3_EDIT_FREQ_002"><text>"Prosseguir padrao."</text></outputEntry><outputEntry id="OutputEntry_2_4_EDIT_FREQ_002"><text>"NENHUM"</text></outputEntry><outputEntry id="OutputEntry_2_5_EDIT_FREQ_002"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_3_EDIT_FREQ_002"><description>Fallback</description><inputEntry id="InputEntry_3_1_EDIT_FREQ_002"><text>-</text></inputEntry><inputEntry id="InputEntry_3_2_EDIT_FREQ_002"><text>-</text></inputEntry><outputEntry id="OutputEntry_3_1_EDIT_FREQ_002"><text>"Revisar"</text></outputEntry><outputEntry id="OutputEntry_3_2_EDIT_FREQ_002"><text>"Analise manual necessaria."</text></outputEntry><outputEntry id="OutputEntry_3_3_EDIT_FREQ_002"><text>"Encaminhar auditoria."</text></outputEntry><outputEntry id="OutputEntry_3_4_EDIT_FREQ_002"><text>"NENHUM"</text></outputEntry><outputEntry id="OutputEntry_3_5_EDIT_FREQ_002"><text>"MEDIO"</text></outputEntry></rule>
      
    </decisionTable>
  </decision>
  <dmndi:DMNDI><dmndi:DMNDiagram id="DMNDiagram_EDIT_FREQ_002"><dmndi:DMNShape id="DMNShape_EDIT_FREQ_002" dmnElementRef="Decision_EDIT_FREQ_002"><dc:Bounds height="80" width="180" x="160" y="100"/></dmndi:DMNShape></dmndi:DMNDiagram></dmndi:DMNDI>
</definitions>
