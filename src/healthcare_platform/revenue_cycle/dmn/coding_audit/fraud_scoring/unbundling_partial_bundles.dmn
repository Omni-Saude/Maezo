<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_UnbundlingPartialBundles"
             name="Unbundling Partial Bundles Decision"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: unbundling_partial_bundles_worker.py -->

  <!-- DMN: Unbundling Partial Bundles Detection
       Based on: detect_fraud_worker.py lines 324-351
       Rule: Detect when bundle group codes are partially present (unbundling fraud)
  -->

  <decision id="Decision_UnbundlingPartialBundles" name="[SP-RC-005 | coding_audit/fraud_scoring] Unbundling Partial Bundles" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_UnbundlingPartialBundles" hitPolicy="FIRST">

      <!-- === INPUTS === -->
      <input id="Input_tussCodesPresent_UnbundlingPartialBundles" label="TUSS Codes Present">
        <inputExpression id="InputExpr_tussCodesPresent_UnbundlingPartialBundles" typeRef="string">
          <text>tuss_codes</text>
        </inputExpression>
      </input>

      <input id="Input_bundleGroupId_UnbundlingPartialBundles" label="Bundle Group ID">
        <inputExpression id="InputExpr_bundleGroupId_UnbundlingPartialBundles" typeRef="string">
          <text>bundle_group_id</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->
      <output id="Output_resultado_UnbundlingPartialBundles" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_UnbundlingPartialBundles" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_UnbundlingPartialBundles" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Partial bundle detected - unbundling fraud -->
      <rule id="Rule_PartialBundle_UnbundlingPartialBundles">
        <description>Possivel desagrupamento: codigos parciais de pacote identificados</description>
        <inputEntry id="IE_Partial_1_UnbundlingPartialBundles"><text>-</text></inputEntry>
        <inputEntry id="IE_Partial_2_UnbundlingPartialBundles"><text>"partial"</text></inputEntry>
        <outputEntry id="OE_Partial_res_UnbundlingPartialBundles"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_Partial_acao_UnbundlingPartialBundles"><text>"Possivel desagrupamento: codigos parciais de pacote identificados"</text></outputEntry>
        <outputEntry id="OE_Partial_risco_UnbundlingPartialBundles"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Complete bundle - proceed -->
      <rule id="Rule_CompleteBundle_UnbundlingPartialBundles">
        <description>Pacote completo identificado</description>
        <inputEntry id="IE_Complete_1_UnbundlingPartialBundles"><text>-</text></inputEntry>
        <inputEntry id="IE_Complete_2_UnbundlingPartialBundles"><text>"complete"</text></inputEntry>
        <outputEntry id="OE_Complete_res_UnbundlingPartialBundles"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Complete_acao_UnbundlingPartialBundles"><text>"Pacote completo identificado"</text></outputEntry>
        <outputEntry id="OE_Complete_risco_UnbundlingPartialBundles"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 3: No bundle codes - proceed -->
      <rule id="Rule_NoBundle_UnbundlingPartialBundles">
        <description>Nenhum codigo de pacote presente</description>
        <inputEntry id="IE_NoBundle_1_UnbundlingPartialBundles"><text>-</text></inputEntry>
        <inputEntry id="IE_NoBundle_2_UnbundlingPartialBundles"><text>"none"</text></inputEntry>
        <outputEntry id="OE_NoBundle_res_UnbundlingPartialBundles"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_NoBundle_acao_UnbundlingPartialBundles"><text>"Nenhum codigo de pacote presente"</text></outputEntry>
        <outputEntry id="OE_NoBundle_risco_UnbundlingPartialBundles"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Fallback: Unknown bundle status - review -->
      
      <rule id="Rule_HighRisk_UnbundlingPartialBundles">
        <description>Risco alto detectado - revisao obrigatoria</description>
        <inputEntry id="IE_HighRisk_1_UnbundlingPartialBundles"><text>-</text></inputEntry>
        <inputEntry id="IE_HighRisk_2_UnbundlingPartialBundles"><text>-</text></inputEntry>
        <outputEntry id="OE_HighRisk_res_UnbundlingPartialBundles"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_HighRisk_acao_UnbundlingPartialBundles"><text>"Situacao de risco alto identificada - avaliacao detalhada necessaria"</text></outputEntry>
        <outputEntry id="OE_HighRisk_risco_UnbundlingPartialBundles"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_UnbundlingPartialBundles">
        <description>Status de pacote desconhecido - revisao obrigatoria</description>
        <inputEntry id="IE_fb_1_UnbundlingPartialBundles"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2_UnbundlingPartialBundles"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res_UnbundlingPartialBundles"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao_UnbundlingPartialBundles"><text>"Status de pacote requer avaliacao manual"</text></outputEntry>
        <outputEntry id="OE_fb_risco_UnbundlingPartialBundles"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_UnbundlingPartialBundles">
      <dmndi:DMNShape id="DMNShape_Decision_UnbundlingPartialBundles" dmnElementRef="Decision_UnbundlingPartialBundles">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
