<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_FrequencyZscoreThreshold"
             name="Frequency Z-Score Threshold Decision"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: frequency_zscore_threshold_worker.py -->

  <!-- DMN: Frequency Abuse Z-Score Threshold Detection
       Based on: detect_fraud_worker.py lines 412-444
       Rule: Flag when code count deviates from statistical baseline using z-score
  -->

  <decision id="Decision_FrequencyZscoreThreshold" name="[SP-RC-005 | coding_audit/fraud_scoring] Frequency Z-Score Threshold" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_FrequencyZscoreThreshold" hitPolicy="FIRST">

      <!-- === INPUTS === -->
      <input id="Input_zScore_FrequencyZscoreThreshold" label="Z-Score">
        <inputExpression id="InputExpr_zScore_FrequencyZscoreThreshold" typeRef="number">
          <text>z_score</text>
        </inputExpression>
      </input>

      <input id="Input_encounterClass_FrequencyZscoreThreshold" label="Encounter Class">
        <inputExpression id="InputExpr_encounterClass_FrequencyZscoreThreshold" typeRef="string">
          <text>encounter_class</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->
      <output id="Output_resultado_FrequencyZscoreThreshold" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_FrequencyZscoreThreshold" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_FrequencyZscoreThreshold" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Z-score > 3 - critical frequency abuse -->
      <rule id="Rule_ZscoreCritical_FrequencyZscoreThreshold">
        <description>Desvio critico: z-score &gt; 3</description>
        <inputEntry id="IE_Critical_1_FrequencyZscoreThreshold"><text>&gt; 3</text></inputEntry>
        <inputEntry id="IE_Critical_2_FrequencyZscoreThreshold"><text>-</text></inputEntry>
        <outputEntry id="OE_Critical_res_FrequencyZscoreThreshold"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_Critical_acao_FrequencyZscoreThreshold"><text>"Quantidade de procedimentos muito acima do esperado (z &gt; 3)"</text></outputEntry>
        <outputEntry id="OE_Critical_risco_FrequencyZscoreThreshold"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Z-score > 2 - high frequency abuse -->
      <rule id="Rule_ZscoreHigh_FrequencyZscoreThreshold">
        <description>Desvio alto: z-score &gt; 2</description>
        <inputEntry id="IE_High_1_FrequencyZscoreThreshold"><text>&gt; 2</text></inputEntry>
        <inputEntry id="IE_High_2_FrequencyZscoreThreshold"><text>-</text></inputEntry>
        <outputEntry id="OE_High_res_FrequencyZscoreThreshold"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_High_acao_FrequencyZscoreThreshold"><text>"Quantidade de procedimentos acima do esperado (z &gt; 2)"</text></outputEntry>
        <outputEntry id="OE_High_risco_FrequencyZscoreThreshold"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Z-score > 1.5 - medium frequency concern -->
      <rule id="Rule_ZscoreMedium_FrequencyZscoreThreshold">
        <description>Desvio medio: z-score &gt; 1.5</description>
        <inputEntry id="IE_Medium_1_FrequencyZscoreThreshold"><text>&gt; 1.5</text></inputEntry>
        <inputEntry id="IE_Medium_2_FrequencyZscoreThreshold"><text>-</text></inputEntry>
        <outputEntry id="OE_Medium_res_FrequencyZscoreThreshold"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_Medium_acao_FrequencyZscoreThreshold"><text>"Quantidade de procedimentos ligeiramente acima do esperado (z &gt; 1.5)"</text></outputEntry>
        <outputEntry id="OE_Medium_risco_FrequencyZscoreThreshold"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Z-score <= 1.5 - within normal range -->
      <rule id="Rule_ZscoreNormal_FrequencyZscoreThreshold">
        <description>Desvio normal: z-score &lt;= 1.5</description>
        <inputEntry id="IE_Normal_1_FrequencyZscoreThreshold"><text>&lt;= 1.5</text></inputEntry>
        <inputEntry id="IE_Normal_2_FrequencyZscoreThreshold"><text>-</text></inputEntry>
        <outputEntry id="OE_Normal_res_FrequencyZscoreThreshold"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Normal_acao_FrequencyZscoreThreshold"><text>"Quantidade de procedimentos dentro da faixa normal"</text></outputEntry>
        <outputEntry id="OE_Normal_risco_FrequencyZscoreThreshold"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Fallback: Unknown z-score - review -->
      <rule id="Rule_Fallback_FrequencyZscoreThreshold">
        <description>Z-score desconhecido - revisao obrigatoria</description>
        <inputEntry id="IE_fb_1_FrequencyZscoreThreshold"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2_FrequencyZscoreThreshold"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res_FrequencyZscoreThreshold"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao_FrequencyZscoreThreshold"><text>"Z-score requer avaliacao manual"</text></outputEntry>
        <outputEntry id="OE_fb_risco_FrequencyZscoreThreshold"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_FrequencyZscoreThreshold">
      <dmndi:DMNShape id="DMNShape_Decision_FrequencyZscoreThreshold" dmnElementRef="Decision_FrequencyZscoreThreshold">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
