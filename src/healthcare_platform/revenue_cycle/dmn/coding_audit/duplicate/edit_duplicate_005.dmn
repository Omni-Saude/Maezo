<?xml version="1.0" encoding="UTF-8"?>
<!--
  EDIT-DUPLICATE-005 - Paciente Duplicado (Homonimos)
  Versao: 1.0.0 (2026-02-08) | Categoria: EDIT-DUPLICATE | Perspectiva: HOSPITAL (Auditoria Administrativa)
  Refs: RN ANS 465/2021, TISS 4.01.00, Lei 9.656/1998
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_EDIT_DUPLICATE_005" name="Paciente Duplicado (Homonimos)" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_EDIT_DUPLICATE_005" name="[SP-RC-005 | coding_audit/duplicate] Paciente Duplicado (Homonimos)" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_EDIT_DUPLICATE_005" hitPolicy="FIRST">
      <input id="Input_1_EDIT_DUPLICATE_005" label="Procedimento Repetido"><inputExpression id="InputExpression_1_EDIT_DUPLICATE_005" typeRef="boolean"><text>procedimentoRepetido</text></inputExpression></input>
      <input id="Input_2_EDIT_DUPLICATE_005" label="Mesma Data"><inputExpression id="InputExpression_2_EDIT_DUPLICATE_005" typeRef="boolean"><text>mesmaData</text></inputExpression></input>
      
      <output id="Output_1_EDIT_DUPLICATE_005" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues></output>
      <output id="Output_2_EDIT_DUPLICATE_005" label="Observacao" name="observacao" typeRef="string"/>
      <output id="Output_3_EDIT_DUPLICATE_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>
      <output id="Output_4_EDIT_DUPLICATE_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output>
      <output id="Output_5_EDIT_DUPLICATE_005" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output>
      <rule id="Rule_1_EDIT_DUPLICATE_005"><description>Possivel homonimo - alerta</description><inputEntry id="InputEntry_1_1_EDIT_DUPLICATE_005"><text>true</text></inputEntry><inputEntry id="InputEntry_1_2_EDIT_DUPLICATE_005"><text>true</text></inputEntry><outputEntry id="OutputEntry_1_1_EDIT_DUPLICATE_005"><text>"Alertar"</text></outputEntry><outputEntry id="OutputEntry_1_2_EDIT_DUPLICATE_005"><text>"RISCO MEDIO: Mesmo procedimento, mesma data. Verificar se sao pacientes homonimos."</text></outputEntry><outputEntry id="OutputEntry_1_3_EDIT_DUPLICATE_005"><text>"Validar CPF e CNS dos pacientes. Confirmar identidades distintas."</text></outputEntry><outputEntry id="OutputEntry_1_4_EDIT_DUPLICATE_005"><text>"DUP"</text></outputEntry><outputEntry id="OutputEntry_1_5_EDIT_DUPLICATE_005"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_2_EDIT_DUPLICATE_005"><description>Pacientes distintos - prosseguir</description><inputEntry id="InputEntry_2_1_EDIT_DUPLICATE_005"><text>false</text></inputEntry><inputEntry id="InputEntry_2_2_EDIT_DUPLICATE_005"><text>-</text></inputEntry><outputEntry id="OutputEntry_2_1_EDIT_DUPLICATE_005"><text>"Prosseguir"</text></outputEntry><outputEntry id="OutputEntry_2_2_EDIT_DUPLICATE_005"><text>"Sem duplicidades por homonimia detectadas."</text></outputEntry><outputEntry id="OutputEntry_2_3_EDIT_DUPLICATE_005"><text>"Prosseguir padrao."</text></outputEntry><outputEntry id="OutputEntry_2_4_EDIT_DUPLICATE_005"><text>"NENHUM"</text></outputEntry><outputEntry id="OutputEntry_2_5_EDIT_DUPLICATE_005"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_3_EDIT_DUPLICATE_005"><description>Fallback</description><inputEntry id="InputEntry_3_1_EDIT_DUPLICATE_005"><text>-</text></inputEntry><inputEntry id="InputEntry_3_2_EDIT_DUPLICATE_005"><text>-</text></inputEntry><outputEntry id="OutputEntry_3_1_EDIT_DUPLICATE_005"><text>"Revisar"</text></outputEntry><outputEntry id="OutputEntry_3_2_EDIT_DUPLICATE_005"><text>"Analise manual necessaria."</text></outputEntry><outputEntry id="OutputEntry_3_3_EDIT_DUPLICATE_005"><text>"Encaminhar auditoria."</text></outputEntry><outputEntry id="OutputEntry_3_4_EDIT_DUPLICATE_005"><text>"NENHUM"</text></outputEntry><outputEntry id="OutputEntry_3_5_EDIT_DUPLICATE_005"><text>"MEDIO"</text></outputEntry></rule>
      
    </decisionTable>
  </decision>
  <dmndi:DMNDI><dmndi:DMNDiagram id="DMNDiagram_EDIT_DUPLICATE_005"><dmndi:DMNShape id="DMNShape_EDIT_DUPLICATE_005" dmnElementRef="Decision_EDIT_DUPLICATE_005"><dc:Bounds height="80" width="180" x="160" y="100"/></dmndi:DMNShape></dmndi:DMNDiagram></dmndi:DMNDI>
</definitions>
