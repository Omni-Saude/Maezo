<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_TUSS_CID10_Correlation"
             name="TUSS-CID10 Correlation Decision"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: cid10_correlation_worker.py -->

  <!-- DMN: TUSS-CID10 Correlation
       Based on: suggest_tuss_worker.py lines 222-276, 315-323
       Rule: Map CID-10 chapter to correlated TUSS procedure codes
  -->

  <decision id="Decision_TUSS_CID10_Correlation" name="[SP-RC-005 | coding_audit/tuss_suggestion] TUSS-CID10 Correlation" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_TUSS_CID10_Correlation" hitPolicy="FIRST">

      <!-- === INPUTS === -->
      <input id="Input_cid10Chapter_TUSS_CID10_Correlation" label="CID-10 Chapter">
        <inputExpression id="InputExpr_cid10Chapter_TUSS_CID10_Correlation" typeRef="string">
          <text>cid10_chapter</text>
        </inputExpression>
      </input>

      <input id="Input_encounterClass_TUSS_CID10_Correlation" label="Encounter Class">
        <inputExpression id="InputExpr_encounterClass_TUSS_CID10_Correlation" typeRef="string">
          <text>encounter_class</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->
      <output id="Output_resultado_TUSS_CID10_Correlation" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_TUSS_CID10_Correlation" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_TUSS_CID10_Correlation" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: J18 (Pneumonia) → Radiografia + Hemograma -->
      <rule id="Rule_J18_Pneumonia_TUSS_CID10_Correlation">
        <description>Pneumonia: sugerir radiografia e hemograma</description>
        <inputEntry id="IE_J18_1_TUSS_CID10_Correlation"><text>"J18"</text></inputEntry>
        <inputEntry id="IE_J18_2_TUSS_CID10_Correlation"><text>-</text></inputEntry>
        <outputEntry id="OE_J18_res_TUSS_CID10_Correlation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_J18_acao_TUSS_CID10_Correlation"><text>"Sugerir TUSS: 40801020 (Radiografia torax), 40304361 (Hemograma completo)"</text></outputEntry>
        <outputEntry id="OE_J18_risco_TUSS_CID10_Correlation"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 2: E11 (Diabetes tipo 2) → Glicose + HbA1c -->
      <rule id="Rule_E11_Diabetes_TUSS_CID10_Correlation">
        <description>Diabetes tipo 2: sugerir glicemia e hemoglobina glicada</description>
        <inputEntry id="IE_E11_1_TUSS_CID10_Correlation"><text>"E11"</text></inputEntry>
        <inputEntry id="IE_E11_2_TUSS_CID10_Correlation"><text>-</text></inputEntry>
        <outputEntry id="OE_E11_res_TUSS_CID10_Correlation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_E11_acao_TUSS_CID10_Correlation"><text>"Sugerir TUSS: 40301010 (Glicose), 40302040 (Hemoglobina glicada)"</text></outputEntry>
        <outputEntry id="OE_E11_risco_TUSS_CID10_Correlation"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 3: I21 (Infarto) → ECG + Hemograma -->
      <rule id="Rule_I21_Infarto_TUSS_CID10_Correlation">
        <description>Infarto: sugerir ECG e hemograma</description>
        <inputEntry id="IE_I21_1_TUSS_CID10_Correlation"><text>"I21"</text></inputEntry>
        <inputEntry id="IE_I21_2_TUSS_CID10_Correlation"><text>-</text></inputEntry>
        <outputEntry id="OE_I21_res_TUSS_CID10_Correlation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_I21_acao_TUSS_CID10_Correlation"><text>"Sugerir TUSS: 40101030 (ECG convencional), 40304361 (Hemograma completo)"</text></outputEntry>
        <outputEntry id="OE_I21_risco_TUSS_CID10_Correlation"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 4: K35 (Apendicite) → Apendicectomia + Ultrassom -->
      <rule id="Rule_K35_Apendicite_TUSS_CID10_Correlation">
        <description>Apendicite: sugerir apendicectomia e ultrassom</description>
        <inputEntry id="IE_K35_1_TUSS_CID10_Correlation"><text>"K35"</text></inputEntry>
        <inputEntry id="IE_K35_2_TUSS_CID10_Correlation"><text>-</text></inputEntry>
        <outputEntry id="OE_K35_res_TUSS_CID10_Correlation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_K35_acao_TUSS_CID10_Correlation"><text>"Sugerir TUSS: 31003036 (Apendicectomia), 40901017 (Ultrassom abdome)"</text></outputEntry>
        <outputEntry id="OE_K35_risco_TUSS_CID10_Correlation"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 5: I10 (Hipertensão) → ECG -->
      <rule id="Rule_I10_Hipertensao_TUSS_CID10_Correlation">
        <description>Hipertensao: sugerir ECG</description>
        <inputEntry id="IE_I10_1_TUSS_CID10_Correlation"><text>"I10"</text></inputEntry>
        <inputEntry id="IE_I10_2_TUSS_CID10_Correlation"><text>-</text></inputEntry>
        <outputEntry id="OE_I10_res_TUSS_CID10_Correlation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_I10_acao_TUSS_CID10_Correlation"><text>"Sugerir TUSS: 40101030 (ECG convencional)"</text></outputEntry>
        <outputEntry id="OE_I10_risco_TUSS_CID10_Correlation"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 6: I50 (Insuficiência cardíaca) → ECG + Radiografia -->
      <rule id="Rule_I50_InsuficienciaCardiaca_TUSS_CID10_Correlation">
        <description>Insuficiencia cardiaca: sugerir ECG e radiografia</description>
        <inputEntry id="IE_I50_1_TUSS_CID10_Correlation"><text>"I50"</text></inputEntry>
        <inputEntry id="IE_I50_2_TUSS_CID10_Correlation"><text>-</text></inputEntry>
        <outputEntry id="OE_I50_res_TUSS_CID10_Correlation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_I50_acao_TUSS_CID10_Correlation"><text>"Sugerir TUSS: 40101030 (ECG convencional), 40801020 (Radiografia torax)"</text></outputEntry>
        <outputEntry id="OE_I50_risco_TUSS_CID10_Correlation"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Fallback: No known correlation -->
      <rule id="Rule_Fallback_TUSS_CID10_Correlation">
        <description>Capitulo CID-10 sem correlacao TUSS conhecida</description>
        <inputEntry id="IE_FB_1_TUSS_CID10_Correlation"><text>-</text></inputEntry>
        <inputEntry id="IE_FB_2_TUSS_CID10_Correlation"><text>-</text></inputEntry>
        <outputEntry id="OE_FB_res_TUSS_CID10_Correlation"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_FB_acao_TUSS_CID10_Correlation"><text>"Sem correlacao automatica CID10-TUSS - revisar procedimentos manualmente"</text></outputEntry>
        <outputEntry id="OE_FB_risco_TUSS_CID10_Correlation"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_TUSS_CID10_Correlation">
      <dmndi:DMNShape id="DMNShape_Decision_TUSS_CID10_Correlation" dmnElementRef="Decision_TUSS_CID10_Correlation">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
