<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_CID10_FormatValidation_Strict"
             name="CID-10 Format Validation (Strict) Decision"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: cid10_format_worker.py -->

  <!-- DMN: CID-10 Format Validation (Strict)
       Based on: validate_codes_worker.py lines 31, 249-278
       Rule: Validate CID-10 code format with strict error handling
  -->

  <decision id="Decision_CID10_FormatValidation_Strict" name="[SP-RC-005 | coding_audit/code_validation] CID-10 Format Validation (Strict)" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_CID10_FormatValidation_Strict" hitPolicy="FIRST">

      <!-- === INPUTS === -->
      <input id="Input_code_CID10_FormatValidation_Strict" label="Code">
        <inputExpression id="InputExpr_code_CID10_FormatValidation_Strict" typeRef="string">
          <text>code</text>
        </inputExpression>
      </input>

      <input id="Input_codeLength_CID10_FormatValidation_Strict" label="Code Length">
        <inputExpression id="InputExpr_codeLength_CID10_FormatValidation_Strict" typeRef="number">
          <text>code_length</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->
      <output id="Output_resultado_CID10_FormatValidation_Strict" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_CID10_FormatValidation_Strict" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_CID10_FormatValidation_Strict" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Empty code → BLOCK HIGH -->
      <rule id="Rule_Empty_Code_CID10_FormatValidation_Strict">
        <description>Codigo CID-10 vazio ou nulo</description>
        <inputEntry id="IE_Empty_1_CID10_FormatValidation_Strict"><text>"EMPTY"</text></inputEntry>
        <inputEntry id="IE_Empty_2_CID10_FormatValidation_Strict"><text>0</text></inputEntry>
        <outputEntry id="OE_Empty_res_CID10_FormatValidation_Strict"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_Empty_acao_CID10_FormatValidation_Strict"><text>"Codigo CID-10 obrigatorio esta vazio ou nulo"</text></outputEntry>
        <outputEntry id="OE_Empty_risco_CID10_FormatValidation_Strict"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Invalid format → BLOCK MEDIUM -->
      <rule id="Rule_Invalid_Format_CID10_FormatValidation_Strict">
        <description>Formato CID-10 invalido</description>
        <inputEntry id="IE_Invalid_1_CID10_FormatValidation_Strict"><text>"INVALID"</text></inputEntry>
        <inputEntry id="IE_Invalid_2_CID10_FormatValidation_Strict"><text>-</text></inputEntry>
        <outputEntry id="OE_Invalid_res_CID10_FormatValidation_Strict"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_Invalid_acao_CID10_FormatValidation_Strict"><text>"Formato CID-10 invalido - esperado: letra + 2-3 digitos + ponto + digito opcional (ex: J18.9, A09, M54.5)"</text></outputEntry>
        <outputEntry id="OE_Invalid_risco_CID10_FormatValidation_Strict"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Valid format → PROCEED LOW -->
      <rule id="Rule_Valid_Format_CID10_FormatValidation_Strict">
        <description>Formato CID-10 valido</description>
        <inputEntry id="IE_Valid_1_CID10_FormatValidation_Strict"><text>"VALID_CID10"</text></inputEntry>
        <inputEntry id="IE_Valid_2_CID10_FormatValidation_Strict"><text>[3..6]</text></inputEntry>
        <outputEntry id="OE_Valid_res_CID10_FormatValidation_Strict"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Valid_acao_CID10_FormatValidation_Strict"><text>"Codigo CID-10 com formato valido aprovado"</text></outputEntry>
        <outputEntry id="OE_Valid_risco_CID10_FormatValidation_Strict"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      
      <rule id="Rule_HighRisk_CID10_FormatValidation_Strict">
        <description>Risco alto detectado - revisao obrigatoria</description>
        <inputEntry id="IE_HighRisk_1_CID10_FormatValidation_Strict"><text>-</text></inputEntry>
        <inputEntry id="IE_HighRisk_2_CID10_FormatValidation_Strict"><text>-</text></inputEntry>
        <outputEntry id="OE_HighRisk_res_CID10_FormatValidation_Strict"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_HighRisk_acao_CID10_FormatValidation_Strict"><text>"Situacao de risco alto identificada - avaliacao detalhada necessaria"</text></outputEntry>
        <outputEntry id="OE_HighRisk_risco_CID10_FormatValidation_Strict"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_CID10_FormatValidation_Strict">
        <description>Caso nao enquadrado</description>
        <inputEntry id="IE_FB_1_CID10_FormatValidation_Strict"><text>-</text></inputEntry>
        <inputEntry id="IE_FB_2_CID10_FormatValidation_Strict"><text>-</text></inputEntry>
        <outputEntry id="OE_FB_res_CID10_FormatValidation_Strict"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_FB_acao_CID10_FormatValidation_Strict"><text>"Codigo CID-10 requer validacao manual"</text></outputEntry>
        <outputEntry id="OE_FB_risco_CID10_FormatValidation_Strict"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_CID10_FormatValidation_Strict">
      <dmndi:DMNShape id="DMNShape_Decision_CID10_FormatValidation_Strict" dmnElementRef="Decision_CID10_FormatValidation_Strict">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
