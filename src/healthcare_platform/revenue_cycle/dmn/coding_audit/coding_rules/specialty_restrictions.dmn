<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_SpecialtyRestrictions"
             name="Specialty Restrictions Decision"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: specialty_restrictions_worker.py -->

  <!-- DMN: Specialty Restrictions
       Based on: apply_coding_rules_worker.py lines 138-140, 234-250
       Rule: Surgical prefixes (40, 41, 42) not allowed in ambulatorial without authorization
  -->

  <decision id="Decision_SpecialtyRestrictions" name="[SP-RC-005 | coding_audit/coding_rules] Specialty Restrictions" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_SpecialtyRestrictions" hitPolicy="FIRST">

      <!-- === INPUTS === -->
      <input id="Input_encounterClass_SpecialtyRestrictions" label="Encounter Class">
        <inputExpression id="InputExpr_encounterClass_SpecialtyRestrictions" typeRef="string">
          <text>encounter_class</text>
        </inputExpression>
      </input>

      <input id="Input_tussPrefix_SpecialtyRestrictions" label="TUSS Prefix">
        <inputExpression id="InputExpr_tussPrefix_SpecialtyRestrictions" typeRef="string">
          <text>tuss_prefix</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->
      <output id="Output_resultado_SpecialtyRestrictions" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_SpecialtyRestrictions" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_SpecialtyRestrictions" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Surgical code in ambulatorial: block -->
      <rule id="Rule_Surgical_Ambulatorial_40_SpecialtyRestrictions">
        <description>Procedimento cirurgico (40) nao permitido em ambulatorial</description>
        <inputEntry id="IE_SA40_1_SpecialtyRestrictions"><text>"ambulatorial"</text></inputEntry>
        <inputEntry id="IE_SA40_2_SpecialtyRestrictions"><text>"40"</text></inputEntry>
        <outputEntry id="OE_SA40_res_SpecialtyRestrictions"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_SA40_acao_SpecialtyRestrictions"><text>"Procedimento cirurgico nao permitido em ambulatorial sem autorizacao previa"</text></outputEntry>
        <outputEntry id="OE_SA40_risco_SpecialtyRestrictions"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Surgical_Ambulatorial_41_SpecialtyRestrictions">
        <description>Procedimento cirurgico (41) nao permitido em ambulatorial</description>
        <inputEntry id="IE_SA41_1_SpecialtyRestrictions"><text>"ambulatorial"</text></inputEntry>
        <inputEntry id="IE_SA41_2_SpecialtyRestrictions"><text>"41"</text></inputEntry>
        <outputEntry id="OE_SA41_res_SpecialtyRestrictions"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_SA41_acao_SpecialtyRestrictions"><text>"Procedimento cirurgico nao permitido em ambulatorial sem autorizacao previa"</text></outputEntry>
        <outputEntry id="OE_SA41_risco_SpecialtyRestrictions"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Surgical_Ambulatorial_42_SpecialtyRestrictions">
        <description>Procedimento cirurgico (42) nao permitido em ambulatorial</description>
        <inputEntry id="IE_SA42_1_SpecialtyRestrictions"><text>"ambulatorial"</text></inputEntry>
        <inputEntry id="IE_SA42_2_SpecialtyRestrictions"><text>"42"</text></inputEntry>
        <outputEntry id="OE_SA42_res_SpecialtyRestrictions"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_SA42_acao_SpecialtyRestrictions"><text>"Procedimento cirurgico nao permitido em ambulatorial sem autorizacao previa"</text></outputEntry>
        <outputEntry id="OE_SA42_risco_SpecialtyRestrictions"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- No restriction -->
      
      <rule id="Rule_HighRisk_SpecialtyRestrictions">
        <description>Risco alto detectado - revisao obrigatoria</description>
        <inputEntry id="IE_HighRisk_1_SpecialtyRestrictions"><text>-</text></inputEntry>
        <inputEntry id="IE_HighRisk_2_SpecialtyRestrictions"><text>-</text></inputEntry>
        <outputEntry id="OE_HighRisk_res_SpecialtyRestrictions"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_HighRisk_acao_SpecialtyRestrictions"><text>"Situacao de risco alto identificada - avaliacao detalhada necessaria"</text></outputEntry>
        <outputEntry id="OE_HighRisk_risco_SpecialtyRestrictions"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_No_Restriction_SpecialtyRestrictions">
        <description>Sem restricao de especialidade</description>
        <inputEntry id="IE_NR_1_SpecialtyRestrictions"><text>-</text></inputEntry>
        <inputEntry id="IE_NR_2_SpecialtyRestrictions"><text>-</text></inputEntry>
        <outputEntry id="OE_NR_res_SpecialtyRestrictions"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_NR_acao_SpecialtyRestrictions"><text>"Procedimento permitido para a classe de atendimento"</text></outputEntry>
        <outputEntry id="OE_NR_risco_SpecialtyRestrictions"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_SpecialtyRestrictions">
      <dmndi:DMNShape id="DMNShape_Decision_SpecialtyRestrictions" dmnElementRef="Decision_SpecialtyRestrictions">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
