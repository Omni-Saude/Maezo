<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_ModifierRequirements"
             name="Modifier Requirements Decision"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: modifier_requirements_worker.py -->

  <!-- DMN: Modifier Requirements
       Based on: apply_coding_rules_worker.py lines 118-123, 219-232
       Rule: TUSS codes requiring modifiers
  -->

  <decision id="Decision_ModifierRequirements" name="[SP-RC-005 | coding_audit/coding_rules] Modifier Requirements" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_ModifierRequirements" hitPolicy="FIRST">

      <!-- === INPUTS === -->
      <input id="Input_tussCode_ModifierRequirements" label="TUSS Code">
        <inputExpression id="InputExpr_tussCode_ModifierRequirements" typeRef="string">
          <text>tuss_code</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->
      <output id="Output_resultado_ModifierRequirements" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_ModifierRequirements" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_ModifierRequirements" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Code 30101012: requires modifier -51 -->
      <rule id="Rule_Modifier_30101012_ModifierRequirements">
        <description>Codigo 30101012 requer modificador -51</description>
        <inputEntry id="IE_M1_1_ModifierRequirements"><text>"30101012"</text></inputEntry>
        <outputEntry id="OE_M1_res_ModifierRequirements"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_M1_acao_ModifierRequirements"><text>"Modificador -51 (multiplos procedimentos) obrigatorio"</text></outputEntry>
        <outputEntry id="OE_M1_risco_ModifierRequirements"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Code 40201010: requires modifier -59 -->
      <rule id="Rule_Modifier_40201010_ModifierRequirements">
        <description>Codigo 40201010 requer modificador -59</description>
        <inputEntry id="IE_M2_1_ModifierRequirements"><text>"40201010"</text></inputEntry>
        <outputEntry id="OE_M2_res_ModifierRequirements"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_M2_acao_ModifierRequirements"><text>"Modificador -59 (procedimento distinto) obrigatorio"</text></outputEntry>
        <outputEntry id="OE_M2_risco_ModifierRequirements"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Code 40301010: requires modifier -26 -->
      <rule id="Rule_Modifier_40301010_ModifierRequirements">
        <description>Codigo 40301010 requer modificador -26</description>
        <inputEntry id="IE_M3_1_ModifierRequirements"><text>"40301010"</text></inputEntry>
        <outputEntry id="OE_M3_res_ModifierRequirements"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_M3_acao_ModifierRequirements"><text>"Modificador -26 (componente profissional) obrigatorio"</text></outputEntry>
        <outputEntry id="OE_M3_risco_ModifierRequirements"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- No modifier required -->
      
      <rule id="Rule_HighRisk_ModifierRequirements">
        <description>Risco alto detectado - revisao obrigatoria</description>
        <inputEntry id="IE_HighRisk_1_ModifierRequirements"><text>-</text></inputEntry>
        <outputEntry id="OE_HighRisk_res_ModifierRequirements"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_HighRisk_acao_ModifierRequirements"><text>"Situacao de risco alto identificada - avaliacao detalhada necessaria"</text></outputEntry>
        <outputEntry id="OE_HighRisk_risco_ModifierRequirements"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_No_Modifier_ModifierRequirements">
        <description>Nenhum modificador obrigatorio</description>
        <inputEntry id="IE_NM_1_ModifierRequirements"><text>-</text></inputEntry>
        <outputEntry id="OE_NM_res_ModifierRequirements"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_NM_acao_ModifierRequirements"><text>"Nenhum modificador obrigatorio para este codigo"</text></outputEntry>
        <outputEntry id="OE_NM_risco_ModifierRequirements"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ModifierRequirements">
      <dmndi:DMNShape id="DMNShape_Decision_ModifierRequirements" dmnElementRef="Decision_ModifierRequirements">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
