<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DocumentationSupport"
             name="Documentation Support Decision"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: documentation_support_worker.py -->

  <!-- DMN: Documentation Support Check
       Based on: audit_coding_worker.py lines 202-231
       Rule: Documentation score must be >= 75% to support codes
  -->

  <decision id="Decision_DocumentationSupport" name="[SP-RC-005 | coding_audit/audit_quality] Documentation Support" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DocumentationSupport" hitPolicy="FIRST">

      <!-- === INPUTS === -->
      <input id="Input_docScore_DocumentationSupport" label="Documentation Score %">
        <inputExpression id="InputExpr_docScore_DocumentationSupport" typeRef="number">
          <text>doc_score_pct</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->
      <output id="Output_resultado_DocumentationSupport" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_DocumentationSupport" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_DocumentationSupport" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Insufficient documentation: < 75% -->
      <rule id="Rule_Insufficient_Doc_DocumentationSupport">
        <description>Documentacao clinica insuficiente</description>
        <inputEntry id="IE_InsuffDoc_1_DocumentationSupport"><text>&lt; 75</text></inputEntry>
        <outputEntry id="OE_InsuffDoc_res_DocumentationSupport"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_InsuffDoc_acao_DocumentationSupport"><text>"Documentacao clinica insuficiente para suportar os codigos informados"</text></outputEntry>
        <outputEntry id="OE_InsuffDoc_risco_DocumentationSupport"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Adequate documentation: >= 75% -->
      <rule id="Rule_Adequate_Doc_DocumentationSupport">
        <description>Documentacao clinica adequada</description>
        <inputEntry id="IE_AdeqDoc_1_DocumentationSupport"><text>&gt;= 75</text></inputEntry>
        <outputEntry id="OE_AdeqDoc_res_DocumentationSupport"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_AdeqDoc_acao_DocumentationSupport"><text>"Documentacao clinica adequada"</text></outputEntry>
        <outputEntry id="OE_AdeqDoc_risco_DocumentationSupport"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      
      <rule id="Rule_NoDoc_DocumentationSupport">
        <description>Documentacao totalmente ausente</description>
        <inputEntry id="IE_NoDoc_1_DocumentationSupport"><text>-</text></inputEntry>
        
        <outputEntry id="OE_NoDoc_res_DocumentationSupport"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_NoDoc_acao_DocumentationSupport"><text>"Nenhuma documentacao de suporte encontrada - codificacao nao sustentavel"</text></outputEntry>
        <outputEntry id="OE_NoDoc_risco_DocumentationSupport"><text>"CRITICO"</text></outputEntry>
      </rule>


      <rule id="Rule_MinimalDoc_DocumentationSupport">
        <description>Documentacao minima presente</description>
        <inputEntry id="IE_MinimalDoc_1_DocumentationSupport"><text>-</text></inputEntry>
        
        <outputEntry id="OE_MinimalDoc_res_DocumentationSupport"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_MinimalDoc_acao_DocumentationSupport"><text>"Apenas documentacao minima - reforcar evidencias clinicas"</text></outputEntry>
        <outputEntry id="OE_MinimalDoc_risco_DocumentationSupport"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_DocumentationSupport">
        <description>Caso nao enquadrado - revisao obrigatoria</description>
        <inputEntry id="IE_FB_1_DocumentationSupport"><text>-</text></inputEntry>
        <outputEntry id="OE_FB_res_DocumentationSupport"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_FB_acao_DocumentationSupport"><text>"Caso requer avaliacao manual"</text></outputEntry>
        <outputEntry id="OE_FB_risco_DocumentationSupport"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DocumentationSupport">
      <dmndi:DMNShape id="DMNShape_Decision_DocumentationSupport" dmnElementRef="Decision_DocumentationSupport">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
