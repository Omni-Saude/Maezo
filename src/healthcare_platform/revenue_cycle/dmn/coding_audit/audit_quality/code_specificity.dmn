<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_CodeSpecificity"
             name="Code Specificity Decision"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: CLINICAL_SCORE | Source: code_specificity_worker.py -->

  <!-- DMN: Code Specificity Check
       Based on: audit_coding_worker.py lines 121-122, 170-200
       Rule: CID-10 codes must have minimum 4 characters for specificity
  -->

  <decision id="Decision_CodeSpecificity" name="[SP-RC-005 | coding_audit/audit_quality] Code Specificity" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_CodeSpecificity" hitPolicy="FIRST">

      <!-- === INPUTS === -->
      <input id="Input_cid10Code_CodeSpecificity" label="CID-10 Code">
        <inputExpression id="InputExpr_cid10Code_CodeSpecificity" typeRef="string">
          <text>cid10_code</text>
        </inputExpression>
      </input>

      <input id="Input_cid10Length_CodeSpecificity" label="CID-10 Length">
        <inputExpression id="InputExpr_cid10Length_CodeSpecificity" typeRef="number">
          <text>cid10_length</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->
      <output id="Output_resultado_CodeSpecificity" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_CodeSpecificity" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_CodeSpecificity" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Unspecific code: < 4 characters -->
      <rule id="Rule_Unspecific_Code_CodeSpecificity">
        <description>Codigo CID-10 sem especificidade suficiente</description>
        <inputEntry id="IE_Unspec_1_CodeSpecificity"><text>-</text></inputEntry>
        <inputEntry id="IE_Unspec_2_CodeSpecificity"><text>&lt; 4</text></inputEntry>
        <outputEntry id="OE_Unspec_res_CodeSpecificity"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_Unspec_acao_CodeSpecificity"><text>"Codigo CID-10 sem especificidade suficiente - utilizar codigo com minimo 4 caracteres"</text></outputEntry>
        <outputEntry id="OE_Unspec_risco_CodeSpecificity"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Specific code: >= 4 characters -->
      <rule id="Rule_Specific_Code_CodeSpecificity">
        <description>Codigo CID-10 com especificidade adequada</description>
        <inputEntry id="IE_Spec_1_CodeSpecificity"><text>-</text></inputEntry>
        <inputEntry id="IE_Spec_2_CodeSpecificity"><text>&gt;= 4</text></inputEntry>
        <outputEntry id="OE_Spec_res_CodeSpecificity"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Spec_acao_CodeSpecificity"><text>"Codigo CID-10 possui especificidade adequada"</text></outputEntry>
        <outputEntry id="OE_Spec_risco_CodeSpecificity"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      
      <rule id="Rule_VeryShort_CodeSpecificity">
        <description>Codigo CID-10 muito curto - 1-2 caracteres</description>
        <inputEntry id="IE_VeryShort_1_CodeSpecificity"><text>-</text></inputEntry>
        <inputEntry id="IE_VeryShort_2_CodeSpecificity"><text>[1..2]</text></inputEntry>
        <outputEntry id="OE_VeryShort_res_CodeSpecificity"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_VeryShort_acao_CodeSpecificity"><text>"Codigo CID-10 com apenas 1-2 caracteres - especificidade insuficiente para codificacao"</text></outputEntry>
        <outputEntry id="OE_VeryShort_risco_CodeSpecificity"><text>"ALTO"</text></outputEntry>
      </rule>


      <rule id="Rule_MinimalSpec_CodeSpecificity">
        <description>Codigo CID-10 com 3 caracteres - especificidade minima</description>
        <inputEntry id="IE_MinimalSpec_1_CodeSpecificity"><text>-</text></inputEntry>
        <inputEntry id="IE_MinimalSpec_2_CodeSpecificity"><text>3</text></inputEntry>
        <outputEntry id="OE_MinimalSpec_res_CodeSpecificity"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_MinimalSpec_acao_CodeSpecificity"><text>"Codigo CID-10 com 3 caracteres - considerar usar codigo mais especifico"</text></outputEntry>
        <outputEntry id="OE_MinimalSpec_risco_CodeSpecificity"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_CodeSpecificity">
        <description>Caso nao enquadrado - revisao obrigatoria</description>
        <inputEntry id="IE_FB_1_CodeSpecificity"><text>-</text></inputEntry>
        <inputEntry id="IE_FB_2_CodeSpecificity"><text>-</text></inputEntry>
        <outputEntry id="OE_FB_res_CodeSpecificity"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_FB_acao_CodeSpecificity"><text>"Caso requer avaliacao manual"</text></outputEntry>
        <outputEntry id="OE_FB_risco_CodeSpecificity"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_CodeSpecificity">
      <dmndi:DMNShape id="DMNShape_Decision_CodeSpecificity" dmnElementRef="Decision_CodeSpecificity">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
