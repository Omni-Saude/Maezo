<?xml version="1.0" encoding="UTF-8"?>
<!--
  EDIT-COMPAT-004 - Procedimento Mutuamente Exclusivo
  Versao: 1.0.0 (2026-02-08) | Categoria: EDIT-COMPAT | Perspectiva: HOSPITAL (Auditoria Administrativa)
  Refs: RN ANS 465/2021, TISS 4.01.00, Lei 9.656/1998
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_EDIT_COMPAT_004" name="Procedimento Mutuamente Exclusivo" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: edit_compat_004_worker.py -->
  <decision id="Decision_EDIT_COMPAT_004" name="[SP-RC-005 | coding_audit/code_compatibility] Procedimento Mutuamente Exclusivo" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_EDIT_COMPAT_004" hitPolicy="FIRST">
      <input id="Input_1_EDIT_COMPAT_004" label="Compativel"><inputExpression id="InputExpression_1_EDIT_COMPAT_004" typeRef="boolean"><text>compativel</text></inputExpression></input>
      
      <output id="Output_1_EDIT_COMPAT_004" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues></output>
      <output id="Output_2_EDIT_COMPAT_004" label="Observacao" name="observacao" typeRef="string"/>
      <output id="Output_3_EDIT_COMPAT_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>
      <output id="Output_4_EDIT_COMPAT_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output>
      <output id="Output_5_EDIT_COMPAT_004" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output>
      <rule id="Rule_1_EDIT_COMPAT_004"><description>Procedimentos exclusivos - bloqueio</description><inputEntry id="InputEntry_1_1_EDIT_COMPAT_004"><text>false</text></inputEntry><outputEntry id="OutputEntry_1_1_EDIT_COMPAT_004"><text>"Bloquear"</text></outputEntry><outputEntry id="OutputEntry_1_2_EDIT_COMPAT_004"><text>"GLOSA CERTA: Procedimentos MUTUAMENTE EXCLUSIVOS cobrados simultaneamente (ex: 2 vias de acesso)."</text></outputEntry><outputEntry id="OutputEntry_1_3_EDIT_COMPAT_004"><text>"Excluir um dos procedimentos. Verificar tecnica realmente utilizada."</text></outputEntry><outputEntry id="OutputEntry_1_4_EDIT_COMPAT_004"><text>"DOC"</text></outputEntry><outputEntry id="OutputEntry_1_5_EDIT_COMPAT_004"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2_EDIT_COMPAT_004"><description>Procedimentos compativeis - prosseguir</description><inputEntry id="InputEntry_2_1_EDIT_COMPAT_004"><text>true</text></inputEntry><outputEntry id="OutputEntry_2_1_EDIT_COMPAT_004"><text>"Prosseguir"</text></outputEntry><outputEntry id="OutputEntry_2_2_EDIT_COMPAT_004"><text>"Procedimentos compativeis entre si. Nenhuma exclusao mutua detectada."</text></outputEntry><outputEntry id="OutputEntry_2_3_EDIT_COMPAT_004"><text>"Prosseguir padrao."</text></outputEntry><outputEntry id="OutputEntry_2_4_EDIT_COMPAT_004"><text>"NENHUM"</text></outputEntry><outputEntry id="OutputEntry_2_5_EDIT_COMPAT_004"><text>"BAIXO"</text></outputEntry></rule>
            <rule id="Rule_AlertaGeral_EDIT_COMPAT_004"><description>Situacao requer atencao - risco moderado</description>
        <inputEntry id="InputEntry_AlertaGeral_1_EDIT_COMPAT_004"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_AlertaGeral_1_EDIT_COMPAT_004"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_AlertaGeral_2_EDIT_COMPAT_004"><text>"Situacao identificada que requer atencao. Risco moderado de impacto."</text></outputEntry>
        <outputEntry id="OutputEntry_AlertaGeral_3_EDIT_COMPAT_004"><text>"Avaliar situacao e tomar medida preventiva apropriada."</text></outputEntry>
        <outputEntry id="OutputEntry_AlertaGeral_4_EDIT_COMPAT_004"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_AlertaGeral_5_EDIT_COMPAT_004"><text>"MEDIO"</text></outputEntry>
      </rule>

            <rule id="Rule_Extra_1_EDIT_COMPAT_004"><description>Regra adicional 1 - avaliacao complementar</description>
        <inputEntry id="InputEntry_Extra_1_1_EDIT_COMPAT_004"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_Extra_1_1_EDIT_COMPAT_004"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_Extra_1_2_EDIT_COMPAT_004"><text>"Avaliacao complementar 1 - verificacao adicional necessaria"</text></outputEntry>
        <outputEntry id="OutputEntry_Extra_1_3_EDIT_COMPAT_004"><text>"Realizar verificacao complementar antes de prosseguir."</text></outputEntry>
        <outputEntry id="OutputEntry_Extra_1_4_EDIT_COMPAT_004"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_Extra_1_5_EDIT_COMPAT_004"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_3_EDIT_COMPAT_004"><description>Fallback</description><inputEntry id="InputEntry_3_1_EDIT_COMPAT_004"><text>-</text></inputEntry><outputEntry id="OutputEntry_3_1_EDIT_COMPAT_004"><text>"Revisar"</text></outputEntry><outputEntry id="OutputEntry_3_2_EDIT_COMPAT_004"><text>"Analise manual necessaria."</text></outputEntry><outputEntry id="OutputEntry_3_3_EDIT_COMPAT_004"><text>"Encaminhar auditoria."</text></outputEntry><outputEntry id="OutputEntry_3_4_EDIT_COMPAT_004"><text>"NENHUM"</text></outputEntry><outputEntry id="OutputEntry_3_5_EDIT_COMPAT_004"><text>"MEDIO"</text></outputEntry></rule>
      
    </decisionTable>
  </decision>
  <dmndi:DMNDI><dmndi:DMNDiagram id="DMNDiagram_EDIT_COMPAT_004"><dmndi:DMNShape id="DMNShape_EDIT_COMPAT_004" dmnElementRef="Decision_EDIT_COMPAT_004"><dc:Bounds height="80" width="180" x="160" y="100"/></dmndi:DMNShape></dmndi:DMNDiagram></dmndi:DMNDI>
</definitions>
