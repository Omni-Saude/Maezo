<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_WarningPairs"
             name="Warning Pairs"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: warning_pairs_worker.py -->

  <!-- DMN: Warning Pairs (requires clinical justification)
       Based on: check_code_compatibility_worker.py lines 120-126
       Rule: Valid but requires justification
  -->

  <decision id="Decision_WarningPairs" name="[SP-RC-005 | coding_audit/code_compatibility] Warning Pairs" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_WarningPairs" hitPolicy="FIRST">

      <input id="Input_cid10Chapter_WarningPairs" label="CID-10 Chapter">
        <inputExpression id="InputExpr_cid10Chapter_WarningPairs" typeRef="string">
          <text>cid10_chapter</text>
        </inputExpression>
      </input>

      <input id="Input_tussPrefix_WarningPairs" label="TUSS Prefix">
        <inputExpression id="InputExpr_tussPrefix_WarningPairs" typeRef="string">
          <text>tuss_prefix</text>
        </inputExpression>
      </input>

      <output id="Output_resultado_WarningPairs" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_WarningPairs" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_WarningPairs" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <rule id="Rule_F_20_21_WarningPairs">
        <description>Psiquiatrico com neurologico: requer justificativa</description>
        <inputEntry id="IE_F20_1_WarningPairs"><text>"F"</text></inputEntry>
        <inputEntry id="IE_F20_2_WarningPairs"><text>"20","21"</text></inputEntry>
        <outputEntry id="OE_F20_res_WarningPairs"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_F20_acao_WarningPairs"><text>"Combinacao CID-10 F com TUSS 20/21 requer justificativa clinica adicional"</text></outputEntry>
        <outputEntry id="OE_F20_risco_WarningPairs"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_E_40_41_WarningPairs">
        <description>Endocrino com cardiaco: verificar correlacao</description>
        <inputEntry id="IE_E40_1_WarningPairs"><text>"E"</text></inputEntry>
        <inputEntry id="IE_E40_2_WarningPairs"><text>"40","41"</text></inputEntry>
        <outputEntry id="OE_E40_res_WarningPairs"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_E40_acao_WarningPairs"><text>"Combinacao CID-10 E com TUSS 40/41 - verificar correlacao clinica"</text></outputEntry>
        <outputEntry id="OE_E40_risco_WarningPairs"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_HighRiskPair_WarningPairs">
        <description>Par de codigos com risco alto de incompatibilidade</description>
        <inputEntry id="IE_HighRiskPair_1_WarningPairs"><text>-</text></inputEntry>
        <inputEntry id="IE_HighRiskPair_2_WarningPairs"><text>-</text></inputEntry>
        <outputEntry id="OE_HighRiskPair_res_WarningPairs"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_HighRiskPair_acao_WarningPairs"><text>"Par de codigos com historico de glosa frequente - revisao obrigatoria"</text></outputEntry>
        <outputEntry id="OE_HighRiskPair_risco_WarningPairs"><text>"ALTO"</text></outputEntry>
      </rule>


      <rule id="Rule_MediumRiskPair_WarningPairs">
        <description>Par com risco moderado</description>
        <inputEntry id="IE_MediumRiskPair_1_WarningPairs"><text>-</text></inputEntry>
        <inputEntry id="IE_MediumRiskPair_2_WarningPairs"><text>-</text></inputEntry>
        <outputEntry id="OE_MediumRiskPair_res_WarningPairs"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_MediumRiskPair_acao_WarningPairs"><text>"Par de codigos com risco moderado - verificar indicacao clinica"</text></outputEntry>
        <outputEntry id="OE_MediumRiskPair_risco_WarningPairs"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_No_Warning_WarningPairs">
        <description>Sem alerta de compatibilidade</description>
        <inputEntry id="IE_NoWarn_1_WarningPairs"><text>-</text></inputEntry>
        <inputEntry id="IE_NoWarn_2_WarningPairs"><text>-</text></inputEntry>
        <outputEntry id="OE_NoWarn_res_WarningPairs"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_NoWarn_acao_WarningPairs"><text>"Nenhum alerta de compatibilidade"</text></outputEntry>
        <outputEntry id="OE_NoWarn_risco_WarningPairs"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_WarningPairs">
      <dmndi:DMNShape id="DMNShape_Decision_WarningPairs" dmnElementRef="Decision_WarningPairs">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
