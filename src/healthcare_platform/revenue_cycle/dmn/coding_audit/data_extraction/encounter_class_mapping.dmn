<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_EncounterClassMapping"
             name="Encounter Class Mapping Decision"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: encounter_class_mapping_worker.py -->

  <!-- DMN: Encounter Class Mapping
       Based on: extract_clinical_data_worker.py lines 197-210
       Rule: Map FHIR encounter class to Brazilian healthcare classification
  -->

  <decision id="Decision_EncounterClassMapping" name="[SP-RC-005 | coding_audit/data_extraction] Encounter Class Mapping" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_EncounterClassMapping" hitPolicy="FIRST">

      <!-- === INPUTS === -->
      <input id="Input_fhirClassCode_EncounterClassMapping" label="FHIR Class Code">
        <inputExpression id="InputExpr_fhirClassCode_EncounterClassMapping" typeRef="string">
          <text>fhir_class_code</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->
      <output id="Output_resultado_EncounterClassMapping" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_EncounterClassMapping" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_EncounterClassMapping" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: IMP - internacao -->
      <rule id="Rule_Internacao_EncounterClassMapping">
        <description>Mapeamento FHIR IMP para internacao</description>
        <inputEntry id="IE_Int_1_EncounterClassMapping"><text>"IMP"</text></inputEntry>
        <outputEntry id="OE_Int_res_EncounterClassMapping"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Int_acao_EncounterClassMapping"><text>"internacao"</text></outputEntry>
        <outputEntry id="OE_Int_risco_EncounterClassMapping"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 2: AMB - ambulatorio -->
      <rule id="Rule_Ambulatorio_EncounterClassMapping">
        <description>Mapeamento FHIR AMB para ambulatorio</description>
        <inputEntry id="IE_Amb_1_EncounterClassMapping"><text>"AMB"</text></inputEntry>
        <outputEntry id="OE_Amb_res_EncounterClassMapping"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Amb_acao_EncounterClassMapping"><text>"ambulatorio"</text></outputEntry>
        <outputEntry id="OE_Amb_risco_EncounterClassMapping"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 3: EMER - emergencia -->
      <rule id="Rule_Emergencia_EncounterClassMapping">
        <description>Mapeamento FHIR EMER para emergencia</description>
        <inputEntry id="IE_Emer_1_EncounterClassMapping"><text>"EMER"</text></inputEntry>
        <outputEntry id="OE_Emer_res_EncounterClassMapping"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Emer_acao_EncounterClassMapping"><text>"emergencia"</text></outputEntry>
        <outputEntry id="OE_Emer_risco_EncounterClassMapping"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 4: SS - ambulatorio (Short Stay) -->
      <rule id="Rule_ShortStay_EncounterClassMapping">
        <description>Mapeamento FHIR SS para ambulatorio</description>
        <inputEntry id="IE_SS_1_EncounterClassMapping"><text>"SS"</text></inputEntry>
        <outputEntry id="OE_SS_res_EncounterClassMapping"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_SS_acao_EncounterClassMapping"><text>"ambulatorio"</text></outputEntry>
        <outputEntry id="OE_SS_risco_EncounterClassMapping"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 5: HH - domiciliar (Home Health) -->
      <rule id="Rule_Domiciliar_EncounterClassMapping">
        <description>Mapeamento FHIR HH para domiciliar</description>
        <inputEntry id="IE_HH_1_EncounterClassMapping"><text>"HH"</text></inputEntry>
        <outputEntry id="OE_HH_res_EncounterClassMapping"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_HH_acao_EncounterClassMapping"><text>"domiciliar"</text></outputEntry>
        <outputEntry id="OE_HH_risco_EncounterClassMapping"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 6: OBSENC - internacao (Obstetric Encounter) -->
      <rule id="Rule_Obstetric_EncounterClassMapping">
        <description>Mapeamento FHIR OBSENC para internacao</description>
        <inputEntry id="IE_Obs_1_EncounterClassMapping"><text>"OBSENC"</text></inputEntry>
        <outputEntry id="OE_Obs_res_EncounterClassMapping"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Obs_acao_EncounterClassMapping"><text>"internacao"</text></outputEntry>
        <outputEntry id="OE_Obs_risco_EncounterClassMapping"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Fallback: Unknown class - default to ambulatorio -->
      <rule id="Rule_Fallback_EncounterClassMapping">
        <description>Classe FHIR desconhecida - padrao ambulatorio</description>
        <inputEntry id="IE_fb_1_EncounterClassMapping"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res_EncounterClassMapping"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_fb_acao_EncounterClassMapping"><text>"ambulatorio"</text></outputEntry>
        <outputEntry id="OE_fb_risco_EncounterClassMapping"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_EncounterClassMapping">
      <dmndi:DMNShape id="DMNShape_Decision_EncounterClassMapping" dmnElementRef="Decision_EncounterClassMapping">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
