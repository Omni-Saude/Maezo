<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_CHARGE_CALCULATION"
             name="Charge Calculation Rules"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Charge Calculation Rules
       Archetype: ADMIN_ADJUDICATION
       Outputs: resultado, acao, risco
       Hit Policy: FIRST
       Worker: calculate_charges_worker.py
  -->

  <decision id="Decision_CHARGE_CALCULATION" name="[SP-RC-006 | billing/charges] Charge Calculation Rules" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_CHARGE_CALCULATION" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_PROC_CODE_CHARGE_CALCULATION" label="Procedure Code">
        <inputExpression id="InputExpr_PROC_CODE_CHARGE_CALCULATION" typeRef="string">
          <text>procedureCode</text>
        </inputExpression>
      </input>

      <input id="Input_QUANTITY_CHARGE_CALCULATION" label="Quantity">
        <inputExpression id="InputExpr_QUANTITY_CHARGE_CALCULATION" typeRef="number">
          <text>quantity</text>
        </inputExpression>
      </input>

      <input id="Input_UNIT_PRICE_CHARGE_CALCULATION" label="Unit Price">
        <inputExpression id="InputExpr_UNIT_PRICE_CHARGE_CALCULATION" typeRef="number">
          <text>unitPrice</text>
        </inputExpression>
      </input>

      <input id="Input_MODIFIER_TYPE_CHARGE_CALCULATION" label="Modifier Type">
        <inputExpression id="InputExpr_MODIFIER_TYPE_CHARGE_CALCULATION" typeRef="string">
          <text>modifierType</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado_CHARGE_CALCULATION" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_CHARGE_CALCULATION" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_CHARGE_CALCULATION" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Missing procedure code -->
      <rule id="Rule_PROC_CODE_MISSING_CHARGE_CALCULATION">
        <description>Rejeitar codigo de procedimento ausente</description>
        <inputEntry id="IE_PROC_CODE_MISSING_1_CHARGE_CALCULATION"><text>null,"","-"</text></inputEntry>
        <inputEntry id="IE_PROC_CODE_MISSING_2_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_PROC_CODE_MISSING_3_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_PROC_CODE_MISSING_4_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <outputEntry id="OE_PROC_CODE_MISSING_res_CHARGE_CALCULATION"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_PROC_CODE_MISSING_acao_CHARGE_CALCULATION"><text>"Rejeitar codigo de procedimento ausente"</text></outputEntry>
        <outputEntry id="OE_PROC_CODE_MISSING_risco_CHARGE_CALCULATION"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Invalid quantity -->
      <rule id="Rule_QUANTITY_INVALID_CHARGE_CALCULATION">
        <description>Rejeitar quantidade invalida</description>
        <inputEntry id="IE_QUANTITY_INVALID_1_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_QUANTITY_INVALID_2_CHARGE_CALCULATION"><text>&lt;= 0</text></inputEntry>
        <inputEntry id="IE_QUANTITY_INVALID_3_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_QUANTITY_INVALID_4_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <outputEntry id="OE_QUANTITY_INVALID_res_CHARGE_CALCULATION"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_QUANTITY_INVALID_acao_CHARGE_CALCULATION"><text>"Rejeitar quantidade invalida"</text></outputEntry>
        <outputEntry id="OE_QUANTITY_INVALID_risco_CHARGE_CALCULATION"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Negative unit price -->
      <rule id="Rule_UNIT_PRICE_NEGATIVE_CHARGE_CALCULATION">
        <description>Rejeitar preco unitario negativo</description>
        <inputEntry id="IE_UNIT_PRICE_NEGATIVE_1_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_UNIT_PRICE_NEGATIVE_2_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_UNIT_PRICE_NEGATIVE_3_CHARGE_CALCULATION"><text>&lt; 0</text></inputEntry>
        <inputEntry id="IE_UNIT_PRICE_NEGATIVE_4_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <outputEntry id="OE_UNIT_PRICE_NEGATIVE_res_CHARGE_CALCULATION"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_UNIT_PRICE_NEGATIVE_acao_CHARGE_CALCULATION"><text>"Rejeitar preco unitario negativo"</text></outputEntry>
        <outputEntry id="OE_UNIT_PRICE_NEGATIVE_risco_CHARGE_CALCULATION"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Unknown modifier type -->
      <rule id="Rule_MODIFIER_UNKNOWN_CHARGE_CALCULATION">
        <description>Rejeitar tipo de modificador desconhecido</description>
        <inputEntry id="IE_MODIFIER_UNKNOWN_1_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_MODIFIER_UNKNOWN_2_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_MODIFIER_UNKNOWN_3_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_MODIFIER_UNKNOWN_4_CHARGE_CALCULATION"><text>not("percentage","fixed","",null)</text></inputEntry>
        <outputEntry id="OE_MODIFIER_UNKNOWN_res_CHARGE_CALCULATION"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_MODIFIER_UNKNOWN_acao_CHARGE_CALCULATION"><text>"Rejeitar tipo de modificador desconhecido"</text></outputEntry>
        <outputEntry id="OE_MODIFIER_UNKNOWN_risco_CHARGE_CALCULATION"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Apply percentage modifier -->
      <rule id="Rule_MODIFIER_PERCENTAGE_CHARGE_CALCULATION">
        <description>Aplicar modificador percentual</description>
        <inputEntry id="IE_MODIFIER_PERCENTAGE_1_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_MODIFIER_PERCENTAGE_2_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_MODIFIER_PERCENTAGE_3_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_MODIFIER_PERCENTAGE_4_CHARGE_CALCULATION"><text>"percentage"</text></inputEntry>
        <outputEntry id="OE_MODIFIER_PERCENTAGE_res_CHARGE_CALCULATION"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_MODIFIER_PERCENTAGE_acao_CHARGE_CALCULATION"><text>"Aplicar modificador percentual"</text></outputEntry>
        <outputEntry id="OE_MODIFIER_PERCENTAGE_risco_CHARGE_CALCULATION"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 6: Apply fixed modifier -->
      <rule id="Rule_MODIFIER_FIXED_CHARGE_CALCULATION">
        <description>Aplicar modificador fixo</description>
        <inputEntry id="IE_MODIFIER_FIXED_1_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_MODIFIER_FIXED_2_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_MODIFIER_FIXED_3_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_MODIFIER_FIXED_4_CHARGE_CALCULATION"><text>"fixed"</text></inputEntry>
        <outputEntry id="OE_MODIFIER_FIXED_res_CHARGE_CALCULATION"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_MODIFIER_FIXED_acao_CHARGE_CALCULATION"><text>"Aplicar modificador fixo"</text></outputEntry>
        <outputEntry id="OE_MODIFIER_FIXED_risco_CHARGE_CALCULATION"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 7: Fallback - no modifier -->
      <rule id="Rule_FALLBACK_CHARGE_CALCULATION">
        <description>Calcular cobranca sem modificador</description>
        <inputEntry id="IE_FALLBACK_1_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_2_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_3_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_4_CHARGE_CALCULATION"><text>-</text></inputEntry>
        <outputEntry id="OE_FALLBACK_res_CHARGE_CALCULATION"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_FALLBACK_acao_CHARGE_CALCULATION"><text>"Calcular cobranca sem modificador"</text></outputEntry>
        <outputEntry id="OE_FALLBACK_risco_CHARGE_CALCULATION"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_CHARGE_CALCULATION">
      <dmndi:DMNShape id="DMNShape_Decision_CHARGE_CALCULATION" dmnElementRef="Decision_CHARGE_CALCULATION">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
