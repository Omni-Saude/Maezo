<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  BILL-BUNDLE-EXT-002 - Pacote Ortopedia Complexa
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: BILL-BUNDLE-EXT
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_BILL_BUNDLE_EXT_002" name="Pacote Ortopedia Complexa" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_BILL_BUNDLE_EXT_002" name="[SP-RC-006 | billing/bundle-ext] Validar Pacote Ortopedia Complexa" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL_BUNDLE_EXT_002" hitPolicy="FIRST">

      <input id="Input_1_BILL_BUNDLE_EXT_002" label="Tipo Protese">
        <inputExpression id="InputExpression_1_BILL_BUNDLE_EXT_002" typeRef="string">
          <text>tipoProtese</text>
        </inputExpression>
        <inputValues><text>"quadril_total", "quadril_parcial", "joelho_total", "joelho_parcial", "coluna", "ombro"</text></inputValues>
      </input>

      <input id="Input_2_BILL_BUNDLE_EXT_002" label="Material Auxiliar Previsto">
        <inputExpression id="InputExpression_2_BILL_BUNDLE_EXT_002" typeRef="boolean">
          <text>materialAuxiliarPrevisto</text>
        </inputExpression>
      </input>

      <input id="Input_3_BILL_BUNDLE_EXT_002" label="Material Nao Previsto">
        <inputExpression id="InputExpression_3_BILL_BUNDLE_EXT_002" typeRef="boolean">
          <text>materialNaoPrevisto</text>
        </inputExpression>
      </input>

      <input id="Input_4_BILL_BUNDLE_EXT_002" label="Honorario Equipe Conforme">
        <inputExpression id="InputExpression_4_BILL_BUNDLE_EXT_002" typeRef="boolean">
          <text>honorarioEquipeConforme</text>
        </inputExpression>
      </input>

      <input id="Input_5_BILL_BUNDLE_EXT_002" label="Autorizacao Material Adicional">
        <inputExpression id="InputExpression_5_BILL_BUNDLE_EXT_002" typeRef="boolean">
          <text>autorizacaoMaterialAdicional</text>
        </inputExpression>
      </input>

      <input id="Input_6_BILL_BUNDLE_EXT_002" label="Protese Compativel Procedimento">
        <inputExpression id="InputExpression_6_BILL_BUNDLE_EXT_002" typeRef="boolean">
          <text>proteseCompativelProcedimento</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_BILL_BUNDLE_EXT_002" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_BILL_BUNDLE_EXT_002" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_BILL_BUNDLE_EXT_002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_BILL_BUNDLE_EXT_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_BILL_BUNDLE_EXT_002" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Block_1_BILL_BUNDLE_EXT_002">
        <description>Bloquear material nao previsto sem autorizacao</description>
        <inputEntry id="InputEntry_B1_1_BILL_BUNDLE_EXT_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_BILL_BUNDLE_EXT_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_BILL_BUNDLE_EXT_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_BILL_BUNDLE_EXT_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_5_BILL_BUNDLE_EXT_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_6_BILL_BUNDLE_EXT_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_BILL_BUNDLE_EXT_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_BILL_BUNDLE_EXT_002"><text>"Material auxiliar nao previsto no pacote ortopedico sem autorizacao previa. Glosa certa."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_BILL_BUNDLE_EXT_002"><text>"Obter autorizacao retroativa ou absorver custo adicional."</text></outputEntry>
<outputEntry id="Rule_Block_1_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_002"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Block_1_outputEntry_riscoDenial_BILL_BUNDLE_EXT_002"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Block_2_BILL_BUNDLE_EXT_002">
        <description>Bloquear protese incompativel com procedimento</description>
        <inputEntry id="InputEntry_B2_1_BILL_BUNDLE_EXT_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_BILL_BUNDLE_EXT_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_BILL_BUNDLE_EXT_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_BILL_BUNDLE_EXT_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_5_BILL_BUNDLE_EXT_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_6_BILL_BUNDLE_EXT_002"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_BILL_BUNDLE_EXT_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_BILL_BUNDLE_EXT_002"><text>"Tipo de protese cobrada incompativel com procedimento realizado. Verificar codigo TUSS correto."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_BILL_BUNDLE_EXT_002"><text>"Corrigir tipo de protese ou procedimento na cobranca."</text></outputEntry>
<outputEntry id="Rule_Block_2_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_002"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Block_2_outputEntry_riscoDenial_BILL_BUNDLE_EXT_002"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alert_1_BILL_BUNDLE_EXT_002">
        <description>Alertar honorarios de equipe divergentes</description>
        <inputEntry id="InputEntry_A1_1_BILL_BUNDLE_EXT_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_BILL_BUNDLE_EXT_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_BILL_BUNDLE_EXT_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_BILL_BUNDLE_EXT_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_BILL_BUNDLE_EXT_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_6_BILL_BUNDLE_EXT_002"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_BILL_BUNDLE_EXT_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_BILL_BUNDLE_EXT_002"><text>"Honorarios da equipe cirurgica divergem do valor contratado. Risco de glosa parcial."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_BILL_BUNDLE_EXT_002"><text>"Verificar tabela contratual de honorarios e ajustar se necessario."</text></outputEntry>
<outputEntry id="Rule_Alert_1_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_002"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Alert_1_outputEntry_riscoDenial_BILL_BUNDLE_EXT_002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alert_2_BILL_BUNDLE_EXT_002">
        <description>Alertar coluna com multiplos materiais auxiliares</description>
        <inputEntry id="InputEntry_A2_1_BILL_BUNDLE_EXT_002"><text>"coluna"</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_BILL_BUNDLE_EXT_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_BILL_BUNDLE_EXT_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_BILL_BUNDLE_EXT_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_5_BILL_BUNDLE_EXT_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_6_BILL_BUNDLE_EXT_002"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_BILL_BUNDLE_EXT_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_BILL_BUNDLE_EXT_002"><text>"Cirurgia de coluna com multiplos materiais. Documentar necessidade clinica de cada item."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_BILL_BUNDLE_EXT_002"><text>"Anexar justificativa clinica e imagens pre e pos-operatorias."</text></outputEntry>
<outputEntry id="Rule_Alert_2_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_002"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Alert_2_outputEntry_riscoDenial_BILL_BUNDLE_EXT_002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_1_BILL_BUNDLE_EXT_002">
        <description>Prosseguir pacote completo com extras autorizados</description>
        <inputEntry id="InputEntry_P1_1_BILL_BUNDLE_EXT_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_BILL_BUNDLE_EXT_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_BILL_BUNDLE_EXT_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_BILL_BUNDLE_EXT_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_5_BILL_BUNDLE_EXT_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_6_BILL_BUNDLE_EXT_002"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_BILL_BUNDLE_EXT_002"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_BILL_BUNDLE_EXT_002"><text>"Pacote ortopedico completo com materiais adicionais autorizados. Cobranca conforme."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_BILL_BUNDLE_EXT_002"><text>"Faturar pacote mais materiais autorizados separadamente."</text></outputEntry>
<outputEntry id="Rule_Proceed_1_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Proceed_1_outputEntry_riscoDenial_BILL_BUNDLE_EXT_002"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_2_BILL_BUNDLE_EXT_002">
        <description>Prosseguir pacote ortopedico padrao</description>
        <inputEntry id="InputEntry_P2_1_BILL_BUNDLE_EXT_002"><text>"quadril_total", "quadril_parcial", "joelho_total", "joelho_parcial"</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_BILL_BUNDLE_EXT_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_BILL_BUNDLE_EXT_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_BILL_BUNDLE_EXT_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_5_BILL_BUNDLE_EXT_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_6_BILL_BUNDLE_EXT_002"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_BILL_BUNDLE_EXT_002"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_BILL_BUNDLE_EXT_002"><text>"Cobranca do pacote ortopedico dentro dos parametros contratuais."</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_BILL_BUNDLE_EXT_002"><text>"Faturar conforme pacote negociado."</text></outputEntry>
<outputEntry id="Rule_Proceed_2_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Proceed_2_outputEntry_riscoDenial_BILL_BUNDLE_EXT_002"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_BILL_BUNDLE_EXT_002">
        <description>Caso padrao - revisar manualmente</description>
        <inputEntry id="InputEntry_F_1_BILL_BUNDLE_EXT_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_BILL_BUNDLE_EXT_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_BILL_BUNDLE_EXT_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_BILL_BUNDLE_EXT_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_BILL_BUNDLE_EXT_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_6_BILL_BUNDLE_EXT_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_BILL_BUNDLE_EXT_002"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_BILL_BUNDLE_EXT_002"><text>"Dados insuficientes para validar pacote ortopedico."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_BILL_BUNDLE_EXT_002"><text>"Verificar tipo de protese, materiais auxiliares e honorarios."</text></outputEntry>
<outputEntry id="Rule_Fallback_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Fallback_outputEntry_riscoDenial_BILL_BUNDLE_EXT_002"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BILL_BUNDLE_EXT_002">
      <dmndi:DMNShape id="DMNShape_Decision_BILL_BUNDLE_EXT_002" dmnElementRef="Decision_BILL_BUNDLE_EXT_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>