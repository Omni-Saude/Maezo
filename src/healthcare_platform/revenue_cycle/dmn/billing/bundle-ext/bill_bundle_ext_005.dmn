<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  BILL-BUNDLE-EXT-005 - Pacote Day Clinic
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: BILL-BUNDLE-EXT
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_BILL_BUNDLE_EXT_005" name="Pacote Day Clinic" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_BILL_BUNDLE_EXT_005" name="[SP-RC-006 | billing/bundle-ext] Validar Pacote Day Clinic" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL_BUNDLE_EXT_005" hitPolicy="FIRST">

      <input id="Input_1_BILL_BUNDLE_EXT_005" label="Procedimento Elegivel Day Clinic">
        <inputExpression id="InputExpression_1_BILL_BUNDLE_EXT_005" typeRef="boolean">
          <text>procedimentoElegivelDayClinic</text>
        </inputExpression>
      </input>

      <input id="Input_2_BILL_BUNDLE_EXT_005" label="Tempo Permanencia Horas">
        <inputExpression id="InputExpression_2_BILL_BUNDLE_EXT_005" typeRef="number">
          <text>tempoPermanenciaHoras</text>
        </inputExpression>
      </input>

      <input id="Input_3_BILL_BUNDLE_EXT_005" label="Tempo Maximo Contratado">
        <inputExpression id="InputExpression_3_BILL_BUNDLE_EXT_005" typeRef="number">
          <text>tempoMaximoContratado</text>
        </inputExpression>
      </input>

      <input id="Input_4_BILL_BUNDLE_EXT_005" label="Recurso Adicional Sala">
        <inputExpression id="InputExpression_4_BILL_BUNDLE_EXT_005" typeRef="boolean">
          <text>recursoAdicionalSala</text>
        </inputExpression>
      </input>

      <input id="Input_5_BILL_BUNDLE_EXT_005" label="Conversao Internacao">
        <inputExpression id="InputExpression_5_BILL_BUNDLE_EXT_005" typeRef="boolean">
          <text>conversaoInternacao</text>
        </inputExpression>
      </input>

      <input id="Input_6_BILL_BUNDLE_EXT_005" label="Complicacao Pos Procedimento">
        <inputExpression id="InputExpression_6_BILL_BUNDLE_EXT_005" typeRef="boolean">
          <text>complicacaoPosProcedimento</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_BILL_BUNDLE_EXT_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_BILL_BUNDLE_EXT_005" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_BILL_BUNDLE_EXT_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_BILL_BUNDLE_EXT_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_BILL_BUNDLE_EXT_005" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Block_1_BILL_BUNDLE_EXT_005">
        <description>Bloquear procedimento nao elegivel para day clinic</description>
        <inputEntry id="InputEntry_B1_1_BILL_BUNDLE_EXT_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_5_BILL_BUNDLE_EXT_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_6_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_BILL_BUNDLE_EXT_005"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_BILL_BUNDLE_EXT_005"><text>"Procedimento nao elegivel para regime de day clinic conforme ANVISA RDC 50."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_BILL_BUNDLE_EXT_005"><text>"Converter para internacao hospitalar ou revisar indicacao."</text></outputEntry>
<outputEntry id="Rule_Block_1_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_005"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Block_1_outputEntry_riscoDenial_BILL_BUNDLE_EXT_005"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Block_2_BILL_BUNDLE_EXT_005">
        <description>Bloquear tempo excedido sem conversao para internacao</description>
        <inputEntry id="InputEntry_B2_1_BILL_BUNDLE_EXT_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_BILL_BUNDLE_EXT_005"><text>&gt; 12</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_5_BILL_BUNDLE_EXT_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_6_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_BILL_BUNDLE_EXT_005"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_BILL_BUNDLE_EXT_005"><text>"Permanencia superior a 12 horas requer conversao para internacao."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_BILL_BUNDLE_EXT_005"><text>"Converter cobranca para regime de internacao hospitalar."</text></outputEntry>
<outputEntry id="Rule_Block_2_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_005"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Block_2_outputEntry_riscoDenial_BILL_BUNDLE_EXT_005"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Block_3_BILL_BUNDLE_EXT_005">
        <description>Bloquear tempo excedido do contratado</description>
        <inputEntry id="InputEntry_B3_1_BILL_BUNDLE_EXT_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_4_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_5_BILL_BUNDLE_EXT_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B3_6_BILL_BUNDLE_EXT_005"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_B3_1_BILL_BUNDLE_EXT_005"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B3_2_BILL_BUNDLE_EXT_005"><text>"Tempo de permanencia excede limite contratual do pacote day clinic."</text></outputEntry>
<outputEntry id="OutputEntry_B3_3_BILL_BUNDLE_EXT_005"><text>"Solicitar autorizacao de extensao ou ajustar cobranca."</text></outputEntry>
<outputEntry id="Rule_Block_3_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_005"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Block_3_outputEntry_riscoDenial_BILL_BUNDLE_EXT_005"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alert_1_BILL_BUNDLE_EXT_005">
        <description>Alertar recursos adicionais de sala</description>
        <inputEntry id="InputEntry_A1_1_BILL_BUNDLE_EXT_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_BILL_BUNDLE_EXT_005"><text>&lt;= 12</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_BILL_BUNDLE_EXT_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_6_BILL_BUNDLE_EXT_005"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_BILL_BUNDLE_EXT_005"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_BILL_BUNDLE_EXT_005"><text>"Recursos adicionais de sala podem nao estar inclusos no pacote day clinic."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_BILL_BUNDLE_EXT_005"><text>"Verificar se recursos extras estao cobertos ou cobrar separadamente."</text></outputEntry>
<outputEntry id="Rule_Alert_1_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_005"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Alert_1_outputEntry_riscoDenial_BILL_BUNDLE_EXT_005"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alert_2_BILL_BUNDLE_EXT_005">
        <description>Alertar complicacao pos procedimento</description>
        <inputEntry id="InputEntry_A2_1_BILL_BUNDLE_EXT_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_5_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_6_BILL_BUNDLE_EXT_005"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_BILL_BUNDLE_EXT_005"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_BILL_BUNDLE_EXT_005"><text>"Complicacao pos procedimento pode justificar conversao para internacao."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_BILL_BUNDLE_EXT_005"><text>"Avaliar necessidade de internacao e documentar complicacao."</text></outputEntry>
<outputEntry id="Rule_Alert_2_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_005"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Alert_2_outputEntry_riscoDenial_BILL_BUNDLE_EXT_005"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_1_BILL_BUNDLE_EXT_005">
        <description>Prosseguir conversao para internacao</description>
        <inputEntry id="InputEntry_P1_1_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_5_BILL_BUNDLE_EXT_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_6_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_BILL_BUNDLE_EXT_005"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_BILL_BUNDLE_EXT_005"><text>"Conversao para internacao autorizada. Cobrar conforme regime hospitalar."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_BILL_BUNDLE_EXT_005"><text>"Faturar como internacao hospitalar com justificativa de conversao."</text></outputEntry>
<outputEntry id="Rule_Proceed_1_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_005"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Proceed_1_outputEntry_riscoDenial_BILL_BUNDLE_EXT_005"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_2_BILL_BUNDLE_EXT_005">
        <description>Prosseguir pacote day clinic padrao</description>
        <inputEntry id="InputEntry_P2_1_BILL_BUNDLE_EXT_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_BILL_BUNDLE_EXT_005"><text>&lt;= 8</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_BILL_BUNDLE_EXT_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P2_5_BILL_BUNDLE_EXT_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P2_6_BILL_BUNDLE_EXT_005"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_BILL_BUNDLE_EXT_005"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_BILL_BUNDLE_EXT_005"><text>"Pacote day clinic dentro dos parametros. Cobranca conforme."</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_BILL_BUNDLE_EXT_005"><text>"Faturar pacote day clinic padrao."</text></outputEntry>
<outputEntry id="Rule_Proceed_2_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_005"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Proceed_2_outputEntry_riscoDenial_BILL_BUNDLE_EXT_005"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_BILL_BUNDLE_EXT_005">
        <description>Caso padrao - revisar manualmente</description>
        <inputEntry id="InputEntry_F_1_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_6_BILL_BUNDLE_EXT_005"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_BILL_BUNDLE_EXT_005"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_BILL_BUNDLE_EXT_005"><text>"Dados insuficientes para validar pacote day clinic."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_BILL_BUNDLE_EXT_005"><text>"Verificar elegibilidade, tempo e recursos utilizados."</text></outputEntry>
<outputEntry id="Rule_Fallback_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_005"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Fallback_outputEntry_riscoDenial_BILL_BUNDLE_EXT_005"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BILL_BUNDLE_EXT_005">
      <dmndi:DMNShape id="DMNShape_Decision_BILL_BUNDLE_EXT_005" dmnElementRef="Decision_BILL_BUNDLE_EXT_005">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>