<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  BILL-BUNDLE-EXT-001 - Pacote Cirurgia Cardiaca
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: BILL-BUNDLE-EXT
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_BILL_BUNDLE_EXT_001" name="Pacote Cirurgia Cardiaca" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_BILL_BUNDLE_EXT_001" name="[SP-RC-006 | billing/bundle-ext] Validar Pacote Cirurgia Cardiaca" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL_BUNDLE_EXT_001" hitPolicy="FIRST">

      <input id="Input_1_BILL_BUNDLE_EXT_001" label="Tipo Procedimento Cardiaco">
        <inputExpression id="InputExpression_1_BILL_BUNDLE_EXT_001" typeRef="string">
          <text>tipoProcedimentoCardiaco</text>
        </inputExpression>
        <inputValues><text>"revascularizacao", "valvula", "congenita", "transplante", "marcapasso"</text></inputValues>
      </input>

      <input id="Input_2_BILL_BUNDLE_EXT_001" label="Itens Inclusos no Pacote">
        <inputExpression id="InputExpression_2_BILL_BUNDLE_EXT_001" typeRef="string">
          <text>itensInclusos</text>
        </inputExpression>
        <inputValues><text>"completo", "parcial", "basico"</text></inputValues>
      </input>

      <input id="Input_3_BILL_BUNDLE_EXT_001" label="Item Fora do Pacote">
        <inputExpression id="InputExpression_3_BILL_BUNDLE_EXT_001" typeRef="boolean">
          <text>itemForaPacote</text>
        </inputExpression>
      </input>

      <input id="Input_4_BILL_BUNDLE_EXT_001" label="Aprovacao Previa Item Adicional">
        <inputExpression id="InputExpression_4_BILL_BUNDLE_EXT_001" typeRef="boolean">
          <text>aprovacaoPreviaItemAdicional</text>
        </inputExpression>
      </input>

      <input id="Input_5_BILL_BUNDLE_EXT_001" label="Valor Negociado Respeitado">
        <inputExpression id="InputExpression_5_BILL_BUNDLE_EXT_001" typeRef="boolean">
          <text>valorNegociadoRespeitado</text>
        </inputExpression>
      </input>

      <input id="Input_6_BILL_BUNDLE_EXT_001" label="Item Questionavel">
        <inputExpression id="InputExpression_6_BILL_BUNDLE_EXT_001" typeRef="boolean">
          <text>itemQuestionavel</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_BILL_BUNDLE_EXT_001" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_BILL_BUNDLE_EXT_001" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_BILL_BUNDLE_EXT_001" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_BILL_BUNDLE_EXT_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_BILL_BUNDLE_EXT_001" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Block_1_BILL_BUNDLE_EXT_001">
        <description>Bloquear item fora do pacote sem aprovacao previa</description>
        <inputEntry id="InputEntry_B1_1_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_BILL_BUNDLE_EXT_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_BILL_BUNDLE_EXT_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_5_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_6_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_BILL_BUNDLE_EXT_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_BILL_BUNDLE_EXT_001"><text>"Item fora do pacote de cirurgia cardiaca sem aprovacao previa. Alto risco de glosa conforme RN ANS 465."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_BILL_BUNDLE_EXT_001"><text>"Obter aprovacao para item adicional ou remover da cobranca."</text></outputEntry>
<outputEntry id="Rule_Block_1_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_001"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Block_1_outputEntry_riscoDenial_BILL_BUNDLE_EXT_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Block_2_BILL_BUNDLE_EXT_001">
        <description>Bloquear valor fora do negociado para pacote</description>
        <inputEntry id="InputEntry_B2_1_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_BILL_BUNDLE_EXT_001"><text>"completo", "parcial"</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_BILL_BUNDLE_EXT_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_5_BILL_BUNDLE_EXT_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_6_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_BILL_BUNDLE_EXT_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_BILL_BUNDLE_EXT_001"><text>"Valor cobrado excede valor negociado do pacote cardiaco. Diferenca sera glosada."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_BILL_BUNDLE_EXT_001"><text>"Ajustar valor ao contratado ou solicitar reajuste formal."</text></outputEntry>
<outputEntry id="Rule_Block_2_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_001"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Block_2_outputEntry_riscoDenial_BILL_BUNDLE_EXT_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alert_1_BILL_BUNDLE_EXT_001">
        <description>Alertar item questionavel no pacote</description>
        <inputEntry id="InputEntry_A1_1_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_BILL_BUNDLE_EXT_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_BILL_BUNDLE_EXT_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_6_BILL_BUNDLE_EXT_001"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_BILL_BUNDLE_EXT_001"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_BILL_BUNDLE_EXT_001"><text>"Item do pacote pode ser questionado pela operadora. Recomendado reforcar documentacao."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_BILL_BUNDLE_EXT_001"><text>"Anexar justificativa clinica e laudo do item questionavel."</text></outputEntry>
<outputEntry id="Rule_Alert_1_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_001"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Alert_1_outputEntry_riscoDenial_BILL_BUNDLE_EXT_001"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alert_2_BILL_BUNDLE_EXT_001">
        <description>Alertar transplante com pacote basico</description>
        <inputEntry id="InputEntry_A2_1_BILL_BUNDLE_EXT_001"><text>"transplante"</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_BILL_BUNDLE_EXT_001"><text>"basico"</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_5_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_6_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_BILL_BUNDLE_EXT_001"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_BILL_BUNDLE_EXT_001"><text>"Transplante cardiaco com pacote basico pode nao cobrir imunossupressores e monitoramento pos-op."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_BILL_BUNDLE_EXT_001"><text>"Verificar cobertura completa ou negociar upgrade de pacote."</text></outputEntry>
<outputEntry id="Rule_Alert_2_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_001"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Alert_2_outputEntry_riscoDenial_BILL_BUNDLE_EXT_001"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_1_BILL_BUNDLE_EXT_001">
        <description>Prosseguir pacote completo com extras aprovados</description>
        <inputEntry id="InputEntry_P1_1_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_BILL_BUNDLE_EXT_001"><text>"completo"</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_BILL_BUNDLE_EXT_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_BILL_BUNDLE_EXT_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_5_BILL_BUNDLE_EXT_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_6_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_BILL_BUNDLE_EXT_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_BILL_BUNDLE_EXT_001"><text>"Pacote cardiaco completo com itens adicionais aprovados. Cobranca conforme contrato."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_BILL_BUNDLE_EXT_001"><text>"Faturar pacote completo mais itens aprovados separadamente."</text></outputEntry>
<outputEntry id="Rule_Proceed_1_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Proceed_1_outputEntry_riscoDenial_BILL_BUNDLE_EXT_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_2_BILL_BUNDLE_EXT_001">
        <description>Prosseguir cobranca padrao do pacote</description>
        <inputEntry id="InputEntry_P2_1_BILL_BUNDLE_EXT_001"><text>"revascularizacao", "valvula", "marcapasso"</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_BILL_BUNDLE_EXT_001"><text>"completo", "parcial"</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_BILL_BUNDLE_EXT_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_5_BILL_BUNDLE_EXT_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_6_BILL_BUNDLE_EXT_001"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_BILL_BUNDLE_EXT_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_BILL_BUNDLE_EXT_001"><text>"Cobranca do pacote cardiaco dentro dos parametros contratuais."</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_BILL_BUNDLE_EXT_001"><text>"Faturar conforme pacote negociado."</text></outputEntry>
<outputEntry id="Rule_Proceed_2_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Proceed_2_outputEntry_riscoDenial_BILL_BUNDLE_EXT_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_BILL_BUNDLE_EXT_001">
        <description>Caso padrao - revisar manualmente</description>
        <inputEntry id="InputEntry_F_1_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_6_BILL_BUNDLE_EXT_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_BILL_BUNDLE_EXT_001"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_BILL_BUNDLE_EXT_001"><text>"Dados insuficientes para validar pacote de cirurgia cardiaca."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_BILL_BUNDLE_EXT_001"><text>"Verificar tipo de procedimento, itens inclusos e valores negociados."</text></outputEntry>
<outputEntry id="Rule_Fallback_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Fallback_outputEntry_riscoDenial_BILL_BUNDLE_EXT_001"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BILL_BUNDLE_EXT_001">
      <dmndi:DMNShape id="DMNShape_Decision_BILL_BUNDLE_EXT_001" dmnElementRef="Decision_BILL_BUNDLE_EXT_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>