<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  BILL-BUNDLE-EXT-004 - Pacote Maternidade
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: BILL-BUNDLE-EXT
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_BILL_BUNDLE_EXT_004" name="Pacote Maternidade" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_BILL_BUNDLE_EXT_004" name="[SP-RC-006 | billing/bundle-ext] Validar Pacote Maternidade" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL_BUNDLE_EXT_004" hitPolicy="FIRST">

      <input id="Input_1_BILL_BUNDLE_EXT_004" label="Tipo Parto">
        <inputExpression id="InputExpression_1_BILL_BUNDLE_EXT_004" typeRef="string">
          <text>tipoParto</text>
        </inputExpression>
        <inputValues><text>"normal", "cesarea_eletiva", "cesarea_urgencia", "forceps", "vacuo"</text></inputValues>
      </input>

      <input id="Input_2_BILL_BUNDLE_EXT_004" label="Intercorrencias Documentadas">
        <inputExpression id="InputExpression_2_BILL_BUNDLE_EXT_004" typeRef="boolean">
          <text>intercorrenciasDocumentadas</text>
        </inputExpression>
      </input>

      <input id="Input_3_BILL_BUNDLE_EXT_004" label="Intercorrencia Coberta no Pacote">
        <inputExpression id="InputExpression_3_BILL_BUNDLE_EXT_004" typeRef="boolean">
          <text>intercorrenciaCobertaPacote</text>
        </inputExpression>
      </input>

      <input id="Input_4_BILL_BUNDLE_EXT_004" label="Dias Internacao">
        <inputExpression id="InputExpression_4_BILL_BUNDLE_EXT_004" typeRef="number">
          <text>diasInternacao</text>
        </inputExpression>
      </input>

      <input id="Input_5_BILL_BUNDLE_EXT_004" label="Dias Excedidos Autorizados">
        <inputExpression id="InputExpression_5_BILL_BUNDLE_EXT_004" typeRef="boolean">
          <text>diasExcedidosAutorizados</text>
        </inputExpression>
      </input>

      <input id="Input_6_BILL_BUNDLE_EXT_004" label="UTI Neonatal Necessaria">
        <inputExpression id="InputExpression_6_BILL_BUNDLE_EXT_004" typeRef="boolean">
          <text>utiNeonatalNecessaria</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_BILL_BUNDLE_EXT_004" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_BILL_BUNDLE_EXT_004" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_BILL_BUNDLE_EXT_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_BILL_BUNDLE_EXT_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_BILL_BUNDLE_EXT_004" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Block_1_BILL_BUNDLE_EXT_004">
        <description>Bloquear intercorrencia nao coberta no pacote</description>
        <inputEntry id="InputEntry_B1_1_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_BILL_BUNDLE_EXT_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_BILL_BUNDLE_EXT_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_5_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_6_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_BILL_BUNDLE_EXT_004"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_BILL_BUNDLE_EXT_004"><text>"Intercorrencia obstetrica nao prevista no pacote maternidade. Cobranca separada requer autorizacao."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_BILL_BUNDLE_EXT_004"><text>"Solicitar autorizacao para intercorrencia ou incluir em aditivo contratual."</text></outputEntry>
<outputEntry id="Rule_Block_1_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_004"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Block_1_outputEntry_riscoDenial_BILL_BUNDLE_EXT_004"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Block_2_BILL_BUNDLE_EXT_004">
        <description>Bloquear dias excedidos cesarea sem autorizacao</description>
        <inputEntry id="InputEntry_B2_1_BILL_BUNDLE_EXT_004"><text>"cesarea_eletiva", "cesarea_urgencia"</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_BILL_BUNDLE_EXT_004"><text>&gt; 3</text></inputEntry>
        <inputEntry id="InputEntry_B2_5_BILL_BUNDLE_EXT_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_6_BILL_BUNDLE_EXT_004"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_BILL_BUNDLE_EXT_004"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_BILL_BUNDLE_EXT_004"><text>"Cesarea com mais de 3 dias sem autorizacao de prorrogacao. Diarias excedentes serao glosadas."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_BILL_BUNDLE_EXT_004"><text>"Obter autorizacao de prorrogacao com justificativa clinica."</text></outputEntry>
<outputEntry id="Rule_Block_2_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_004"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Block_2_outputEntry_riscoDenial_BILL_BUNDLE_EXT_004"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Block_3_BILL_BUNDLE_EXT_004">
        <description>Bloquear dias excedidos parto normal sem autorizacao</description>
        <inputEntry id="InputEntry_B3_1_BILL_BUNDLE_EXT_004"><text>"normal", "forceps", "vacuo"</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_4_BILL_BUNDLE_EXT_004"><text>&gt; 2</text></inputEntry>
        <inputEntry id="InputEntry_B3_5_BILL_BUNDLE_EXT_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B3_6_BILL_BUNDLE_EXT_004"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_B3_1_BILL_BUNDLE_EXT_004"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B3_2_BILL_BUNDLE_EXT_004"><text>"Parto normal com mais de 2 dias sem autorizacao de prorrogacao."</text></outputEntry>
<outputEntry id="OutputEntry_B3_3_BILL_BUNDLE_EXT_004"><text>"Justificar necessidade clinica de internacao prolongada."</text></outputEntry>
<outputEntry id="Rule_Block_3_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_004"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Block_3_outputEntry_riscoDenial_BILL_BUNDLE_EXT_004"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alert_1_BILL_BUNDLE_EXT_004">
        <description>Alertar necessidade de UTI neonatal</description>
        <inputEntry id="InputEntry_A1_1_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_6_BILL_BUNDLE_EXT_004"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_BILL_BUNDLE_EXT_004"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_BILL_BUNDLE_EXT_004"><text>"UTI neonatal geralmente nao inclusa no pacote maternidade. Cobrar separadamente."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_BILL_BUNDLE_EXT_004"><text>"Verificar contrato e abrir guia separada para UTI neonatal."</text></outputEntry>
<outputEntry id="Rule_Alert_1_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_004"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Alert_1_outputEntry_riscoDenial_BILL_BUNDLE_EXT_004"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alert_2_BILL_BUNDLE_EXT_004">
        <description>Alertar dias excedidos com autorizacao</description>
        <inputEntry id="InputEntry_A2_1_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_BILL_BUNDLE_EXT_004"><text>&gt; 4</text></inputEntry>
        <inputEntry id="InputEntry_A2_5_BILL_BUNDLE_EXT_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_6_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_BILL_BUNDLE_EXT_004"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_BILL_BUNDLE_EXT_004"><text>"Internacao prolongada autorizada. Documentar evolucao clinica diaria."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_BILL_BUNDLE_EXT_004"><text>"Manter registros de evolucao e justificativa para cada dia adicional."</text></outputEntry>
<outputEntry id="Rule_Alert_2_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_004"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Alert_2_outputEntry_riscoDenial_BILL_BUNDLE_EXT_004"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_1_BILL_BUNDLE_EXT_004">
        <description>Prosseguir pacote cesarea padrao</description>
        <inputEntry id="InputEntry_P1_1_BILL_BUNDLE_EXT_004"><text>"cesarea_eletiva", "cesarea_urgencia"</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_BILL_BUNDLE_EXT_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_BILL_BUNDLE_EXT_004"><text>&lt;= 3</text></inputEntry>
        <inputEntry id="InputEntry_P1_5_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_6_BILL_BUNDLE_EXT_004"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_BILL_BUNDLE_EXT_004"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_BILL_BUNDLE_EXT_004"><text>"Pacote cesarea dentro dos parametros. Cobranca conforme contrato."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_BILL_BUNDLE_EXT_004"><text>"Faturar pacote maternidade cesarea padrao."</text></outputEntry>
<outputEntry id="Rule_Proceed_1_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_004"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Proceed_1_outputEntry_riscoDenial_BILL_BUNDLE_EXT_004"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Proceed_2_BILL_BUNDLE_EXT_004">
        <description>Prosseguir pacote parto normal padrao</description>
        <inputEntry id="InputEntry_P2_1_BILL_BUNDLE_EXT_004"><text>"normal", "forceps", "vacuo"</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_BILL_BUNDLE_EXT_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_BILL_BUNDLE_EXT_004"><text>&lt;= 2</text></inputEntry>
        <inputEntry id="InputEntry_P2_5_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_6_BILL_BUNDLE_EXT_004"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_BILL_BUNDLE_EXT_004"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_BILL_BUNDLE_EXT_004"><text>"Pacote parto normal dentro dos parametros. Cobranca conforme."</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_BILL_BUNDLE_EXT_004"><text>"Faturar pacote maternidade parto normal."</text></outputEntry>
<outputEntry id="Rule_Proceed_2_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_004"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Proceed_2_outputEntry_riscoDenial_BILL_BUNDLE_EXT_004"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_BILL_BUNDLE_EXT_004">
        <description>Caso padrao - revisar manualmente</description>
        <inputEntry id="InputEntry_F_1_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_6_BILL_BUNDLE_EXT_004"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_BILL_BUNDLE_EXT_004"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_BILL_BUNDLE_EXT_004"><text>"Dados insuficientes para validar pacote maternidade."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_BILL_BUNDLE_EXT_004"><text>"Verificar tipo de parto, dias de internacao e intercorrencias."</text></outputEntry>
<outputEntry id="Rule_Fallback_outputEntry_alertasConformidade_BILL_BUNDLE_EXT_004"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Fallback_outputEntry_riscoDenial_BILL_BUNDLE_EXT_004"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BILL_BUNDLE_EXT_004">
      <dmndi:DMNShape id="DMNShape_Decision_BILL_BUNDLE_EXT_004" dmnElementRef="Decision_BILL_BUNDLE_EXT_004">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>