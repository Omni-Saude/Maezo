<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  BILL-BUNDLE-003 - Cesariana Ligadura Bundle Validation
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: BILL-BUNDLE
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_BILL_BUNDLE_003" name="Cesariana Ligadura Bundle Validation" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_BILL_BUNDLE_003" name="[SP-RC-006 | billing/bundle] Validar Bundle Cesariana Ligadura" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL_BUNDLE_003" hitPolicy="FIRST">

      <input id="Input_1_BILL_BUNDLE_003" label="Cesariana Realizada">
        <inputExpression id="InputExpression_1_BILL_BUNDLE_003" typeRef="boolean">
          <text>cesarianaRealizada</text>
        </inputExpression>
      </input>

      <input id="Input_2_BILL_BUNDLE_003" label="Ligadura Realizada">
        <inputExpression id="InputExpression_2_BILL_BUNDLE_003" typeRef="boolean">
          <text>ligaduraRealizada</text>
        </inputExpression>
      </input>

      <input id="Input_3_BILL_BUNDLE_003" label="Termo Consentimento Valido">
        <inputExpression id="InputExpression_3_BILL_BUNDLE_003" typeRef="boolean">
          <text>termoConsentimentoValido</text>
        </inputExpression>
      </input>

      <input id="Input_4_BILL_BUNDLE_003" label="Intervalo Legal Atendido">
        <inputExpression id="InputExpression_4_BILL_BUNDLE_003" typeRef="boolean">
          <text>intervaloLegalAtendido</text>
        </inputExpression>
      </input>

      <input id="Input_5_BILL_BUNDLE_003" label="Contrato Permite Cobranca Separada">
        <inputExpression id="InputExpression_5_BILL_BUNDLE_003" typeRef="boolean">
          <text>contratoPermiteSeparada</text>
        </inputExpression>
      </input>

      <output id="Output_1_BILL_BUNDLE_003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_BILL_BUNDLE_003" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_BILL_BUNDLE_003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_BILL_BUNDLE_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_BILL_BUNDLE_003" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Block_1_BILL_BUNDLE_003">
        <description>Bloquear ligadura sem termo de consentimento valido</description>
        <inputEntry id="InputEntry_B1_1_BILL_BUNDLE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_BILL_BUNDLE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_BILL_BUNDLE_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_BILL_BUNDLE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_5_BILL_BUNDLE_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_BILL_BUNDLE_003"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_BILL_BUNDLE_003"><text>"Termo de consentimento ausente ou invalido. Lei 9.263/1996 exige consentimento expresso."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_BILL_BUNDLE_003"><text>"Obter termo de consentimento assinado com antecedencia minima de 60 dias conforme lei."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_1_4_BILL_BUNDLE_003"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_1_5_BILL_BUNDLE_003"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Block_2_BILL_BUNDLE_003">
        <description>Bloquear ligadura sem intervalo legal atendido</description>
        <inputEntry id="InputEntry_B2_1_BILL_BUNDLE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_BILL_BUNDLE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_BILL_BUNDLE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_BILL_BUNDLE_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_5_BILL_BUNDLE_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B2_1_BILL_BUNDLE_003"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_2_BILL_BUNDLE_003"><text>"Intervalo legal de 60 dias nao atendido. Risco de nao cobertura."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_3_BILL_BUNDLE_003"><text>"Documentar justificativa medica se cesaria de emergencia."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_2_4_BILL_BUNDLE_003"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_2_5_BILL_BUNDLE_003"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Block_3_BILL_BUNDLE_003">
        <description>Bloquear cobranca separada quando contrato nao permite</description>
        <inputEntry id="InputEntry_B3_1_BILL_BUNDLE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_BILL_BUNDLE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_BILL_BUNDLE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B3_4_BILL_BUNDLE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B3_5_BILL_BUNDLE_003"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_B3_1_BILL_BUNDLE_003"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B3_2_BILL_BUNDLE_003"><text>"Contrato inclui ligadura na cesariana. Cobranca separada nao permitida."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B3_3_BILL_BUNDLE_003"><text>"Cobrar apenas cesariana. Ligadura inclusa no pacote."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_3_4_BILL_BUNDLE_003"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_3_5_BILL_BUNDLE_003"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_1_BILL_BUNDLE_003">
        <description>Prosseguir cobranca separada com todos requisitos atendidos</description>
        <inputEntry id="InputEntry_P1_1_BILL_BUNDLE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_BILL_BUNDLE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_BILL_BUNDLE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_BILL_BUNDLE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_5_BILL_BUNDLE_003"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_P1_1_BILL_BUNDLE_003"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_2_BILL_BUNDLE_003"><text>"Todos requisitos legais atendidos. Cobranca separada permitida pelo contrato."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_3_BILL_BUNDLE_003"><text>"Faturar cesariana (31309178) + ligadura (31303129) separadamente."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_1_4_BILL_BUNDLE_003"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_1_5_BILL_BUNDLE_003"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_2_BILL_BUNDLE_003">
        <description>Prosseguir quando apenas cesariana realizada</description>
        <inputEntry id="InputEntry_P2_1_BILL_BUNDLE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_BILL_BUNDLE_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_BILL_BUNDLE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_BILL_BUNDLE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_5_BILL_BUNDLE_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_P2_1_BILL_BUNDLE_003"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_2_BILL_BUNDLE_003"><text>"Cesariana sem ligadura. Cobranca simples."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_3_BILL_BUNDLE_003"><text>"Faturar apenas cesariana (31309178)."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_2_4_BILL_BUNDLE_003"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_2_5_BILL_BUNDLE_003"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_BILL_BUNDLE_003">
        <description>Caso padrao - revisar manualmente</description>
        <inputEntry id="InputEntry_F_1_BILL_BUNDLE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_BILL_BUNDLE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_BILL_BUNDLE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_BILL_BUNDLE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_BILL_BUNDLE_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_BILL_BUNDLE_003"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_BILL_BUNDLE_003"><text>"Dados insuficientes para validar bundle cesariana/ligadura."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_BILL_BUNDLE_003"><text>"Verificar termo consentimento, intervalo legal e contrato."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_4_BILL_BUNDLE_003"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_5_BILL_BUNDLE_003"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BILL_BUNDLE_003">
      <dmndi:DMNShape id="DMNShape_Decision_BILL_BUNDLE_003" dmnElementRef="Decision_BILL_BUNDLE_003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>