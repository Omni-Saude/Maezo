<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  BILL-BUNDLE-005 - Cirurgia Coluna Artrodese Bundle Validation
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: BILL-BUNDLE
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_BILL_BUNDLE_005" name="Cirurgia Coluna Artrodese Bundle Validation" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_BILL_BUNDLE_005" name="[SP-RC-006 | billing/bundle] Validar Bundle Coluna Artrodese" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL_BUNDLE_005" hitPolicy="FIRST">

      <input id="Input_1_BILL_BUNDLE_005" label="Tipo Procedimento Principal">
        <inputExpression id="InputExpression_1_BILL_BUNDLE_005" typeRef="string">
          <text>tipoProcedimentoPrincipal</text>
        </inputExpression>
        <inputValues><text>"artrodese", "descompressao", "discectomia", "outro"</text></inputValues>
      </input>

      <input id="Input_2_BILL_BUNDLE_005" label="Numero Niveis">
        <inputExpression id="InputExpression_2_BILL_BUNDLE_005" typeRef="number">
          <text>numeroNiveis</text>
        </inputExpression>
      </input>

      <input id="Input_3_BILL_BUNDLE_005" label="Implantes Utilizados">
        <inputExpression id="InputExpression_3_BILL_BUNDLE_005" typeRef="boolean">
          <text>implantesUtilizados</text>
        </inputExpression>
      </input>

      <input id="Input_4_BILL_BUNDLE_005" label="Contrato Pagamento Por Nivel">
        <inputExpression id="InputExpression_4_BILL_BUNDLE_005" typeRef="boolean">
          <text>contratoPagamentoPorNivel</text>
        </inputExpression>
      </input>

      <input id="Input_5_BILL_BUNDLE_005" label="Documentacao Imagem Completa">
        <inputExpression id="InputExpression_5_BILL_BUNDLE_005" typeRef="boolean">
          <text>documentacaoImagemCompleta</text>
        </inputExpression>
      </input>

      <output id="Output_1_BILL_BUNDLE_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_BILL_BUNDLE_005" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_BILL_BUNDLE_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_BILL_BUNDLE_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_BILL_BUNDLE_005" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Block_1_BILL_BUNDLE_005">
        <description>Bloquear artrodese sem documentacao de imagem completa</description>
        <inputEntry id="InputEntry_B1_1_BILL_BUNDLE_005"><text>"artrodese"</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_BILL_BUNDLE_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_BILL_BUNDLE_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_BILL_BUNDLE_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_5_BILL_BUNDLE_005"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_BILL_BUNDLE_005"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_BILL_BUNDLE_005"><text>"Artrodese sem documentacao de imagem pre e pos-operatoria. Alto risco de glosa."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_BILL_BUNDLE_005"><text>"Anexar RM/TC pre-op e radiografia pos-op confirmando niveis e implantes."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_1_4_BILL_BUNDLE_005"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_1_5_BILL_BUNDLE_005"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Block_2_BILL_BUNDLE_005">
        <description>Bloquear niveis acima do padrao sem pagamento por nivel</description>
        <inputEntry id="InputEntry_B2_1_BILL_BUNDLE_005"><text>"artrodese"</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_BILL_BUNDLE_005"><text>&gt; 3</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_BILL_BUNDLE_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_BILL_BUNDLE_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_5_BILL_BUNDLE_005"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_B2_1_BILL_BUNDLE_005"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_2_BILL_BUNDLE_005"><text>"Artrodese de mais de 3 niveis sem contrato de pagamento por nivel. Revisar cobertura."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_3_BILL_BUNDLE_005"><text>"Negociar pagamento por nivel adicional ou justificar clinicamente extensao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_2_4_BILL_BUNDLE_005"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_2_5_BILL_BUNDLE_005"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alert_1_BILL_BUNDLE_005">
        <description>Alertar artrodese multinivel - confirmar cobranca por nivel</description>
        <inputEntry id="InputEntry_A1_1_BILL_BUNDLE_005"><text>"artrodese"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_BILL_BUNDLE_005"><text>&gt; 2</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_BILL_BUNDLE_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_BILL_BUNDLE_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_BILL_BUNDLE_005"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_BILL_BUNDLE_005"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_BILL_BUNDLE_005"><text>"Artrodese multinivel com pagamento por nivel. Confirmar quantidade de implantes."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_BILL_BUNDLE_005"><text>"Documentar cada nivel com imagem e listar todos implantes utilizados."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alert_1_4_BILL_BUNDLE_005"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Alert_1_5_BILL_BUNDLE_005"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_1_BILL_BUNDLE_005">
        <description>Prosseguir artrodese padrao com documentacao</description>
        <inputEntry id="InputEntry_P1_1_BILL_BUNDLE_005"><text>"artrodese"</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_BILL_BUNDLE_005"><text>[1..3]</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_BILL_BUNDLE_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_BILL_BUNDLE_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_5_BILL_BUNDLE_005"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_P1_1_BILL_BUNDLE_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_2_BILL_BUNDLE_005"><text>"Artrodese padrao com documentacao completa. Cobranca aprovada."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_3_BILL_BUNDLE_005"><text>"Faturar procedimento com nota fiscal de implantes."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_1_4_BILL_BUNDLE_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_1_5_BILL_BUNDLE_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_2_BILL_BUNDLE_005">
        <description>Prosseguir descompressao simples</description>
        <inputEntry id="InputEntry_P2_1_BILL_BUNDLE_005"><text>"descompressao", "discectomia"</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_BILL_BUNDLE_005"><text>[1..2]</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_BILL_BUNDLE_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_BILL_BUNDLE_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_5_BILL_BUNDLE_005"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_P2_1_BILL_BUNDLE_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_2_BILL_BUNDLE_005"><text>"Descompressao/discectomia sem implantes. Cobranca padrao."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_3_BILL_BUNDLE_005"><text>"Faturar procedimento conforme tabela."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_2_4_BILL_BUNDLE_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_2_5_BILL_BUNDLE_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_BILL_BUNDLE_005">
        <description>Caso padrao - revisar manualmente</description>
        <inputEntry id="InputEntry_F_1_BILL_BUNDLE_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_BILL_BUNDLE_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_BILL_BUNDLE_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_BILL_BUNDLE_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_BILL_BUNDLE_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_BILL_BUNDLE_005"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_BILL_BUNDLE_005"><text>"Dados insuficientes para validar bundle cirurgia de coluna."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_BILL_BUNDLE_005"><text>"Verificar tipo procedimento, niveis, implantes e documentacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_4_BILL_BUNDLE_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_5_BILL_BUNDLE_005"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BILL_BUNDLE_005">
      <dmndi:DMNShape id="DMNShape_Decision_BILL_BUNDLE_005" dmnElementRef="Decision_BILL_BUNDLE_005">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>