<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  BILL-BUNDLE-002 - Colecistectomia Colangiografia Bundle Validation
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: BILL-BUNDLE
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_BILL_BUNDLE_002" name="Colecistectomia Colangiografia Bundle Validation" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_BILL_BUNDLE_002" name="[SP-RC-006 | billing/bundle] Validar Bundle Colecistectomia Colangiografia" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL_BUNDLE_002" hitPolicy="FIRST">

      <input id="Input_1_BILL_BUNDLE_002" label="Codigo TUSS Cirurgia">
        <inputExpression id="InputExpression_1_BILL_BUNDLE_002" typeRef="string">
          <text>codigoTussCirurgia</text>
        </inputExpression>
      </input>

      <input id="Input_2_BILL_BUNDLE_002" label="Colangiografia Realizada">
        <inputExpression id="InputExpression_2_BILL_BUNDLE_002" typeRef="boolean">
          <text>colangiografiaRealizada</text>
        </inputExpression>
      </input>

      <input id="Input_3_BILL_BUNDLE_002" label="Contrato Inclui Colangiografia">
        <inputExpression id="InputExpression_3_BILL_BUNDLE_002" typeRef="boolean">
          <text>contratoIncluiColangiografia</text>
        </inputExpression>
      </input>

      <input id="Input_4_BILL_BUNDLE_002" label="Indicacao Clinica Documentada">
        <inputExpression id="InputExpression_4_BILL_BUNDLE_002" typeRef="boolean">
          <text>indicacaoClinicaDocumentada</text>
        </inputExpression>
      </input>

      <output id="Output_1_BILL_BUNDLE_002" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_BILL_BUNDLE_002" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_BILL_BUNDLE_002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_BILL_BUNDLE_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_BILL_BUNDLE_002" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Block_1_BILL_BUNDLE_002">
        <description>Bloquear cobranca separada quando contrato inclui colangiografia na colecistectomia</description>
        <inputEntry id="InputEntry_B1_1_BILL_BUNDLE_002"><text>"31005497"</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_BILL_BUNDLE_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_BILL_BUNDLE_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_BILL_BUNDLE_002"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_BILL_BUNDLE_002"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_BILL_BUNDLE_002"><text>"BLOQUEIO: Contrato especifica que colangiografia (40808041) esta INCLUSA no valor da colecistectomia VLP (31005497). Cobranca separada resultara em glosa."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_BILL_BUNDLE_002"><text>"Remover codigo 40808041 da conta. Cobrar apenas colecistectomia (31005497). Se discordar, negociar aditivo contratual para futuros casos."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_1_4_BILL_BUNDLE_002"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_1_5_BILL_BUNDLE_002"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alert_1_BILL_BUNDLE_002">
        <description>Alertar colangiografia sem indicacao clinica documentada</description>
        <inputEntry id="InputEntry_A1_1_BILL_BUNDLE_002"><text>"31005497"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_BILL_BUNDLE_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_BILL_BUNDLE_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_BILL_BUNDLE_002"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_BILL_BUNDLE_002"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_BILL_BUNDLE_002"><text>"ALERTA: Colangiografia realizada sem indicacao clinica documentada. Auditoria pode questionar necessidade."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_BILL_BUNDLE_002"><text>"Solicitar ao cirurgiao relatorio com indicacao clinica: suspeita de coledocolitiase, alteracao de enzimas hepaticas (GGT/FA), dilatacao de via biliar, etc."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alert_1_4_BILL_BUNDLE_002"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Alert_1_5_BILL_BUNDLE_002"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_1_BILL_BUNDLE_002">
        <description>Prosseguir cobranca separada quando contrato permite e indicacao documentada</description>
        <inputEntry id="InputEntry_P1_1_BILL_BUNDLE_002"><text>"31005497"</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_BILL_BUNDLE_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_BILL_BUNDLE_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_BILL_BUNDLE_002"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_P1_1_BILL_BUNDLE_002"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_2_BILL_BUNDLE_002"><text>"Cobranca separada permitida. Indicacao clinica documentada."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_3_BILL_BUNDLE_002"><text>"Faturar colecistectomia (31005497) + colangiografia (40808041)."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_1_4_BILL_BUNDLE_002"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_1_5_BILL_BUNDLE_002"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_2_BILL_BUNDLE_002">
        <description>Prosseguir quando colangiografia nao realizada</description>
        <inputEntry id="InputEntry_P2_1_BILL_BUNDLE_002"><text>"31005497"</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_BILL_BUNDLE_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_BILL_BUNDLE_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_BILL_BUNDLE_002"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_P2_1_BILL_BUNDLE_002"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_2_BILL_BUNDLE_002"><text>"Colecistectomia VLP sem colangiografia. Cobranca simples."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_3_BILL_BUNDLE_002"><text>"Faturar apenas colecistectomia (31005497)."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_2_4_BILL_BUNDLE_002"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_2_5_BILL_BUNDLE_002"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_BILL_BUNDLE_002">
        <description>Caso padrao - revisar manualmente</description>
        <inputEntry id="InputEntry_F_1_BILL_BUNDLE_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_BILL_BUNDLE_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_BILL_BUNDLE_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_BILL_BUNDLE_002"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_BILL_BUNDLE_002"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_BILL_BUNDLE_002"><text>"Dados insuficientes para validar bundle colecistectomia/colangiografia."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_BILL_BUNDLE_002"><text>"Verificar contrato, indicacao clinica e procedimentos realizados."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_4_BILL_BUNDLE_002"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_5_BILL_BUNDLE_002"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BILL_BUNDLE_002">
      <dmndi:DMNShape id="DMNShape_Decision_BILL_BUNDLE_002" dmnElementRef="Decision_BILL_BUNDLE_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>