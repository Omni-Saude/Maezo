<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  BILL-BUNDLE-004 - Histerectomia Ooforectomia Bundle Validation
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: BILL-BUNDLE
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_BILL_BUNDLE_004" name="Histerectomia Ooforectomia Bundle Validation" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_BILL_BUNDLE_004" name="[SP-RC-006 | billing/bundle] Validar Bundle Histerectomia Ooforectomia" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL_BUNDLE_004" hitPolicy="FIRST">

      <input id="Input_1_BILL_BUNDLE_004" label="Codigo TUSS Histerectomia">
        <inputExpression id="InputExpression_1_BILL_BUNDLE_004" typeRef="string">
          <text>codigoHisterectomia</text>
        </inputExpression>
      </input>

      <input id="Input_2_BILL_BUNDLE_004" label="Ooforectomia Bilateral">
        <inputExpression id="InputExpression_2_BILL_BUNDLE_004" typeRef="boolean">
          <text>ooforectomiaBilateral</text>
        </inputExpression>
      </input>

      <input id="Input_3_BILL_BUNDLE_004" label="Indicacao Oncologica">
        <inputExpression id="InputExpression_3_BILL_BUNDLE_004" typeRef="boolean">
          <text>indicacaoOncologica</text>
        </inputExpression>
      </input>

      <input id="Input_4_BILL_BUNDLE_004" label="Contrato Permite Separado">
        <inputExpression id="InputExpression_4_BILL_BUNDLE_004" typeRef="boolean">
          <text>contratoPermiteSeparado</text>
        </inputExpression>
      </input>

      <output id="Output_1_BILL_BUNDLE_004" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_BILL_BUNDLE_004" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_BILL_BUNDLE_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_BILL_BUNDLE_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_BILL_BUNDLE_004" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Block_1_BILL_BUNDLE_004">
        <description>Bloquear cobranca separada sem indicacao oncologica quando contrato nao permite</description>
        <inputEntry id="InputEntry_B1_1_BILL_BUNDLE_004"><text>"31306063", "31306055", "31306098"</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_BILL_BUNDLE_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_BILL_BUNDLE_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_BILL_BUNDLE_004"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_BILL_BUNDLE_004"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_BILL_BUNDLE_004"><text>"Ooforectomia profilatica sem indicacao oncologica. Contrato nao permite cobranca separada."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_BILL_BUNDLE_004"><text>"Documentar indicacao oncologica ou incluir no valor da histerectomia."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_1_4_BILL_BUNDLE_004"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_1_5_BILL_BUNDLE_004"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alert_1_BILL_BUNDLE_004">
        <description>Alertar ooforectomia bilateral sem indicacao clara</description>
        <inputEntry id="InputEntry_A1_1_BILL_BUNDLE_004"><text>"31306063", "31306055", "31306098"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_BILL_BUNDLE_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_BILL_BUNDLE_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_BILL_BUNDLE_004"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_BILL_BUNDLE_004"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_BILL_BUNDLE_004"><text>"Ooforectomia bilateral sem indicacao oncologica. Verificar justificativa medica."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_BILL_BUNDLE_004"><text>"Anexar justificativa medica detalhada para evitar glosa."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alert_1_4_BILL_BUNDLE_004"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Alert_1_5_BILL_BUNDLE_004"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_1_BILL_BUNDLE_004">
        <description>Prosseguir com indicacao oncologica</description>
        <inputEntry id="InputEntry_P1_1_BILL_BUNDLE_004"><text>"31306063", "31306055", "31306098"</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_BILL_BUNDLE_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_BILL_BUNDLE_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_BILL_BUNDLE_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_P1_1_BILL_BUNDLE_004"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_2_BILL_BUNDLE_004"><text>"Indicacao oncologica documentada. Cobranca separada justificada."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_3_BILL_BUNDLE_004"><text>"Faturar histerectomia + salpingooforectomia com CID oncologico."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_1_4_BILL_BUNDLE_004"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_1_5_BILL_BUNDLE_004"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_2_BILL_BUNDLE_004">
        <description>Prosseguir apenas histerectomia</description>
        <inputEntry id="InputEntry_P2_1_BILL_BUNDLE_004"><text>"31306063", "31306055", "31306098"</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_BILL_BUNDLE_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_BILL_BUNDLE_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_BILL_BUNDLE_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_P2_1_BILL_BUNDLE_004"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_2_BILL_BUNDLE_004"><text>"Histerectomia sem ooforectomia. Cobranca simples."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_3_BILL_BUNDLE_004"><text>"Faturar apenas histerectomia."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_2_4_BILL_BUNDLE_004"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_2_5_BILL_BUNDLE_004"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_BILL_BUNDLE_004">
        <description>Caso padrao - revisar manualmente</description>
        <inputEntry id="InputEntry_F_1_BILL_BUNDLE_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_BILL_BUNDLE_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_BILL_BUNDLE_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_BILL_BUNDLE_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_BILL_BUNDLE_004"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_BILL_BUNDLE_004"><text>"Dados insuficientes para validar bundle histerectomia/ooforectomia."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_BILL_BUNDLE_004"><text>"Verificar indicacao, lateralidade e contrato."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_4_BILL_BUNDLE_004"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_5_BILL_BUNDLE_004"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BILL_BUNDLE_004">
      <dmndi:DMNShape id="DMNShape_Decision_BILL_BUNDLE_004" dmnElementRef="Decision_BILL_BUNDLE_004">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>