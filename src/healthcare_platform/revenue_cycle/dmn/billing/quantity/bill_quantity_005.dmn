<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  BILL-QUANTITY-005 - Multiple Session Billing Validation
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: BILL-QUANTITY
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_BILL_QUANTITY_005" name="Multiple Session Billing Validation" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_BILL_QUANTITY_005" name="[SP-RC-006 | billing/quantity] Validar Cobranca Multiplas Sessoes" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL_QUANTITY_005" hitPolicy="FIRST">

      <input id="Input_1_BILL_QUANTITY_005" label="Tipo Procedimento">
        <inputExpression id="InputExpression_1_BILL_QUANTITY_005" typeRef="string">
          <text>tipoProcedimento</text>
        </inputExpression>
        <inputValues><text>"radioterapia", "fisioterapia", "dialise", "infusao", "curativo"</text></inputValues>
      </input>

      <input id="Input_2_BILL_QUANTITY_005" label="Sessoes Mesmo Dia">
        <inputExpression id="InputExpression_2_BILL_QUANTITY_005" typeRef="number">
          <text>sessoesMesmoDia</text>
        </inputExpression>
      </input>

      <input id="Input_3_BILL_QUANTITY_005" label="Intervalo Minimo Respeitado">
        <inputExpression id="InputExpression_3_BILL_QUANTITY_005" typeRef="boolean">
          <text>intervaloMinimoRespeitado</text>
        </inputExpression>
      </input>

      <input id="Input_4_BILL_QUANTITY_005" label="Regioes Anatomicas Diferentes">
        <inputExpression id="InputExpression_4_BILL_QUANTITY_005" typeRef="boolean">
          <text>regioesAnatomicasDiferentes</text>
        </inputExpression>
      </input>

      <input id="Input_5_BILL_QUANTITY_005" label="Prescricao Justifica Multiplas">
        <inputExpression id="InputExpression_5_BILL_QUANTITY_005" typeRef="boolean">
          <text>prescricaoJustificaMultiplas</text>
        </inputExpression>
      </input>

      <output id="Output_1_BILL_QUANTITY_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_BILL_QUANTITY_005" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_BILL_QUANTITY_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_BILL_QUANTITY_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_BILL_QUANTITY_005" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Block_1_BILL_QUANTITY_005">
        <description>Bloquear multiplas sessoes sem justificativa</description>
        <inputEntry id="InputEntry_B1_1_BILL_QUANTITY_005"><text>"fisioterapia"</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_BILL_QUANTITY_005"><text>&gt; 2</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_BILL_QUANTITY_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_BILL_QUANTITY_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_5_BILL_QUANTITY_005"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_BILL_QUANTITY_005"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_BILL_QUANTITY_005"><text>"Mais de 2 sessoes de fisioterapia no mesmo dia sem justificativa."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_BILL_QUANTITY_005"><text>"Limitar a 2 sessoes ou documentar regioes anatomicas diferentes."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_1_4_BILL_QUANTITY_005"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_1_5_BILL_QUANTITY_005"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Block_2_BILL_QUANTITY_005">
        <description>Bloquear dialise multipla sem intervalo</description>
        <inputEntry id="InputEntry_B2_1_BILL_QUANTITY_005"><text>"dialise"</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_BILL_QUANTITY_005"><text>&gt; 1</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_BILL_QUANTITY_005"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_BILL_QUANTITY_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_5_BILL_QUANTITY_005"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_B2_1_BILL_QUANTITY_005"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_2_BILL_QUANTITY_005"><text>"Multiplas sessoes de dialise no mesmo dia sem intervalo minimo."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_3_BILL_QUANTITY_005"><text>"Dialise requer intervalo. Documentar situacao especial se aplicavel."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_2_4_BILL_QUANTITY_005"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_2_5_BILL_QUANTITY_005"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alert_1_BILL_QUANTITY_005">
        <description>Alertar multiplas infusoes</description>
        <inputEntry id="InputEntry_A1_1_BILL_QUANTITY_005"><text>"infusao"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_BILL_QUANTITY_005"><text>&gt; 2</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_BILL_QUANTITY_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_BILL_QUANTITY_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_BILL_QUANTITY_005"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_BILL_QUANTITY_005"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_BILL_QUANTITY_005"><text>"Multiplas infusoes no mesmo dia. Verificar se SADTs diferentes."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_BILL_QUANTITY_005"><text>"Confirmar que cada infusao tem codigo TUSS distinto."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alert_1_4_BILL_QUANTITY_005"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alert_1_5_BILL_QUANTITY_005"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_1_BILL_QUANTITY_005">
        <description>Prosseguir radioterapia multiplas fracoes</description>
        <inputEntry id="InputEntry_P1_1_BILL_QUANTITY_005"><text>"radioterapia"</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_BILL_QUANTITY_005"><text>[1..2]</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_BILL_QUANTITY_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_BILL_QUANTITY_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_5_BILL_QUANTITY_005"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_P1_1_BILL_QUANTITY_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_2_BILL_QUANTITY_005"><text>"Radioterapia com multiplas fracoes em regioes diferentes. Permitido."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_3_BILL_QUANTITY_005"><text>"Faturar cada fracao com campos de tratamento especificados."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_1_4_BILL_QUANTITY_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_1_5_BILL_QUANTITY_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_2_BILL_QUANTITY_005">
        <description>Prosseguir fisioterapia regioes diferentes</description>
        <inputEntry id="InputEntry_P2_1_BILL_QUANTITY_005"><text>"fisioterapia"</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_BILL_QUANTITY_005"><text>2</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_BILL_QUANTITY_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_BILL_QUANTITY_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_5_BILL_QUANTITY_005"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_P2_1_BILL_QUANTITY_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_2_BILL_QUANTITY_005"><text>"2 sessoes fisioterapia em regioes anatomicas diferentes. Permitido."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_3_BILL_QUANTITY_005"><text>"Faturar especificando regiao de cada sessao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_2_4_BILL_QUANTITY_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_2_5_BILL_QUANTITY_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_3_BILL_QUANTITY_005">
        <description>Prosseguir multiplos curativos</description>
        <inputEntry id="InputEntry_P3_1_BILL_QUANTITY_005"><text>"curativo"</text></inputEntry>
        <inputEntry id="InputEntry_P3_2_BILL_QUANTITY_005"><text>&gt;= 1</text></inputEntry>
        <inputEntry id="InputEntry_P3_3_BILL_QUANTITY_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P3_4_BILL_QUANTITY_005"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P3_5_BILL_QUANTITY_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_P3_1_BILL_QUANTITY_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P3_2_BILL_QUANTITY_005"><text>"Multiplos curativos em lesoes diferentes. Cobranca por lesao permitida."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P3_3_BILL_QUANTITY_005"><text>"Faturar cada curativo com localizacao especifica."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_3_4_BILL_QUANTITY_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_3_5_BILL_QUANTITY_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_4_BILL_QUANTITY_005">
        <description>Prosseguir sessao unica</description>
        <inputEntry id="InputEntry_P4_1_BILL_QUANTITY_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P4_2_BILL_QUANTITY_005"><text>1</text></inputEntry>
        <inputEntry id="InputEntry_P4_3_BILL_QUANTITY_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P4_4_BILL_QUANTITY_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P4_5_BILL_QUANTITY_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_P4_1_BILL_QUANTITY_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P4_2_BILL_QUANTITY_005"><text>"Sessao unica no dia. Sem restricao."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P4_3_BILL_QUANTITY_005"><text>"Faturar normalmente."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_4_4_BILL_QUANTITY_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_4_5_BILL_QUANTITY_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_BILL_QUANTITY_005">
        <description>Caso padrao - revisar manualmente</description>
        <inputEntry id="InputEntry_F_1_BILL_QUANTITY_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_BILL_QUANTITY_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_BILL_QUANTITY_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_BILL_QUANTITY_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_BILL_QUANTITY_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_BILL_QUANTITY_005"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_BILL_QUANTITY_005"><text>"Dados insuficientes para validar multiplas sessoes."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_BILL_QUANTITY_005"><text>"Verificar tipo, quantidade, intervalo e justificativa."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_4_BILL_QUANTITY_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_5_BILL_QUANTITY_005"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BILL_QUANTITY_005">
      <dmndi:DMNShape id="DMNShape_Decision_BILL_QUANTITY_005" dmnElementRef="Decision_BILL_QUANTITY_005">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>