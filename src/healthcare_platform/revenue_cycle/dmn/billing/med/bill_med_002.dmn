<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  BILL-MED-002 - Antimicrobiano Hospitalar
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: BILL-MED
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_BILL-MED-002" name="Antimicrobiano Hospitalar" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_BILL-MED-002" name="[SP-RC-006 | billing/med] Antimicrobiano Hospitalar" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL-MED-002" hitPolicy="FIRST">

      <input id="Input_1_BILL-MED-002" label="Classe Antimicrobiano">
        <inputExpression id="InputExpression_1_BILL-MED-002" typeRef="string">
          <text>classeAntimicrobiano</text>
        </inputExpression>
        <inputValues id="InputValues_1_BILL-MED-002">
          <text>"RESTRITO", "CONTROLADO", "PADRAO"</text>
        </inputValues>
      </input>

      <input id="Input_2_BILL-MED-002" label="Percentual Duracao Protocolo">
        <inputExpression id="InputExpression_2_BILL-MED-002" typeRef="number">
          <text>percentualDuracaoProtocolo</text>
        </inputExpression>
      </input>

      <input id="Input_3_BILL-MED-002" label="Cultura Sensibilidade Status">
        <inputExpression id="InputExpression_3_BILL-MED-002" typeRef="string">
          <text>culturaSensibilidadeStatus</text>
        </inputExpression>
        <inputValues id="InputValues_3_BILL-MED-002">
          <text>"DOCUMENTADA", "PENDENTE", "NAO_APLICAVEL"</text>
        </inputValues>
      </input>

      <input id="Input_4_BILL-MED-002" label="Autorizacao CCIH">
        <inputExpression id="InputExpression_4_BILL-MED-002" typeRef="boolean">
          <text>possuiAutorizacaoCcih</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_BILL-MED-002" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_BILL-MED-002" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_BILL-MED-002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_BILL-MED-002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_BILL-MED-002" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_BILL-MED-002">
        <description>Bloqueio: Antimicrobiano restrito sem autorizacao CCIH</description>
        <inputEntry id="InputEntry_B1_1_BILL-MED-002"><text>"RESTRITO"</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_BILL-MED-002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_BILL-MED-002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_BILL-MED-002"><text>false</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_BILL-MED-002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_BILL-MED-002"><text>"BLOQUEADO - Antimicrobiano de uso restrito sem autorizacao CCIH. Conforme RDC ANVISA 2616/1998, antimicrobianos restritos requerem liberacao da Comissao de Controle de Infeccao."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_BILL-MED-002"><text>"SOLICITAR_CCIH"</text></outputEntry>
<outputEntry id="Rule_Bloquear_1_outputEntry_alertasConformidade_BILL-MED-002"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Bloquear_1_outputEntry_riscoDenial_BILL-MED-002"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Bloquear_2_BILL-MED-002">
        <description>Bloqueio: Duracao excede protocolo sem cultura</description>
        <inputEntry id="InputEntry_B2_1_BILL-MED-002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_BILL-MED-002"><text>&gt; 100</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_BILL-MED-002"><text>"NAO_APLICAVEL"</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_BILL-MED-002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_BILL-MED-002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_BILL-MED-002"><text>"BLOQUEADO - Duracao de tratamento antimicrobiano excede protocolo sem cultura de sensibilidade. Programa de Stewardship requer justificativa documentada para uso prolongado."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_BILL-MED-002"><text>"DOCUMENTAR_CULTURA"</text></outputEntry>
<outputEntry id="Rule_Bloquear_2_outputEntry_alertasConformidade_BILL-MED-002"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Bloquear_2_outputEntry_riscoDenial_BILL-MED-002"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Bloquear_3_BILL-MED-002">
        <description>Bloqueio: Uso prolongado sem justificativa</description>
        <inputEntry id="InputEntry_B3_1_BILL-MED-002"><text>"CONTROLADO"</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_BILL-MED-002"><text>&gt; 100</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_BILL-MED-002"><text>"PENDENTE"</text></inputEntry>
        <inputEntry id="InputEntry_B3_4_BILL-MED-002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B3_1_BILL-MED-002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B3_2_BILL-MED-002"><text>"BLOQUEADO - Antimicrobiano controlado com duracao superior ao protocolo e cultura pendente. Completar investigacao microbiologica ou justificar extensao do tratamento."</text></outputEntry>
<outputEntry id="OutputEntry_B3_3_BILL-MED-002"><text>"JUSTIFICAR_DURACAO"</text></outputEntry>
<outputEntry id="Rule_Bloquear_3_outputEntry_alertasConformidade_BILL-MED-002"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Bloquear_3_outputEntry_riscoDenial_BILL-MED-002"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_BILL-MED-002">
        <description>Alerta: Duracao proxima do limite (75%)</description>
        <inputEntry id="InputEntry_A1_1_BILL-MED-002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_BILL-MED-002"><text>[75..100]</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_BILL-MED-002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_BILL-MED-002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_BILL-MED-002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_BILL-MED-002"><text>"ALERTA - Duracao de tratamento antimicrobiano acima de 75% do limite protocolar. Avaliar necessidade de extensao e preparar justificativa se necessario."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_BILL-MED-002"><text>"JUSTIFICAR_DURACAO"</text></outputEntry>
<outputEntry id="Rule_Alertar_1_outputEntry_alertasConformidade_BILL-MED-002"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Alertar_1_outputEntry_riscoDenial_BILL-MED-002"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Alertar_2_BILL-MED-002">
        <description>Alerta: Cultura pendente em tratamento empirico</description>
        <inputEntry id="InputEntry_A2_1_BILL-MED-002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_BILL-MED-002"><text>&lt; 75</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_BILL-MED-002"><text>"PENDENTE"</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_BILL-MED-002"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_BILL-MED-002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_BILL-MED-002"><text>"ALERTA - Tratamento empirico com cultura de sensibilidade pendente. Acompanhar resultado para ajuste terapeutico e documentacao adequada."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_BILL-MED-002"><text>"DOCUMENTAR_CULTURA"</text></outputEntry>
<outputEntry id="Rule_Alertar_2_outputEntry_alertasConformidade_BILL-MED-002"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Alertar_2_outputEntry_riscoDenial_BILL-MED-002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_BILL-MED-002">
        <description>Aprovado: Antimicrobiano restrito com autorizacao</description>
        <inputEntry id="InputEntry_P1_1_BILL-MED-002"><text>"RESTRITO"</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_BILL-MED-002"><text>&lt; 75</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_BILL-MED-002"><text>"DOCUMENTADA"</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_BILL-MED-002"><text>true</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_BILL-MED-002"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_BILL-MED-002"><text>"APROVADO - Antimicrobiano restrito com autorizacao CCIH, cultura documentada e duracao dentro do protocolo. Prosseguir com faturamento."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_BILL-MED-002"><text>"FATURAR"</text></outputEntry>
<outputEntry id="Rule_Prosseguir_1_outputEntry_alertasConformidade_BILL-MED-002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Prosseguir_1_outputEntry_riscoDenial_BILL-MED-002"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Prosseguir_2_BILL-MED-002">
        <description>Aprovado: Antimicrobiano padrao dentro do protocolo</description>
        <inputEntry id="InputEntry_P2_1_BILL-MED-002"><text>"PADRAO"</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_BILL-MED-002"><text>&lt; 100</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_BILL-MED-002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_BILL-MED-002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_BILL-MED-002"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_BILL-MED-002"><text>"APROVADO - Antimicrobiano padrao com duracao dentro do protocolo. Dispensa autorizacao CCIH especial. Prosseguir com faturamento."</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_BILL-MED-002"><text>"FATURAR"</text></outputEntry>
<outputEntry id="Rule_Prosseguir_2_outputEntry_alertasConformidade_BILL-MED-002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Prosseguir_2_outputEntry_riscoDenial_BILL-MED-002"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_BILL-MED-002">
        <description>Regra padrao - Dados insuficientes para decisao automatica</description>
        <inputEntry id="InputEntry_F_1_BILL-MED-002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_BILL-MED-002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_BILL-MED-002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_BILL-MED-002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_BILL-MED-002"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_BILL-MED-002"><text>"REVISAR - Dados insuficientes para validacao de antimicrobiano hospitalar. Verificar: classe, duracao, cultura de sensibilidade e autorizacao CCIH."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_BILL-MED-002"><text>"SOLICITAR_CCIH"</text></outputEntry>
<outputEntry id="Rule_Fallback_BILL-MED-002_outputEntry_alertasConformidade"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Fallback_BILL-MED-002_outputEntry_riscoDenial"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BILL-MED-002">
      <dmndi:DMNShape id="DMNShape_Decision_BILL-MED-002" dmnElementRef="Decision_BILL-MED-002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>