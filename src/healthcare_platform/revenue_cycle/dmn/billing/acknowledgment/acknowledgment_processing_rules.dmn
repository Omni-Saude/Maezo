<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_ACKNOWLEDGMENT_PROCESSING"
             name="Acknowledgment Processing Rules"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Acknowledgment Processing Rules
       Archetype: ADMIN_ADJUDICATION
       Outputs: resultado, acao, risco
       Hit Policy: FIRST
       Worker: handle_acknowledgment_worker.py
  -->

  <decision id="Decision_ACKNOWLEDGMENT_PROCESSING" name="[SP-RC-006 | billing/acknowledgment] Acknowledgment Processing Rules" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_ACKNOWLEDGMENT_PROCESSING" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_PROTOCOL_NUMBER_ACKNOWLEDGMENT_PROCESSING" label="Protocol Number">
        <inputExpression id="InputExpr_PROTOCOL_NUMBER_ACKNOWLEDGMENT_PROCESSING" typeRef="string">
          <text>protocolNumber</text>
        </inputExpression>
      </input>

      <input id="Input_CLAIM_ID_ACKNOWLEDGMENT_PROCESSING" label="Claim ID">
        <inputExpression id="InputExpr_CLAIM_ID_ACKNOWLEDGMENT_PROCESSING" typeRef="string">
          <text>claimId</text>
        </inputExpression>
      </input>

      <input id="Input_ACK_TYPE_ACKNOWLEDGMENT_PROCESSING" label="Acknowledgment Type">
        <inputExpression id="InputExpr_ACK_TYPE_ACKNOWLEDGMENT_PROCESSING" typeRef="string">
          <text>acknowledgmentType</text>
        </inputExpression>
      </input>

      <input id="Input_RESPONSE_CODE_ACKNOWLEDGMENT_PROCESSING" label="Response Code">
        <inputExpression id="InputExpr_RESPONSE_CODE_ACKNOWLEDGMENT_PROCESSING" typeRef="string">
          <text>responseCode</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado_ACKNOWLEDGMENT_PROCESSING" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_ACKNOWLEDGMENT_PROCESSING" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_ACKNOWLEDGMENT_PROCESSING" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Missing protocol number -->
      <rule id="Rule_PROTOCOL_MISSING_ACKNOWLEDGMENT_PROCESSING">
        <description>Rejeitar protocolo ausente</description>
        <inputEntry id="IE_PROTOCOL_MISSING_1_ACKNOWLEDGMENT_PROCESSING"><text>null,"","-"</text></inputEntry>
        <inputEntry id="IE_PROTOCOL_MISSING_2_ACKNOWLEDGMENT_PROCESSING"><text>-</text></inputEntry>
        <inputEntry id="IE_PROTOCOL_MISSING_3_ACKNOWLEDGMENT_PROCESSING"><text>-</text></inputEntry>
        <inputEntry id="IE_PROTOCOL_MISSING_4_ACKNOWLEDGMENT_PROCESSING"><text>-</text></inputEntry>
        <outputEntry id="OE_PROTOCOL_MISSING_res_ACKNOWLEDGMENT_PROCESSING"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_PROTOCOL_MISSING_acao_ACKNOWLEDGMENT_PROCESSING"><text>"Rejeitar protocolo ausente"</text></outputEntry>
        <outputEntry id="OE_PROTOCOL_MISSING_risco_ACKNOWLEDGMENT_PROCESSING"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Missing claim ID -->
      <rule id="Rule_CLAIM_MISSING_ACKNOWLEDGMENT_PROCESSING">
        <description>Rejeitar conta ausente</description>
        <inputEntry id="IE_CLAIM_MISSING_1_ACKNOWLEDGMENT_PROCESSING"><text>-</text></inputEntry>
        <inputEntry id="IE_CLAIM_MISSING_2_ACKNOWLEDGMENT_PROCESSING"><text>null,"","-"</text></inputEntry>
        <inputEntry id="IE_CLAIM_MISSING_3_ACKNOWLEDGMENT_PROCESSING"><text>-</text></inputEntry>
        <inputEntry id="IE_CLAIM_MISSING_4_ACKNOWLEDGMENT_PROCESSING"><text>-</text></inputEntry>
        <outputEntry id="OE_CLAIM_MISSING_res_ACKNOWLEDGMENT_PROCESSING"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_CLAIM_MISSING_acao_ACKNOWLEDGMENT_PROCESSING"><text>"Rejeitar conta ausente"</text></outputEntry>
        <outputEntry id="OE_CLAIM_MISSING_risco_ACKNOWLEDGMENT_PROCESSING"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Invalid acknowledgment type -->
      <rule id="Rule_ACK_TYPE_INVALID_ACKNOWLEDGMENT_PROCESSING">
        <description>Rejeitar tipo de confirmacao invalido</description>
        <inputEntry id="IE_ACK_TYPE_INVALID_1_ACKNOWLEDGMENT_PROCESSING"><text>-</text></inputEntry>
        <inputEntry id="IE_ACK_TYPE_INVALID_2_ACKNOWLEDGMENT_PROCESSING"><text>-</text></inputEntry>
        <inputEntry id="IE_ACK_TYPE_INVALID_3_ACKNOWLEDGMENT_PROCESSING"><text>not("ACK","NACK")</text></inputEntry>
        <inputEntry id="IE_ACK_TYPE_INVALID_4_ACKNOWLEDGMENT_PROCESSING"><text>-</text></inputEntry>
        <outputEntry id="OE_ACK_TYPE_INVALID_res_ACKNOWLEDGMENT_PROCESSING"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_ACK_TYPE_INVALID_acao_ACKNOWLEDGMENT_PROCESSING"><text>"Rejeitar tipo de confirmacao invalido"</text></outputEntry>
        <outputEntry id="OE_ACK_TYPE_INVALID_risco_ACKNOWLEDGMENT_PROCESSING"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 4: ACK - set status to ACKNOWLEDGED -->
      <rule id="Rule_ACK_SUCCESS_ACKNOWLEDGMENT_PROCESSING">
        <description>Definir status ACKNOWLEDGED</description>
        <inputEntry id="IE_ACK_SUCCESS_1_ACKNOWLEDGMENT_PROCESSING"><text>-</text></inputEntry>
        <inputEntry id="IE_ACK_SUCCESS_2_ACKNOWLEDGMENT_PROCESSING"><text>-</text></inputEntry>
        <inputEntry id="IE_ACK_SUCCESS_3_ACKNOWLEDGMENT_PROCESSING"><text>"ACK"</text></inputEntry>
        <inputEntry id="IE_ACK_SUCCESS_4_ACKNOWLEDGMENT_PROCESSING"><text>-</text></inputEntry>
        <outputEntry id="OE_ACK_SUCCESS_res_ACKNOWLEDGMENT_PROCESSING"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_ACK_SUCCESS_acao_ACKNOWLEDGMENT_PROCESSING"><text>"Definir status ACKNOWLEDGED"</text></outputEntry>
        <outputEntry id="OE_ACK_SUCCESS_risco_ACKNOWLEDGMENT_PROCESSING"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 5: NACK with retryable error - set to SUBMITTED for resubmission -->
      <rule id="Rule_NACK_RETRYABLE_ACKNOWLEDGMENT_PROCESSING">
        <description>Definir status SUBMITTED para reenvio</description>
        <inputEntry id="IE_NACK_RETRYABLE_1_ACKNOWLEDGMENT_PROCESSING"><text>-</text></inputEntry>
        <inputEntry id="IE_NACK_RETRYABLE_2_ACKNOWLEDGMENT_PROCESSING"><text>-</text></inputEntry>
        <inputEntry id="IE_NACK_RETRYABLE_3_ACKNOWLEDGMENT_PROCESSING"><text>"NACK"</text></inputEntry>
        <inputEntry id="IE_NACK_RETRYABLE_4_ACKNOWLEDGMENT_PROCESSING"><text>"TIMEOUT","SERVICE_UNAVAILABLE","RATE_LIMIT"</text></inputEntry>
        <outputEntry id="OE_NACK_RETRYABLE_res_ACKNOWLEDGMENT_PROCESSING"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_NACK_RETRYABLE_acao_ACKNOWLEDGMENT_PROCESSING"><text>"Definir status SUBMITTED para reenvio"</text></outputEntry>
        <outputEntry id="OE_NACK_RETRYABLE_risco_ACKNOWLEDGMENT_PROCESSING"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 6: NACK - permanent rejection -->
      <rule id="Rule_NACK_PERMANENT_ACKNOWLEDGMENT_PROCESSING">
        <description>Definir status DENIED - rejeicao definitiva</description>
        <inputEntry id="IE_NACK_PERMANENT_1_ACKNOWLEDGMENT_PROCESSING"><text>-</text></inputEntry>
        <inputEntry id="IE_NACK_PERMANENT_2_ACKNOWLEDGMENT_PROCESSING"><text>-</text></inputEntry>
        <inputEntry id="IE_NACK_PERMANENT_3_ACKNOWLEDGMENT_PROCESSING"><text>"NACK"</text></inputEntry>
        <inputEntry id="IE_NACK_PERMANENT_4_ACKNOWLEDGMENT_PROCESSING"><text>-</text></inputEntry>
        <outputEntry id="OE_NACK_PERMANENT_res_ACKNOWLEDGMENT_PROCESSING"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_NACK_PERMANENT_acao_ACKNOWLEDGMENT_PROCESSING"><text>"Definir status DENIED - rejeicao definitiva"</text></outputEntry>
        <outputEntry id="OE_NACK_PERMANENT_risco_ACKNOWLEDGMENT_PROCESSING"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 7: Fallback - requires manual review -->
      <rule id="Rule_FALLBACK_ACKNOWLEDGMENT_PROCESSING">
        <description>Caso requer avaliacao manual</description>
        <inputEntry id="IE_FALLBACK_1_ACKNOWLEDGMENT_PROCESSING"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_2_ACKNOWLEDGMENT_PROCESSING"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_3_ACKNOWLEDGMENT_PROCESSING"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_4_ACKNOWLEDGMENT_PROCESSING"><text>-</text></inputEntry>
        <outputEntry id="OE_FALLBACK_res_ACKNOWLEDGMENT_PROCESSING"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_FALLBACK_acao_ACKNOWLEDGMENT_PROCESSING"><text>"Caso requer avaliacao manual"</text></outputEntry>
        <outputEntry id="OE_FALLBACK_risco_ACKNOWLEDGMENT_PROCESSING"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ACKNOWLEDGMENT_PROCESSING">
      <dmndi:DMNShape id="DMNShape_Decision_ACKNOWLEDGMENT_PROCESSING" dmnElementRef="Decision_ACKNOWLEDGMENT_PROCESSING">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>