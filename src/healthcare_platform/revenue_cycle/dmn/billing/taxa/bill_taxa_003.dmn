<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  BILL-TAXA-003 - Gasoterapia Oxigenio
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: BILL-TAXA
  Perspectiva: HOSPITAL (Faturamento/Hotelaria)

  ============================================================================
  INDICACOES (Quando PROSSEGUIR):
  ============================================================================
  - Prescricao medica de oxigenoterapia documentada
  - Registro de consumo de oxigenio (litros/minuto x tempo)
  - Taxa compativel com consumo real medido

  ============================================================================
  CONTRAINDICACOES (Quando BLOQUEAR):
  ============================================================================
  - Cobranca de oxigenio sem prescricao medica
  - Ausencia de registro de consumo (medidor de fluxo)
  - Taxa estimada sem medicao real de consumo

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - ANS RN 465/2021 (cobertura de gasoterapia)
  - ANVISA RDC 50/2002 (sistemas de gases medicinais)
  - TISS 4.01.00 (codificacao de taxas)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_BILL_TAXA_003"
             name="Gasoterapia Oxigenio"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_BILL_TAXA_003" name="[SP-RC-006 | billing/taxa] Gasoterapia Oxigenio" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL_TAXA_003" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_BILL_TAXA_003" label="Prescricao Medica">
        <inputExpression id="InputExpression_1_BILL_TAXA_003" typeRef="boolean">
          <text>prescricaoMedica</text>
        </inputExpression>
      </input>

      <input id="Input_2_BILL_TAXA_003" label="Consumo Registrado">
        <inputExpression id="InputExpression_2_BILL_TAXA_003" typeRef="boolean">
          <text>consumoRegistrado</text>
        </inputExpression>
      </input>

      <input id="Input_3_BILL_TAXA_003" label="Dias Oxigenoterapia">
        <inputExpression id="InputExpression_3_BILL_TAXA_003" typeRef="number">
          <text>diasOxigenoterapia</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_BILL_TAXA_003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_BILL_TAXA_003" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_BILL_TAXA_003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_BILL_TAXA_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_BILL_TAXA_003" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA B1: Bloqueio - Ausencia de prescricao medica -->
      <rule id="Rule_Bloqueio_1_BILL_TAXA_003">
        <description>Cobranca de oxigenoterapia sem prescricao medica</description>
        <inputEntry id="InputEntry_B1_1_BILL_TAXA_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_BILL_TAXA_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_BILL_TAXA_003"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B1_1_BILL_TAXA_003"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_2_BILL_TAXA_003"><text>"Cobranca de oxigenoterapia sem prescricao medica. Glosa certa pela operadora."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_3_BILL_TAXA_003"><text>"Bloquear faturamento. Solicitar prescricao medica retroativa ou anular cobranca."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_4_BILL_TAXA_003"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_5_BILL_TAXA_003"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA B2: Bloqueio - Consumo nao registrado -->
      <rule id="Rule_Bloqueio_2_BILL_TAXA_003">
        <description>Cobranca de oxigenio sem registro de consumo real</description>
        <inputEntry id="InputEntry_B2_1_BILL_TAXA_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_BILL_TAXA_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_BILL_TAXA_003"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B2_1_BILL_TAXA_003"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_2_BILL_TAXA_003"><text>"Ausencia de registro de consumo de oxigenio. Impossivel comprovar utilizacao."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_3_BILL_TAXA_003"><text>"Bloquear faturamento. Solicitar planilha de controle de fluxo de oxigenio (L/min x tempo)."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_4_BILL_TAXA_003"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_5_BILL_TAXA_003"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA A1: Alerta - Oxigenoterapia prolongada -->
      <rule id="Rule_Alerta_1_BILL_TAXA_003">
        <description>Oxigenoterapia por periodo prolongado (&gt;7 dias) - Revisar necessidade</description>
        <inputEntry id="InputEntry_A1_1_BILL_TAXA_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_BILL_TAXA_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_BILL_TAXA_003"><text>&gt; 7</text></inputEntry>
        <outputEntry id="OutputEntry_A1_1_BILL_TAXA_003"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_2_BILL_TAXA_003"><text>"Oxigenoterapia prolongada (&gt;7 dias). Operadora pode questionar necessidade clinica."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_3_BILL_TAXA_003"><text>"Anexar evolucoes clinicas diarias justificando necessidade de oxigenoterapia prolongada."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_4_BILL_TAXA_003"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_5_BILL_TAXA_003"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA P1: Aprovado - Oxigenoterapia prescrita e documentada -->
      <rule id="Rule_Aprovado_1_BILL_TAXA_003">
        <description>Oxigenoterapia com prescricao medica e registro de consumo</description>
        <inputEntry id="InputEntry_P1_1_BILL_TAXA_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_BILL_TAXA_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_BILL_TAXA_003"><text>[1..7]</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_BILL_TAXA_003"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_2_BILL_TAXA_003"><text>"Oxigenoterapia devidamente prescrita e registrada. Prosseguir com faturamento."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_3_BILL_TAXA_003"><text>"Prosseguir com faturamento de gasoterapia. Anexar prescricao e planilha de consumo."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_4_BILL_TAXA_003"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_5_BILL_TAXA_003"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisao manual -->
      <rule id="Rule_Fallback_BILL_TAXA_003">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_BILL_TAXA_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_BILL_TAXA_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_BILL_TAXA_003"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_BILL_TAXA_003"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_BILL_TAXA_003"><text>"Situacao requer analise manual por nao corresponder a nenhum criterio automatico."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_BILL_TAXA_003"><text>"Encaminhar para auditoria administrativa para avaliacao caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_BILL_TAXA_003"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_BILL_TAXA_003"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BILL_TAXA_003">
      <dmndi:DMNShape id="DMNShape_Decision_BILL_TAXA_003" dmnElementRef="Decision_BILL_TAXA_003">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
