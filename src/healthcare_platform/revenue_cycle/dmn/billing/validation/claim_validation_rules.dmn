<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_ClaimValidation"
             name="Claim Validation Rules"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: claim_validation_rules_worker.py -->

  <decision id="Decision_ClaimValidation" name="[SP-RC-006 | billing/validation] Claim Validation Rules" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_ClaimValidation" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_claimId_ClaimValidation" label="Claim ID">
        <inputExpression id="InputExpr_claimId_ClaimValidation" typeRef="string">
          <text>claimId</text>
        </inputExpression>
      </input>

      <input id="Input_claimDataValid_ClaimValidation" label="Claim Data Valid">
        <inputExpression id="InputExpr_claimDataValid_ClaimValidation" typeRef="boolean">
          <text>claimDataValid</text>
        </inputExpression>
      </input>

      <input id="Input_requiredFieldsPresent_ClaimValidation" label="Required Fields Present">
        <inputExpression id="InputExpr_requiredFieldsPresent_ClaimValidation" typeRef="boolean">
          <text>requiredFieldsPresent</text>
        </inputExpression>
      </input>

      <input id="Input_itemsCount_ClaimValidation" label="Items Count">
        <inputExpression id="InputExpr_itemsCount_ClaimValidation" typeRef="number">
          <text>itemsCount</text>
        </inputExpression>
      </input>

      <input id="Input_itemsValid_ClaimValidation" label="Items Valid">
        <inputExpression id="InputExpr_itemsValid_ClaimValidation" typeRef="boolean">
          <text>itemsValid</text>
        </inputExpression>
      </input>

      <input id="Input_totalConsistent_ClaimValidation" label="Total Consistent">
        <inputExpression id="InputExpr_totalConsistent_ClaimValidation" typeRef="boolean">
          <text>totalConsistent</text>
        </inputExpression>
      </input>

      <input id="Input_hasDuplicates_ClaimValidation" label="Has Duplicates">
        <inputExpression id="InputExpr_hasDuplicates_ClaimValidation" typeRef="boolean">
          <text>hasDuplicates</text>
        </inputExpression>
      </input>

      <input id="Input_authorizationRequired_ClaimValidation" label="Authorization Required">
        <inputExpression id="InputExpr_authorizationRequired_ClaimValidation" typeRef="boolean">
          <text>authorizationRequired</text>
        </inputExpression>
      </input>

      <input id="Input_authorizationPresent_ClaimValidation" label="Authorization Present">
        <inputExpression id="InputExpr_authorizationPresent_ClaimValidation" typeRef="boolean">
          <text>authorizationPresent</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado_ClaimValidation" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_ClaimValidation" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_ClaimValidation" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Missing claim ID -->
      <rule id="Rule_NoClaimId_ClaimValidation">
        <description>Rejeitar ID da conta ausente</description>
        <inputEntry id="IE_NoClaimId_1_ClaimValidation"><text>claimId = null or claimId = ""</text></inputEntry>
        <inputEntry id="IE_NoClaimId_2_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_NoClaimId_3_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_NoClaimId_4_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_NoClaimId_5_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_NoClaimId_6_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_NoClaimId_7_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_NoClaimId_8_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_NoClaimId_9_ClaimValidation"><text>-</text></inputEntry>
        <outputEntry id="OE_NoClaimId_res_ClaimValidation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_NoClaimId_acao_ClaimValidation"><text>"Rejeitar ID da conta ausente"</text></outputEntry>
        <outputEntry id="OE_NoClaimId_risco_ClaimValidation"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Invalid claim data format -->
      <rule id="Rule_InvalidData_ClaimValidation">
        <description>Rejeitar formato de dados invalido</description>
        <inputEntry id="IE_InvalidData_1_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidData_2_ClaimValidation"><text>claimDataValid = false</text></inputEntry>
        <inputEntry id="IE_InvalidData_3_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidData_4_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidData_5_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidData_6_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidData_7_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidData_8_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidData_9_ClaimValidation"><text>-</text></inputEntry>
        <outputEntry id="OE_InvalidData_res_ClaimValidation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_InvalidData_acao_ClaimValidation"><text>"Rejeitar formato de dados invalido"</text></outputEntry>
        <outputEntry id="OE_InvalidData_risco_ClaimValidation"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Missing required fields -->
      <rule id="Rule_MissingFields_ClaimValidation">
        <description>Campos obrigatorios ausentes</description>
        <inputEntry id="IE_MissingFields_1_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingFields_2_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingFields_3_ClaimValidation"><text>requiredFieldsPresent = false</text></inputEntry>
        <inputEntry id="IE_MissingFields_4_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingFields_5_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingFields_6_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingFields_7_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingFields_8_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingFields_9_ClaimValidation"><text>-</text></inputEntry>
        <outputEntry id="OE_MissingFields_res_ClaimValidation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_MissingFields_acao_ClaimValidation"><text>"Campos obrigatorios ausentes"</text></outputEntry>
        <outputEntry id="OE_MissingFields_risco_ClaimValidation"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Empty items list -->
      <rule id="Rule_EmptyItems_ClaimValidation">
        <description>Rejeitar lista de itens vazia</description>
        <inputEntry id="IE_EmptyItems_1_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_EmptyItems_2_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_EmptyItems_3_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_EmptyItems_4_ClaimValidation"><text>itemsCount &lt;= 0</text></inputEntry>
        <inputEntry id="IE_EmptyItems_5_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_EmptyItems_6_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_EmptyItems_7_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_EmptyItems_8_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_EmptyItems_9_ClaimValidation"><text>-</text></inputEntry>
        <outputEntry id="OE_EmptyItems_res_ClaimValidation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_EmptyItems_acao_ClaimValidation"><text>"Rejeitar lista de itens vazia"</text></outputEntry>
        <outputEntry id="OE_EmptyItems_risco_ClaimValidation"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Invalid items -->
      <rule id="Rule_InvalidItems_ClaimValidation">
        <description>Itens com dados invalidos (quantidade, preco, codigo)</description>
        <inputEntry id="IE_InvalidItems_1_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidItems_2_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidItems_3_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidItems_4_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidItems_5_ClaimValidation"><text>itemsValid = false</text></inputEntry>
        <inputEntry id="IE_InvalidItems_6_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidItems_7_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidItems_8_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidItems_9_ClaimValidation"><text>-</text></inputEntry>
        <outputEntry id="OE_InvalidItems_res_ClaimValidation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_InvalidItems_acao_ClaimValidation"><text>"Itens com dados invalidos (quantidade, preco, codigo)"</text></outputEntry>
        <outputEntry id="OE_InvalidItems_risco_ClaimValidation"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 6: Missing required authorization -->
      <rule id="Rule_MissingAuth_ClaimValidation">
        <description>Autorizacao obrigatoria ausente para guia de internacao/prorrogacao</description>
        <inputEntry id="IE_MissingAuth_1_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingAuth_2_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingAuth_3_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingAuth_4_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingAuth_5_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingAuth_6_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingAuth_7_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_MissingAuth_8_ClaimValidation"><text>authorizationRequired = true</text></inputEntry>
        <inputEntry id="IE_MissingAuth_9_ClaimValidation"><text>authorizationPresent = false</text></inputEntry>
        <outputEntry id="OE_MissingAuth_res_ClaimValidation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_MissingAuth_acao_ClaimValidation"><text>"Autorizacao obrigatoria ausente para guia de internacao/prorrogacao"</text></outputEntry>
        <outputEntry id="OE_MissingAuth_risco_ClaimValidation"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 7: Inconsistent total -->
      <rule id="Rule_InconsistentTotal_ClaimValidation">
        <description>Total da conta inconsistente com soma dos itens</description>
        <inputEntry id="IE_InconsistentTotal_1_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InconsistentTotal_2_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InconsistentTotal_3_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InconsistentTotal_4_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InconsistentTotal_5_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InconsistentTotal_6_ClaimValidation"><text>totalConsistent = false</text></inputEntry>
        <inputEntry id="IE_InconsistentTotal_7_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InconsistentTotal_8_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InconsistentTotal_9_ClaimValidation"><text>-</text></inputEntry>
        <outputEntry id="OE_InconsistentTotal_res_ClaimValidation"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_InconsistentTotal_acao_ClaimValidation"><text>"Total da conta inconsistente com soma dos itens"</text></outputEntry>
        <outputEntry id="OE_InconsistentTotal_risco_ClaimValidation"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 8: Duplicate items detected -->
      <rule id="Rule_Duplicates_ClaimValidation">
        <description>Itens duplicados detectados - requer revisao</description>
        <inputEntry id="IE_Duplicates_1_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_Duplicates_2_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_Duplicates_3_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_Duplicates_4_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_Duplicates_5_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_Duplicates_6_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_Duplicates_7_ClaimValidation"><text>hasDuplicates = true</text></inputEntry>
        <inputEntry id="IE_Duplicates_8_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_Duplicates_9_ClaimValidation"><text>-</text></inputEntry>
        <outputEntry id="OE_Duplicates_res_ClaimValidation"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_Duplicates_acao_ClaimValidation"><text>"Itens duplicados detectados - requer revisao"</text></outputEntry>
        <outputEntry id="OE_Duplicates_risco_ClaimValidation"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Fallback: Validation passed -->
      <rule id="Rule_Fallback_ClaimValidation">
        <description>Conta validada - pronta para submissao</description>
        <inputEntry id="IE_Fallback_1_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_2_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_3_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_4_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_5_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_6_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_7_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_8_ClaimValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_9_ClaimValidation"><text>-</text></inputEntry>
        <outputEntry id="OE_Fallback_res_ClaimValidation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Fallback_acao_ClaimValidation"><text>"Conta validada - pronta para submissao"</text></outputEntry>
        <outputEntry id="OE_Fallback_risco_ClaimValidation"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ClaimValidation">
      <dmndi:DMNShape id="DMNShape_ClaimValidation" dmnElementRef="Decision_ClaimValidation">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
