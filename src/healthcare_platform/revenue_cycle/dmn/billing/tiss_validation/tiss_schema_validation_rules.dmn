<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_TissSchemaValidation"
             name="TISS Schema Validation Rules"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: tiss_schema_validation_rules_worker.py -->

  <decision id="Decision_TissSchemaValidation" name="[SP-RC-006 | billing/tiss_validation] TISS Schema Validation Rules" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_TissSchemaValidation" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_tissXmlPresent_TissSchemaValidation" label="TISS XML Present">
        <inputExpression id="InputExpr_tissXmlPresent_TissSchemaValidation" typeRef="boolean">
          <text>tissXmlPresent</text>
        </inputExpression>
      </input>

      <input id="Input_guideType_TissSchemaValidation" label="Guide Type">
        <inputExpression id="InputExpr_guideType_TissSchemaValidation" typeRef="string">
          <text>guideType</text>
        </inputExpression>
      </input>

      <input id="Input_validationErrorsCount_TissSchemaValidation" label="Validation Errors Count">
        <inputExpression id="InputExpr_validationErrorsCount_TissSchemaValidation" typeRef="number">
          <text>validationErrorsCount</text>
        </inputExpression>
      </input>

      <input id="Input_hasCriticalErrors_TissSchemaValidation" label="Has Critical Errors">
        <inputExpression id="InputExpr_hasCriticalErrors_TissSchemaValidation" typeRef="boolean">
          <text>hasCriticalErrors</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado_TissSchemaValidation" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_TissSchemaValidation" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_TissSchemaValidation" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Missing TISS XML -->
      <rule id="Rule_NoTissXml_TissSchemaValidation">
        <description>Rejeitar XML TISS ausente</description>
        <inputEntry id="IE_NoTissXml_1_TissSchemaValidation"><text>tissXmlPresent = false</text></inputEntry>
        <inputEntry id="IE_NoTissXml_2_TissSchemaValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_NoTissXml_3_TissSchemaValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_NoTissXml_4_TissSchemaValidation"><text>-</text></inputEntry>
        <outputEntry id="OE_NoTissXml_res_TissSchemaValidation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_NoTissXml_acao_TissSchemaValidation"><text>"Rejeitar XML TISS ausente"</text></outputEntry>
        <outputEntry id="OE_NoTissXml_risco_TissSchemaValidation"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Missing guide type -->
      <rule id="Rule_NoGuideType_TissSchemaValidation">
        <description>Rejeitar tipo de guia ausente</description>
        <inputEntry id="IE_NoGuideType_1_TissSchemaValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_NoGuideType_2_TissSchemaValidation"><text>guideType = null or guideType = ""</text></inputEntry>
        <inputEntry id="IE_NoGuideType_3_TissSchemaValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_NoGuideType_4_TissSchemaValidation"><text>-</text></inputEntry>
        <outputEntry id="OE_NoGuideType_res_TissSchemaValidation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_NoGuideType_acao_TissSchemaValidation"><text>"Rejeitar tipo de guia ausente"</text></outputEntry>
        <outputEntry id="OE_NoGuideType_risco_TissSchemaValidation"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Invalid guide type -->
      <rule id="Rule_InvalidGuideType_TissSchemaValidation">
        <description>Rejeitar tipo de guia invalido</description>
        <inputEntry id="IE_InvalidGuideType_1_TissSchemaValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidGuideType_2_TissSchemaValidation"><text>not(guideType in ("sp_sadt","consultation","admission","extension","honorarios","summary"))</text></inputEntry>
        <inputEntry id="IE_InvalidGuideType_3_TissSchemaValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_InvalidGuideType_4_TissSchemaValidation"><text>-</text></inputEntry>
        <outputEntry id="OE_InvalidGuideType_res_TissSchemaValidation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_InvalidGuideType_acao_TissSchemaValidation"><text>"Rejeitar tipo de guia invalido"</text></outputEntry>
        <outputEntry id="OE_InvalidGuideType_risco_TissSchemaValidation"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Critical schema errors -->
      <rule id="Rule_CriticalErrors_TissSchemaValidation">
        <description>Erros criticos de schema encontrados</description>
        <inputEntry id="IE_CriticalErrors_1_TissSchemaValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_CriticalErrors_2_TissSchemaValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_CriticalErrors_3_TissSchemaValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_CriticalErrors_4_TissSchemaValidation"><text>hasCriticalErrors = true</text></inputEntry>
        <outputEntry id="OE_CriticalErrors_res_TissSchemaValidation"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_CriticalErrors_acao_TissSchemaValidation"><text>"Erros criticos de schema encontrados"</text></outputEntry>
        <outputEntry id="OE_CriticalErrors_risco_TissSchemaValidation"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Validation warnings -->
      <rule id="Rule_ValidationWarnings_TissSchemaValidation">
        <description>Avisos de validacao encontrados - verificar</description>
        <inputEntry id="IE_ValidationWarnings_1_TissSchemaValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_ValidationWarnings_2_TissSchemaValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_ValidationWarnings_3_TissSchemaValidation"><text>validationErrorsCount &gt; 0</text></inputEntry>
        <inputEntry id="IE_ValidationWarnings_4_TissSchemaValidation"><text>-</text></inputEntry>
        <outputEntry id="OE_ValidationWarnings_res_TissSchemaValidation"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_ValidationWarnings_acao_TissSchemaValidation"><text>"Avisos de validacao encontrados - verificar"</text></outputEntry>
        <outputEntry id="OE_ValidationWarnings_risco_TissSchemaValidation"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Fallback: Validation passed -->
      <rule id="Rule_Fallback_TissSchemaValidation">
        <description>Schema TISS validado com sucesso</description>
        <inputEntry id="IE_Fallback_1_TissSchemaValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_2_TissSchemaValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_3_TissSchemaValidation"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_4_TissSchemaValidation"><text>-</text></inputEntry>
        <outputEntry id="OE_Fallback_res_TissSchemaValidation"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Fallback_acao_TissSchemaValidation"><text>"Schema TISS validado com sucesso"</text></outputEntry>
        <outputEntry id="OE_Fallback_risco_TissSchemaValidation"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_TissSchemaValidation">
      <dmndi:DMNShape id="DMNShape_TissSchemaValidation" dmnElementRef="Decision_TissSchemaValidation">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
