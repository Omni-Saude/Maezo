<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_ProtocolTracking"
             name="Protocol Tracking Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: protocol_tracking_validation_worker.py -->

  <decision id="Decision_ProtocolTracking" name="[SP-RC-006 | billing/tracking] Protocol Tracking Validation" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_ProtocolTracking" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_claimId_ProtocolTracking" label="Claim ID">
        <inputExpression id="InputExpr_claimId_ProtocolTracking" typeRef="string">
          <text>claimId</text>
        </inputExpression>
      </input>

      <input id="Input_protocolNumber_ProtocolTracking" label="Protocol Number">
        <inputExpression id="InputExpr_protocolNumber_ProtocolTracking" typeRef="string">
          <text>protocolNumber</text>
        </inputExpression>
      </input>

      <input id="Input_payerId_ProtocolTracking" label="Payer ID">
        <inputExpression id="InputExpr_payerId_ProtocolTracking" typeRef="string">
          <text>payerId</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado_ProtocolTracking" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_ProtocolTracking" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_ProtocolTracking" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Missing claim ID -->
      <rule id="Rule_NoClaimId_ProtocolTracking">
        <description>Rejeitar conta ausente</description>
        <inputEntry id="IE_NoClaimId_1_ProtocolTracking"><text>claimId = null or claimId = ""</text></inputEntry>
        <inputEntry id="IE_NoClaimId_2_ProtocolTracking"><text>-</text></inputEntry>
        <inputEntry id="IE_NoClaimId_3_ProtocolTracking"><text>-</text></inputEntry>
        <outputEntry id="OE_NoClaimId_res_ProtocolTracking"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_NoClaimId_acao_ProtocolTracking"><text>"Rejeitar conta ausente"</text></outputEntry>
        <outputEntry id="OE_NoClaimId_risco_ProtocolTracking"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Missing protocol number -->
      <rule id="Rule_NoProtocol_ProtocolTracking">
        <description>Rejeitar protocolo ausente</description>
        <inputEntry id="IE_NoProtocol_1_ProtocolTracking"><text>-</text></inputEntry>
        <inputEntry id="IE_NoProtocol_2_ProtocolTracking"><text>protocolNumber = null or protocolNumber = ""</text></inputEntry>
        <inputEntry id="IE_NoProtocol_3_ProtocolTracking"><text>-</text></inputEntry>
        <outputEntry id="OE_NoProtocol_res_ProtocolTracking"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_NoProtocol_acao_ProtocolTracking"><text>"Rejeitar protocolo ausente"</text></outputEntry>
        <outputEntry id="OE_NoProtocol_risco_ProtocolTracking"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Missing payer ID -->
      <rule id="Rule_NoPayerId_ProtocolTracking">
        <description>Rejeitar operadora ausente</description>
        <inputEntry id="IE_NoPayerId_1_ProtocolTracking"><text>-</text></inputEntry>
        <inputEntry id="IE_NoPayerId_2_ProtocolTracking"><text>-</text></inputEntry>
        <inputEntry id="IE_NoPayerId_3_ProtocolTracking"><text>payerId = null or payerId = ""</text></inputEntry>
        <outputEntry id="OE_NoPayerId_res_ProtocolTracking"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_NoPayerId_acao_ProtocolTracking"><text>"Rejeitar operadora ausente"</text></outputEntry>
        <outputEntry id="OE_NoPayerId_risco_ProtocolTracking"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Fallback: Tracking approved -->
      
      <rule id="Rule_HighRisk_ProtocolTracking">
        <description>Risco alto detectado - revisao obrigatoria</description>
        <inputEntry id="IE_HighRisk_1_ProtocolTracking"><text>-</text></inputEntry>
        <inputEntry id="IE_HighRisk_2_ProtocolTracking"><text>-</text></inputEntry>
        <inputEntry id="IE_HighRisk_3_ProtocolTracking"><text>-</text></inputEntry>
        <outputEntry id="OE_HighRisk_res_ProtocolTracking"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_HighRisk_acao_ProtocolTracking"><text>"Situacao de risco alto identificada - avaliacao detalhada necessaria"</text></outputEntry>
        <outputEntry id="OE_HighRisk_risco_ProtocolTracking"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_ProtocolTracking">
        <description>Rastreamento aprovado - armazenar protocolo</description>
        <inputEntry id="IE_Fallback_1_ProtocolTracking"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_2_ProtocolTracking"><text>-</text></inputEntry>
        <inputEntry id="IE_Fallback_3_ProtocolTracking"><text>-</text></inputEntry>
        <outputEntry id="OE_Fallback_res_ProtocolTracking"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_Fallback_acao_ProtocolTracking"><text>"Rastreamento aprovado - armazenar protocolo"</text></outputEntry>
        <outputEntry id="OE_Fallback_risco_ProtocolTracking"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_ProtocolTracking">
      <dmndi:DMNShape id="DMNShape_ProtocolTracking" dmnElementRef="Decision_ProtocolTracking">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
