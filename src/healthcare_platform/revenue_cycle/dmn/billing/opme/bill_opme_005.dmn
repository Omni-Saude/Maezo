<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  BILL-OPME-005 - Preco Referencia OPME (Banco de Precos Saude)
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: BILL-OPME
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_BILL_OPME_005" name="Preco Referencia OPME (Banco de Precos Saude)" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_BILL_OPME_005" name="[SP-RC-006 | billing/opme] Preco Referencia OPME" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL_OPME_005" hitPolicy="FIRST">

      
      <input id="Input_1_BILL_OPME_005" label="Preco Cobrado OPME">
        <inputExpression id="InputExpression_1_BILL_OPME_005" typeRef="double">
          <text>precoCobrado</text>
        </inputExpression>
      </input>

      <input id="Input_2_BILL_OPME_005" label="Preco Referencia BPS">
        <inputExpression id="InputExpression_2_BILL_OPME_005" typeRef="double">
          <text>precoReferenciaBPS</text>
        </inputExpression>
      </input>

      <input id="Input_3_BILL_OPME_005" label="Percentual Variacao">
        <inputExpression id="InputExpression_3_BILL_OPME_005" typeRef="double">
          <text>percentualVariacao</text>
        </inputExpression>
      </input>

      <input id="Input_4_BILL_OPME_005" label="Tem Justificativa">
        <inputExpression id="InputExpression_4_BILL_OPME_005" typeRef="boolean">
          <text>temJustificativa</text>
        </inputExpression>
      </input>

      
      <output id="Output_1_BILL_OPME_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_BILL_OPME_005" label="Observacao" name="observacao" typeRef="string" />

      <output id="Output_3_BILL_OPME_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      <output id="Output_4_BILL_OPME_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_BILL_OPME_005" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      

      
      <rule id="Rule_Bloqueio_1_BILL_OPME_005">
        <description>Bloqueio: Preco OPME zerado ou negativo</description>
        <inputEntry id="InputEntry_B1_1_BILL_OPME_005"><text>&lt;= 0</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_BILL_OPME_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_BILL_OPME_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_BILL_OPME_005"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B1_1_BILL_OPME_005"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_2_BILL_OPME_005"><text>"BLOQUEADO - Preco OPME invalido (zerado ou negativo). Impossivel processar faturamento sem valor valido."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_3_BILL_OPME_005"><text>"Corrigir preco OPME conforme nota fiscal ou tabela contratada."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_4_BILL_OPME_005"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_5_BILL_OPME_005"><text>"CRITICO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloqueio_2_BILL_OPME_005">
        <description>Bloqueio: Preco muito acima da referencia BPS sem justificativa</description>
        <inputEntry id="InputEntry_B2_1_BILL_OPME_005"><text>&gt; 0</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_BILL_OPME_005"><text>&gt; 0</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_BILL_OPME_005"><text>&gt; 50</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_BILL_OPME_005"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_B2_1_BILL_OPME_005"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_2_BILL_OPME_005"><text>"BLOQUEADO - Preco OPME mais de 50% acima do Banco de Precos em Saude sem justificativa tecnica. Risco alto de glosa."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_3_BILL_OPME_005"><text>"Apresentar justificativa tecnica para variacao de preco ou renegociar com fornecedor."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_4_BILL_OPME_005"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_5_BILL_OPME_005"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alerta_1_BILL_OPME_005">
        <description>Alerta: Preco significativamente acima da referencia BPS</description>
        <inputEntry id="InputEntry_A1_1_BILL_OPME_005"><text>&gt; 0</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_BILL_OPME_005"><text>&gt; 0</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_BILL_OPME_005"><text>[20..50]</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_BILL_OPME_005"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_A1_1_BILL_OPME_005"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_2_BILL_OPME_005"><text>"ALERTA - Preco OPME entre 20% e 50% acima do Banco de Precos em Saude. Recomenda-se apresentar justificativa para evitar glosa."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_3_BILL_OPME_005"><text>"Preparar justificativa tecnica documentada para variacao de preco."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_4_BILL_OPME_005"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_5_BILL_OPME_005"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alerta_2_BILL_OPME_005">
        <description>Alerta: OPME sem preco de referencia no BPS</description>
        <inputEntry id="InputEntry_A2_1_BILL_OPME_005"><text>&gt; 0</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_BILL_OPME_005"><text>0</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_BILL_OPME_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_BILL_OPME_005"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_A2_1_BILL_OPME_005"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A2_2_BILL_OPME_005"><text>"ALERTA - OPME sem preco de referencia no Banco de Precos em Saude. Verificar compatibilidade com tabela contratada."</text></outputEntry>
        <outputEntry id="OutputEntry_A2_3_BILL_OPME_005"><text>"Confirmar preco com tabela contratada ou solicitar tres orcamentos de fornecedores."</text></outputEntry>
        <outputEntry id="OutputEntry_A2_4_BILL_OPME_005"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_A2_5_BILL_OPME_005"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_1_BILL_OPME_005">
        <description>Aprovado: Preco OPME dentro da faixa aceitavel</description>
        <inputEntry id="InputEntry_P1_1_BILL_OPME_005"><text>&gt; 0</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_BILL_OPME_005"><text>&gt; 0</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_BILL_OPME_005"><text>[0..20]</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_BILL_OPME_005"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_BILL_OPME_005"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_2_BILL_OPME_005"><text>"APROVADO - Preco OPME dentro da faixa aceitavel do Banco de Precos em Saude (variacao ate 20%)."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_3_BILL_OPME_005"><text>"Prosseguir com faturamento conforme procedimento padrao."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_4_BILL_OPME_005"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_5_BILL_OPME_005"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_BILL_OPME_005">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_BILL_OPME_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_BILL_OPME_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_BILL_OPME_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_BILL_OPME_005"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_BILL_OPME_005"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_BILL_OPME_005"><text>"Situacao requer analise manual por nao corresponder a nenhum criterio automatico."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_BILL_OPME_005"><text>"Encaminhar para auditoria administrativa para avaliacao caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_BILL_OPME_005"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_BILL_OPME_005"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BILL_OPME_005">
      <dmndi:DMNShape id="DMNShape_Decision_BILL_OPME_005" dmnElementRef="Decision_BILL_OPME_005">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>