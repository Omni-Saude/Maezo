<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  BILL-OPME-004 - Compatibilidade OPME x Procedimento TUSS
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: BILL-OPME
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_BILL_OPME_004" name="Compatibilidade OPME x Procedimento TUSS" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_BILL_OPME_004" name="[SP-RC-006 | billing/opme] Compatibilidade OPME x Procedimento TUSS" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL_OPME_004" hitPolicy="FIRST">

      
      <input id="Input_1_BILL_OPME_004" label="Codigo TUSS Procedimento">
        <inputExpression id="InputExpression_1_BILL_OPME_004" typeRef="string">
          <text>codigoTUSS</text>
        </inputExpression>
      </input>

      <input id="Input_2_BILL_OPME_004" label="OPME Compativel Procedimento">
        <inputExpression id="InputExpression_2_BILL_OPME_004" typeRef="boolean">
          <text>opmeCompativelProcedimento</text>
        </inputExpression>
      </input>

      <input id="Input_3_BILL_OPME_004" label="OPME Autorizado ANS">
        <inputExpression id="InputExpression_3_BILL_OPME_004" typeRef="boolean">
          <text>opmeAutorizadoANS</text>
        </inputExpression>
      </input>

      <input id="Input_4_BILL_OPME_004" label="Quantidade OPME">
        <inputExpression id="InputExpression_4_BILL_OPME_004" typeRef="integer">
          <text>quantidadeOPME</text>
        </inputExpression>
      </input>

      
      <output id="Output_1_BILL_OPME_004" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_BILL_OPME_004" label="Observacao" name="observacao" typeRef="string" />

      <output id="Output_3_BILL_OPME_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      <output id="Output_4_BILL_OPME_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_BILL_OPME_004" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      

      
      <rule id="Rule_Bloqueio_1_BILL_OPME_004">
        <description>Bloqueio: OPME incompativel com procedimento TUSS</description>
        <inputEntry id="InputEntry_B1_1_BILL_OPME_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_BILL_OPME_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_BILL_OPME_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_BILL_OPME_004"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B1_1_BILL_OPME_004"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_2_BILL_OPME_004"><text>"BLOQUEADO - OPME incompativel com procedimento TUSS informado. A ortese/protese/material especial nao e adequada para o procedimento cirurgico realizado."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_3_BILL_OPME_004"><text>"Verificar compatibilidade OPME x procedimento na tabela TUSS ANS. Corrigir codigo OPME ou codigo procedimento."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_4_BILL_OPME_004"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_5_BILL_OPME_004"><text>"CRITICO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloqueio_2_BILL_OPME_004">
        <description>Bloqueio: OPME nao autorizado pela ANS para este procedimento</description>
        <inputEntry id="InputEntry_B2_1_BILL_OPME_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_BILL_OPME_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_BILL_OPME_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_BILL_OPME_004"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B2_1_BILL_OPME_004"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_2_BILL_OPME_004"><text>"BLOQUEADO - OPME nao consta no Rol ANS para este procedimento especifico. Conforme RN 465/2021, apenas OPME listados na tabela ANS podem ser cobertos."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_3_BILL_OPME_004"><text>"Solicitar autorizacao previa da operadora para OPME fora do Rol ANS ou substituir por material autorizado."</text></outputEntry>
        <outputEntry id="OutputEntry_B2_4_BILL_OPME_004"><text>"CONTRATO"</text></outputEntry>
        <outputEntry id="OutputEntry_B2_5_BILL_OPME_004"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Bloqueio_3_BILL_OPME_004">
        <description>Bloqueio: Quantidade de OPME excede limite tecnico</description>
        <inputEntry id="InputEntry_B3_1_BILL_OPME_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_BILL_OPME_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_BILL_OPME_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B3_4_BILL_OPME_004"><text>&gt; 10</text></inputEntry>
        <outputEntry id="OutputEntry_B3_1_BILL_OPME_004"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B3_2_BILL_OPME_004"><text>"BLOQUEADO - Quantidade de OPME excede limite tecnico esperado para o procedimento. Possivel erro de lancamento ou fraude."</text></outputEntry>
        <outputEntry id="OutputEntry_B3_3_BILL_OPME_004"><text>"Revisar quantidade de OPME utilizada no procedimento. Solicitar justificativa medica se quantidade estiver correta."</text></outputEntry>
        <outputEntry id="OutputEntry_B3_4_BILL_OPME_004"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_B3_5_BILL_OPME_004"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alerta_1_BILL_OPME_004">
        <description>Alerta: Quantidade de OPME proxima ao limite tecnico</description>
        <inputEntry id="InputEntry_A1_1_BILL_OPME_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_BILL_OPME_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_BILL_OPME_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_BILL_OPME_004"><text>[5..10]</text></inputEntry>
        <outputEntry id="OutputEntry_A1_1_BILL_OPME_004"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_2_BILL_OPME_004"><text>"ALERTA - Quantidade de OPME proxima ao limite tecnico esperado. Verificar se esta dentro da normalidade para o caso clinico."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_3_BILL_OPME_004"><text>"Revisar relatorio cirurgico para confirmar necessidade de quantidade informada de OPME."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_4_BILL_OPME_004"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_5_BILL_OPME_004"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_1_BILL_OPME_004">
        <description>Aprovado: OPME compativel, autorizado e quantidade adequada</description>
        <inputEntry id="InputEntry_P1_1_BILL_OPME_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_BILL_OPME_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_BILL_OPME_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_BILL_OPME_004"><text>[1..4]</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_BILL_OPME_004"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_2_BILL_OPME_004"><text>"APROVADO - OPME compativel com procedimento TUSS, autorizado pela ANS e quantidade dentro do esperado."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_3_BILL_OPME_004"><text>"Prosseguir com faturamento conforme procedimento padrao."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_4_BILL_OPME_004"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_5_BILL_OPME_004"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_BILL_OPME_004">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_BILL_OPME_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_BILL_OPME_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_BILL_OPME_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_BILL_OPME_004"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_BILL_OPME_004"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_BILL_OPME_004"><text>"Situacao requer analise manual por nao corresponder a nenhum criterio automatico."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_BILL_OPME_004"><text>"Encaminhar para auditoria administrativa para avaliacao caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_BILL_OPME_004"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_BILL_OPME_004"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BILL_OPME_004">
      <dmndi:DMNShape id="DMNShape_Decision_BILL_OPME_004" dmnElementRef="Decision_BILL_OPME_004">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>