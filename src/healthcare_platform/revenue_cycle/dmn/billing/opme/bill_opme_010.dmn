<?xml version="1.0" encoding="UTF-8"?>
<!-- BILL-OPME-010 - Marca/Modelo Autorizado pelo Convenio | V1.0.0 (2026-02-08) | HOSPITAL -->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_BILL_OPME_010" name="Marca Modelo Autorizado Convenio" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="Decision_BILL_OPME_010" name="[SP-RC-006 | billing/opme] Marca Modelo Autorizado Convenio" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL_OPME_010" hitPolicy="FIRST">
      <input id="Input_1_BILL_OPME_010" label="Marca Autorizada"><inputExpression id="InputExpression_1_BILL_OPME_010" typeRef="boolean"><text>marcaAutorizada</text></inputExpression></input>
      <input id="Input_2_BILL_OPME_010" label="Tem Justificativa Troca"><inputExpression id="InputExpression_2_BILL_OPME_010" typeRef="boolean"><text>temJustificativaTroca</text></inputExpression></input>
      <input id="Input_3_BILL_OPME_010" label="Diferenca Preco"><inputExpression id="InputExpression_3_BILL_OPME_010" typeRef="double"><text>diferencaPreco</text></inputExpression></input>
      <input id="Input_4_BILL_OPME_010" label="Autorizacao Previa"><inputExpression id="InputExpression_4_BILL_OPME_010" typeRef="boolean"><text>autorizacaoPrevia</text></inputExpression></input>
      <output id="Output_1_BILL_OPME_010" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues></output>
      <output id="Output_2_BILL_OPME_010" label="Observacao" name="observacao" typeRef="string"/>
      <output id="Output_3_BILL_OPME_010" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>
      <output id="Output_4_BILL_OPME_010" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output>
      <output id="Output_5_BILL_OPME_010" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output>
      <rule id="Rule_Bloqueio_1_BILL_OPME_010"><description>Bloqueio: Marca nao autorizada sem justificativa</description><inputEntry id="InputEntry_B1_1_BILL_OPME_010"><text>false</text></inputEntry><inputEntry id="InputEntry_B1_2_BILL_OPME_010"><text>false</text></inputEntry><inputEntry id="InputEntry_B1_3_BILL_OPME_010"><text>-</text></inputEntry><inputEntry id="InputEntry_B1_4_BILL_OPME_010"><text>false</text></inputEntry><outputEntry id="OutputEntry_B1_1_BILL_OPME_010"><text>"Bloquear"</text></outputEntry><outputEntry id="OutputEntry_B1_2_BILL_OPME_010"><text>"BLOQUEADO - Marca/modelo OPME nao autorizado pelo convenio e sem justificativa tecnica. RN 465/2021 exige autorizacao previa."</text></outputEntry><outputEntry id="OutputEntry_B1_3_BILL_OPME_010"><text>"Solicitar autorizacao previa da operadora ou substituir por marca autorizada."</text></outputEntry><outputEntry id="OutputEntry_B1_4_BILL_OPME_010"><text>"CONTRATO"</text></outputEntry><outputEntry id="OutputEntry_B1_5_BILL_OPME_010"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_Bloqueio_2_BILL_OPME_010"><description>Bloqueio: Diferenca preco elevada sem autorizacao</description><inputEntry id="InputEntry_B2_1_BILL_OPME_010"><text>false</text></inputEntry><inputEntry id="InputEntry_B2_2_BILL_OPME_010"><text>true</text></inputEntry><inputEntry id="InputEntry_B2_3_BILL_OPME_010"><text>&gt; 30</text></inputEntry><inputEntry id="InputEntry_B2_4_BILL_OPME_010"><text>false</text></inputEntry><outputEntry id="OutputEntry_B2_1_BILL_OPME_010"><text>"Bloquear"</text></outputEntry><outputEntry id="OutputEntry_B2_2_BILL_OPME_010"><text>"BLOQUEADO - Troca de marca OPME com diferenca de preco superior a 30% sem autorizacao previa da operadora."</text></outputEntry><outputEntry id="OutputEntry_B2_3_BILL_OPME_010"><text>"Obter autorizacao previa da operadora para troca de marca com acrescimo de custo."</text></outputEntry><outputEntry id="OutputEntry_B2_4_BILL_OPME_010"><text>"VALOR"</text></outputEntry><outputEntry id="OutputEntry_B2_5_BILL_OPME_010"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_Alerta_1_BILL_OPME_010"><description>Alerta: Marca nao autorizada com justificativa</description><inputEntry id="InputEntry_A1_1_BILL_OPME_010"><text>false</text></inputEntry><inputEntry id="InputEntry_A1_2_BILL_OPME_010"><text>true</text></inputEntry><inputEntry id="InputEntry_A1_3_BILL_OPME_010"><text>[0..30]</text></inputEntry><inputEntry id="InputEntry_A1_4_BILL_OPME_010"><text>false</text></inputEntry><outputEntry id="OutputEntry_A1_1_BILL_OPME_010"><text>"Alertar"</text></outputEntry><outputEntry id="OutputEntry_A1_2_BILL_OPME_010"><text>"ALERTA - Marca OPME nao autorizada mas com justificativa tecnica. Recomenda-se obter autorizacao retroativa."</text></outputEntry><outputEntry id="OutputEntry_A1_3_BILL_OPME_010"><text>"Documentar justificativa e solicitar autorizacao retroativa da operadora."</text></outputEntry><outputEntry id="OutputEntry_A1_4_BILL_OPME_010"><text>"CONTRATO"</text></outputEntry><outputEntry id="OutputEntry_A1_5_BILL_OPME_010"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_Aprovado_1_BILL_OPME_010"><description>Aprovado: Marca autorizada pelo convenio</description><inputEntry id="InputEntry_P1_1_BILL_OPME_010"><text>true</text></inputEntry><inputEntry id="InputEntry_P1_2_BILL_OPME_010"><text>-</text></inputEntry><inputEntry id="InputEntry_P1_3_BILL_OPME_010"><text>-</text></inputEntry><inputEntry id="InputEntry_P1_4_BILL_OPME_010"><text>-</text></inputEntry><outputEntry id="OutputEntry_P1_1_BILL_OPME_010"><text>"Prosseguir"</text></outputEntry><outputEntry id="OutputEntry_P1_2_BILL_OPME_010"><text>"APROVADO - Marca/modelo OPME autorizado pelo convenio conforme clausulas contratuais."</text></outputEntry><outputEntry id="OutputEntry_P1_3_BILL_OPME_010"><text>"Prosseguir com faturamento conforme procedimento padrao."</text></outputEntry><outputEntry id="OutputEntry_P1_4_BILL_OPME_010"><text>"NENHUM"</text></outputEntry><outputEntry id="OutputEntry_P1_5_BILL_OPME_010"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_Aprovado_2_BILL_OPME_010"><description>Aprovado: Troca autorizada previamente</description><inputEntry id="InputEntry_P2_1_BILL_OPME_010"><text>false</text></inputEntry><inputEntry id="InputEntry_P2_2_BILL_OPME_010"><text>true</text></inputEntry><inputEntry id="InputEntry_P2_3_BILL_OPME_010"><text>-</text></inputEntry><inputEntry id="InputEntry_P2_4_BILL_OPME_010"><text>true</text></inputEntry><outputEntry id="OutputEntry_P2_1_BILL_OPME_010"><text>"Prosseguir"</text></outputEntry><outputEntry id="OutputEntry_P2_2_BILL_OPME_010"><text>"APROVADO - Troca de marca OPME com autorizacao previa da operadora."</text></outputEntry><outputEntry id="OutputEntry_P2_3_BILL_OPME_010"><text>"Prosseguir com faturamento conforme procedimento padrao."</text></outputEntry><outputEntry id="OutputEntry_P2_4_BILL_OPME_010"><text>"NENHUM"</text></outputEntry><outputEntry id="OutputEntry_P2_5_BILL_OPME_010"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_Fallback_BILL_OPME_010"><description>Regra padrao</description><inputEntry id="InputEntry_F_1_BILL_OPME_010"><text>-</text></inputEntry><inputEntry id="InputEntry_F_2_BILL_OPME_010"><text>-</text></inputEntry><inputEntry id="InputEntry_F_3_BILL_OPME_010"><text>-</text></inputEntry><inputEntry id="InputEntry_F_4_BILL_OPME_010"><text>-</text></inputEntry><outputEntry id="OutputEntry_F_1_BILL_OPME_010"><text>"Revisar"</text></outputEntry><outputEntry id="OutputEntry_F_2_BILL_OPME_010"><text>"Situacao requer analise manual por nao corresponder a nenhum criterio automatico."</text></outputEntry><outputEntry id="OutputEntry_F_3_BILL_OPME_010"><text>"Encaminhar para auditoria administrativa para avaliacao caso a caso."</text></outputEntry><outputEntry id="OutputEntry_F_4_BILL_OPME_010"><text>"NENHUM"</text></outputEntry><outputEntry id="OutputEntry_F_5_BILL_OPME_010"><text>"MEDIO"</text></outputEntry></rule>
    </decisionTable>
  </decision>
  <dmndi:DMNDI><dmndi:DMNDiagram id="DMNDiagram_BILL_OPME_010"><dmndi:DMNShape id="DMNShape_Decision_BILL_OPME_010" dmnElementRef="Decision_BILL_OPME_010"><dc:Bounds height="80" width="180" x="160" y="100"/></dmndi:DMNShape></dmndi:DMNDiagram></dmndi:DMNDI>
</definitions>
