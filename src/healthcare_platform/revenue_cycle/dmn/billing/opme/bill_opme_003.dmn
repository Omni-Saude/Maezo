<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  BILL-OPME-003 - Cadeia Autorizacao OPME
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: BILL-OPME
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_BILL-OPME-003" name="Cadeia Autorizacao OPME" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_BILL-OPME-003" name="[SP-RC-006 | billing/opme] Cadeia Autorizacao OPME" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL-OPME-003" hitPolicy="FIRST">

      <input id="Input_1_BILL-OPME-003" label="Possui Autorizacao Previa">
        <inputExpression id="InputExpression_1_BILL-OPME-003" typeRef="boolean">
          <text>possuiAutorizacaoPrevia</text>
        </inputExpression>
      </input>

      <input id="Input_2_BILL-OPME-003" label="Valor Excede Limite">
        <inputExpression id="InputExpression_2_BILL-OPME-003" typeRef="boolean">
          <text>valorExcedeLimite</text>
        </inputExpression>
      </input>

      <input id="Input_3_BILL-OPME-003" label="Laudo Medico Completo">
        <inputExpression id="InputExpression_3_BILL-OPME-003" typeRef="boolean">
          <text>laudoMedicoCompleto</text>
        </inputExpression>
      </input>

      <input id="Input_4_BILL-OPME-003" label="Cotacao Fornecedor Valida">
        <inputExpression id="InputExpression_4_BILL-OPME-003" typeRef="boolean">
          <text>cotacaoFornecedorValida</text>
        </inputExpression>
      </input>

      <input id="Input_5_BILL-OPME-003" label="Status Autorizacao">
        <inputExpression id="InputExpression_5_BILL-OPME-003" typeRef="string">
          <text>statusAutorizacao</text>
        </inputExpression>
        <inputValues id="InputValues_5_BILL-OPME-003">
          <text>"CONFIRMADA", "PENDENTE", "NAO_SOLICITADA"</text>
        </inputValues>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_BILL-OPME-003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_BILL-OPME-003" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_BILL-OPME-003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_BILL-OPME-003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_BILL-OPME-003" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Bloquear_1_BILL-OPME-003">
        <description>Bloqueio: Alto valor sem autorizacao previa</description>
        <inputEntry id="InputEntry_B1_1_BILL-OPME-003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_BILL-OPME-003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_BILL-OPME-003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_BILL-OPME-003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_5_BILL-OPME-003"><text>"NAO_SOLICITADA"</text></inputEntry>
<outputEntry id="OutputEntry_B1_1_BILL-OPME-003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B1_2_BILL-OPME-003"><text>"BLOQUEADO - OPME de alto valor sem autorizacao previa. Conforme RN ANS 465/2021, materiais acima do limite contratual requerem autorizacao. Solicitar antes de faturar."</text></outputEntry>
<outputEntry id="OutputEntry_B1_3_BILL-OPME-003"><text>"SOLICITAR_AUTORIZACAO"</text></outputEntry>
<outputEntry id="Rule_Bloquear_1_outputEntry_alertasConformidade_BILL-OPME-003"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Bloquear_1_outputEntry_riscoDenial_BILL-OPME-003"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Bloquear_2_BILL-OPME-003">
        <description>Bloqueio: Sem laudo medico para OPME especial</description>
        <inputEntry id="InputEntry_B2_1_BILL-OPME-003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_BILL-OPME-003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_BILL-OPME-003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_BILL-OPME-003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_5_BILL-OPME-003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B2_1_BILL-OPME-003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B2_2_BILL-OPME-003"><text>"BLOQUEADO - OPME especial sem laudo medico justificativo. Resolucao CFM exige laudo para materiais de alto custo. Completar documentacao medica antes de faturar."</text></outputEntry>
<outputEntry id="OutputEntry_B2_3_BILL-OPME-003"><text>"COMPLETAR_LAUDO"</text></outputEntry>
<outputEntry id="Rule_Bloquear_2_outputEntry_alertasConformidade_BILL-OPME-003"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Bloquear_2_outputEntry_riscoDenial_BILL-OPME-003"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Bloquear_3_BILL-OPME-003">
        <description>Bloqueio: Sem cotacao de fornecedor</description>
        <inputEntry id="InputEntry_B3_1_BILL-OPME-003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_BILL-OPME-003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_BILL-OPME-003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B3_4_BILL-OPME-003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B3_5_BILL-OPME-003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_B3_1_BILL-OPME-003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_B3_2_BILL-OPME-003"><text>"BLOQUEADO - OPME sem cotacao de fornecedor documentada. Auditoria de operadora pode questionar origem e preco. Documentar cotacao antes de faturar."</text></outputEntry>
<outputEntry id="OutputEntry_B3_3_BILL-OPME-003"><text>"OBTER_COTACAO"</text></outputEntry>
<outputEntry id="Rule_Bloquear_3_outputEntry_alertasConformidade_BILL-OPME-003"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Bloquear_3_outputEntry_riscoDenial_BILL-OPME-003"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alertar_1_BILL-OPME-003">
        <description>Alerta: Autorizacao pendente de confirmacao</description>
        <inputEntry id="InputEntry_A1_1_BILL-OPME-003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_BILL-OPME-003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_BILL-OPME-003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_BILL-OPME-003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_BILL-OPME-003"><text>"PENDENTE"</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_BILL-OPME-003"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_BILL-OPME-003"><text>"ALERTA - Autorizacao previa solicitada mas pendente de confirmacao. Aguardar confirmacao da operadora ou faturar com risco de glosa por falta de autorizacao vigente."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_BILL-OPME-003"><text>"SOLICITAR_AUTORIZACAO"</text></outputEntry>
<outputEntry id="Rule_Alertar_1_outputEntry_alertasConformidade_BILL-OPME-003"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Alertar_1_outputEntry_riscoDenial_BILL-OPME-003"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Prosseguir_1_BILL-OPME-003">
        <description>Aprovado: Cadeia de autorizacao completa para alto valor</description>
        <inputEntry id="InputEntry_P1_1_BILL-OPME-003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_BILL-OPME-003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_BILL-OPME-003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_BILL-OPME-003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_5_BILL-OPME-003"><text>"CONFIRMADA"</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_BILL-OPME-003"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_BILL-OPME-003"><text>"APROVADO - Cadeia de autorizacao OPME completa. Autorizacao previa confirmada, laudo medico presente, cotacao valida documentada. Prosseguir com faturamento."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_BILL-OPME-003"><text>"FATURAR"</text></outputEntry>
<outputEntry id="Rule_Prosseguir_1_outputEntry_alertasConformidade_BILL-OPME-003"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Prosseguir_1_outputEntry_riscoDenial_BILL-OPME-003"><text>"BAIXO"</text></outputEntry>
      </rule>

      <rule id="Rule_Prosseguir_2_BILL-OPME-003">
        <description>Aprovado: OPME abaixo do limite sem autorizacao</description>
        <inputEntry id="InputEntry_P2_1_BILL-OPME-003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_BILL-OPME-003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_BILL-OPME-003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_BILL-OPME-003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_5_BILL-OPME-003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_BILL-OPME-003"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_BILL-OPME-003"><text>"APROVADO - OPME abaixo do limite de autorizacao previa. Laudo medico presente e cotacao documentada. Autorizacao nao obrigatoria para este valor."</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_BILL-OPME-003"><text>"FATURAR"</text></outputEntry>
<outputEntry id="Rule_Prosseguir_2_outputEntry_alertasConformidade_BILL-OPME-003"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Prosseguir_2_outputEntry_riscoDenial_BILL-OPME-003"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_BILL-OPME-003">
        <description>Regra padrao - Dados insuficientes para decisao automatica</description>
        <inputEntry id="InputEntry_F_1_BILL-OPME-003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_BILL-OPME-003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_BILL-OPME-003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_BILL-OPME-003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_BILL-OPME-003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_BILL-OPME-003"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_BILL-OPME-003"><text>"REVISAR - Dados insuficientes para validacao de cadeia de autorizacao OPME. Verificar: autorizacao previa, laudo medico, cotacao e status de aprovacao."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_BILL-OPME-003"><text>"SOLICITAR_AUTORIZACAO"</text></outputEntry>
<outputEntry id="Rule_Fallback_BILL-OPME-003_outputEntry_alertasConformidade"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Fallback_BILL-OPME-003_outputEntry_riscoDenial"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BILL-OPME-003">
      <dmndi:DMNShape id="DMNShape_Decision_BILL-OPME-003" dmnElementRef="Decision_BILL-OPME-003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>