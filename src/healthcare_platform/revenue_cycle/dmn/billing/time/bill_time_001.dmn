<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  BILL-TIME-001 - Anesthesia Time Documentation Validation
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: BILL-TIME
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_BILL_TIME_001" name="Anesthesia Time Documentation Validation" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_BILL_TIME_001" name="[SP-RC-006 | billing/time] Validar Documentacao Tempo Anestesia" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL_TIME_001" hitPolicy="FIRST">

      <input id="Input_1_BILL_TIME_001" label="Hora Inicio Documentada">
        <inputExpression id="InputExpression_1_BILL_TIME_001" typeRef="boolean">
          <text>horaInicioDocumentada</text>
        </inputExpression>
      </input>

      <input id="Input_2_BILL_TIME_001" label="Hora Fim Documentada">
        <inputExpression id="InputExpression_2_BILL_TIME_001" typeRef="boolean">
          <text>horaFimDocumentada</text>
        </inputExpression>
      </input>

      <input id="Input_3_BILL_TIME_001" label="Duracao Calculada Minutos">
        <inputExpression id="InputExpression_3_BILL_TIME_001" typeRef="number">
          <text>duracaoCalculadaMinutos</text>
        </inputExpression>
      </input>

      <input id="Input_4_BILL_TIME_001" label="Duracao Cobrada Minutos">
        <inputExpression id="InputExpression_4_BILL_TIME_001" typeRef="number">
          <text>duracaoCobradaMinutos</text>
        </inputExpression>
      </input>

      <input id="Input_5_BILL_TIME_001" label="Ficha Anestesica Assinada">
        <inputExpression id="InputExpression_5_BILL_TIME_001" typeRef="boolean">
          <text>fichaAnestesicaAssinada</text>
        </inputExpression>
      </input>

      <output id="Output_1_BILL_TIME_001" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_BILL_TIME_001" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_BILL_TIME_001" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_BILL_TIME_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_BILL_TIME_001" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Block_1_BILL_TIME_001">
        <description>Bloquear sem hora inicio ou fim</description>
        <inputEntry id="InputEntry_B1_1_BILL_TIME_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_BILL_TIME_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_BILL_TIME_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_BILL_TIME_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_5_BILL_TIME_001"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_BILL_TIME_001"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_BILL_TIME_001"><text>"BLOQUEIO: Hora de inicio da anestesia nao documentada conforme CFM 1.802/2006. Impossivel calcular tempo anestesico para faturamento."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_BILL_TIME_001"><text>"Completar ficha anestesica com hora de inicio ANTES de enviar ao faturamento. Solicitar ao anestesista preenchimento retroativo se necessario."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_1_4_BILL_TIME_001"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_1_5_BILL_TIME_001"><text>"ALTO"</text></outputEntry></rule>

      <rule id="Rule_Block_2_BILL_TIME_001">
        <description>Bloquear sem hora fim</description>
        <inputEntry id="InputEntry_B2_1_BILL_TIME_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_BILL_TIME_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_BILL_TIME_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_BILL_TIME_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_5_BILL_TIME_001"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B2_1_BILL_TIME_001"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_2_BILL_TIME_001"><text>"Hora de termino da anestesia nao documentada."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_3_BILL_TIME_001"><text>"Completar ficha anestesica com hora de termino."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_2_4_BILL_TIME_001"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_2_5_BILL_TIME_001"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Block_3_BILL_TIME_001">
        <description>Bloquear tempo cobrado maior que documentado</description>
        <inputEntry id="InputEntry_B3_1_BILL_TIME_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_BILL_TIME_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_BILL_TIME_001"><text>&lt; 60</text></inputEntry>
        <inputEntry id="InputEntry_B3_4_BILL_TIME_001"><text>&gt; 90</text></inputEntry>
        <inputEntry id="InputEntry_B3_5_BILL_TIME_001"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B3_1_BILL_TIME_001"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B3_2_BILL_TIME_001"><text>"Tempo cobrado excede significativamente o tempo documentado."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B3_3_BILL_TIME_001"><text>"Ajustar tempo cobrado para corresponder ao documentado."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_3_4_BILL_TIME_001"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_3_5_BILL_TIME_001"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Block_4_BILL_TIME_001">
        <description>Bloquear sem assinatura do anestesista</description>
        <inputEntry id="InputEntry_B4_1_BILL_TIME_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B4_2_BILL_TIME_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B4_3_BILL_TIME_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B4_4_BILL_TIME_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B4_5_BILL_TIME_001"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_B4_1_BILL_TIME_001"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B4_2_BILL_TIME_001"><text>"BLOQUEIO: Ficha anestesica sem assinatura do anestesista responsavel. Documento invalido conforme CFM 1.802/2006 Art. 5."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B4_3_BILL_TIME_001"><text>"Obter assinatura do anestesista responsavel (CRM + carimbo). Verificar se anestesista esta ativo no CRM antes de enviar."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_4_4_BILL_TIME_001"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_4_5_BILL_TIME_001"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alert_1_BILL_TIME_001">
        <description>Alertar possivel subcobranca de tempo</description>
        <inputEntry id="InputEntry_A1_1_BILL_TIME_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_BILL_TIME_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_BILL_TIME_001"><text>&gt; 180</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_BILL_TIME_001"><text>&lt; 150</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_BILL_TIME_001"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_BILL_TIME_001"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_BILL_TIME_001"><text>"ALERTA RECEITA: Tempo cobrado ({{duracaoCobradaMinutos}}min) menor que documentado ({{duracaoCalculadaMinutos}}min). Perda potencial de faturamento de porte anestesico."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_BILL_TIME_001"><text>"Revisar calculo de tempo anestesico. Ajustar para tempo real documentado na ficha para maximizar faturamento legitimo conforme CBHPM."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alert_1_4_BILL_TIME_001"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alert_1_5_BILL_TIME_001"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_1_BILL_TIME_001">
        <description>Prosseguir tempos compativeis</description>
        <inputEntry id="InputEntry_P1_1_BILL_TIME_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_BILL_TIME_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_BILL_TIME_001"><text>&gt;= 30</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_BILL_TIME_001"><text>&gt;= 30</text></inputEntry>
        <inputEntry id="InputEntry_P1_5_BILL_TIME_001"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_P1_1_BILL_TIME_001"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_2_BILL_TIME_001"><text>"Documentacao de tempo completa e compativel com cobranca."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_3_BILL_TIME_001"><text>"Faturar com ficha anestesica anexa."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_1_4_BILL_TIME_001"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_1_5_BILL_TIME_001"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_BILL_TIME_001">
        <description>Caso padrao - revisar manualmente</description>
        <inputEntry id="InputEntry_F_1_BILL_TIME_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_BILL_TIME_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_BILL_TIME_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_BILL_TIME_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_BILL_TIME_001"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_BILL_TIME_001"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_BILL_TIME_001"><text>"Dados insuficientes para validar documentacao de tempo."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_BILL_TIME_001"><text>"Verificar ficha anestesica completa."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_4_BILL_TIME_001"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_5_BILL_TIME_001"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BILL_TIME_001">
      <dmndi:DMNShape id="DMNShape_Decision_BILL_TIME_001" dmnElementRef="Decision_BILL_TIME_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>