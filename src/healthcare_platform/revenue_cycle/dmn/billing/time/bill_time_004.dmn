<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  BILL-TIME-004 - Recovery Room Time Billing Validation
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: BILL-TIME
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_BILL_TIME_004" name="Recovery Room Time Billing Validation" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_BILL_TIME_004" name="[SP-RC-006 | billing/time] Validar Cobranca Tempo SRPA" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL_TIME_004" hitPolicy="FIRST">

      <input id="Input_1_BILL_TIME_004" label="Tipo Anestesia">
        <inputExpression id="InputExpression_1_BILL_TIME_004" typeRef="string">
          <text>tipoAnestesia</text>
        </inputExpression>
        <inputValues><text>"geral", "raqui", "peridural", "bloqueio", "sedacao", "local"</text></inputValues>
      </input>

      <input id="Input_2_BILL_TIME_004" label="Tempo SRPA Minutos">
        <inputExpression id="InputExpression_2_BILL_TIME_004" typeRef="number">
          <text>tempoSRPAMinutos</text>
        </inputExpression>
      </input>

      <input id="Input_3_BILL_TIME_004" label="Aldrete Score Alta">
        <inputExpression id="InputExpression_3_BILL_TIME_004" typeRef="number">
          <text>aldreteScoreAlta</text>
        </inputExpression>
      </input>

      <input id="Input_4_BILL_TIME_004" label="Complicacoes SRPA">
        <inputExpression id="InputExpression_4_BILL_TIME_004" typeRef="boolean">
          <text>complicacoesSRPA</text>
        </inputExpression>
      </input>

      <input id="Input_5_BILL_TIME_004" label="Cobranca SRPA Separada">
        <inputExpression id="InputExpression_5_BILL_TIME_004" typeRef="boolean">
          <text>cobrancaSRPASeparada</text>
        </inputExpression>
      </input>

      <output id="Output_1_BILL_TIME_004" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_BILL_TIME_004" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_BILL_TIME_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_BILL_TIME_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_BILL_TIME_004" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Block_1_BILL_TIME_004">
        <description>Bloquear SRPA prolongada sem complicacao documentada</description>
        <inputEntry id="InputEntry_B1_1_BILL_TIME_004"><text>"geral", "raqui"</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_BILL_TIME_004"><text>&gt; 180</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_BILL_TIME_004"><text>&gt;= 9</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_BILL_TIME_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_5_BILL_TIME_004"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_BILL_TIME_004"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_BILL_TIME_004"><text>"SRPA &gt; 3h com Aldrete alto e sem complicacoes. Tempo incompativel."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_BILL_TIME_004"><text>"Documentar razao da permanencia prolongada ou ajustar tempo."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_1_4_BILL_TIME_004"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_1_5_BILL_TIME_004"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Block_2_BILL_TIME_004">
        <description>Bloquear cobranca SRPA para anestesia local</description>
        <inputEntry id="InputEntry_B2_1_BILL_TIME_004"><text>"local"</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_BILL_TIME_004"><text>&gt; 30</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_BILL_TIME_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_BILL_TIME_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_5_BILL_TIME_004"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_B2_1_BILL_TIME_004"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_2_BILL_TIME_004"><text>"Cobranca SRPA para anestesia local normalmente nao e coberta."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_3_BILL_TIME_004"><text>"Remover cobranca SRPA ou documentar intercorrencia que justifique."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_2_4_BILL_TIME_004"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_2_5_BILL_TIME_004"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alert_1_BILL_TIME_004">
        <description>Alertar anestesia geral sem cobranca SRPA</description>
        <inputEntry id="InputEntry_A1_1_BILL_TIME_004"><text>"geral"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_BILL_TIME_004"><text>&gt; 60</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_BILL_TIME_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_BILL_TIME_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_BILL_TIME_004"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_BILL_TIME_004"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_BILL_TIME_004"><text>"Anestesia geral com tempo SRPA significativo sem cobranca separada."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_BILL_TIME_004"><text>"Verificar se contrato permite cobranca SRPA separada."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alert_1_4_BILL_TIME_004"><text>"DOC"</text></outputEntry>
      <outputEntry id="OutputEntry_Alert_1_5_BILL_TIME_004"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_1_BILL_TIME_004">
        <description>Prosseguir SRPA prolongada com complicacoes</description>
        <inputEntry id="InputEntry_P1_1_BILL_TIME_004"><text>"geral", "raqui", "peridural"</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_BILL_TIME_004"><text>&gt; 120</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_BILL_TIME_004"><text>&lt; 9</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_BILL_TIME_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_5_BILL_TIME_004"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_P1_1_BILL_TIME_004"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_2_BILL_TIME_004"><text>"SRPA prolongada justificada por complicacoes documentadas."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_3_BILL_TIME_004"><text>"Faturar com documentacao de intercorrencias."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_1_4_BILL_TIME_004"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_1_5_BILL_TIME_004"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_2_BILL_TIME_004">
        <description>Prosseguir SRPA tempo padrao</description>
        <inputEntry id="InputEntry_P2_1_BILL_TIME_004"><text>"geral", "raqui", "peridural"</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_BILL_TIME_004"><text>[30..120]</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_BILL_TIME_004"><text>&gt;= 9</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_BILL_TIME_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_5_BILL_TIME_004"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_P2_1_BILL_TIME_004"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_2_BILL_TIME_004"><text>"Tempo SRPA dentro do esperado. Aldrete satisfatorio."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_3_BILL_TIME_004"><text>"Faturar SRPA conforme tempo."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_2_4_BILL_TIME_004"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_2_5_BILL_TIME_004"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_3_BILL_TIME_004">
        <description>Prosseguir sedacao SRPA minima</description>
        <inputEntry id="InputEntry_P3_1_BILL_TIME_004"><text>"sedacao", "bloqueio"</text></inputEntry>
        <inputEntry id="InputEntry_P3_2_BILL_TIME_004"><text>[15..60]</text></inputEntry>
        <inputEntry id="InputEntry_P3_3_BILL_TIME_004"><text>&gt;= 9</text></inputEntry>
        <inputEntry id="InputEntry_P3_4_BILL_TIME_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P3_5_BILL_TIME_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_P3_1_BILL_TIME_004"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P3_2_BILL_TIME_004"><text>"Tempo SRPA adequado para sedacao/bloqueio."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P3_3_BILL_TIME_004"><text>"Faturar se contrato permitir."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_3_4_BILL_TIME_004"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_3_5_BILL_TIME_004"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_BILL_TIME_004">
        <description>Caso padrao - revisar manualmente</description>
        <inputEntry id="InputEntry_F_1_BILL_TIME_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_BILL_TIME_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_BILL_TIME_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_BILL_TIME_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_BILL_TIME_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_BILL_TIME_004"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_BILL_TIME_004"><text>"Dados insuficientes para validar cobranca SRPA."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_BILL_TIME_004"><text>"Verificar tipo anestesia, tempo, Aldrete e contrato."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_4_BILL_TIME_004"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_5_BILL_TIME_004"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BILL_TIME_004">
      <dmndi:DMNShape id="DMNShape_Decision_BILL_TIME_004" dmnElementRef="Decision_BILL_TIME_004">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>