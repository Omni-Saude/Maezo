<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  BILL-UPCODE-005 - Emergency Elective Surcharge Validation
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: BILL-UPCODE
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_BILL_UPCODE_005" name="Emergency Elective Surcharge Validation" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_BILL_UPCODE_005" name="[SP-RC-006 | billing/upcode] Validar Adicional Urgencia Emergencia" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL_UPCODE_005" hitPolicy="FIRST">

      <input id="Input_1_BILL_UPCODE_005" label="Tipo Atendimento Cobrado">
        <inputExpression id="InputExpression_1_BILL_UPCODE_005" typeRef="string">
          <text>tipoAtendimentoCobrado</text>
        </inputExpression>
        <inputValues><text>"emergencia", "urgencia", "eletivo"</text></inputValues>
      </input>

      <input id="Input_2_BILL_UPCODE_005" label="Hora Entrada PS">
        <inputExpression id="InputExpression_2_BILL_UPCODE_005" typeRef="number">
          <text>horaEntradaPS</text>
        </inputExpression>
      </input>

      <input id="Input_3_BILL_UPCODE_005" label="Tempo Porta Bisturi (min)">
        <inputExpression id="InputExpression_3_BILL_UPCODE_005" typeRef="number">
          <text>tempoPortaBisturi</text>
        </inputExpression>
      </input>

      <input id="Input_4_BILL_UPCODE_005" label="Classificacao Risco Manchester">
        <inputExpression id="InputExpression_4_BILL_UPCODE_005" typeRef="string">
          <text>classificacaoRiscoManchester</text>
        </inputExpression>
        <inputValues><text>"vermelho", "laranja", "amarelo", "verde", "azul"</text></inputValues>
      </input>

      <input id="Input_5_BILL_UPCODE_005" label="CID Trauma Agudo">
        <inputExpression id="InputExpression_5_BILL_UPCODE_005" typeRef="boolean">
          <text>cidTraumaAgudo</text>
        </inputExpression>
      </input>

      <output id="Output_1_BILL_UPCODE_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_BILL_UPCODE_005" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_BILL_UPCODE_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_BILL_UPCODE_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_BILL_UPCODE_005" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Block_1_BILL_UPCODE_005">
        <description>Bloquear adicional emergencia para caso eletivo</description>
        <inputEntry id="InputEntry_B1_1_BILL_UPCODE_005"><text>"emergencia"</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_BILL_UPCODE_005"><text>[8..18]</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_BILL_UPCODE_005"><text>&gt; 240</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_BILL_UPCODE_005"><text>"verde", "azul"</text></inputEntry>
        <inputEntry id="InputEntry_B1_5_BILL_UPCODE_005"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_BILL_UPCODE_005"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_BILL_UPCODE_005"><text>"Adicional emergencia para caso verde/azul em horario comercial com &gt; 4h para cirurgia."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_BILL_UPCODE_005"><text>"Remover adicional de emergencia. Cobrar como eletivo."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_1_4_BILL_UPCODE_005"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_1_5_BILL_UPCODE_005"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Block_2_BILL_UPCODE_005">
        <description>Bloquear emergencia sem classificacao de risco</description>
        <inputEntry id="InputEntry_B2_1_BILL_UPCODE_005"><text>"emergencia"</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_BILL_UPCODE_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_BILL_UPCODE_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_BILL_UPCODE_005"><text>null</text></inputEntry>
        <inputEntry id="InputEntry_B2_5_BILL_UPCODE_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B2_1_BILL_UPCODE_005"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_2_BILL_UPCODE_005"><text>"Adicional emergencia sem classificacao de risco documentada."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_3_BILL_UPCODE_005"><text>"Documentar classificacao Manchester ou remover adicional."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_2_4_BILL_UPCODE_005"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_2_5_BILL_UPCODE_005"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alert_1_BILL_UPCODE_005">
        <description>Alertar possivel subcobranca - eletivo noturno</description>
        <inputEntry id="InputEntry_A1_1_BILL_UPCODE_005"><text>"eletivo"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_BILL_UPCODE_005"><text>&lt; 6, &gt; 22</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_BILL_UPCODE_005"><text>&lt; 60</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_BILL_UPCODE_005"><text>"vermelho", "laranja"</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_BILL_UPCODE_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_BILL_UPCODE_005"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_BILL_UPCODE_005"><text>"Caso vermelho/laranja em horario noturno cobrado como eletivo. Verificar adicional."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_BILL_UPCODE_005"><text>"Avaliar cobranca de adicional noturno/urgencia se aplicavel."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alert_1_4_BILL_UPCODE_005"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Alert_1_5_BILL_UPCODE_005"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Alert_2_BILL_UPCODE_005">
        <description>Alertar urgencia fim de semana sem adicional</description>
        <inputEntry id="InputEntry_A2_1_BILL_UPCODE_005"><text>"urgencia"</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_BILL_UPCODE_005"><text>&lt; 6, &gt; 22</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_BILL_UPCODE_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_BILL_UPCODE_005"><text>"laranja", "amarelo"</text></inputEntry>
        <inputEntry id="InputEntry_A2_5_BILL_UPCODE_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A2_1_BILL_UPCODE_005"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_2_BILL_UPCODE_005"><text>"Urgencia noturna. Verificar se adicional noturno foi aplicado."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_3_BILL_UPCODE_005"><text>"Aplicar adicional noturno se contrato permitir."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alert_2_4_BILL_UPCODE_005"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Alert_2_5_BILL_UPCODE_005"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_1_BILL_UPCODE_005">
        <description>Prosseguir emergencia verdadeira</description>
        <inputEntry id="InputEntry_P1_1_BILL_UPCODE_005"><text>"emergencia"</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_BILL_UPCODE_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_BILL_UPCODE_005"><text>&lt; 60</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_BILL_UPCODE_005"><text>"vermelho", "laranja"</text></inputEntry>
        <inputEntry id="InputEntry_P1_5_BILL_UPCODE_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_P1_1_BILL_UPCODE_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_2_BILL_UPCODE_005"><text>"Emergencia verdadeira: classificacao alta e tempo porta-bisturi &lt; 1h."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_3_BILL_UPCODE_005"><text>"Faturar com adicional de emergencia. Anexar classificacao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_1_4_BILL_UPCODE_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_1_5_BILL_UPCODE_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_2_BILL_UPCODE_005">
        <description>Prosseguir trauma agudo</description>
        <inputEntry id="InputEntry_P2_1_BILL_UPCODE_005"><text>"emergencia"</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_BILL_UPCODE_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_BILL_UPCODE_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_BILL_UPCODE_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_5_BILL_UPCODE_005"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_P2_1_BILL_UPCODE_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_2_BILL_UPCODE_005"><text>"CID de trauma agudo justifica adicional de emergencia."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_3_BILL_UPCODE_005"><text>"Faturar com adicional. CID de trauma documenta urgencia."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_2_4_BILL_UPCODE_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_2_5_BILL_UPCODE_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_3_BILL_UPCODE_005">
        <description>Prosseguir eletivo padrao</description>
        <inputEntry id="InputEntry_P3_1_BILL_UPCODE_005"><text>"eletivo"</text></inputEntry>
        <inputEntry id="InputEntry_P3_2_BILL_UPCODE_005"><text>[8..18]</text></inputEntry>
        <inputEntry id="InputEntry_P3_3_BILL_UPCODE_005"><text>&gt; 60</text></inputEntry>
        <inputEntry id="InputEntry_P3_4_BILL_UPCODE_005"><text>"amarelo", "verde", "azul"</text></inputEntry>
        <inputEntry id="InputEntry_P3_5_BILL_UPCODE_005"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_P3_1_BILL_UPCODE_005"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P3_2_BILL_UPCODE_005"><text>"Procedimento eletivo em horario comercial. Cobranca padrao."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P3_3_BILL_UPCODE_005"><text>"Faturar sem adicional de urgencia/emergencia."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_3_4_BILL_UPCODE_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_3_5_BILL_UPCODE_005"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_BILL_UPCODE_005">
        <description>Caso padrao - revisar manualmente</description>
        <inputEntry id="InputEntry_F_1_BILL_UPCODE_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_BILL_UPCODE_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_BILL_UPCODE_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_BILL_UPCODE_005"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_BILL_UPCODE_005"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_BILL_UPCODE_005"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_BILL_UPCODE_005"><text>"Dados insuficientes para validar tipo de atendimento."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_BILL_UPCODE_005"><text>"Verificar classificacao de risco, horario e CID."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_4_BILL_UPCODE_005"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_5_BILL_UPCODE_005"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BILL_UPCODE_005">
      <dmndi:DMNShape id="DMNShape_Decision_BILL_UPCODE_005" dmnElementRef="Decision_BILL_UPCODE_005">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>