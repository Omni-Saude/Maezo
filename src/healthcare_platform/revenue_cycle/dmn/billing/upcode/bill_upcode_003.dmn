<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  BILL-UPCODE-003 - Anesthesia Time Based Coding Validation
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: BILL-UPCODE
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_BILL_UPCODE_003" name="Anesthesia Time Based Coding Validation" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_BILL_UPCODE_003" name="[SP-RC-006 | billing/upcode] Validar Cobranca Anestesia por Tempo" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL_UPCODE_003" hitPolicy="FIRST">

      <input id="Input_1_BILL_UPCODE_003" label="Tempo Anestesia Documentado (min)">
        <inputExpression id="InputExpression_1_BILL_UPCODE_003" typeRef="number">
          <text>tempoAnestesiaMinutos</text>
        </inputExpression>
      </input>

      <input id="Input_2_BILL_UPCODE_003" label="Unidades Anestesia Cobradas">
        <inputExpression id="InputExpression_2_BILL_UPCODE_003" typeRef="number">
          <text>unidadesAnestesiaCobradas</text>
        </inputExpression>
      </input>

      <input id="Input_3_BILL_UPCODE_003" label="Tipo Anestesia">
        <inputExpression id="InputExpression_3_BILL_UPCODE_003" typeRef="string">
          <text>tipoAnestesia</text>
        </inputExpression>
        <inputValues><text>"geral", "raqui", "peridural", "local", "sedacao"</text></inputValues>
      </input>

      <input id="Input_4_BILL_UPCODE_003" label="Ficha Anestesica Completa">
        <inputExpression id="InputExpression_4_BILL_UPCODE_003" typeRef="boolean">
          <text>fichaAnestesicaCompleta</text>
        </inputExpression>
      </input>

      <input id="Input_5_BILL_UPCODE_003" label="ASA do Paciente">
        <inputExpression id="InputExpression_5_BILL_UPCODE_003" typeRef="number">
          <text>asaPaciente</text>
        </inputExpression>
      </input>

      <output id="Output_1_BILL_UPCODE_003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_BILL_UPCODE_003" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_BILL_UPCODE_003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_BILL_UPCODE_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_BILL_UPCODE_003" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Block_1_BILL_UPCODE_003">
        <description>Bloquear sem ficha anestesica</description>
        <inputEntry id="InputEntry_B1_1_BILL_UPCODE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_BILL_UPCODE_003"><text>&gt; 0</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_BILL_UPCODE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_BILL_UPCODE_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_5_BILL_UPCODE_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_BILL_UPCODE_003"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_BILL_UPCODE_003"><text>"Cobranca de anestesia sem ficha anestesica completa. Glosa certa."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_BILL_UPCODE_003"><text>"Anexar ficha anestesica com horarios inicio/fim e sinais vitais."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_1_4_BILL_UPCODE_003"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_1_5_BILL_UPCODE_003"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Block_2_BILL_UPCODE_003">
        <description>Bloquear unidades acima do tempo documentado</description>
        <inputEntry id="InputEntry_B2_1_BILL_UPCODE_003"><text>&lt; 60</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_BILL_UPCODE_003"><text>&gt; 4</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_BILL_UPCODE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_BILL_UPCODE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_5_BILL_UPCODE_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B2_1_BILL_UPCODE_003"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_2_BILL_UPCODE_003"><text>"Unidades cobradas excedem tempo documentado. Tempo &lt; 60min nao comporta &gt; 4 unidades."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_3_BILL_UPCODE_003"><text>"Ajustar unidades para compatibilizar com tempo ou corrigir ficha."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_2_4_BILL_UPCODE_003"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_2_5_BILL_UPCODE_003"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Block_3_BILL_UPCODE_003">
        <description>Bloquear discrepancia extrema tempo vs unidades</description>
        <inputEntry id="InputEntry_B3_1_BILL_UPCODE_003"><text>&lt; 30</text></inputEntry>
        <inputEntry id="InputEntry_B3_2_BILL_UPCODE_003"><text>&gt; 2</text></inputEntry>
        <inputEntry id="InputEntry_B3_3_BILL_UPCODE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_4_BILL_UPCODE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B3_5_BILL_UPCODE_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B3_1_BILL_UPCODE_003"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B3_2_BILL_UPCODE_003"><text>"Tempo anestesico &lt; 30min com mais de 2 unidades. Incompativel."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B3_3_BILL_UPCODE_003"><text>"Revisar ficha anestesica e quantidade de unidades."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_3_4_BILL_UPCODE_003"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_3_5_BILL_UPCODE_003"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alert_1_BILL_UPCODE_003">
        <description>Alertar possivel subcobranca - ASA alto com poucas unidades</description>
        <inputEntry id="InputEntry_A1_1_BILL_UPCODE_003"><text>&gt; 180</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_BILL_UPCODE_003"><text>&lt; 8</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_BILL_UPCODE_003"><text>"geral"</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_BILL_UPCODE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_BILL_UPCODE_003"><text>&gt;= 4</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_BILL_UPCODE_003"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_BILL_UPCODE_003"><text>"Paciente ASA 4-5 com anestesia geral &gt; 3h pode ter adicional de complexidade."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_BILL_UPCODE_003"><text>"Verificar se adicional por ASA elevado esta sendo cobrado."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alert_1_4_BILL_UPCODE_003"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Alert_1_5_BILL_UPCODE_003"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_1_BILL_UPCODE_003">
        <description>Prosseguir tempo e unidades alinhados</description>
        <inputEntry id="InputEntry_P1_1_BILL_UPCODE_003"><text>&gt;= 60</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_BILL_UPCODE_003"><text>[4..12]</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_BILL_UPCODE_003"><text>"geral", "raqui", "peridural"</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_BILL_UPCODE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_5_BILL_UPCODE_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_P1_1_BILL_UPCODE_003"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_2_BILL_UPCODE_003"><text>"Tempo anestesico e unidades compativeis. Ficha completa."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_3_BILL_UPCODE_003"><text>"Faturar com ficha anestesica anexa."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_1_4_BILL_UPCODE_003"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_1_5_BILL_UPCODE_003"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_2_BILL_UPCODE_003">
        <description>Prosseguir procedimento curto com sedacao/local</description>
        <inputEntry id="InputEntry_P2_1_BILL_UPCODE_003"><text>&lt; 60</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_BILL_UPCODE_003"><text>[1..4]</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_BILL_UPCODE_003"><text>"local", "sedacao"</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_BILL_UPCODE_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_5_BILL_UPCODE_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_P2_1_BILL_UPCODE_003"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_2_BILL_UPCODE_003"><text>"Sedacao/local com tempo e unidades compativeis."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_3_BILL_UPCODE_003"><text>"Faturar conforme tabela."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_2_4_BILL_UPCODE_003"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_2_5_BILL_UPCODE_003"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_BILL_UPCODE_003">
        <description>Caso padrao - revisar manualmente</description>
        <inputEntry id="InputEntry_F_1_BILL_UPCODE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_BILL_UPCODE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_BILL_UPCODE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_BILL_UPCODE_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_BILL_UPCODE_003"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_BILL_UPCODE_003"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_BILL_UPCODE_003"><text>"Dados insuficientes para validar cobranca de anestesia."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_BILL_UPCODE_003"><text>"Verificar ficha anestesica, tempo, tipo e unidades."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_4_BILL_UPCODE_003"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_5_BILL_UPCODE_003"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BILL_UPCODE_003">
      <dmndi:DMNShape id="DMNShape_Decision_BILL_UPCODE_003" dmnElementRef="Decision_BILL_UPCODE_003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>