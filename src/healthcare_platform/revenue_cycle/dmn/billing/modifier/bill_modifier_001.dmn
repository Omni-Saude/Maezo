<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  BILL-MODIFIER-001 - Same Access Modifier Validation
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: BILL-MODIFIER
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_BILL_MODIFIER_001" name="Same Access Modifier Validation" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_BILL_MODIFIER_001" name="[SP-RC-006 | billing/modifier] Validar Modificador Mesmo Acesso" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL_MODIFIER_001" hitPolicy="FIRST">

      <input id="Input_1_BILL_MODIFIER_001" label="Quantidade Procedimentos">
        <inputExpression id="InputExpression_1_BILL_MODIFIER_001" typeRef="number">
          <text>quantidadeProcedimentos</text>
        </inputExpression>
      </input>

      <input id="Input_2_BILL_MODIFIER_001" label="Mesmo Acesso Cirurgico">
        <inputExpression id="InputExpression_2_BILL_MODIFIER_001" typeRef="boolean">
          <text>mesmoAcessoCirurgico</text>
        </inputExpression>
      </input>

      <input id="Input_3_BILL_MODIFIER_001" label="Acessos Diferentes Documentados">
        <inputExpression id="InputExpression_3_BILL_MODIFIER_001" typeRef="boolean">
          <text>acessosDiferentesDocumentados</text>
        </inputExpression>
      </input>

      <input id="Input_4_BILL_MODIFIER_001" label="Modificador Mesmo Acesso Aplicado">
        <inputExpression id="InputExpression_4_BILL_MODIFIER_001" typeRef="boolean">
          <text>modificadorMesmoAcessoAplicado</text>
        </inputExpression>
      </input>

      <output id="Output_1_BILL_MODIFIER_001" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_BILL_MODIFIER_001" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_BILL_MODIFIER_001" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_BILL_MODIFIER_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_BILL_MODIFIER_001" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Block_1_BILL_MODIFIER_001">
        <description>Bloquear multiplos procedimentos mesmo acesso sem modificador</description>
        <inputEntry id="InputEntry_B1_1_BILL_MODIFIER_001"><text>&gt; 1</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_BILL_MODIFIER_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_BILL_MODIFIER_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_BILL_MODIFIER_001"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_BILL_MODIFIER_001"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_BILL_MODIFIER_001"><text>"BLOQUEIO: Multiplos procedimentos pela mesma via de acesso sem modificador conforme CBHPM. Operadora aplicara reducao de 50-70% automaticamente, resultando em glosa parcial."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_BILL_MODIFIER_001"><text>"Aplicar modificador de mesmo acesso no sistema antes do faturamento OU anexar descricao operatoria documentando acessos cirurgicos distintos (ex: incisao separada)."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_1_4_BILL_MODIFIER_001"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_1_5_BILL_MODIFIER_001"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alert_1_BILL_MODIFIER_001">
        <description>Alertar modificador aplicado quando acessos podem ser diferentes</description>
        <inputEntry id="InputEntry_A1_1_BILL_MODIFIER_001"><text>&gt; 1</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_BILL_MODIFIER_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_BILL_MODIFIER_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_BILL_MODIFIER_001"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_BILL_MODIFIER_001"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_BILL_MODIFIER_001"><text>"ALERTA RECEITA: Modificador de reducao aplicado mas acessos DIFERENTES estao documentados. Perda potencial de 30-50% da receita do procedimento secundario."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_BILL_MODIFIER_001"><text>"Revisar descricao operatoria. Se acessos sao realmente diferentes (incisoes distintas, tempos separados), REMOVER modificador e faturar integralmente conforme CBHPM."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alert_1_4_BILL_MODIFIER_001"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Alert_1_5_BILL_MODIFIER_001"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Alert_2_BILL_MODIFIER_001">
        <description>Alertar multiplos procedimentos sem documentacao de acesso</description>
        <inputEntry id="InputEntry_A2_1_BILL_MODIFIER_001"><text>&gt; 1</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_BILL_MODIFIER_001"><text>null</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_BILL_MODIFIER_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_BILL_MODIFIER_001"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_A2_1_BILL_MODIFIER_001"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_2_BILL_MODIFIER_001"><text>"Multiplos procedimentos sem documentacao clara de acesso. Risco de glosa."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A2_3_BILL_MODIFIER_001"><text>"Documentar acessos cirurgicos na descricao operatoria."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alert_2_4_BILL_MODIFIER_001"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Alert_2_5_BILL_MODIFIER_001"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_1_BILL_MODIFIER_001">
        <description>Prosseguir acessos diferentes documentados</description>
        <inputEntry id="InputEntry_P1_1_BILL_MODIFIER_001"><text>&gt; 1</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_BILL_MODIFIER_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_BILL_MODIFIER_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_BILL_MODIFIER_001"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_P1_1_BILL_MODIFIER_001"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_2_BILL_MODIFIER_001"><text>"Acessos diferentes documentados. Cobranca integral de cada procedimento."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_3_BILL_MODIFIER_001"><text>"Faturar todos procedimentos sem reducao. Anexar descricao dos acessos."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_1_4_BILL_MODIFIER_001"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_1_5_BILL_MODIFIER_001"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_2_BILL_MODIFIER_001">
        <description>Prosseguir mesmo acesso com modificador correto</description>
        <inputEntry id="InputEntry_P2_1_BILL_MODIFIER_001"><text>&gt; 1</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_BILL_MODIFIER_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_BILL_MODIFIER_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_BILL_MODIFIER_001"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_P2_1_BILL_MODIFIER_001"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_2_BILL_MODIFIER_001"><text>"Modificador mesmo acesso corretamente aplicado. Cobranca padrao."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_3_BILL_MODIFIER_001"><text>"Faturar com reducao conforme tabela contratual."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_2_4_BILL_MODIFIER_001"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_2_5_BILL_MODIFIER_001"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_3_BILL_MODIFIER_001">
        <description>Prosseguir procedimento unico</description>
        <inputEntry id="InputEntry_P3_1_BILL_MODIFIER_001"><text>1</text></inputEntry>
        <inputEntry id="InputEntry_P3_2_BILL_MODIFIER_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P3_3_BILL_MODIFIER_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P3_4_BILL_MODIFIER_001"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_P3_1_BILL_MODIFIER_001"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P3_2_BILL_MODIFIER_001"><text>"Procedimento unico. Modificador de acesso nao aplicavel."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P3_3_BILL_MODIFIER_001"><text>"Faturar procedimento normalmente."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_3_4_BILL_MODIFIER_001"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_3_5_BILL_MODIFIER_001"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_BILL_MODIFIER_001">
        <description>Caso padrao - revisar manualmente</description>
        <inputEntry id="InputEntry_F_1_BILL_MODIFIER_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_BILL_MODIFIER_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_BILL_MODIFIER_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_BILL_MODIFIER_001"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_BILL_MODIFIER_001"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_BILL_MODIFIER_001"><text>"Dados insuficientes para validar modificador de acesso."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_BILL_MODIFIER_001"><text>"Verificar quantidade procedimentos e documentacao de acessos."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_4_BILL_MODIFIER_001"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_5_BILL_MODIFIER_001"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BILL_MODIFIER_001">
      <dmndi:DMNShape id="DMNShape_Decision_BILL_MODIFIER_001" dmnElementRef="Decision_BILL_MODIFIER_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>