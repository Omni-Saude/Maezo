<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  BILL-MODIFIER-002 - Multiple Procedure Modifier Validation
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: BILL-MODIFIER
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_BILL_MODIFIER_002" name="Multiple Procedure Modifier Validation" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_BILL_MODIFIER_002" name="[SP-RC-006 | billing/modifier] Validar Modificador Multiplos Procedimentos" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL_MODIFIER_002" hitPolicy="FIRST">

      <input id="Input_1_BILL_MODIFIER_002" label="Quantidade Procedimentos">
        <inputExpression id="InputExpression_1_BILL_MODIFIER_002" typeRef="number">
          <text>quantidadeProcedimentos</text>
        </inputExpression>
      </input>

      <input id="Input_2_BILL_MODIFIER_002" label="Procedimento Principal Maior Valor">
        <inputExpression id="InputExpression_2_BILL_MODIFIER_002" typeRef="boolean">
          <text>procedimentoPrincipalMaiorValor</text>
        </inputExpression>
      </input>

      <input id="Input_3_BILL_MODIFIER_002" label="Reducao Contratual Aplicada">
        <inputExpression id="InputExpression_3_BILL_MODIFIER_002" typeRef="boolean">
          <text>reducaoContratualAplicada</text>
        </inputExpression>
      </input>

      <input id="Input_4_BILL_MODIFIER_002" label="Mesma Especialidade">
        <inputExpression id="InputExpression_4_BILL_MODIFIER_002" typeRef="boolean">
          <text>mesmaEspecialidade</text>
        </inputExpression>
      </input>

      <input id="Input_5_BILL_MODIFIER_002" label="Mesma Equipe Cirurgica">
        <inputExpression id="InputExpression_5_BILL_MODIFIER_002" typeRef="boolean">
          <text>mesmaEquipeCirurgica</text>
        </inputExpression>
      </input>

      <output id="Output_1_BILL_MODIFIER_002" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_BILL_MODIFIER_002" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_BILL_MODIFIER_002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_BILL_MODIFIER_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_BILL_MODIFIER_002" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Block_1_BILL_MODIFIER_002">
        <description>Bloquear ordenacao incorreta - menor valor como principal</description>
        <inputEntry id="InputEntry_B1_1_BILL_MODIFIER_002"><text>&gt; 1</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_BILL_MODIFIER_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_BILL_MODIFIER_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_BILL_MODIFIER_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_5_BILL_MODIFIER_002"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_BILL_MODIFIER_002"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_BILL_MODIFIER_002"><text>"Procedimento de menor valor como principal. Perda de receita."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_BILL_MODIFIER_002"><text>"Reordenar procedimentos: maior valor primeiro (principal), secundarios depois."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_1_4_BILL_MODIFIER_002"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_1_5_BILL_MODIFIER_002"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Block_2_BILL_MODIFIER_002">
        <description>Bloquear multiplos sem reducao - operadora glosara</description>
        <inputEntry id="InputEntry_B2_1_BILL_MODIFIER_002"><text>&gt; 2</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_BILL_MODIFIER_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_BILL_MODIFIER_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_BILL_MODIFIER_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_B2_5_BILL_MODIFIER_002"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_B2_1_BILL_MODIFIER_002"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_2_BILL_MODIFIER_002"><text>"Multiplos procedimentos mesma equipe/especialidade sem reducao. Sera glosado."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_3_BILL_MODIFIER_002"><text>"Aplicar reducao contratual para procedimentos secundarios."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_2_4_BILL_MODIFIER_002"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_2_5_BILL_MODIFIER_002"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alert_1_BILL_MODIFIER_002">
        <description>Alertar cobranca integral com especialidades diferentes</description>
        <inputEntry id="InputEntry_A1_1_BILL_MODIFIER_002"><text>&gt; 1</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_BILL_MODIFIER_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_BILL_MODIFIER_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_BILL_MODIFIER_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_BILL_MODIFIER_002"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_BILL_MODIFIER_002"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_BILL_MODIFIER_002"><text>"Cobranca integral com especialidades/equipes diferentes. Verificar contrato."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_BILL_MODIFIER_002"><text>"Confirmar que contrato permite cobranca integral para equipes distintas."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alert_1_4_BILL_MODIFIER_002"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Alert_1_5_BILL_MODIFIER_002"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_1_BILL_MODIFIER_002">
        <description>Prosseguir ordenacao correta com reducao</description>
        <inputEntry id="InputEntry_P1_1_BILL_MODIFIER_002"><text>&gt; 1</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_BILL_MODIFIER_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_BILL_MODIFIER_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_BILL_MODIFIER_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_5_BILL_MODIFIER_002"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_P1_1_BILL_MODIFIER_002"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_2_BILL_MODIFIER_002"><text>"Multiplos procedimentos corretamente ordenados e com reducao contratual."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_3_BILL_MODIFIER_002"><text>"Faturar com reducao aplicada. Principal 100%, secundarios conforme tabela."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_1_4_BILL_MODIFIER_002"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_1_5_BILL_MODIFIER_002"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_2_BILL_MODIFIER_002">
        <description>Prosseguir equipes diferentes - cobranca integral</description>
        <inputEntry id="InputEntry_P2_1_BILL_MODIFIER_002"><text>&gt; 1</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_BILL_MODIFIER_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_BILL_MODIFIER_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_BILL_MODIFIER_002"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P2_5_BILL_MODIFIER_002"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_P2_1_BILL_MODIFIER_002"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_2_BILL_MODIFIER_002"><text>"Equipes/especialidades diferentes. Cobranca integral de cada."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_3_BILL_MODIFIER_002"><text>"Faturar cada procedimento por sua equipe sem reducao."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_2_4_BILL_MODIFIER_002"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_2_5_BILL_MODIFIER_002"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_3_BILL_MODIFIER_002">
        <description>Prosseguir procedimento unico</description>
        <inputEntry id="InputEntry_P3_1_BILL_MODIFIER_002"><text>1</text></inputEntry>
        <inputEntry id="InputEntry_P3_2_BILL_MODIFIER_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P3_3_BILL_MODIFIER_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P3_4_BILL_MODIFIER_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P3_5_BILL_MODIFIER_002"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_P3_1_BILL_MODIFIER_002"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P3_2_BILL_MODIFIER_002"><text>"Procedimento unico. Modificador multiplo nao aplicavel."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P3_3_BILL_MODIFIER_002"><text>"Faturar normalmente."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_3_4_BILL_MODIFIER_002"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_3_5_BILL_MODIFIER_002"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_BILL_MODIFIER_002">
        <description>Caso padrao - revisar manualmente</description>
        <inputEntry id="InputEntry_F_1_BILL_MODIFIER_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_BILL_MODIFIER_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_BILL_MODIFIER_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_BILL_MODIFIER_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_BILL_MODIFIER_002"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_BILL_MODIFIER_002"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_BILL_MODIFIER_002"><text>"Dados insuficientes para validar modificador multiplo."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_BILL_MODIFIER_002"><text>"Verificar ordenacao, especialidades e equipes."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_4_BILL_MODIFIER_002"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_5_BILL_MODIFIER_002"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BILL_MODIFIER_002">
      <dmndi:DMNShape id="DMNShape_Decision_BILL_MODIFIER_002" dmnElementRef="Decision_BILL_MODIFIER_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>