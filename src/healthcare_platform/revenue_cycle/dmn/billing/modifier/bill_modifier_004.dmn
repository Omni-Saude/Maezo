<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  BILL-MODIFIER-004 - Professional Technical Component Validation
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: BILL-MODIFIER
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_BILL_MODIFIER_004" name="Professional Technical Component Validation" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_BILL_MODIFIER_004" name="[SP-RC-006 | billing/modifier] Validar Componente Profissional Tecnico" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_BILL_MODIFIER_004" hitPolicy="FIRST">

      <input id="Input_1_BILL_MODIFIER_004" label="Tipo Componente Cobrado">
        <inputExpression id="InputExpression_1_BILL_MODIFIER_004" typeRef="string">
          <text>tipoComponenteCobrado</text>
        </inputExpression>
        <inputValues><text>"global", "tecnico", "profissional"</text></inputValues>
      </input>

      <input id="Input_2_BILL_MODIFIER_004" label="Medico Vinculo Hospital">
        <inputExpression id="InputExpression_2_BILL_MODIFIER_004" typeRef="string">
          <text>medicoVinculoHospital</text>
        </inputExpression>
        <inputValues><text>"empregado", "cooperado", "credenciado", "autonomo"</text></inputValues>
      </input>

      <input id="Input_3_BILL_MODIFIER_004" label="Equipamento Hospital">
        <inputExpression id="InputExpression_3_BILL_MODIFIER_004" typeRef="boolean">
          <text>equipamentoHospital</text>
        </inputExpression>
      </input>

      <input id="Input_4_BILL_MODIFIER_004" label="Laudo Emitido Hospital">
        <inputExpression id="InputExpression_4_BILL_MODIFIER_004" typeRef="boolean">
          <text>laudoEmitidoHospital</text>
        </inputExpression>
      </input>

      <input id="Input_5_BILL_MODIFIER_004" label="Contrato Permite Global">
        <inputExpression id="InputExpression_5_BILL_MODIFIER_004" typeRef="boolean">
          <text>contratoPermiteGlobal</text>
        </inputExpression>
      </input>

      <output id="Output_1_BILL_MODIFIER_004" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>
      <output id="Output_2_BILL_MODIFIER_004" label="Observacao" name="observacao" typeRef="string" />
      <output id="Output_3_BILL_MODIFIER_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string" />

      
      <output id="Output_4_BILL_MODIFIER_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string"><outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues></output><output id="Output_5_BILL_MODIFIER_004" label="Risco Denial" name="riscoDenial" typeRef="string"><outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues></output><rule id="Rule_Block_1_BILL_MODIFIER_004">
        <description>Bloquear global sem permissao contratual</description>
        <inputEntry id="InputEntry_B1_1_BILL_MODIFIER_004"><text>"global"</text></inputEntry>
        <inputEntry id="InputEntry_B1_2_BILL_MODIFIER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_3_BILL_MODIFIER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_4_BILL_MODIFIER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B1_5_BILL_MODIFIER_004"><text>false</text></inputEntry>
        
      <outputEntry id="OutputEntry_B1_1_BILL_MODIFIER_004"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_2_BILL_MODIFIER_004"><text>"Cobranca global sem permissao contratual. Operadora pagara apenas tecnico."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B1_3_BILL_MODIFIER_004"><text>"Separar em tecnico (hospital) e profissional (medico) ou renegociar contrato."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_1_4_BILL_MODIFIER_004"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_1_5_BILL_MODIFIER_004"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Block_2_BILL_MODIFIER_004">
        <description>Bloquear tecnico sem equipamento proprio</description>
        <inputEntry id="InputEntry_B2_1_BILL_MODIFIER_004"><text>"tecnico"</text></inputEntry>
        <inputEntry id="InputEntry_B2_2_BILL_MODIFIER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_3_BILL_MODIFIER_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_B2_4_BILL_MODIFIER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_B2_5_BILL_MODIFIER_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_B2_1_BILL_MODIFIER_004"><text>"Bloquear"</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_2_BILL_MODIFIER_004"><text>"Cobranca de componente tecnico sem equipamento hospitalar."</text></outputEntry>
        
      <outputEntry id="OutputEntry_B2_3_BILL_MODIFIER_004"><text>"Verificar propriedade do equipamento ou ajustar componente."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Block_2_4_BILL_MODIFIER_004"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Block_2_5_BILL_MODIFIER_004"><text>"ALTO"</text></outputEntry></rule>

      
      <rule id="Rule_Alert_1_BILL_MODIFIER_004">
        <description>Alertar profissional separado quando medico empregado</description>
        <inputEntry id="InputEntry_A1_1_BILL_MODIFIER_004"><text>"profissional"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_BILL_MODIFIER_004"><text>"empregado"</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_BILL_MODIFIER_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_BILL_MODIFIER_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_BILL_MODIFIER_004"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_A1_1_BILL_MODIFIER_004"><text>"Alertar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_2_BILL_MODIFIER_004"><text>"Medico empregado com profissional separado. Contrato permite global."</text></outputEntry>
        
      <outputEntry id="OutputEntry_A1_3_BILL_MODIFIER_004"><text>"Avaliar se global e mais vantajoso para o hospital."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Alert_1_4_BILL_MODIFIER_004"><text>"VALOR"</text></outputEntry>
      <outputEntry id="OutputEntry_Alert_1_5_BILL_MODIFIER_004"><text>"MEDIO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_1_BILL_MODIFIER_004">
        <description>Prosseguir global com medico empregado</description>
        <inputEntry id="InputEntry_P1_1_BILL_MODIFIER_004"><text>"global"</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_BILL_MODIFIER_004"><text>"empregado"</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_BILL_MODIFIER_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_BILL_MODIFIER_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P1_5_BILL_MODIFIER_004"><text>true</text></inputEntry>
        
      <outputEntry id="OutputEntry_P1_1_BILL_MODIFIER_004"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_2_BILL_MODIFIER_004"><text>"Cobranca global correta: medico empregado, equipamento e laudo hospitalares."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P1_3_BILL_MODIFIER_004"><text>"Faturar valor global. Toda receita fica com hospital."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_1_4_BILL_MODIFIER_004"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_1_5_BILL_MODIFIER_004"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_2_BILL_MODIFIER_004">
        <description>Prosseguir tecnico com equipamento hospital</description>
        <inputEntry id="InputEntry_P2_1_BILL_MODIFIER_004"><text>"tecnico"</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_BILL_MODIFIER_004"><text>"credenciado", "autonomo"</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_BILL_MODIFIER_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_BILL_MODIFIER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P2_5_BILL_MODIFIER_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_P2_1_BILL_MODIFIER_004"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_2_BILL_MODIFIER_004"><text>"Componente tecnico correto: medico externo usa equipamento hospital."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P2_3_BILL_MODIFIER_004"><text>"Faturar tecnico. Medico fatura profissional separado."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_2_4_BILL_MODIFIER_004"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_2_5_BILL_MODIFIER_004"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Proceed_3_BILL_MODIFIER_004">
        <description>Prosseguir apenas profissional</description>
        <inputEntry id="InputEntry_P3_1_BILL_MODIFIER_004"><text>"profissional"</text></inputEntry>
        <inputEntry id="InputEntry_P3_2_BILL_MODIFIER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_P3_3_BILL_MODIFIER_004"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_P3_4_BILL_MODIFIER_004"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_P3_5_BILL_MODIFIER_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_P3_1_BILL_MODIFIER_004"><text>"Prosseguir"</text></outputEntry>
        
      <outputEntry id="OutputEntry_P3_2_BILL_MODIFIER_004"><text>"Apenas laudo/interpretacao. Componente profissional adequado."</text></outputEntry>
        
      <outputEntry id="OutputEntry_P3_3_BILL_MODIFIER_004"><text>"Faturar profissional. Tecnico com terceiro."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Proceed_3_4_BILL_MODIFIER_004"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Proceed_3_5_BILL_MODIFIER_004"><text>"BAIXO"</text></outputEntry></rule>

      
      <rule id="Rule_Fallback_BILL_MODIFIER_004">
        <description>Caso padrao - revisar manualmente</description>
        <inputEntry id="InputEntry_F_1_BILL_MODIFIER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_BILL_MODIFIER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_BILL_MODIFIER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_BILL_MODIFIER_004"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_BILL_MODIFIER_004"><text>-</text></inputEntry>
        
      <outputEntry id="OutputEntry_F_1_BILL_MODIFIER_004"><text>"Revisar"</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_2_BILL_MODIFIER_004"><text>"Dados insuficientes para validar componente."</text></outputEntry>
        
      <outputEntry id="OutputEntry_F_3_BILL_MODIFIER_004"><text>"Verificar vinculo medico, equipamento e contrato."</text></outputEntry>
      
      <outputEntry id="OutputEntry_Fallback_4_BILL_MODIFIER_004"><text>"NENHUM"</text></outputEntry>
      <outputEntry id="OutputEntry_Fallback_5_BILL_MODIFIER_004"><text>"MEDIO"</text></outputEntry></rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BILL_MODIFIER_004">
      <dmndi:DMNShape id="DMNShape_Decision_BILL_MODIFIER_004" dmnElementRef="Decision_BILL_MODIFIER_004">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>