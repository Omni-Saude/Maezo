<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_DISCOUNT_APPLICABILITY"
             name="Discount Applicability Rules"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Discount Applicability Rules
       Archetype: ADMIN_ADJUDICATION
       Outputs: resultado, acao, risco
       Hit Policy: FIRST
       Worker: apply_discounts_worker.py
  -->

  <decision id="Decision_DISCOUNT_APPLICABILITY" name="[SP-RC-006 | billing/discounts] Discount Applicability Rules" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_DISCOUNT_APPLICABILITY" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_DISCOUNT_PCT_DISCOUNT_APPLICABILITY" label="Discount Percentage">
        <inputExpression id="InputExpr_DISCOUNT_PCT_DISCOUNT_APPLICABILITY" typeRef="number">
          <text>discountPercentage</text>
        </inputExpression>
      </input>

      <input id="Input_QUANTITY_DISCOUNT_APPLICABILITY" label="Quantity">
        <inputExpression id="InputExpr_QUANTITY_DISCOUNT_APPLICABILITY" typeRef="number">
          <text>quantity</text>
        </inputExpression>
      </input>

      <input id="Input_MIN_QUANTITY_DISCOUNT_APPLICABILITY" label="Minimum Quantity">
        <inputExpression id="InputExpr_MIN_QUANTITY_DISCOUNT_APPLICABILITY" typeRef="number">
          <text>minQuantity</text>
        </inputExpression>
      </input>

      <input id="Input_MIN_AMOUNT_DISCOUNT_APPLICABILITY" label="Minimum Amount">
        <inputExpression id="InputExpr_MIN_AMOUNT_DISCOUNT_APPLICABILITY" typeRef="number">
          <text>minAmount</text>
        </inputExpression>
      </input>

      <input id="Input_TOTAL_AMOUNT_DISCOUNT_APPLICABILITY" label="Total Amount">
        <inputExpression id="InputExpr_TOTAL_AMOUNT_DISCOUNT_APPLICABILITY" typeRef="number">
          <text>totalAmount</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado_DISCOUNT_APPLICABILITY" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_DISCOUNT_APPLICABILITY" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_DISCOUNT_APPLICABILITY" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Invalid discount percentage -->
      <rule id="Rule_DISCOUNT_INVALID_DISCOUNT_APPLICABILITY">
        <description>Rejeitar percentual de desconto invalido</description>
        <inputEntry id="IE_DISCOUNT_INVALID_1_DISCOUNT_APPLICABILITY"><text>&lt; 0 or &gt; 100</text></inputEntry>
        <inputEntry id="IE_DISCOUNT_INVALID_2_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_DISCOUNT_INVALID_3_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_DISCOUNT_INVALID_4_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_DISCOUNT_INVALID_5_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <outputEntry id="OE_DISCOUNT_INVALID_res_DISCOUNT_APPLICABILITY"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_DISCOUNT_INVALID_acao_DISCOUNT_APPLICABILITY"><text>"Rejeitar percentual de desconto invalido"</text></outputEntry>
        <outputEntry id="OE_DISCOUNT_INVALID_risco_DISCOUNT_APPLICABILITY"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Volume bonus >= 100 -->
      <rule id="Rule_VOLUME_BONUS_100_DISCOUNT_APPLICABILITY">
        <description>Aplicar bonus de volume 50%</description>
        <inputEntry id="IE_VOLUME_BONUS_100_1_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_100_2_DISCOUNT_APPLICABILITY"><text>&gt;= 100</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_100_3_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_100_4_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_100_5_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <outputEntry id="OE_VOLUME_BONUS_100_res_DISCOUNT_APPLICABILITY"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_VOLUME_BONUS_100_acao_DISCOUNT_APPLICABILITY"><text>"Aplicar bonus de volume 50%"</text></outputEntry>
        <outputEntry id="OE_VOLUME_BONUS_100_risco_DISCOUNT_APPLICABILITY"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Volume bonus >= 50 -->
      <rule id="Rule_VOLUME_BONUS_50_DISCOUNT_APPLICABILITY">
        <description>Aplicar bonus de volume 30%</description>
        <inputEntry id="IE_VOLUME_BONUS_50_1_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_50_2_DISCOUNT_APPLICABILITY"><text>&gt;= 50</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_50_3_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_50_4_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_50_5_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <outputEntry id="OE_VOLUME_BONUS_50_res_DISCOUNT_APPLICABILITY"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_VOLUME_BONUS_50_acao_DISCOUNT_APPLICABILITY"><text>"Aplicar bonus de volume 30%"</text></outputEntry>
        <outputEntry id="OE_VOLUME_BONUS_50_risco_DISCOUNT_APPLICABILITY"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Volume bonus >= 20 -->
      <rule id="Rule_VOLUME_BONUS_20_DISCOUNT_APPLICABILITY">
        <description>Aplicar bonus de volume 15%</description>
        <inputEntry id="IE_VOLUME_BONUS_20_1_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_20_2_DISCOUNT_APPLICABILITY"><text>&gt;= 20</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_20_3_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_20_4_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_VOLUME_BONUS_20_5_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <outputEntry id="OE_VOLUME_BONUS_20_res_DISCOUNT_APPLICABILITY"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_VOLUME_BONUS_20_acao_DISCOUNT_APPLICABILITY"><text>"Aplicar bonus de volume 15%"</text></outputEntry>
        <outputEntry id="OE_VOLUME_BONUS_20_risco_DISCOUNT_APPLICABILITY"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Below minimum quantity -->
      <rule id="Rule_MIN_QUANTITY_NOT_MET_DISCOUNT_APPLICABILITY">
        <description>Quantidade minima nao atingida - pular desconto</description>
        <inputEntry id="IE_MIN_QUANTITY_NOT_MET_1_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_MIN_QUANTITY_NOT_MET_2_DISCOUNT_APPLICABILITY"><text>&lt; minQuantity</text></inputEntry>
        <inputEntry id="IE_MIN_QUANTITY_NOT_MET_3_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_MIN_QUANTITY_NOT_MET_4_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_MIN_QUANTITY_NOT_MET_5_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <outputEntry id="OE_MIN_QUANTITY_NOT_MET_res_DISCOUNT_APPLICABILITY"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_MIN_QUANTITY_NOT_MET_acao_DISCOUNT_APPLICABILITY"><text>"Quantidade minima nao atingida - pular desconto"</text></outputEntry>
        <outputEntry id="OE_MIN_QUANTITY_NOT_MET_risco_DISCOUNT_APPLICABILITY"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 6: Below minimum amount -->
      <rule id="Rule_MIN_AMOUNT_NOT_MET_DISCOUNT_APPLICABILITY">
        <description>Valor minimo nao atingido - pular desconto</description>
        <inputEntry id="IE_MIN_AMOUNT_NOT_MET_1_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_MIN_AMOUNT_NOT_MET_2_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_MIN_AMOUNT_NOT_MET_3_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_MIN_AMOUNT_NOT_MET_4_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_MIN_AMOUNT_NOT_MET_5_DISCOUNT_APPLICABILITY"><text>&lt; minAmount</text></inputEntry>
        <outputEntry id="OE_MIN_AMOUNT_NOT_MET_res_DISCOUNT_APPLICABILITY"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_MIN_AMOUNT_NOT_MET_acao_DISCOUNT_APPLICABILITY"><text>"Valor minimo nao atingido - pular desconto"</text></outputEntry>
        <outputEntry id="OE_MIN_AMOUNT_NOT_MET_risco_DISCOUNT_APPLICABILITY"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 7: Discount >= 100% requires review -->
      <rule id="Rule_DISCOUNT_FULL_DISCOUNT_APPLICABILITY">
        <description>Desconto >= 100% requer revisao manual</description>
        <inputEntry id="IE_DISCOUNT_FULL_1_DISCOUNT_APPLICABILITY"><text>&gt;= 100</text></inputEntry>
        <inputEntry id="IE_DISCOUNT_FULL_2_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_DISCOUNT_FULL_3_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_DISCOUNT_FULL_4_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_DISCOUNT_FULL_5_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <outputEntry id="OE_DISCOUNT_FULL_res_DISCOUNT_APPLICABILITY"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_DISCOUNT_FULL_acao_DISCOUNT_APPLICABILITY"><text>"Desconto >= 100% requer revisao manual"</text></outputEntry>
        <outputEntry id="OE_DISCOUNT_FULL_risco_DISCOUNT_APPLICABILITY"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 8: Fallback - apply base discount -->
      <rule id="Rule_FALLBACK_DISCOUNT_APPLICABILITY">
        <description>Aplicar desconto base</description>
        <inputEntry id="IE_FALLBACK_1_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_2_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_3_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_4_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <inputEntry id="IE_FALLBACK_5_DISCOUNT_APPLICABILITY"><text>-</text></inputEntry>
        <outputEntry id="OE_FALLBACK_res_DISCOUNT_APPLICABILITY"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_FALLBACK_acao_DISCOUNT_APPLICABILITY"><text>"Aplicar desconto base"</text></outputEntry>
        <outputEntry id="OE_FALLBACK_risco_DISCOUNT_APPLICABILITY"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_DISCOUNT_APPLICABILITY">
      <dmndi:DMNShape id="DMNShape_Decision_DISCOUNT_APPLICABILITY" dmnElementRef="Decision_DISCOUNT_APPLICABILITY">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
