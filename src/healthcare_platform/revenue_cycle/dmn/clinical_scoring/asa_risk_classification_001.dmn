<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             id="Definitions_asa_risk_classification_001"
             name="ASA Physical Status Classification"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="asa_risk_classification_001" name="[SP-RC-003 | clinical_scoring] ASA Physical Status Classification" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_asa_risk_classification_001" hitPolicy="UNIQUE">
      <input id="input1_asa_risk_classification_001" label="ASA Class">
        <inputExpression typeRef="string">
          <text>asa_class</text>
        </inputExpression>
      </input>
      <output id="output1_asa_risk_classification_001" label="Description" name="description" typeRef="string"/>
      <output id="output2_asa_risk_classification_001" label="Risk Category" name="risk_category" typeRef="string"/>
      <output id="output3_asa_risk_classification_001" label="Mortality Risk" name="mortality_risk" typeRef="string"/>
      <output id="output4_asa_risk_classification_001" label="Special Considerations" name="special_considerations" typeRef="string"/>

      <!-- ASA I -->
      <rule id="rule1_asa_risk_classification_001">
        <inputEntry><text>"1"</text></inputEntry>
        <outputEntry><text>"Normal healthy patient"</text></outputEntry>
        <outputEntry><text>"minimal"</text></outputEntry>
        <outputEntry><text>"0.05-0.1%"</text></outputEntry>
        <outputEntry><text>"Standard perioperative care"</text></outputEntry>
      </rule>

      <!-- ASA II -->
      <rule id="rule2_asa_risk_classification_001">
        <inputEntry><text>"2"</text></inputEntry>
        <outputEntry><text>"Patient with mild systemic disease"</text></outputEntry>
        <outputEntry><text>"low"</text></outputEntry>
        <outputEntry><text>"0.2-0.5%"</text></outputEntry>
        <outputEntry><text>"Monitor chronic conditions, adjust medications as needed"</text></outputEntry>
      </rule>

      <!-- ASA III -->
      <rule id="rule3_asa_risk_classification_001">
        <inputEntry><text>"3"</text></inputEntry>
        <outputEntry><text>"Patient with severe systemic disease"</text></outputEntry>
        <outputEntry><text>"moderate"</text></outputEntry>
        <outputEntry><text>"1.8-4.3%"</text></outputEntry>
        <outputEntry><text>"Enhanced monitoring, optimize medical management preoperatively"</text></outputEntry>
      </rule>

      <!-- ASA IV -->
      <rule id="rule4_asa_risk_classification_001">
        <inputEntry><text>"4"</text></inputEntry>
        <outputEntry><text>"Patient with severe systemic disease that is a constant threat to life"</text></outputEntry>
        <outputEntry><text>"high"</text></outputEntry>
        <outputEntry><text>"7.8-23%"</text></outputEntry>
        <outputEntry><text>"ICU-level monitoring, specialized anesthesia team, consider risks vs benefits"</text></outputEntry>
      </rule>

      <!-- ASA V -->
      <rule id="rule5_asa_risk_classification_001">
        <inputEntry><text>"5"</text></inputEntry>
        <outputEntry><text>"Moribund patient not expected to survive without operation"</text></outputEntry>
        <outputEntry><text>"critical"</text></outputEntry>
        <outputEntry><text>"9.4-50%"</text></outputEntry>
        <outputEntry><text>"Emergency protocol, highest level of monitoring, inform family of risks"</text></outputEntry>
      </rule>

      <!-- ASA VI -->
      <rule id="rule6_asa_risk_classification_001">
        <inputEntry><text>"6"</text></inputEntry>
        <outputEntry><text>"Declared brain-dead patient for organ donation"</text></outputEntry>
        <outputEntry><text>"organ_donation"</text></outputEntry>
        <outputEntry><text>"N/A"</text></outputEntry>
        <outputEntry><text>"Organ preservation protocol, coordinate with transplant team"</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_asa_risk_classification_001">
      <dmndi:DMNShape id="DMNShape_asa_risk_classification_001" dmnElementRef="asa_risk_classification_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
