<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             id="Definitions_severity_priority_001"
             name="Severity-Based Priority Assignment"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="severity_priority_001" name="[SP-RC-003 | clinical_safety] Severity-Based Priority Assignment" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_severity_priority_001" hitPolicy="UNIQUE">
      <input id="input1_severity_priority_001" label="Severity">
        <inputExpression typeRef="string">
          <text>severity</text>
        </inputExpression>
      </input>
      <output id="output1_severity_priority_001" label="Priority Number" name="priority_number" typeRef="integer"/>
      <output id="output2_severity_priority_001" label="Queue Position" name="queue_position" typeRef="string"/>
      <output id="output3_severity_priority_001" label="Escalation Required" name="escalation_required" typeRef="boolean"/>

      <!-- Critical severity gets highest priority -->
      <rule id="rule1_severity_priority_001">
        <inputEntry><text>"critical"</text></inputEntry>
        <outputEntry><text>1</text></outputEntry>
        <outputEntry><text>"front"</text></outputEntry>
        <outputEntry><text>true</text></outputEntry>
      </rule>

      <!-- High severity gets second priority -->
      <rule id="rule2_severity_priority_001">
        <inputEntry><text>"high"</text></inputEntry>
        <outputEntry><text>2</text></outputEntry>
        <outputEntry><text>"high_priority"</text></outputEntry>
        <outputEntry><text>false</text></outputEntry>
      </rule>

      <!-- Medium severity gets third priority -->
      <rule id="rule3_severity_priority_001">
        <inputEntry><text>"medium"</text></inputEntry>
        <outputEntry><text>3</text></outputEntry>
        <outputEntry><text>"standard"</text></outputEntry>
        <outputEntry><text>false</text></outputEntry>
      </rule>

      <!-- Low severity gets lowest priority -->
      <rule id="rule4_severity_priority_001">
        <inputEntry><text>"low"</text></inputEntry>
        <outputEntry><text>4</text></outputEntry>
        <outputEntry><text>"back"</text></outputEntry>
        <outputEntry><text>false</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_severity_priority_001">
      <dmndi:DMNShape id="DMNShape_severity_priority_001" dmnElementRef="severity_priority_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
