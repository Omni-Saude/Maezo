<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             id="Definitions_alert_routing_rules_001"
             name="Clinical Alert Routing Rules"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="alert_routing_rules_001" name="[SP-RC-003 | clinical_safety] Clinical Alert Routing Rules" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_alert_routing_rules_001" hitPolicy="COLLECT">
      <input id="input1_alert_routing_rules_001" label="Alert Type">
        <inputExpression typeRef="string">
          <text>alert_type</text>
        </inputExpression>
      </input>
      <input id="input2_alert_routing_rules_001" label="Alert Severity">
        <inputExpression typeRef="string">
          <text>severity</text>
        </inputExpression>
      </input>
      <input id="input3_alert_routing_rules_001" label="Department">
        <inputExpression typeRef="string">
          <text>department</text>
        </inputExpression>
      </input>
      <output id="output1_alert_routing_rules_001" label="Notification Target" name="notification_target" typeRef="string"/>
      <output id="output2_alert_routing_rules_001" label="Channel" name="channel" typeRef="string"/>
      <output id="output3_alert_routing_rules_001" label="Response SLA (minutes)" name="response_sla" typeRef="integer"/>

      <!-- Critical lab alerts -->
      <rule id="rule1_alert_routing_rules_001">
        <inputEntry><text>"critical_lab"</text></inputEntry>
        <inputEntry><text>"critical"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"attending_physician"</text></outputEntry>
        <outputEntry><text>"phone_call"</text></outputEntry>
        <outputEntry><text>5</text></outputEntry>
      </rule>
      <rule id="rule2_alert_routing_rules_001">
        <inputEntry><text>"critical_lab"</text></inputEntry>
        <inputEntry><text>"critical"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"primary_nurse"</text></outputEntry>
        <outputEntry><text>"sms"</text></outputEntry>
        <outputEntry><text>5</text></outputEntry>
      </rule>

      <!-- Vital sign alerts -->
      <rule id="rule3_alert_routing_rules_001">
        <inputEntry><text>"vital_sign"</text></inputEntry>
        <inputEntry><text>"critical", "high"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"bedside_nurse"</text></outputEntry>
        <outputEntry><text>"ehr_alert"</text></outputEntry>
        <outputEntry><text>3</text></outputEntry>
      </rule>
      <rule id="rule4_alert_routing_rules_001">
        <inputEntry><text>"vital_sign"</text></inputEntry>
        <inputEntry><text>"critical"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"rapid_response_team"</text></outputEntry>
        <outputEntry><text>"pager"</text></outputEntry>
        <outputEntry><text>5</text></outputEntry>
      </rule>

      <!-- Medication alerts -->
      <rule id="rule5_alert_routing_rules_001">
        <inputEntry><text>"medication"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"pharmacist"</text></outputEntry>
        <outputEntry><text>"ehr_notification"</text></outputEntry>
        <outputEntry><text>15</text></outputEntry>
      </rule>
      <rule id="rule6_alert_routing_rules_001">
        <inputEntry><text>"medication"</text></inputEntry>
        <inputEntry><text>"critical", "high"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"prescribing_provider"</text></outputEntry>
        <outputEntry><text>"sms"</text></outputEntry>
        <outputEntry><text>10</text></outputEntry>
      </rule>

      <!-- Allergy alerts -->
      <rule id="rule7_alert_routing_rules_001">
        <inputEntry><text>"allergy"</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>-</text></inputEntry>
        <outputEntry><text>"care_team"</text></outputEntry>
        <outputEntry><text>"broadcast"</text></outputEntry>
        <outputEntry><text>5</text></outputEntry>
      </rule>

      <!-- Department-specific routing -->
      <rule id="rule8_alert_routing_rules_001">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"critical"</text></inputEntry>
        <inputEntry><text>"icu"</text></inputEntry>
        <outputEntry><text>"intensivist"</text></outputEntry>
        <outputEntry><text>"phone_call"</text></outputEntry>
        <outputEntry><text>3</text></outputEntry>
      </rule>
      <rule id="rule9_alert_routing_rules_001">
        <inputEntry><text>-</text></inputEntry>
        <inputEntry><text>"critical"</text></inputEntry>
        <inputEntry><text>"emergency"</text></inputEntry>
        <outputEntry><text>"ed_physician"</text></outputEntry>
        <outputEntry><text>"phone_call"</text></outputEntry>
        <outputEntry><text>3</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_alert_routing_rules_001">
      <dmndi:DMNShape id="DMNShape_alert_routing_rules_001" dmnElementRef="alert_routing_rules_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
