<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             id="Definitions_sbar_validation_001"
             name="SBAR Communication Validation"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="sbar_validation_001" name="[SP-RC-003 | clinical_safety] SBAR Communication Validation" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_sbar_validation_001" hitPolicy="COLLECT">
      <input id="input1_sbar_validation_001" label="SBAR Field">
        <inputExpression typeRef="string">
          <text>sbar_field</text>
        </inputExpression>
      </input>
      <output id="output1_sbar_validation_001" label="Is Required" name="is_required" typeRef="boolean"/>
      <output id="output2_sbar_validation_001" label="Field Description" name="field_description" typeRef="string"/>
      <output id="output3_sbar_validation_001" label="Validation Rule" name="validation_rule" typeRef="string"/>
      <output id="output4_sbar_validation_001" label="Min Length" name="min_length" typeRef="integer"/>

      <!-- Situation field -->
      <rule id="rule1_sbar_validation_001">
        <inputEntry><text>"situation"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"Current patient condition and reason for communication"</text></outputEntry>
        <outputEntry><text>"not_empty_and_descriptive"</text></outputEntry>
        <outputEntry><text>20</text></outputEntry>
      </rule>

      <!-- Background field -->
      <rule id="rule2_sbar_validation_001">
        <inputEntry><text>"background"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"Relevant medical history and context"</text></outputEntry>
        <outputEntry><text>"not_empty_and_descriptive"</text></outputEntry>
        <outputEntry><text>30</text></outputEntry>
      </rule>

      <!-- Assessment field -->
      <rule id="rule3_sbar_validation_001">
        <inputEntry><text>"assessment"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"Clinical assessment and analysis of situation"</text></outputEntry>
        <outputEntry><text>"not_empty_and_descriptive"</text></outputEntry>
        <outputEntry><text>25</text></outputEntry>
      </rule>

      <!-- Recommendation field -->
      <rule id="rule4_sbar_validation_001">
        <inputEntry><text>"recommendation"</text></inputEntry>
        <outputEntry><text>true</text></outputEntry>
        <outputEntry><text>"Suggested actions or interventions needed"</text></outputEntry>
        <outputEntry><text>"not_empty_and_actionable"</text></outputEntry>
        <outputEntry><text>20</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_sbar_validation_001">
      <dmndi:DMNShape id="DMNShape_sbar_validation_001" dmnElementRef="sbar_validation_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
