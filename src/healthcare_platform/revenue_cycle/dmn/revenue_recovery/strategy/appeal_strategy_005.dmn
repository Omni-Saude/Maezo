<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  APPEAL-STRATEGY-005 - Escalacao Juridica (Glosa Abusiva)
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: APPEAL-STRATEGY
  Perspectiva: HOSPITAL (Receivables - Appeals Management)

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Lei 9.656/1998 (planos de saude)
  - RN ANS 395/2016 (recursos de glosa)
  - CPC 25 (provisoes)
  - IFRS 15 (reconhecimento de receita)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_APPEAL_STRATEGY_005"
             name="Escalacao Juridica (Glosa Abusiva)"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_APPEAL_STRATEGY_005" name="[SP-RC-010 | revenue_recovery/strategy] Escalacao Juridica (Glosa Abusiva)" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_APPEAL_STRATEGY_005" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_APPEAL_STRATEGY_005" label="Glosa Abusiva">
        <inputExpression id="InputExpression_1_APPEAL_STRATEGY_005" typeRef="boolean">
          <text>glosaAbusiva</text>
        </inputExpression>
      </input>


      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_APPEAL_STRATEGY_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_APPEAL_STRATEGY_005" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_APPEAL_STRATEGY_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_APPEAL_STRATEGY_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_APPEAL_STRATEGY_005" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA A11: Alertar -->
      <rule id="Rule_A1_1_APPEAL_STRATEGY_005">
        <description>Glosa caracterizada como abusiva.</description>
        <inputEntry id="InputEntry_A11_1_APPEAL_STRATEGY_005"><text>glosaAbusiva</text></inputEntry>
        <outputEntry id="OutputEntry_A11_1_APPEAL_STRATEGY_005"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A11_2_APPEAL_STRATEGY_005"><text>"Glosa caracterizada como abusiva."</text></outputEntry>
        <outputEntry id="OutputEntry_A11_3_APPEAL_STRATEGY_005"><text>"Escalar para departamento juridico. Avaliar via judicial."</text></outputEntry>
        <outputEntry id="OutputEntry_A11_4_APPEAL_STRATEGY_005"><text>"CONTRATO"</text></outputEntry>
        <outputEntry id="OutputEntry_A11_5_APPEAL_STRATEGY_005"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA P12: Prosseguir -->
      <rule id="Rule_P1_2_APPEAL_STRATEGY_005">
        <description>Glosa dentro de parametros normais.</description>
        <inputEntry id="InputEntry_P12_1_APPEAL_STRATEGY_005"><text>not glosaAbusiva</text></inputEntry>
        <outputEntry id="OutputEntry_P12_1_APPEAL_STRATEGY_005"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P12_2_APPEAL_STRATEGY_005"><text>"Glosa dentro de parametros normais."</text></outputEntry>
        <outputEntry id="OutputEntry_P12_3_APPEAL_STRATEGY_005"><text>"Prosseguir com recurso administrativo padrao."</text></outputEntry>
        <outputEntry id="OutputEntry_P12_4_APPEAL_STRATEGY_005"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P12_5_APPEAL_STRATEGY_005"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisao manual -->
      <rule id="Rule_Fallback_APPEAL_STRATEGY_005">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_APPEAL_STRATEGY_005"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_APPEAL_STRATEGY_005"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_APPEAL_STRATEGY_005"><text>"Situacao requer analise manual por nao corresponder a nenhum criterio automatico."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_APPEAL_STRATEGY_005"><text>"Encaminhar para auditoria administrativa para avaliacao caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_APPEAL_STRATEGY_005"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_APPEAL_STRATEGY_005"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_APPEAL_STRATEGY_005">
      <dmndi:DMNShape id="DMNShape_Decision_APPEAL_STRATEGY_005" dmnElementRef="Decision_APPEAL_STRATEGY_005">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
