<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  APPEAL-STRATEGY-002 - Argumentacao Baseada em DUT/ANS
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: APPEAL-STRATEGY
  Perspectiva: HOSPITAL (Receivables - Appeals Management)

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Lei 9.656/1998 (planos de saude)
  - RN ANS 395/2016 (recursos de glosa)
  - CPC 25 (provisoes)
  - IFRS 15 (reconhecimento de receita)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_APPEAL_STRATEGY_002"
             name="Argumentacao Baseada em DUT/ANS"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_APPEAL_STRATEGY_002" name="[SP-RC-010 | revenue_recovery/strategy] Argumentacao Baseada em DUT/ANS" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_APPEAL_STRATEGY_002" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_APPEAL_STRATEGY_002" label="Tem Fundamentacao ANS">
        <inputExpression id="InputExpression_1_APPEAL_STRATEGY_002" typeRef="boolean">
          <text>temFundamentacaoANS</text>
        </inputExpression>
      </input>


      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_APPEAL_STRATEGY_002" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_APPEAL_STRATEGY_002" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_APPEAL_STRATEGY_002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_APPEAL_STRATEGY_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_APPEAL_STRATEGY_002" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA B11: Bloquear -->
      <rule id="Rule_B1_1_APPEAL_STRATEGY_002">
        <description>Sem fundamentacao DUT/ANS adequada.</description>
        <inputEntry id="InputEntry_B11_1_APPEAL_STRATEGY_002"><text>not temFundamentacaoANS</text></inputEntry>
        <outputEntry id="OutputEntry_B11_1_APPEAL_STRATEGY_002"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B11_2_APPEAL_STRATEGY_002"><text>"Sem fundamentacao DUT/ANS adequada."</text></outputEntry>
        <outputEntry id="OutputEntry_B11_3_APPEAL_STRATEGY_002"><text>"Buscar pareceres tecnicos ou aceitar glosa."</text></outputEntry>
        <outputEntry id="OutputEntry_B11_4_APPEAL_STRATEGY_002"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_B11_5_APPEAL_STRATEGY_002"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA P12: Prosseguir -->
      <rule id="Rule_P1_2_APPEAL_STRATEGY_002">
        <description>Fundamentacao ANS presente.</description>
        <inputEntry id="InputEntry_P12_1_APPEAL_STRATEGY_002"><text>temFundamentacaoANS</text></inputEntry>
        <outputEntry id="OutputEntry_P12_1_APPEAL_STRATEGY_002"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P12_2_APPEAL_STRATEGY_002"><text>"Fundamentacao ANS presente."</text></outputEntry>
        <outputEntry id="OutputEntry_P12_3_APPEAL_STRATEGY_002"><text>"Estruturar recurso baseado em DUT e normativas."</text></outputEntry>
        <outputEntry id="OutputEntry_P12_4_APPEAL_STRATEGY_002"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P12_5_APPEAL_STRATEGY_002"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisao manual -->
      <rule id="Rule_Fallback_APPEAL_STRATEGY_002">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_APPEAL_STRATEGY_002"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_APPEAL_STRATEGY_002"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_APPEAL_STRATEGY_002"><text>"Situacao requer analise manual por nao corresponder a nenhum criterio automatico."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_APPEAL_STRATEGY_002"><text>"Encaminhar para auditoria administrativa para avaliacao caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_APPEAL_STRATEGY_002"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_APPEAL_STRATEGY_002"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_APPEAL_STRATEGY_002">
      <dmndi:DMNShape id="DMNShape_Decision_APPEAL_STRATEGY_002" dmnElementRef="Decision_APPEAL_STRATEGY_002">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
