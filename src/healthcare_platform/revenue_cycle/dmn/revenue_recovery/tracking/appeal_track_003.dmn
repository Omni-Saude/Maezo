<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  APPEAL-TRACK-003 - Alerta Recurso sem Resposta (30 dias)
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: APPEAL-TRACK
  Perspectiva: HOSPITAL (Receivables - Appeals Management)

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Lei 9.656/1998 (planos de saude)
  - RN ANS 395/2016 (recursos de glosa)
  - CPC 25 (provisoes)
  - IFRS 15 (reconhecimento de receita)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_APPEAL_TRACK_003"
             name="Alerta Recurso sem Resposta (30 dias)"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: appeal_track_003_worker.py -->

  <decision id="Decision_APPEAL_TRACK_003" name="[SP-RC-010 | revenue_recovery/tracking] Alerta Recurso sem Resposta (30 dias)" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_APPEAL_TRACK_003" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_APPEAL_TRACK_003" label="Dias em Aberto">
        <inputExpression id="InputExpression_1_APPEAL_TRACK_003" typeRef="number">
          <text>diasAberto</text>
        </inputExpression>
      </input>

      <input id="Input_2_APPEAL_TRACK_003" label="Tem Resposta">
        <inputExpression id="InputExpression_2_APPEAL_TRACK_003" typeRef="boolean">
          <text>temResposta</text>
        </inputExpression>
      </input>


      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_APPEAL_TRACK_003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_APPEAL_TRACK_003" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_APPEAL_TRACK_003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_APPEAL_TRACK_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_APPEAL_TRACK_003" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA A11: Alertar -->
      <rule id="Rule_A1_1_APPEAL_TRACK_003">
        <description>Recurso sem resposta ha 30+ dias.</description>
        <inputEntry id="InputEntry_A11_1_APPEAL_TRACK_003"><text>diasAberto >= 30 and not temResposta</text></inputEntry>
        <inputEntry id="InputEntry_A11_2_APPEAL_TRACK_003"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_A11_1_APPEAL_TRACK_003"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A11_2_APPEAL_TRACK_003"><text>"Recurso sem resposta ha 30+ dias."</text></outputEntry>
        <outputEntry id="OutputEntry_A11_3_APPEAL_TRACK_003"><text>"Cobrar formalmente operadora ou ANS via oficio."</text></outputEntry>
        <outputEntry id="OutputEntry_A11_4_APPEAL_TRACK_003"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_A11_5_APPEAL_TRACK_003"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA P12: Prosseguir -->
      <rule id="Rule_P1_2_APPEAL_TRACK_003">
        <description>Recurso com resposta ou dentro prazo.</description>
        <inputEntry id="InputEntry_P12_1_APPEAL_TRACK_003"><text>temResposta or diasAberto &lt; 30</text></inputEntry>
        <inputEntry id="InputEntry_P12_2_APPEAL_TRACK_003"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_P12_1_APPEAL_TRACK_003"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P12_2_APPEAL_TRACK_003"><text>"Recurso com resposta ou dentro prazo."</text></outputEntry>
        <outputEntry id="OutputEntry_P12_3_APPEAL_TRACK_003"><text>"Monitorar evolucao normal."</text></outputEntry>
        <outputEntry id="OutputEntry_P12_4_APPEAL_TRACK_003"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P12_5_APPEAL_TRACK_003"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisao manual -->
            <rule id="Rule_TrackAtraso_APPEAL_TRACK_003"><description>Recurso com atraso no acompanhamento</description>
        <inputEntry id="InputEntry_TrackAtraso_1_APPEAL_TRACK_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_TrackAtraso_2_APPEAL_TRACK_003"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_TrackAtraso_1_APPEAL_TRACK_003"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_TrackAtraso_2_APPEAL_TRACK_003"><text>"Recurso com atraso de acompanhamento. Prazo pode estar proximo."</text></outputEntry>
        <outputEntry id="OutputEntry_TrackAtraso_3_APPEAL_TRACK_003"><text>"Priorizar acompanhamento. Verificar prazo restante para resposta."</text></outputEntry>
        <outputEntry id="OutputEntry_TrackAtraso_4_APPEAL_TRACK_003"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_TrackAtraso_5_APPEAL_TRACK_003"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_TrackPendencia_APPEAL_TRACK_003"><description>Recurso com pendencia de documentacao</description>
        <inputEntry id="InputEntry_TrackPendencia_1_APPEAL_TRACK_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_TrackPendencia_2_APPEAL_TRACK_003"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_TrackPendencia_1_APPEAL_TRACK_003"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_TrackPendencia_2_APPEAL_TRACK_003"><text>"Recurso em andamento com pendencia de documentacao complementar."</text></outputEntry>
        <outputEntry id="OutputEntry_TrackPendencia_3_APPEAL_TRACK_003"><text>"Providenciar documentacao pendente para dar continuidade ao recurso."</text></outputEntry>
        <outputEntry id="OutputEntry_TrackPendencia_4_APPEAL_TRACK_003"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_TrackPendencia_5_APPEAL_TRACK_003"><text>"MEDIO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_APPEAL_TRACK_003">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_APPEAL_TRACK_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_APPEAL_TRACK_003"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_APPEAL_TRACK_003"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_APPEAL_TRACK_003"><text>"Situacao requer analise manual por nao corresponder a nenhum criterio automatico."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_APPEAL_TRACK_003"><text>"Encaminhar para auditoria administrativa para avaliacao caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_APPEAL_TRACK_003"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_APPEAL_TRACK_003"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_APPEAL_TRACK_003">
      <dmndi:DMNShape id="DMNShape_Decision_APPEAL_TRACK_003" dmnElementRef="Decision_APPEAL_TRACK_003">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
