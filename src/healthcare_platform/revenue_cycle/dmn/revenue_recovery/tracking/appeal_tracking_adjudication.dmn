<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_appeal_tracking_adjudication"
             name="Appeal Tracking Adjudication"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Appeal Tracking Adjudication
       For: track_appeal_status_worker
       Archetype: ADMIN_ADJUDICATION
       Purpose: Interpret payer status codes and determine follow-up actions
  -->

  <decision id="Decision_appeal_tracking_adjudication" name="[SP-RC-010 | revenue_recovery/tracking] Appeal Tracking Adjudication" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_appeal_tracking_adjudication" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_1_appeal_tracking_adjudication" label="Payer Status Code">
        <inputExpression id="InputExpr_1_appeal_tracking_adjudication" typeRef="string">
          <text>payerStatusCode</text>
        </inputExpression>
      </input>

      <input id="Input_2_appeal_tracking_adjudication" label="Elapsed Days">
        <inputExpression id="InputExpr_2_appeal_tracking_adjudication" typeRef="number">
          <text>elapsedDays</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado_appeal_tracking_adjudication" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_appeal_tracking_adjudication" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_appeal_tracking_adjudication" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Approved -->
      <rule id="Rule_1_appeal_tracking_adjudication">
        <description>Recurso aprovado - glosas revertidas</description>
        <inputEntry id="IE_1_1_appeal_tracking_adjudication"><text>"APPROVED"</text></inputEntry>
        <inputEntry id="IE_1_2_appeal_tracking_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_1_res_appeal_tracking_adjudication"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_1_acao_appeal_tracking_adjudication"><text>"Recurso aprovado - glosas revertidas"</text></outputEntry>
        <outputEntry id="OE_1_risco_appeal_tracking_adjudication"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Partially approved -->
      <rule id="Rule_2_appeal_tracking_adjudication">
        <description>Parcialmente aprovado - verificar itens</description>
        <inputEntry id="IE_2_1_appeal_tracking_adjudication"><text>"PARTIALLY_APPROVED"</text></inputEntry>
        <inputEntry id="IE_2_2_appeal_tracking_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_2_res_appeal_tracking_adjudication"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_2_acao_appeal_tracking_adjudication"><text>"Parcialmente aprovado - verificar itens"</text></outputEntry>
        <outputEntry id="OE_2_risco_appeal_tracking_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Denied -->
      <rule id="Rule_3_appeal_tracking_adjudication">
        <description>Recurso negado - avaliar próximas ações</description>
        <inputEntry id="IE_3_1_appeal_tracking_adjudication"><text>"DENIED"</text></inputEntry>
        <inputEntry id="IE_3_2_appeal_tracking_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_3_res_appeal_tracking_adjudication"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_3_acao_appeal_tracking_adjudication"><text>"Recurso negado - avaliar próximas ações"</text></outputEntry>
        <outputEntry id="OE_3_risco_appeal_tracking_adjudication"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Rejected -->
      <rule id="Rule_4_appeal_tracking_adjudication">
        <description>Recurso rejeitado</description>
        <inputEntry id="IE_4_1_appeal_tracking_adjudication"><text>"REJECTED"</text></inputEntry>
        <inputEntry id="IE_4_2_appeal_tracking_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_4_res_appeal_tracking_adjudication"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_4_acao_appeal_tracking_adjudication"><text>"Recurso rejeitado"</text></outputEntry>
        <outputEntry id="OE_4_risco_appeal_tracking_adjudication"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Pending info -->
      <rule id="Rule_5_appeal_tracking_adjudication">
        <description>Informação adicional solicitada - acompanhar</description>
        <inputEntry id="IE_5_1_appeal_tracking_adjudication"><text>"PENDING_INFO"</text></inputEntry>
        <inputEntry id="IE_5_2_appeal_tracking_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_5_res_appeal_tracking_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_5_acao_appeal_tracking_adjudication"><text>"Informação adicional solicitada - acompanhar"</text></outputEntry>
        <outputEntry id="OE_5_risco_appeal_tracking_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 6: In analysis - prazo excedido -->
      <rule id="Rule_6_appeal_tracking_adjudication">
        <description>Prazo excedido - contatar operadora</description>
        <inputEntry id="IE_6_1_appeal_tracking_adjudication"><text>"IN_ANALYSIS","RECEIVED"</text></inputEntry>
        <inputEntry id="IE_6_2_appeal_tracking_adjudication"><text>&gt; 15</text></inputEntry>
        <outputEntry id="OE_6_res_appeal_tracking_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_6_acao_appeal_tracking_adjudication"><text>"Prazo excedido - contatar operadora"</text></outputEntry>
        <outputEntry id="OE_6_risco_appeal_tracking_adjudication"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 7: In analysis - dentro do prazo -->
      <rule id="Rule_7_appeal_tracking_adjudication">
        <description>Em análise - aguardar</description>
        <inputEntry id="IE_7_1_appeal_tracking_adjudication"><text>"IN_ANALYSIS","RECEIVED"</text></inputEntry>
        <inputEntry id="IE_7_2_appeal_tracking_adjudication"><text>&lt;= 15</text></inputEntry>
        <outputEntry id="OE_7_res_appeal_tracking_adjudication"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_7_acao_appeal_tracking_adjudication"><text>"Em análise - aguardar"</text></outputEntry>
        <outputEntry id="OE_7_risco_appeal_tracking_adjudication"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="Rule_fallback_appeal_tracking_adjudication">
        <description>Caso não enquadrado — revisão obrigatória</description>
        <inputEntry id="IE_fb_1_appeal_tracking_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2_appeal_tracking_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res_appeal_tracking_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao_appeal_tracking_adjudication"><text>"Status desconhecido - verificar manualmente"</text></outputEntry>
        <outputEntry id="OE_fb_risco_appeal_tracking_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1_appeal_tracking_adjudication">
      <dmndi:DMNShape id="DMNShape_Decision_appeal_tracking_adjudication" dmnElementRef="Decision_appeal_tracking_adjudication">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
