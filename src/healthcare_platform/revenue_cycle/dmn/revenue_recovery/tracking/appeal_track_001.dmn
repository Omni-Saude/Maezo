<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  APPEAL-TRACK-001 - Dias em Aberto por Recurso
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: APPEAL-TRACK
  Perspectiva: HOSPITAL (Receivables - Appeals Management)

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Lei 9.656/1998 (planos de saude)
  - RN ANS 395/2016 (recursos de glosa)
  - CPC 25 (provisoes)
  - IFRS 15 (reconhecimento de receita)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_APPEAL_TRACK_001"
             name="Dias em Aberto por Recurso"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: appeal_track_001_worker.py -->

  <decision id="Decision_APPEAL_TRACK_001" name="[SP-RC-010 | revenue_recovery/tracking] Dias em Aberto por Recurso" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_APPEAL_TRACK_001" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_APPEAL_TRACK_001" label="Dias em Aberto">
        <inputExpression id="InputExpression_1_APPEAL_TRACK_001" typeRef="number">
          <text>diasAberto</text>
        </inputExpression>
      </input>


      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_APPEAL_TRACK_001" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_APPEAL_TRACK_001" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_APPEAL_TRACK_001" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_APPEAL_TRACK_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_APPEAL_TRACK_001" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA 1: Recurso >90 dias - prazo legal esgotado -->
      <rule id="Rule_B1_1_APPEAL_TRACK_001">
        <description>Recurso acima de 90 dias - prazo legal esgotado.</description>
        <inputEntry id="InputEntry_B11_1_APPEAL_TRACK_001"><text>diasAberto &gt; 90</text></inputEntry>
        <outputEntry id="OutputEntry_B11_1_APPEAL_TRACK_001"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B11_2_APPEAL_TRACK_001"><text>"Recurso acima de 90 dias. Prazo legal esgotado (RN ANS 395)."</text></outputEntry>
        <outputEntry id="OutputEntry_B11_3_APPEAL_TRACK_001"><text>"Escalar ANS. Avaliar acao judicial ou provisao contabil."</text></outputEntry>
        <outputEntry id="OutputEntry_B11_4_APPEAL_TRACK_001"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_B11_5_APPEAL_TRACK_001"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- REGRA 2: Recurso 61-90 dias -->
      <rule id="Rule_A1_1_APPEAL_TRACK_001">
        <description>Recurso em aberto ha mais de 60 dias.</description>
        <inputEntry id="InputEntry_A11_1_APPEAL_TRACK_001"><text>diasAberto &gt; 60</text></inputEntry>
        <outputEntry id="OutputEntry_A11_1_APPEAL_TRACK_001"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A11_2_APPEAL_TRACK_001"><text>"Recurso em aberto ha 61-90 dias. Proximidade do prazo legal."</text></outputEntry>
        <outputEntry id="OutputEntry_A11_3_APPEAL_TRACK_001"><text>"Cobrar resposta da operadora. Preparar recurso ANS."</text></outputEntry>
        <outputEntry id="OutputEntry_A11_4_APPEAL_TRACK_001"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_A11_5_APPEAL_TRACK_001"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA 3: Recurso 31-60 dias - atencao -->
      <rule id="Rule_A1_2_APPEAL_TRACK_001">
        <description>Recurso em aberto 31-60 dias.</description>
        <inputEntry id="InputEntry_A12_1_APPEAL_TRACK_001"><text>diasAberto &gt; 30</text></inputEntry>
        <outputEntry id="OutputEntry_A12_1_APPEAL_TRACK_001"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A12_2_APPEAL_TRACK_001"><text>"Recurso em aberto 31-60 dias. Monitoramento ativo necessario."</text></outputEntry>
        <outputEntry id="OutputEntry_A12_3_APPEAL_TRACK_001"><text>"Enviar lembrete a operadora. Verificar status do recurso."</text></outputEntry>
        <outputEntry id="OutputEntry_A12_4_APPEAL_TRACK_001"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_A12_5_APPEAL_TRACK_001"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA 4: Recurso <=30 dias - prazo normal -->
      <rule id="Rule_P1_2_APPEAL_TRACK_001">
        <description>Recurso dentro do prazo normal de resposta.</description>
        <inputEntry id="InputEntry_P12_1_APPEAL_TRACK_001"><text>diasAberto &lt;= 30</text></inputEntry>
        <outputEntry id="OutputEntry_P12_1_APPEAL_TRACK_001"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P12_2_APPEAL_TRACK_001"><text>"Recurso dentro do prazo normal de resposta."</text></outputEntry>
        <outputEntry id="OutputEntry_P12_3_APPEAL_TRACK_001"><text>"Monitorar evolucao do recurso."</text></outputEntry>
        <outputEntry id="OutputEntry_P12_4_APPEAL_TRACK_001"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P12_5_APPEAL_TRACK_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisao manual -->
      <rule id="Rule_Fallback_APPEAL_TRACK_001">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_APPEAL_TRACK_001"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_APPEAL_TRACK_001"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_APPEAL_TRACK_001"><text>"Situacao requer analise manual por nao corresponder a nenhum criterio automatico."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_APPEAL_TRACK_001"><text>"Encaminhar para auditoria administrativa para avaliacao caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_APPEAL_TRACK_001"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_APPEAL_TRACK_001"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_APPEAL_TRACK_001">
      <dmndi:DMNShape id="DMNShape_Decision_APPEAL_TRACK_001" dmnElementRef="Decision_APPEAL_TRACK_001">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
