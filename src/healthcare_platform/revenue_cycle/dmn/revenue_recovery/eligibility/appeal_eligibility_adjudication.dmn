<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_appeal_eligibility_adjudication"
             name="Appeal Eligibility Adjudication"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Appeal Eligibility Adjudication
       For: check_appeal_eligibility_worker
       Archetype: ADMIN_ADJUDICATION
       Purpose: Determine if glosa is eligible for appeal based on type, reason, and deadline
  -->

  <decision id="Decision_appeal_eligibility_adjudication" name="[SP-RC-010 | revenue_recovery/eligibility] Appeal Eligibility Adjudication" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_appeal_eligibility_adjudication" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_1_appeal_eligibility_adjudication" label="Glosa Type">
        <inputExpression id="InputExpr_1_appeal_eligibility_adjudication" typeRef="string">
          <text>glosaType</text>
        </inputExpression>
      </input>

      <input id="Input_2_appeal_eligibility_adjudication" label="Reason Code">
        <inputExpression id="InputExpr_2_appeal_eligibility_adjudication" typeRef="string">
          <text>reasonCode</text>
        </inputExpression>
      </input>

      <input id="Input_3_appeal_eligibility_adjudication" label="Days Remaining">
        <inputExpression id="InputExpr_3_appeal_eligibility_adjudication" typeRef="number">
          <text>daysRemaining</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado_appeal_eligibility_adjudication" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_appeal_eligibility_adjudication" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_appeal_eligibility_adjudication" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Glosa total não passível de recurso -->
      <rule id="Rule_1_appeal_eligibility_adjudication">
        <description>Glosa total não passível de recurso</description>
        <inputEntry id="IE_1_1_appeal_eligibility_adjudication"><text>"TOTAL"</text></inputEntry>
        <inputEntry id="IE_1_2_appeal_eligibility_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3_appeal_eligibility_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_1_res_appeal_eligibility_adjudication"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_acao_appeal_eligibility_adjudication"><text>"Glosa total não passível de recurso"</text></outputEntry>
        <outputEntry id="OE_1_risco_appeal_eligibility_adjudication"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Prazo expirado -->
      <rule id="Rule_2_appeal_eligibility_adjudication">
        <description>Prazo expirado conforme ANS RN 424/2017</description>
        <inputEntry id="IE_2_1_appeal_eligibility_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_2_2_appeal_eligibility_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_2_3_appeal_eligibility_adjudication"><text>&lt; 0</text></inputEntry>
        <outputEntry id="OE_2_res_appeal_eligibility_adjudication"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_2_acao_appeal_eligibility_adjudication"><text>"Prazo expirado conforme ANS RN 424/2017"</text></outputEntry>
        <outputEntry id="OE_2_risco_appeal_eligibility_adjudication"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Prazo crítico -->
      <rule id="Rule_3_appeal_eligibility_adjudication">
        <description>Prazo crítico - submeter urgente</description>
        <inputEntry id="IE_3_1_appeal_eligibility_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_3_2_appeal_eligibility_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_3_3_appeal_eligibility_adjudication"><text>&lt;= 5</text></inputEntry>
        <outputEntry id="OE_3_res_appeal_eligibility_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_3_acao_appeal_eligibility_adjudication"><text>"Prazo crítico - submeter urgente"</text></outputEntry>
        <outputEntry id="OE_3_risco_appeal_eligibility_adjudication"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Missing signature - elegível -->
      <rule id="Rule_4_appeal_eligibility_adjudication">
        <description>Recurso elegível - assinatura</description>
        <inputEntry id="IE_4_1_appeal_eligibility_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_4_2_appeal_eligibility_adjudication"><text>"MISSING_SIGNATURE"</text></inputEntry>
        <inputEntry id="IE_4_3_appeal_eligibility_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_4_res_appeal_eligibility_adjudication"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_4_acao_appeal_eligibility_adjudication"><text>"Recurso elegível - assinatura"</text></outputEntry>
        <outputEntry id="OE_4_risco_appeal_eligibility_adjudication"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Missing justification - elegível -->
      <rule id="Rule_5_appeal_eligibility_adjudication">
        <description>Recurso elegível - justificativa</description>
        <inputEntry id="IE_5_1_appeal_eligibility_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_5_2_appeal_eligibility_adjudication"><text>"MISSING_CLINICAL_JUSTIFICATION"</text></inputEntry>
        <inputEntry id="IE_5_3_appeal_eligibility_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_5_res_appeal_eligibility_adjudication"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_acao_appeal_eligibility_adjudication"><text>"Recurso elegível - justificativa"</text></outputEntry>
        <outputEntry id="OE_5_risco_appeal_eligibility_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 6: Invalid code - elegível -->
      <rule id="Rule_6_appeal_eligibility_adjudication">
        <description>Recurso elegível - código</description>
        <inputEntry id="IE_6_1_appeal_eligibility_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_6_2_appeal_eligibility_adjudication"><text>"INVALID_CODE"</text></inputEntry>
        <inputEntry id="IE_6_3_appeal_eligibility_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_6_res_appeal_eligibility_adjudication"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_6_acao_appeal_eligibility_adjudication"><text>"Recurso elegível - código"</text></outputEntry>
        <outputEntry id="OE_6_risco_appeal_eligibility_adjudication"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 7: Duplicate billing - verificar -->
      <rule id="Rule_7_appeal_eligibility_adjudication">
        <description>Verificar duplicidade antes de recurso</description>
        <inputEntry id="IE_7_1_appeal_eligibility_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_7_2_appeal_eligibility_adjudication"><text>"DUPLICATE_BILLING"</text></inputEntry>
        <inputEntry id="IE_7_3_appeal_eligibility_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_7_res_appeal_eligibility_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_7_acao_appeal_eligibility_adjudication"><text>"Verificar duplicidade antes de recurso"</text></outputEntry>
        <outputEntry id="OE_7_risco_appeal_eligibility_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 8: Not covered - verificar cobertura -->
      <rule id="Rule_8_appeal_eligibility_adjudication">
        <description>Verificar cobertura contratual</description>
        <inputEntry id="IE_8_1_appeal_eligibility_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_8_2_appeal_eligibility_adjudication"><text>"NOT_COVERED_PROCEDURE"</text></inputEntry>
        <inputEntry id="IE_8_3_appeal_eligibility_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_8_res_appeal_eligibility_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_8_acao_appeal_eligibility_adjudication"><text>"Verificar cobertura contratual"</text></outputEntry>
        <outputEntry id="OE_8_risco_appeal_eligibility_adjudication"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 9: Lack of authorization - emergência -->
      <rule id="Rule_9_appeal_eligibility_adjudication">
        <description>Recurso elegível - emergência</description>
        <inputEntry id="IE_9_1_appeal_eligibility_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_9_2_appeal_eligibility_adjudication"><text>"LACK_OF_PRIOR_AUTHORIZATION"</text></inputEntry>
        <inputEntry id="IE_9_3_appeal_eligibility_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_9_res_appeal_eligibility_adjudication"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_9_acao_appeal_eligibility_adjudication"><text>"Recurso elegível - emergência"</text></outputEntry>
        <outputEntry id="OE_9_risco_appeal_eligibility_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="Rule_fallback_appeal_eligibility_adjudication">
        <description>Caso não enquadrado — revisão obrigatória</description>
        <inputEntry id="IE_fb_1_appeal_eligibility_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2_appeal_eligibility_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_3_appeal_eligibility_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res_appeal_eligibility_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao_appeal_eligibility_adjudication"><text>"Avaliar elegibilidade manualmente"</text></outputEntry>
        <outputEntry id="OE_fb_risco_appeal_eligibility_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1_appeal_eligibility_adjudication">
      <dmndi:DMNShape id="DMNShape_Decision_appeal_eligibility_adjudication" dmnElementRef="Decision_appeal_eligibility_adjudication">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
