<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  APPEAL-ELIG-004 - Recurso 1a Instancia vs 2a Instancia
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: APPEAL-ELIG
  Perspectiva: HOSPITAL (Receivables - Appeals Management)

  ============================================================================
  INDICACOES (Quando PROSSEGUIR):
  ============================================================================
  - Instancia correta para o tipo de recurso
  - Esgotamento de instancia anterior quando aplicavel
  - Conformidade com fluxo recursal ANS/Operadora

  ============================================================================
  CONTRAINDICACOES (Quando BLOQUEAR):
  ============================================================================
  - Recurso em instancia incorreta
  - Falta de esgotamento da instancia anterior
  - Violacao do fluxo recursal hierarquico

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - RN ANS 395/2016 Art. 3-6 (instancias recursais)
  - RN ANS 388/2015 (ANS como segunda instancia)
  - Lei 9.656/1998 Art. 12
  - Principio da hierarquia recursal
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_APPEAL_ELIG_004"
             name="Recurso 1a Instancia vs 2a Instancia"
             namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: ADMIN_ADJUDICATION | Source: appeal_elig_004_worker.py -->

  <decision id="Decision_APPEAL_ELIG_004" name="[SP-RC-010 | revenue_recovery/eligibility] Recurso 1a Instancia vs 2a Instancia" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_APPEAL_ELIG_004" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_APPEAL_ELIG_004" label="Instancia Atual">
        <inputExpression id="InputExpression_1_APPEAL_ELIG_004" typeRef="string">
          <text>instanciaAtual</text>
        </inputExpression>
        <inputValues id="InputValues_1_APPEAL_ELIG_004">
          <text>"1A", "2A", "ANS"</text>
        </inputValues>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_APPEAL_ELIG_004" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_APPEAL_ELIG_004" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_APPEAL_ELIG_004" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_APPEAL_ELIG_004" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_APPEAL_ELIG_004" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA P1: Aprovado - Primeira instancia (operadora) -->
      <rule id="Rule_Aprovado_1_APPEAL_ELIG_004">
        <description>Recurso em primeira instancia junto a operadora</description>
        <inputEntry id="InputEntry_P1_1_APPEAL_ELIG_004"><text>"1A"</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_APPEAL_ELIG_004"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_2_APPEAL_ELIG_004"><text>"Recurso em primeira instancia (operadora). Instancia correta e adequada. Prosseguir com preparacao e apresentacao."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_3_APPEAL_ELIG_004"><text>"Preparar recurso administrativo junto a operadora. Reunir documentacao conforme RN ANS 395/2016. Protocolar dentro do prazo."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_4_APPEAL_ELIG_004"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_5_APPEAL_ELIG_004"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA P2: Aprovado - Segunda instancia (recurso interno) -->
      <rule id="Rule_Aprovado_2_APPEAL_ELIG_004">
        <description>Recurso em segunda instancia junto a operadora</description>
        <inputEntry id="InputEntry_P2_1_APPEAL_ELIG_004"><text>"2A"</text></inputEntry>
        <outputEntry id="OutputEntry_P2_1_APPEAL_ELIG_004"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P2_2_APPEAL_ELIG_004"><text>"Recurso em segunda instancia (operadora). Primeira instancia foi esgotada. Prosseguir com recurso hierarquico."</text></outputEntry>
        <outputEntry id="OutputEntry_P2_3_APPEAL_ELIG_004"><text>"Apresentar recurso a instancia superior da operadora. Reforcar argumentacao com evidencias adicionais. Fundamentar inadequacao da decisao anterior."</text></outputEntry>
        <outputEntry id="OutputEntry_P2_4_APPEAL_ELIG_004"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P2_5_APPEAL_ELIG_004"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA A1: Alerta - Recurso ANS (ultma instancia) -->
      <rule id="Rule_Alerta_1_APPEAL_ELIG_004">
        <description>Recurso junto a ANS (esgotadas vias internas)</description>
        <inputEntry id="InputEntry_A1_1_APPEAL_ELIG_004"><text>"ANS"</text></inputEntry>
        <outputEntry id="OutputEntry_A1_1_APPEAL_ELIG_004"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_2_APPEAL_ELIG_004"><text>"Recurso junto a ANS (ultima instancia administrativa). Vias internas da operadora devem estar esgotadas. Verificar cumprimento de requisitos formais."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_3_APPEAL_ELIG_004"><text>"Confirmar esgotamento de vias internas. Reunir historico completo do recurso. Fundamentar em DUT e normativas ANS. Protocolar via sistema ANS."</text></outputEntry>
        <outputEntry id="OutputEntry_A1_4_APPEAL_ELIG_004"><text>"PRAZO"</text></outputEntry>
        <outputEntry id="OutputEntry_A1_5_APPEAL_ELIG_004"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisao manual -->
            <rule id="Rule_ElegParcial_APPEAL_ELIG_004"><description>Elegibilidade parcial para recurso</description>
        <inputEntry id="InputEntry_ElegParcial_1_APPEAL_ELIG_004"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_ElegParcial_1_APPEAL_ELIG_004"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_ElegParcial_2_APPEAL_ELIG_004"><text>"Recurso parcialmente elegivel. Alguns criterios nao atendidos."</text></outputEntry>
        <outputEntry id="OutputEntry_ElegParcial_3_APPEAL_ELIG_004"><text>"Verificar criterios pendentes e reforcar documentacao antes de submeter."</text></outputEntry>
        <outputEntry id="OutputEntry_ElegParcial_4_APPEAL_ELIG_004"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_ElegParcial_5_APPEAL_ELIG_004"><text>"ALTO"</text></outputEntry>
      </rule>

      <rule id="Rule_Fallback_APPEAL_ELIG_004">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_APPEAL_ELIG_004"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_APPEAL_ELIG_004"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_APPEAL_ELIG_004"><text>"Situacao requer analise manual para confirmar instancia correta e fluxo recursal aplicavel."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_APPEAL_ELIG_004"><text>"Encaminhar para gestor de recebiveis para validar instancia e historico recursal do caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_APPEAL_ELIG_004"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_APPEAL_ELIG_004"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_APPEAL_ELIG_004">
      <dmndi:DMNShape id="DMNShape_Decision_APPEAL_ELIG_004" dmnElementRef="Decision_APPEAL_ELIG_004">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
