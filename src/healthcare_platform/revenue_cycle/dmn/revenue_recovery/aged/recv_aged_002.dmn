<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  RECV-AGED-002 - Recebiveis 91-180 Dias - Escalacao
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: RECV-AGED
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_RECV_AGED_002" name="Recebiveis 91-180 Dias - Escalacao" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_RECV_AGED_002" name="[SP-RC-010 | revenue_recovery/aged] Acao para Recebiveis 91-180 Dias" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_RECV_AGED_002" hitPolicy="FIRST">

      
      <input id="Input_1_RECV_AGED_002" label="Dias em Aberto">
        <inputExpression id="InputExpression_1_RECV_AGED_002" typeRef="number">
          <text>diasEmAberto</text>
        </inputExpression>
      </input>

      <input id="Input_2_RECV_AGED_002" label="Valor Recebivel">
        <inputExpression id="InputExpression_2_RECV_AGED_002" typeRef="number">
          <text>valorRecebivel</text>
        </inputExpression>
      </input>

      <input id="Input_3_RECV_AGED_002" label="Status Cobranca">
        <inputExpression id="InputExpression_3_RECV_AGED_002" typeRef="string">
          <text>statusCobranca</text>
        </inputExpression>
        <inputValues id="InputValues_3_RECV_AGED_002">
          <text>"PENDENTE", "EM_CONTATO", "PROMESSA_PAGAMENTO", "CONTESTADO", "PARCIAL", "ESCALADO"</text>
        </inputValues>
      </input>

      <input id="Input_4_RECV_AGED_002" label="Tentativas de Cobranca">
        <inputExpression id="InputExpression_4_RECV_AGED_002" typeRef="number">
          <text>tentativasCobranca</text>
        </inputExpression>
      </input>

      
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_RECV_AGED_002" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_RECV_AGED_002" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_RECV_AGED_002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_RECV_AGED_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_RECV_AGED_002" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Contraindicacao_1_RECV_AGED_002">
        <description>Aging abaixo do range desta regra</description>
        <inputEntry id="InputEntry_C1_1_RECV_AGED_002"><text>&lt; 91</text></inputEntry>
        <inputEntry id="InputEntry_C1_2_RECV_AGED_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C1_3_RECV_AGED_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C1_4_RECV_AGED_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_C1_1_RECV_AGED_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_C1_2_RECV_AGED_002"><text>"Aging &lt; 91 dias. Usar regra RECV-AGED-001."</text></outputEntry>
<outputEntry id="OutputEntry_C1_3_RECV_AGED_002"><text>"RECORRER"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_1_4_RECV_AGED_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_1_5_RECV_AGED_002"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Contraindicacao_2_RECV_AGED_002">
        <description>Aging acima do range desta regra</description>
        <inputEntry id="InputEntry_C2_1_RECV_AGED_002"><text>&gt; 180</text></inputEntry>
        <inputEntry id="InputEntry_C2_2_RECV_AGED_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C2_3_RECV_AGED_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C2_4_RECV_AGED_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_C2_1_RECV_AGED_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_C2_2_RECV_AGED_002"><text>"Aging &gt; 180 dias. Usar regra RECV-AGED-003."</text></outputEntry>
<outputEntry id="OutputEntry_C2_3_RECV_AGED_002"><text>"SOLICITAR_PARECER"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_2_4_RECV_AGED_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_2_5_RECV_AGED_002"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_1_RECV_AGED_002">
        <description>Aging 91-120 dias - Escalar para gestao</description>
        <inputEntry id="InputEntry_A1_1_RECV_AGED_002"><text>[91..120]</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_RECV_AGED_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_RECV_AGED_002"><text>not("ESCALADO")</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_RECV_AGED_002"><text>&gt;= 2</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_RECV_AGED_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_RECV_AGED_002"><text>"Aging 91-120 dias com multiplas tentativas. Escalar para gerencia. Avaliar acao comercial direta."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_RECV_AGED_002"><text>"SOLICITAR_PARECER"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_1_4_RECV_AGED_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_1_5_RECV_AGED_002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_2_RECV_AGED_002">
        <description>Aging 121-180 dias - Revisar provisao</description>
        <inputEntry id="InputEntry_A2_1_RECV_AGED_002"><text>[121..180]</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_RECV_AGED_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_RECV_AGED_002"><text>"PENDENTE", "EM_CONTATO"</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_RECV_AGED_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_RECV_AGED_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_RECV_AGED_002"><text>"Aging 121-180 dias. OBRIGATORIO: Revisar provisao. Considerar provisao parcial ou total conforme probabilidade."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_RECV_AGED_002"><text>"PROVISIONAR"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_2_4_RECV_AGED_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_2_5_RECV_AGED_002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_3_RECV_AGED_002">
        <description>Ja escalado - aguardar resolucao</description>
        <inputEntry id="InputEntry_A3_1_RECV_AGED_002"><text>[91..180]</text></inputEntry>
        <inputEntry id="InputEntry_A3_2_RECV_AGED_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_3_RECV_AGED_002"><text>"ESCALADO"</text></inputEntry>
        <inputEntry id="InputEntry_A3_4_RECV_AGED_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A3_1_RECV_AGED_002"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_A3_2_RECV_AGED_002"><text>"Caso ja escalado. Monitorar resolucao pela gestao. Atualizar status em 7 dias."</text></outputEntry>
<outputEntry id="OutputEntry_A3_3_RECV_AGED_002"><text>"SOLICITAR_PARECER"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_3_4_RECV_AGED_002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_3_5_RECV_AGED_002"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_4_RECV_AGED_002">
        <description>Alto valor requer escalacao imediata</description>
        <inputEntry id="InputEntry_A4_1_RECV_AGED_002"><text>[91..180]</text></inputEntry>
        <inputEntry id="InputEntry_A4_2_RECV_AGED_002"><text>&gt;= 50000</text></inputEntry>
        <inputEntry id="InputEntry_A4_3_RECV_AGED_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A4_4_RECV_AGED_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A4_1_RECV_AGED_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A4_2_RECV_AGED_002"><text>"URGENTE: Recebivel de alto valor (&gt;= R$ 50.000) com aging critico. Escalar para diretoria. Acionar juridico se necessario."</text></outputEntry>
<outputEntry id="OutputEntry_A4_3_RECV_AGED_002"><text>"SOLICITAR_PARECER"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_4_4_RECV_AGED_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_4_5_RECV_AGED_002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_5_RECV_AGED_002">
        <description>Promessa de pagamento - monitorar cumprimento</description>
        <inputEntry id="InputEntry_A5_1_RECV_AGED_002"><text>[91..180]</text></inputEntry>
        <inputEntry id="InputEntry_A5_2_RECV_AGED_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A5_3_RECV_AGED_002"><text>"PROMESSA_PAGAMENTO"</text></inputEntry>
        <inputEntry id="InputEntry_A5_4_RECV_AGED_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A5_1_RECV_AGED_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A5_2_RECV_AGED_002"><text>"Promessa de pagamento com aging elevado. Monitorar rigorosamente. Se nao cumprir em 15 dias, escalar."</text></outputEntry>
<outputEntry id="OutputEntry_A5_3_RECV_AGED_002"><text>"RECORRER"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_5_4_RECV_AGED_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_5_5_RECV_AGED_002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_RECV_AGED_002">
        <description>Caso padrao - Escalar e revisar provisao</description>
        <inputEntry id="InputEntry_F_1_RECV_AGED_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_RECV_AGED_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_RECV_AGED_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_RECV_AGED_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_RECV_AGED_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_RECV_AGED_002"><text>"Recebivel em faixa critica (91-180 dias). Escalar para gestao e revisar provisao."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_RECV_AGED_002"><text>"PROVISIONAR"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_RECV_AGED_002_4"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_RECV_AGED_002_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RECV_AGED_002">
      <dmndi:DMNShape id="DMNShape_Decision_RECV_AGED_002" dmnElementRef="Decision_RECV_AGED_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>