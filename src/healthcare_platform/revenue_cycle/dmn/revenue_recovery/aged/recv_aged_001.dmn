<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  RECV-AGED-001 - Recebiveis 0-90 Dias - Acompanhamento Ativo
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: RECV-AGED
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_RECV_AGED_001" name="Recebiveis 0-90 Dias - Acompanhamento Ativo" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_RECV_AGED_001" name="[SP-RC-010 | revenue_recovery/aged] Acao para Recebiveis 0-90 Dias" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_RECV_AGED_001" hitPolicy="FIRST">

      
      <input id="Input_1_RECV_AGED_001" label="Dias em Aberto">
        <inputExpression id="InputExpression_1_RECV_AGED_001" typeRef="number">
          <text>diasEmAberto</text>
        </inputExpression>
      </input>

      <input id="Input_2_RECV_AGED_001" label="Valor Recebivel">
        <inputExpression id="InputExpression_2_RECV_AGED_001" typeRef="number">
          <text>valorRecebivel</text>
        </inputExpression>
      </input>

      <input id="Input_3_RECV_AGED_001" label="Status Cobranca">
        <inputExpression id="InputExpression_3_RECV_AGED_001" typeRef="string">
          <text>statusCobranca</text>
        </inputExpression>
        <inputValues id="InputValues_3_RECV_AGED_001">
          <text>"PENDENTE", "EM_CONTATO", "PROMESSA_PAGAMENTO", "CONTESTADO", "PARCIAL"</text>
        </inputValues>
      </input>

      <input id="Input_4_RECV_AGED_001" label="Tentativas de Cobranca">
        <inputExpression id="InputExpression_4_RECV_AGED_001" typeRef="number">
          <text>tentativasCobranca</text>
        </inputExpression>
      </input>

      
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_RECV_AGED_001" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_RECV_AGED_001" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_RECV_AGED_001" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_RECV_AGED_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_RECV_AGED_001" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Contraindicacao_1_RECV_AGED_001">
        <description>Aging fora do range desta regra</description>
        <inputEntry id="InputEntry_C1_1_RECV_AGED_001"><text>&gt; 90</text></inputEntry>
        <inputEntry id="InputEntry_C1_2_RECV_AGED_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C1_3_RECV_AGED_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C1_4_RECV_AGED_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_C1_1_RECV_AGED_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_C1_2_RECV_AGED_001"><text>"Aging &gt; 90 dias. Usar regra RECV-AGED-002 ou RECV-AGED-003."</text></outputEntry>
<outputEntry id="OutputEntry_C1_3_RECV_AGED_001"><text>"SOLICITAR_PARECER"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_1_4_RECV_AGED_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_1_5_RECV_AGED_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_1_RECV_AGED_001">
        <description>Aging 0-30 dias - Acompanhamento padrao</description>
        <inputEntry id="InputEntry_A1_1_RECV_AGED_001"><text>[0..30]</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_RECV_AGED_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_RECV_AGED_001"><text>"PENDENTE"</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_RECV_AGED_001"><text>0</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_RECV_AGED_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_RECV_AGED_001"><text>"Recebivel recente (0-30 dias). Acompanhamento padrao. Aguardar ciclo normal de pagamento da operadora."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_RECV_AGED_001"><text>"RECORRER"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_1_4_RECV_AGED_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_1_5_RECV_AGED_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_2_RECV_AGED_001">
        <description>Aging 31-60 dias - Primeiro contato</description>
        <inputEntry id="InputEntry_A2_1_RECV_AGED_001"><text>[31..60]</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_RECV_AGED_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_RECV_AGED_001"><text>"PENDENTE"</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_RECV_AGED_001"><text>0</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_RECV_AGED_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_RECV_AGED_001"><text>"Aging 31-60 dias. Realizar primeiro contato com operadora. Verificar status do processamento."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_RECV_AGED_001"><text>"RECORRER"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_2_4_RECV_AGED_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_2_5_RECV_AGED_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_3_RECV_AGED_001">
        <description>Aging 61-90 dias - Segundo contato e alerta</description>
        <inputEntry id="InputEntry_A3_1_RECV_AGED_001"><text>[61..90]</text></inputEntry>
        <inputEntry id="InputEntry_A3_2_RECV_AGED_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_3_RECV_AGED_001"><text>"PENDENTE", "EM_CONTATO"</text></inputEntry>
        <inputEntry id="InputEntry_A3_4_RECV_AGED_001"><text>&lt;= 1</text></inputEntry>
<outputEntry id="OutputEntry_A3_1_RECV_AGED_001"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A3_2_RECV_AGED_001"><text>"Aging 61-90 dias. Segundo contato URGENTE conforme RN 412/2016. Formalizar cobranca por escrito via protocolo TISS. Prazo para resposta: 15 dias uteis."</text></outputEntry>
<outputEntry id="OutputEntry_A3_3_RECV_AGED_001"><text>"RECORRER"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_3_4_RECV_AGED_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_3_5_RECV_AGED_001"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_4_RECV_AGED_001">
        <description>Com promessa de pagamento - monitorar</description>
        <inputEntry id="InputEntry_A4_1_RECV_AGED_001"><text>[0..90]</text></inputEntry>
        <inputEntry id="InputEntry_A4_2_RECV_AGED_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A4_3_RECV_AGED_001"><text>"PROMESSA_PAGAMENTO"</text></inputEntry>
        <inputEntry id="InputEntry_A4_4_RECV_AGED_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A4_1_RECV_AGED_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_A4_2_RECV_AGED_001"><text>"Promessa de pagamento registrada. Monitorar cumprimento. Reagendar follow-up em 7 dias."</text></outputEntry>
<outputEntry id="OutputEntry_A4_3_RECV_AGED_001"><text>"RECORRER"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_4_4_RECV_AGED_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_4_5_RECV_AGED_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_5_RECV_AGED_001">
        <description>Valor alto requer atencao especial</description>
        <inputEntry id="InputEntry_A5_1_RECV_AGED_001"><text>[31..90]</text></inputEntry>
        <inputEntry id="InputEntry_A5_2_RECV_AGED_001"><text>&gt;= 10000</text></inputEntry>
        <inputEntry id="InputEntry_A5_3_RECV_AGED_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A5_4_RECV_AGED_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A5_1_RECV_AGED_001"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A5_2_RECV_AGED_001"><text>"Recebivel de alto valor (&gt;= R$ 10.000). Escalar para gerencia comercial. Contato direto com gestor de relacionamento da operadora."</text></outputEntry>
<outputEntry id="OutputEntry_A5_3_RECV_AGED_001"><text>"RECORRER"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_5_4_RECV_AGED_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_5_5_RECV_AGED_001"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_6_RECV_AGED_001">
        <description>Recebivel contestado pela operadora</description>
        <inputEntry id="InputEntry_A6_1_RECV_AGED_001"><text>[0..90]</text></inputEntry>
        <inputEntry id="InputEntry_A6_2_RECV_AGED_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A6_3_RECV_AGED_001"><text>"CONTESTADO"</text></inputEntry>
        <inputEntry id="InputEntry_A6_4_RECV_AGED_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A6_1_RECV_AGED_001"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A6_2_RECV_AGED_001"><text>"Recebivel contestado. Encaminhar para analise de glosa. Verificar motivo da contestacao."</text></outputEntry>
<outputEntry id="OutputEntry_A6_3_RECV_AGED_001"><text>"SOLICITAR_PARECER"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_6_4_RECV_AGED_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_6_5_RECV_AGED_001"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_RECV_AGED_001">
        <description>Caso padrao - Acompanhamento ativo</description>
        <inputEntry id="InputEntry_F_1_RECV_AGED_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_RECV_AGED_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_RECV_AGED_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_RECV_AGED_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_RECV_AGED_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_RECV_AGED_001"><text>"Manter acompanhamento ativo. Registrar contatos e atualizar status."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_RECV_AGED_001"><text>"RECORRER"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_RECV_AGED_001_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_RECV_AGED_001_5"><text>"BAIXO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RECV_AGED_001">
      <dmndi:DMNShape id="DMNShape_Decision_RECV_AGED_001" dmnElementRef="Decision_RECV_AGED_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>