<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_appeal_submission_adjudication"
             name="Appeal Submission Adjudication"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Appeal Submission Adjudication
       For: submit_appeal_worker
       Archetype: ADMIN_ADJUDICATION
       Purpose: Determine action based on submission response and retry attempts
  -->

  <decision id="Decision_appeal_submission_adjudication" name="[SP-RC-010 | revenue_recovery/submission] Appeal Submission Adjudication" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_appeal_submission_adjudication" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_1_appeal_submission_adjudication" label="Response Code">
        <inputExpression id="InputExpr_1_appeal_submission_adjudication" typeRef="string">
          <text>responseCode</text>
        </inputExpression>
      </input>

      <input id="Input_2_appeal_submission_adjudication" label="Attempt Count">
        <inputExpression id="InputExpr_2_appeal_submission_adjudication" typeRef="number">
          <text>attemptCount</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado_appeal_submission_adjudication" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_appeal_submission_adjudication" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_appeal_submission_adjudication" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Success -->
      <rule id="Rule_1_appeal_submission_adjudication">
        <description>Submissão aceita</description>
        <inputEntry id="IE_1_1_appeal_submission_adjudication"><text>"SUCCESS"</text></inputEntry>
        <inputEntry id="IE_1_2_appeal_submission_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_1_res_appeal_submission_adjudication"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_1_acao_appeal_submission_adjudication"><text>"Submissão aceita"</text></outputEntry>
        <outputEntry id="OE_1_risco_appeal_submission_adjudication"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Validation error -->
      <rule id="Rule_2_appeal_submission_adjudication">
        <description>Erro de validação TISS</description>
        <inputEntry id="IE_2_1_appeal_submission_adjudication"><text>"VALIDATION_ERROR"</text></inputEntry>
        <inputEntry id="IE_2_2_appeal_submission_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_2_res_appeal_submission_adjudication"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_2_acao_appeal_submission_adjudication"><text>"Erro de validação TISS"</text></outputEntry>
        <outputEntry id="OE_2_risco_appeal_submission_adjudication"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Rejected by payer -->
      <rule id="Rule_3_appeal_submission_adjudication">
        <description>Recurso rejeitado pela operadora</description>
        <inputEntry id="IE_3_1_appeal_submission_adjudication"><text>"REJECTED"</text></inputEntry>
        <inputEntry id="IE_3_2_appeal_submission_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_3_res_appeal_submission_adjudication"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_3_acao_appeal_submission_adjudication"><text>"Recurso rejeitado pela operadora"</text></outputEntry>
        <outputEntry id="OE_3_risco_appeal_submission_adjudication"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Timeout/connection - max retries exceeded -->
      <rule id="Rule_4_appeal_submission_adjudication">
        <description>Falha após máximo de tentativas</description>
        <inputEntry id="IE_4_1_appeal_submission_adjudication"><text>"TIMEOUT","CONNECTION_ERROR"</text></inputEntry>
        <inputEntry id="IE_4_2_appeal_submission_adjudication"><text>&gt;= 3</text></inputEntry>
        <outputEntry id="OE_4_res_appeal_submission_adjudication"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_4_acao_appeal_submission_adjudication"><text>"Falha após máximo de tentativas"</text></outputEntry>
        <outputEntry id="OE_4_risco_appeal_submission_adjudication"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Timeout/connection - retry available -->
      <rule id="Rule_5_appeal_submission_adjudication">
        <description>Erro transitório - retry</description>
        <inputEntry id="IE_5_1_appeal_submission_adjudication"><text>"TIMEOUT","CONNECTION_ERROR"</text></inputEntry>
        <inputEntry id="IE_5_2_appeal_submission_adjudication"><text>&lt; 3</text></inputEntry>
        <outputEntry id="OE_5_res_appeal_submission_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_5_acao_appeal_submission_adjudication"><text>"Erro transitório - retry"</text></outputEntry>
        <outputEntry id="OE_5_risco_appeal_submission_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="Rule_fallback_appeal_submission_adjudication">
        <description>Caso não enquadrado — revisão obrigatória</description>
        <inputEntry id="IE_fb_1_appeal_submission_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2_appeal_submission_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res_appeal_submission_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao_appeal_submission_adjudication"><text>"Resposta desconhecida - avaliar"</text></outputEntry>
        <outputEntry id="OE_fb_risco_appeal_submission_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1_appeal_submission_adjudication">
      <dmndi:DMNShape id="DMNShape_Decision_appeal_submission_adjudication" dmnElementRef="Decision_appeal_submission_adjudication">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
