<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  RECV-PROVISION-003 - Baixa Probabilidade - Provisao Total
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: RECV-PROVISION
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_RECV_PROVISION_003" name="Baixa Probabilidade - Provisao Total" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_RECV_PROVISION_003" name="[SP-RC-010 | revenue_recovery/provision] Avaliacao Provisao - Baixa Probabilidade" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_RECV_PROVISION_003" hitPolicy="FIRST">

      
      <input id="Input_1_RECV_PROVISION_003" label="Probabilidade Recuperacao">
        <inputExpression id="InputExpression_1_RECV_PROVISION_003" typeRef="number">
          <text>probabilidadeRecuperacao</text>
        </inputExpression>
      </input>

      <input id="Input_2_RECV_PROVISION_003" label="Valor em Aberto">
        <inputExpression id="InputExpression_2_RECV_PROVISION_003" typeRef="number">
          <text>valorEmAberto</text>
        </inputExpression>
      </input>

      <input id="Input_3_RECV_PROVISION_003" label="Dias em Aberto">
        <inputExpression id="InputExpression_3_RECV_PROVISION_003" typeRef="number">
          <text>diasEmAberto</text>
        </inputExpression>
      </input>

      <input id="Input_4_RECV_PROVISION_003" label="Recurso Esgotado">
        <inputExpression id="InputExpression_4_RECV_PROVISION_003" typeRef="boolean">
          <text>recursoEsgotado</text>
        </inputExpression>
      </input>

      <input id="Input_5_RECV_PROVISION_003" label="Provisao Atual">
        <inputExpression id="InputExpression_5_RECV_PROVISION_003" typeRef="number">
          <text>provisaoAtual</text>
        </inputExpression>
      </input>

      
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_RECV_PROVISION_003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_RECV_PROVISION_003" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_RECV_PROVISION_003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_RECV_PROVISION_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_RECV_PROVISION_003" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Contraindicacao_1_RECV_PROVISION_003">
        <description>Probabilidade acima de 30% - nao e baixa</description>
        <inputEntry id="InputEntry_C1_1_RECV_PROVISION_003"><text>&gt;= 0.30</text></inputEntry>
        <inputEntry id="InputEntry_C1_2_RECV_PROVISION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C1_3_RECV_PROVISION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C1_4_RECV_PROVISION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C1_5_RECV_PROVISION_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_C1_1_RECV_PROVISION_003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_C1_2_RECV_PROVISION_003"><text>"Probabilidade &gt;= 30%. Usar regra apropriada (PROVISION-001 ou PROVISION-002)."</text></outputEntry>
<outputEntry id="OutputEntry_C1_3_RECV_PROVISION_003"><text>"SOLICITAR_PARECER"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_1_4_RECV_PROVISION_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_1_5_RECV_PROVISION_003"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_1_RECV_PROVISION_003">
        <description>Baixa probabilidade, constituir provisao de 100%</description>
        <inputEntry id="InputEntry_A1_1_RECV_PROVISION_003"><text>[0.10..0.30[</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_RECV_PROVISION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_RECV_PROVISION_003"><text>&lt;= 180</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_RECV_PROVISION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_RECV_PROVISION_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_RECV_PROVISION_003"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_RECV_PROVISION_003"><text>"Probabilidade baixa (10-30%). Constituir provisao de 100% do valor. Manter registro para eventual recuperacao."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_RECV_PROVISION_003"><text>"PROVISIONAR"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_1_4_RECV_PROVISION_003"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_1_5_RECV_PROVISION_003"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_2_RECV_PROVISION_003">
        <description>Probabilidade muito baixa, candidato a write-off</description>
        <inputEntry id="InputEntry_A2_1_RECV_PROVISION_003"><text>&lt; 0.10</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_RECV_PROVISION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_RECV_PROVISION_003"><text>&lt;= 365</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_RECV_PROVISION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_5_RECV_PROVISION_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_RECV_PROVISION_003"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_RECV_PROVISION_003"><text>"Probabilidade muito baixa (&lt;10%). Provisionar 100%. Avaliar criterios para write-off."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_RECV_PROVISION_003"><text>"PROVISIONAR"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_2_4_RECV_PROVISION_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_2_5_RECV_PROVISION_003"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_3_RECV_PROVISION_003">
        <description>Baixa probabilidade e recursos esgotados</description>
        <inputEntry id="InputEntry_A3_1_RECV_PROVISION_003"><text>&lt; 0.30</text></inputEntry>
        <inputEntry id="InputEntry_A3_2_RECV_PROVISION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_3_RECV_PROVISION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_4_RECV_PROVISION_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A3_5_RECV_PROVISION_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A3_1_RECV_PROVISION_003"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A3_2_RECV_PROVISION_003"><text>"Recursos esgotados com baixa probabilidade. Provisionar 100%. Encaminhar para avaliacao de write-off."</text></outputEntry>
<outputEntry id="OutputEntry_A3_3_RECV_PROVISION_003"><text>"BAIXAR"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_3_4_RECV_PROVISION_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_3_5_RECV_PROVISION_003"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_4_RECV_PROVISION_003">
        <description>Baixa probabilidade com aging &gt; 180 dias</description>
        <inputEntry id="InputEntry_A4_1_RECV_PROVISION_003"><text>&lt; 0.30</text></inputEntry>
        <inputEntry id="InputEntry_A4_2_RECV_PROVISION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A4_3_RECV_PROVISION_003"><text>&gt; 180</text></inputEntry>
        <inputEntry id="InputEntry_A4_4_RECV_PROVISION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A4_5_RECV_PROVISION_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_A4_1_RECV_PROVISION_003"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A4_2_RECV_PROVISION_003"><text>"Aging &gt; 180 dias com baixa probabilidade. Provisao 100% obrigatoria. Priorizar analise de write-off."</text></outputEntry>
<outputEntry id="OutputEntry_A4_3_RECV_PROVISION_003"><text>"BAIXAR"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_4_4_RECV_PROVISION_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_4_5_RECV_PROVISION_003"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_RECV_PROVISION_003">
        <description>Caso padrao - Provisionar e revisar</description>
        <inputEntry id="InputEntry_F_1_RECV_PROVISION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_RECV_PROVISION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_RECV_PROVISION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_RECV_PROVISION_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_RECV_PROVISION_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_RECV_PROVISION_003"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_RECV_PROVISION_003"><text>"Revisar classificacao. Constituir provisao de 100% como medida conservadora."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_RECV_PROVISION_003"><text>"PROVISIONAR"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_RECV_PROVISION_003_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_RECV_PROVISION_003_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RECV_PROVISION_003">
      <dmndi:DMNShape id="DMNShape_Decision_RECV_PROVISION_003" dmnElementRef="Decision_RECV_PROVISION_003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>