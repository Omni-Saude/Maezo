<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  RECV-KPI-003 - Indice Recuperacao Glosa
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: RECV-KPI
  Perspectiva: HOSPITAL (Receivables - Appeals Management)

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Lei 9.656/1998 (planos de saude)
  - RN ANS 395/2016 (recursos de glosa)
  - CPC 25 (provisoes)
  - IFRS 15 (reconhecimento de receita)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_RECV_KPI_003"
             name="Indice Recuperacao Glosa"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_RECV_KPI_003" name="[SP-RC-010 | revenue_recovery/kpi] Indice Recuperacao Glosa" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_RECV_KPI_003" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_RECV_KPI_003" label="Indice Recuperacao">
        <inputExpression id="InputExpression_1_RECV_KPI_003" typeRef="number">
          <text>indiceRecuperacao</text>
        </inputExpression>
      </input>


      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_RECV_KPI_003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_RECV_KPI_003" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_RECV_KPI_003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_RECV_KPI_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_RECV_KPI_003" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA P11: Prosseguir -->
      <rule id="Rule_P1_1_RECV_KPI_003">
        <description>Alta taxa de recuperacao de glosas.</description>
        <inputEntry id="InputEntry_P11_1_RECV_KPI_003"><text>indiceRecuperacao >= 0.7</text></inputEntry>
        <outputEntry id="OutputEntry_P11_1_RECV_KPI_003"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P11_2_RECV_KPI_003"><text>"Alta taxa de recuperacao de glosas."</text></outputEntry>
        <outputEntry id="OutputEntry_P11_3_RECV_KPI_003"><text>"Manter estrategia de recursos atual."</text></outputEntry>
        <outputEntry id="OutputEntry_P11_4_RECV_KPI_003"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P11_5_RECV_KPI_003"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA A12: Alertar -->
      <rule id="Rule_A1_2_RECV_KPI_003">
        <description>Baixa taxa de recuperacao.</description>
        <inputEntry id="InputEntry_A12_1_RECV_KPI_003"><text>indiceRecuperacao &lt; 0.5</text></inputEntry>
        <outputEntry id="OutputEntry_A12_1_RECV_KPI_003"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A12_2_RECV_KPI_003"><text>"Baixa taxa de recuperacao."</text></outputEntry>
        <outputEntry id="OutputEntry_A12_3_RECV_KPI_003"><text>"Revisar estrategia de recursos e argumentacao."</text></outputEntry>
        <outputEntry id="OutputEntry_A12_4_RECV_KPI_003"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_A12_5_RECV_KPI_003"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisao manual -->
      <rule id="Rule_Fallback_RECV_KPI_003">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_RECV_KPI_003"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_RECV_KPI_003"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_RECV_KPI_003"><text>"Situacao requer analise manual por nao corresponder a nenhum criterio automatico."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_RECV_KPI_003"><text>"Encaminhar para auditoria administrativa para avaliacao caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_RECV_KPI_003"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_RECV_KPI_003"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RECV_KPI_003">
      <dmndi:DMNShape id="DMNShape_Decision_RECV_KPI_003" dmnElementRef="Decision_RECV_KPI_003">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
