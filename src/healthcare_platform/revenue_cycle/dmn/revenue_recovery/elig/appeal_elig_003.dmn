<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  APPEAL-ELIG-003 - Documentacao Suporte Disponivel
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: APPEAL-ELIG
  Perspectiva: HOSPITAL (Receivables - Appeals Management)

  ============================================================================
  INDICACOES (Quando PROSSEGUIR):
  ============================================================================
  - Documentacao suporte completa e disponivel
  - Evidencias clinicas ou administrativas adequadas
  - Fundamentacao tecnica consistente

  ============================================================================
  CONTRAINDICACOES (Quando BLOQUEAR):
  ============================================================================
  - Ausencia de documentacao suporte
  - Impossibilidade de obter evidencias necessarias
  - Recurso sem fundamentacao viavel

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - RN ANS 395/2016 (documentacao recurso)
  - RN ANS 305/2012 (diretrizes assistenciais)
  - CFM Resolucao 1638/2002 (prontuario medico)
  - Lei 9.656/1998 Art. 12
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_APPEAL_ELIG_003"
             name="Documentacao Suporte Disponivel"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_APPEAL_ELIG_003" name="[SP-RC-010 | revenue_recovery/elig] Documentacao Suporte Disponivel" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_APPEAL_ELIG_003" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_APPEAL_ELIG_003" label="Tem Documentacao">
        <inputExpression id="InputExpression_1_APPEAL_ELIG_003" typeRef="boolean">
          <text>temDocumentacao</text>
        </inputExpression>
      </input>

      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_APPEAL_ELIG_003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_APPEAL_ELIG_003" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_APPEAL_ELIG_003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_APPEAL_ELIG_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_APPEAL_ELIG_003" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA B1: Bloqueio - Sem documentacao -->
      <rule id="Rule_Bloqueio_1_APPEAL_ELIG_003">
        <description>Documentacao suporte nao disponivel</description>
        <inputEntry id="InputEntry_B1_1_APPEAL_ELIG_003"><text>false</text></inputEntry>
        <outputEntry id="OutputEntry_B1_1_APPEAL_ELIG_003"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_2_APPEAL_ELIG_003"><text>"Documentacao suporte indisponivel. Recurso sem fundamentacao tecnica viavel. Alta probabilidade de rejeicao."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_3_APPEAL_ELIG_003"><text>"Aceitar glosa ou tentar obter documentacao complementar antes de prosseguir. Avaliar fonte alternativa de evidencias."</text></outputEntry>
        <outputEntry id="OutputEntry_B1_4_APPEAL_ELIG_003"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_B1_5_APPEAL_ELIG_003"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA P1: Aprovado - Documentacao disponivel -->
      <rule id="Rule_Aprovado_1_APPEAL_ELIG_003">
        <description>Documentacao suporte disponivel e completa</description>
        <inputEntry id="InputEntry_P1_1_APPEAL_ELIG_003"><text>true</text></inputEntry>
        <outputEntry id="OutputEntry_P1_1_APPEAL_ELIG_003"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_2_APPEAL_ELIG_003"><text>"Documentacao suporte disponivel. Fundamentacao tecnica viavel. Recurso elegivel para preparacao e apresentacao."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_3_APPEAL_ELIG_003"><text>"Prosseguir com preparacao do recurso. Organizar documentacao conforme checklist ANS. Anexar evidencias completas."</text></outputEntry>
        <outputEntry id="OutputEntry_P1_4_APPEAL_ELIG_003"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P1_5_APPEAL_ELIG_003"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisao manual -->
      <rule id="Rule_Fallback_APPEAL_ELIG_003">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_APPEAL_ELIG_003"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_APPEAL_ELIG_003"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_APPEAL_ELIG_003"><text>"Situacao requer analise manual para verificar disponibilidade e adequacao da documentacao suporte."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_APPEAL_ELIG_003"><text>"Encaminhar para auditoria medica para avaliar suficiencia da documentacao disponivel."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_APPEAL_ELIG_003"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_APPEAL_ELIG_003"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_APPEAL_ELIG_003">
      <dmndi:DMNShape id="DMNShape_Decision_APPEAL_ELIG_003" dmnElementRef="Decision_APPEAL_ELIG_003">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
