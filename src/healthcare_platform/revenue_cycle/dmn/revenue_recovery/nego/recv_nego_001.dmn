<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  RECV-NEGO-001 - Desconto Quitacao
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: RECV-NEGO
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_RECV_NEGO_001" name="Desconto Quitacao" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_RECV_NEGO_001" name="[SP-RC-010 | revenue_recovery/nego] Avaliacao Desconto para Quitacao" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_RECV_NEGO_001" hitPolicy="FIRST">

      
      <input id="Input_1_RECV_NEGO_001" label="Valor Original">
        <inputExpression id="InputExpression_1_RECV_NEGO_001" typeRef="number">
          <text>valorOriginal</text>
        </inputExpression>
      </input>

      <input id="Input_2_RECV_NEGO_001" label="Percentual Desconto">
        <inputExpression id="InputExpression_2_RECV_NEGO_001" typeRef="number">
          <text>percentualDesconto</text>
        </inputExpression>
      </input>

      <input id="Input_3_RECV_NEGO_001" label="Prazo Quitacao (dias)">
        <inputExpression id="InputExpression_3_RECV_NEGO_001" typeRef="number">
          <text>prazoQuitacao</text>
        </inputExpression>
      </input>

      <input id="Input_4_RECV_NEGO_001" label="Historico Operadora">
        <inputExpression id="InputExpression_4_RECV_NEGO_001" typeRef="string">
          <text>historicoOperadora</text>
        </inputExpression>
        <inputValues id="InputValues_4_RECV_NEGO_001">
          <text>"REGULAR", "IRREGULAR", "INADIMPLENTE"</text>
        </inputValues>
      </input>

      
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_RECV_NEGO_001" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_RECV_NEGO_001" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_RECV_NEGO_001" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_RECV_NEGO_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_RECV_NEGO_001" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Contraindicacao_1_RECV_NEGO_001">
        <description>Desconto superior a 30% com prazo superior a 30 dias</description>
        <inputEntry id="InputEntry_C1_1_RECV_NEGO_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C1_2_RECV_NEGO_001"><text>&gt; 30</text></inputEntry>
        <inputEntry id="InputEntry_C1_3_RECV_NEGO_001"><text>&gt; 30</text></inputEntry>
        <inputEntry id="InputEntry_C1_4_RECV_NEGO_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_C1_1_RECV_NEGO_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_C1_2_RECV_NEGO_001"><text>"Desconto superior a 30% com prazo acima de 30 dias nao permitido. CDC Art. 52 requer proporcionalidade entre desconto e antecipacao."</text></outputEntry>
<outputEntry id="OutputEntry_C1_3_RECV_NEGO_001"><text>"REJEITAR"</text></outputEntry>
<outputEntry id="Rule_Contraindicacao_1_outputEntry_alertasConformidade_RECV_NEGO_001"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Contraindicacao_1_outputEntry_riscoDenial_RECV_NEGO_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Contraindicacao_2_RECV_NEGO_001">
        <description>Operadora com historico de inadimplencia grave</description>
        <inputEntry id="InputEntry_C2_1_RECV_NEGO_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C2_2_RECV_NEGO_001"><text>&gt; 10</text></inputEntry>
        <inputEntry id="InputEntry_C2_3_RECV_NEGO_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C2_4_RECV_NEGO_001"><text>"INADIMPLENTE"</text></inputEntry>
<outputEntry id="OutputEntry_C2_1_RECV_NEGO_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_C2_2_RECV_NEGO_001"><text>"Operadora inadimplente nao elegivel para desconto superior a 10%. Exigir quitacao integral ou garantias adicionais."</text></outputEntry>
<outputEntry id="OutputEntry_C2_3_RECV_NEGO_001"><text>"REJEITAR"</text></outputEntry>
<outputEntry id="Rule_Contraindicacao_2_outputEntry_alertasConformidade_RECV_NEGO_001"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Contraindicacao_2_outputEntry_riscoDenial_RECV_NEGO_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Alerta_1_RECV_NEGO_001">
        <description>Desconto entre 20% e 30% requer aprovacao</description>
        <inputEntry id="InputEntry_A1_1_RECV_NEGO_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_RECV_NEGO_001"><text>[20..30]</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_RECV_NEGO_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_RECV_NEGO_001"><text>"REGULAR", "IRREGULAR"</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_RECV_NEGO_001"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_RECV_NEGO_001"><text>"Desconto entre 20% e 30% requer aprovacao da diretoria financeira. Verificar margem de contribuicao."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_RECV_NEGO_001"><text>"ESCALAR_DIRETORIA"</text></outputEntry>
<outputEntry id="Rule_Alerta_1_outputEntry_alertasConformidade_RECV_NEGO_001"><text>"VALOR"</text></outputEntry>
<outputEntry id="Rule_Alerta_1_outputEntry_riscoDenial_RECV_NEGO_001"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_1_RECV_NEGO_001">
        <description>Desconto ate 15% com quitacao em ate 15 dias</description>
        <inputEntry id="InputEntry_P1_1_RECV_NEGO_001"><text>&gt;= 1000</text></inputEntry>
        <inputEntry id="InputEntry_P1_2_RECV_NEGO_001"><text>&lt;= 15</text></inputEntry>
        <inputEntry id="InputEntry_P1_3_RECV_NEGO_001"><text>&lt;= 15</text></inputEntry>
        <inputEntry id="InputEntry_P1_4_RECV_NEGO_001"><text>"REGULAR"</text></inputEntry>
<outputEntry id="OutputEntry_P1_1_RECV_NEGO_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P1_2_RECV_NEGO_001"><text>"Desconto de ate 15% aprovado para quitacao em ate 15 dias. Operadora com historico regular."</text></outputEntry>
<outputEntry id="OutputEntry_P1_3_RECV_NEGO_001"><text>"APROVAR_DESCONTO"</text></outputEntry>
<outputEntry id="Rule_Aprovado_1_outputEntry_alertasConformidade_RECV_NEGO_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Aprovado_1_outputEntry_riscoDenial_RECV_NEGO_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_2_RECV_NEGO_001">
        <description>Desconto ate 20% com quitacao em ate 30 dias</description>
        <inputEntry id="InputEntry_P2_1_RECV_NEGO_001"><text>&gt;= 5000</text></inputEntry>
        <inputEntry id="InputEntry_P2_2_RECV_NEGO_001"><text>&lt;= 20</text></inputEntry>
        <inputEntry id="InputEntry_P2_3_RECV_NEGO_001"><text>&lt;= 30</text></inputEntry>
        <inputEntry id="InputEntry_P2_4_RECV_NEGO_001"><text>"REGULAR"</text></inputEntry>
<outputEntry id="OutputEntry_P2_1_RECV_NEGO_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_P2_2_RECV_NEGO_001"><text>"Desconto de ate 20% aprovado para valores acima de R$ 5.000 com quitacao em ate 30 dias."</text></outputEntry>
<outputEntry id="OutputEntry_P2_3_RECV_NEGO_001"><text>"APROVAR_DESCONTO"</text></outputEntry>
<outputEntry id="Rule_Aprovado_2_outputEntry_alertasConformidade_RECV_NEGO_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Aprovado_2_outputEntry_riscoDenial_RECV_NEGO_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_RECV_NEGO_001">
        <description>Caso nao atenda criterios automaticos - Contraproposta</description>
        <inputEntry id="InputEntry_F_1_RECV_NEGO_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_RECV_NEGO_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_RECV_NEGO_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_RECV_NEGO_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_RECV_NEGO_001"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_RECV_NEGO_001"><text>"Proposta de desconto requer analise manual. Avaliar valor, prazo e historico para contraproposta."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_RECV_NEGO_001"><text>"CONTRAPROPOSTA"</text></outputEntry>
<outputEntry id="Rule_Fallback_RECV_NEGO_001_outputEntry_alertasConformidade"><text>"NENHUM"</text></outputEntry>
<outputEntry id="Rule_Fallback_RECV_NEGO_001_outputEntry_riscoDenial"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RECV_NEGO_001">
      <dmndi:DMNShape id="DMNShape_Decision_RECV_NEGO_001" dmnElementRef="Decision_RECV_NEGO_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>