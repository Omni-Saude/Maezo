<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  RECV-GLOSA-012 - Glosa Parcial (Valor Reduzido)
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: RECV-GLOSA
  Perspectiva: HOSPITAL (Receivables - Appeals Management)

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Lei 9.656/1998 (planos de saude)
  - RN ANS 395/2016 (recursos de glosa)
  - CPC 25 (provisoes)
  - IFRS 15 (reconhecimento de receita)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_RECV_GLOSA_012"
             name="Glosa Parcial (Valor Reduzido)"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_RECV_GLOSA_012" name="[SP-RC-010 | revenue_recovery/glosa] Glosa Parcial (Valor Reduzido)" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_RECV_GLOSA_012" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_RECV_GLOSA_012" label="Valor Glosa">
        <inputExpression id="InputExpression_1_RECV_GLOSA_012" typeRef="number">
          <text>valorGlosa</text>
        </inputExpression>
      </input>

      <input id="Input_2_RECV_GLOSA_012" label="Valor Original">
        <inputExpression id="InputExpression_2_RECV_GLOSA_012" typeRef="number">
          <text>valorOriginal</text>
        </inputExpression>
      </input>


      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_RECV_GLOSA_012" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_RECV_GLOSA_012" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_RECV_GLOSA_012" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_RECV_GLOSA_012" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_RECV_GLOSA_012" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA A11: Alertar -->
      <rule id="Rule_A1_1_RECV_GLOSA_012">
        <description>Glosa parcial - menos de 50% do valor.</description>
        <inputEntry id="InputEntry_A11_1_RECV_GLOSA_012"><text>valorGlosa &lt; (valorOriginal * 0.5)</text></inputEntry>
        <inputEntry id="InputEntry_A11_2_RECV_GLOSA_012"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_A11_1_RECV_GLOSA_012"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A11_2_RECV_GLOSA_012"><text>"Glosa parcial - menos de 50% do valor."</text></outputEntry>
        <outputEntry id="OutputEntry_A11_3_RECV_GLOSA_012"><text>"Avaliar custo-beneficio de recorrer valor parcial."</text></outputEntry>
        <outputEntry id="OutputEntry_A11_4_RECV_GLOSA_012"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_A11_5_RECV_GLOSA_012"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA P12: Prosseguir -->
      <rule id="Rule_P1_2_RECV_GLOSA_012">
        <description>Glosa parcial significativa.</description>
        <inputEntry id="InputEntry_P12_1_RECV_GLOSA_012"><text>valorGlosa &gt;= (valorOriginal * 0.5)</text></inputEntry>
        <inputEntry id="InputEntry_P12_2_RECV_GLOSA_012"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_P12_1_RECV_GLOSA_012"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P12_2_RECV_GLOSA_012"><text>"Glosa parcial significativa."</text></outputEntry>
        <outputEntry id="OutputEntry_P12_3_RECV_GLOSA_012"><text>"Recurso justificavel pelo valor em questao."</text></outputEntry>
        <outputEntry id="OutputEntry_P12_4_RECV_GLOSA_012"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P12_5_RECV_GLOSA_012"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisao manual -->
      <rule id="Rule_Fallback_RECV_GLOSA_012">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_RECV_GLOSA_012"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_RECV_GLOSA_012"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_RECV_GLOSA_012"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_RECV_GLOSA_012"><text>"Situacao requer analise manual por nao corresponder a nenhum criterio automatico."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_RECV_GLOSA_012"><text>"Encaminhar para auditoria administrativa para avaliacao caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_RECV_GLOSA_012"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_RECV_GLOSA_012"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RECV_GLOSA_012">
      <dmndi:DMNShape id="DMNShape_Decision_RECV_GLOSA_012" dmnElementRef="Decision_RECV_GLOSA_012">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
