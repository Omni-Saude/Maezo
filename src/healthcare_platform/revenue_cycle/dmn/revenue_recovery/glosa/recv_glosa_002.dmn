<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  RECV-GLOSA-002 - Avaliacao de Glosa Tecnica
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: RECV-GLOSA
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_RECV_GLOSA_002" name="Avaliacao de Glosa Tecnica" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_RECV_GLOSA_002" name="[SP-RC-010 | revenue_recovery/glosa] Avaliacao Recurso Glosa Tecnica" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_RECV_GLOSA_002" hitPolicy="FIRST">

      
      <input id="Input_1_RECV_GLOSA_002" label="Categoria Glosa">
        <inputExpression id="InputExpression_1_RECV_GLOSA_002" typeRef="string">
          <text>categoriaGlosa</text>
        </inputExpression>
        <inputValues id="InputValues_1_RECV_GLOSA_002">
          <text>"ADMINISTRATIVA", "TECNICA", "MEDICA"</text>
        </inputValues>
      </input>

      <input id="Input_2_RECV_GLOSA_002" label="Motivo Glosa">
        <inputExpression id="InputExpression_2_RECV_GLOSA_002" typeRef="string">
          <text>motivoGlosa</text>
        </inputExpression>
      </input>

      <input id="Input_3_RECV_GLOSA_002" label="Valor Glosa">
        <inputExpression id="InputExpression_3_RECV_GLOSA_002" typeRef="number">
          <text>valorGlosa</text>
        </inputExpression>
      </input>

      <input id="Input_4_RECV_GLOSA_002" label="Tem Documentacao Adicional">
        <inputExpression id="InputExpression_4_RECV_GLOSA_002" typeRef="boolean">
          <text>temDocumentacaoAdicional</text>
        </inputExpression>
      </input>

      <input id="Input_5_RECV_GLOSA_002" label="Historico Recursos Operadora">
        <inputExpression id="InputExpression_5_RECV_GLOSA_002" typeRef="number">
          <text>historicoRecursosOperadora</text>
        </inputExpression>
      </input>

      <input id="Input_6_RECV_GLOSA_002" label="Dias Desde Glosa">
        <inputExpression id="InputExpression_6_RECV_GLOSA_002" typeRef="number">
          <text>diasDesdeGlosa</text>
        </inputExpression>
      </input>

      
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_RECV_GLOSA_002" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_RECV_GLOSA_002" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_RECV_GLOSA_002" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_RECV_GLOSA_002" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_RECV_GLOSA_002" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Contraindicacao_1_RECV_GLOSA_002">
        <description>Regra so aplica a glosas tecnicas</description>
        <inputEntry id="InputEntry_C1_1_RECV_GLOSA_002"><text>not("TECNICA")</text></inputEntry>
        <inputEntry id="InputEntry_C1_2_RECV_GLOSA_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C1_3_RECV_GLOSA_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C1_4_RECV_GLOSA_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C1_5_RECV_GLOSA_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C1_6_RECV_GLOSA_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_C1_1_RECV_GLOSA_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_C1_2_RECV_GLOSA_002"><text>"Esta regra so processa glosas tecnicas. Encaminhar para regra apropriada."</text></outputEntry>
<outputEntry id="OutputEntry_C1_3_RECV_GLOSA_002"><text>"SOLICITAR_PARECER"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_1_4_RECV_GLOSA_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_1_5_RECV_GLOSA_002"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Contraindicacao_2_RECV_GLOSA_002">
        <description>Prazo de recurso expirado</description>
        <inputEntry id="InputEntry_C2_1_RECV_GLOSA_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C2_2_RECV_GLOSA_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C2_3_RECV_GLOSA_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C2_4_RECV_GLOSA_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C2_5_RECV_GLOSA_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C2_6_RECV_GLOSA_002"><text>&gt; 60</text></inputEntry>
<outputEntry id="OutputEntry_C2_1_RECV_GLOSA_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_C2_2_RECV_GLOSA_002"><text>"Prazo de recurso expirado. Provisionar glosa."</text></outputEntry>
<outputEntry id="OutputEntry_C2_3_RECV_GLOSA_002"><text>"PROVISIONAR"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_2_4_RECV_GLOSA_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_2_5_RECV_GLOSA_002"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Contraindicacao_3_RECV_GLOSA_002">
        <description>Glosa por cobranca duplicada - sem recurso</description>
        <inputEntry id="InputEntry_C3_1_RECV_GLOSA_002"><text>"TECNICA"</text></inputEntry>
        <inputEntry id="InputEntry_C3_2_RECV_GLOSA_002"><text>"COBRANCA_DUPLICADA"</text></inputEntry>
        <inputEntry id="InputEntry_C3_3_RECV_GLOSA_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C3_4_RECV_GLOSA_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C3_5_RECV_GLOSA_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C3_6_RECV_GLOSA_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_C3_1_RECV_GLOSA_002"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_C3_2_RECV_GLOSA_002"><text>"Glosa por cobranca duplicada confirmada. Aceitar glosa."</text></outputEntry>
<outputEntry id="OutputEntry_C3_3_RECV_GLOSA_002"><text>"ACEITAR"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_3_4_RECV_GLOSA_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_3_5_RECV_GLOSA_002"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_1_RECV_GLOSA_002">
        <description>Glosa de quantidade com documentacao e historico favoravel</description>
        <inputEntry id="InputEntry_A1_1_RECV_GLOSA_002"><text>"TECNICA"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_RECV_GLOSA_002"><text>"QUANTIDADE_ACIMA_PADRAO"</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_RECV_GLOSA_002"><text>&gt;= 200</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_RECV_GLOSA_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_RECV_GLOSA_002"><text>&gt;= 50</text></inputEntry>
        <inputEntry id="InputEntry_A1_6_RECV_GLOSA_002"><text>&lt;= 30</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_RECV_GLOSA_002"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_RECV_GLOSA_002"><text>"Glosa de quantidade com justificativa clinica e historico favoravel com operadora. Recorrer com protocolo clinico."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_RECV_GLOSA_002"><text>"RECORRER"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_1_4_RECV_GLOSA_002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_1_5_RECV_GLOSA_002"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_2_RECV_GLOSA_002">
        <description>Cobranca separada de bundled com justificativa tecnica</description>
        <inputEntry id="InputEntry_A2_1_RECV_GLOSA_002"><text>"TECNICA"</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_RECV_GLOSA_002"><text>"COBRANCA_SEPARADA_BUNDLED"</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_RECV_GLOSA_002"><text>&gt;= 300</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_RECV_GLOSA_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_5_RECV_GLOSA_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_6_RECV_GLOSA_002"><text>&lt;= 45</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_RECV_GLOSA_002"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_RECV_GLOSA_002"><text>"Procedimento bundled realizado separadamente por motivo tecnico documentado. Recorrer com justificativa."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_RECV_GLOSA_002"><text>"RECORRER"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_2_4_RECV_GLOSA_002"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_2_5_RECV_GLOSA_002"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_3_RECV_GLOSA_002">
        <description>Glosa tecnica com documentacao adicional</description>
        <inputEntry id="InputEntry_A3_1_RECV_GLOSA_002"><text>"TECNICA"</text></inputEntry>
        <inputEntry id="InputEntry_A3_2_RECV_GLOSA_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_3_RECV_GLOSA_002"><text>&gt;= 150</text></inputEntry>
        <inputEntry id="InputEntry_A3_4_RECV_GLOSA_002"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A3_5_RECV_GLOSA_002"><text>&gt;= 40</text></inputEntry>
        <inputEntry id="InputEntry_A3_6_RECV_GLOSA_002"><text>&lt;= 45</text></inputEntry>
<outputEntry id="OutputEntry_A3_1_RECV_GLOSA_002"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A3_2_RECV_GLOSA_002"><text>"Glosa tecnica com documentacao disponivel. Avaliar custo-beneficio do recurso antes de prosseguir."</text></outputEntry>
<outputEntry id="OutputEntry_A3_3_RECV_GLOSA_002"><text>"RECORRER"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_3_4_RECV_GLOSA_002"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_3_5_RECV_GLOSA_002"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_RECV_GLOSA_002">
        <description>Caso padrao - Revisar manualmente</description>
        <inputEntry id="InputEntry_F_1_RECV_GLOSA_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_RECV_GLOSA_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_RECV_GLOSA_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_RECV_GLOSA_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_RECV_GLOSA_002"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_6_RECV_GLOSA_002"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_RECV_GLOSA_002"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_RECV_GLOSA_002"><text>"Glosa tecnica requer analise detalhada. Verificar justificativa tecnica, historico e custo-beneficio."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_RECV_GLOSA_002"><text>"SOLICITAR_PARECER"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_RECV_GLOSA_002_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_RECV_GLOSA_002_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RECV_GLOSA_002">
      <dmndi:DMNShape id="DMNShape_Decision_RECV_GLOSA_002" dmnElementRef="Decision_RECV_GLOSA_002">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>