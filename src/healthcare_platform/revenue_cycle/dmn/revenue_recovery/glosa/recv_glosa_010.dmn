<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  RECV-GLOSA-010 - Glosa por Material Nao Autorizado
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: RECV-GLOSA
  Perspectiva: HOSPITAL (Receivables - Appeals Management)

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Lei 9.656/1998 (planos de saude)
  - RN ANS 395/2016 (recursos de glosa)
  - CPC 25 (provisoes)
  - IFRS 15 (reconhecimento de receita)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_RECV_GLOSA_010"
             name="Glosa por Material Nao Autorizado"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_RECV_GLOSA_010" name="[SP-RC-010 | revenue_recovery/glosa] Glosa por Material Nao Autorizado" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_RECV_GLOSA_010" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_RECV_GLOSA_010" label="Motivo Glosa">
        <inputExpression id="InputExpression_1_RECV_GLOSA_010" typeRef="string">
          <text>motivoGlosa</text>
        </inputExpression>
      </input>

      <input id="Input_2_RECV_GLOSA_010" label="Material Autorizado">
        <inputExpression id="InputExpression_2_RECV_GLOSA_010" typeRef="boolean">
          <text>materialAutorizado</text>
        </inputExpression>
      </input>


      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_RECV_GLOSA_010" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_RECV_GLOSA_010" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_RECV_GLOSA_010" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_RECV_GLOSA_010" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_RECV_GLOSA_010" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA B11: Bloquear -->
      <rule id="Rule_B1_1_RECV_GLOSA_010">
        <description>Material nao autorizado previamente.</description>
        <inputEntry id="InputEntry_B11_1_RECV_GLOSA_010"><text>motivoGlosa == "MATERIAL" and not materialAutorizado</text></inputEntry>
        <inputEntry id="InputEntry_B11_2_RECV_GLOSA_010"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_B11_1_RECV_GLOSA_010"><text>"Bloquear"</text></outputEntry>
        <outputEntry id="OutputEntry_B11_2_RECV_GLOSA_010"><text>"Material nao autorizado previamente."</text></outputEntry>
        <outputEntry id="OutputEntry_B11_3_RECV_GLOSA_010"><text>"Aceitar glosa ou negociar retroativo."</text></outputEntry>
        <outputEntry id="OutputEntry_B11_4_RECV_GLOSA_010"><text>"DOC"</text></outputEntry>
        <outputEntry id="OutputEntry_B11_5_RECV_GLOSA_010"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- REGRA P12: Prosseguir -->
      <rule id="Rule_P1_2_RECV_GLOSA_010">
        <description>Material autorizado mas glosado incorretamente.</description>
        <inputEntry id="InputEntry_P12_1_RECV_GLOSA_010"><text>motivoGlosa == "MATERIAL" and materialAutorizado</text></inputEntry>
        <inputEntry id="InputEntry_P12_2_RECV_GLOSA_010"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_P12_1_RECV_GLOSA_010"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P12_2_RECV_GLOSA_010"><text>"Material autorizado mas glosado incorretamente."</text></outputEntry>
        <outputEntry id="OutputEntry_P12_3_RECV_GLOSA_010"><text>"Recurso com autorizacao anexa."</text></outputEntry>
        <outputEntry id="OutputEntry_P12_4_RECV_GLOSA_010"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P12_5_RECV_GLOSA_010"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisao manual -->
      <rule id="Rule_Fallback_RECV_GLOSA_010">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_RECV_GLOSA_010"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_RECV_GLOSA_010"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_RECV_GLOSA_010"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_RECV_GLOSA_010"><text>"Situacao requer analise manual por nao corresponder a nenhum criterio automatico."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_RECV_GLOSA_010"><text>"Encaminhar para auditoria administrativa para avaliacao caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_RECV_GLOSA_010"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_RECV_GLOSA_010"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RECV_GLOSA_010">
      <dmndi:DMNShape id="DMNShape_Decision_RECV_GLOSA_010" dmnElementRef="Decision_RECV_GLOSA_010">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
