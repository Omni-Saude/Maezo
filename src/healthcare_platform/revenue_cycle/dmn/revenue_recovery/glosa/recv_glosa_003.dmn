<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  RECV-GLOSA-003 - Avaliacao de Glosa Medica
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: RECV-GLOSA
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_RECV_GLOSA_003" name="Avaliacao de Glosa Medica" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_RECV_GLOSA_003" name="[SP-RC-010 | revenue_recovery/glosa] Avaliacao Recurso Glosa Medica" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_RECV_GLOSA_003" hitPolicy="FIRST">

      
      <input id="Input_1_RECV_GLOSA_003" label="Categoria Glosa">
        <inputExpression id="InputExpression_1_RECV_GLOSA_003" typeRef="string">
          <text>categoriaGlosa</text>
        </inputExpression>
        <inputValues id="InputValues_1_RECV_GLOSA_003">
          <text>"ADMINISTRATIVA", "TECNICA", "MEDICA"</text>
        </inputValues>
      </input>

      <input id="Input_2_RECV_GLOSA_003" label="Motivo Glosa">
        <inputExpression id="InputExpression_2_RECV_GLOSA_003" typeRef="string">
          <text>motivoGlosa</text>
        </inputExpression>
      </input>

      <input id="Input_3_RECV_GLOSA_003" label="Valor Glosa">
        <inputExpression id="InputExpression_3_RECV_GLOSA_003" typeRef="number">
          <text>valorGlosa</text>
        </inputExpression>
      </input>

      <input id="Input_4_RECV_GLOSA_003" label="Tem Documentacao Adicional">
        <inputExpression id="InputExpression_4_RECV_GLOSA_003" typeRef="boolean">
          <text>temDocumentacaoAdicional</text>
        </inputExpression>
      </input>

      <input id="Input_5_RECV_GLOSA_003" label="Historico Recursos Operadora">
        <inputExpression id="InputExpression_5_RECV_GLOSA_003" typeRef="number">
          <text>historicoRecursosOperadora</text>
        </inputExpression>
      </input>

      <input id="Input_6_RECV_GLOSA_003" label="Dias Desde Glosa">
        <inputExpression id="InputExpression_6_RECV_GLOSA_003" typeRef="number">
          <text>diasDesdeGlosa</text>
        </inputExpression>
      </input>

      
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_RECV_GLOSA_003" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_RECV_GLOSA_003" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_RECV_GLOSA_003" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_RECV_GLOSA_003" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_RECV_GLOSA_003" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Contraindicacao_1_RECV_GLOSA_003">
        <description>Regra so aplica a glosas medicas</description>
        <inputEntry id="InputEntry_C1_1_RECV_GLOSA_003"><text>not("MEDICA")</text></inputEntry>
        <inputEntry id="InputEntry_C1_2_RECV_GLOSA_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C1_3_RECV_GLOSA_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C1_4_RECV_GLOSA_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C1_5_RECV_GLOSA_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C1_6_RECV_GLOSA_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_C1_1_RECV_GLOSA_003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_C1_2_RECV_GLOSA_003"><text>"Esta regra so processa glosas medicas. Encaminhar para regra apropriada."</text></outputEntry>
<outputEntry id="OutputEntry_C1_3_RECV_GLOSA_003"><text>"SOLICITAR_PARECER"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_1_4_RECV_GLOSA_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_1_5_RECV_GLOSA_003"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Contraindicacao_2_RECV_GLOSA_003">
        <description>Prazo de recurso expirado</description>
        <inputEntry id="InputEntry_C2_1_RECV_GLOSA_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C2_2_RECV_GLOSA_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C2_3_RECV_GLOSA_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C2_4_RECV_GLOSA_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C2_5_RECV_GLOSA_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C2_6_RECV_GLOSA_003"><text>&gt; 60</text></inputEntry>
<outputEntry id="OutputEntry_C2_1_RECV_GLOSA_003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_C2_2_RECV_GLOSA_003"><text>"Prazo de recurso expirado. Provisionar glosa."</text></outputEntry>
<outputEntry id="OutputEntry_C2_3_RECV_GLOSA_003"><text>"PROVISIONAR"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_2_4_RECV_GLOSA_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_2_5_RECV_GLOSA_003"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Contraindicacao_3_RECV_GLOSA_003">
        <description>Procedimento fora de cobertura sem documentacao de excecao</description>
        <inputEntry id="InputEntry_C3_1_RECV_GLOSA_003"><text>"MEDICA"</text></inputEntry>
        <inputEntry id="InputEntry_C3_2_RECV_GLOSA_003"><text>"SEM_COBERTURA_CONTRATUAL"</text></inputEntry>
        <inputEntry id="InputEntry_C3_3_RECV_GLOSA_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C3_4_RECV_GLOSA_003"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_C3_5_RECV_GLOSA_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C3_6_RECV_GLOSA_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_C3_1_RECV_GLOSA_003"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_C3_2_RECV_GLOSA_003"><text>"Procedimento sem cobertura contratual e sem documentacao de excecao. Baixa probabilidade de reversao."</text></outputEntry>
<outputEntry id="OutputEntry_C3_3_RECV_GLOSA_003"><text>"ACEITAR"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_3_4_RECV_GLOSA_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_3_5_RECV_GLOSA_003"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_1_RECV_GLOSA_003">
        <description>Glosa medica em urgencia/emergencia com parecer especializado</description>
        <inputEntry id="InputEntry_A1_1_RECV_GLOSA_003"><text>"MEDICA"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_RECV_GLOSA_003"><text>"PROCEDIMENTO_NAO_INDICADO"</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_RECV_GLOSA_003"><text>&gt;= 1000</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_RECV_GLOSA_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_5_RECV_GLOSA_003"><text>&gt;= 30</text></inputEntry>
        <inputEntry id="InputEntry_A1_6_RECV_GLOSA_003"><text>&lt;= 30</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_RECV_GLOSA_003"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_RECV_GLOSA_003"><text>"Glosa medica com valor significativo e parecer especializado. Recorrer com documentacao clinica robusta."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_RECV_GLOSA_003"><text>"RECORRER"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_1_4_RECV_GLOSA_003"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_1_5_RECV_GLOSA_003"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_2_RECV_GLOSA_003">
        <description>Sem cobertura mas com indicacao clinica documentada</description>
        <inputEntry id="InputEntry_A2_1_RECV_GLOSA_003"><text>"MEDICA"</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_RECV_GLOSA_003"><text>"SEM_COBERTURA_CONTRATUAL"</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_RECV_GLOSA_003"><text>&gt;= 2000</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_RECV_GLOSA_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A2_5_RECV_GLOSA_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A2_6_RECV_GLOSA_003"><text>&lt;= 45</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_RECV_GLOSA_003"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_RECV_GLOSA_003"><text>"Procedimento sem cobertura padrao mas com indicacao clinica. Avaliar via judicial ou ANS."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_RECV_GLOSA_003"><text>"SOLICITAR_PARECER"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_2_4_RECV_GLOSA_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_2_5_RECV_GLOSA_003"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_3_RECV_GLOSA_003">
        <description>Glosa medica com documentacao e valor relevante</description>
        <inputEntry id="InputEntry_A3_1_RECV_GLOSA_003"><text>"MEDICA"</text></inputEntry>
        <inputEntry id="InputEntry_A3_2_RECV_GLOSA_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_3_RECV_GLOSA_003"><text>&gt;= 500</text></inputEntry>
        <inputEntry id="InputEntry_A3_4_RECV_GLOSA_003"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A3_5_RECV_GLOSA_003"><text>&gt;= 25</text></inputEntry>
        <inputEntry id="InputEntry_A3_6_RECV_GLOSA_003"><text>&lt;= 45</text></inputEntry>
<outputEntry id="OutputEntry_A3_1_RECV_GLOSA_003"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A3_2_RECV_GLOSA_003"><text>"Glosa medica com documentacao. Solicitar parecer medico detalhado antes de recurso."</text></outputEntry>
<outputEntry id="OutputEntry_A3_3_RECV_GLOSA_003"><text>"SOLICITAR_PARECER"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_3_4_RECV_GLOSA_003"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_3_5_RECV_GLOSA_003"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_RECV_GLOSA_003">
        <description>Caso padrao - Revisar com especialista</description>
        <inputEntry id="InputEntry_F_1_RECV_GLOSA_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_RECV_GLOSA_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_RECV_GLOSA_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_RECV_GLOSA_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_5_RECV_GLOSA_003"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_6_RECV_GLOSA_003"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_RECV_GLOSA_003"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_RECV_GLOSA_003"><text>"Glosa medica requer parecer de auditor medico. Encaminhar para analise especializada."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_RECV_GLOSA_003"><text>"SOLICITAR_PARECER"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_RECV_GLOSA_003_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_RECV_GLOSA_003_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RECV_GLOSA_003">
      <dmndi:DMNShape id="DMNShape_Decision_RECV_GLOSA_003" dmnElementRef="Decision_RECV_GLOSA_003">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>