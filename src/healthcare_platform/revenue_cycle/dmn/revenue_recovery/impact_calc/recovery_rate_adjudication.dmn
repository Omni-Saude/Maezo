<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_recovery_rate_adjudication"
             name="Recovery Rate Adjudication"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Recovery Rate Adjudication
       For: calculate_glosa_impact_worker
       Archetype: ADMIN_ADJUDICATION
       Purpose: Determine recovery viability based on glosa type and denial percentage
  -->

  <decision id="Decision_recovery_rate_adjudication" name="[SP-RC-010 | revenue_recovery/impact_calc] Recovery Rate Adjudication" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_recovery_rate_adjudication" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_1_recovery_rate_adjudication" label="Glosa Type">
        <inputExpression id="InputExpr_1_recovery_rate_adjudication" typeRef="string">
          <text>glosaType</text>
        </inputExpression>
      </input>

      <input id="Input_2_recovery_rate_adjudication" label="Denial Percentage">
        <inputExpression id="InputExpr_2_recovery_rate_adjudication" typeRef="number">
          <text>denialPercentage</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado_recovery_rate_adjudication" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_recovery_rate_adjudication" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_recovery_rate_adjudication" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Glosa total sem recuperação -->
      <rule id="Rule_1_recovery_rate_adjudication">
        <description>Glosa total sem recuperação</description>
        <inputEntry id="IE_1_1_recovery_rate_adjudication"><text>"TOTAL"</text></inputEntry>
        <inputEntry id="IE_1_2_recovery_rate_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_1_res_recovery_rate_adjudication"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_acao_recovery_rate_adjudication"><text>"Glosa total sem recuperação"</text></outputEntry>
        <outputEntry id="OE_1_risco_recovery_rate_adjudication"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Administrative - alto percentual -->
      <rule id="Rule_2_recovery_rate_adjudication">
        <description>Alto percentual administrativo - revisar</description>
        <inputEntry id="IE_2_1_recovery_rate_adjudication"><text>"ADMINISTRATIVE"</text></inputEntry>
        <inputEntry id="IE_2_2_recovery_rate_adjudication"><text>&gt;= 50</text></inputEntry>
        <outputEntry id="OE_2_res_recovery_rate_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_2_acao_recovery_rate_adjudication"><text>"Alto percentual negado - revisar"</text></outputEntry>
        <outputEntry id="OE_2_risco_recovery_rate_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Administrative - recuperação viável -->
      <rule id="Rule_3_recovery_rate_adjudication">
        <description>Recuperação administrativa viável</description>
        <inputEntry id="IE_3_1_recovery_rate_adjudication"><text>"ADMINISTRATIVE"</text></inputEntry>
        <inputEntry id="IE_3_2_recovery_rate_adjudication"><text>&lt; 50</text></inputEntry>
        <outputEntry id="OE_3_res_recovery_rate_adjudication"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_3_acao_recovery_rate_adjudication"><text>"Recuperação administrativa viável"</text></outputEntry>
        <outputEntry id="OE_3_risco_recovery_rate_adjudication"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Technical - alto percentual -->
      <rule id="Rule_4_recovery_rate_adjudication">
        <description>Percentual técnico alto - avaliar</description>
        <inputEntry id="IE_4_1_recovery_rate_adjudication"><text>"TECHNICAL"</text></inputEntry>
        <inputEntry id="IE_4_2_recovery_rate_adjudication"><text>&gt;= 30</text></inputEntry>
        <outputEntry id="OE_4_res_recovery_rate_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_4_acao_recovery_rate_adjudication"><text>"Percentual técnico alto - avaliar"</text></outputEntry>
        <outputEntry id="OE_4_risco_recovery_rate_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Technical - recuperação viável -->
      <rule id="Rule_5_recovery_rate_adjudication">
        <description>Recuperação técnica viável</description>
        <inputEntry id="IE_5_1_recovery_rate_adjudication"><text>"TECHNICAL"</text></inputEntry>
        <inputEntry id="IE_5_2_recovery_rate_adjudication"><text>&lt; 30</text></inputEntry>
        <outputEntry id="OE_5_res_recovery_rate_adjudication"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_5_acao_recovery_rate_adjudication"><text>"Recuperação técnica viável"</text></outputEntry>
        <outputEntry id="OE_5_risco_recovery_rate_adjudication"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 6: Linear - ajuste aplicável -->
      <rule id="Rule_6_recovery_rate_adjudication">
        <description>Ajuste linear aplicável</description>
        <inputEntry id="IE_6_1_recovery_rate_adjudication"><text>"LINEAR"</text></inputEntry>
        <inputEntry id="IE_6_2_recovery_rate_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_6_res_recovery_rate_adjudication"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_6_acao_recovery_rate_adjudication"><text>"Ajuste linear aplicável"</text></outputEntry>
        <outputEntry id="OE_6_risco_recovery_rate_adjudication"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Rule 7: Partial - avaliação necessária -->
      <rule id="Rule_7_recovery_rate_adjudication">
        <description>Avaliação de recuperação parcial</description>
        <inputEntry id="IE_7_1_recovery_rate_adjudication"><text>"PARTIAL"</text></inputEntry>
        <inputEntry id="IE_7_2_recovery_rate_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_7_res_recovery_rate_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_7_acao_recovery_rate_adjudication"><text>"Avaliação de recuperação parcial"</text></outputEntry>
        <outputEntry id="OE_7_risco_recovery_rate_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="Rule_fallback_recovery_rate_adjudication">
        <description>Caso não enquadrado — revisão obrigatória</description>
        <inputEntry id="IE_fb_1_recovery_rate_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2_recovery_rate_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res_recovery_rate_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao_recovery_rate_adjudication"><text>"Caso requer avaliação manual"</text></outputEntry>
        <outputEntry id="OE_fb_risco_recovery_rate_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1_recovery_rate_adjudication">
      <dmndi:DMNShape id="DMNShape_Decision_recovery_rate_adjudication" dmnElementRef="Decision_recovery_rate_adjudication">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
