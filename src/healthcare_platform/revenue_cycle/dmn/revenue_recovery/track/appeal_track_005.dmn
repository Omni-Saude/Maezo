<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  APPEAL-TRACK-005 - Dashboard KPI Recursos de Glosa
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: APPEAL-TRACK
  Perspectiva: HOSPITAL (Receivables - Appeals Management)

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Lei 9.656/1998 (planos de saude)
  - RN ANS 395/2016 (recursos de glosa)
  - CPC 25 (provisoes)
  - IFRS 15 (reconhecimento de receita)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_APPEAL_TRACK_005"
             name="Dashboard KPI Recursos de Glosa"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_APPEAL_TRACK_005" name="[SP-RC-010 | revenue_recovery/track] Dashboard KPI Recursos de Glosa" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_APPEAL_TRACK_005" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_APPEAL_TRACK_005" label="KPI Meta">
        <inputExpression id="InputExpression_1_APPEAL_TRACK_005" typeRef="number">
          <text>kpiMeta</text>
        </inputExpression>
      </input>


      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_APPEAL_TRACK_005" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_APPEAL_TRACK_005" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_APPEAL_TRACK_005" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_APPEAL_TRACK_005" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_APPEAL_TRACK_005" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA P11: Prosseguir -->
      <rule id="Rule_P1_1_APPEAL_TRACK_005">
        <description>KPI de recursos acima da meta.</description>
        <inputEntry id="InputEntry_P11_1_APPEAL_TRACK_005"><text>kpiMeta >= 0.8</text></inputEntry>
        <outputEntry id="OutputEntry_P11_1_APPEAL_TRACK_005"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P11_2_APPEAL_TRACK_005"><text>"KPI de recursos acima da meta."</text></outputEntry>
        <outputEntry id="OutputEntry_P11_3_APPEAL_TRACK_005"><text>"Manter estrategia atual de recursos."</text></outputEntry>
        <outputEntry id="OutputEntry_P11_4_APPEAL_TRACK_005"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P11_5_APPEAL_TRACK_005"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA A12: Alertar -->
      <rule id="Rule_A1_2_APPEAL_TRACK_005">
        <description>KPI de recursos abaixo da meta.</description>
        <inputEntry id="InputEntry_A12_1_APPEAL_TRACK_005"><text>kpiMeta &lt; 0.6</text></inputEntry>
        <outputEntry id="OutputEntry_A12_1_APPEAL_TRACK_005"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A12_2_APPEAL_TRACK_005"><text>"KPI de recursos abaixo da meta."</text></outputEntry>
        <outputEntry id="OutputEntry_A12_3_APPEAL_TRACK_005"><text>"Revisar estrategia e processos de recurso."</text></outputEntry>
        <outputEntry id="OutputEntry_A12_4_APPEAL_TRACK_005"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_A12_5_APPEAL_TRACK_005"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisao manual -->
      <rule id="Rule_Fallback_APPEAL_TRACK_005">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_APPEAL_TRACK_005"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_APPEAL_TRACK_005"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_APPEAL_TRACK_005"><text>"Situacao requer analise manual por nao corresponder a nenhum criterio automatico."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_APPEAL_TRACK_005"><text>"Encaminhar para auditoria administrativa para avaliacao caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_APPEAL_TRACK_005"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_APPEAL_TRACK_005"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_APPEAL_TRACK_005">
      <dmndi:DMNShape id="DMNShape_Decision_APPEAL_TRACK_005" dmnElementRef="Decision_APPEAL_TRACK_005">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
