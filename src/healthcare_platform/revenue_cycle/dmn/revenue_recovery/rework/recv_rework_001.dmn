<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  RECV-REWORK-001 - Roteamento de Correcao Simples
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: RECV-REWORK
  Perspectiva: HOSPITAL (Administrativo)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_RECV_REWORK_001" name="Roteamento de Correcao Simples" namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_RECV_REWORK_001" name="[SP-RC-010 | revenue_recovery/rework] Roteamento para Correcao Documental" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_RECV_REWORK_001" hitPolicy="FIRST">

      
      <input id="Input_1_RECV_REWORK_001" label="Tipo Correcao">
        <inputExpression id="InputExpression_1_RECV_REWORK_001" typeRef="string">
          <text>tipoCorrecao</text>
        </inputExpression>
        <inputValues id="InputValues_1_RECV_REWORK_001">
          <text>"DOCUMENTACAO", "CODIFICACAO", "JUSTIFICATIVA_CLINICA", "MULTIPLO"</text>
        </inputValues>
      </input>

      <input id="Input_2_RECV_REWORK_001" label="Complexidade Correcao">
        <inputExpression id="InputExpression_2_RECV_REWORK_001" typeRef="string">
          <text>complexidadeCorrecao</text>
        </inputExpression>
        <inputValues id="InputValues_2_RECV_REWORK_001">
          <text>"SIMPLES", "MEDIA", "COMPLEXA"</text>
        </inputValues>
      </input>

      <input id="Input_3_RECV_REWORK_001" label="Tem Modelo Correcao">
        <inputExpression id="InputExpression_3_RECV_REWORK_001" typeRef="boolean">
          <text>temModeloCorrecao</text>
        </inputExpression>
      </input>

      <input id="Input_4_RECV_REWORK_001" label="Prazo Reapresentacao (dias)">
        <inputExpression id="InputExpression_4_RECV_REWORK_001" typeRef="number">
          <text>prazoReapresentacao</text>
        </inputExpression>
      </input>

      
      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_RECV_REWORK_001" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_RECV_REWORK_001" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_RECV_REWORK_001" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_RECV_REWORK_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_RECV_REWORK_001" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->
<rule id="Rule_Contraindicacao_1_RECV_REWORK_001">
        <description>Esta regra so trata correcoes de documentacao</description>
        <inputEntry id="InputEntry_C1_1_RECV_REWORK_001"><text>not("DOCUMENTACAO")</text></inputEntry>
        <inputEntry id="InputEntry_C1_2_RECV_REWORK_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C1_3_RECV_REWORK_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C1_4_RECV_REWORK_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_C1_1_RECV_REWORK_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_C1_2_RECV_REWORK_001"><text>"Tipo de correcao nao e documentacao simples. Encaminhar para regra apropriada."</text></outputEntry>
<outputEntry id="OutputEntry_C1_3_RECV_REWORK_001"><text>"SOLICITAR_PARECER"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_1_4_RECV_REWORK_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_1_5_RECV_REWORK_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Contraindicacao_2_RECV_REWORK_001">
        <description>Prazo de reapresentacao expirado</description>
        <inputEntry id="InputEntry_C2_1_RECV_REWORK_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C2_2_RECV_REWORK_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C2_3_RECV_REWORK_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C2_4_RECV_REWORK_001"><text>&lt;= 0</text></inputEntry>
<outputEntry id="OutputEntry_C2_1_RECV_REWORK_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_C2_2_RECV_REWORK_001"><text>"Prazo de reapresentacao expirado. Provisionar glosa."</text></outputEntry>
<outputEntry id="OutputEntry_C2_3_RECV_REWORK_001"><text>"PROVISIONAR"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_2_4_RECV_REWORK_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_2_5_RECV_REWORK_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Contraindicacao_3_RECV_REWORK_001">
        <description>Correcao nao e simples</description>
        <inputEntry id="InputEntry_C3_1_RECV_REWORK_001"><text>"DOCUMENTACAO"</text></inputEntry>
        <inputEntry id="InputEntry_C3_2_RECV_REWORK_001"><text>not("SIMPLES")</text></inputEntry>
        <inputEntry id="InputEntry_C3_3_RECV_REWORK_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_C3_4_RECV_REWORK_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_C3_1_RECV_REWORK_001"><text>"Bloquear"</text></outputEntry>
<outputEntry id="OutputEntry_C3_2_RECV_REWORK_001"><text>"Complexidade de correcao nao e simples. Encaminhar para analise especializada."</text></outputEntry>
<outputEntry id="OutputEntry_C3_3_RECV_REWORK_001"><text>"SOLICITAR_PARECER"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_3_4_RECV_REWORK_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Contraindicacao_3_5_RECV_REWORK_001"><text>"ALTO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_1_RECV_REWORK_001">
        <description>Correcao documental simples com modelo disponivel</description>
        <inputEntry id="InputEntry_A1_1_RECV_REWORK_001"><text>"DOCUMENTACAO"</text></inputEntry>
        <inputEntry id="InputEntry_A1_2_RECV_REWORK_001"><text>"SIMPLES"</text></inputEntry>
        <inputEntry id="InputEntry_A1_3_RECV_REWORK_001"><text>true</text></inputEntry>
        <inputEntry id="InputEntry_A1_4_RECV_REWORK_001"><text>&gt;= 15</text></inputEntry>
<outputEntry id="OutputEntry_A1_1_RECV_REWORK_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_A1_2_RECV_REWORK_001"><text>"Correcao simples com modelo padrao. Roteando para equipe de faturamento. SLA: 3 dias uteis."</text></outputEntry>
<outputEntry id="OutputEntry_A1_3_RECV_REWORK_001"><text>"RECORRER"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_1_4_RECV_REWORK_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_1_5_RECV_REWORK_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_2_RECV_REWORK_001">
        <description>Correcao documental simples sem modelo padrao</description>
        <inputEntry id="InputEntry_A2_1_RECV_REWORK_001"><text>"DOCUMENTACAO"</text></inputEntry>
        <inputEntry id="InputEntry_A2_2_RECV_REWORK_001"><text>"SIMPLES"</text></inputEntry>
        <inputEntry id="InputEntry_A2_3_RECV_REWORK_001"><text>false</text></inputEntry>
        <inputEntry id="InputEntry_A2_4_RECV_REWORK_001"><text>&gt;= 20</text></inputEntry>
<outputEntry id="OutputEntry_A2_1_RECV_REWORK_001"><text>"Prosseguir"</text></outputEntry>
<outputEntry id="OutputEntry_A2_2_RECV_REWORK_001"><text>"Correcao simples sem modelo. Roteando para faturamento senior. SLA: 5 dias uteis."</text></outputEntry>
<outputEntry id="OutputEntry_A2_3_RECV_REWORK_001"><text>"RECORRER"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_2_4_RECV_REWORK_001"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_2_5_RECV_REWORK_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Aprovado_3_RECV_REWORK_001">
        <description>Correcao simples com prazo curto - urgente</description>
        <inputEntry id="InputEntry_A3_1_RECV_REWORK_001"><text>"DOCUMENTACAO"</text></inputEntry>
        <inputEntry id="InputEntry_A3_2_RECV_REWORK_001"><text>"SIMPLES"</text></inputEntry>
        <inputEntry id="InputEntry_A3_3_RECV_REWORK_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_A3_4_RECV_REWORK_001"><text>[5..15[</text></inputEntry>
<outputEntry id="OutputEntry_A3_1_RECV_REWORK_001"><text>"Alertar"</text></outputEntry>
<outputEntry id="OutputEntry_A3_2_RECV_REWORK_001"><text>"Correcao simples com prazo curto. URGENTE: Priorizar processamento imediato."</text></outputEntry>
<outputEntry id="OutputEntry_A3_3_RECV_REWORK_001"><text>"RECORRER"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_3_4_RECV_REWORK_001"><text>"DOC"</text></outputEntry>
<outputEntry id="OutputEntry_Aprovado_3_5_RECV_REWORK_001"><text>"MEDIO"</text></outputEntry>
      </rule>

      
      <rule id="Rule_Fallback_RECV_REWORK_001">
        <description>Caso padrao - Revisar roteamento</description>
        <inputEntry id="InputEntry_F_1_RECV_REWORK_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_RECV_REWORK_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_3_RECV_REWORK_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_4_RECV_REWORK_001"><text>-</text></inputEntry>
<outputEntry id="OutputEntry_F_1_RECV_REWORK_001"><text>"Revisar"</text></outputEntry>
<outputEntry id="OutputEntry_F_2_RECV_REWORK_001"><text>"Verificar tipo de correcao, complexidade e prazo para roteamento adequado."</text></outputEntry>
<outputEntry id="OutputEntry_F_3_RECV_REWORK_001"><text>"SOLICITAR_PARECER"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_RECV_REWORK_001_4"><text>"NENHUM"</text></outputEntry>
<outputEntry id="OutputEntry_Fallback_RECV_REWORK_001_5"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RECV_REWORK_001">
      <dmndi:DMNShape id="DMNShape_Decision_RECV_REWORK_001" dmnElementRef="Decision_RECV_REWORK_001">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>