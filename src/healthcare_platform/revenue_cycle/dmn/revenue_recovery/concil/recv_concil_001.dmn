<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  RECV-CONCIL-001 - Conciliacao Bancaria Automatica
  ============================================================================
  Versao: 1.0.0 (2026-02-08)
  Categoria: RECV-CONCIL
  Perspectiva: HOSPITAL (Receivables - Appeals Management)

  ============================================================================
  REFERENCIAS NORMATIVAS:
  ============================================================================
  - Lei 9.656/1998 (planos de saude)
  - RN ANS 395/2016 (recursos de glosa)
  - CPC 25 (provisoes)
  - IFRS 15 (reconhecimento de receita)
  ============================================================================
-->
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_RECV_CONCIL_001"
             name="Conciliacao Bancaria Automatica"
             namespace="http://camunda.org/schema/1.0/dmn">

  <decision id="Decision_RECV_CONCIL_001" name="[SP-RC-010 | revenue_recovery/concil] Conciliacao Bancaria Automatica" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_RECV_CONCIL_001" hitPolicy="FIRST">

      <!-- ========== INPUTS ========== -->
      <input id="Input_1_RECV_CONCIL_001" label="Valor Pago">
        <inputExpression id="InputExpression_1_RECV_CONCIL_001" typeRef="number">
          <text>valorPago</text>
        </inputExpression>
      </input>

      <input id="Input_2_RECV_CONCIL_001" label="Valor Faturado">
        <inputExpression id="InputExpression_2_RECV_CONCIL_001" typeRef="number">
          <text>valorFaturado</text>
        </inputExpression>
      </input>


      <!-- ========== OUTPUTS (5 STANDARD) ========== -->
      <output id="Output_1_RECV_CONCIL_001" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"Prosseguir", "Bloquear", "Alertar", "Revisar"</text></outputValues>
      </output>

      <output id="Output_2_RECV_CONCIL_001" label="Observacao" name="observacao" typeRef="string"/>

      <output id="Output_3_RECV_CONCIL_001" label="Acao Recomendada" name="acaoRecomendada" typeRef="string"/>

      <output id="Output_4_RECV_CONCIL_001" label="Alertas Conformidade" name="alertasConformidade" typeRef="string">
        <outputValues><text>"NENHUM", "DUP", "FREQ", "PRAZO", "DOC", "VALOR", "CRED", "CONTRATO"</text></outputValues>
      </output>

      <output id="Output_5_RECV_CONCIL_001" label="Risco Denial" name="riscoDenial" typeRef="string">
        <outputValues><text>"BAIXO", "MEDIO", "ALTO", "CRITICO"</text></outputValues>
      </output>

      <!-- ========== RULES ========== -->

      <!-- REGRA P11: Prosseguir -->
      <rule id="Rule_P1_1_RECV_CONCIL_001">
        <description>Conciliacao automatica bem-sucedida.</description>
        <inputEntry id="InputEntry_P11_1_RECV_CONCIL_001"><text>valorPago == valorFaturado</text></inputEntry>
        <inputEntry id="InputEntry_P11_2_RECV_CONCIL_001"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_P11_1_RECV_CONCIL_001"><text>"Prosseguir"</text></outputEntry>
        <outputEntry id="OutputEntry_P11_2_RECV_CONCIL_001"><text>"Conciliacao automatica bem-sucedida."</text></outputEntry>
        <outputEntry id="OutputEntry_P11_3_RECV_CONCIL_001"><text>"Baixar recebivel automaticamente."</text></outputEntry>
        <outputEntry id="OutputEntry_P11_4_RECV_CONCIL_001"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_P11_5_RECV_CONCIL_001"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- REGRA A12: Alertar -->
      <rule id="Rule_A1_2_RECV_CONCIL_001">
        <description>Divergencia entre pago e faturado.</description>
        <inputEntry id="InputEntry_A12_1_RECV_CONCIL_001"><text>valorPago != valorFaturado</text></inputEntry>
        <inputEntry id="InputEntry_A12_2_RECV_CONCIL_001"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_A12_1_RECV_CONCIL_001"><text>"Alertar"</text></outputEntry>
        <outputEntry id="OutputEntry_A12_2_RECV_CONCIL_001"><text>"Divergencia entre pago e faturado."</text></outputEntry>
        <outputEntry id="OutputEntry_A12_3_RECV_CONCIL_001"><text>"Investigar origem da divergencia."</text></outputEntry>
        <outputEntry id="OutputEntry_A12_4_RECV_CONCIL_001"><text>"VALOR"</text></outputEntry>
        <outputEntry id="OutputEntry_A12_5_RECV_CONCIL_001"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- REGRA F: Fallback - Requer revisao manual -->
      <rule id="Rule_Fallback_RECV_CONCIL_001">
        <description>Regra padrao - Requer avaliacao manual</description>
        <inputEntry id="InputEntry_F_1_RECV_CONCIL_001"><text>-</text></inputEntry>
        <inputEntry id="InputEntry_F_2_RECV_CONCIL_001"><text>-</text></inputEntry>
        <outputEntry id="OutputEntry_F_1_RECV_CONCIL_001"><text>"Revisar"</text></outputEntry>
        <outputEntry id="OutputEntry_F_2_RECV_CONCIL_001"><text>"Situacao requer analise manual por nao corresponder a nenhum criterio automatico."</text></outputEntry>
        <outputEntry id="OutputEntry_F_3_RECV_CONCIL_001"><text>"Encaminhar para auditoria administrativa para avaliacao caso a caso."</text></outputEntry>
        <outputEntry id="OutputEntry_F_4_RECV_CONCIL_001"><text>"NENHUM"</text></outputEntry>
        <outputEntry id="OutputEntry_F_5_RECV_CONCIL_001"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_RECV_CONCIL_001">
      <dmndi:DMNShape id="DMNShape_Decision_RECV_CONCIL_001" dmnElementRef="Decision_RECV_CONCIL_001">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
