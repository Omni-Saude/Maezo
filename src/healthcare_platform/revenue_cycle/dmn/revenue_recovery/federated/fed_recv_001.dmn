<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             id="collection-workflow-definitions"
             name="Collection Workflow Decision"
             namespace="http://camunda.org/schema/1.0/dmn"
             exporter="Camunda Modeler"
             exporterVersion="5.20.0">

  <decision id="collection-workflow" name="[SP-RC-010 | revenue_recovery/federated] Estratégia de Cobrança" camunda:historyTimeToLive="180">

    <decisionTable id="collection-table" hitPolicy="FIRST">

      <!-- ===== INPUT DEFINITIONS ===== -->
      <input id="input-debtor-type_collection-workflow" label="Tipo de Devedor" camunda:inputVariable="debtorType">
        <inputExpression id="input-expr-1_collection-workflow" typeRef="string">
          <text>debtorType</text>
        </inputExpression>
        <inputValues id="input-values-1_collection-workflow">
          <text>"INSURANCE","PATIENT","GOVERNMENT","CORPORATE","INTERNATIONAL"</text>
        </inputValues>
      </input>

      <input id="input-days-overdue_collection-workflow" label="Dias em Atraso" camunda:inputVariable="daysOverdue">
        <inputExpression id="input-expr-2_collection-workflow" typeRef="integer">
          <text>daysOverdue</text>
        </inputExpression>
      </input>

      <input id="input-outstanding-amount_collection-workflow" label="Valor em Aberto" camunda:inputVariable="outstandingAmount">
        <inputExpression id="input-expr-3_collection-workflow" typeRef="double">
          <text>outstandingAmount</text>
        </inputExpression>
      </input>

      <input id="input-previous-attempts_collection-workflow" label="Tentativas Anteriores" camunda:inputVariable="previousAttempts">
        <inputExpression id="input-expr-4_collection-workflow" typeRef="integer">
          <text>previousAttempts</text>
        </inputExpression>
      </input>

      <input id="input-payment-history_collection-workflow" label="Histórico de Pagamento" camunda:inputVariable="paymentHistory">
        <inputExpression id="input-expr-5_collection-workflow" typeRef="string">
          <text>paymentHistory</text>
        </inputExpression>
        <inputValues id="input-values-2_collection-workflow">
          <text>"EXCELLENT","GOOD","REGULAR","POOR","NO_HISTORY"</text>
        </inputValues>
      </input>

      <!-- ===== OUTPUT DEFINITIONS ===== -->
      <output id="output-collection-strategy_collection-workflow" label="Estratégia de Cobrança" name="collectionStrategy" typeRef="string">
        <outputValues id="output-values-1_collection-workflow">
          <text>"FRIENDLY_REMINDER","PHONE_CONTACT","EMAIL_CAMPAIGN","FORMAL_NOTICE","LEGAL_ACTION","NEGOTIATION","WRITE_OFF"</text>
        </outputValues>
      </output>

      <output id="output-communication-channel_collection-workflow" label="Canal de Comunicação" name="communicationChannel" typeRef="string">
        <outputValues id="output-values-2_collection-workflow">
          <text>"EMAIL","PHONE","SMS","WHATSAPP","REGISTERED_MAIL","IN_PERSON","LEGAL_LETTER"</text>
        </outputValues>
      </output>

      <output id="output-escalate-to-legal_collection-workflow" label="Escalar para Jurídico" name="escalateToLegal" typeRef="boolean" />

      <output id="output-discount-offer_collection-workflow" label="Oferecer Desconto (%)" name="discountOffer" typeRef="integer">
        <outputValues id="output-values-3_collection-workflow">
          <text>0,5,10,15,20,30</text>
        </outputValues>
      </output>

      <output id="output-next-action-days_collection-workflow" label="Próxima Ação (dias)" name="nextActionDays" typeRef="integer" />

      <!-- ===== DECISION RULES ===== -->

      <!-- RULE 1: Primeiro lembrete - atraso recente -->
      <rule id="rule-first-reminder_collection-workflow">
        <description>Primeiro contato amigável para atraso de 1-15 dias</description>
        <inputEntry id="rule1-input1_collection-workflow">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule1-input2_collection-workflow">
          <text>&gt; 0, &lt;= 15</text>
        </inputEntry>
        <inputEntry id="rule1-input3_collection-workflow">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule1-input4_collection-workflow">
          <text>0</text>
        </inputEntry>
        <inputEntry id="rule1-input5_collection-workflow">
          <text>"EXCELLENT","GOOD"</text>
        </inputEntry>
        <outputEntry id="rule1-output1_collection-workflow">
          <text>"FRIENDLY_REMINDER"</text>
        </outputEntry>
        <outputEntry id="rule1-output2_collection-workflow">
          <text>"EMAIL"</text>
        </outputEntry>
        <outputEntry id="rule1-output3_collection-workflow">
          <text>false</text>
        </outputEntry>
        <outputEntry id="rule1-output4_collection-workflow">
          <text>0</text>
        </outputEntry>
        <outputEntry id="rule1-output5_collection-workflow">
          <text>7</text>
        </outputEntry>
      </rule>

      <!-- RULE 2: Contato telefônico - atraso moderado -->
      <rule id="rule-phone-contact_collection-workflow">
        <description>Contato telefônico para atraso de 16-30 dias</description>
        <inputEntry id="rule2-input1_collection-workflow">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule2-input2_collection-workflow">
          <text>&gt; 15, &lt;= 30</text>
        </inputEntry>
        <inputEntry id="rule2-input3_collection-workflow">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule2-input4_collection-workflow">
          <text>&lt;= 2</text>
        </inputEntry>
        <inputEntry id="rule2-input5_collection-workflow">
          <text>"GOOD","REGULAR"</text>
        </inputEntry>
        <outputEntry id="rule2-output1_collection-workflow">
          <text>"PHONE_CONTACT"</text>
        </outputEntry>
        <outputEntry id="rule2-output2_collection-workflow">
          <text>"PHONE"</text>
        </outputEntry>
        <outputEntry id="rule2-output3_collection-workflow">
          <text>false</text>
        </outputEntry>
        <outputEntry id="rule2-output4_collection-workflow">
          <text>5</text>
        </outputEntry>
        <outputEntry id="rule2-output5_collection-workflow">
          <text>10</text>
        </outputEntry>
      </rule>

      <!-- RULE 3: Campanha intensiva - atraso significativo -->
      <rule id="rule-email-campaign_collection-workflow">
        <description>Campanha multicanal para atraso de 31-60 dias</description>
        <inputEntry id="rule3-input1_collection-workflow">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule3-input2_collection-workflow">
          <text>&gt; 30, &lt;= 60</text>
        </inputEntry>
        <inputEntry id="rule3-input3_collection-workflow">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule3-input4_collection-workflow">
          <text>&lt;= 4</text>
        </inputEntry>
        <inputEntry id="rule3-input5_collection-workflow">
          <text>-</text>
        </inputEntry>
        <outputEntry id="rule3-output1_collection-workflow">
          <text>"EMAIL_CAMPAIGN"</text>
        </outputEntry>
        <outputEntry id="rule3-output2_collection-workflow">
          <text>"EMAIL"</text>
        </outputEntry>
        <outputEntry id="rule3-output3_collection-workflow">
          <text>false</text>
        </outputEntry>
        <outputEntry id="rule3-output4_collection-workflow">
          <text>10</text>
        </outputEntry>
        <outputEntry id="rule3-output5_collection-workflow">
          <text>15</text>
        </outputEntry>
      </rule>

      <!-- RULE 4: Notificação formal - atraso grave -->
      <rule id="rule-formal-notice_collection-workflow">
        <description>Notificação formal para atraso de 61-90 dias</description>
        <inputEntry id="rule4-input1_collection-workflow">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule4-input2_collection-workflow">
          <text>&gt; 60, &lt;= 90</text>
        </inputEntry>
        <inputEntry id="rule4-input3_collection-workflow">
          <text>&gt; 1000</text>
        </inputEntry>
        <inputEntry id="rule4-input4_collection-workflow">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule4-input5_collection-workflow">
          <text>-</text>
        </inputEntry>
        <outputEntry id="rule4-output1_collection-workflow">
          <text>"FORMAL_NOTICE"</text>
        </outputEntry>
        <outputEntry id="rule4-output2_collection-workflow">
          <text>"REGISTERED_MAIL"</text>
        </outputEntry>
        <outputEntry id="rule4-output3_collection-workflow">
          <text>false</text>
        </outputEntry>
        <outputEntry id="rule4-output4_collection-workflow">
          <text>15</text>
        </outputEntry>
        <outputEntry id="rule4-output5_collection-workflow">
          <text>30</text>
        </outputEntry>
      </rule>

      <!-- RULE 5: Cobrança governamental - tratamento especial -->
      <rule id="rule-government-debtor_collection-workflow">
        <description>Governo tem processo específico de cobrança</description>
        <inputEntry id="rule5-input1_collection-workflow">
          <text>"GOVERNMENT"</text>
        </inputEntry>
        <inputEntry id="rule5-input2_collection-workflow">
          <text>&gt; 90</text>
        </inputEntry>
        <inputEntry id="rule5-input3_collection-workflow">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule5-input4_collection-workflow">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule5-input5_collection-workflow">
          <text>-</text>
        </inputEntry>
        <outputEntry id="rule5-output1_collection-workflow">
          <text>"FORMAL_NOTICE"</text>
        </outputEntry>
        <outputEntry id="rule5-output2_collection-workflow">
          <text>"REGISTERED_MAIL"</text>
        </outputEntry>
        <outputEntry id="rule5-output3_collection-workflow">
          <text>false</text>
        </outputEntry>
        <outputEntry id="rule5-output4_collection-workflow">
          <text>0</text>
        </outputEntry>
        <outputEntry id="rule5-output5_collection-workflow">
          <text>60</text>
        </outputEntry>
      </rule>

      <!-- RULE 6: Paciente particular - negociação com desconto -->
      <rule id="rule-patient-negotiation_collection-workflow">
        <description>Paciente particular com dificuldades - oferecer negociação</description>
        <inputEntry id="rule6-input1_collection-workflow">
          <text>"PATIENT"</text>
        </inputEntry>
        <inputEntry id="rule6-input2_collection-workflow">
          <text>&gt; 45, &lt;= 90</text>
        </inputEntry>
        <inputEntry id="rule6-input3_collection-workflow">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule6-input4_collection-workflow">
          <text>&gt;= 3</text>
        </inputEntry>
        <inputEntry id="rule6-input5_collection-workflow">
          <text>"POOR","NO_HISTORY"</text>
        </inputEntry>
        <outputEntry id="rule6-output1_collection-workflow">
          <text>"NEGOTIATION"</text>
        </outputEntry>
        <outputEntry id="rule6-output2_collection-workflow">
          <text>"PHONE"</text>
        </outputEntry>
        <outputEntry id="rule6-output3_collection-workflow">
          <text>false</text>
        </outputEntry>
        <outputEntry id="rule6-output4_collection-workflow">
          <text>20</text>
        </outputEntry>
        <outputEntry id="rule6-output5_collection-workflow">
          <text>15</text>
        </outputEntry>
      </rule>

      <!-- RULE 7: Alto valor com atraso crítico - ação legal -->
      <rule id="rule-legal-action_collection-workflow">
        <description>Valor elevado com atraso superior a 90 dias - ação judicial</description>
        <inputEntry id="rule7-input1_collection-workflow">
          <text>"INSURANCE","CORPORATE"</text>
        </inputEntry>
        <inputEntry id="rule7-input2_collection-workflow">
          <text>&gt; 90</text>
        </inputEntry>
        <inputEntry id="rule7-input3_collection-workflow">
          <text>&gt; 10000</text>
        </inputEntry>
        <inputEntry id="rule7-input4_collection-workflow">
          <text>&gt;= 5</text>
        </inputEntry>
        <inputEntry id="rule7-input5_collection-workflow">
          <text>-</text>
        </inputEntry>
        <outputEntry id="rule7-output1_collection-workflow">
          <text>"LEGAL_ACTION"</text>
        </outputEntry>
        <outputEntry id="rule7-output2_collection-workflow">
          <text>"LEGAL_LETTER"</text>
        </outputEntry>
        <outputEntry id="rule7-output3_collection-workflow">
          <text>true</text>
        </outputEntry>
        <outputEntry id="rule7-output4_collection-workflow">
          <text>0</text>
        </outputEntry>
        <outputEntry id="rule7-output5_collection-workflow">
          <text>0</text>
        </outputEntry>
      </rule>

      <!-- RULE 8: Baixo valor irrecuperável - write-off -->
      <rule id="rule-write-off_collection-workflow">
        <description>Valor baixo com múltiplas tentativas - considerar baixa</description>
        <inputEntry id="rule8-input1_collection-workflow">
          <text>"PATIENT"</text>
        </inputEntry>
        <inputEntry id="rule8-input2_collection-workflow">
          <text>&gt; 180</text>
        </inputEntry>
        <inputEntry id="rule8-input3_collection-workflow">
          <text>&lt; 500</text>
        </inputEntry>
        <inputEntry id="rule8-input4_collection-workflow">
          <text>&gt;= 6</text>
        </inputEntry>
        <inputEntry id="rule8-input5_collection-workflow">
          <text>"POOR","NO_HISTORY"</text>
        </inputEntry>
        <outputEntry id="rule8-output1_collection-workflow">
          <text>"WRITE_OFF"</text>
        </outputEntry>
        <outputEntry id="rule8-output2_collection-workflow">
          <text>"EMAIL"</text>
        </outputEntry>
        <outputEntry id="rule8-output3_collection-workflow">
          <text>false</text>
        </outputEntry>
        <outputEntry id="rule8-output4_collection-workflow">
          <text>0</text>
        </outputEntry>
        <outputEntry id="rule8-output5_collection-workflow">
          <text>0</text>
        </outputEntry>
      </rule>

      <!-- RULE 9: Convênio internacional - contato especial -->
      <rule id="rule-international_collection-workflow">
        <description>Devedor internacional requer abordagem diferenciada</description>
        <inputEntry id="rule9-input1_collection-workflow">
          <text>"INTERNATIONAL"</text>
        </inputEntry>
        <inputEntry id="rule9-input2_collection-workflow">
          <text>&gt; 30</text>
        </inputEntry>
        <inputEntry id="rule9-input3_collection-workflow">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule9-input4_collection-workflow">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule9-input5_collection-workflow">
          <text>-</text>
        </inputEntry>
        <outputEntry id="rule9-output1_collection-workflow">
          <text>"NEGOTIATION"</text>
        </outputEntry>
        <outputEntry id="rule9-output2_collection-workflow">
          <text>"EMAIL"</text>
        </outputEntry>
        <outputEntry id="rule9-output3_collection-workflow">
          <text>false</text>
        </outputEntry>
        <outputEntry id="rule9-output4_collection-workflow">
          <text>10</text>
        </outputEntry>
        <outputEntry id="rule9-output5_collection-workflow">
          <text>20</text>
        </outputEntry>
      </rule>

      <!-- RULE 10: Fallback - estratégia padrão -->
      <rule id="rule-default-strategy_collection-workflow">
        <description>Estratégia padrão para casos não mapeados</description>
        <inputEntry id="rule10-input1_collection-workflow">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule10-input2_collection-workflow">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule10-input3_collection-workflow">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule10-input4_collection-workflow">
          <text>-</text>
        </inputEntry>
        <inputEntry id="rule10-input5_collection-workflow">
          <text>-</text>
        </inputEntry>
        <outputEntry id="rule10-output1_collection-workflow">
          <text>"PHONE_CONTACT"</text>
        </outputEntry>
        <outputEntry id="rule10-output2_collection-workflow">
          <text>"PHONE"</text>
        </outputEntry>
        <outputEntry id="rule10-output3_collection-workflow">
          <text>false</text>
        </outputEntry>
        <outputEntry id="rule10-output4_collection-workflow">
          <text>5</text>
        </outputEntry>
        <outputEntry id="rule10-output5_collection-workflow">
          <text>14</text>
        </outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <!-- ===== DIAGRAM LAYOUT ===== -->
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_collection_collection-workflow">
      <dmndi:DMNShape id="DMNShape_collection_collection-workflow" dmnElementRef="collection-workflow">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
