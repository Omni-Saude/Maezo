<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="Definitions_escalation_adjudication"
             name="Escalation Adjudication"
             namespace="http://camunda.org/schema/1.0/dmn">

  <!-- DMN: Escalation Adjudication
       For: escalate_to_supervisor_worker
       Archetype: ADMIN_ADJUDICATION
       Purpose: Determine escalation level based on impact, count, and severity
  -->

  <decision id="Decision_escalation_adjudication" name="[SP-RC-010 | revenue_recovery/escalation] Escalation Adjudication" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_escalation_adjudication" hitPolicy="FIRST">

      <!-- === INPUTS === -->

      <input id="Input_1_escalation_adjudication" label="Impact Amount">
        <inputExpression id="InputExpr_1_escalation_adjudication" typeRef="number">
          <text>impactAmount</text>
        </inputExpression>
      </input>

      <input id="Input_2_escalation_adjudication" label="Glosa Count">
        <inputExpression id="InputExpr_2_escalation_adjudication" typeRef="number">
          <text>glosaCount</text>
        </inputExpression>
      </input>

      <input id="Input_3_escalation_adjudication" label="Has Total Glosa">
        <inputExpression id="InputExpr_3_escalation_adjudication" typeRef="boolean">
          <text>hasTotalGlosa</text>
        </inputExpression>
      </input>

      <!-- === OUTPUTS === -->

      <output id="Output_resultado_escalation_adjudication" label="Resultado" name="resultado" typeRef="string">
        <outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues>
      </output>

      <output id="Output_acao_escalation_adjudication" label="Acao" name="acao" typeRef="string"/>

      <output id="Output_risco_escalation_adjudication" label="Risco" name="risco" typeRef="string">
        <outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues>
      </output>

      <!-- === RULES === -->

      <!-- Rule 1: Glosa total - escalar para Diretoria -->
      <rule id="Rule_1_escalation_adjudication">
        <description>Escalar para Diretoria - glosa total</description>
        <inputEntry id="IE_1_1_escalation_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_1_2_escalation_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_1_3_escalation_adjudication"><text>true</text></inputEntry>
        <outputEntry id="OE_1_res_escalation_adjudication"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_1_acao_escalation_adjudication"><text>"Escalar para Diretoria - glosa total"</text></outputEntry>
        <outputEntry id="OE_1_risco_escalation_adjudication"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 2: Valor crítico >= 50k -->
      <rule id="Rule_2_escalation_adjudication">
        <description>Escalar para Diretoria - valor crítico</description>
        <inputEntry id="IE_2_1_escalation_adjudication"><text>&gt;= 50000</text></inputEntry>
        <inputEntry id="IE_2_2_escalation_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_2_3_escalation_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_2_res_escalation_adjudication"><text>"BLOQUEAR"</text></outputEntry>
        <outputEntry id="OE_2_acao_escalation_adjudication"><text>"Escalar para Diretoria - valor crítico"</text></outputEntry>
        <outputEntry id="OE_2_risco_escalation_adjudication"><text>"CRITICO"</text></outputEntry>
      </rule>

      <!-- Rule 3: Valor alto >= 10k -->
      <rule id="Rule_3_escalation_adjudication">
        <description>Escalar para Supervisão de Auditoria</description>
        <inputEntry id="IE_3_1_escalation_adjudication"><text>&gt;= 10000</text></inputEntry>
        <inputEntry id="IE_3_2_escalation_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_3_3_escalation_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_3_res_escalation_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_3_acao_escalation_adjudication"><text>"Escalar para Supervisão de Auditoria"</text></outputEntry>
        <outputEntry id="OE_3_risco_escalation_adjudication"><text>"ALTO"</text></outputEntry>
      </rule>

      <!-- Rule 4: Valor médio >= 5k -->
      <rule id="Rule_4_escalation_adjudication">
        <description>Escalar para Coordenação de Glosas</description>
        <inputEntry id="IE_4_1_escalation_adjudication"><text>&gt;= 5000</text></inputEntry>
        <inputEntry id="IE_4_2_escalation_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_4_3_escalation_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_4_res_escalation_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_4_acao_escalation_adjudication"><text>"Escalar para Coordenação de Glosas"</text></outputEntry>
        <outputEntry id="OE_4_risco_escalation_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 5: Volume alto > 10 glosas -->
      <rule id="Rule_5_escalation_adjudication">
        <description>Volume alto de glosas</description>
        <inputEntry id="IE_5_1_escalation_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_5_2_escalation_adjudication"><text>&gt; 10</text></inputEntry>
        <inputEntry id="IE_5_3_escalation_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_5_res_escalation_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_5_acao_escalation_adjudication"><text>"Volume alto de glosas"</text></outputEntry>
        <outputEntry id="OE_5_risco_escalation_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

      <!-- Rule 6: Baixo impacto - processo normal -->
      <rule id="Rule_6_escalation_adjudication">
        <description>Baixo impacto - processo normal</description>
        <inputEntry id="IE_6_1_escalation_adjudication"><text>&lt; 5000</text></inputEntry>
        <inputEntry id="IE_6_2_escalation_adjudication"><text>&lt;= 10</text></inputEntry>
        <inputEntry id="IE_6_3_escalation_adjudication"><text>false</text></inputEntry>
        <outputEntry id="OE_6_res_escalation_adjudication"><text>"PROSSEGUIR"</text></outputEntry>
        <outputEntry id="OE_6_acao_escalation_adjudication"><text>"Baixo impacto - processo normal"</text></outputEntry>
        <outputEntry id="OE_6_risco_escalation_adjudication"><text>"BAIXO"</text></outputEntry>
      </rule>

      <!-- Fallback -->
      <rule id="Rule_fallback_escalation_adjudication">
        <description>Caso não enquadrado — revisão obrigatória</description>
        <inputEntry id="IE_fb_1_escalation_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_2_escalation_adjudication"><text>-</text></inputEntry>
        <inputEntry id="IE_fb_3_escalation_adjudication"><text>-</text></inputEntry>
        <outputEntry id="OE_fb_res_escalation_adjudication"><text>"REVISAR"</text></outputEntry>
        <outputEntry id="OE_fb_acao_escalation_adjudication"><text>"Avaliar necessidade de escalação"</text></outputEntry>
        <outputEntry id="OE_fb_risco_escalation_adjudication"><text>"MEDIO"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_1_escalation_adjudication">
      <dmndi:DMNShape id="DMNShape_Decision_escalation_adjudication" dmnElementRef="Decision_escalation_adjudication">
        <dc:Bounds height="80" width="180" x="160" y="100"/>
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
