<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/" xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_underpayment_threshold" name="Underpayment Threshold" namespace="http://camunda.org/schema/1.0/dmn">
  <!-- Archetype: OPERATIONAL_ROUTING | Source: handle_underpayment_worker.py -->
  <decision id="Decision_underpayment_threshold" name="[SP-RC-008 | collection_payment] Underpayment Threshold" camunda:historyTimeToLive="180">
    <decisionTable id="DecisionTable_underpayment_threshold" hitPolicy="FIRST">
      <input id="Input_shortfall_pct_underpayment_threshold" label="Deficit %"><inputExpression id="IE_sp_underpayment_threshold" typeRef="double"><text>shortfall_percentage</text></inputExpression></input>
      <output id="Output_resultado_underpayment_threshold" label="Resultado" name="resultado" typeRef="string"><outputValues><text>"PROSSEGUIR","BLOQUEAR","REVISAR"</text></outputValues></output>
      <output id="Output_acao_underpayment_threshold" label="Acao" name="acao" typeRef="string"/>
      <output id="Output_risco_underpayment_threshold" label="Risco" name="risco" typeRef="string"><outputValues><text>"CRITICO","ALTO","MEDIO","BAIXO"</text></outputValues></output>
      <rule id="Rule_1_underpayment_threshold"><inputEntry id="U1_underpayment_threshold"><text>> 50</text></inputEntry><outputEntry id="L1_underpayment_threshold"><text>"BLOQUEAR"</text></outputEntry><outputEntry id="L1a_underpayment_threshold"><text>"Deficit superior a 50% - anomalia"</text></outputEntry><outputEntry id="L1b_underpayment_threshold"><text>"CRITICO"</text></outputEntry></rule>
      <rule id="Rule_2_underpayment_threshold"><inputEntry id="U2_underpayment_threshold"><text>(25..50]</text></inputEntry><outputEntry id="L2_underpayment_threshold"><text>"REVISAR"</text></outputEntry><outputEntry id="L2a_underpayment_threshold"><text>"Deficit significativo - verificar contrato"</text></outputEntry><outputEntry id="L2b_underpayment_threshold"><text>"ALTO"</text></outputEntry></rule>
      <rule id="Rule_3_underpayment_threshold"><inputEntry id="U3_underpayment_threshold"><text>(10..25]</text></inputEntry><outputEntry id="L3_underpayment_threshold"><text>"REVISAR"</text></outputEntry><outputEntry id="L3a_underpayment_threshold"><text>"Deficit moderado - cobrar diferenca"</text></outputEntry><outputEntry id="L3b_underpayment_threshold"><text>"MEDIO"</text></outputEntry></rule>
      <rule id="Rule_4_underpayment_threshold"><inputEntry id="U4_underpayment_threshold"><text>(2..10]</text></inputEntry><outputEntry id="L4_underpayment_threshold"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L4a_underpayment_threshold"><text>"Deficit menor - incluir na proxima cobranca"</text></outputEntry><outputEntry id="L4b_underpayment_threshold"><text>"BAIXO"</text></outputEntry></rule>
      <rule id="Rule_5_underpayment_threshold"><inputEntry id="U5_underpayment_threshold"><text>&lt;= 2</text></inputEntry><outputEntry id="L5_underpayment_threshold"><text>"PROSSEGUIR"</text></outputEntry><outputEntry id="L5a_underpayment_threshold"><text>"Diferenca marginal - ajuste contabil"</text></outputEntry><outputEntry id="L5b_underpayment_threshold"><text>"BAIXO"</text></outputEntry></rule>
    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_Decision_underpayment_threshold">
      <dmndi:DMNShape id="DMNShape_Decision_underpayment_threshold" dmnElementRef="Decision_underpayment_threshold">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
