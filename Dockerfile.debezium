FROM confluentinc/cp-kafka-connect:7.7.0 AS avro-source

FROM debezium/connect:2.6

# S3 Sink Connector (Confluent)
COPY config/debezium/plugins/kafka-connect-s3/ /kafka/connect/kafka-connect-s3/

# AvroConverter no classpath principal do worker (evita isolamento de classloader
# que impede carregamento de dependências transitivas do Guava)
USER root
COPY --from=avro-source /usr/share/java/kafka-serde-tools/kafka-connect-avro-converter-7.7.0.jar /kafka/libs/
COPY --from=avro-source /usr/share/java/kafka-serde-tools/kafka-avro-serializer-7.7.0.jar /kafka/libs/
COPY --from=avro-source /usr/share/java/kafka-serde-tools/kafka-connect-avro-data-7.7.0.jar /kafka/libs/
COPY --from=avro-source /usr/share/java/kafka-serde-tools/kafka-schema-registry-client-7.7.0.jar /kafka/libs/
COPY --from=avro-source /usr/share/java/kafka-serde-tools/kafka-schema-serializer-7.7.0.jar /kafka/libs/
COPY --from=avro-source /usr/share/java/kafka-serde-tools/kafka-schema-converter-7.7.0.jar /kafka/libs/
COPY --from=avro-source /usr/share/java/kafka-serde-tools/guava-32.0.1-jre.jar /kafka/libs/
COPY --from=avro-source /usr/share/java/kafka-serde-tools/failureaccess-1.0.1.jar /kafka/libs/
COPY --from=avro-source /usr/share/java/kafka-serde-tools/avro-1.11.3.jar /kafka/libs/
COPY --from=avro-source /usr/share/java/kafka-serde-tools/jackson-core-2.16.0.jar /kafka/libs/
COPY --from=avro-source /usr/share/java/kafka-serde-tools/jackson-databind-2.16.0.jar /kafka/libs/
COPY --from=avro-source /usr/share/java/kafka-serde-tools/jackson-annotations-2.16.0.jar /kafka/libs/
COPY --from=avro-source /usr/share/java/kafka-serde-tools/httpclient-4.5.13.jar /kafka/libs/
COPY --from=avro-source /usr/share/java/kafka-serde-tools/httpcore-4.4.15.jar /kafka/libs/
COPY --from=avro-source /usr/share/java/kafka-serde-tools/commons-codec-1.16.1.jar /kafka/libs/
COPY --from=avro-source /usr/share/java/kafka-serde-tools/commons-logging-1.2.jar /kafka/libs/
COPY --from=avro-source /usr/share/java/kafka-serde-tools/logredactor-1.0.12.jar /kafka/libs/
COPY --from=avro-source /usr/share/java/kafka-serde-tools/logredactor-metrics-1.0.12.jar /kafka/libs/
COPY --from=avro-source /usr/share/java/kafka-serde-tools/slf4j-api-1.7.36.jar /kafka/libs/

# Entrypoint que injeta AWS credentials dos Docker Secrets como variáveis de ambiente
RUN printf '#!/bin/bash\nset -e\n[ -f /run/secrets/aws_access_key_id ] && export AWS_ACCESS_KEY_ID="$(cat /run/secrets/aws_access_key_id)"\n[ -f /run/secrets/aws_secret_access_key ] && export AWS_SECRET_ACCESS_KEY="$(cat /run/secrets/aws_secret_access_key)"\nexec /docker-entrypoint.sh "$@"\n' > /debezium-entrypoint.sh \
  && chmod +x /debezium-entrypoint.sh
USER 1001

ENTRYPOINT ["/debezium-entrypoint.sh"]
CMD ["start"]
