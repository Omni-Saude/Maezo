# ── Procedure Validation ──

msgid "Invalid procedure code: {code}"
msgstr "Código de procedimento inválido: {code}"

msgid "Procedure code not found in TUSS table: {code}"
msgstr "Código de procedimento não encontrado na tabela TUSS: {code}"

msgid "Procedure code not found in CBHPM table: {code}"
msgstr "Código de procedimento não encontrado na tabela CBHPM: {code}"

msgid "Procedure {code} is not active in ANS Rol"
msgstr "Procedimento {code} não está ativo no Rol da ANS"

msgid "Procedure {code} is not covered for coverage type {coverage_type}"
msgstr "Procedimento {code} não é coberto para o tipo de cobertura {coverage_type}"

msgid "ANS validation service unavailable"
msgstr "Serviço de validação da ANS indisponível"

# ── Procedure Capture ──

msgid "Encounter not found: {encounter_id}"
msgstr "Atendimento não encontrado: {encounter_id}"

msgid "No procedures found for encounter {encounter_id}"
msgstr "Nenhum procedimento encontrado para o atendimento {encounter_id}"

msgid "ERP system unavailable for procedure capture"
msgstr "Sistema ERP indisponível para captura de procedimentos"

msgid "Failed to capture procedures from {erp_system}"
msgstr "Falha ao capturar procedimentos do {erp_system}"

msgid "Encounter {encounter_id} is not in a valid state for capture"
msgstr "Atendimento {encounter_id} não está em estado válido para captura"

# ── Procedure Enrichment ──

msgid "Missing diagnosis code (CID-10) for procedure {code}"
msgstr "Código de diagnóstico (CID-10) ausente para o procedimento {code}"

msgid "Performer not found for procedure {code}"
msgstr "Executante não encontrado para o procedimento {code}"

msgid "Invalid body site for procedure {code}"
msgstr "Local anatômico inválido para o procedimento {code}"

msgid "Failed to enrich procedure {code}: {reason}"
msgstr "Falha ao enriquecer procedimento {code}: {reason}"

# ── Authorization ──

msgid "Authorization required for procedure {code}"
msgstr "Autorização necessária para o procedimento {code}"

msgid "Authorization {auth_id} has expired"
msgstr "Autorização {auth_id} expirou"

msgid "Authorization {auth_id} was denied: {reason}"
msgstr "Autorização {auth_id} foi negada: {reason}"

msgid "Authorization not found for procedure {code}"
msgstr "Autorização não encontrada para o procedimento {code}"

msgid "Insurance API unavailable for authorization check"
msgstr "API da operadora indisponível para verificação de autorização"

msgid "Authorization {auth_id} does not cover procedure {code}"
msgstr "Autorização {auth_id} não cobre o procedimento {code}"

# ── Quantity Calculation ──

msgid "Invalid quantity for procedure {code}: {quantity}"
msgstr "Quantidade inválida para o procedimento {code}: {quantity}"

msgid "Quantity exceeds maximum allowed for procedure {code}: {max_qty}"
msgstr "Quantidade excede o máximo permitido para o procedimento {code}: {max_qty}"

msgid "Quantity must be positive for procedure {code}"
msgstr "Quantidade deve ser positiva para o procedimento {code}"

msgid "Duration-based quantity calculation failed for {code}"
msgstr "Cálculo de quantidade baseado em duração falhou para {code}"

# ── Price Assignment ──

msgid "Price not found for procedure {code} in contract {contract_id}"
msgstr "Preço não encontrado para o procedimento {code} no contrato {contract_id}"

msgid "Price table expired for procedure {code}"
msgstr "Tabela de preços expirada para o procedimento {code}"

msgid "No active price table found for tenant {tenant_id}"
msgstr "Nenhuma tabela de preços ativa encontrada para o hospital {tenant_id}"

msgid "Price calculation error for procedure {code}: {reason}"
msgstr "Erro no cálculo de preço para o procedimento {code}: {reason}"

# ── Compatibility Check ──

msgid "Incompatible procedures detected: {code1} and {code2}"
msgstr "Procedimentos incompatíveis detectados: {code1} e {code2}"

msgid "Procedure {code} cannot be performed with {other_code} on same date"
msgstr "Procedimento {code} não pode ser realizado com {other_code} na mesma data"

msgid "Procedure {code} exceeds frequency limit: {limit} per {period}"
msgstr "Procedimento {code} excede limite de frequência: {limit} por {period}"

msgid "Gender restriction violated for procedure {code}"
msgstr "Restrição de gênero violada para o procedimento {code}"

msgid "Age restriction violated for procedure {code}"
msgstr "Restrição de idade violada para o procedimento {code}"

# ── Persistence ──

msgid "Failed to persist production data: {reason}"
msgstr "Falha ao persistir dados de produção: {reason}"

msgid "FHIR store unavailable"
msgstr "Repositório FHIR indisponível"

msgid "Duplicate production entry detected for encounter {encounter_id}"
msgstr "Entrada de produção duplicada detectada para o atendimento {encounter_id}"

msgid "Production data validation failed: {errors}"
msgstr "Validação dos dados de produção falhou: {errors}"

# ── General ──

msgid "Tenant context required"
msgstr "Contexto do hospital é obrigatório"

msgid "Operation timed out after {seconds} seconds"
msgstr "Operação expirou após {seconds} segundos"

msgid "Service {service_name} is unavailable"
msgstr "Serviço {service_name} está indisponível"

msgid "Internal error in {worker_name}: {error}"
msgstr "Erro interno em {worker_name}: {error}"

msgid "Invalid input: {field} - {reason}"
msgstr "Entrada inválida: {field} - {reason}"

msgid "LGPD: PII data detected in variable {var_name}"
msgstr "LGPD: Dados pessoais detectados na variável {var_name}"
